{\n   247→          const t = entry.freeCount + fc2 + pivotPresses;\n   248→          if (t > bestTotal) break;\n   249→          const candidate = buildToggleResultMITM(entry.freeMask, mask2, half1Size, half2Size,\n   250→            freeVars, rows, pivotCol, rank, numButtons);\n   251→          if (lexSmaller(candidate, bestResult!)) {\n   252→            bestResult = candidate;\n   253→          }\n   254→        }\n   255→      }\n   256→    }\n   257→  }\n   258→\n   259→  return bestResult!;\n   260→}\n   261→\n   262→function buildToggleResult(\n   263→  freeMask: number, numFree: number, freeVars: number[],\n   264→  rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n   265→): number[] {\n   266→  const pressed: number[] = [];\n   267→\n   268→  for (let f = 0; f < numFree; f++) {\n   269→    if (freeMask & (1 << f)) {\n   270→      pressed.push(freeVars[f]);\n   271→    }\n   272→  }\n   273→\n   274→  for (let r = 0; r < rank; r++) {\n   275→    let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n   276→    for (let f = 0; f < numFree; f++) {\n   277→      if ((freeMask & (1 << f)) && (rows[r] >> BigInt(freeVars[f])) & 1n) {\n   278→        val ^= 1;\n   279→      }\n   280→    }\n   281→    if (val) {\n   282→      pressed.push(pivotCol[r]);\n   283→    }\n   284→  }\n   285→\n   286→  pressed.sort((a, b) => a - b);\n   287→  return pressed;\n   288→}\n   289→\n   290→function buildToggleResultMITM(\n   291→  mask1: number, mask2: number, half1Size: number, half2Size: number,\n   292→  freeVars: number[], rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n   293→): number[] {\n   294→  const combined = mask1 | (mask2 << half1Size);\n   295→  return buildToggleResult(combined, half1Size + half2Size, freeVars, rows, pivotCol, rank, numButtons);\n   296→}\n   297→\n   298→function lexSmaller(a: number[], b: number[]): boolean {\n   299→  if (a.length !== b.length) return a.length < b.length;\n   300→  for (let i = 0; i < a.length; i++) {\n   301→    if (a[i] !== b[i]) return a[i] < b[i];\n   302→  }\n   303→  return false;\n   304→}\n   305→\n   306→// ─── Counter Solver ──────────────────────────────────────────────────────────\n   307→\n   308→/**\n   309→ * Solve the counter puzzle using Gaussian elimination over GF(p).\n   310→ *\n   311→ * Build matrix where A[i][j] = 1 if button j affects counter i.\n   312→ * Solve A*x = target (mod p). Return result minimizing sum of presses,\n   313→ * lex-smallest on ties.\n   314→ */\n   315→export function solveCounter(\n   316→  lights: number[],\n   317→  buttons: number[][],\n   318→  modulus: number\n   319→): number[] | null {\n   320→  const numCounters = lights.length;\n   321→  const numButtons = buttons.length;\n   322→\n   323→  // Build augmented matrix [A | target]\n   324→  const matrix: number[][] = [];\n   325→  for (let i = 0; i < numCounters; i++) {\n   326→    const row = new Array(numButtons + 1).fill(0);\n   327→    for (let j = 0; j < numButtons; j++) {\n   328→      if (buttons[j].includes(i)) {\n   329→        row[j] = 1;\n   330→      }\n   331→    }\n   332→    row[numButtons] = lights[i];\n   333→    matrix.push(row);\n   334→  }\n   335→\n   336→  // Gaussian elimination over GF(p) → reduced row echelon form\n   337→  const pivotCol: number[] = new Array(numCounters).fill(-1);\n   338→  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n   339→  let rank = 0;\n   340→\n   341→  for (let col = 0; col < numButtons; col++) {\n   342→    let found = -1;\n   343→    for (let row = rank; row < numCounters; row++) {\n   344→      if (matrix[row][col] !== 0) {\n   345→        found = row;\n   346→        break;\n   347→      }\n   348→    }\n   349→    if (found === -1) continue;\n   350→\n   351→    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n   352→    pivotCol[rank] = col;\n   353→    pivotRowForCol[col] = rank;\n   354→\n   355→    const inv = modInverse(matrix[rank][col], modulus);\n   356→    for (let c = 0; c < numButtons + 1; c++) {\n   357→      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n   358→    }\n   359→\n   360→    for (let row = 0; row < numCounters; row++) {\n   361→      if (row !== rank && matrix[row][col] !== 0) {\n   362→        const factor = matrix[row][col];\n   363→        for (let c = 0; c < numButtons + 1; c++) {\n   364→          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n   365→        }\n   366→      }\n   367→    }\n   368→    rank++;\n   369→  }\n   370→\n   371→  // Check consistency\n   372→  for (let row = rank; row < numCounters; row++) {\n   373→    if (matrix[row][numButtons] !== 0) {\n   374→      return null;\n   375→    }\n   376→  }\n   377→\n   378→  // Identify free variables\n   379→  const freeVars: number[] = [];\n   380→  for (let col = 0; col < numButtons; col++) {\n   381→    if (pivotRowForCol[col] === -1) {\n   382→      freeVars.push(col);\n   383→    }\n   384→  }\n   385→\n   386→  const numFree = freeVars.length;\n   387→\n   388→  if (numFree === 0) {\n   389→    const result = new Array(numButtons).fill(0);\n   390→    for (let r = 0; r < rank; r++) {\n   391→      result[pivotCol[r]] = matrix[r][numButtons];\n   392→    }\n   393→    return result;\n   394→  }\n   395→\n   396→  // Extract free variable effects and RHS\n   397→  // freeEffect[r][f] = coefficient of free variable f in pivot row r\n   398→  const freeEffect: number[][] = [];\n   399→  for (let r = 0; r < rank; r++) {\n   400→    const effects: number[] = [];\n   401→    for (let f = 0; f < numFree; f++) {\n   402→      effects.push(matrix[r][freeVars[f]]);\n   403→    }\n   404→    freeEffect.push(effects);\n   405→  }\n   406→\n   407→  const rhsVals: number[] = [];\n   408→  for (let r = 0; r < rank; r++) {\n   409→    rhsVals.push(matrix[r][numButtons]);\n   410→  }\n   411→\n   412→  // Strategy selection based on problem size\n   413→  const bruteForceSize = Math.pow(modulus, numFree);\n   414→  const dpSize = Math.pow(modulus, rank);\n   415→\n   416→  if (bruteForceSize <= 5_000_000) {\n   417→    // Direct enumeration over free variables\n   418→    return counterBruteForce(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n   419→  } else if (dpSize <= 2_000_000) {\n   420→    // DP over contribution vectors\n   421→    return counterDP(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n   422→  } else {\n   423→    // MITM approach\n   424→    return counterMITM(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n   425→  }\n   426→}\n   427→\n   428→function counterBruteForce(\n   429→  numButtons: number, numFree: number, freeVars: number[],\n   430→  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n   431→  rank: number, modulus: number\n   432→): number[] {\n   433→  let bestResult: number[] | null = null;\n   434→  let bestSum = Infinity;\n   435→\n   436→  const freeVals = new Array(numFree).fill(0);\n   437→\n   438→  while (true) {\n   439→    let totalSum = 0;\n   440→    const result = new Array(numButtons).fill(0);\n   441→\n   442→    for (let f = 0; f < numFree; f++) {\n   443→      result[freeVars[f]] = freeVals[f];\n   444→      totalSum += freeVals[f];\n   445→    }\n   446→\n   447→    if (totalSum <= bestSum) {\n   448→      for (let r = 0; r < rank; r++) {\n   449→        let val = rhsVals[r];\n   450→        for (let f = 0; f < numFree; f++) {\n   451→          val = ((val - freeEffect[r][f] * freeVals[f]) % modulus + modulus * modulus) % modulus;\n   452→        }\n   453→        result[pivotCol[r]] = val;\n   454→        totalSum += val;\n   455→      }\n   456→\n   457→      if (totalSum < bestSum || (totalSum === bestSum && lexSmallerArr(result, bestResult!))) {\n   458→        bestSum = totalSum;\n   459→        bestResult = [...result];\n   460→      }\n   461→    }\n   462→\n   463→    // Increment counter (rightmost first = lex order)\n   464→    let carry = true;\n   465→    for (let f = numFree - 1; f >= 0 && carry; f--) {\n   466→      freeVals[f]++;\n   467→      if (freeVals[f] >= modulus) {\n   468→        freeVals[f] = 0;\n   469→      } else {\n   470→        carry = false;\n   471→      }\n   472→    }\n   473→    if (carry) break;\n   474→  }\n   475→\n   476→  return bestResult!;\n   477→}\n   478→\n   479→/**\n   480→ * DP approach for when rank is small.\n   481→ *\n   482→ * State: contribution vector c[0..rank-1] where c[r] = sum(freeEffect[r][f] * free[f]) mod p.\n   483→ * For each state, track the minimum sum of free variable values and the lex-smallest assignment.\n   484→ *\n   485→ * Process free variables one by one. For each, try all p values and update states.\n   486→ */\n   487→function counterDP(\n   488→  numButtons: number, numFree: number, freeVars: number[],\n   489→  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n   490→  rank: number, modulus: number\n   491→): number[] {\n   492→  // Encode contribution vector as a single integer (mixed-radix number)\n   493→  function encodeContrib(contrib: number[]): number {\n   494→    let key = 0;\n   495→    for (let r = 0; r < rank; r++) {\n   496→      key = key * modulus + contrib[r];\n   497→    }\n   498→    return key;\n   499→  }\n   500→\n   501→  // For each state, store {sum, vals (free variable assignments)}\n   502→  // Process free variables one at a time.\n   503→  // Initial state: contribution = [0,0,...,0], sum = 0, vals = []\n   504→\n   505→  interface DPEntry { sum: number; vals: number[]; }\n   506→\n   507→  let current = new Map<number, DPEntry>();\n   508→  current.set(0, { sum: 0, vals: [] });\n   509→\n   510→  for (let f = 0; f < numFree; f++) {\n   511→    const next = new Map<number, DPEntry>();\n   512→\n   513→    for (const [stateKey, entry] of current) {\n   514→      // Decode state to get contribution vector\n   515→      const contrib = new Array(rank);\n   516→      let tmp = stateKey;\n   517→      for (let r = rank - 1; r >= 0; r--) {\n   518→        contrib[r] = tmp % modulus;\n   519→        tmp = Math.floor(tmp / modulus);\n   520→      }\n   521→\n   522→      for (let v = 0; v < modulus; v++) {\n   523→        // Update contribution vector\n   524→        const newContrib = new Array(rank);\n   525→        for (let r = 0; r < rank; r++) {\n   526→          newContrib[r] = (contrib[r] + freeEffect[r][f] * v) % modulus;\n   527→        }\n   528→\n   529→        const newKey = encodeContrib(newContrib);\n   530→        const newSum = entry.sum + v;\n   531→        const newVals = [...entry.vals, v];\n   532→\n   533→        const existing = next.get(newKey);\n   534→        if (!existing || newSum < existing.sum ||\n   535→            (newSum === existing.sum && lexSmallerRaw(newVals, existing.vals))) {\n   536→          next.set(newKey, { sum: newSum, vals: newVals });\n   537→        }\n   538→      }\n   539→    }\n   540→\n   541→    current = next;\n   542→  }\n   543→\n   544→  // Find the best overall solution\n   545→  let bestResult: number[] | null = null;\n   546→  let bestSum = Infinity;\n   547→\n   548→  for (const [stateKey, entry] of current) {\n   549→    // Decode contribution vector\n   550→    const contrib = new Array(rank);\n   551→    let tmp = stateKey;\n   552→    for (let r = rank - 1; r >= 0; r--) {\n   553→      contrib[r] = tmp % modulus;\n   554→      tmp = Math.floor(tmp / modulus);\n   555→    }\n   556→\n   557→    // Compute pivot values and total sum\n   558→    const result = new Array(numButtons).fill(0);\n   559→    let totalSum = entry.sum;\n   560→\n   561→    for (let f = 0; f < numFree; f++) {\n   562→      result[freeVars[f]] = entry.vals[f];\n   563→    }\n   564→\n   565→    for (let r = 0; r < rank; r++) {\n   566→      const pivotVal = (rhsVals[r] - contrib[r] + modulus * modulus) % modulus;\n   567→      result[pivotCol[r]] = pivotVal;\n   568→      totalSum += pivotVal;\n   569→    }\n   570→\n   571→    if (totalSum < bestSum || (totalSum === bestSum && lexSmallerArr(result, bestResult!))) {\n   572→      bestSum = totalSum;\n   573→      bestResult = [...result];\n   574→    }\n   575→  }\n   576→\n   577→  return bestResult!;\n   578→}\n   579→\n   580→/**\n   581→ * MITM approach for counter puzzle.\n   582→ *\n   583→ * Split free variables into two halves. Build table for first half\n   584→ * mapping contribution vector to (min sum, best assignment).\n   585→ * Then iterate over second half and look up optimal first half.\n   586→ */\n   587→function counterMITM(\n   588→  numButtons: number, numFree: number, freeVars: number[],\n   589→  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n   590→  rank: number, modulus: number\n   591→): number[] {\n   592→  const half1Size = Math.floor(numFree / 2);\n   593→  const half2Size = numFree - half1Size;\n   594→\n   595→  // Use DP to build the first half table\n   596→  // State: contribution vector encoded as number\n   597→  function encodeContrib(contrib: number[]): number {\n   598→    let key = 0;\n   599→    for (let r = 0; r < rank; r++) {\n   600→      key = key * modulus + contrib[r];\n   601→    }\n   602→    return key;\n   603→  }\n   604→\n   605→  interface HalfEntry { sum: number; vals: number[]; }\n   606→\n   607→  // Build first half table using DP\n   608→  let half1States = new Map<number, HalfEntry>();\n   609→  half1States.set(0, { sum: 0, vals: [] });\n   610→\n   611→  for (let f = 0; f < half1Size; f++) {\n   612→    const next = new Map<number, HalfEntry>();\n   613→\n   614→    for (const [stateKey, entry] of half1States) {\n   615→      const contrib = new Array(rank);\n   616→      let tmp = stateKey;\n   617→      for (let r = rank - 1; r >= 0; r--) {\n   618→        contrib[r] = tmp % modulus;\n   619→        tmp = Math.floor(tmp / modulus);\n   620→      }\n   621→\n   622→      for (let v = 0; v < modulus; v++) {\n   623→        const newContrib = new Array(rank);\n   624→        for (let r = 0; r < rank; r++) {\n   625→          newContrib[r] = (contrib[r] + freeEffect[r][f] * v) % modulus;\n   626→        }\n   627→\n   628→        const newKey = encodeContrib(newContrib);\n   629→        const newSum = entry.sum + v;\n   630→        const newVals = [...entry.vals, v];\n   631→\n   632→        const existing = next.get(newKey);\n   633→        if (!existing || newSum < existing.sum ||\n   634→            (newSum === existing.sum && lexSmallerRaw(newVals, existing.vals))) {\n   635→          next.set(newKey, { sum: newSum, vals: newVals });\n   636→        }\n   637→      }\n   638→    }\n   639→\n   640→    half1States = next;\n   641→  }\n   642→\n   643→  // Build second half using DP, then combine with first half\n   644→  let half2States = new Map<number, HalfEntry>();\n   645→  half2States.set(0, { sum: 0, vals: [] });\n   646→\n   647→  for (let f = 0; f < half2Size; f++) {\n   648→    const next = new Map<number, HalfEntry>();\n   649→\n   650→    for (const [stateKey, entry] of half2States) {\n   651→      const contrib = new Array(rank);\n   652→      let tmp = stateKey;\n   653→      for (let r = rank - 1; r >= 0; r--) {\n   654→        contrib[r] = tmp % modulus;\n   655→        tmp = Math.floor(tmp / modulus);\n   656→      }\n   657→\n   658→      for (let v = 0; v < modulus; v++) {\n   659→        const newContrib = new Array(rank);\n   660→        for (let r = 0; r < rank; r++) {\n   661→          newContrib[r] = (contrib[r] + freeEffect[r][half1Size + f] * v) % modulus;\n   662→        }\n   663→\n   664→        const newKey = encodeContrib(newContrib);\n   665→        const newSum = entry.sum + v;\n   666→        const newVals = [...entry.vals, v];\n   667→\n   668→        const existing = next.get(newKey);\n   669→        if (!existing || newSum < existing.sum ||\n   670→            (newSum === existing.sum && lexSmallerRaw(newVals, existing.vals))) {\n   671→          next.set(newKey, { sum: newSum, vals: newVals });\n   672→        }\n   673→      }\n   674→    }\n   675→\n   676→    half2States = next;\n   677→  }\n   678→\n   679→  // Combine: for each half2 state, find the best half1 state\n   680→  let bestResult: number[] | null = null;\n   681→  let bestSum = Infinity;\n   682→\n   683→  for (const [state2Key, entry2] of half2States) {\n   684→    const contrib2 = new Array(rank);\n   685→    let tmp2 = state2Key;\n   686→    for (let r = rank - 1; r >= 0; r--) {\n   687→      contrib2[r] = tmp2 % modulus;\n   688→      tmp2 = Math.floor(tmp2 / modulus);\n   689→    }\n   690→\n   691→    // We need contrib1 such that for each pivot row r:\n   692→    // pivotVal[r] = (rhsVals[r] - contrib1[r] - contrib2[r]) mod p\n   693→    // We want to minimize entry1.sum + entry2.sum + sum(pivotVals)\n   694→\n   695→    // We need to iterate over all half1 states and compute the total.\n   696→    // If the half1 table is small enough, just iterate.\n   697→    // Otherwise, for each needed contribution vector, look it up directly.\n   698→\n   699→    // For an exact match (all pivots = 0), we need contrib1[r] = (rhsVals[r] - contrib2[r]) mod p\n   700→    const neededContrib = new Array(rank);\n   701→    for (let r = 0; r < rank; r++) {\n   702→      neededContrib[r] = (rhsVals[r] - contrib2[r] + modulus * modulus) % modulus;\n   703→    }\n   704→    const neededKey = encodeContrib(neededContrib);\n   705→    const exactMatch = half1States.get(neededKey);\n   706→    if (exactMatch) {\n   707→      const totalSum = exactMatch.sum + entry2.sum; // pivot sum = 0\n   708→      if (totalSum < bestSum) {\n   709→        bestSum = totalSum;\n   710→        bestResult = buildCounterResultFromHalves(\n   711→          exactMatch.vals, entry2.vals, half1Size, half2Size,\n   712→          freeVars, freeEffect, rhsVals, pivotCol, rank, numButtons, modulus\n   713→        );\n   714→      } else if (totalSum === bestSum) {\n   715→        const candidate = buildCounterResultFromHalves(\n   716→          exactMatch.vals, entry2.vals, half1Size, half2Size,\n   717→          freeVars, freeEffect, rhsVals, pivotCol, rank, numButtons, modulus\n   718→        );\n   719→        if (lexSmallerArr(candidate, bestResult!)) {\n   720→          bestResult = candidate;\n   721→        }\n   722→      }\n   723→    }\n   724→\n   725→    // Also iterate all half1 states if the table is manageable\n   726→    if (half1States.size <= 500_000) {\n   727→      for (const [state1Key, entry1] of half1States) {\n   728→        const contrib1 = new Array(rank);\n   729→        let tmp1 = state1Key;\n   730→        for (let r = rank - 1; r >= 0; r--) {\n   731→          contrib1[r] = tmp1 % modulus;\n   732→          tmp1 = Math.floor(tmp1 / modulus);\n   733→        }\n   734→\n   735→        let pivotSum = 0;\n   736→        for (let r = 0; r < rank; r++) {\n   737→          pivotSum += (rhsVals[r] - contrib1[r] - contrib2[r] + modulus * modulus * 2) % modulus;\n   738→        }\n   739→\n   740→        const totalSum = entry1.sum + entry2.sum + pivotSum;\n   741→        if (totalSum < bestSum) {\n   742→          bestSum = totalSum;\n   743→          bestResult = buildCounterResultFromHalves(\n   744→            entry1.vals, entry2.vals, half1Size, half2Size,\n   745→            freeVars, freeEffect, rhsVals, pivotCol, rank, numButtons, modulus\n   746→          );\n   747→        } else if (totalSum === bestSum) {\n   748→          const candidate = buildCounterResultFromHalves(\n   749→            entry1.vals, entry2.vals, half1Size, half2Size,\n   750→            freeVars, freeEffect, rhsVals, pivotCol, rank, numButtons, modulus\n   751→          );\n   752→          if (lexSmallerArr(candidate, bestResult!)) {\n   753→            bestResult = candidate;\n   754→          }\n   755→        }\n   756→      }\n   757→    }\n   758→  }\n   759→\n   760→  return bestResult!;\n   761→}\n   762→\n   763→function buildCounterResultFromHalves(\n   764→  vals1: number[], vals2: number[], half1Size: number, half2Size: number,\n   765→  freeVars: number[], freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n   766→  rank: number, numButtons: number, modulus: number\n   767→): number[] {\n   768→  const result = new Array(numButtons).fill(0);\n   769→  const allFreeVals = [...vals1, ...vals2];\n   770→\n   771→  for (let f = 0; f < allFreeVals.length; f++) {\n   772→    result[freeVars[f]] = allFreeVals[f];\n   773→  }\n   774→\n   775→  for (let r = 0; r < rank; r++) {\n   776→    let val = rhsVals[r];\n   777→    for (let f = 0; f < allFreeVals.length; f++) {\n   778→      val = ((val - freeEffect[r][f] * allFreeVals[f]) % modulus + modulus * modulus) % modulus;\n   779→    }\n   780→    result[pivotCol[r]] = val;\n   781→  }\n   782→\n   783→  return result;\n   784→}\n   785→\n   786→function lexSmallerArr(a: number[], b: number[]): boolean {\n   787→  for (let i = 0; i < a.length; i++) {\n   788→    if (a[i] !== b[i]) return a[i] < b[i];\n   789→  }\n   790→  return false;\n   791→}\n   792→\n   793→function lexSmallerRaw(a: number[], b: number[]): boolean {\n   794→  for (let i = 0; i < a.length; i++) {\n   795→    if (a[i] !== b[i]) return a[i] < b[i];\n   796→  }\n   797→  return false;\n   798→}\n   799→\n   800→function modInverse(a: number, m: number): number {\n   801→  let [old_r, r] = [a % m, m];\n   802→  let [old_s, s] = [1, 0];\n   803→\n   804→  while (r !== 0) {\n   805→    const quotient = Math.floor(old_r / r);\n   806→    [old_r, r] = [r, old_r - quotient * r];\n   807→    [old_s, s] = [s, old_s - quotient * s];\n   808→  }\n   809→\n   810→  return ((old_s % m) + m) % m;\n   811→}\n   812→"}]},"parent_tool_use_id":null,"session_id":"b6d44172-140e-44bc-82be-d7c119bf96ba","uuid":"a79ef18f-5b16-4d75-a6ed-5ef8b53fc88a","tool_use_result":{"type":"update","filePath":"/workspace/src/index.ts","content":"/**\n * Factory Reset - Toggle and Counter puzzle solvers\n *\n * Both problems reduce to solving systems of linear equations over finite fields.\n * Toggle: GF(2), Counter: GF(p) where p is prime.\n */\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── Toggle Solver ───────────────────────────────────────────────────────────\n\n/**\n * Solve the toggle puzzle using Gaussian elimination over GF(2).\n *\n * We build a matrix where row i = light i, column j = button j.\n * A[i][j] = 1 if button j toggles light i. We solve A*x = target (mod 2).\n * Return the minimum set of button presses, lex-smallest on ties.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | target] over GF(2) using bigint bitmasks\n  const rows: bigint[] = new Array(numLights);\n  for (let i = 0; i < numLights; i++) {\n    let row = 0n;\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    rows[i] = row;\n  }\n\n  // Gaussian elimination over GF(2) → reduced row echelon form\n  const pivotCol: number[] = new Array(numLights).fill(-1);\n  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let found = -1;\n    for (let row = rank; row < numLights; row++) {\n      if ((rows[row] >> BigInt(col)) & 1n) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n    pivotCol[rank] = col;\n    pivotRowForCol[col] = rank;\n\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && (rows[row] >> BigInt(col)) & 1n) {\n        rows[row] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numLights; row++) {\n    if ((rows[row] >> BigInt(numButtons)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRowForCol[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(numButtons)) & 1n) {\n        result.push(pivotCol[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Precompute: for each pivot row, which free vars affect it (as bitmask over freeVars index)\n  const pivotFreeEffect: bigint[] = new Array(rank);\n  for (let r = 0; r < rank; r++) {\n    let effect = 0n;\n    for (let f = 0; f < freeVars.length; f++) {\n      if ((rows[r] >> BigInt(freeVars[f])) & 1n) {\n        effect |= 1n << BigInt(f);\n      }\n    }\n    pivotFreeEffect[r] = effect;\n  }\n\n  // Compute \"signature\" of a free-var assignment: bitmask of which pivot rows get flipped\n  // The signature determines the pivot variable values (combined with basePivotRHS).\n  // Number of distinct signatures ≤ 2^rank.\n\n  let basePivotRHS = 0n;\n  for (let r = 0; r < rank; r++) {\n    if ((rows[r] >> BigInt(numButtons)) & 1n) {\n      basePivotRHS |= 1n << BigInt(r);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each free-var mask, compute the signature (which pivot rows get flipped)\n  function getSignature(freeMask: number | bigint, startFree: number, countFree: number): bigint {\n    let sig = 0n;\n    for (let r = 0; r < rank; r++) {\n      // Count parity of free vars in this row's effect that are set\n      // (pivotFreeEffect[r] >> startFree) & freeMask, then popcount parity\n      const relevantBits = (pivotFreeEffect[r] >> BigInt(startFree)) & ((1n << BigInt(countFree)) - 1n);\n      const masked = relevantBits & BigInt(freeMask);\n      // Parity of popcount\n      let parity = 0n;\n      let tmp = masked;\n      while (tmp) {\n        parity ^= 1n;\n        tmp &= tmp - 1n;\n      }\n      if (parity) {\n        sig |= 1n << BigInt(r);\n      }\n    }\n    return sig;\n  }\n\n  function bigPopcount(x: bigint): number {\n    let count = 0;\n    while (x) { x &= x - 1n; count++; }\n    return count;\n  }\n\n  function bitcount(x: number): number {\n    let count = 0;\n    while (x) { x &= x - 1; count++; }\n    return count;\n  }\n\n  if (numFree <= 25) {\n    // Direct enumeration\n    let bestResult: number[] | null = null;\n    let bestCount = Infinity;\n\n    for (let mask = 0; mask < (1 << numFree); mask++) {\n      const freeCount = bitcount(mask);\n      const sig = getSignature(mask, 0, numFree);\n      const pivotPresses = bigPopcount(basePivotRHS ^ sig);\n      const total = freeCount + pivotPresses;\n\n      if (total < bestCount || (total === bestCount && bestResult !== null)) {\n        if (total < bestCount) {\n          bestCount = total;\n          bestResult = buildToggleResult(mask, numFree, freeVars, rows, pivotCol, rank, numButtons);\n        } else {\n          const candidate = buildToggleResult(mask, numFree, freeVars, rows, pivotCol, rank, numButtons);\n          if (lexSmaller(candidate, bestResult!)) {\n            bestResult = candidate;\n          }\n        }\n      }\n    }\n\n    return bestResult!;\n  }\n\n  // MITM for numFree > 25. Since rank = numButtons - numFree < 15,\n  // distinct signatures ≤ 2^15 = 32768.\n  const half1Size = Math.floor(numFree / 2);\n  const half2Size = numFree - half1Size;\n\n  // Build table for first half: signature → best (freeCount, freeMask)\n  // For each signature, keep ALL entries grouped by freeCount,\n  // but we only need the lex-smallest mask per freeCount per signature.\n  interface HalfEntry { freeCount: number; freeMask: number; }\n  const half1Table = new Map<bigint, HalfEntry[]>();\n\n  for (let mask = 0; mask < (1 << half1Size); mask++) {\n    const sig = getSignature(mask, 0, half1Size);\n    const fc = bitcount(mask);\n    const entries = half1Table.get(sig);\n    if (entries) {\n      entries.push({ freeCount: fc, freeMask: mask });\n    } else {\n      half1Table.set(sig, [{ freeCount: fc, freeMask: mask }]);\n    }\n  }\n\n  // For each signature, sort entries by freeCount, then keep only the lex-best mask per freeCount\n  for (const [sig, entries] of half1Table) {\n    entries.sort((a, b) => a.freeCount - b.freeCount || a.freeMask - b.freeMask);\n    // Deduplicate: keep only first entry per freeCount (it's the smallest mask)\n    const deduped: HalfEntry[] = [];\n    let lastFc = -1;\n    for (const e of entries) {\n      if (e.freeCount !== lastFc) {\n        deduped.push(e);\n        lastFc = e.freeCount;\n      }\n    }\n    half1Table.set(sig, deduped);\n  }\n\n  let bestTotal = Infinity;\n  let bestResult: number[] | null = null;\n\n  for (let mask2 = 0; mask2 < (1 << half2Size); mask2++) {\n    const sig2 = getSignature(mask2, half1Size, half2Size);\n    const fc2 = bitcount(mask2);\n\n    if (fc2 > bestTotal) continue; // can't improve\n\n    // For this half2, we need half1 with sig1 such that total is minimized.\n    // total = fc1 + fc2 + popcount(basePivotRHS ^ sig1 ^ sig2)\n    // = fc2 + fc1 + popcount(needed ^ sig1) where needed = basePivotRHS ^ sig2\n\n    const needed = basePivotRHS ^ sig2;\n\n    for (const [sig1, entries] of half1Table) {\n      const pivotPresses = bigPopcount(needed ^ sig1);\n      const bestEntry = entries[0]; // lowest freeCount\n      const total = bestEntry.freeCount + fc2 + pivotPresses;\n\n      if (total > bestTotal) continue;\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        bestResult = buildToggleResultMITM(bestEntry.freeMask, mask2, half1Size, half2Size,\n          freeVars, rows, pivotCol, rank, numButtons);\n      } else {\n        // Check all entries with same total\n        for (const entry of entries) {\n          const t = entry.freeCount + fc2 + pivotPresses;\n          if (t > bestTotal) break;\n          const candidate = buildToggleResultMITM(entry.freeMask, mask2, half1Size, half2Size,\n            freeVars, rows, pivotCol, rank, numButtons);\n          if (lexSmaller(candidate, bestResult!)) {\n            bestResult = candidate;\n          }\n        }\n      }\n    }\n  }\n\n  return bestResult!;\n}\n\nfunction buildToggleResult(\n  freeMask: number, numFree: number, freeVars: number[],\n  rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n): number[] {\n  const pressed: number[] = [];\n\n  for (let f = 0; f < numFree; f++) {\n    if (freeMask & (1 << f)) {\n      pressed.push(freeVars[f]);\n    }\n  }\n\n  for (let r = 0; r < rank; r++) {\n    let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n    for (let f = 0; f < numFree; f++) {\n      if ((freeMask & (1 << f)) && (rows[r] >> BigInt(freeVars[f])) & 1n) {\n        val ^= 1;\n      }\n    }\n    if (val) {\n      pressed.push(pivotCol[r]);\n    }\n  }\n\n  pressed.sort((a, b) => a - b);\n  return pressed;\n}\n\nfunction buildToggleResultMITM(\n  mask1: number, mask2: number, half1Size: number, half2Size: number,\n  freeVars: number[], rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n): number[] {\n  const combined = mask1 | (mask2 << half1Size);\n  return buildToggleResult(combined, half1Size + half2Size, freeVars, rows, pivotCol, rank, numButtons);\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  if (a.length !== b.length) return a.length < b.length;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i];\n  }\n  return false;\n}\n\n// ─── Counter Solver ──────────────────────────────────────────────────────────\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n *\n * Build matrix where A[i][j] = 1 if button j affects counter i.\n * Solve A*x = target (mod p). Return result minimizing sum of presses,\n * lex-smallest on ties.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | target]\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = lights[i];\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p) → reduced row echelon form\n  const pivotCol: number[] = new Array(numCounters).fill(-1);\n  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let found = -1;\n    for (let row = rank; row < numCounters; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol[rank] = col;\n    pivotRowForCol[col] = rank;\n\n    const inv = modInverse(matrix[rank][col], modulus);\n    for (let c = 0; c < numButtons + 1; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n    }\n\n    for (let row = 0; row < numCounters; row++) {\n      if (row !== rank && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let c = 0; c < numButtons + 1; c++) {\n          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numCounters; row++) {\n    if (matrix[row][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRowForCol[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  if (numFree === 0) {\n    const result = new Array(numButtons).fill(0);\n    for (let r = 0; r < rank; r++) {\n      result[pivotCol[r]] = matrix[r][numButtons];\n    }\n    return result;\n  }\n\n  // Extract free variable effects and RHS\n  // freeEffect[r][f] = coefficient of free variable f in pivot row r\n  const freeEffect: number[][] = [];\n  for (let r = 0; r < rank; r++) {\n    const effects: number[] = [];\n    for (let f = 0; f < numFree; f++) {\n      effects.push(matrix[r][freeVars[f]]);\n    }\n    freeEffect.push(effects);\n  }\n\n  const rhsVals: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    rhsVals.push(matrix[r][numButtons]);\n  }\n\n  // Strategy selection based on problem size\n  const bruteForceSize = Math.pow(modulus, numFree);\n  const dpSize = Math.pow(modulus, rank);\n\n  if (bruteForceSize <= 5_000_000) {\n    // Direct enumeration over free variables\n    return counterBruteForce(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  } else if (dpSize <= 2_000_000) {\n    // DP over contribution vectors\n    return counterDP(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  } else {\n    // MITM approach\n    return counterMITM(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  }\n}\n\nfunction counterBruteForce(\n  numButtons: number, numFree: number, freeVars: number[],\n  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n  rank: number, modulus: number\n): number[] {\n  let bestResult: number[] | null = null;\n  let bestSum = Infinity;\n\n  const freeVals = new Array(numFree).fill(0);\n\n  while (true) {\n    let totalSum = 0;\n    const result = new Array(numButtons).fill(0);\n\n    for (let f = 0; f < numFree; f++) {\n      result[freeVars[f]] = freeVals[f];\n      totalSum += freeVals[f];\n    }\n\n    if (totalSum <= bestSum) {\n      for (let r = 0; r < rank; r++) {\n        let val = rhsVals[r];\n        for (let f = 0; f < numFree; f++) {\n          val = ((val - freeEffect[r][f] * freeVals[f]) % modulus + modulus * modulus) % modulus;\n        }\n        result[pivotCol[r]] = val;\n        totalSum += val;\n      }\n\n      if (totalSum < bestSum || (totalSum === bestSum && lexSmallerArr(result, bestResult!))) {\n        bestSum = totalSum;\n        bestResult = [...result];\n      }\n    }\n\n    // Increment counter (rightmost first = lex order)\n    let carry = true;\n    for (let f = numFree - 1; f >= 0 && carry; f--) {\n      freeVals[f]++;\n      if (freeVals[f] >= modulus) {\n        freeVals[f] = 0;\n      } else {\n        carry = false;\n      }\n    }\n    if (carry) break;\n  }\n\n  return bestResult!;\n}\n\n/**\n * DP approach for when rank is small.\n *\n * State: contribution vector c[0..rank-1] where c[r] = sum(freeEffect[r][f] * free[f]) mod p.\n * For each state, track the minimum sum of free variable values and the lex-smallest assignment.\n *\n * Process free variables one by one. For each, try all p values and update states.\n */\nfunction counterDP(\n  numButtons: number, numFree: number, freeVars: number[],\n  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n  rank: number, modulus: number\n): number[] {\n  // Encode contribution vector as a single integer (mixed-radix number)\n  function encodeContrib(contrib: number[]): number {\n    let key = 0;\n    for (let r = 0; r < rank; r++) {\n      key = key * modulus + contrib[r];\n    }\n    return key;\n  }\n\n  // For each state, store {sum, vals (free variable assignments)}\n  // Process free variables one at a time.\n  // Initial state: contribution = [0,0,...,0], sum = 0, vals = []\n\n  interface DPEntry { sum: number; vals: number[]; }\n\n  let current = new Map<number, DPEntry>();\n  current.set(0, { sum: 0, vals: [] });\n\n  for (let f = 0; f < numFree; f++) {\n    const next = new Map<num