tons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    rows[i] = row;\n  }\n\n  // Gaussian elimination over GF(2)\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(numLights).fill(-1);\n  let rank = 0;\n  const pivotRow: number[] = new Array(cols).fill(-1); // pivotRow[col] = row index that has pivot at col\n\n  for (let col = 0; col < numButtons; col++) {\n    // Find a row with a 1 in this column, starting from rank\n    let found = -1;\n    for (let row = rank; row < numLights; row++) {\n      if ((rows[row] >> BigInt(col)) & 1n) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n    pivotCol[rank] = col;\n    pivotRow[col] = rank;\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && (rows[row] >> BigInt(col)) & 1n) {\n        rows[row] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency: any row with all-zero coefficients but non-zero target\n  for (let row = rank; row < numLights; row++) {\n    if ((rows[row] >> BigInt(numButtons)) & 1n) {\n      return null; // inconsistent system\n    }\n  }\n\n  // Identify free variables (columns not used as pivots)\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // If no free variables, unique solution\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(numButtons)) & 1n) {\n        result.push(pivotCol[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Enumerate all 2^freeVars.length combinations to find minimum presses\n  // freeVars.length can be up to 40, but in practice with 40 buttons and 40 lights,\n  // the number of free variables is numButtons - rank. Worst case scenario\n  // could be large. However, we need a smarter approach for large free variable counts.\n  //\n  // For up to ~25 free variables, direct enumeration is feasible.\n  // For larger counts, we use meet-in-the-middle.\n\n  const numFree = freeVars.length;\n\n  if (numFree <= 25) {\n    return solveToggleBruteForce(rows, pivotCol, pivotRow, rank, numButtons, freeVars);\n  } else {\n    return solveToggleMeetInMiddle(rows, pivotCol, pivotRow, rank, numButtons, freeVars);\n  }\n}\n\nfunction solveToggleBruteForce(\n  rows: bigint[],\n  pivotCol: number[],\n  pivotRow: number[],\n  rank: number,\n  numButtons: number,\n  freeVars: number[]\n): number[] {\n  const numFree = freeVars.length;\n  let bestResult: number[] | null = null;\n  let bestCount = Infinity;\n\n  for (let mask = 0; mask < (1 << numFree); mask++) {\n    const pressed: number[] = [];\n    const freeValues: number[] = new Array(numButtons).fill(0);\n\n    // Set free variable values\n    for (let f = 0; f < numFree; f++) {\n      if (mask & (1 << f)) {\n        freeValues[freeVars[f]] = 1;\n        pressed.push(freeVars[f]);\n      }\n    }\n\n    // Determine pivot variable values\n    for (let r = 0; r < rank; r++) {\n      const col = pivotCol[r];\n      let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n      // Subtract contributions of free variables\n      for (let f = 0; f < numFree; f++) {\n        if (freeValues[freeVars[f]] && (rows[r] >> BigInt(freeVars[f])) & 1n) {\n          val ^= 1;\n        }\n      }\n      if (val) {\n        pressed.push(col);\n      }\n    }\n\n    pressed.sort((a, b) => a - b);\n\n    if (pressed.length < bestCount ||\n        (pressed.length === bestCount && lexSmaller(pressed, bestResult!))) {\n      bestCount = pressed.length;\n      bestResult = pressed;\n    }\n  }\n\n  return bestResult!;\n}\n\nfunction solveToggleMeetInMiddle(\n  rows: bigint[],\n  pivotCol: number[],\n  pivotRow: number[],\n  rank: number,\n  numButtons: number,\n  freeVars: number[]\n): number[] {\n  // Split free variables into two halves\n  const numFree = freeVars.length;\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // For each assignment of free variables, we can compute the full solution.\n  // The key observation: the pivot variables are determined by the free variables.\n  // For each pivot variable r: pivotVal[r] = rhs[r] XOR (sum of free contributions in row r)\n  //\n  // Total presses = number of free vars set to 1 + number of pivot vars that become 1\n  //\n  // We need to find the combination of free variable assignments that minimizes total presses.\n  //\n  // For meet-in-the-middle, we precompute the effect of the first half on each pivot row,\n  // then for each second-half assignment, combine.\n\n  // Precompute: for each pivot row, what free vars affect it\n  // pivotEffect[r] = bitmask over freeVars that affect row r\n  const pivotRHS: number[] = new Array(rank);\n  const pivotFreeEffect: bigint[] = new Array(rank);\n\n  for (let r = 0; r < rank; r++) {\n    pivotRHS[r] = Number((rows[r] >> BigInt(numButtons)) & 1n);\n    let effect = 0n;\n    for (let f = 0; f < numFree; f++) {\n      if ((rows[r] >> BigInt(freeVars[f])) & 1n) {\n        effect |= 1n << BigInt(f);\n      }\n    }\n    pivotFreeEffect[r] = effect;\n  }\n\n  // For a given free variable assignment (as bitmask over freeVars),\n  // compute the total number of presses:\n  // - Count of free vars set to 1\n  // - For each pivot row r: pivotRHS[r] XOR (popcount of pivotFreeEffect[r] & freeMask % 2)\n  //   i.e., if odd number of free vars in that row's effect are set, flip the RHS\n\n  // Represent the effect on pivot rows as a \"signature\" (bigint bitmask of which pivot rows get flipped)\n  // Then for each signature from half1, we know the contribution to pivot presses.\n  // For half2, same thing. Combined signature = sig1 XOR sig2.\n  // Total pivot presses = popcount of (basePivotRHS XOR combinedSig)\n  // where basePivotRHS is the bitmask of which pivot rows have RHS=1.\n\n  let basePivotRHS = 0n;\n  for (let r = 0; r < rank; r++) {\n    if (pivotRHS[r]) {\n      basePivotRHS |= 1n << BigInt(r);\n    }\n  }\n\n  // Compute signature for a free variable assignment\n  function computeSignature(freeMask: number, startFree: number, countFree: number): bigint {\n    let sig = 0n;\n    for (let r = 0; r < rank; r++) {\n      let flip = 0;\n      for (let f = 0; f < countFree; f++) {\n        if ((freeMask & (1 << f)) && (pivotFreeEffect[r] >> BigInt(startFree + f)) & 1n) {\n          flip ^= 1;\n        }\n      }\n      if (flip) {\n        sig |= 1n << BigInt(r);\n      }\n    }\n    return sig;\n  }\n\n  function popcount(x: bigint): number {\n    let count = 0;\n    while (x) {\n      x &= x - 1n;\n      count++;\n    }\n    return count;\n  }\n\n  function bitcount(x: number): number {\n    let count = 0;\n    while (x) {\n      x &= x - 1;\n      count++;\n    }\n    return count;\n  }\n\n  // Build first half table: signature -> { freeCount, freeMask (best) }\n  // We want minimum total presses, so for each signature, store minimum free count\n  // and the lex smallest mask for that count.\n  const half1Table = new Map<bigint, { freeCount: number; freeMask: number }[]>();\n\n  for (let mask = 0; mask < (1 << half1); mask++) {\n    const sig = computeSignature(mask, 0, half1);\n    const fc = bitcount(mask);\n    const entry = half1Table.get(sig);\n    if (entry) {\n      entry.push({ freeCount: fc, freeMask: mask });\n    } else {\n      half1Table.set(sig, [{ freeCount: fc, freeMask: mask }]);\n    }\n  }\n\n  // Sort each entry list by freeCount, then by freeMask for lex order\n  for (const [, entries] of half1Table) {\n    entries.sort((a, b) => a.freeCount - b.freeCount || a.freeMask - b.freeMask);\n  }\n\n  let bestTotal = Infinity;\n  let bestResult: number[] | null = null;\n\n  for (let mask2 = 0; mask2 < (1 << half2); mask2++) {\n    const sig2 = computeSignature(mask2, half1, half2);\n    const fc2 = bitcount(mask2);\n\n    // We need sig1 such that pivotPresses = popcount(basePivotRHS XOR sig1 XOR sig2) is minimized\n    // along with fc1 + fc2 + pivotPresses.\n    // Since we want to find the best overall, we'd need to check all possible sig1 values,\n    // but that's what the table is for. However, we can't easily optimize the XOR search.\n    // Let's iterate over all entries in the table (which in worst case is 2^20 entries).\n    // Total work: 2^20 * 2^20 = 2^40 which is too much.\n\n    // Better approach: for each mask2, the target sig1 that minimizes pivotPresses\n    // depends on basePivotRHS XOR sig2. The optimal sig1 = basePivotRHS XOR sig2\n    // (to make all pivot presses 0). But that specific sig1 may not exist.\n    // We need to try all sig1 values in the table.\n\n    // Actually for MITM with up to 40 free vars, each half is up to 20.\n    // 2^20 ~ 1M entries per half. For each of 1M mask2 values, we'd need to\n    // look up in the table. But we can't just look up one sig1 -- we need\n    // the optimal combination.\n\n    // Alternative: just iterate all table entries. With 1M * (some small number per sig) it should be fine\n    // if we only keep the best per signature.\n\n    // Let's keep only the single best (min freeCount, lex smallest mask) per signature.\n    // Then iterate all sig1 in table.\n\n    // But 1M * 1M = 1T iterations. Too slow.\n\n    // Actually, let's reconsider. With 40 buttons and 40 lights, rank can be at most 40.\n    // So free vars = 40 - rank. If rank = 0, we have 40 free vars and 0 pivot vars.\n    // In that case all lights must be off in the target (since rank=0 means no equations constrain anything).\n    // But with 40 lights, rank is at most 40. Free vars could be large only if numButtons >> numLights,\n    // but numButtons <= 40 and numLights <= 40, so free vars <= 40.\n    // However, with 40 free vars and 0 pivot rows, the \"cost\" is just the number of free vars set to 1.\n    // The minimum is 0 (press no buttons). But we need target to be all false for that to work.\n\n    // In practice with 40 buttons and 40 lights, rank will typically be close to min(40, 40) = 40,\n    // leaving very few free variables. The brute force path (numFree <= 25) will almost always be taken.\n    // This MITM path is a safety net.\n\n    // For MITM to work efficiently: iterate all (sig1, sig2) pairs.\n    // Group sig1 by signature. For each sig2, compute needed = basePivotRHS XOR sig2.\n    // Then pivotPresses(sig1) = popcount(needed XOR sig1).\n    // We want to minimize fc1 + fc2 + popcount(needed XOR sig1).\n    // Since fc2 is fixed for this iteration, minimize fc1 + popcount(needed XOR sig1).\n\n    // We can iterate over all sig1 entries in the table.\n    // Table has at most 2^half1 entries (up to ~2^20 = 1M).\n    // For each mask2, iterating 1M entries: total 1M * 1M = too slow.\n\n    // Better: for small number of distinct signatures (which is bounded by 2^rank),\n    // iterate over distinct signatures only.\n    // With rank up to 40 and half1 up to 20, distinct signatures up to 2^20.\n    // But 2^20 * 2^20 = 2^40 is still too much.\n\n    // Let's use a different strategy: since we only reach this code path when numFree > 25,\n    // and rank = numButtons - numFree < 40 - 25 = 15, we have at most 2^15 = 32768 distinct\n    // signatures. So iterating over distinct signatures is fast!\n\n    const needed = basePivotRHS ^ sig2;\n    const pivotPresses = popcount(needed); // if sig1 = 0 (no first-half flips)\n\n    for (const [sig1, entries] of half1Table) {\n      const totalPivot = popcount(needed ^ sig1);\n      const bestEntry = entries[0]; // sorted by freeCount first\n      const total = bestEntry.freeCount + fc2 + totalPivot;\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        bestResult = buildToggleResult(bestEntry.freeMask, mask2, half1, half2,\n          freeVars, rows, pivotCol, rank, numButtons);\n      } else if (total === bestTotal) {\n        const candidate = buildToggleResult(bestEntry.freeMask, mask2, half1, half2,\n          freeVars, rows, pivotCol, rank, numButtons);\n        if (lexSmaller(candidate, bestResult!)) {\n          bestResult = candidate;\n        }\n\n        // Also check other entries with same total\n        for (let e = 1; e < entries.length; e++) {\n          const entry = entries[e];\n          const t = entry.freeCount + fc2 + totalPivot;\n          if (t > total) break; // entries sorted by freeCount\n          if (t === bestTotal) {\n            const c2 = buildToggleResult(entry.freeMask, mask2, half1, half2,\n              freeVars, rows, pivotCol, rank, numButtons);\n            if (lexSmaller(c2, bestResult!)) {\n              bestResult = c2;\n            }\n          }\n        }\n      }\n    }\n  }\n\n  return bestResult!;\n}\n\nfunction buildToggleResult(\n  mask1: number, mask2: number, half1: number, half2: number,\n  freeVars: number[], rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n): number[] {\n  const pressed: number[] = [];\n  const freeValues: number[] = new Array(numButtons).fill(0);\n\n  for (let f = 0; f < half1; f++) {\n    if (mask1 & (1 << f)) {\n      freeValues[freeVars[f]] = 1;\n      pressed.push(freeVars[f]);\n    }\n  }\n  for (let f = 0; f < half2; f++) {\n    if (mask2 & (1 << f)) {\n      freeValues[freeVars[half1 + f]] = 1;\n      pressed.push(freeVars[half1 + f]);\n    }\n  }\n\n  for (let r = 0; r < rank; r++) {\n    const col = pivotCol[r];\n    let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n    for (let fv = 0; fv < freeVars.length; fv++) {\n      if (freeValues[freeVars[fv]] && (rows[r] >> BigInt(freeVars[fv])) & 1n) {\n        val ^= 1;\n      }\n    }\n    if (val) {\n      pressed.push(col);\n    }\n  }\n\n  pressed.sort((a, b) => a - b);\n  return pressed;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  // Compare two sorted arrays lexicographically as sets\n  // Shorter length wins first (fewer presses)\n  if (a.length !== b.length) return a.length < b.length;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i];\n  }\n  return false;\n}\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n *\n * We build a matrix A where A[i][j] = 1 if button j affects counter i, else 0.\n * We solve A * x = target (mod p), where x[j] ∈ {0, ..., p-1}.\n * Among all solutions, return the one with minimum sum of presses,\n * breaking ties by lex smallest result array.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | lights] over GF(modulus)\n  // matrix[i][j] = coefficient of button j in counter i's equation\n  // matrix[i][numButtons] = target value for counter i\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = lights[i];\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(modulus)\n  const pivotCol: number[] = new Array(numCounters).fill(-1);\n  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    // Find a row with non-zero in this column\n    let found = -1;\n    for (let row = rank; row < numCounters; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol[rank] = col;\n    pivotRowForCol[col] = rank;\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(matrix[rank][col], modulus);\n    for (let c = 0; c < numButtons + 1; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n    }\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < numCounters; row++) {\n      if (row !== rank && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let c = 0; c < numButtons + 1; c++) {\n          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numCounters; row++) {\n    if (matrix[row][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRowForCol[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  if (numFree === 0) {\n    // Unique solution\n    const result = new Array(numButtons).fill(0);\n    for (let r = 0; r < rank; r++) {\n      result[pivotCol[r]] = matrix[r][numButtons];\n    }\n    return result;\n  }\n\n  // With free variables, we need to find the assignment that minimizes total presses.\n  // Each free variable can take values 0..modulus-1.\n  // Total combinations = modulus^numFree. With modulus up to 97 and numFree potentially large,\n  // brute force is infeasible for large numFree.\n  //\n  // For small numFree (e.g., <= 5 with modulus 97: 97^5 ~ 8.5 billion -- too much),\n  // we need a smarter approach.\n  //\n  // Strategy: meet-in-the-middle when numFree > threshold.\n  // For numFree <= threshold, brute force.\n  //\n  // With modulus p and k free variables:\n  // - Brute force: p^k iterations\n  // - MITM: p^(k/2) * factor for each half, then combine\n  //\n  // But the \"combine\" step for GF(p) is more complex than GF(2).\n  // For each assignment of free vars, the pivot vars are determined:\n  //   pivotVal[r] = rhs[r] - sum(matrix[r][freeVar] * freeVal) mod p\n  // The total presses = sum(freeVals) + sum(pivotVals) where all values are in [0, p-1].\n  //\n  // For MITM: split free vars into two halves.\n  // For half1, compute a \"contribution vector\" to each pivot row.\n  // For half2, same. Combined pivot values = rhs - contrib1 - contrib2 (mod p).\n  // Total presses = sum(free1) + sum(free2) + sum(pivotVals).\n  //\n  // This is hard to optimize with MITM because pivotVals depend on both halves non-linearly\n  // (each pivot val is in [0, p-1] and contributes its value to the sum).\n  //\n  // Alternative for small free var counts: direct enumeration\n  // For modulus 2-3 and numFree up to ~25: feasible\n  // For modulus up to 97 and numFree up to ~3: feasible (97^3 ~ 900K)\n  // For larger: need smarter approach.\n  //\n  // Given the constraint of 40 buttons and 40 counters, rank is at most 40,\n  // so numFree = numButtons - rank. Typically rank will be close to min(numButtons, numCounters).\n  // With both at 40, numFree could be 0. In adversarial cases, numFree could be up to 40.\n  //\n  // For the general case with large numFree and large modulus, we need the MITM approach\n  // with a hash map on the pivot contribution signature.\n\n  // Compute how each free variable affects each pivot row\n  // freeEffect[r][f] = matrix[r][freeVars[f]] (the coefficient)\n  const freeEffect: number[][] = [];\n  for (let r = 0; r < rank; r++) {\n    const effects: number[] = [];\n    for (let f = 0; f < numFree; f++) {\n      effects.push(matrix[r][freeVars[f]]);\n    }\n    freeEffect.push(effects);\n  }\n\n  const rhs: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    rhs.push(matrix[r][numButtons]);\n  }\n\n  // Estimate total combinations\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (totalCombinations <= 5_000_000) {\n    // Direct enumerati