,"-","   while (r !== 0) {","     const quotient = Math.floor(old_r / r);","     [old_r, r] = [r, old_r - quotient * r];","     [old_s, s] = [s, old_s - quotient * s];","   }","-","   return ((old_s % m) + m) % m;"," }"]}],"originalFile":"/**\n * Factory Reset - Toggle and Counter puzzle solvers\n *\n * Both problems reduce to solving systems of linear equations over finite fields.\n * Toggle: GF(2), Counter: GF(p) where p is prime.\n */\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── Toggle Solver ───────────────────────────────────────────────────────────\n\n/**\n * Solve the toggle puzzle using Gaussian elimination over GF(2).\n *\n * We build a matrix where row i = light i, column j = button j.\n * A[i][j] = 1 if button j toggles light i. We solve A*x = target (mod 2).\n * Return the minimum set of button presses, lex-smallest on ties.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | target] over GF(2) using bigint bitmasks\n  const rows: bigint[] = new Array(numLights);\n  for (let i = 0; i < numLights; i++) {\n    let row = 0n;\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    rows[i] = row;\n  }\n\n  // Gaussian elimination over GF(2) → reduced row echelon form\n  const pivotCol: number[] = new Array(numLights).fill(-1);\n  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let found = -1;\n    for (let row = rank; row < numLights; row++) {\n      if ((rows[row] >> BigInt(col)) & 1n) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n    pivotCol[rank] = col;\n    pivotRowForCol[col] = rank;\n\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && (rows[row] >> BigInt(col)) & 1n) {\n        rows[row] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numLights; row++) {\n    if ((rows[row] >> BigInt(numButtons)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRowForCol[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(numButtons)) & 1n) {\n        result.push(pivotCol[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Precompute: for each pivot row, which free vars affect it (as bitmask over freeVars index)\n  const pivotFreeEffect: bigint[] = new Array(rank);\n  for (let r = 0; r < rank; r++) {\n    let effect = 0n;\n    for (let f = 0; f < freeVars.length; f++) {\n      if ((rows[r] >> BigInt(freeVars[f])) & 1n) {\n        effect |= 1n << BigInt(f);\n      }\n    }\n    pivotFreeEffect[r] = effect;\n  }\n\n  // Compute \"signature\" of a free-var assignment: bitmask of which pivot rows get flipped\n  // The signature determines the pivot variable values (combined with basePivotRHS).\n  // Number of distinct signatures ≤ 2^rank.\n\n  let basePivotRHS = 0n;\n  for (let r = 0; r < rank; r++) {\n    if ((rows[r] >> BigInt(numButtons)) & 1n) {\n      basePivotRHS |= 1n << BigInt(r);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each free-var mask, compute the signature (which pivot rows get flipped)\n  function getSignature(freeMask: number | bigint, startFree: number, countFree: number): bigint {\n    let sig = 0n;\n    for (let r = 0; r < rank; r++) {\n      // Count parity of free vars in this row's effect that are set\n      // (pivotFreeEffect[r] >> startFree) & freeMask, then popcount parity\n      const relevantBits = (pivotFreeEffect[r] >> BigInt(startFree)) & ((1n << BigInt(countFree)) - 1n);\n      const masked = relevantBits & BigInt(freeMask);\n      // Parity of popcount\n      let parity = 0n;\n      let tmp = masked;\n      while (tmp) {\n        parity ^= 1n;\n        tmp &= tmp - 1n;\n      }\n      if (parity) {\n        sig |= 1n << BigInt(r);\n      }\n    }\n    return sig;\n  }\n\n  function bigPopcount(x: bigint): number {\n    let count = 0;\n    while (x) { x &= x - 1n; count++; }\n    return count;\n  }\n\n  function bitcount(x: number): number {\n    let count = 0;\n    while (x) { x &= x - 1; count++; }\n    return count;\n  }\n\n  if (numFree <= 25) {\n    // Direct enumeration\n    let bestResult: number[] | null = null;\n    let bestCount = Infinity;\n\n    for (let mask = 0; mask < (1 << numFree); mask++) {\n      const freeCount = bitcount(mask);\n      const sig = getSignature(mask, 0, numFree);\n      const pivotPresses = bigPopcount(basePivotRHS ^ sig);\n      const total = freeCount + pivotPresses;\n\n      if (total < bestCount || (total === bestCount && bestResult !== null)) {\n        if (total < bestCount) {\n          bestCount = total;\n          bestResult = buildToggleResult(mask, numFree, freeVars, rows, pivotCol, rank, numButtons);\n        } else {\n          const candidate = buildToggleResult(mask, numFree, freeVars, rows, pivotCol, rank, numButtons);\n          if (lexSmaller(candidate, bestResult!)) {\n            bestResult = candidate;\n          }\n        }\n      }\n    }\n\n    return bestResult!;\n  }\n\n  // MITM for numFree > 25. Since rank = numButtons - numFree < 15,\n  // distinct signatures ≤ 2^15 = 32768.\n  const half1Size = Math.floor(numFree / 2);\n  const half2Size = numFree - half1Size;\n\n  // Build table for first half: signature → best (freeCount, freeMask)\n  // For each signature, keep ALL entries grouped by freeCount,\n  // but we only need the lex-smallest mask per freeCount per signature.\n  interface HalfEntry { freeCount: number; freeMask: number; }\n  const half1Table = new Map<bigint, HalfEntry[]>();\n\n  for (let mask = 0; mask < (1 << half1Size); mask++) {\n    const sig = getSignature(mask, 0, half1Size);\n    const fc = bitcount(mask);\n    const entries = half1Table.get(sig);\n    if (entries) {\n      entries.push({ freeCount: fc, freeMask: mask });\n    } else {\n      half1Table.set(sig, [{ freeCount: fc, freeMask: mask }]);\n    }\n  }\n\n  // For each signature, sort entries by freeCount, then keep only the lex-best mask per freeCount\n  for (const [sig, entries] of half1Table) {\n    entries.sort((a, b) => a.freeCount - b.freeCount || a.freeMask - b.freeMask);\n    // Deduplicate: keep only first entry per freeCount (it's the smallest mask)\n    const deduped: HalfEntry[] = [];\n    let lastFc = -1;\n    for (const e of entries) {\n      if (e.freeCount !== lastFc) {\n        deduped.push(e);\n        lastFc = e.freeCount;\n      }\n    }\n    half1Table.set(sig, deduped);\n  }\n\n  let bestTotal = Infinity;\n  let bestResult: number[] | null = null;\n\n  for (let mask2 = 0; mask2 < (1 << half2Size); mask2++) {\n    const sig2 = getSignature(mask2, half1Size, half2Size);\n    const fc2 = bitcount(mask2);\n\n    if (fc2 > bestTotal) continue; // can't improve\n\n    // For this half2, we need half1 with sig1 such that total is minimized.\n    // total = fc1 + fc2 + popcount(basePivotRHS ^ sig1 ^ sig2)\n    // = fc2 + fc1 + popcount(needed ^ sig1) where needed = basePivotRHS ^ sig2\n\n    const needed = basePivotRHS ^ sig2;\n\n    for (const [sig1, entries] of half1Table) {\n      const pivotPresses = bigPopcount(needed ^ sig1);\n      const bestEntry = entries[0]; // lowest freeCount\n      const total = bestEntry.freeCount + fc2 + pivotPresses;\n\n      if (total > bestTotal) continue;\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        bestResult = buildToggleResultMITM(bestEntry.freeMask, mask2, half1Size, half2Size,\n          freeVars, rows, pivotCol, rank, numButtons);\n      } else {\n        // Check all entries with same total\n        for (const entry of entries) {\n          const t = entry.freeCount + fc2 + pivotPresses;\n          if (t > bestTotal) break;\n          const candidate = buildToggleResultMITM(entry.freeMask, mask2, half1Size, half2Size,\n            freeVars, rows, pivotCol, rank, numButtons);\n          if (lexSmaller(candidate, bestResult!)) {\n            bestResult = candidate;\n          }\n        }\n      }\n    }\n  }\n\n  return bestResult!;\n}\n\nfunction buildToggleResult(\n  freeMask: number, numFree: number, freeVars: number[],\n  rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n): number[] {\n  const pressed: number[] = [];\n\n  for (let f = 0; f < numFree; f++) {\n    if (freeMask & (1 << f)) {\n      pressed.push(freeVars[f]);\n    }\n  }\n\n  for (let r = 0; r < rank; r++) {\n    let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n    for (let f = 0; f < numFree; f++) {\n      if ((freeMask & (1 << f)) && (rows[r] >> BigInt(freeVars[f])) & 1n) {\n        val ^= 1;\n      }\n    }\n    if (val) {\n      pressed.push(pivotCol[r]);\n    }\n  }\n\n  pressed.sort((a, b) => a - b);\n  return pressed;\n}\n\nfunction buildToggleResultMITM(\n  mask1: number, mask2: number, half1Size: number, half2Size: number,\n  freeVars: number[], rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n): number[] {\n  const combined = mask1 | (mask2 << half1Size);\n  return buildToggleResult(combined, half1Size + half2Size, freeVars, rows, pivotCol, rank, numButtons);\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  if (a.length !== b.length) return a.length < b.length;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i];\n  }\n  return false;\n}\n\n// ─── Counter Solver ──────────────────────────────────────────────────────────\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n *\n * Build matrix where A[i][j] = 1 if button j affects counter i.\n * Solve A*x = target (mod p). Return result minimizing sum of presses,\n * lex-smallest on ties.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | target]\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = lights[i];\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p) → reduced row echelon form\n  const pivotCol: number[] = new Array(numCounters).fill(-1);\n  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let found = -1;\n    for (let row = rank; row < numCounters; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol[rank] = col;\n    pivotRowForCol[col] = rank;\n\n    const inv = modInverse(matrix[rank][col], modulus);\n    for (let c = 0; c < numButtons + 1; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n    }\n\n    for (let row = 0; row < numCounters; row++) {\n      if (row !== rank && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let c = 0; c < numButtons + 1; c++) {\n          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numCounters; row++) {\n    if (matrix[row][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRowForCol[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  if (numFree === 0) {\n    const result = new Array(numButtons).fill(0);\n    for (let r = 0; r < rank; r++) {\n      result[pivotCol[r]] = matrix[r][numButtons];\n    }\n    return result;\n  }\n\n  // Extract free variable effects and RHS\n  // freeEffect[r][f] = coefficient of free variable f in pivot row r\n  const freeEffect: number[][] = [];\n  for (let r = 0; r < rank; r++) {\n    const effects: number[] = [];\n    for (let f = 0; f < numFree; f++) {\n      effects.push(matrix[r][freeVars[f]]);\n    }\n    freeEffect.push(effects);\n  }\n\n  const rhsVals: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    rhsVals.push(matrix[r][numButtons]);\n  }\n\n  // Strategy selection based on problem size\n  const bruteForceSize = Math.pow(modulus, numFree);\n  const dpSize = Math.pow(modulus, rank);\n\n  if (bruteForceSize <= 5_000_000) {\n    // Direct enumeration over free variables\n    return counterBruteForce(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  } else if (dpSize <= 2_000_000) {\n    // DP over contribution vectors\n    return counterDP(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  } else {\n    // MITM approach\n    return counterMITM(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  }\n}\n\nfunction counterBruteForce(\n  numButtons: number, numFree: number, freeVars: number[],\n  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n  rank: number, modulus: number\n): number[] {\n  let bestResult: number[] | null = null;\n  let bestSum = Infinity;\n\n  const freeVals = new Array(numFree).fill(0);\n\n  while (true) {\n    let totalSum = 0;\n    const result = new Array(numButtons).fill(0);\n\n    for (let f = 0; f < numFree; f++) {\n      result[freeVars[f]] = freeVals[f];\n      totalSum += freeVals[f];\n    }\n\n    if (totalSum <= bestSum) {\n      for (let r = 0; r < rank; r++) {\n        let val = rhsVals[r];\n        for (let f = 0; f < numFree; f++) {\n          val = ((val - freeEffect[r][f] * freeVals[f]) % modulus + modulus * modulus) % modulus;\n        }\n        result[pivotCol[r]] = val;\n        totalSum += val;\n      }\n\n      if (totalSum < bestSum || (totalSum === bestSum && lexSmallerArr(result, bestResult!))) {\n        bestSum = totalSum;\n        bestResult = [...result];\n      }\n    }\n\n    // Increment counter (rightmost first = lex order)\n    let carry = true;\n    for (let f = numFree - 1; f >= 0 && carry; f--) {\n      freeVals[f]++;\n      if (freeVals[f] >= modulus) {\n        freeVals[f] = 0;\n      } else {\n        carry = false;\n      }\n    }\n    if (carry) break;\n  }\n\n  return bestResult!;\n}\n\n/**\n * DP approach for when rank is small (p^rank fits in memory).\n *\n * Two-phase approach:\n * Phase 1 (Forward): For each state (contribution vector), find the minimum\n *   sum of free variable values. Store only sums, not assignments.\n * Phase 2 (Backward): Reconstruct the lex-smallest assignment that achieves\n *   the optimal total cost.\n */\nfunction counterDP(\n  numButtons: number, numFree: number, freeVars: number[],\n  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n  rank: number, modulus: number\n): number[] {\n  const totalStates = Math.pow(modulus, rank);\n\n  // Encode contribution vector as a single integer (mixed-radix number)\n  function encodeContrib(contrib: number[]): number {\n    let key = 0;\n    for (let r = 0; r < rank; r++) {\n      key = key * modulus + contrib[r];\n    }\n    return key;\n  }\n\n  // Precompute: for each free variable f and value v, what is the state offset?\n  // stateOffset[f][v] = encoded contribution of setting free var f to value v\n  // When adding free var f with value v, new_contrib[r] = (old_contrib[r] + effect[r][f] * v) mod p\n  // We precompute the offset key for each (f, v) to avoid recomputing.\n\n  // Forward pass: dp[state] = minimum sum of free variables to reach this state\n  // Use arrays indexed by state key (0 to totalStates-1) for efficiency\n  const INF = Infinity;\n\n  // Save all DP layers for backward reconstruction\n  const dpLayers: Float64Array[] = [];\n  let currentDP = new Float64Array(totalStates).fill(INF);\n  currentDP[0] = 0;\n  dpLayers.push(currentDP);\n\n  for (let f = 0; f < numFree; f++) {\n    const nextDP = new Float64Array(totalStates).fill(INF);\n\n    // Precompute transition: for state s and value v, compute next state\n    // Iterate over all states\n    for (let s = 0; s < totalStates; s++) {\n      if (currentDP[s] === INF) continue;\n\n      // Decode state\n      const contrib = new Array(rank);\n      let tmp = s;\n      for (let r = rank - 1; r >= 0; r--) {\n        contrib[r] = tmp % modulus;\n        tmp = Math.floor(tmp / modulus);\n      }\n\n      for (let v = 0; v < modulus; v++) {\n        // Compute new state\n        let newKey = 0;\n        for (let r = 0; r < rank; r++) {\n          newKey = newKey * modulus + (contrib[r] + freeEffect[r][f] * v) % modulus;\n        }\n\n        const newSum = currentDP[s] + v;\n        if (newSum < nextDP[newKey]) {\n          nextDP[newKey] = newSum;\n        }\n      }\n    }\n\n    currentDP = nextDP;\n    dpLayers.push(currentDP);\n  }\n\n  // Determine the best total cost across all final states\n  let bestTotalCost = INF;\n  for (let s = 0; s < totalStates; s++) {\n    if (currentDP[s] === INF) continue;\n\n    // Compute pivot sum for this state\n    let pivotSum = 0;\n    let tmp = s;\n    for (let r = rank - 1; r >= 0; r--) {\n      const c = tmp % modulus;\n      pivotSum += (rhsVals[r] - c + modulus * modulus) % modulus;\n      tmp = Math.floor(tmp / modulus);\n    }\n\n    const totalCost = currentDP[s] + pivotSum;\n    if (totalCost < bestTotalCost) {\n      bestTotalCost = totalCost;\n    }\n  }\n\n  // Backward pass: reconstruct the lex-smallest assignment with optimal total cost.\n  // For each free variable (from first to last), pick the smallest value v such that\n  // the remaining cost can still achieve the optimal total.\n\n  // We need to find the lex-smallest free variable assignment that achieves bestTotalCost.\n  // Start from state 0, for each free variable try v=0,1,...,p-1 and pick the smallest v\n  // where the remaining can still achieve the target.\n\n  const freeVals = new Array(numFree);\n  let currentState = 0;\n  let usedFreeSum = 0;\n\n  for (let f = 0; f < numFree; f++) {\n    // Decode current state\n    const contrib = new Array(rank);\n    let tmp = currentState;\n    for (let r = rank - 1; r >= 0; r--) {\n      contrib[r] = tmp % modulus;\n      tmp = Math.floor(tmp / modulus);\n    }\n\n    let found = false;\n    for (let v = 0; v < modulus; v++) {\n      // Compute next state\n      let nextState = 0;\n      for (let r = 0; r < rank; r++) {\n        nextState = nextState * modulus + (contrib[r] + freeEffect[r][f] * v) % modulus;\n      }\n\n      const nextFreeSum = usedFreeSum + v;\n      const remainingDP = dpLayers[f + 1][nextState]; // minimum remaining free sum from state nextState\n\n      // Check: can we achieve bestTotalCost from this point?\n      // We need: nextFreeSum + (remaining free sum from nextState to final state) + pivotSum = bestTotalCost\n      // But pivotSum depends on the final state, not just nextState.\n      // Actually, remainingDP is the minimum sum to reach some final state FROM the beginning,\n      // not from nextState onward.\n\n      // Wait, dpLayers[f+1][nextState] is the min sum of free vars 0..f that reaches nextState.\n      // That's not what we want for the backward pass.\n\n      // We need a different approach: compute the \"remaining cost\" from each state at each layer.\n      // remainingCost[f][s] = min over assignments of free vars f..numFree-1 of (sum + pivotSum)\n      //   where the contribution transitions from state s.\n\n      // This requires a backward DP. Let's compute it.\n\n      // Actually, let me restructure. The backward DP computes:\n      // For layer f and state s: minimum (sum of free vars f..numFree-1) + pivotSum\n      //   achievable starting from state s.\n      // Then optimal is backwardDP[0][0].\n\n      // For the backward pass reconstruction, we pick the smallest v at each step such that\n      // v + backwardDP[f+1][nextState] = backwardDP[f][currentState].\n\n      // But computing backwardDP requires another pass. Let me do that.\n      found = false; // will be set below after computing backward DP\n      break;\n    }\n\n    if (!found) break;\n  }\n\n  // Compute backward DP\n  // backDP[s] = minimum (sum of remaining free vars) + pivot cost, starting from state s\n  let backDP = new Float64Array(totalStates).fill(INF);\n\n  // Base case: after processing all free variables, backDP[s] = pivot cost for state s\n  for (let s = 0; s < totalStates; s++) {\n    let pivotSum = 0;\n    let tmp = s;\n    for (let r = rank - 1; r >= 0; r--) {\n      const c = tmp % modulus;\n      pivotSum += (rhsVals[r] - c + modulus * modulus) % modulus;\n      tmp = Math.floor(tmp / modulus);\n    }\n    backDP[s] = pivotSum;\n  }\n\n  // Process free variables in reverse\n  const backDPLayers: Float64Array[] = new Array(numFree + 1);\n  backDPLayers[numFree] = backDP;\n\n  for (let f = numFree - 1; f >= 0; f--) {\n    const prevBackDP = new Float64Array(totalStates).fill(INF);\n\n    for (let s = 0; s < totalStates; s++) {\n      // Decode state\n      const contrib = new Array(rank);\n      let tmp = s;\n      for (let r = rank - 1; r >= 0; r--) {\n        contrib[r] = tmp % modulus;\n        tmp = Math.floor(tmp / modulus);\n      }\n\n      for (let v = 0; v < modulus; v++) {\n        let nextState = 0;\n        for (let r = 0; r < rank; r++) {\n          nextState = nextState * modulus + (contrib[r] + freeEffect[r][f] * v) % modulus;\n        }\n\n        const cost = v + backDPLayers[f + 1][nextState];\n        if (cost < prevBackDP[s]) {\n          prevBackDP[s] = cost;\n        }\n      }\n    }\n\n    backDPLayers[f] = prevBackDP;\n  }\n\n  // Now reconstruct: greedily pick smallest v at each step\n  currentState = 0;\n\n  for (let f = 0; f < numFree; f++) {\n    const contrib = new Array(rank);\n    let tmp = currentState;\n    for (let r = rank - 1; r >= 0; r--) {\n      contrib[r] = tmp % modulus;\n      tmp = Math.floor(tmp / modulus);\n    }\n\n    const targetCost = backDPLayers[f][currentState];\n\n    for (let v = 0; v < modulus; v++) {\n      let nextState = 0;\n      for (let r = 0; r < rank; r++) {\n        nextState = nextState * modulus + (contrib[r] + freeEffect[r][f] * v) % modulus;\n      }\n\n      if (v + backDPLayers[f + 1][nextState] === targetCost) {\n        freeVals[f] = v;\n        currentState = nextState;\n        break;\n      }\n    }\n  }\n\n  // Build result\n  const result = new Array(numButtons).fill(0);\n  for (let f = 0; f < numFree; f++) {\n    result[freeVars[f]] = freeVals[f];\n  }\n\n  // Compute pivot values from final state\n  let tmp2 = currentState;\n  for (let r = rank - 1; r >= 0; r--) {\n    const c = tmp2 % modulus;\n    result[pivotCol[r]] = (rhsVals[r] - c + modulus * modulus) % modulus;\n    tmp2 = Math.floor(tmp2 / modulus);\n  }\n\n  return result;\n}\n\n/**\n * MITM approach for counter puzzle.\n *\n * Uses DP over each half's free variables to build maps from contribution\n * vector to minimum sum. Then combines the two halves.\n *\n * For reconstruction, uses the same backward-DP technique to find\n * the lex-smallest assignment.\n */\nfunction counterMITM(\n  numButtons: number, numFree: number, freeVars: number[],\n  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n  rank: number, modulus: number\n): number[] {\n  // For MITM, we split free vars into two halves and build DP tables for each.\n  // Then combine by iterating over all state pairs.\n  //\n  // The DP state space is p^rank for each half. But if both halves' DP tables\n  // are too large, this won't help. In that case, fall back to iterating one half\n  // while using DP lookup on the other.\n\n  const totalStates = Math.pow(modulus, rank);\n\n  // If totalStates is too large, we can't do the DP approach at all.\n  // Fall back to iterating over one half with fewer free vars.\n  // Actually, if we reached MITM, both brute force and DP were too large.\n  // The MITM with DP approach works when p^rank is manageable for DP per half.\n  // If p^rank is huge, this is truly intractable. In practice this shouldn't happen\n  // with the problem constraints (40 buttons/counters, p ≤ 97).\n\n  // Let's split into two halves and build DP for each half over the shared\n  // state space of p^rank contribution vectors.\n\n  const half1Size = Math.floor(numFree / 2);\n  const half2Size = numFree - half1Size;\n\n  // Build half1 forward DP (for reconstruction) and backward DP\n  // half1FwdDP[f][s] = min sum of free vars 0..f-1 reaching state s\n  // half1BackDP[f][s] = min (sum of free vars f..half1Size-1 + remaining cost) from state s\n\n  // For half1, we just need the min sum per final state.\n  // For half2, same thing.\n  // Then combine: for each pair (s1, s2), total cost =\n  //   half1MinSum[s1] + half2MinSum[s2] + pivotCost(s1 + s2)\n\n  // First build half1 min sum\n  let h1DP = new Float64Array(totalStates).fill(Infinity);\n  h1DP[0] = 0;\n\n  const h1Layers: Float64Array[] = [h1DP];\n  for (let f = 0; f < half1Size; f++) {\n    const next = new Float64Array(totalStates).fill(Infinity);\n    for (let s = 0; s < totalStates; s++) {\n      if (h1DP[s] === Infinity) continue;\n      const contrib = decodeState(s, rank, modulus);\n      for (let v = 0; v < modulus; v++) {\n        const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n        const cost = h1DP[s] + v;\n        if (cost < next[ns]) next[ns] = cost;\n      }\n    }\n    h1DP = next;\n    h1Layers.push(h1DP);\n  }\n\n  // Build half2 min sum\n  let h2DP = new Float64Array(totalStates).fill(Infinity);\n  h2DP[0] = 0;\n\n  const h2Layers: Float64Array[] = [h2DP];\n  for (let f = 0; f < half2Size; f++) {\n    const next = new Float64Array(totalStates).fill(Infinity);\n    for (let s = 0; s < totalStates; s++) {\n      if (h2DP[s] === Infinity) continue;\n      const contrib = decodeState(s, rank, modulus);\n      for (let v = 0; v < modulus; v++) {\n        const ns = encodeTransition(contrib, freeEffect, half1Size + f, v, rank, modulus);\n        const cost = h2DP[s] + v;\n        if (cost < next[ns]) next[ns] = cost;\n      }\n    }\n    h2DP = next;\n    h2Layers.push(h2DP);\n  }\n\n  // Combine: find optimal total cost and the optimal (s1, s2) pair\n  let bestCost = Infinity;\n  let bestS1 = 0, bestS2 = 0;\n\n  for (let s1 = 0; s1 < totalStates; s1++) {\n    if (h1DP[s1] === Infinity) continue;\n\n    for (let s2 = 0; s2 < totalStates; s2++) {\n      if (h2DP[s2] === Infinity) continue;\n\n      // Combined contribution: (s1 + s2) element-wise mod p\n      const c1 = decodeState(s1, rank, modulus);\n      const c2 = decodeState(s2, rank, modulus);\n      let pivotSum = 0;\n      for (let r = 0; r < rank; r++) {\n        pivotSum += (rhsVals[r] - c1[r] - c2[r] + modulus * modulus * 2) % modulus;\n      }\n\n      const total = h1DP[s1] + h2DP[s2] + pivotSum;\n      if (total < bestCost) {\n        bestCost = total;\n        bestS1 = s1;\n        bestS2 = s2;\n      }\n    }\n  }\n\n  // Now reconstruct the lex-smallest assignment for each half using backward DP.\n  // Half 1: reconstruct from state 0 to bestS1\n  const h1Vals = reconstructHalf(h1Layers, freeEffect, 0, half1Size, bestS1, rank, modulus, totalStates);\n  // Half 2: reconstruct from state 0 to bestS2\n  const h2Vals = reconstructHalf(h2Layers, freeEffect, half1Size, half2Size, bestS2, rank, modulus, totalStates);\n\n  // Build result\n  const result = new Array(numButtons).fill(0);\n  for (let f = 0; f < half1Size; f++) {\n    result[freeVars[f]] = h1Vals[f];\n  }\n  for (let f = 0; f < half2Size; f++) {\n    result[freeVars[half1Size + f]] = h2Vals[f];\n  }\n\n  // Compute pivot values\n  const c1 = decodeState(bestS1, rank, modulus);\n  const c2 = decodeState(bestS2, rank, modulus);\n  for (let r = 0; r < rank; r++) {\n    result[pivotCol[r]] = (rhsVals[r] - c1[r] - c2[r] + modulus * modulus * 2) % modulus;\n  }\n\n  // Now we need to also check all (s1, s2) pairs that achieve bestCost\n  // to find the lex-smallest result. But the reconstruction is expensive,\n  // so we first check if there are ties.\n  // For simplicity, collect all tied (s1, s2) pairs and reconstruct each.\n\n  // Actually, to get the lex-smallest result correctly, we need to consider\n  // ALL (s1, s2) pairs that achieve bestCost and pick the lex-smallest result.\n  // Let's do this more carefully.\n\n  let finalBestResult = [...result];\n\n  for (let s1 = 0; s1 < totalStates; s1++) {\n    if (h1DP[s1] === Infinity) continue;\n    for (let s2 = 0; s2 < totalStates; s2++) {\n      if (h2DP[s2] === Infinity) continue;\n\n      const cc1 = decodeState(s1, rank, modulus);\n      const cc2 = decodeState(s2, rank, modulus);\n      let pivotSum = 0;\n      for (let r = 0; r < rank; r++) {\n        pivotSum += (rhsVals[r] - cc1[r] - cc2[r] + modulus * modulus * 2) % modulus;\n      }\n\n      const total = h1DP[s1] + h2DP[s2] + pivotSum;\n      if (total !== bestCost) continue;\n\n      const hv1 = reconstructHalf(h1Layers, freeEffect, 0, half1Size, s1, rank, modulus, totalStates);\n      const hv2 = reconstructHalf(h2Layers, freeEffect, half1Size, half2Size, s2, rank, modulus, totalStates);\n\n      const candidate = new Array(num