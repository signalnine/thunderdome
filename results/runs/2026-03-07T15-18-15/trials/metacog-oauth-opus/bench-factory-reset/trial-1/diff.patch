k; r++) {\n   203→    pivotRHS[r] = Number((rows[r] >> BigInt(numButtons)) & 1n);\n   204→    let effect = 0n;\n   205→    for (let f = 0; f < numFree; f++) {\n   206→      if ((rows[r] >> BigInt(freeVars[f])) & 1n) {\n   207→        effect |= 1n << BigInt(f);\n   208→      }\n   209→    }\n   210→    pivotFreeEffect[r] = effect;\n   211→  }\n   212→\n   213→  // For a given free variable assignment (as bitmask over freeVars),\n   214→  // compute the total number of presses:\n   215→  // - Count of free vars set to 1\n   216→  // - For each pivot row r: pivotRHS[r] XOR (popcount of pivotFreeEffect[r] & freeMask % 2)\n   217→  //   i.e., if odd number of free vars in that row's effect are set, flip the RHS\n   218→\n   219→  // Represent the effect on pivot rows as a \"signature\" (bigint bitmask of which pivot rows get flipped)\n   220→  // Then for each signature from half1, we know the contribution to pivot presses.\n   221→  // For half2, same thing. Combined signature = sig1 XOR sig2.\n   222→  // Total pivot presses = popcount of (basePivotRHS XOR combinedSig)\n   223→  // where basePivotRHS is the bitmask of which pivot rows have RHS=1.\n   224→\n   225→  let basePivotRHS = 0n;\n   226→  for (let r = 0; r < rank; r++) {\n   227→    if (pivotRHS[r]) {\n   228→      basePivotRHS |= 1n << BigInt(r);\n   229→    }\n   230→  }\n   231→\n   232→  // Compute signature for a free variable assignment\n   233→  function computeSignature(freeMask: number, startFree: number, countFree: number): bigint {\n   234→    let sig = 0n;\n   235→    for (let r = 0; r < rank; r++) {\n   236→      let flip = 0;\n   237→      for (let f = 0; f < countFree; f++) {\n   238→        if ((freeMask & (1 << f)) && (pivotFreeEffect[r] >> BigInt(startFree + f)) & 1n) {\n   239→          flip ^= 1;\n   240→        }\n   241→      }\n   242→      if (flip) {\n   243→        sig |= 1n << BigInt(r);\n   244→      }\n   245→    }\n   246→    return sig;\n   247→  }\n   248→\n   249→  function pop