minimize entry1.sum + entry2.sum + sum(pivotVals)\n\n    // We need to iterate over all half1 states and compute the total.\n    // If the half1 table is small enough, just iterate.\n    // Otherwise, for each needed contribution vector, look it up directly.\n\n    // For an exact match (all pivots = 0), we need contrib1[r] = (rhsVals[r] - contrib2[r]) mod p\n    const neededContrib = new Array(rank);\n    for (let r = 0; r < rank; r++) {\n      neededContrib[r] = (rhsVals[r] - contrib2[r] + modulus * modulus) % modulus;\n    }\n    const neededKey = encodeContrib(neededContrib);\n    const exactMatch = half1States.get(neededKey);\n    if (exactMatch) {\n      const totalSum = exactMatch.sum + entry2.sum; // pivot sum = 0\n      if (totalSum < bestSum) {\n        bestSum = totalSum;\n        bestResult = buildCounterResultFromHalves(\n          exactMatch.vals, entry2.vals, half1Size, half2Size,\n          freeVars, freeEffect, rhsVals, pivotCol, rank, numButtons, modulus\n        );\n      } else if (totalSum === bestSum) {\n        const candidate = buildCounterResultFromHalves(\n          exactMatch.vals, entry2.vals, half1Size, half2Size,\n          freeVars, freeEffect, rhsVals, pivotCol, rank, numButtons, modulus\n        );\n        if (lexSmallerArr(candidate, bestResult!)) {\n          bestResult = candidate;\n        }\n      }\n    }\n\n    // Also iterate all half1 states if the table is manageable\n    if (half1States.size <= 500_000) {\n      for (const [state1Key, entry1] of half1States) {\n        const contrib1 = new Array(rank);\n        let tmp1 = state1Key;\n        for (let r = rank - 1; r >= 0; r--) {\n          contrib1[r] = tmp1 % modulus;\n          tmp1 = Math.floor(tmp1 / modulus);\n        }\n\n        let pivotSum = 0;\n        for (let r = 0; r < rank; r++) {\n          pivotSum += (rhsVals[r] - contrib1[r] - contrib2[r] + modulus * modulus * 2) % modulus;\n        }\n\n        const totalSum = entry1.sum + entry2.sum + pivotSum;\n     