+++ b/src/index.ts
@@ -0,0 +1,156 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ */
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  let sourceRow = -1, sourceCol = -1;
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === 'S') {
+        sourceRow = r;
+        sourceCol = c;
+      }
+    }
+  }
+  if (sourceRow === -1) return 0;
+
+  const visited = new Set<number>();
+  const seen = new Set<number>();
+
+  const stack: Beam[] = [{ row: sourceRow, col: sourceCol, dir: 'down' }];
+
+  const dirIndex = { 'down': 0, 'down-left': 1, 'down-right': 2 };
+
+  while (stack.length > 0) {
+    const beam = stack.pop()!;
+    const key = beam.row * cols * 3 + beam.col * 3 + dirIndex[beam.dir];
+    if (seen.has(key)) continue;
+    seen.add(key);
+    visited.add(beam.row * cols + beam.col);
+
+    const cell = grid[beam.row][beam.col];
+
+    if (cell === '^') {
+      const lr = beam.row + 1, lc = beam.col - 1;
+      const rr = beam.row + 1, rc = beam.col + 1;
+      if (inBounds(lr, lc, rows, cols)) {
+        stack.push({ row: lr, col: lc, dir: 'down-left' });
+      }
+      if (inBounds(rr, rc, rows, cols)) {
+        stack.push({ row: rr, col: rc, dir: 'down-right' });
+      }
+    } else {
+      let nr: number, nc: number;
+      switch (beam.dir) {
+        case 'down': nr = beam.row + 1; nc = beam.col; break;
+        case 'down-left': nr = beam.row + 1; nc = beam.col - 1; break;
+        case 'down-right': nr = beam.row + 1; nc = beam.col + 1; break;
+      }
+      if (inBounds(nr, nc, rows, cols)) {
+        stack.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count the total number of distinct source-to-exit paths.
+ * Uses row-by-row counter propagation with bigint for precision.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  let sourceRow = -1, sourceCol = -1;
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === 'S') {
+        sourceRow = r;
+        sourceCol = c;
+      }
+    }
+  }
+  if (sourceRow === -1) return 0n;
+
+  // State: map of "col,dir" -> count of beams
+  const makeKey = (col: number, dir: Direction): string => `${col},${dir}`;
+
+  let current = new Map<string, bigint>();
+  current.set(makeKey(sourceCol, 'down'), 1n);
+
+  let totalExited = 0n;
+
+  for (let r = sourceRow; r < rows; r++) {
+    const next = new Map<string, bigint>();
+
+    for (const [key, count] of current) {
+      const comma = key.indexOf(',');
+      const col = parseInt(key.substring(0, comma), 10);
+      const dir = key.substring(comma + 1) as Direction;
+
+      const cell = grid[r][col];
+
+      if (cell === '^') {
+        const leftCol = col - 1;
+        const rightCol = col + 1;
+        const nextRow = r + 1;
+
+        if (nextRow < rows && leftCol >= 0 && leftCol < cols) {
+          const k = makeKey(leftCol, 'down-left');
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+
+        if (nextRow < rows && rightCol >= 0 && rightCol < cols) {
+          const k = makeKey(rightCol, 'down-right');
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+      } else {
+        let nextCol: number;
+        switch (dir) {
+          case 'down': nextCol = col; break;
+          case 'down-left': nextCol = col - 1; break;
+          case 'down-right': nextCol = col + 1; break;
+        }
+        const nextRow = r + 1;
+
+        if (nextRow < rows && nextCol >= 0 && nextCol < cols) {
+          const k = makeKey(nextCol, dir);
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  // Beams still in current after processing last row exit the grid
+  for (const [, count] of current) {
+    totalExited += count;
+  }
+
+  return totalExited;
+}
