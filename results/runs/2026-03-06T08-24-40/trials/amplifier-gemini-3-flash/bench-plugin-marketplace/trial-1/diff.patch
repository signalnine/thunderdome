@@ -0,0 +1,83 @@
+import Database from 'better-sqlite3';
+import { PluginManifest, RegistryService } from './types.js';
+
+export class PluginRegistry implements RegistryService {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    this.init();
+  }
+
+  private init() {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS plugins (
+        name TEXT,
+        version TEXT,
+        manifest TEXT,
+        PRIMARY KEY (name, version)
+      )
+    `);
+  }
+
+  register(manifest: PluginManifest): void {
+    const stmt = this.db.prepare(
+      'INSERT OR REPLACE INTO plugins (name, version, manifest) VALUES (?, ?, ?)'
+    );
+    stmt.run(manifest.name, manifest.version, JSON.stringify(manifest));
+  }
+
+  get(name: string): PluginManifest | null {
+    const stmt = this.db.prepare(
+      'SELECT manifest FROM plugins WHERE name = ? ORDER BY version DESC LIMIT 1'
+    );
+    const row = stmt.get(name) as { manifest: string } | undefined;
+    return row ? JSON.parse(row.manifest) : null;
+  }
+
+  getVersion(name: string, version: string): PluginManifest | null {
+    const stmt = this.db.prepare(
+      'SELECT manifest FROM plugins WHERE name = ? AND version = ?'
+    );
+    const row = stmt.get(name, version) as { manifest: string } | undefined;
+    return row ? JSON.parse(row.manifest) : null;
+  }
+
+  list(): PluginManifest[] {
+    const stmt = this.db.prepare('SELECT manifest FROM plugins');
+    const rows = stmt.all() as { manifest: string }[];
+    return rows.map((row) => JSON.parse(row.manifest));
+  }
+
+  search(query: string): PluginManifest[] {
+    const stmt = this.db.prepare(
+      'SELECT manifest FROM plugins WHERE name LIKE ? OR manifest LIKE ?'
+    );
+    const rows = stmt.all(`%${query}%`, `%${query}%`) as { manifest: string }[];
+    return rows.map((row) => JSON.parse(row.manifest));
+  }
+
+  remove(name: string, version: string): boolean {
+    const stmt = this.db.prepare(
+      'DELETE FROM plugins WHERE name = ? AND version = ?'
+    );
+    const result = stmt.run(name, version);
+    return result.changes > 0;
+  }
+
+  listVersions(name: string): string[] {
+    const stmt = this.db.prepare(
+      'SELECT version FROM plugins WHERE name = ? ORDER BY version DESC'
+    );
+    const rows = stmt.all(name) as { version: string }[];
+    return rows.map((row) => row.version);
+  }
+
+  update(name: string, version: string, updates: Partial<PluginManifest>): void {
+    const manifest = this.getVersion(name, version);
+    if (manifest) {
+      const updatedManifest = { ...manifest, ...updates };
+      this.register(updatedManifest);
+    }
+  }
+}
