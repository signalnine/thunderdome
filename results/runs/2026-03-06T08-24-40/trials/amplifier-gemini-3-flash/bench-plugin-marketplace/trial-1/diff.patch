@@ -0,0 +1,109 @@
+import { DepsService, RegistryService, DependencyNode } from './types.js';
+import semver from 'semver';
+
+export class DependencyGraph implements DepsService {
+  buildTree(name: string, registry: RegistryService): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      throw new Error(`Plugin ${name} not found in registry`);
+    }
+
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    for (const [depName, range] of Object.entries(manifest.dependencies)) {
+      const versions = registry.listVersions(depName);
+      const version = semver.maxSatisfying(versions, range);
+      if (!version) {
+        throw new Error(`Dependency ${depName} satisfying ${range} not found for ${name}`);
+      }
+      node.dependencies.push(this.buildTree(depName, registry));
+    }
+
+    return node;
+  }
+
+  detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const cycles: string[][] = [];
+    const visited = new Set<string>();
+    const path: string[] = [];
+
+    const visit = (curr: string) => {
+      if (path.includes(curr)) {
+        const cycle = path.slice(path.indexOf(curr));
+        cycle.push(curr);
+        cycles.push(cycle);
+        return;
+      }
+      if (visited.has(curr)) return;
+
+      visited.add(curr);
+      path.push(curr);
+
+      const manifest = registry.get(curr);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          visit(depName);
+        }
+      }
+
+      path.pop();
+    };
+
+    visit(name);
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  topologicalSort(name: string, registry: RegistryService): string[] {
+    const result: string[] = [];
+    const visited = new Set<string>();
+    const temp = new Set<string>();
+
+    const visit = (curr: string) => {
+      if (temp.has(curr)) {
+        throw new Error('Circular dependency detected');
+      }
+      if (visited.has(curr)) return;
+
+      temp.add(curr);
+      const manifest = registry.get(curr);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          visit(depName);
+        }
+      }
+      temp.delete(curr);
+      visited.add(curr);
+      result.push(curr);
+    };
+
+    visit(name);
+    return result;
+  }
+
+  flattenDependencies(name: string, registry: RegistryService): string[] {
+    const deps = new Set<string>();
+    
+    const visit = (curr: string) => {
+      const manifest = registry.get(curr);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          if (!deps.has(depName)) {
+            deps.add(depName);
+            visit(depName);
+          }
+        }
+      }
+    };
+
+    visit(name);
+    return Array.from(deps);
+  }
+
+  hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return this.detectCycles(name, registry) !== null;
+  }
+}
