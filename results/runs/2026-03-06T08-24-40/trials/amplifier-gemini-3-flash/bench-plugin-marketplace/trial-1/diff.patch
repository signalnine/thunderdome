@@ -0,0 +1,80 @@
+import { PluginRegistry } from './registry.js';
+import { VersionResolver } from './resolver.js';
+import { SandboxedRunner } from './sandbox.js';
+import { ReviewSystem } from './reviews.js';
+import { DependencyGraph } from './graph.js';
+import { 
+  PluginManifest, 
+  RegistryService, 
+  ResolverService, 
+  RunnerService, 
+  ReviewService, 
+  DepsService,
+  ResolvedVersion,
+  SandboxResult
+} from './types.js';
+
+export interface Marketplace {
+  registry: RegistryService;
+  resolver: ResolverService;
+  runner: RunnerService;
+  reviews: ReviewService;
+  graph: DepsService;
+  installPlugin(manifest: PluginManifest): Promise<{
+    resolvedDependencies: ResolvedVersion[];
+    executionResult: SandboxResult;
+  }>;
+}
+
+export function createMarketplace(dbPath: string = ':memory:'): Marketplace {
+  const registry = new PluginRegistry(dbPath);
+  const resolver = new VersionResolver();
+  const runner = new SandboxedRunner();
+  const reviews = new ReviewSystem(dbPath);
+  const graph = new DependencyGraph();
+
+  return {
+    registry,
+    resolver,
+    runner,
+    reviews,
+    graph,
+
+    async installPlugin(manifest: PluginManifest) {
+      // 1. Validate required fields
+      if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+        throw new Error('Invalid manifest: name, version, and entryPoint are required');
+      }
+
+      // 2. Register the plugin
+      registry.register(manifest);
+
+      // 3. Resolve dependency versions
+      const constraints = Object.entries(manifest.dependencies).map(([name, range]) => ({
+        name,
+        range,
+      }));
+
+      const available: Record<string, string[]> = {};
+      for (const depName of Object.keys(manifest.dependencies)) {
+        available[depName] = registry.listVersions(depName);
+      }
+
+      const resolvedDependencies = resolver.resolve(constraints, available);
+
+      // 4. Check for circular dependencies
+      if (graph.hasCircularDependency(manifest.name, registry)) {
+        registry.remove(manifest.name, manifest.version);
+        throw new Error(`Circular dependency detected for plugin: ${manifest.name}`);
+      }
+
+      // 5. Execute the plugin's entry point
+      const executionResult = await runner.execute(manifest.entryPoint);
+
+      return {
+        resolvedDependencies,
+        executionResult,
+      };
+    },
+  };
+}
