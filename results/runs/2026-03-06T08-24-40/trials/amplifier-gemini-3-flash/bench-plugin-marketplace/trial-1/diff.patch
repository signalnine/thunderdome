@@ -0,0 +1,266 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from '../src/index.js';
+import { PluginManifest } from '../src/types.js';
+
+describe('Plugin Marketplace', () => {
+  let marketplace: ReturnType<typeof createMarketplace>;
+
+  beforeEach(() => {
+    marketplace = createMarketplace(':memory:');
+  });
+
+  describe('Plugin Registry', () => {
+    it('should register and retrieve a plugin', () => {
+      const manifest: PluginManifest = {
+        name: 'test-plugin',
+        version: '1.0.0',
+        description: 'A test plugin',
+        author: 'Test Author',
+        dependencies: {},
+        entryPoint: 'console.log("hello")',
+        permissions: [],
+      };
+
+      marketplace.registry.register(manifest);
+      const retrieved = marketplace.registry.getVersion('test-plugin', '1.0.0');
+      expect(retrieved).toEqual(manifest);
+    });
+
+    it('should list all plugins', () => {
+      const p1: PluginManifest = {
+        name: 'p1',
+        version: '1.0.0',
+        description: 'd1',
+        author: 'a1',
+        dependencies: {},
+        entryPoint: 'e1',
+        permissions: [],
+      };
+      const p2: PluginManifest = {
+        name: 'p2',
+        version: '1.1.0',
+        description: 'd2',
+        author: 'a2',
+        dependencies: {},
+        entryPoint: 'e2',
+        permissions: [],
+      };
+
+      marketplace.registry.register(p1);
+      marketplace.registry.register(p2);
+
+      const list = marketplace.registry.list();
+      expect(list).toHaveLength(2);
+      expect(list.map(p => p.name)).toContain('p1');
+      expect(list.map(p => p.name)).toContain('p2');
+    });
+
+    it('should search plugins', () => {
+      const p1: PluginManifest = {
+        name: 'auth-plugin',
+        version: '1.0.0',
+        description: 'Authentication',
+        author: 'a1',
+        dependencies: {},
+        entryPoint: 'e1',
+        permissions: [],
+      };
+      marketplace.registry.register(p1);
+
+      const results = marketplace.registry.search('auth');
+      expect(results).toHaveLength(1);
+      expect(results[0].name).toBe('auth-plugin');
+    });
+  });
+
+  describe('Version Resolver', () => {
+    it('should resolve versions correctly', () => {
+      const available = {
+        'plugin-a': ['1.0.0', '1.1.0', '2.0.0'],
+      };
+      const constraints = [
+        { name: 'plugin-a', range: '^1.0.0' },
+      ];
+
+      const resolved = marketplace.resolver.resolve(constraints, available);
+      expect(resolved).toHaveLength(1);
+      expect(resolved[0].version).toBe('1.1.0');
+    });
+
+    it('should throw error if no version satisfies constraint', () => {
+      const available = {
+        'plugin-a': ['1.0.0'],
+      };
+      const constraints = [
+        { name: 'plugin-a', range: '>=2.0.0' },
+      ];
+
+      expect(() => marketplace.resolver.resolve(constraints, available)).toThrow();
+    });
+  });
+
+  describe('Sandboxed Runner', () => {
+    it('should execute code and return result', async () => {
+      const result = await marketplace.runner.execute('1 + 1');
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(2);
+    });
+
+    it('should handle errors in sandbox', async () => {
+      const result = await marketplace.runner.execute('throw new Error("fail")');
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('fail');
+    });
+
+    it('should enforce timeout', async () => {
+      const result = await marketplace.runner.executeWithTimeout('while(true){}', 100);
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Script execution timed out');
+    });
+
+    it('should support context variables', async () => {
+      const result = await marketplace.runner.execute('x * y', { x: 5, y: 10 });
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(50);
+    });
+  });
+
+  describe('Review System', () => {
+    it('should add and retrieve reviews', () => {
+      marketplace.reviews.addReview({
+        pluginName: 'p1',
+        pluginVersion: '1.0.0',
+        userId: 'u1',
+        rating: 5,
+        comment: 'Great!',
+      });
+
+      const reviews = marketplace.reviews.getReviews('p1');
+      expect(reviews).toHaveLength(1);
+      expect(reviews[0].rating).toBe(5);
+    });
+
+    it('should compute average rating excluding flagged reviews', () => {
+      const r1 = marketplace.reviews.addReview({
+        pluginName: 'p1',
+        pluginVersion: '1.0.0',
+        userId: 'u1',
+        rating: 5,
+        comment: 'G',
+      });
+      marketplace.reviews.addReview({
+        pluginName: 'p1',
+        pluginVersion: '1.0.0',
+        userId: 'u2',
+        rating: 1,
+        comment: 'B',
+      });
+
+      expect(marketplace.reviews.getAverageRating('p1')).toBe(3);
+
+      marketplace.reviews.flagReview(r1.id);
+      expect(marketplace.reviews.getAverageRating('p1')).toBe(1);
+    });
+  });
+
+  describe('Dependency Graph', () => {
+    it('should build dependency tree', () => {
+      marketplace.registry.register({
+        name: 'a', version: '1.0.0', dependencies: { 'b': '1.0.0' },
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+      marketplace.registry.register({
+        name: 'b', version: '1.0.0', dependencies: {},
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+
+      const tree = marketplace.graph.buildTree('a', marketplace.registry);
+      expect(tree.name).toBe('a');
+      expect(tree.dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].name).toBe('b');
+    });
+
+    it('should detect circular dependencies', () => {
+      marketplace.registry.register({
+        name: 'a', version: '1.0.0', dependencies: { 'b': '1.0.0' },
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+      marketplace.registry.register({
+        name: 'b', version: '1.0.0', dependencies: { 'a': '1.0.0' },
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+
+      expect(marketplace.graph.hasCircularDependency('a', marketplace.registry)).toBe(true);
+      const cycles = marketplace.graph.detectCycles('a', marketplace.registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles![0]).toContain('a');
+      expect(cycles![0]).toContain('b');
+    });
+
+    it('should perform topological sort', () => {
+      marketplace.registry.register({
+        name: 'a', version: '1.0.0', dependencies: { 'b': '1.0.0' },
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+      marketplace.registry.register({
+        name: 'b', version: '1.0.0', dependencies: { 'c': '1.0.0' },
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+      marketplace.registry.register({
+        name: 'c', version: '1.0.0', dependencies: {},
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+
+      const order = marketplace.graph.topologicalSort('a', marketplace.registry);
+      expect(order).toEqual(['c', 'b', 'a']);
+    });
+  });
+
+  describe('Integration Layer', () => {
+    it('should install plugin successfully', async () => {
+      marketplace.registry.register({
+        name: 'dep-a', version: '1.0.0', dependencies: {},
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+
+      const manifest: PluginManifest = {
+        name: 'main-plugin',
+        version: '1.0.0',
+        description: 'Main',
+        author: 'Me',
+        dependencies: { 'dep-a': '^1.0.0' },
+        entryPoint: '({ result: "ok" })',
+        permissions: [],
+      };
+
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toEqual({ result: 'ok' });
+    });
+
+    it('should reject plugin with circular dependencies', async () => {
+      // Note: installPlugin registers the plugin before checking circular deps
+      // but it should cleanup if it finds one.
+      
+      marketplace.registry.register({
+        name: 'b', version: '1.0.0', dependencies: { 'a': '1.0.0' },
+        description: '', author: '', entryPoint: '', permissions: []
+      });
+
+      const manifest: PluginManifest = {
+        name: 'a',
+        version: '1.0.0',
+        description: '',
+        author: '',
+        dependencies: { 'b': '1.0.0' },
+        entryPoint: 'console.log("a")',
+        permissions: [],
+      };
+
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency detected');
+      expect(marketplace.registry.getVersion('a', '1.0.0')).toBeNull();
+    });
+  });
+});
