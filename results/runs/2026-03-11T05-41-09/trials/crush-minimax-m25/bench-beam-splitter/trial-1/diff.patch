+type Direction = 0 | -1 | 1;
+
+interface BeamState {
+  row: number;
+  col: number;
+  direction: Direction;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  if (cols === 0) return 0;
+
+  const visited = new Set<string>();
+  const queue: BeamState[] = [];
+
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      queue.push({ row: 0, col: c, direction: 0 });
+      visited.add(`0,${c}`);
+    }
+  }
+
+  const directionDeltas: Record<Direction, number> = {
+    0: 0,
+    [-1]: -1,
+    [1]: 1,
+  };
+
+  while (queue.length > 0) {
+    const beam = queue.shift()!;
+    const { row, col, direction } = beam;
+
+    const nextRow = row + 1;
+    if (nextRow >= rows) continue;
+
+    const nextCol = col + directionDeltas[direction];
+    if (nextCol < 0 || nextCol >= cols) continue;
+
+    const cell = grid[nextRow][nextCol];
+    const stateKey = `${nextRow},${nextCol}`;
+
+    if (cell === '^') {
+      if (!visited.has(stateKey)) {
+        visited.add(stateKey);
+        queue.push({ row: nextRow, col: nextCol, direction: -1 });
+        queue.push({ row: nextRow, col: nextCol, direction: 1 });
+      }
+    } else {
+      if (!visited.has(stateKey)) {
+        visited.add(stateKey);
+        queue.push({ row: nextRow, col: nextCol, direction });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  if (cols === 0) return 0n;
+
+  const memo = new Map<string, bigint>();
+
+  function computePaths(row: number, col: number, direction: Direction): bigint {
+    const key = `${row},${col},${direction}`;
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    if (row < 0 || row >= rows || col < 0 || col >= cols) {
+      return 1n;
+    }
+
+    const cell = grid[row][col];
+    let result: bigint;
+
+    if (cell === '^') {
+      result = computePaths(row + 1, col - 1, -1) + computePaths(row + 1, col + 1, 1);
+    } else {
+      const delta = direction;
+      result = computePaths(row + 1, col + delta, direction);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  let totalPaths = 0n;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      totalPaths += computePaths(1, c, 0);
+    }
+  }
+
+  return totalPaths;
+}
