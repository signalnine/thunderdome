index 0000000..2d44e50
--- /dev/null
+++ b/src/parser.ts
@@ -0,0 +1,252 @@
+import type { ASTNode } from './types.js';
+
+type Token =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'ident'; value: string }
+  | { type: 'op'; value: string }
+  | { type: 'lparen' }
+  | { type: 'rparen' }
+  | { type: 'comma' }
+  | { type: 'colon' };
+
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    const ch = input[i];
+
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    if (ch === '"') {
+      i++;
+      let str = '';
+      while (i < input.length && input[i] !== '"') {
+        str += input[i];
+        i++;
+      }
+      if (i < input.length) i++; // skip closing quote
+      tokens.push({ type: 'string', value: str });
+      continue;
+    }
+
+    if (ch >= '0' && ch <= '9') {
+      let num = '';
+      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {
+        num += input[i];
+        i++;
+      }
+      tokens.push({ type: 'number', value: parseFloat(num) });
+      continue;
+    }
+
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let ident = '';
+      while (i < input.length && ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z') || (input[i] >= '0' && input[i] <= '9'))) {
+        ident += input[i];
+        i++;
+      }
+      const upper = ident.toUpperCase();
+      if (upper === 'TRUE') {
+        tokens.push({ type: 'boolean', value: true });
+      } else if (upper === 'FALSE') {
+        tokens.push({ type: 'boolean', value: false });
+      } else {
+        tokens.push({ type: 'ident', value: upper });
+      }
+      continue;
+    }
+
+    if (ch === '(') { tokens.push({ type: 'lparen' }); i++; continue; }
+    if (ch === ')') { tokens.push({ type: 'rparen' }); i++; continue; }
+    if (ch === ',') { tokens.push({ type: 'comma' }); i++; continue; }
+    if (ch === ':') { tokens.push({ type: 'colon' }); i++; continue; }
+
+    if (ch === '<' && i + 1 < input.length && input[i + 1] === '>') {
+      tokens.push({ type: 'op', value: '<>' }); i += 2; continue;
+    }
+    if (ch === '<' && i + 1 < input.length && input[i + 1] === '=') {
+      tokens.push({ type: 'op', value: '<=' }); i += 2; continue;
+    }
+    if (ch === '>' && i + 1 < input.length && input[i + 1] === '=') {
+      tokens.push({ type: 'op', value: '>=' }); i += 2; continue;
+    }
+
+    if ('+-*/>=<'.includes(ch)) {
+      tokens.push({ type: 'op', value: ch }); i++; continue;
+    }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  return tokens;
+}
+
+const CELL_REF_RE = /^[A-Z]+[0-9]+$/;
+
+function isCellRef(s: string): boolean {
+  return CELL_REF_RE.test(s);
+}
+
+export function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  let pos = 0;
+
+  function peek(): Token | undefined {
+    return tokens[pos];
+  }
+
+  function advance(): Token {
+    return tokens[pos++];
+  }
+
+  function expect(type: string): Token {
+    const t = advance();
+    if (t.type !== type) throw new Error(`Expected ${type} but got ${t.type}`);
+    return t;
+  }
+
+  function parseExpression(): ASTNode {
+    return parseComparison();
+  }
+
+  function parseComparison(): ASTNode {
+    let left = parseAddSub();
+    while (peek() && peek()!.type === 'op' && ['>', '<', '>=', '<=', '=', '<>'].includes((peek() as { value: string }).value)) {
+      const op = (advance() as { value: string }).value;
+      const right = parseAddSub();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  function parseAddSub(): ASTNode {
+    let left = parseMulDiv();
+    while (peek() && peek()!.type === 'op' && (peek() as { value: string }).value === '+' || peek() && peek()!.type === 'op' && (peek() as { value: string }).value === '-') {
+      const op = (advance() as { value: string }).value;
+      const right = parseMulDiv();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  function parseMulDiv(): ASTNode {
+    let left = parseUnary();
+    while (peek() && peek()!.type === 'op' && ((peek() as { value: string }).value === '*' || (peek() as { value: string }).value === '/')) {
+      const op = (advance() as { value: string }).value;
+      const right = parseUnary();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  function parseUnary(): ASTNode {
+    if (peek() && peek()!.type === 'op' && (peek() as { value: string }).value === '-') {
+      advance();
+      const operand = parseUnary();
+      return { type: 'unary', op: '-', operand };
+    }
+    if (peek() && peek()!.type === 'op' && (peek() as { value: string }).value === '+') {
+      advance();
+      return parseUnary();
+    }
+    return parsePrimary();
+  }
+
+  function parsePrimary(): ASTNode {
+    const t = peek();
+    if (!t) throw new Error('Unexpected end of formula');
+
+    if (t.type === 'number') {
+      advance();
+      return { type: 'number', value: t.value };
+    }
+
+    if (t.type === 'string') {
+      advance();
+      return { type: 'string', value: t.value };
+    }
+
+    if (t.type === 'boolean') {
+      advance();
+      return { type: 'boolean', value: t.value };
+    }
+
+    if (t.type === 'lparen') {
+      advance();
+      const expr = parseExpression();
+      expect('rparen');
+      return expr;
+    }
+
+    if (t.type === 'ident') {
+      advance();
+      const name = t.value;
+
+      // Check if it's a function call
+      if (peek() && peek()!.type === 'lparen') {
+        advance(); // consume '('
+        const args: ASTNode[] = [];
+        if (peek() && peek()!.type !== 'rparen') {
+          args.push(parseArg());
+          while (peek() && peek()!.type === 'comma') {
+            advance();
+            args.push(parseArg());
+          }
+        }
+        expect('rparen');
+        return { type: 'call', name, args };
+      }
+
+      // Check if it's a cell reference
+      if (isCellRef(name)) {
+        // Check for range
+        if (peek() && peek()!.type === 'colon') {
+          advance();
+          const endToken = advance();
+          if (endToken.type !== 'ident' || !isCellRef(endToken.value)) {
+            throw new Error('Expected cell reference after colon');
+          }
+          return { type: 'range', start: name, end: endToken.value };
+        }
+        return { type: 'cellref', ref: name };
+      }
+
+      throw new Error(`Unknown identifier: ${name}`);
+    }
+
+    throw new Error(`Unexpected token: ${t.type}`);
+  }
+
+  function parseArg(): ASTNode {
+    // Check for range pattern: IDENT:IDENT
+    if (peek() && peek()!.type === 'ident') {
+      const saved = pos;
+      const first = advance() as { type: 'ident'; value: string };
+      if (peek() && peek()!.type === 'colon' && isCellRef(first.value)) {
+        advance(); // consume ':'
+        const second = peek();
+        if (second && second.type === 'ident' && isCellRef(second.value)) {
+          advance();
+          return { type: 'range', start: first.value, end: second.value };
+        }
+        // backtrack
+        pos = saved;
+      } else {
+        pos = saved;
+      }
+    }
+    return parseExpression();
+  }
+
+  const ast = parseExpression();
+  if (pos < tokens.length) {
+    throw new Error(`Unexpected token at position ${pos}`);
+  }
+  return ast;
+}
