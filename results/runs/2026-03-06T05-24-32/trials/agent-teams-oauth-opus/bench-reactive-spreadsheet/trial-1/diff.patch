+++ b/src/index.ts
@@ -0,0 +1,339 @@
+import { parseFormula } from './parser.js';
+import type { ASTNode, CellValue } from './types.js';
+
+function parseColRow(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  const letters = match[1];
+  const row = parseInt(match[2], 10);
+  let col = 0;
+  for (let i = 0; i < letters.length; i++) {
+    col = col * 26 + (letters.charCodeAt(i) - 64);
+  }
+  return { col, row };
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseColRow(start);
+  const e = parseColRow(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+
+  const refs: string[] = [];
+  for (let c = minCol; c <= maxCol; c++) {
+    for (let r = minRow; r <= maxRow; r++) {
+      refs.push(colToLetters(c) + r);
+    }
+  }
+  return refs;
+}
+
+function colToLetters(col: number): string {
+  let result = '';
+  while (col > 0) {
+    const rem = (col - 1) % 26;
+    result = String.fromCharCode(65 + rem) + result;
+    col = Math.floor((col - 1) / 26);
+  }
+  return result;
+}
+
+function normalizeRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: CellValue;
+  deps: Set<string>; // cells this cell depends on
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private dependents: Map<string, Set<string>> = new Map(); // reverse deps: cell -> cells that depend on it
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+    const oldData = this.cells.get(ref);
+
+    // Remove old reverse dependencies
+    if (oldData) {
+      for (const dep of oldData.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.slice(1));
+      deps = this.collectDeps(formula);
+    }
+
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      value: null,
+      deps,
+    };
+
+    this.cells.set(ref, cellData);
+
+    // Add new reverse dependencies
+    for (const dep of deps) {
+      let set = this.dependents.get(dep);
+      if (!set) {
+        set = new Set();
+        this.dependents.set(dep, set);
+      }
+      set.add(ref);
+    }
+
+    // Check for circular references before evaluating
+    this.checkCircular(ref);
+
+    // Evaluate this cell
+    cellData.value = this.evaluate(cellData);
+
+    // Propagate changes to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private collectDeps(node: ASTNode): Set<string> {
+    const deps = new Set<string>();
+    this.walkDeps(node, deps);
+    return deps;
+  }
+
+  private walkDeps(node: ASTNode, deps: Set<string>): void {
+    switch (node.type) {
+      case 'cellref':
+        deps.add(node.ref);
+        break;
+      case 'range': {
+        const refs = expandRange(node.start, node.end);
+        for (const r of refs) deps.add(r);
+        break;
+      }
+      case 'binop':
+        this.walkDeps(node.left, deps);
+        this.walkDeps(node.right, deps);
+        break;
+      case 'unary':
+        this.walkDeps(node.operand, deps);
+        break;
+      case 'call':
+        for (const arg of node.args) this.walkDeps(arg, deps);
+        break;
+    }
+  }
+
+  private checkCircular(startRef: string): void {
+    const visited = new Set<string>();
+    const stack = new Set<string>();
+
+    const dfs = (ref: string): void => {
+      if (stack.has(ref)) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      stack.add(ref);
+
+      const data = this.cells.get(ref);
+      if (data) {
+        for (const dep of data.deps) {
+          dfs(dep);
+        }
+      }
+
+      stack.delete(ref);
+    };
+
+    dfs(startRef);
+  }
+
+  private evaluate(data: CellData): CellValue {
+    if (!data.formula) {
+      if (typeof data.raw === 'string' && !data.raw.startsWith('=')) {
+        return data.raw;
+      }
+      if (typeof data.raw === 'number' || typeof data.raw === 'boolean') {
+        return data.raw;
+      }
+      return null;
+    }
+    return this.evalNode(data.formula);
+  }
+
+  private evalNode(node: ASTNode): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cellref': {
+        const data = this.cells.get(node.ref);
+        if (!data) return 0;
+        return data.value ?? 0;
+      }
+      case 'unary': {
+        const val = this.evalNode(node.operand);
+        if (node.op === '-') return -(val as number);
+        return val;
+      }
+      case 'binop': {
+        const left = this.evalNode(node.left);
+        const right = this.evalNode(node.right);
+        return this.evalBinop(node.op, left, right);
+      }
+      case 'call':
+        return this.evalCall(node.name, node.args);
+      case 'range':
+        throw new Error('Range cannot be used outside a function');
+      default:
+        throw new Error(`Unknown node type`);
+    }
+  }
+
+  private evalBinop(op: string, left: CellValue, right: CellValue): CellValue {
+    const l = left as number;
+    const r = right as number;
+    switch (op) {
+      case '+': return l + r;
+      case '-': return l - r;
+      case '*': return l * r;
+      case '/': return l / r;
+      case '>': return l > r;
+      case '<': return l < r;
+      case '>=': return l >= r;
+      case '<=': return l <= r;
+      case '=': return left === right;
+      case '<>': return left !== right;
+      default:
+        throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  private evalCall(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        const values = this.resolveNumericArgs(args);
+        return values.reduce((a, b) => a + b, 0);
+      }
+      case 'AVERAGE': {
+        const values = this.resolveNumericArgs(args);
+        if (values.length === 0) return 0;
+        return values.reduce((a, b) => a + b, 0) / values.length;
+      }
+      case 'MIN': {
+        const values = this.resolveNumericArgs(args);
+        if (values.length === 0) return 0;
+        return Math.min(...values);
+      }
+      case 'MAX': {
+        const values = this.resolveNumericArgs(args);
+        if (values.length === 0) return 0;
+        return Math.max(...values);
+      }
+      case 'COUNT': {
+        const values = this.resolveNumericArgs(args);
+        return values.length;
+      }
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evalNode(args[0]);
+        if (condition && condition !== 0) {
+          return this.evalNode(args[1]);
+        }
+        return this.evalNode(args[2]);
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+
+  private resolveNumericArgs(args: ASTNode[]): number[] {
+    const values: number[] = [];
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const refs = expandRange(arg.start, arg.end);
+        for (const ref of refs) {
+          const data = this.cells.get(ref);
+          if (data && typeof data.value === 'number') {
+            values.push(data.value);
+          }
+        }
+      } else {
+        const val = this.evalNode(arg);
+        if (typeof val === 'number') {
+          values.push(val);
+        }
+      }
+    }
+    return values;
+  }
+
+  private propagate(changedRef: string): void {
+    // Topological sort of all dependents, then re-evaluate in order
+    const order: string[] = [];
+    const visited = new Set<string>();
+
+    const dfs = (ref: string): void => {
+      const deps = this.dependents.get(ref);
+      if (!deps) return;
+      for (const dep of deps) {
+        if (visited.has(dep)) continue;
+        visited.add(dep);
+        dfs(dep);
+        order.push(dep);
+      }
+    };
+
+    dfs(changedRef);
+
+    // Re-evaluate in topological order (reverse of post-order gives us correct order,
+    // but since we push after recursive calls, we should reverse)
+    // Actually for this DAG, the order we push is already leaf-first, so we need to reverse
+    // to get root-first. But we want to evaluate dependencies first, so we actually want
+    // the order as-is (post-order = dependencies evaluated first).
+    // Wait - let's think again. If B depends on A, and C depends on B:
+    // dfs(A) -> visits B, recurses to C, pushes C, pushes B
+    // So order = [C, B]. But we need B before C. So we reverse.
+    order.reverse();
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data) {
+        data.value = this.evaluate(data);
+      }
+    }
+  }
+}
