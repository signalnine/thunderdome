+import { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+let assetManifest: string[] = [];
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const assetManifest = ctx.data.get('asset-manifest') as string[] | undefined;
+        const searchIndex = ctx.output.get('search-index.json') || '';
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes: [],
+          assetPaths: assetManifest || [],
+          searchIndexPath: searchIndex ? '/search-index.json' : '',
