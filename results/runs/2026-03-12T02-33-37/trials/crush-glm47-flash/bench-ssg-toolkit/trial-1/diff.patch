+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const searchIndex = ctx.files.map(file => {
+          const plainContent = stripHTMLTags(file.content);
+          return {
+            slug: file.slug,
+            title: file.title,
+            content: plainContent,
+            tags: file.tags || [],
+          };
+        });
+
+        const searchIndexJson = JSON.stringify(searchIndex, null, 2);
+        ctx.output.set('search-index.json', searchIndexJson);
+      },
+    },
+  };
+}
+
+function stripHTMLTags(text: string): string {
+  if (typeof text !== 'string') {
+    return text;
+  }
+  return text.replace(/<[^>]*>/g, '');
+}
