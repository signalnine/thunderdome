+import { marked } from 'marked';
+import { Plugin, ContentFile } from '../core/types.js';
+
+function escapeHtml(text: string): string {
+  if (typeof text !== 'string') {
+    return text;
+  }
+  return text
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;');
+}
+
+function createAdmonition(type: string): string {
+  const titles: Record<string, string> = {
+    note: 'Note',
+    warning: 'Warning',
+    tip: 'Tip',
+  };
+  const title = titles[type] || 'NOTE';
+  return `<div class="admonition admonition-${type}">
+  <strong>${title}</strong>
+</div>`;
+}
+
+let footnoteCounter = 0;
+
+export function createMarkdownExtPlugin(): Plugin {
+  const activeFootnotes: Map<number, string> = new Map();
+
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: ContentFile): Promise<ContentFile> {
+        if (!file.content) {
+          return file;
+        }
+
+        let markdown = file.content;
+
+        const admonitionPattern = /:::(note|warning|tip)\n(.*?)\n:::/gs;
+        markdown = markdown.replace(admonitionPattern, (_match, type, content) => {
+          const outer = createAdmonition(type);
+          const inner = content.trim().split('\n')[0];
+          return `${outer} ${inner}`;
+        });
+
+        const footnotePattern = /\[\^(\d+)\]:\s*(.*)$/gm;
+        let match;
+        while ((match = footnotePattern.exec(markdown)) !== null) {
+          const number = parseInt(match[1]);
+          const text = match[2] || '';
+          if (!activeFootnotes.has(number)) {
+            activeFootnotes.set(number, text);
+          }
+        }
+
+        const footnoteIds = Array.from(activeFootnotes.keys())
+          .sort((a, b) => a - b);
+
+        const footnoteLinks = message => {
+          const number = match[1];
+          return `<sup><a href="#fn-${number}">[${number}]</a></sup>`;
+        };
+
+        const contentWithLinks = content.replace(/\[\^(\d+)\]/g, (_match, number) => {
+  return `<sup><a href="#fn-${number}">[${number}]</a></sup>`;
+});
+
+        const footnotesList = footnoteIds
+          .map(num => {
+            const text = activeFootnotes.get(num) || '';
+            return `<li id="fn-${num}">${escapeHtml(text)}</li>`;
+          })
+          .join('\n');
+
+        const footnoteSection = `
+<section class="footnotes">
+  <hr>
+  <ol>
+    ${footnotesList}
+  </ol>
+</section>`;
+
+        const html = marked.parse(contentWithLinks);
+
+        const existingFootnotes = html.match(/<section class="footnotes">[\s\S]*?<\/section>/gi);
+
+        return {
+          ...file,
+          content: existingFootnotes ? html + footnoteSection : html,
+        };
+      },
+    },
+  };
+}
