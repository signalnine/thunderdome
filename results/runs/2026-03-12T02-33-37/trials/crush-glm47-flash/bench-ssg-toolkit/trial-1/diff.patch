+import { Plugin, BuildContext } from '../core/types.js';
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        let urls = new Set<string>();
+        const baseUrl = ctx.config.baseUrl;
+
+        for (const [path] of ctx.output) {
+          urls.add(`${baseUrl}/${path}`);
+        }
+
+        const urlsArray = Array.from(urls);
+
+        const sitemapXml = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+${urlsArray.map(url => `  <url>
+    <loc>${url}</loc>
+    <priority>1.0</priority>
+    <changefreq>daily</changefreq>
+  </url>`).join('\n')}
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemapXml);
+      },
+    },
+  };
+}
