+import { Plugin, ContentFile } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: ContentFile): Promise<ContentFile> {
+        if (!file.content) {
+          return file;
+        }
+
+        let content = file.content;
+
+        const codeBlockRegex = /<pre><code(?: class="language-([a-zA-Z0-9]-+))?"?(.*?)>(.*?)<\/code><\/pre>/gi;
+        let modified = false;
+
+        content = content.replace(codeBlockRegex, (_match, lang, attrs, code) => {
+          const languageName = lang || 'plain';
+
+          if (!lang) {
+            return _match;
+          }
+
+          const dataAttr = ` data-language="${languageName}"`;
+          modified = true;
+
+          if (hasLanguageClass) {
+            return `<pre><code${attrs} class="language-${languageName} highlighted"${dataAttr}>${code}</code></pre>`;
+          }
+          return `<pre><code class="language-${languageName} highlighted"${dataAttr}>${code}</code></pre>`;
+        });
+
+        return { ...file, content };
+      },
+    },
+  };
+}
