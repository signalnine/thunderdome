+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function escapeHtml(text: string): string {
+  if (typeof text !== 'string') {
+    return text;
+  }
+  return text
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;');
+}
+
+function escapeCData(text: string): string {
+  if (typeof text !== 'string') {
+    return text;
+  }
+  return text
+    .replace(/\]\]>/g, ']]]]><![CDATA[>')
+    .replace(/]]>/g, ']]&gt;');
+}
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        const validFiles = ctx.files
+          .filter(file => file.date)
+          .map(file => ({
+            ...file,
+            date: new Date(file.date!),
+          }))
+          .sort((a, b) => b.date.getTime() - a.date.getTime());
+
+        const feedItems = validFiles.map(file => {
+          let categoryTags = '';
+
+          if (tagMap && file.tags) {
+            const categories = file.tags
+              .filter(tag => {
+                const normalizedTag = tag.toLowerCase().trim();
+                return tagMap?.has(normalizedTag);
+              })
+              .map(tag => `<category>${escapeHtml(tag)}</category>`);
+
+            if (categories.length > 0) {
+              categoryTags = categories.join('\n    ');
+            }
+          }
+
+          const pubDate = file.date ? new Date(file.date).toUTCString() : '';
+
+          const isHtml = file.content.includes('<');
+          const contentTag = isHtml
+            ? `<![CDATA[${file.content}]]>`
+            : escapeCData(file.content);
+
+          return `<item>
+    <title>${escapeHtml(file.title)}</title>
+    <link>${ctx.config.baseUrl}/${file.slug}.html</link>
+    <pubDate>${pubDate}</pubDate>
+    ${categoryTags}
+  </item>`;
+        }).join('\n');
+
+        const feedXml = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeHtml(ctx.config.title)}</title>
+    <link>${ctx.config.baseUrl}</link>
+<atom:link href="${ctx.config.baseUrl}/feed.xml" rel="self" type="application/rss+xml"/>
+    ${feedItems}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feedXml);
+      },
+    },
+  };
+}
