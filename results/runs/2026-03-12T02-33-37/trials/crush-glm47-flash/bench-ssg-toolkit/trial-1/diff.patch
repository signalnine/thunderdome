+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+let tagMap: Map<string, ContentFile[]> = new Map();
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async beforeBuild(ctx: BuildContext): Promise<void> {
+        tagMap = new Map();
+        const filesGrouped: Map<string, ContentFile[]> = new Map();
+
+        for (const file of ctx.files) {
+          const tags = file.tags;
+          if (tags && Array.isArray(tags) && tags.length > 0) {
+            for (const tag of tags) {
+              const normalizedTag = tag.toLowerCase().trim();
+              if (!filesGrouped.has(normalizedTag)) {
+                filesGrouped.set(normalizedTag, []);
+              }
+              filesGrouped.get(normalizedTag)!.push(file);
+            }
+          }
+        }
+
+        tagMap = filesGrouped;
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        if (tagMap.size === 0) {
+          return;
+        }
+
+        for (const [tag, posts] of tagMap) {
+          const postsHtml = posts
+            .map(post => `<h2><a href="${post.slug}.html">${escapeHtml(post.title)}</a></h2>`)
+            .join('\n');
+
+          const tagPageHtml = `<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <title>${escapeHtml(tag)} | ${ctx.config.title}</title>
+</head>
+<body>
+  <article>
+    <h1>Tag: ${escapeHtml(tag)}</h1>
+    <div class="content">
+      ${postsHtml}
+    </div>
+  </article>
+</body>
+</html>`;
+
+          ctx.output.set(`tags/${tag}.html`, tagPageHtml);
+        }
+      },
+    },
+  };
+}
+
+function escapeHtml(text: string): string {
+  if (typeof text !== 'string') {
+    return text;
+  }
+  return text
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;');
+}
+
+function escapeCData(text: string): string {
+  return text
+    .replace(/\]\]>/g, ']]]]><![CDATA[>')
+    .replace(/]]>/g, ']]&gt;');
+}
