+import { Plugin, ContentFile } from '../core/types.js';
+
+let assetManifest: string[] = [];
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: ContentFile): Promise<ContentFile> {
+        if (!file.content) {
+          return file;
+        }
+
+        let content = file.content;
+
+        const assetRegex = /(src|href)="([^"]*(?:\.png|\.jpg|\.jpeg|\.gif|\.svg|\.webp|\.pdf|\.css|\.js)(?:\"|'|$))/gi;
+        let hasAssets = false;
+        let capturedAssets: string[] = [];
+
+        content = content.replace(assetRegex, (match, attr, path) => {
+          if (path.startsWith('http') || path.startsWith('/assets/')) {
+            return match;
+          }
+
+          hasAssets = true;
+          const cleanPath = path.replace(/['"]/g, '');
+          capturedAssets.push(cleanPath);
+
+          if (cleanPath.startsWith('./') || cleanPath.startsWith('../')) {
+            const relativePath = cleanPath.replace(/^\.+/, '');
+            return `${attr}="/assets${relativePath}"`;
+          }
+
+          return `${attr}="/assets/${cleanPath}"`;
+        });
+
+        if (hasAssets && capturedAssets.length > 0) {
+          const currentSlug = file.slug.toLowerCase().replace(/\//g, '-');
+          const manifestEntry = `${currentSlug}-${Date.now()}-${capturedAssets[0].replace(/\./g, '-')}`;
+          if (!ctx.data.has('asset-manifest')) {
+            ctx.data.set('asset-manifest', { assets: [] });
+          }
+          const manifest = ctx.data.get('asset-manifest') as { assets: string[] };
+          if (!manifest.assets.includes(manifestEntry)) {
+            manifest.assets.push(manifestEntry);
+          }
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
