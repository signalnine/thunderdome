diff --git a/src/index.test.ts b/src/index.test.ts
new file mode 100644
index 0000000..6575a1f
--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,104 @@
+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions, Assignment } from './index.js';
+
+describe('Constraint-Based Event Scheduler', () => {
+  const rooms: Room[] = [
+    { id: 'r1', name: 'Small Room', capacity: 10 },
+    { id: 'r2', name: 'Large Room', capacity: 50 },
+  ];
+
+  const options: ScheduleOptions = {
+    startTime: 540, // 9:00 AM
+    endTime: 1020,  // 5:00 PM
+    gap: 15,
+  };
+
+  it('schedules a single event', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Meeting', duration: 60, attendees: 5 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments[0].eventId).toBe('e1');
+    expect(result.assignments[0].startTime).toBe(540);
+    expect(result.assignments[0].endTime).toBe(600);
+  });
+
+  it('respects room capacity', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Big Workshop', duration: 60, attendees: 40 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('respects prerequisites', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Part 1', duration: 60 },
+      { id: 'e2', name: 'Part 2', duration: 60, prerequisites: ['e1'] },
+    ];
+    const result = schedule(events, rooms, options);
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + (options.gap ?? 15));
+  });
+
+  it('throws error on prerequisite cycles', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'A', duration: 60, prerequisites: ['e2'] },
+      { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },
+    ];
+    expect(() => schedule(events, rooms, options)).toThrow(/cycle/i);
+  });
+
+  it('honors preferred room if possible', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Pref R2', duration: 60, preferredRoom: 'r2' },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('handles unschedulable events', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Too Long', duration: 1000 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toContain('e1');
+  });
+
+  it('maximizes scheduled events by picking smallest capable room', () => {
+    const rooms: Room[] = [
+      { id: 'r1', name: 'Small', capacity: 10 },
+      { id: 'r2', name: 'Large', capacity: 50 },
+    ];
+    const events: Event[] = [
+      { id: 'e1', name: 'Big Event', duration: 60, attendees: 40 },
+      { id: 'e2', name: 'Small Event', duration: 60, attendees: 5 },
+    ];
+    // If e2 (small) takes r2 (large), e1 (big) won't fit in r1.
+    // Our heuristic should put e2 in r1 and e1 in r2.
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(2);
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a1.roomId).toBe('r2');
+    expect(a2.roomId).toBe('r1');
+  });
+
+  it('respects gaps between events in the same room', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'M1', duration: 60 },
+      { id: 'e2', name: 'M2', duration: 60 },
+    ];
+    // Force them into the same small room by making the other room full or non-existent
+    const smallRooms = [rooms[0]];
+    const result = schedule(events, smallRooms, options);
+    expect(result.assignments).toHaveLength(2);
+    const sorted = [...result.assignments].sort((a: Assignment, b: Assignment) => a.startTime - b.startTime);
+    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + (options.gap ?? 15));
+  });
+});
+
