+++ b/src/index.ts
@@ -0,0 +1,278 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // 1. Prerequisite cycle detection
+  checkCycles(events);
+
+  // 2. Build dependency map and calculate earliest possible start times based on prerequisites
+  
+  // Sort events to maximize scheduled count. 
+  // Heuristic: Events with more prerequisites/dependents or shorter duration might be better to schedule first?
+  // Actually, topological order is mandatory for prerequisites.
+  
+  const sortedEvents = topologicalSort(events);
+  
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+  
+  // Track room availability: roomId -> list of {start, end} intervals
+  const roomSchedules = new Map<string, { start: number; end: number }[]>();
+  for (const room of rooms) {
+    roomSchedules.set(room.id, []);
+  }
+
+  // Track event completion times for prerequisite checks
+  const completionTimes = new Map<string, number>();
+
+  for (const event of sortedEvents) {
+    let earliestPossibleStart = options.startTime;
+    
+    // Respect prerequisites
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        const finishTime = completionTimes.get(prereqId);
+        if (finishTime === undefined) {
+          // Prerequisite wasn't scheduled, so this event can't be scheduled
+          earliestPossibleStart = Infinity;
+          break;
+        }
+        earliestPossibleStart = Math.max(earliestPossibleStart, finishTime + gap);
+      }
+    }
+
+    if (earliestPossibleStart + event.duration > options.endTime) {
+      unscheduled.push(event.id);
+      continue;
+    }
+
+    // Find best room and time
+    let bestRoomId: string | null = null;
+    let bestStartTime = Infinity;
+
+    // Try preferred room first if it exists
+    const roomsToTry = [...rooms];
+    if (event.preferredRoom) {
+      const prefIdx = roomsToTry.findIndex(r => r.id === event.preferredRoom);
+      if (prefIdx > -1) {
+        const [prefRoom] = roomsToTry.splice(prefIdx, 1);
+        roomsToTry.unshift(prefRoom);
+      }
+    }
+
+    let bestRoomCapacity = Infinity;
+
+    for (const room of roomsToTry) {
+      // Check capacity
+      if ((event.attendees ?? 1) > room.capacity) continue;
+
+      const schedule = roomSchedules.get(room.id)!;
+      const startTime = findEarliestSlot(schedule, earliestPossibleStart, event.duration, options.endTime, gap);
+      
+      if (startTime !== null) {
+        // If this is the preferred room and it's "good enough" (e.g. earliest possible), take it
+        if (room.id === event.preferredRoom && startTime === earliestPossibleStart) {
+          bestRoomId = room.id;
+          bestStartTime = startTime;
+          bestRoomCapacity = room.capacity;
+          break;
+        }
+        
+        // Selection criteria:
+        // 1. Earliest start time
+        // 2. Smallest capacity (to save large rooms for large events)
+        // 3. Preferred room (already handled by roomsToTry order)
+        if (startTime < bestStartTime || (startTime === bestStartTime && room.capacity < bestRoomCapacity)) {
+          bestStartTime = startTime;
+          bestRoomId = room.id;
+          bestRoomCapacity = room.capacity;
+        }
+      }
+    }
+
+    if (bestRoomId !== null) {
+      const assignment: Assignment = {
+        eventId: event.id,
+        roomId: bestRoomId,
+        startTime: bestStartTime,
+        endTime: bestStartTime + event.duration
+      };
+      assignments.push(assignment);
+      completionTimes.set(event.id, assignment.endTime);
+      
+      const roomSched = roomSchedules.get(bestRoomId)!;
+      roomSched.push({ start: assignment.startTime, end: assignment.endTime });
+      roomSched.sort((a, b) => a.start - b.start);
+    } else {
+      unscheduled.push(event.id);
+    }
+  }
+
+  return {
+    assignments,
+    unscheduled
+  };
+}
+
+function checkCycles(events: Event[]) {
+  const adj = new Map<string, string[]>();
+  for (const event of events) {
+    adj.set(event.id, event.prerequisites ?? []);
+  }
+
+  const visited = new Set<string>();
+  const recStack = new Set<string>();
+
+  function hasCycle(id: string): boolean {
+    if (recStack.has(id)) return true;
+    if (visited.has(id)) return false;
+
+    visited.add(id);
+    recStack.add(id);
+
+    const neighbors = adj.get(id) ?? [];
+    for (const neighbor of neighbors) {
+      if (hasCycle(neighbor)) return true;
+    }
+
+    recStack.delete(id);
+    return false;
+  }
+
+  for (const event of events) {
+    if (hasCycle(event.id)) {
+      throw new Error(`Prerequisite cycle detected involving event ${event.id}`);
+    }
+  }
+}
+
+function topologicalSort(events: Event[]): Event[] {
+  const adj = new Map<string, string[]>();
+  const inDegree = new Map<string, number>();
+  
+  for (const event of events) {
+    inDegree.set(event.id, 0);
+  }
+
+  for (const event of events) {
+    const prereqs = event.prerequisites ?? [];
+    for (const p of prereqs) {
+      const list = adj.get(p) ?? [];
+      list.push(event.id);
+      adj.set(p, list);
+      inDegree.set(event.id, (inDegree.get(event.id) ?? 0) + 1);
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, degree] of inDegree.entries()) {
+    if (degree === 0) queue.push(id);
+  }
+
+  // To help maximize scheduling, we could sort the queue by some heuristic
+  // but for now, let's just process in order.
+  
+  const result: Event[] = [];
+  const eventMap = new Map(events.map(e => [e.id, e]));
+
+  while (queue.length > 0) {
+    // Heuristic: pick event that is more "constrained" or "constrains others"
+    // For now, let's sort queue by duration (shorter first) or preferred room presence
+    queue.sort((a, b) => {
+      const ea = eventMap.get(a)!;
+      const eb = eventMap.get(b)!;
+      // Primary: favor events with more dependents?
+      // Secondary: favor shorter duration
+      return ea.duration - eb.duration;
+    });
+
+    const id = queue.shift()!;
+    result.push(eventMap.get(id)!);
+
+    const neighbors = adj.get(id) ?? [];
+    for (const neighbor of neighbors) {
+      const d = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, d);
+      if (d === 0) queue.push(neighbor);
+    }
+  }
+
+  return result;
+}
+
+function findEarliestSlot(
+  schedule: { start: number; end: number }[],
+  earliestStart: number,
+  duration: number,
+  maxEndTime: number,
+  gap: number
+): number | null {
+  let candidateStart = earliestStart;
+
+  // If no events scheduled yet
+  if (schedule.length === 0) {
+    return candidateStart + duration <= maxEndTime ? candidateStart : null;
+  }
+
+  // Check before first event
+  if (candidateStart + duration + gap <= schedule[0].start) {
+    return candidateStart;
+  }
+
+  // Check between events
+  for (let i = 0; i < schedule.length; i++) {
+    const current = schedule[i];
+    const next = schedule[i + 1];
+
+    candidateStart = Math.max(candidateStart, current.end + gap);
+
+    if (next) {
+      if (candidateStart + duration + gap <= next.start) {
+        return candidateStart;
+      }
+    } else {
+      // After last event
+      if (candidateStart + duration <= maxEndTime) {
+        return candidateStart;
+      }
+    }
+  }
+
+  return null;
+}
