+// Operational Transform (OT) for real-time collaboration
+// Supports Insert and Delete operations on text documents
+
+export type OperationType = 'insert' | 'delete';
+
+export interface Operation {
+  type: OperationType;
+  position: number;
+  text?: string;      // For insert: the text to insert
+  length?: number;    // For delete: number of chars to delete
+  clientId: string;
+  baseVersion: number;
+}
+
+export interface TransformedPair {
+  op1Prime: Operation;
+  op2Prime: Operation;
+}
+
+// Transform function: takes two concurrent operations and returns
+// transformed versions that can be applied in either order
+export function transform(op1: Operation, op2: Operation): TransformedPair {
+  const op1Prime = { ...op1 };
+  const op2Prime = { ...op2 };
+
+  // Both insert: adjust positions
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    if (op1.position < op2.position) {
+      op2Prime.position = op2.position + (op1.text?.length || 0);
+    } else if (op1.position > op2.position) {
+      op1Prime.position = op1.position + (op2.text?.length || 0);
+    } else {
+      // Same position: give priority to op1, push op2
+      op2Prime.position = op2.position + (op1.text?.length || 0);
+    }
+  }
+  // op1 insert, op2 delete
+  else if (op1.type === 'insert' && op2.type === 'delete') {
+    const deleteEnd = op2.position + (op2.length || 0);
+    if (op1.position <= op2.position) {
+      // Insert before delete range: push delete down
+      op2Prime.position = op2.position + (op1.text?.length || 0);
+    } else if (op1.position >= deleteEnd) {
+      // Insert after delete range: no change needed to op2
+      op1Prime.position = op1.position - (op2.length || 0);
+    } else {
+      // Insert is within delete range: adjust to insert at start of delete
+      op1Prime.position = op2.position;
+    }
+  }
+  // op1 delete, op2 insert
+  else if (op1.type === 'delete' && op2.type === 'insert') {
+    const deleteEnd = op1.position + (op1.length || 0);
+    if (op2.position <= op1.position) {
+      // Insert before delete range: push delete down
+      op1Prime.position = op1.position + (op2.text?.length || 0);
+    } else if (op2.position >= deleteEnd) {
+      // Insert after delete range
+      op2Prime.position = op2.position - (op1.length || 0);
+    } else {
+      // Insert is within delete range: adjust to insert at start of delete
+      op2Prime.position = op1.position;
+    }
+  }
+  // Both delete: handle overlapping ranges
+  else if (op1.type === 'delete' && op2.type === 'delete') {
+    const delete1End = op1.position + (op1.length || 0);
+    const delete2End = op2.position + (op2.length || 0);
+
+    if (delete1End <= op2.position) {
+      // op1 is entirely before op2: adjust op2
+      op2Prime.position = op2.position - (op1.length || 0);
+    } else if (delete2End <= op1.position) {
+      // op2 is entirely before op1: adjust op1
+      op1Prime.position = op1.position - (op2.length || 0);
+    } else {
+      // Overlapping deletes
+      if (op1.position <= op2.position) {
+        if (delete1End >= delete2End) {
+          // op1 completely contains op2: op2 becomes no-op
+          op2Prime.length = 0;
+        } else {
+          // Partial overlap: op2 deletes less
+          op2Prime.length = delete2End - delete1End;
+          op2Prime.position = op1.position;
+        }
+      } else {
+        if (delete2End >= delete1End) {
+          // op2 completely contains op1: op1 becomes no-op
+          op1Prime.length = 0;
+        } else {
+          // Partial overlap: op1 deletes less
+          op1Prime.length = delete1End - delete2End;
+          op1Prime.position = op2.position;
+        }
+      }
+    }
+  }
+
+  return { op1Prime, op2Prime };
+}
+
+// Apply an operation to a document string
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert' && op.text) {
+    const pos = Math.min(op.position, content.length);
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else if (op.type === 'delete' && op.length) {
+    const pos = Math.min(op.position, content.length);
+    const end = Math.min(pos + op.length, content.length);
+    return content.slice(0, pos) + content.slice(end);
+  }
+  return content;
+}
+
+// Serialize operation for transmission
+export function serializeOperation(op: Operation): string {
+  return JSON.stringify(op);
+}
+
+// Deserialize operation
+export function deserializeOperation(data: string): Operation {
+  return JSON.parse(data);
+}
+
+// Compose multiple operations into a single operation (for batching)
+export function composeOperations(ops: Operation[]): Operation[] {
+  // For simplicity, just return the operations as-is
+  // A more sophisticated implementation would merge adjacent operations
+  return ops;
+}
