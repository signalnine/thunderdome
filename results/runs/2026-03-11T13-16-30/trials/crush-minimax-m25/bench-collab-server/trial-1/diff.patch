+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { fileURLToPath } from 'url';
+import { dirname, join } from 'path';
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = dirname(__filename);
+
+export interface Database {
+  db: Database.Database;
+}
+
+export function createDatabase(dbPath: string = ':memory:'): Database {
+  const db = new Database(dbPath);
+  
+  // Enable foreign keys
+  db.pragma('foreign_keys = ON');
+  
+  // Initialize schema
+  const schemaPath = join(__dirname, '..', 'schema.sql');
+  try {
+    const schema = readFileSync(schemaPath, 'utf-8');
+    db.exec(schema);
+  } catch (e) {
+    // Schema already applied or using embedded schema
+  }
+  
+  return { db };
+}
+
+export function closeDatabase(database: Database): void {
+  database.db.close();
+}
+
+// Document types
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+// Document operations
+export function createDocument(db: Database.Database, id: string, title: string, content: string = ''): Document {
+  const stmt = db.prepare(`
+    INSERT INTO documents (id, title, content)
+    VALUES (?, ?, ?)
+  `);
+  stmt.run(id, title, content);
+  
+  // Create initial version
+  const versionStmt = db.prepare(`
+    INSERT INTO versions (document_id, version, content, operation)
+    VALUES (?, 1, ?, ?)
+  `);
+  versionStmt.run(id, content, JSON.stringify({ type: 'init', content }));
+  
+  return getDocument(db, id)!;
+}
+
+export function getDocument(db: Database.Database, id: string): Document | undefined {
+  const stmt = db.prepare('SELECT * FROM documents WHERE id = ?');
+  return stmt.get(id) as Document | undefined;
+}
+
+export function listDocuments(db: Database.Database): Document[] {
+  const stmt = db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');
+  return stmt.all() as Document[];
+}
+
+export function updateDocument(db: Database.Database, id: string, title: string, content: string): Document | undefined {
+  const doc = getDocument(db, id);
+  if (!doc) return undefined;
+  
+  const stmt = db.prepare(`
+    UPDATE documents
+    SET title = ?, content = ?, updated_at = datetime('now')
+    WHERE id = ?
+  `);
+  stmt.run(title, content, id);
+  
+  return getDocument(db, id);
+}
+
+export function deleteDocument(db: Database.Database, id: string): boolean {
+  const stmt = db.prepare('DELETE FROM documents WHERE id = ?');
+  const result = stmt.run(id);
+  return result.changes > 0;
+}
+
+// Version operations
+export function getVersions(db: Database.Database, documentId: string): Version[] {
+  const stmt = db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC');
+  return stmt.all(documentId) as Version[];
+}
+
+export function getLatestVersion(db: Database.Database, documentId: string): number {
+  const stmt = db.prepare('SELECT MAX(version) as version FROM versions WHERE document_id = ?');
+  const result = stmt.get(documentId) as { version: number | null };
+  return result.version || 0;
+}
+
+export function createVersion(db: Database.Database, documentId: string, content: string, operation: object): number {
+  const version = getLatestVersion(db, documentId) + 1;
+  const stmt = db.prepare(`
+    INSERT INTO versions (document_id, version, content, operation)
+    VALUES (?, ?, ?, ?)
+  `);
+  stmt.run(documentId, version, content, JSON.stringify(operation));
+  return version;
+}
