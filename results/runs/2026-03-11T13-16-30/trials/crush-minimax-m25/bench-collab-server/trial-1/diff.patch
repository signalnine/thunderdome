@@ -0,0 +1,230 @@
+import { WebSocket, WebSocketServer } from 'ws';
+import { Server } from 'http';
+import Database from 'better-sqlite3';
+import { 
+  Operation, 
+  transform, 
+  applyOperation, 
+  serializeOperation, 
+  deserializeOperation 
+} from './ot.js';
+import { getDocument, createVersion, getLatestVersion, updateDocument } from './database.js';
+
+interface Client {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+interface DocumentState {
+  content: string;
+  version: number;
+  clients: Map<string, Client>;
+}
+
+interface WSMessage {
+  type: string;
+  [key: string]: unknown;
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer | null = null;
+  private documentStates: Map<string, DocumentState> = new Map();
+  private db: Database.Database;
+  private pendingOperations: Map<string, Operation[]> = new Map();
+
+  constructor(db: Database.Database) {
+    this.db = db;
+  }
+
+  attach(server: Server): void {
+    this.wss = new WebSocketServer({ server, path: '/ws' });
+
+    this.wss.on('connection', (ws: WebSocket, req) => {
+      const url = new URL(req.url || '', `http://${req.headers.host}`);
+      const documentId = url.searchParams.get('documentId');
+      const clientId = url.searchParams.get('clientId') || this.generateClientId();
+
+      if (!documentId) {
+        ws.send(JSON.stringify({ type: 'error', message: 'documentId required' }));
+        ws.close();
+        return;
+      }
+
+      // Verify document exists
+      const doc = getDocument(this.db, documentId);
+      if (!doc) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+        ws.close();
+        return;
+      }
+
+      // Initialize document state if needed
+      if (!this.documentStates.has(documentId)) {
+        this.documentStates.set(documentId, {
+          content: doc.content,
+          version: getLatestVersion(this.db, documentId),
+          clients: new Map()
+        });
+      }
+
+      const state = this.documentStates.get(documentId)!;
+      
+      // Register client
+      const client: Client = { ws, clientId, documentId };
+      state.clients.set(clientId, client);
+
+      console.log(`Client ${clientId} connected to document ${documentId}`);
+
+      // Send sync message with current document state
+      ws.send(JSON.stringify({
+        type: 'sync',
+        documentId,
+        content: state.content,
+        version: state.version,
+        clientId
+      }));
+
+      // Handle messages
+      ws.on('message', (data: Buffer) => {
+        try {
+          const message: WSMessage = JSON.parse(data.toString());
+          this.handleMessage(client, message);
+        } catch (e) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Invalid message format' }));
+        }
+      });
+
+      ws.on('close', () => {
+        state.clients.delete(clientId);
+        console.log(`Client ${clientId} disconnected from document ${documentId}`);
+        
+        // Clean up document state if no clients
+        if (state.clients.size === 0) {
+          // Save final content to database
+          this.saveDocumentState(documentId);
+        }
+      });
+
+      ws.on('error', (error) => {
+        console.error(`WebSocket error for client ${clientId}:`, error);
+      });
+    });
+  }
+
+  private handleMessage(client: Client, message: WSMessage): void {
+    const state = this.documentStates.get(client.documentId);
+    if (!state) return;
+
+    switch (message.type) {
+      case 'operation':
+        this.handleOperation(client, message as unknown as { type: string; operation: string });
+        break;
+      case 'ping':
+        client.ws.send(JSON.stringify({ type: 'pong' }));
+        break;
+      default:
+        client.ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${message.type}` }));
+    }
+  }
+
+  private handleOperation(client: Client, message: { type: string; operation: string }): void {
+    const state = this.documentStates.get(client.documentId);
+    if (!state) return;
+
+    try {
+      const operation: Operation = deserializeOperation(message.operation);
+      
+      // Transform against any pending operations
+      const pending = this.pendingOperations.get(client.documentId) || [];
+      let transformedOp = operation;
+      
+      for (const pendingOp of pending) {
+        const result = transform(pendingOp, transformedOp);
+        transformedOp = result.op2Prime;
+      }
+
+      // Apply the operation
+      const newContent = applyOperation(state.content, transformedOp);
+      state.content = newContent;
+      state.version++;
+
+      // Store the operation
+      pending.push(transformedOp);
+      this.pendingOperations.set(client.documentId, pending);
+
+      // Save to database periodically (every 10 operations or so)
+      if (state.version % 10 === 0) {
+        this.saveDocumentState(client.documentId);
+      }
+
+      // Broadcast to all clients including sender (for confirmation)
+      const broadcastMsg = JSON.stringify({
+        type: 'operation',
+        operation: serializeOperation(transformedOp),
+        version: state.version,
+        clientId: client.clientId
+      });
+
+      for (const [, c] of state.clients) {
+        if (c.ws.readyState === WebSocket.OPEN) {
+          c.ws.send(broadcastMsg);
+        }
+      }
+    } catch (e) {
+      client.ws.send(JSON.stringify({ 
+        type: 'error', 
+        message: `Operation failed: ${e instanceof Error ? e.message : 'Unknown error'}` 
+      }));
+    }
+  }
+
+  private saveDocumentState(documentId: string): void {
+    const state = this.documentStates.get(documentId);
+    if (!state) return;
+
+    // Save content to database
+    const doc = getDocument(this.db, documentId);
+    if (doc) {
+      updateDocument(this.db, documentId, doc.title, state.content);
+      
+      // Create a version record
+      const lastPending = this.pendingOperations.get(documentId);
+      if (lastPending && lastPending.length > 0) {
+        const lastOp = lastPending[lastPending.length - 1];
+        createVersion(this.db, documentId, state.content, lastOp);
+      }
+    }
+
+    // Clear pending operations after saving
+    this.pendingOperations.set(documentId, []);
+  }
+
+  private generateClientId(): string {
+    return `client_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`;
+  }
+
+  // Get current state for testing
+  getDocumentState(documentId: string): DocumentState | undefined {
+    return this.documentStates.get(documentId);
+  }
+
+  // Force save all documents (for shutdown)
+  saveAll(): void {
+    for (const documentId of this.documentStates.keys()) {
+      this.saveDocumentState(documentId);
+    }
+  }
+
+  // Close all connections
+  close(): void {
+    this.saveAll();
+    if (this.wss) {
+      for (const client of this.wss.clients) {
+        client.close();
+      }
+      this.wss.close();
+    }
+    this.documentStates.clear();
+  }
