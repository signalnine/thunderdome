+<invoke name="write">
+<parameter name="content">import { Router, Request, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import Database from 'better-sqlite3';
+import {
+  createDocument,
+  getDocument,
+  listDocuments,
+  updateDocument,
+  deleteDocument,
+  getVersions,
+  Document,
+  Version
+} from './database.js';
+
+export function createDocumentRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Generate UUID (simple implementation without external library)
+  function generateId(): string {
+    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, (c) => {
+      const r = Math.random() * 16 | 0;
+      const v = c === 'x' ? r : (r & 0x3 | 0x8);
+      return v.toString(16);
+    });
+  }
+
+  // Create a new document
+  router.post('/documents', (req: Request, res: Response) => {
+    try {
+      const { title, content = '' } = req.body;
+      
+      if (!title || typeof title !== 'string') {
+        res.status(400).json({ error: 'Title is required' });
+        return;
+      }
+
+      const id = generateId();
+      const doc = createDocument(db, id, title, content);
+      
+      res.status(201).json(doc);
+    } catch (e) {
+      res.status(500).json({ error: 'Failed to create document' });
+    }
+  });
+
+  // Get all documents
+  router.get('/documents', (_req: Request, res: Response) => {
+    try {
+      const docs = listDocuments(db);
+      res.json(docs);
+    } catch (e) {
+      res.status(500).json({ error: 'Failed to list documents' });
+    }
+  });
+
+  // Get a specific document
+  router.get('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const { id } = req.params;
+      const doc = getDocument(db, id);
+      
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      
+      res.json(doc);
+    } catch (e) {
+      res.status(500).json({ error: 'Failed to get document' });
+    }
+  });
+
+  // Update a document
+  router.put('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const { id } = req.params;
+      const { title, content } = req.body;
+      
+      const existing = getDocument(db, id);
+      if (!existing) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+
+      const newTitle = title !== undefined ? title : existing.title;
+      const newContent = content !== undefined ? content : existing.content;
+
+      const doc = updateDocument(db, id, newTitle, newContent);
+      res.json(doc);
+    } catch (e) {
+      res.status(500).json({ error: 'Failed to update document' });
+    }
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const { id } = req.params;
+      const deleted = deleteDocument(db, id);
+      
+      if (!deleted) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      
+      res.status(204).send();
+    } catch (e) {
+      res.status(500).json({ error: 'Failed to delete document' });
+    }
+  });
+
+  // Get document version history
+  router.get('/documents/:id/versions', (req: Request, res: Response) => {
+    try {
+      const { id } = req.params;
+      
+      const doc = getDocument(db, id);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+
+      const versions = getVersions(db, id);
+      res.json(versions);
+    } catch (e) {
+      res.status(500).json({ error: 'Failed to get versions' });
+    }
+  });
+
+  return router;
+}</parameter>
