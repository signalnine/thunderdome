+function testToggle() {
+    let passed = 0;
+    let failed = 0;
+    const randomInt = (max) => Math.floor(Math.random() * max);
+    const randomBool = () => Math.random() < 0.5;
+    for (let trial = 0; trial < 1000; trial++) {
+        const N = randomInt(8) + 1;
+        const M = randomInt(8) + 1;
+        const target: boolean[] = [];
+        for (let i = 0; i < N; i++) target.push(randomBool());
+        const buttons: number[][] = [];
+        for (let i = 0; i < M; i++) {
+            const k = randomInt(N + 1);
+            const lights: number[] = [];
+            const seen = new Set();
+            while (lights.length < k) {
+                const light = randomInt(N);
+                if (!seen.has(light)) {
+                    seen.add(light);
+                    lights.push(light);
+                }
+            }
+            buttons.push(lights);
+        }
+        const result = solveToggle({ target, buttons });
+        if (result !== null) {
+            // Verify
+            const lights = target.map(() => false);
+            for (const btn of result) {
+                for (const light of buttons[btn]) {
+                    lights[light] = !lights[light];
+                }
+            }
+            let ok = true;
+            for (let i = 0; i < N; i++) {
+                if (lights[i] !== target[i]) {
+                    ok = false;
+                    break;
+                }
+            }
+            if (ok) {
+                passed++;
+            } else {
+                console.log('Toggle verification failed');
+                console.log('target:', target);
+                console.log('buttons:', buttons);
+                console.log('result:', result);
+                console.log('computed lights:', lights);
+                failed++;
+                break;
+            }
+        }
+        // If result is null, we cannot verify, but we assume it's correct (no solution)
+    }
+    console.log(`Toggle tests: passed ${passed}, failed ${failed}`);
+    return failed === 0;
+}
+
+function testCounter() {
+    let passed = 0;
