+import { solveToggle, solveCounter } from './index';
+
+describe('solveToggle', () => {
+  it('returns null for the example in the description', () => {
+    const machine = {
+      target: [true, true, false, true],
+      buttons: [
+        [0, 1],
+        [1, 2, 3],
+        [0, 3]
+      ]
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('returns empty array when target is all off and no buttons needed', () => {
+    const machine = {
+      target: [false, false, false],
+      buttons: [
+        [0, 1],
+        [1, 2]
+      ]
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('returns single button when it matches target', () => {
+    const machine = {
+      target: [true, true, false],
+      buttons: [
+        [0, 1],
+        [2],
+        [0, 2]
+      ]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('returns lexicographically smallest when multiple solutions with same count', () => {
+    const machine = {
+      target: [true, false, true],
+      buttons: [
+        [0, 1], // button0
+        [1, 2], // button1
+        [0, 2]  // button2
+      ]
+    };
+    // Possible solutions:
+    // button0 + button1: toggles [0,1] and [1,2] -> [0:1, 1:0, 2:1] -> [true, false, true] -> presses=2
+    // button0 + button2: toggles [0,1] and [0,2] -> [0:0,1:1,2:1] -> [false, true, true] -> not target
+    // button1 + button2: toggles [1,2] and [0,2] -> [0:1,1:1,2:0] -> [true, true, false] -> not target
+    // button0 + button1 + button2: toggles all three -> [0:0,1:0,2:0] -> [false, false, false] -> not target
+    // Actually, let's recalc:
+    // We need to solve: b0 XOR b2 = 1 (light0), b0 XOR b1 = 0 (light1), b1 XOR b2 = 1 (light2)
+    // From light1: b0 = b1
+    // Then light0: b0 XOR b2 = 1 -> b1 XOR b2 = 1
+    // light2: b1 XOR b2 = 1 -> same, so consistent.
+    // Let b1 = 0 then b0=0, then b2=1 -> solution [2] (press button2 only) -> presses=1
+    // Let b1 = 1 then b0=1, then b2=0 -> solution [0,1] -> presses=2
+    // So the minimal presses is 1 with solution [2].
+    // But wait, check: button2 toggles [0,2] -> [true, false, true] -> yes! So solution [2] works.
+    // So the function should return [2].
+    const result = solveToggle(machine);
+    expect(result).toEqual([2]);
+  });
+
+  it('returns null when no solution', () => {
+    const machine = {
+      target: [true, true],
+      buttons: [
+        [0],
+        [0]
+      ]
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+});
+
+describe('solveCounter', () => {
+  it('solves a simple counter puzzle', () => {
+    // Example: 2 lights, modulus 2 (so buttons are like toggles but can be pressed 0 or 1 times)
+    // Actually, modulus 2 is same as toggle but we can press 0 or 1.
+    // Let's set up: target [1,0], buttons: button0 toggles light0, button1 toggles light1.
+    // We need: x0 = 1 mod2, x1 = 0 mod2 -> solution [1,0]
+    const lights = [1, 0];
+    const buttons = [
+      [0],
+      [1]
+    ];
+    const modulus = 2;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([1, 0]);
+  });
+
+  it('returns null when no solution', () => {
+    const lights = [1, 0];
+    const buttons = [
+      [0, 1],
+      [0, 1]
+    ];
+    const modulus = 2;
+    // Equations: 
+    //   x0 + x1 = 1 mod2
+    //   x0 + x1 = 0 mod2
+    // Inconsistent.
+    expect(solveCounter(lights, buttons, modulus)).toBeNull();
+  });
+
+  it('returns lexicographically smallest when multiple solutions with same total presses', () => {
+    // Example: modulus 3, 2 lights.
+    // Buttons: 
+    //   button0: [0]
+    //   button1: [0,1]
+    // Target: [1,1]
+    // Equations:
+    //   x0 + x1 = 1 mod3
+    //   x0 + x1 = 1 mod3   (same)
+    // So we have one equation: x0 + x1 = 1 mod3.
+    // Solutions: (0,1), (1,0), (2,2) because 2+2=4 mod3=1.
+    // Total presses: 0+1=1, 1+0=1, 2+2=4 -> so minimal total presses is 1.
+    // Among solutions with total presses 1: (0,1) and (1,0). Lexicographically smallest is [0,1] (since 0<1).
+    const lights = [1, 1];
+    const buttons = [
+      [0],
+      [0, 1]
+    ];
+    const modulus = 3;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([0, 1]);
+  });
+});
