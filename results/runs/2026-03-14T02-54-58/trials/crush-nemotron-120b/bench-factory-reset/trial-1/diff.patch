+import { solveToggle } from './src/index';
+
+function verifySolution(target: boolean[], buttons: number[][], result: number[] | null): boolean {
+    if (result === null) {
+        // We cannot verify, but we can at least check that the algorithm didn't crash.
+        return true;
+    }
+    const lights = target.map(() => false);
+    for (const btn of result) {
+        for (const light of buttons[btn]) {
+            lights[light] = !lights[light];
+        }
+    }
+    for (let i = 0; i < target.length; i++) {
+        if (lights[i] !== target[i]) {
+            return false;
+        }
+    }
+    return true;
+}
+
+let foundFailure = false;
+let attempt = 0;
+while (!foundFailure && attempt < 200) {
+    attempt++;
+    const M = 40;
+    const N = 40;
+    // Use a seed based on attempt to get different cases
+    let seed = attempt * 123456789 + 987654321;
+    function randomSeed() {
+        // xorshift32
+        let x = seed;
+        x ^= x << 13;
+        x ^= x >> 17;
+        x ^= x << 5;
+        seed = x;
+        return (seed < 0 ? ~seed : seed) / 0xFFFFFFFF;
+    }
+    const target: boolean[] = [];
+    for (let i = 0; i < N; i++) {
+        target.push(randomSeed() < 0.5);
+    }
+    const buttons: number[][] = [];
+    for (let i = 0; i < M; i++) {
+        const k = Math.floor(randomSeed() * (N + 1));
+        const lights: number[] = [];
+        const seen = new Set();
+        while (lights.length < k) {
+            const light = Math.floor(randomSeed() * N);
+            if (!seen.has(light)) {
+                seen.add(light);
+                lights.push(light);
+            }
+        }
+        buttons.push(lights);
+    }
+    const result = solveToggle({ target, buttons });
+    if (!verifySolution(target, buttons, result)) {
+        console.log(`Failure at attempt ${attempt}`);
+        console.log('Target:', target);
+        console.log('Buttons:', buttons);
+        console.log('Result:', result);
+        foundFailure = true;
+        break;
+    }
+    if (attempt % 20 === 0) {
+        console.log(`Attempt ${attempt}: still ok`);
+    }
+}
+if (!foundFailure) {
+    console.log('No failure found in 200 attempts');
+}
