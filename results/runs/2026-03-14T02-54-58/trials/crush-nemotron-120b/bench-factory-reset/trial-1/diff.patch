+import { solveCounter } from './src/index';
+
+// Brute force for counter for small M and modulus
+function bruteCounter(lights: number[], buttons: number[][], modulus: number): number[] | null {
+    const M = buttons.length;
+    // If M is too big, we cannot brute force
+    if (M > 10) {
+        return null; // skip
+    }
+    const limit = Math.pow(modulus, M);
+    if (limit > 100000) {
+        return null; // skip
+    }
+    let best: number[] | null = null;
+    let bestSum = Infinity;
+    // We'll encode the combination as a number in base modulus.
+    for (let combo = 0; combo < limit; combo++) {
+        const x: number[] = [];
+        let temp = combo;
+        for (let i = 0; i < M; i++) {
+            x.push(temp % modulus);
+            temp = Math.floor(temp / modulus);
+        }
+        // Compute resulting lights
+        const res: number[] = new Array(lights.length).fill(0);
+        for (let i = 0; i < M; i++) {
+            const presses = x[i];
+            if (presses === 0) continue;
+            for (const j of buttons[i]) {
+                res[j] = (res[j] + presses) % modulus;
+            }
+        }
+        // Check if matches target
+        let ok = true;
+        for (let j = 0; j < lights.length; j++) {
+            if (res[j] !== lights[j]) {
+                ok = false;
+                break;
+            }
+        }
+        if (ok) {
+            const sum = x.reduce((a, b) => a + b, 0);
+            if (sum < bestSum || (sum === bestSum && lexCompare(x, best) < 0)) {
+                best = x.slice();
+                bestSum = sum;
+            }
+        }
+    }
+    return best;
+}
+
+function lexCompare(a: number[] | null, b: number[] | null): number {
+    if (a === null && b === null) return 0;
+    if (a === null) return -1;
+    if (b === null) return 1;
+    const len = Math.min(a.length, b.length);
+    for (let i = 0; i < len; i++) {
+        if (a[i] < b[i]) return -1;
+        if (a[i] > b[i]) return 1;
+    }
+    if (a.length < b.length) return -1;
+    if (a.length > b.length) return 1;
+    return 0;
+}
+
+// Test random small instances
+function testCounter() {
+    const randomInt = (max) => Math.floor(Math.random() * max);
+    const randomModulus = () => [2, 3, 5, 7][randomInt(4)];
+    let passed = 0;
+    let failed = 0;
+    for (let trial = 0; trial < 200; trial++) {
+        const N = randomInt(4) + 1;
+        const M = randomInt(4) + 1;
+        const modulus = randomModulus();
+        const lights: number[] = [];
+        for (let i = 0; i < N; i++) lights.push(randomInt(modulus));
+        const buttons: number[][] = [];
+        for (let i = 0; i < M; i++) {
+            const k = randomInt(N + 1);
+            const lightsIdx: number[] = [];
+            const seen = new Set();
+            while (lightsIdx.length < k) {
+                const light = randomInt(N);
+                if (!seen.has(light)) {
+                    seen.add(light);
+                    lightsIdx.push(light);
+                }
+            }
+            buttons.push(lightsIdx);
+        }
+        const expected = bruteCounter(lights, buttons, modulus);
+        const actual = solveCounter(lights, buttons, modulus);
+        if (expected === null && actual === null) {
+            passed++;
+        } else if (expected === null || actual === null) {
+            console.log('Mismatch: one null other not');
+            console.log({ lights, buttons, modulus });
+            console.log('expected:', expected);
+            console.log('actual:', actual);
+            failed++;
+        } else {
+            if (expected.length !== actual.length) {
+                console.log('Length mismatch');
+                console.log({ lights, buttons, modulus });
+                console.log('expected:', expected);
+                console.log('actual:', actual);
+                failed++;
+            } else {
+                let match = true;
+                for (let i = 0; i < expected.length; i++) {
+                    if (expected[i] !== actual[i]) {
+                        match = false;
+                        break;
+                    }
+                }
+                if (match) {
+                    passed++;
+                } else {
+                    console.log('Array content mismatch');
+                    console.log({ lights, buttons, modulus });
+                    console.log('expected:', expected);
+                    console.log('actual:', actual);
+                    failed++;
+                }
+            }
+        }
+    }
+    console.log(`Counter tests: passed ${passed}, failed ${failed}`);
+    return failed === 0;
+}
+
+// Test the example from the description? Not given, but we can make one.
+console.log('=== Testing counter ===');
+const pass = testCounter();
+console.log('All passed?', pass);
+
+// Also test a specific case: modulus 2, should be like toggle but with counts 0 or 1.
+console.log('\n=== Testing modulus 2 (like toggle) ===');
+const lights = [1, 0, 1];
+const buttons = [
+    [0, 1], // button0 toggles 0,1
+    [1, 2], // button1 toggles 1,2
+    [0, 2]  // button2 toggles 0,2
+];
+const modulus = 2;
+// We can brute force small
+const expected = bruteCounter(lights, buttons, modulus);
+const actual = solveCounter(lights, buttons, modulus);
+console.log('lights:', lights);
+console.log('buttons:', buttons);
+console.log('expected:', expected);
+console.log('actual:', actual);
+console.log('match?', JSON.stringify(expected) === JSON.stringify(actual));
+
+// Verify if actual is not null
+if (actual !== null) {
+    const res = new Array(lights.length).fill(0);
+    for (let i = 0; i < buttons.length; i++) {
+        const presses = actual[i];
+        for (const j of buttons[i]) {
+            res[j] = (res[j] + presses) % modulus;
+        }
+    }
+    console.log('result lights:', res);
+    console.log('matches target?', JSON.stringify(res) === JSON.stringify(lights));
+}
