+            const light = Math.floor(Math.random() * N);
+            if (!seen.has(light)) {
+                seen.add(light);
+                lightsIdx.push(light);
+            }
+        }
+        buttons.push(lightsIdx);
+    }
+    console.log(`Counter stress test: M=${M}, N=${N}, modulus=${modulus}`);
+    const { result, time } = timeIt(() => solveCounter(lights, buttons, modulus));
+    console.log(`  Time: ${time.toFixed(2)} ms`);
+    console.log(`  Result: ${result === null ? 'null' : '[' + result.map(String).join(',') + ']'}`);
+    if (result !== null) {
