+import { solveToggle } from './src/index';
+
+// Brute force for toggle for small M (<= 10)
+function bruteToggle(target: boolean[], buttons: number[][]): number[] | null {
+    const M = buttons.length;
+    let best: number[] | null = null;
+    let bestCount = Infinity;
+    // iterate over all subsets
+    for (let mask = 0; mask < (1 << M); mask++) {
+        // compute resulting lights
+        const lights = target.map(() => false); // start all off
+        let count = 0;
+        for (let i = 0; i < M; i++) {
+            if (mask & (1 << i)) {
+                count++;
+                for (const light of buttons[i]) {
+                    lights[light] = !lights[light];
+                }
+            }
+        }
+        // check if matches target
+        let ok = true;
+        for (let i = 0; i < target.length; i++) {
+            if (lights[i] !== target[i]) {
+                ok = false;
+                break;
+            }
+        }
+        if (ok) {
+            if (count < bestCount || (count === bestCount && (!best || maskToArray(mask, M).every((v, i) => v < (best[i] ?? 0))))) {
+                // lexicographic compare: we need to compare the sorted indices? Actually, the array of indices pressed in ascending order.
+                // The mask corresponds to which buttons are pressed. The array of indices is the positions of set bits.
+                const candidate = maskToArray(mask, M);
+                if (best === null || lexCompare(candidate, best) < 0) {
+                    best = candidate;
+                    bestCount = count;
+                }
+            }
+        }
+    }
+    return best;
+}
+
+function maskToArray(mask: number, M: number): number[] {
+    const res: number[] = [];
+    for (let i = 0; i < M; i++) {
+        if (mask & (1 << i)) {
+            res.push(i);
+        }
+    }
+    return res;
+}
+
+function lexCompare(a: number[], b: number[]): number {
+    const len = Math.min(a.length, b.length);
+    for (let i = 0; i < len; i++) {
+        if (a[i] < b[i]) return -1;
+        if (a[i] > b[i]) return 1;
+    }
+    if (a.length < b.length) return -1;
+    if (a.length > b.length) return 1;
+    return 0;
+}
+
+function testOne(target: boolean[], buttons: number[][]) {
+    const expected = bruteToggle(target, buttons);
+    const actual = solveToggle({ target, buttons });
+    if (expected === null && actual === null) {
+        return true;
+    }
+    if (expected === null || actual === null) {
+        console.log('Mismatch: one null other not');
+        console.log({ target, buttons });
+        console.log('expected:', expected);
+        console.log('actual:', actual);
+        return false;
+    }
+    // compare arrays
+    if (expected.length !== actual.length) {
+        console.log('Length mismatch');
+        console.log({ target, buttons });
+        console.log('expected:', expected);
+        console.log('actual:', actual);
+        return false;
+    }
+    for (let i = 0; i < expected.length; i++) {
+        if (expected[i] !== actual[i]) {
+            console.log('Array content mismatch');
+            console.log({ target, buttons });
+            console.log('expected:', expected);
+            console.log('actual:', actual);
+            return false;
+        }
+    }
+    return true;
+}
+
+// Let's run random tests until we find a failure
+let found = false;
+for (let trial = 0; trial < 10000; trial++) {
+    const N = Math.floor(Math.random() * 6) + 1; // up to 6 lights
+    const M = Math.floor(Math.random() * 6) + 1; // up to 6 buttons
+    const target: boolean[] = [];
+    for (let i = 0; i < N; i++) {
+        target.push(Math.random() < 0.5);
+    }
+    const buttons: number[][] = [];
+    for (let i = 0; i < M; i++) {
+        const k = Math.floor(Math.random() * (N + 1));
+        const lights: number[] = [];
+        const seen = new Set();
+        while (lights.length < k) {
+            const light = Math.floor(Math.random() * N);
+            if (!seen.has(light)) {
+                seen.add(light);
+                lights.push(light);
+            }
+        }
+        buttons.push(lights);
+    }
+    if (!testOne(target, buttons)) {
+        console.log(`Found failure at trial ${trial}`);
+        found = true;
+        break;
+    }
+}
+if (!found) {
+    console.log('No failure found in 10000 random small tests');
+}
+
+// Now test the specific case from stress test that failed
+// We'll need to capture that case. Let's modify stress test to save the failing case.
+// For now, let's just run the stress test again but with logging.
+
+console.log('\nNow running stress test with detailed logging...');
+const M = 40;
+const N = 40;
