+    }
+    console.log(`Verification: ${ok ? 'PASS' : 'FAIL'}`);
+    if (!ok) {
+        console.log('Debugging...');
+        // Compute the xor of button masks for the result
+        let computedXor = 0;
+        for (const btnIdx of result) {
+            let mask = 0;
+            for (const light of buttons[btnIdx]) {
+                mask |= (1 << light);
+            }
+            computedXor ^= mask;
+        }
+        // Compute target mask
+        let targetMask = 0;
+        for (let i = 0; i < N; i++) {
+            if (target[i]) {
+                targetMask |= (1 << i);
+            }
+        }
+        console.log(`Target mask: ${targetMask.toString(2).padStart(N, '0')}`);
+        console.log(`Computed mask: ${computedXor.toString(2).padStart(N, '0')}`);
+        console.log(`Masks equal? ${targetMask === computedXor}`);
+        // Also compute the lights after applying result manually
+        const lights2 = target.map(() => false);
+        for (const btnIdx of result) {
+            for (const light of buttons[btnIdx]) {
