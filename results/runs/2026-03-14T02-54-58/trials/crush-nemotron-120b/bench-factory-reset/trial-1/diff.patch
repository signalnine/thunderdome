+import { solveToggle } from './src/index';
+
+// Helper: compute lights from pressed buttons
+function computeLights(targetStart: boolean[], pressed: number[], buttons: number[][]): boolean[] {
+    const lights = targetStart.map(b => b); // copy
+    for (const btn of pressed) {
+        for (const light of buttons[btn]) {
+            lights[light] = !lights[light];
+        }
+    }
+    return lights;
+}
+
+// Generate a random instance with a known solution
+function generateInstanceWithSolution(maxLights: number, maxButtons: number): { target: boolean[]; buttons: number[][]; solution: number[] } {
+    const N = Math.floor(Math.random() * maxLights) + 1;
+    const M = Math.floor(Math.random() * maxButtons) + 1;
+    const buttons: number[][] = [];
+    for (let i = 0; i < M; i++) {
+        const k = Math.floor(Math.random() * (N + 1));
+        const lights: number[] = [];
+        const seen = new Set();
+        while (lights.length < k) {
+            const light = Math.floor(Math.random() * N);
+            if (!seen.has(light)) {
+                seen.add(light);
+                lights.push(light);
+            }
+        }
+        buttons.push(lights);
+    }
+    // Choose a random subset of buttons to press
+    const solution: number[] = [];
+    for (let i = 0; i < M; i++) {
+        if (Math.random() < 0.5) {
+            solution.push(i);
+        }
+    }
+    // Start with all lights off
+    const targetStart = new Array(N).fill(false);
+    // Compute target by pressing the solution buttons
+    const target = computeLights(targetStart, solution, buttons);
+    return { target, buttons, solution };
+}
+
+// Test that the solver returns a solution that is correct and minimal
+function testInstance({ target, buttons, solution }: { target: boolean[]; buttons: number[][]; solution: number[] }): boolean {
+    const result = solveToggle({ target, buttons });
+    if (result === null) {
+        console.log('ERROR: Solver returned null but we know a solution exists');
+        console.log('target:', target);
+        console.log('buttons:', buttons);
+        console.log('known solution:', solution);
+        return false;
+    }
+    // Verify that pressing result yields target
+    const lights = computeLights(new Array(target.length).fill(false), result, buttons);
+    if (JSON.stringify(lights) !== JSON.stringify(target)) {
+        console.log('ERROR: Solver result does not produce target');
+        console.log('target:', target);
+        console.log('buttons:', buttons);
+        console.log('solver result:', result);
+        console.log('computed lights:', lights);
+        return false;
+    }
+    // Check that result is minimal in size
+    if (result.length > solution.length) {
+        // It's possible that there is a better solution than the planted one.
+        // We need to check if there exists any solution with fewer presses.
+        // We'll do brute force over subsets up to size result.length-1 to see if any works.
+        const M = buttons.length;
+        const maxSizeToCheck = Math.min(result.length - 1, M); // we only need to check up to result.length-1
+        let foundBetter = false;
+        // We'll iterate over all subsets of size up to maxSizeToCheck
+        // For efficiency, we'll stop if we find any.
+        const visitSubset = (mask: number) => {
+            const count = bitCount(mask);
+            if (count > maxSizeToCheck) return;
+            const pressed: number[] = [];
+            for (let i = 0; i < M; i++) {
+                if (mask & (1 << i)) pressed.push(i);
+            }
+            const lights = computeLights(new Array(target.length).fill(false), pressed, buttons);
+            if (JSON.stringify(lights) === JSON.stringify(target)) {
+                foundBetter = true;
+            }
+        };
+        // We'll iterate over all masks from 0 to (1<<M)-1 but break early if foundBetter.
+        // Since M might be up to maybe 10 in our generation, it's fine.
+        for (let mask = 0; mask < (1 << M); mask++) {
+            visitSubset(mask);
+            if (foundBetter) break;
+        }
+        if (foundBetter) {
+            console.log('INFO: There exists a better solution than the planted one; that's okay.');
+            // We still need to check that our result is indeed minimal.
+            // We'll brute force to find the minimal size.
+            let minSize = Infinity;
+            for (let mask = 0; mask < (1 << M); mask++) {
+                const pressed: number[] = [];
+                for (let i = 0; i < M; i++) {
+                    if (mask & (1 << i)) pressed.push(i);
+                }
+                const lights = computeLights(new Array(target.length).fill(false), pressed, buttons);
+                if (JSON.stringify(lights) === JSON.stringify(target)) {
+                    minSize = Math.min(minSize, pressed.length);
+                }
+            }
+            if (result.length > minSize) {
+                console.log('ERROR: Solver result is not minimal');
+                console.log('target:', target);
+                console.log('buttons:', buttons);
+                console.log('solver result:', result, 'length', result.length);
+                console.log('minimal size found:', minSize);
+                return false;
+            }
+        }
+    }
+    // Check lexicographic order among minimal solutions? We'll skip for now; we can add later.
+    return true;
+}
+
+function bitCount(x: number): number {
+    let c = 0;
+    while (x) {
+        c += x & 1;
+        x >>= 1;
+    }
+    return c;
+}
+
+let passed = 0;
+let failed = 0;
+for (let trial = 0; trial < 500; trial++) {
+    const instance = generateInstanceWithSolution(8, 8); // up to 8 lights, 8 buttons for brute force checking
+    if (testInstance(instance)) {
+        passed++;
+    } else {
+        failed++;
+        break;
+    }
+}
+console.log(`Toggle solver tests: passed ${passed}, failed ${failed}`);
+if (failed === 0) {
+    console.log('All tests passed!');
+} else {
+    console.log('Some tests failed.');
+}
