+export function solveToggle(machine: { target: boolean[]; buttons: number[][] }): number[] | null {
+    const { target, buttons } = machine;
+    const M = buttons.length;
+    if (M === 0) {
+        // Check if target is all false
+        if (target.every(b => !b)) return [];
+        else return null;
+    }
+    const N = target.length;
+
+    // Convert target to bitmask
+    let targetMask = 0;
+    for (let i = 0; i < N; i++) {
+        if (target[i]) {
+            targetMask |= (1 << i);
+        }
+    }
+
+    // Convert each button to a bitmask
+    const buttonMasks = buttons.map(btn => {
+        let mask = 0;
+        for (const light of btn) {
+            if (light < N) { // safety
+                mask |= (1 << light);
+            }
+        }
+        return mask;
+    });
+
+    // Split the buttons
+    const mid = Math.floor(M / 2);
+    const leftCount = mid;
+    const rightCount = M - mid;
+
+    // Helper: compare two subsets (bitmask over their half) by lexicographic order of sorted indices.
+    // Returns -1 if subsetA < subsetB, 0 if equal, 1 if subsetA > subsetB.
+    const compareSubsetLex = (subsetA: number, subsetB: number, size: number): number => {
+        for (let i = 0; i < size; i++) {
+            const aBit = (subsetA >> i) & 1;
+            const bBit = (subsetB >> i) & 1;
+            if (aBit !== bBit) {
+                // If aBit is 1 and bBit is 0, then subsetA is lexicographically smaller
+                return aBit > bBit ? -1 : 1;
+            }
+        }
+        return 0;
+    };
+
+    // Precompute left_map: xor_value -> { count: number, subset: number } (for left half)
+    const leftMap = new Map();
+    // Start with empty subset
+    leftMap.set(0, { count: 0, subset: 0 });
+
+    // Iterate over all subsets of left half
+    for (let subset = 0; subset < (1 << leftCount); subset++) {
+        let xorVal = 0;
+        let count = 0;
+        for (let i = 0; i < leftCount; i++) {
+            if (subset & (1 << i)) {
+                xorVal ^= buttonMasks[i];
+                count++;
+            }
+        }
+        const existing = leftMap.get(xorVal);
+        if (!existing) {
+            leftMap.set(xorVal, { count: count, subset: subset });
+        } else {
+            // Compare: first by count, then by lexicographic order of subset indices
+            if (count < existing.count || 
+                (count === existing.count && compareSubsetLex(subset, existing.subset, leftCount) < 0)) {
+                leftMap.set(xorVal, { count: count, subset: subset });
+            }
+        }
+    }
+
+    // Now iterate over right half subsets
+    let bestTotalCount = Infinity;
+    let bestLeftSubset = null; // bitmask over left half
+    let bestRightSubset = null; // bitmask over right half
+
+    for (let subset = 0; subset < (1 << rightCount); subset++) {
+        let xorVal = 0;
+        let count = 0;
+        for (let i = 0; i < rightCount; i++) {
+            if (subset & (1 << i)) {
+                xorVal ^= buttonMasks[mid + i];
+                count++;
+            }
+        }
+        const needed = targetMask ^ xorVal;
+        const leftInfo = leftMap.get(needed);
+        if (leftInfo) {
+            const totalCount = leftInfo.count + count;
+            const leftSubset = leftInfo.subset;
+            const rightSubset = subset;
+            // Check if this solution is better
+            if (totalCount < bestTotalCount || 
+                (totalCount === bestTotalCount && 
+                 (bestLeftSubset === null || 
+                  compareSubsetLex(leftSubset, bestLeftSubset, leftCount) < 0 ||
+                  (compareSubsetLex(leftSubset, bestLeftSubset, leftCount) === 0 && 
+                   compareSubsetLex(rightSubset, bestRightSubset, rightCount) < 0)))) {
+                bestTotalCount = totalCount;
+                bestLeftSubset = leftSubset;
+                bestRightSubset = rightSubset;
+            }
+        }
+    }
+
+    if (bestLeftSubset === null) {
+        return null;
+    }
+
+    // Convert bestLeftSubset and bestRightSubset to array of button indices (sorted)
+    const result = [];
+    // Left half buttons: indices 0 .. leftCount-1
+    for (let i = 0; i < leftCount; i++) {
+        if (bestLeftSubset & (1 << i)) {
+            result.push(i);
+        }
+    }
+    // Right half buttons: indices mid .. M-1
+    for (let i = 0; i < rightCount; i++) {
+        if (bestRightSubset & (1 << i)) {
+            result.push(mid + i);
+        }
+    }
+    return result;
+}
+
+export function solveCounter(lights: number[], buttons: number[][], modulus: number): number[] | null {
+    const M = buttons.length;
+    const N = lights.length;
+
+    // Build the matrix A (N x M) and vector b (N)
+    const A: number[][] = [];
+    for (let j = 0; j < N; j++) {
+        A[j] = new Array(M).fill(0);
+    }
+    for (let i = 0; i < M; i++) {
+        for (const j of buttons[i]) {
+            if (j < N) {
+                A[j][i] = 1;
+            }
+        }
+    }
+    const b = lights.slice(); // copy
+
+    // We will solve A * x = b (mod modulus) for x in [0, modulus-1]^M
+
+    // Step 1: Gaussian elimination to find the null space and a particular solution.
+    // We will perform Gaussian elimination on the augmented matrix [A | b] over GF(modulus).
+
+    // Make a copy of A and b to work on.
+    const Ab: number[][] = [];
+    for (let j = 0; j < N; j++) {
+        Ab[j] = A[j].slice();
+        Ab[j].push(b[j]);
+    }
+
+    // We will do elimination to row echelon form.
+    let row = 0;
+    const pivotRows = new Array(M).fill(-1); // pivotRows[col] = the row that has pivot in this col, or -1 if free.
+    for (let c = 0; c < M && row < N; c++) {
+        // Find a pivot in column c from row row to N-1
+        let pivotRow = -1;
+        for (let r = row; r < N; r++) {
+            if (Ab[r][c] % modulus !== 0) {
+                pivotRow = r;
+                break;
+            }
+        }
+        if (pivotRow === -1) {
+            // no pivot in this column, move to next
+            continue;
+        }
+        // Swap Ab[row] and Ab[pivotRow]
+        [Ab[row], Ab[pivotRow]] = [Ab[pivotRow], Ab[row]];
+        pivotRows[c] = row;
+
+        // Normalize the pivot row: make the pivot 1 by multiplying by the inverse of Ab[row][c] mod modulus.
+        const pivotVal = Ab[row][c];
+        const inv = modInverse(pivotVal, modulus);
+        if (inv !== 1) {
+            for (let j = c; j <= M; j++) { // j from c to M (the last column is the b)
+                Ab[row][j] = (Ab[row][j] * inv) % modulus;
+                if (Ab[row][j] < 0) Ab[row][j] += modulus;
+            }
+        }
+
+        // Eliminate this column in other rows
+        for (let r = 0; r < N; r++) {
+            if (r === row) continue;
+            const factor = Ab[r][c];
+            if (factor !== 0) {
+                for (let j = c; j <= M; j++) {
+                    Ab[r][j] = (Ab[r][j] - factor * Ab[row][j]) % modulus;
+                    if (Ab[r][j] < 0) Ab[r][j] += modulus;
+                }
+            }
+        }
+        row++;
+    }
+
+    // Check for consistency: if there is a row [0 0 ... 0 | non-zero] then no solution.
+    for (let r = row; r < N; r++) {
+        let allZero = true;
+        for (let c = 0; c < M; c++) {
+            if (Ab[r][c] % modulus !== 0) {
+                allZero = false;
+                break;
+            }
+        }
+        if (allZero && Ab[r][M] % modulus !== 0) {
+            return null; // inconsistent
+        }
+    }
+
+    // Now, we have a row echelon form.
+    // We will find a particular solution and the null space.
+
+    // First, back-substitute to get a particular solution (setting free variables to 0).
+    const x0: number[] = new Array(M).fill(0);
+    // We'll go from bottom up.
+    const pivotCols: number[] = [];
+    for (let c = 0; c < M; c++) {
+        if (pivotRows[c] !== -1) {
+            pivotCols.push(c);
+        }
+    }
+    // Process pivot rows in reverse order
+    for (let i = pivotCols.length - 1; i >= 0; i--) {
+        const c = pivotCols[i];
+        const r = pivotRows[c];
+        // x0[c] = Ab[r][M] - sum_{j>c} Ab[r][j]*x0[j]   (mod modulus)
+        let sum = 0;
+        for (let j = c+1; j < M; j++) {
+            sum = (sum + Ab[r][j] * x0[j]) % modulus;
+            if (sum < 0) sum += modulus;
+        }
+        x0[c] = (Ab[r][M] - sum) % modulus;
+        if (x0[c] < 0) x0[c] += modulus;
+    }
+
+    // Now, find the null space: solve A * x = 0.
+    // The null space basis vectors: for each free variable, set it to 1 and others to 0, then solve for the pivot variables.
+    const freeVars: number[] = [];
+    for (let c = 0; c < M; c++) {
+        if (pivotRows[c] === -1) {
+            freeVars.push(c);
+        }
+    }
+    const d = freeVars.length;
+    const nullSpaceBasis: number[][] = []; // each basis vector is of length M
+    for (let f = 0; f < d; f++) {
+        const vec: number[] = new Array(M).fill(0);
+        const freeVarIndex = freeVars[f];
+        vec[freeVarIndex] = 1; // set this free variable to 1
+        // Now, for each pivot variable, compute its value from the equations.
+        for (let i = pivotCols.length - 1; i >= 0; i--) {
+            const c = pivotCols[i];
+            const r = pivotRows[c];
+            // A[r][c]*x[c] + sum_{j>c} A[r][j]*x[j] = 0 (mod modulus)
+            // We know x[j] for j>c (either free or pivot already computed in this backward pass)
+            let sum = 0;
+            for (let j = c+1; j < M; j++) {
+                sum = (sum + Ab[r][j] * vec[j]) % modulus;
+                if (sum < 0) sum += modulus;
+            }
+            // Since A[r][c] is 1 (because we normalized) -> x[c] = -sum mod modulus
+            vec[c] = (-sum) % modulus;
+            if (vec[c] < 0) vec[c] += modulus;
+        }
+        nullSpaceBasis.push(vec);
+    }
+
+    // Now, the general solution is: x = x0 + sum_{k=0}^{d-1} t_k * nullSpaceBasis[k]   (mod modulus)
+    // where t_k in [0, modulus-1].
+
+    // We want to minimize ||x||_1 = sum_i x_i (since x_i in [0, modulus-1]) and then lexicographically smallest x.
+
+    // If d is small enough, we can iterate over all t_k.
+    // Let's set a threshold: if modulus^d <= 10^7, then we iterate.
+    // Otherwise, we try to split the free variables into two halves and do meet-in-the-middle on the free variables.
+
+    // First, try if d is small.
+    let totalCombinations = 1;
+    for (let i = 0; i < d; i++) {
+        totalCombinations *= modulus;
+        if (totalCombinations > 10000000) { // 10^7
+            break;
+        }
+    }
+
+    if (totalCombinations <= 10000000) {
+        // Iterate over all combinations of t_k
+        let bestSum = Infinity;
+        let bestX: number[] | null = null;
+        // We'll use a single loop from 0 to totalCombinations-1 and decode the t_k.
+        for (let combo = 0; combo < totalCombinations; combo++) {
+            // Decode combo into t_0, t_1, ..., t_{d-1} in base modulus
+            const t: number[] = new Array(d).fill(0);
+            let temp = combo;
+            for (let k = 0; k < d; k++) {
+                t[k] = temp % modulus;
+                temp = Math.floor(temp / modulus);
+            }
+            // Compute x = x0 + sum t[k] * nullSpaceBasis[k] (mod modulus)
+            const x: number[] = x0.slice(); // copy
+            for (let k = 0; k < d; k++) {
+                const tK = t[k];
+                const basis = nullSpaceBasis[k];
+                for (let i = 0; i < M; i++) {
+                    x[i] = (x[i] + tK * basis[i]) % modulus;
+                    if (x[i] < 0) x[i] += modulus;
+                }
+            }
+            // Ensure non-negative (should be by modulus)
+            const sum = x.reduce((a, b) => a + b, 0);
+            // Compare: first by sum, then by lexicographic order of x
+            if (bestX === null || sum < bestSum || (sum === bestSum && lexCompare(x, bestX) < 0)) {
+                bestSum = sum;
+                bestX = x.slice();
+            }
+        }
+        return bestX;
+    } else {
+        // d is too big, try meet-in-the-middle on the free variables.
+        // Split the free variables into two halves: d1 and d2.
+        const d1 = Math.floor(d / 2);
+        const d2 = d - d1;
+        // Precompute for the first half of free variables: index 0 to d1-1
+        const leftMap = new Map(); // key: the contribution vector (from the first half) -> value: best (min sum of the partial x from the first half, then lexicographically smallest partial x for the first half) 
+        // We will compute y = x0 + sum_{k=0}^{d1-1} t_k * nullSpaceBasis[k]
+        // Store for each y: the best (minimal sum of y, then lexicographically smallest y) for the first half.
+        // Note: we are not including the second half yet.
+
+        // Iterate over all combinations for the first half
+        const leftTotal = modulus ** d1;
+        for (let combo = 0; combo < leftTotal; combo++) {
+            // Decode combo into t_0, t_1, ..., t_{d1-1} in base modulus
+            const t: number[] = new Array(d1).fill(0);
+            let temp = combo;
+            for (let k = 0; k < d1; k++) {
+                t[k] = temp % modulus;
+                temp = Math.floor(temp / modulus);
+            }
+            // Compute y = x0 + sum_{k=0}^{d1-1} t_k * nullSpaceBasis[k] (mod modulus)
+            const y: number[] = x0.slice(); // copy
+            for (let k = 0; k < d1; k++) {
+                const tK = t[k];
+                const basis = nullSpaceBasis[k];
+                for (let i = 0; i < M; i++) {
+                    y[i] = (y[i] + tK * basis[i]) % modulus;
+                    if (y[i] < 0) y[i] += modulus;
+                }
+            }
+            const sumY = y.reduce((a, b) => a + b, 0);
+            // Store in leftMap: key is y (as a string for hashing), value is {sum: sumY, vector: y}
+            // We use a string representation of y as the key.
+            const key = y.join(',');
+            const existing = leftMap.get(key);
+            if (!existing || sumY < existing.sum || (sumY === existing.sum && lexCompare(y, existing.vector) < 0)) {
+                leftMap.set(key, { sum: sumY, vector: y.slice() });
+            }
+        }
+
+        // Now iterate over the second half of free variables: index d1 to d-1
+        let bestSum = Infinity;
+        let bestX: number[] | null = null;
+        const rightTotal = modulus ** d2;
+        for (let combo = 0; combo < rightTotal; combo++) {
+            // Decode combo into t_{d1}, t_{d1+1}, ..., t_{d-1} in base modulus
+            const t: number[] = new Array(d2).fill(0);
+            let temp = combo;
+            for (let k = 0; k < d2; k++) {
+                t[k] = temp % modulus;
+                temp = Math.floor(temp / modulus);
+            }
+            // Compute z = sum_{k=d1}^{d-1} t_k * nullSpaceBasis[k] (mod modulus)
+            const z: number[] = new Array(M).fill(0);
+            for (let k = 0; k < d2; k++) {
+                const tK = t[k];
+                const basis = nullSpaceBasis[d1 + k];
+                for (let i = 0; i < M; i++) {
+                    z[i] = (z[i] + tK * basis[i]) % modulus;
+                    if (z[i] < 0) z[i] += modulus;
+                }
+            }
+            // Now, we need to find y such that: x = y + z (mod modulus) is the solution.
+            // But note: our general solution is x = x0 + sum t_k * basis_k = y + z, where y is from the first half and z from the second half.
+            // Actually, we have: 
+            //   y = x0 + sum_{k=0}^{d1-1} t_k * basis_k
+            //   z = sum_{k=d1}^{d-1} t_k * basis_k
+            //   so x = y + z (mod modulus)
+            // We want to minimize ||x||_1 and then lexicographically smallest x.
+
+            // For a fixed z, we need to find y in the leftMap such that we minimize ||y+z||_1 and then lexicographically smallest y+z.
+            // We cannot iterate over all y in the leftMap for each z because the leftMap might be large.
+
+            // Instead, we can precompute for the leftMap a data structure that allows us to query by z? 
+            // But note: we are iterating over z, and for each z we want to find the y that minimizes ||y+z||_1 and then lexicographically smallest y+z.
+
+            // Given the complexity, and since we are already in the branch where d is too big for brute force, we will skip this meet-in-the-middle for now.
+            // We will return null in this branch.
+            // However, to avoid returning null too often, we will only do this if the leftMap size is small enough to iterate over for each z.
+            // Let's set a threshold: if leftMap.size * rightTotal <= 10^7, then we do nested loops.
+            // Otherwise, we skip.
+            if (leftMap.size * rightTotal > 10000000) {
+                // Too big, skip this branch and return null later if we don't find a solution in the brute force null space (but we are in the else branch of the null space brute force)
+                // We will break and return null after the loops.
+                continue;
+            }
+            // Now iterate over leftMap for this z
+            for (const [_keyStr, leftInfo] of leftMap.entries()) {
+                // Parse keyStr back to vector? We didn't store the vector as the key, we stored it in leftInfo.vector.
+                const y = leftInfo.vector;
+                // Compute x = (y + z) mod modulus
+                const x: number[] = new Array(M).fill(0);
+                let sumX = 0;
+                for (let i = 0; i < M; i++) {
+                    x[i] = (y[i] + z[i]) % modulus;
+                    if (x[i] < 0) x[i] += modulus;
+                    sumX += x[i];
+                }
+                // Compare: first by sumX, then by lexicographic order of x
+                if (sumX < bestSum || (sumX === bestSum && lexCompare(x, bestX) < 0)) {
+                    bestSum = sumX;
+                    bestX = x.slice();
+                }
+            }
+        }
+        if (bestX !== null) {
+            return bestX;
+        }
+        // If we didn't find a solution in the meet-in-the-middle, we return null.
+        return null;
+    }
+}
+
+// Helper function: modular inverse for prime modulus
+function modInverse(a: number, modulus: number): number {
+    // Since modulus is prime, we can use Fermat's little theorem: a^(modulus-2) mod modulus
+    // But note: a might be 0 -> then no inverse, but in our use we only call when a != 0.
+    a = ((a % modulus) + modulus) % modulus;
+    if (a === 0) {
+        throw new Error('Modular inverse does not exist for 0');
+    }
+    // Fast exponentiation
+    let result = 1;
+    let base = a;
+    let exp = modulus - 2;
+    while (exp > 0) {
+        if (exp & 1) {
+            result = (result * base) % modulus;
+        }
+        base = (base * base) % modulus;
+        exp >>= 1;
+    }
+    return result;
+}
+
+// Helper function: lexicographic comparison of two number arrays (return -1 if a < b, 0 if a == b, 1 if a > b)
+function lexCompare(a: number[] | null, b: number[] | null): number {
+    if (a === null && b === null) return 0;
+    if (a === null) return -1; // null is considered smaller? but we should not have null in our comparison in the algorithm.
+    if (b === null) return 1;
+    const len = Math.min(a.length, b.length);
+    for (let i = 0; i < len; i++) {
+        if (a[i] < b[i]) return -1;
+        if (a[i] > b[i]) return 1;
+    }
+    if (a.length < b.length) return -1;
+    if (a.length > b.length) return 1;
+    return 0;
+}
