+function timeIt(fn: () => any) {
+    const start = performance.now();
+    const result = fn();
+    const end = performance.now();
+    return { result, time: end - start };
+}
+
+// Stress test for toggle
+function stressToggle() {
+    const M = 40;
+    const N = 40;
+    // Generate random target
+    const target: boolean[] = [];
+    for (let i = 0; i < N; i++) {
+        target.push(Math.random() < 0.5);
+    }
+    // Generate random buttons: each button toggles a random subset of lights
+    const buttons: number[][] = [];
+    for (let i = 0; i < M; i++) {
+        // Each button toggles between 1 and N lights (but we can also have 0? but then it's useless, let's allow 0)
+        const k = Math.floor(Math.random() * (N + 1)); // 0..N
+        const lights: number[] = [];
+        const seen = new Set();
+        while (lights.length < k) {
+            const light = Math.floor(Math.random() * N);
+            if (!seen.has(light)) {
+                seen.add(light);
+                lights.push(light);
+            }
+        }
+        buttons.push(lights);
+    }
+    console.log(`Toggle stress test: M=${M}, N=${N}`);
+    const { result, time } = timeIt(() => solveToggle({ target, buttons }));
+    console.log(`  Time: ${time.toFixed(2)} ms`);
+    console.log(`  Result: ${result === null ? 'null' : '[' + result.map(String).join(',') + ']'}`);
+    if (result !== null) {
+        // Verify the solution
+        const lights = target.map(() => false); // start all off
+        for (const btnIdx of result) {
+            for (const light of buttons[btnIdx]) {
+                lights[light] = !lights[light];
+            }
+        }
+        let ok = true;
+        for (let i = 0; i < N; i++) {
+            if (lights[i] !== target[i]) {
+                ok = false;
+                break;
+            }
+        }
+        console.log(`  Verification: ${ok ? 'PASS' : 'FAIL'}`);
+    }
+}
+
+// Stress test for counter
+function stressCounter() {
+    const M = 40;
+    const N = 40;
+    const modulus = 97; // largest prime <=97
+    // Generate random target lights (0..modulus-1)
+    const lights: number[] = [];
+    for (let i = 0; i < N; i++) {
+        lights.push(Math.floor(Math.random() * modulus));
+    }
+    // Generate random buttons: each button affects a random subset of counters
+    const buttons: number[][] = [];
+    for (let i = 0; i < M; i++) {
+        const k = Math.floor(Math.random() * (N + 1));
+        const lightsIdx: number[] = [];
+        const seen = new Set();
