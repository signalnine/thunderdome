+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createTaxonomyPlugin() {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: async (ctx: BuildContext) => {
+        // Build tag index: Map<tag, ContentFile[]>
+        const tagMap = new Map<string, ContentFile[]>();
+        
+        // Process each file to build tag index
+        for (const file of ctx.files) {
+          const tags = file.tags || [];
+          for (const tag of tags) {
+            // Normalize tag to lowercase
+            const normalizedTag = tag.toLowerCase();
+            
+            // Add file to tag map
+            if (!tagMap.has(normalizedTag)) {
+              tagMap.set(normalizedTag, []);
+            }
+            tagMap.get(normalizedTag)!.push(file);
+          }
+        }
+        
+        // Store tag map in ctx.data
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      
+      afterBuild: async (ctx: BuildContext) => {
+        // Generate tag listing pages
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (!tagMap) return;
+        
+        // Generate a tag page for each tag
+        for (const [tag, files] of tagMap.entries()) {
+          // Simple HTML template for tag listing
+          let html = `<!DOCTYPE html>
+<html>
+<head>
+  <title>Tag: ${tag}</title>
+</head>
+<body>
+  <h1>Tag: ${tag}</h1>
+  <ul>`;
+          
+          // List all files with this tag
+          for (const file of files) {
+            html += `<li><a href="/${file.slug}.html">${file.title}</a></li>`;
+          }
+          
+          html += `</ul>
+</body>
+</html>`;
+          
+          // Add to output
+          ctx.output.set(`tags/${tag}.html`, html);
+        }
+      }
+    }
+  };
+}
