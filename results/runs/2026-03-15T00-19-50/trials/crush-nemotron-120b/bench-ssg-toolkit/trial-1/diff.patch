+import { marked } from 'marked';
+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin() {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext) => {
+        let content = file.content;
+
+        // 1. Extract footnote definitions: [^1]: definition (single line)
+        const footnoteDefs: Record<string, string> = {};
+        // Regex to match footnote definitions at start of line, capture id and definition (until end of line)
+        const footnoteDefRegex = /^\s*\[\^(\d+)\]:\s*(.*)$/m;
+        
+        // Extract definitions and remove them from content
+        const lines = content.split('\n');
+        const keptLines: string[] = [];
+        
+        for (const line of lines) {
+          const match = line.match(footnoteDefRegex);
+          if (match) {
+            const id = match[1];
+            const _def = match[2];
+            footnoteDefs[id] = _def;
+            // Do not add this line to keptLines (removes the definition)
+          } else {
+            keptLines.push(line);
+          }
+        }
+        
+        content = keptLines.join('\n');
+
+        // 2. Replace footnote markers with placeholders
+        content = content.replace(/\[\^(\d+)\]/g, (match, id) => {
+          return `__FOOTNOTE_MARKER_${id}__`;
+        });
+
+        // 3. Extract admonition blocks
+        const admonitionTypes = ['note', 'warning', 'tip'];
+        const admonitionPlaceholders: Record<string, { type: string; inner: string }> = {};
+        let placeholderIndex = 0;
+
+        for (const type of admonitionTypes) {
+          // Regex to match :::type\ncontent\n::: (handles multiple inner newlines)
+          const regex = new RegExp(`:::${type}\\n([\\s\\S]*?)\n:::(?=\\n|$)`, 'g');
+          content = content.replace(regex, (match, inner) => {
+            const placeholder = `<!-- ADMONITION_PLACEHOLDER_${placeholderIndex} -->`;
+            admonitionPlaceholders[placeholder] = { type, inner };
+            placeholderIndex++;
+            return placeholder;
+          });
+        }
+
+        // 4. Convert the remaining markdown with marked
+        const html = marked.parse(content, { async: false });
+
+        // 5. Process footnotes: replace marker placeholders and add footnote section
+        let processedHtml = html;
+        for (const [id] of Object.keys(footnoteDefs)) {
+          const markerPlaceholder = `__FOOTNOTE_MARKER_${id}__`;
+          const link = `<sup><a href="#fn-${id}">${id}</a></sup>`;
+          processedHtml = processedHtml.replace(new RegExp(markerPlaceholder, 'g'), link);
+        }
+
+        if (Object.keys(footnoteDefs).length > 0) {
+          let footnoteSection = '<section class="footnotes"><ol>';
+          for (const [id, def] of Object.entries(footnoteDefs)) {
+            footnoteSection += `<li id="fn-${id}">${def}</li>`;
+          }
+          footnoteSection += '</ol></section>';
+          processedHtml += footnoteSection;
+        }
+
+        // 6. Replace admonition placeholders
+        for (const [placeholder, { type, inner }] of Object.entries(admonitionPlaceholders)) {
+          const div = `<div class="admonition admonition-${type}">${inner}</div>`;
+          processedHtml = processedHtml.replace(placeholder, div);
+        }
+
+        return { ...file, content: processedHtml };
+      }
+    }
+  };
+}
