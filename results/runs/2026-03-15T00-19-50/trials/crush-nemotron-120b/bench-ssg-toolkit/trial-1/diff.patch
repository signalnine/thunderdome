+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin() {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        // Get the tag map from taxonomy plugin
+        const _tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        
+        // Sort files: those with dates first (newest first), then those without dates
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          const hasDateA = a.date !== undefined && a.date !== null;
+          const hasDateB = b.date !== undefined && b.date !== null;
+          
+          // Files with dates come first
+          if (hasDateA && !hasDateB) return -1;
+          if (!hasDateA && hasDateB) return 1;
+          
+          // Both have dates: sort by date descending (newest first)
+          if (hasDateA && hasDateB) {
+            const dateA = new Date(a.date!).getTime();
+            const dateB = new Date(b.date!).getTime();
+            return dateB - dateA;
+          }
+          
+          // Both don't have dates: maintain original order (or sort by title/slug)
+          return a.slug.localeCompare(b.slug);
+        });
+        
+        // Build RSS 2.0 XML
+        const now = new Date().toUTCString();
+        let rss = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${ctx.config.title}</title>
+    <link>${ctx.config.baseUrl}</link>
+    <description>Latest posts from ${ctx.config.title}</description>
+    <lastBuildDate>${now}</lastBuildDate>
+    <language>en-us</language>
+`;
+        
+        // Add each file as an RSS item
+        for (const file of sortedFiles) {
+          // Get categories/tags for this file
+          const categories = (file.tags || []).map(tag => `<category>${tag.toLowerCase()}</category>`).join('\n    ');
+          
+          rss += `    <item>
+      <title>${file.title}</title>
+      <link>${ctx.config.baseUrl}/${file.slug}.html</link>
+      <guid>${ctx.config.baseUrl}/${file.slug}.html</guid>`;
+          
+          // Only add pubDate if the file has a date
+          if (file.date !== undefined && file.date !== null) {
+            rss += `
+      <pubDate>${new Date(file.date!).toUTCString()}</pubDate>`;
+          }
+          
+          rss += `
+      <description><![CDATA[${file.content}]]></description>
+${categories}
+    </item>
+`;
+        }
+        
+        rss += `  </channel>
+</rss>`;
+        
+        // Add to output
+        ctx.output.set('feed.xml', rss);
+      }
+    }
+  };
+}
