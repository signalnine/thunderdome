+import { BuildContext } from '../core/types.js';
+
+export function createDevServerPlugin() {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        // Default port
+        const port = 3000;
+        
+        // Initialize routes array
+        const routes: Array<{ path: string; handler: string }> = [];
+        
+        // Asset paths from asset-pipeline manifest
+        const assetManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assetPaths: string[] = assetManifest?.assets ?? [];
+        
+        // Add asset routes: each asset served at /assets/<asset>
+        for (const asset of assetPaths) {
+          routes.push({ path: `/assets/${asset}`, handler: 'asset' });
+        }
+        
+        // Search index path
+        let searchIndexPath = '';
+        if (ctx.output.has('search-index.json')) {
+          searchIndexPath = '/search-index.json';
+          routes.push({ path: searchIndexPath, handler: 'static' });
+        }
+        
+        // Content routes: all output files except assets and search index
+        for (const [outputPath] of ctx.output.entries()) {
+          // Skip if it's an asset path (starts with assets/) or search index
+          if (outputPath.startsWith('assets/') || outputPath === 'search-index.json') {
+            continue;
+          }
+          routes.push({ path: `/${outputPath}`, handler: 'static' });
+        }
+        
+        // Dev server configuration
+        const devServerConfig = {
+          port,
+          routes,
+          assetPaths,
+          searchIndexPath
+        };
+        
+        // Store in ctx.data
+        ctx.data.set('dev-server-config', devServerConfig);
+      }
+    }
+  };
+}
