+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin() {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext) => {
+        let content = file.content;
+        
+        // Pattern to match <pre><code class="language-...">...</code></pre>
+        // We'll find code blocks with language classes and add highlighted class + data attribute
+        const codeBlockRegex = /(<pre><code class=")language-([^"]*)(">[^<]*<\/code><\/pre>)/g;
+        
+        content = content.replace(codeBlockRegex, (match, p1, lang, p3) => {
+          // Add 'highlighted' class to the existing class attribute
+          // Also add data-language attribute to the <pre> tag
+          return `<pre data-language="${lang}">${p1}language-${lang} highlighted${p3}`;
+        });
+        
+        return { ...file, content };
+      }
+    }
+  };
+}
