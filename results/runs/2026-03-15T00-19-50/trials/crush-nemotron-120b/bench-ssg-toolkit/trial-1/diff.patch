+import { ContentFile, BuildContext } from '../core/types.js';
+
+export function createSitemapPlugin() {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        // Build sitemap XML
+        let sitemap = '<?xml version="1.0" encoding="UTF-8"?>\n';
+        sitemap += '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n';
+        
+        // Add all output files to sitemap
+        for (const [path, _content] of ctx.output.entries()) {
+          // Skip the sitemap itself to avoid infinite loop
+          if (path === 'sitemap.xml') continue;
+          
+          sitemap += '  <url>\n';
+          sitemap += `    <loc>${ctx.config.baseUrl}/${path}</loc>\n`;
+          sitemap += '  </url>\n';
+        }
+        
+        // Add tag pages from taxonomy
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (tagMap) {
+          for (const tag of tagMap.keys()) {
+            sitemap += '  <url>\n';
+            sitemap += `    <loc>${ctx.config.baseUrl}/tags/${tag}.html</loc>\n`;
+            sitemap += '  </url>\n';
+          }
+        }
+        
+        // Add feed.xml if it exists (from rss-feed plugin)
+        if (ctx.output.has('feed.xml')) {
+          sitemap += '  <url>\n';
+          sitemap += `    <loc>${ctx.config.baseUrl}/feed.xml</loc>\n`;
+          sitemap += '  </url>\n';
+        }
+        
+        sitemap += '</urlset>';
+        
+        // Add to output
+        ctx.output.set('sitemap.xml', sitemap);
+      }
+    }
+  };
+}
