+import { BuildContext } from '../core/types.js';
+
+export function createSearchIndexPlugin() {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext) => {
+        // Create search index array
+        const index = [];
+        
+        // Process each file
+        for (const file of ctx.files) {
+          // Extract plain text content by stripping HTML tags
+          // Replace code block content with plain text (already handled by markdown-ext and syntax-highlight)
+          const plainText = file.content
+            // Remove HTML tags but keep their content
+            .replace(/<[^>]*>/g, ' ')
+            // Replace multiple whitespace with single space
+            .replace(/\s+/g, ' ')
+            // Trim
+            .trim();
+          
+          // Create index entry
+          const entry: Record<string, unknown> = {
+            slug: file.slug,
+            title: file.title,
+            content: plainText
+          };
+          
+          // Include tags if present
+          if (file.tags && file.tags.length > 0) {
+            entry.tags = file.tags;
+          }
+          
+          index.push(entry);
+        }
+        
+        // Add to output as JSON
+        ctx.output.set('search-index.json', JSON.stringify(index, null, 2));
+      }
+    }
+  };
+}
