new file mode 100644
index 0000000..43b4f24
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,273 @@
+import { WebSocket, WebSocketServer } from 'ws';
+import { IncomingMessage } from 'http';
+import { DocumentStore } from './db.js';
+import {
+  OpComponent,
+  apply,
+  transform,
+  inputLength,
+  validateOperation,
+} from './ot.js';
+
+/** Messages sent from client to server */
+export interface ClientMessage {
+  type: 'operation';
+  /** The version this operation was created against */
+  baseVersion: number;
+  /** The operation components */
+  components: OpComponent[];
+}
+
+/** Messages sent from server to client */
+export type ServerMessage =
+  | { type: 'sync'; content: string; version: number; clientId: string }
+  | { type: 'operation'; components: OpComponent[]; version: number; clientId: string }
+  | { type: 'ack'; version: number }
+  | { type: 'error'; message: string };
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+interface DocumentSession {
+  /** Current document content in memory */
+  content: string;
+  /** Current version number */
+  version: number;
+  /** History of operations indexed by the version they produced */
+  operationLog: Map<number, OpComponent[]>;
+  /** Connected clients */
+  clients: Map<string, ClientConnection>;
+}
+
+export class CollaborationManager {
+  private store: DocumentStore;
+  private sessions: Map<string, DocumentSession> = new Map();
+  private wss: WebSocketServer | null = null;
+  private clientCounter = 0;
+
+  constructor(store: DocumentStore) {
+    this.store = store;
+  }
+
+  setupWebSocket(wss: WebSocketServer): void {
+    this.wss = wss;
+
+    wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      const url = req.url;
+      if (!url) {
+        this.sendError(ws, 'No URL provided');
+        ws.close();
+        return;
+      }
+
+      // Extract document ID from URL path: /ws/documents/:id
+      const match = url.match(/\/ws\/documents\/([^/?]+)/);
+      if (!match) {
+        this.sendError(ws, 'Invalid WebSocket URL. Expected /ws/documents/:id');
+        ws.close();
+        return;
+      }
+
+      const documentId = match[1];
+      this.handleConnection(ws, documentId);
+    });
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string): void {
+    // Check document exists
+    const doc = this.store.getDocument(documentId);
+    if (!doc) {
+      this.sendError(ws, 'Document not found');
+      ws.close();
+      return;
+    }
+
+    const clientId = `client-${++this.clientCounter}`;
+
+    // Get or create session
+    let session = this.sessions.get(documentId);
+    if (!session) {
+      const latestVersion = this.store.getLatestVersion(documentId);
+      session = {
+        content: doc.content,
+        version: latestVersion ? latestVersion.version : 1,
+        operationLog: new Map(),
+        clients: new Map(),
+      };
+      this.sessions.set(documentId, session);
+    }
+
+    const connection: ClientConnection = { ws, clientId, documentId };
+    session.clients.set(clientId, connection);
+
+    // Send sync message with current state
+    this.send(ws, {
+      type: 'sync',
+      content: session.content,
+      version: session.version,
+      clientId,
+    });
+
+    ws.on('message', (data) => {
+      try {
+        const message = JSON.parse(data.toString()) as ClientMessage;
+        this.handleMessage(connection, message);
+      } catch (err) {
+        this.sendError(ws, `Invalid message: ${err instanceof Error ? err.message : String(err)}`);
+      }
+    });
+
+    ws.on('close', () => {
+      this.handleDisconnect(connection);
+    });
+
+    ws.on('error', () => {
+      this.handleDisconnect(connection);
+    });
+  }
+
+  private handleMessage(connection: ClientConnection, message: ClientMessage): void {
+    if (message.type !== 'operation') {
+      this.sendError(connection.ws, `Unknown message type: ${(message as { type: string }).type}`);
+      return;
+    }
+
+    // Validate the operation
+    const validationError = validateOperation(message.components);
+    if (validationError) {
+      this.sendError(connection.ws, `Invalid operation: ${validationError}`);
+      return;
+    }
+
+    if (typeof message.baseVersion !== 'number' || !Number.isInteger(message.baseVersion) || message.baseVersion < 0) {
+      this.sendError(connection.ws, 'baseVersion must be a non-negative integer');
+      return;
+    }
+
+    const session = this.sessions.get(connection.documentId);
+    if (!session) {
+      this.sendError(connection.ws, 'Document session not found');
+      return;
+    }
+
+    if (message.baseVersion > session.version) {
+      this.sendError(connection.ws, `baseVersion ${message.baseVersion} is ahead of server version ${session.version}`);
+      return;
+    }
+
+    let components = message.components as OpComponent[];
+
+    // Transform against any operations that happened between baseVersion and current version
+    for (let v = message.baseVersion + 1; v <= session.version; v++) {
+      const serverOp = session.operationLog.get(v);
+      if (!serverOp) {
+        this.sendError(connection.ws, `Missing operation for version ${v} in log`);
+        return;
+      }
+      try {
+        const [clientPrime] = transform(components, serverOp);
+        components = clientPrime;
+      } catch (err) {
+        this.sendError(
+          connection.ws,
+          `Transform failed: ${err instanceof Error ? err.message : String(err)}`
+        );
+        return;
+      }
+    }
+
+    // Validate that the transformed operation matches the current document length
+    const opInputLen = inputLength(components);
+    if (opInputLen !== session.content.length) {
+      this.sendError(
+        connection.ws,
+        `Operation input length (${opInputLen}) does not match document length (${session.content.length})`
+      );
+      return;
+    }
+
+    // Apply the transformed operation
+    try {
+      session.content = apply(session.content, components);
+    } catch (err) {
+      this.sendError(
+        connection.ws,
+        `Apply failed: ${err instanceof Error ? err.message : String(err)}`
+      );
+      return;
+    }
+
+    session.version++;
+    session.operationLog.set(session.version, components);
+
+    // Persist to database
+    this.store.updateDocumentContent(
+      connection.documentId,
+      session.content,
+      JSON.stringify(components)
+    );
+
+    // Acknowledge to the sender
+    this.send(connection.ws, {
+      type: 'ack',
+      version: session.version,
+    });
+
+    // Broadcast to other clients
+    for (const [cid, client] of session.clients) {
+      if (cid !== connection.clientId && client.ws.readyState === WebSocket.OPEN) {
+        this.send(client.ws, {
+          type: 'operation',
+          components,
+          version: session.version,
+          clientId: connection.clientId,
+        });
+      }
+    }
+  }
+
+  private handleDisconnect(connection: ClientConnection): void {
+    const session = this.sessions.get(connection.documentId);
+    if (session) {
+      session.clients.delete(connection.clientId);
+      // Clean up session if no more clients
+      if (session.clients.size === 0) {
+        this.sessions.delete(connection.documentId);
+      }
+    }
+  }
+
+  private send(ws: WebSocket, message: ServerMessage): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(message));
+    }
+  }
+
+  private sendError(ws: WebSocket, message: string): void {
+    this.send(ws, { type: 'error', message });
+  }
+
+  /** Close all client connections and clean up sessions */
+  closeAll(): void {
+    for (const session of this.sessions.values()) {
+      for (const client of session.clients.values()) {
+        client.ws.close();
+      }
+    }
+    this.sessions.clear();
+    this.wss = null;
+  }
+
+  /** Get number of active sessions (for testing) */
+  getSessionCount(): number {
+    return this.sessions.size;
+  }
+
+  /** Get number of clients connected to a document (for testing) */
+  getClientCount(documentId: string): number {
+    return this.sessions.get(documentId)?.clients.size ?? 0;
+  }
+}
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..f0aa100
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,152 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { resolve, dirname } from 'path';
+import { fileURLToPath } from 'url';
+import crypto from 'crypto';
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = dirname(__filename);
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath ?? ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  const schemaPath = resolve(__dirname, '..', 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  // Prepared statements
+  private stmtInsertDoc: Database.Statement;
+  private stmtGetDoc: Database.Statement;
+  private stmtListDocs: Database.Statement;
+  private stmtUpdateDoc: Database.Statement;
+  private stmtDeleteDoc: Database.Statement;
+  private stmtInsertVersion: Database.Statement;
+  private stmtGetVersions: Database.Statement;
+  private stmtGetLatestVersion: Database.Statement;
+  private stmtGetVersion: Database.Statement;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+
+    this.stmtInsertDoc = db.prepare(
+      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`
+    );
+
+    this.stmtGetDoc = db.prepare(
+      `SELECT * FROM documents WHERE id = ?`
+    );
+
+    this.stmtListDocs = db.prepare(
+      `SELECT * FROM documents ORDER BY updated_at DESC`
+    );
+
+    this.stmtUpdateDoc = db.prepare(
+      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+    );
+
+    this.stmtDeleteDoc = db.prepare(
+      `DELETE FROM documents WHERE id = ?`
+    );
+
+    this.stmtInsertVersion = db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`
+    );
+
+    this.stmtGetVersions = db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+    );
+
+    this.stmtGetLatestVersion = db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1`
+    );
+
+    this.stmtGetVersion = db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? AND version = ?`
+    );
+  }
+
+  createDocument(title: string, content: string = ''): DocumentRow {
+    const id = crypto.randomUUID();
+    const txn = this.db.transaction(() => {
+      this.stmtInsertDoc.run(id, title, content);
+      this.stmtInsertVersion.run(id, 1, content, null);
+    });
+    txn();
+    return this.stmtGetDoc.get(id) as DocumentRow;
+  }
+
+  getDocument(id: string): DocumentRow | undefined {
+    return this.stmtGetDoc.get(id) as DocumentRow | undefined;
+  }
+
+  listDocuments(): DocumentRow[] {
+    return this.stmtListDocs.all() as DocumentRow[];
+  }
+
+  updateDocument(id: string, title: string, content: string): DocumentRow | undefined {
+    const result = this.stmtUpdateDoc.run(title, content, id);
+    if (result.changes === 0) return undefined;
+    return this.stmtGetDoc.get(id) as DocumentRow;
+  }
+
+  updateDocumentContent(id: string, content: string, operation?: string): DocumentRow | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const txn = this.db.transaction(() => {
+      this.stmtUpdateDoc.run(doc.title, content, id);
+      const latestVersion = this.getLatestVersion(id);
+      const nextVersion = latestVersion ? latestVersion.version + 1 : 1;
+      this.stmtInsertVersion.run(id, nextVersion, content, operation ?? null);
+    });
+    txn();
+
+    return this.stmtGetDoc.get(id) as DocumentRow;
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.stmtDeleteDoc.run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(documentId: string): VersionRow[] {
+    return this.stmtGetVersions.all(documentId) as VersionRow[];
+  }
+
+  getLatestVersion(documentId: string): VersionRow | undefined {
+    return this.stmtGetLatestVersion.get(documentId) as VersionRow | undefined;
+  }
+
+  getVersion(documentId: string, version: number): VersionRow | undefined {
+    return this.stmtGetVersion.get(documentId, version) as VersionRow | undefined;
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/documents.ts b/src/documents.ts
new file mode 100644
index 0000000..d8101a8
--- /dev/null
+++ b/src/documents.ts
@@ -0,0 +1,103 @@
+import { Router, Request, Response } from 'express';
+import { DocumentStore } from './db.js';
+
+export function createDocumentRouter(store: DocumentStore): Router {
+  const router = Router();
+
+  // List all documents
+  router.get('/', (_req: Request, res: Response) => {
+    const docs = store.listDocuments();
+    res.json(docs);
+  });
+
+  // Create a new document
+  router.post('/', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Title is required and must be a string' });
+      return;
+    }
+
+    const doc = store.createDocument(title, typeof content === 'string' ? content : '');
+    res.status(201).json(doc);
+  });
+
+  // Get a specific document
+  router.get('/:id', (req: Request, res: Response) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document
+  router.put('/:id', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Title is required and must be a string' });
+      return;
+    }
+
+    if (typeof content !== 'string') {
+      res.status(400).json({ error: 'Content must be a string' });
+      return;
+    }
+
+    const doc = store.updateDocument(req.params.id, title, content);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Delete a document
+  router.delete('/:id', (req: Request, res: Response) => {
+    const deleted = store.deleteDocument(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get version history for a document
+  router.get('/:id/versions', (req: Request, res: Response) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const versions = store.getVersions(req.params.id);
+    res.json(versions);
+  });
+
+  // Get a specific version
+  router.get('/:id/versions/:version', (req: Request, res: Response) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const versionNum = parseInt(req.params.version, 10);
+    if (isNaN(versionNum)) {
+      res.status(400).json({ error: 'Version must be a number' });
+      return;
+    }
+
+    const version = store.getVersion(req.params.id, versionNum);
+    if (!version) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+    res.json(version);
+  });
+
+  return router;
+}
