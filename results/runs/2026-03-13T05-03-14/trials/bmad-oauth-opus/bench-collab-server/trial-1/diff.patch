+import express from 'express';
+import { createServer, Server } from 'http';
+import { WebSocketServer } from 'ws';
+import { createDatabase, DocumentStore } from './db.js';
+import { createDocumentRouter } from './documents.js';
+import { CollaborationManager } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+  const collaboration = new CollaborationManager(store);
+
+  const app = express();
+  app.use(express.json());
+
+  // REST API routes
+  app.use('/documents', createDocumentRouter(store));
+
+  // Health check
+  app.get('/health', (_req, res) => {
+    res.json({ status: 'ok' });
+  });
+
+  let httpServer: Server | null = null;
+  let wss: WebSocketServer | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      if (httpServer) {
+        throw new Error('Server is already started');
+      }
+
+      return new Promise((resolve, reject) => {
+        httpServer = createServer(app);
+
+        wss = new WebSocketServer({
+          server: httpServer,
+          maxPayload: 1024 * 1024, // 1MB limit per message
+        });
+        collaboration.setupWebSocket(wss);
+
+        httpServer.on('error', reject);
+
+        httpServer.listen(port ?? 0, () => {
+          const address = httpServer!.address();
+          if (address && typeof address === 'object') {
+            resolve(address.port);
+          } else {
+            reject(new Error('Failed to get server address'));
+          }
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      try {
+        collaboration.closeAll();
+      } catch (_e) {
+        // Best-effort cleanup; continue shutting down other resources
+      }
+
+      if (wss) {
+        wss.close();
+        wss = null;
+      }
+
+      if (httpServer) {
+        await new Promise<void>((resolve, reject) => {
+          httpServer!.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+        httpServer = null;
+      }
+
+      store.close();
+    },
+  };
+}
