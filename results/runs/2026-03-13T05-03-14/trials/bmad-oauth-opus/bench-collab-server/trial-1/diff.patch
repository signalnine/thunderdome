+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019hdKT11eAzyqNLqjPu8YgN","type":"tool_result","content":"     1→/**\n     2→ * Operational Transform (OT) engine for collaborative text editing.\n     3→ *\n     4→ * Operations are represented as a sequence of components:\n     5→ * - retain(n): skip n characters\n     6→ * - insert(s): insert string s at current position\n     7→ * - delete(n): delete n characters at current position\n     8→ *\n     9→ * The total \"input length\" of an operation (sum of retains + deletes) must\n    10→ * equal the length of the document it is applied to.\n    11→ */\n    12→\n    13→export type OpComponent =\n    14→  | { type: 'retain'; count: number }\n    15→  | { type: 'insert'; text: string }\n    16→  | { type: 'delete'; count: number };\n    17→\n    18→export interface Operation {\n    19→  /** The document version this operation was generated against */\n    20→  baseVersion: number;\n    21→  /** The operation components */\n    22→  components: OpComponent[];\n    23→}\n    24→\n    25→/** Calculate the input length an operation expects */\n    26→export function inputLength(op: OpComponent[]): number {\n    27→  let len = 0;\n    28→  for (const c of op) {\n    29→    if (c.type === 'retain') len += c.count;\n    30→    else if (c.type === 'delete') len += c.count;\n    31→  }\n    32→  return len;\n    33→}\n    34→\n    35→/** Calculate the output length an operation produces */\n    36→export function outputLength(op: OpComponent[]): number {\n    37→  let len = 0;\n    38→  for (const c of op) {\n    39→    if (c.type === 'retain') len += c.count;\n    40→    else if (c.type === 'insert') len += c.text.length;\n    41→  }\n    42→  return len;\n    43→}\n    44→\n    45→/** Normalize an operation by merging adjacent same-type components and removing no-ops */\n    46→export function normalize(components: OpComponent[]): OpComponent[] {\n    47→  const result: OpComponent[] = [];\n    48→  for (const c of components) {\n    49→    if (c.type === 'retain' && c.count === 0) continue;\n    50→    if (c.type === 'delete' && c.count === 0) continue;\n    51→    if (c.type === 'insert' && c.text === '') continue;\n    52→\n    53→    const last = result[result.length - 1];\n    54→    if (last && last.type === c.type) {\n    55→      if (last.type === 'retain' && c.type === 'retain') {\n    56→        last.count += c.count;\n    57→      } else if (last.type === 'delete' && c.type === 'delete') {\n    58→        last.count += c.count;\n    59→      } else if (last.type === 'insert' && c.type === 'insert') {\n    60→        last.text += c.text;\n    61→      }\n    62→    } else {\n    63→      result.push({ ...c } as OpComponent);\n    64→    }\n    65→  }\n    66→  return result;\n    67→}\n    68→\n    69→/** Apply an operation to a document string, returning the new document */\n    70→export function apply(doc: string, components: OpComponent[]): string {\n    71→  const inLen = inputLength(components);\n    72→  if (inLen !== doc.length) {\n    73→    throw new Error(\n    74→      `Operation input length (${inLen}) does not match document length (${doc.length})`\n    75→    );\n    76→  }\n    77→\n    78→  let result = '';\n    79→  let pos = 0;\n    80→\n    81→  for (const c of components) {\n    82→    switch (c.type) {\n    83→      case 'retain':\n    84→        result += doc.slice(pos, pos + c.count);\n    85→        pos += c.count;\n    86→        break;\n    87→      case 'insert':\n    88→        result += c.text;\n    89→        break;\n    90→      case 'delete':\n    91→        pos += c.count;\n    92→        break;\n    93→    }\n    94→  }\n    95→\n    96→  return result;\n    97→}\n    98→\n    99→/**\n   100→ * Transform two concurrent operations (a and b) that were both applied to the\n   101→ * same document state, producing a' and b' such that:\n   102→ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')\n   103→ *\n   104→ * Returns [aPrime, bPrime].\n   105→ *\n   106→ * This uses the standard OT transform algorithm where:\n   107→ * - Insert vs Insert: a's insert goes first (left wins)\n   108→ * - Insert vs Retain/Delete: insert is preserved\n   109→ * - Retain vs Retain: both retain\n   110→ * - Delete vs Delete: cancel out\n   111→ * - Delete vs Retain: delete wins\n   112→ */\n   113→export function transform(\n   114→  aComponents: OpComponent[],\n   115→  bComponents: OpComponent[]\n   116→): [OpComponent[], OpComponent[]] {\n   117→  const aPrime: OpComponent[] = [];\n   118→  const bPrime: OpComponent[] = [];\n   119→\n   120→  // Use iterators to walk through both operations\n   121→  let ai = 0;\n   122→  let bi = 0;\n   123→  let aRemain: OpComponent | null = null;\n   124→  let bRemain: OpComponent | null = null;\n   125→\n   126→  function nextA(): OpComponent | null {\n   127→    if (aRemain) {\n   128→      const r = aRemain;\n   129→      aRemain = null;\n   130→      return r;\n   131→    }\n   132→    if (ai < aComponents.length) return aComponents[ai++];\n   133→    return null;\n   134→  }\n   135→\n   136→  function nextB(): OpComponent | null {\n   137→    if (bRemain) {\n   138→      const r = bRemain;\n   139→      bRemain = null;\n   140→      return r;\n   141→    }\n   142→    if (bi < bComponents.length) return bComponents[bi++];\n   143→    return null;\n   144→  }\n   145→\n   146→  let a = nextA();\n   147→  let b = nextB();\n   148→\n   149→  while (a !== null || b !== null) {\n   150→    // a inserts: a' gets the insert, b' retains over it\n   151→    if (a && a.type === 'insert') {\n   152→      aPrime.push({ type: 'insert', text: a.text });\n   153→      bPrime.push({ type: 'retain', count: a.text.length });\n   154→      if (b) bRemain = b; // put b back\n   155→      a = nextA();\n   156→      b = nextB();\n   157→      continue;\n   158→    }\n   159→\n   160→    // b inserts: b' gets the insert, a' retains over it\n   161→    if (b && b.type === 'insert') {\n   162→      bPrime.push({ type: 'insert', text: b.text });\n   163→      aPrime.push({ type: 'retain', count: b.text.length });\n   164→      if (a) aRemain = a; // put a back\n   165→      a = nextA();\n   166→      b = nextB();\n   167→      continue;\n   168→    }\n   169→\n   170→    if (a === null || b === null) {\n   171→      throw new Error('Operation length mismatch during transform');\n   172→    }\n   173→\n   174→    // Both are retain or delete from here\n   175→    if (a.type === 'retain' && b.type === 'retain') {\n   176→      const min = Math.min(a.count, b.count);\n   177→      aPrime.push({ type: 'retain', count: min });\n   178→      bPrime.push({ type: 'retain', count: min });\n   179→      if (a.count > min) aRemain = { type: 'retain', count: a.count - min };\n   180→      if (b.count > min) bRemain = { type: 'retain', count: b.count - min };\n   181→    } else if (a.type === 'delete' && b.type === 'delete') {\n   182→      const min = Math.min(a.count, b.count);\n   183→      // Both delete the same chars - they cancel out (no output for either)\n   184→      if (a.count > min) aRemain = { type: 'delete', count: a.count - min };\n   185→      if (b.count > min) bRemain = { type: 'delete', count: b.count - min };\n   186→    } else if (a.type === 'delete' && b.type === 'retain') {\n   187→      const min = Math.min(a.count, b.count);\n   188→      aPrime.push({ type: 'delete', count: min });\n   189→      // b skips over deleted chars\n   190→      if (a.count > min) aRemain = { type: 'delete', count: a.count - min };\n   191→      if (b.count > min) bRemain = { type: 'retain', count: b.count - min };\n   192→    } else if (a.type === 'retain' && b.type === 'delete') {\n   193→      const min = Math.min(a.count, b.count);\n   194→      bPrime.push({ type: 'delete', count: min });\n   195→      // a skips over deleted chars\n   196→      if (a.count > min) aRemain = { type: 'retain', count: a.count - min };\n   197→      if (b.count > min) bRemain = { type: 'delete', count: b.count - min };\n   198→    }\n   199→\n   200→    a = nextA();\n   201→    b = nextB();\n   202→  }\n   203→\n   204→  return [normalize(aPrime), normalize(bPrime)];\n   205→}\n   206→\n   207→/**\n   208→ * Compose two operations into a single operation.\n   209→ * compose(a, b) produces an operation c such that apply(doc, c) === apply(apply(doc, a), b)\n   210→ */\n   211→export function compose(\n   212→  aComponents: OpComponent[],\n   213→  bComponents: OpComponent[]\n   214→): OpComponent[] {\n   215→  const result: OpComponent[] = [];\n   216→\n   217→  let ai = 0;\n   218→  let bi = 0;\n   219→  let aRemain: OpComponent | null = null;\n   220→  let bRemain: OpComponent | null = null;\n   221→\n   222→  function nextA(): OpComponent | null {\n   223→    if (aRemain) {\n   224→      const r = aRemain;\n   225→      aRemain = null;\n   226→      return r;\n   227→    }\n   228→    if (ai < aComponents.length) return aComponents[ai++];\n   229→    return null;\n   230→  }\n   231→\n   232→  function nextB(): OpComponent | null {\n   233→    if (bRemain) {\n   234→      const r = bRemain;\n   235→      bRemain = null;\n   236→      return r;\n   237→    }\n   238→    if (bi < bComponents.length) return bComponents[bi++];\n   239→    return null;\n   240→  }\n   241→\n   242→  let a = nextA();\n   243→  let b = nextB();\n   244→\n   245→  while (a !== null || b !== null) {\n   246→    // a deletes: output delete, put b back\n   247→    if (a && a.type === 'delete') {\n   248→      result.push({ type: 'delete', count: a.count });\n   249→      if (b) bRemain = b;\n   250→      a = nextA();\n   251→      b = nextB();\n   252→      continue;\n   253→    }\n   254→\n   255→    // b inserts: output insert, put a back\n   256→    if (b && b.type === 'insert') {\n   257→      result.push({ type: 'insert', text: b.text });\n   258→      if (a) aRemain = a;\n   259→      a = nextA();\n   260→      b = nextB();\n   261→      continue;\n   262→    }\n   263→\n   264→    if (a === null || b === null) {\n   265→      throw new Error('Compose length mismatch');\n   266→    }\n   267→\n   268→    if (a.type === 'retain' && b.type === 'retain') {\n   269→      const min = Math.min(a.count, b.count);\n   270→      result.push({ type: 'retain', count: min });\n   271→      if (a.count > min) aRemain = { type: 'retain', count: a.count - min };\n   272→      if (b.count > min) bRemain = { type: 'retain', count: b.count - min };\n   273→    } else if (a.type === 'insert' && b.type === 'retain') {\n   274→      const min = Math.min(a.text.length, b.count);\n   275→      result.push({ type: 'insert', text: a.text.slice(0, min) });\n   276→      if (a.text.length > min) aRemain = { type: 'insert', text: a.text.slice(min) };\n   277→      if (b.count > min) bRemain = { type: 'retain', count: b.count - min };\n   278→    } else if (a.type === 'insert' && b.type === 'delete') {\n   279→      const min = Math.min(a.text.length, b.count);\n   280→      // insert then delete cancels out\n   281→      if (a.text.length > min) aRemain = { type: 'insert', text: a.text.slice(min) };\n   282→      if (b.count > min) bRemain = { type: 'delete', count: b.count - min };\n   283→    } else if (a.type === 'retain' && b.type === 'delete') {\n   284→      const min = Math.min(a.count, b.count);\n   285→      result.push({ type: 'delete', count: min });\n   286→      if (a.count > min) aRemain = { type: 'retain', count: a.count - min };\n   287→      if (b.count > min) bRemain = { type: 'delete', count: b.count - min };\n   288→    }\n   289→\n   290→    a = nextA();\n   291→    b = nextB();\n   292→  }\n   293→\n   294→  return normalize(result);\n   295→}\n   296→\n   297→/** Validate operation components and return error message if invalid */\n   298→export function validateOperation(components: unknown): string | null {\n   299→  if (!Array.isArray(components)) {\n   300→    return 'Operation components must be an array';\n   301→  }\n   302→\n   303→  for (let i = 0; i < components.length; i++) {\n   304→    const c = components[i];\n   305→    if (typeof c !== 'object' || c === null) {\n   306→      return `Component ${i}: must be an object`;\n   307→    }\n   308→\n   309→    const comp = c as Record<string, unknown>;\n   310→    if (!('type' in comp)) {\n   311→      return `Component ${i}: missing 'type' field`;\n   312→    }\n   313→\n   314→    switch (comp.type) {\n   315→      case 'retain':\n   316→        if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {\n   317→          return `Component ${i}: retain count must be a non-negative integer`;\n   318→        }\n   319→        break;\n   320→      case 'insert':\n   321→        if (typeof comp.text !== 'string') {\n   322→          return `Component ${i}: insert text must be a string`;\n   323→        }\n   324→        break;\n   325→      case 'delete':\n   326→        if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {\n   327→          return `Component ${i}: delete count must be a non-negative integer`;\n   328→        }\n   329→        break;\n   330→      default:\n   331→        return `Component ${i}: unknown type '${String(comp.type)}'`;\n   332→    }\n   333→  }\n   334→\n   335→  return null;\n   336→}\n   337→"}]},"parent_tool_use_id":"toolu_01KHWzF3RVdsXKWqp8HchrYp","session_id":"4507f320-b808-4e74-bda1-a4565da48d2e","uuid":"a062618b-e25d-496c-b982-4f797a376f31"}
