@@ -0,0 +1,336 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are represented as a sequence of components:
+ * - retain(n): skip n characters
+ * - insert(s): insert string s at current position
+ * - delete(n): delete n characters at current position
+ *
+ * The total "input length" of an operation (sum of retains + deletes) must
+ * equal the length of the document it is applied to.
+ */
+
+export type OpComponent =
+  | { type: 'retain'; count: number }
+  | { type: 'insert'; text: string }
+  | { type: 'delete'; count: number };
+
+export interface Operation {
+  /** The document version this operation was generated against */
+  baseVersion: number;
+  /** The operation components */
+  components: OpComponent[];
+}
+
+/** Calculate the input length an operation expects */
+export function inputLength(op: OpComponent[]): number {
+  let len = 0;
+  for (const c of op) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'delete') len += c.count;
+  }
+  return len;
+}
+
+/** Calculate the output length an operation produces */
+export function outputLength(op: OpComponent[]): number {
+  let len = 0;
+  for (const c of op) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'insert') len += c.text.length;
+  }
+  return len;
+}
+
+/** Normalize an operation by merging adjacent same-type components and removing no-ops */
+export function normalize(components: OpComponent[]): OpComponent[] {
+  const result: OpComponent[] = [];
+  for (const c of components) {
+    if (c.type === 'retain' && c.count === 0) continue;
+    if (c.type === 'delete' && c.count === 0) continue;
+    if (c.type === 'insert' && c.text === '') continue;
+
+    const last = result[result.length - 1];
+    if (last && last.type === c.type) {
+      if (last.type === 'retain' && c.type === 'retain') {
+        last.count += c.count;
+      } else if (last.type === 'delete' && c.type === 'delete') {
+        last.count += c.count;
+      } else if (last.type === 'insert' && c.type === 'insert') {
+        last.text += c.text;
+      }
+    } else {
+      result.push({ ...c } as OpComponent);
+    }
+  }
+  return result;
+}
+
+/** Apply an operation to a document string, returning the new document */
+export function apply(doc: string, components: OpComponent[]): string {
+  const inLen = inputLength(components);
+  if (inLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${inLen}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of components) {
+    switch (c.type) {
+      case 'retain':
+        result += doc.slice(pos, pos + c.count);
+        pos += c.count;
+        break;
+      case 'insert':
+        result += c.text;
+        break;
+      case 'delete':
+        pos += c.count;
+        break;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations (a and b) that were both applied to the
+ * same document state, producing a' and b' such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Returns [aPrime, bPrime].
+ *
+ * This uses the standard OT transform algorithm where:
+ * - Insert vs Insert: a's insert goes first (left wins)
+ * - Insert vs Retain/Delete: insert is preserved
+ * - Retain vs Retain: both retain
+ * - Delete vs Delete: cancel out
+ * - Delete vs Retain: delete wins
+ */
+export function transform(
+  aComponents: OpComponent[],
+  bComponents: OpComponent[]
+): [OpComponent[], OpComponent[]] {
+  const aPrime: OpComponent[] = [];
+  const bPrime: OpComponent[] = [];
+
+  // Use iterators to walk through both operations
+  let ai = 0;
+  let bi = 0;
+  let aRemain: OpComponent | null = null;
+  let bRemain: OpComponent | null = null;
+
+  function nextA(): OpComponent | null {
+    if (aRemain) {
+      const r = aRemain;
+      aRemain = null;
+      return r;
+    }
+    if (ai < aComponents.length) return aComponents[ai++];
+    return null;
+  }
+
+  function nextB(): OpComponent | null {
+    if (bRemain) {
+      const r = bRemain;
+      bRemain = null;
+      return r;
+    }
+    if (bi < bComponents.length) return bComponents[bi++];
+    return null;
+  }
+
+  let a = nextA();
+  let b = nextB();
+
+  while (a !== null || b !== null) {
+    // a inserts: a' gets the insert, b' retains over it
+    if (a && a.type === 'insert') {
+      aPrime.push({ type: 'insert', text: a.text });
+      bPrime.push({ type: 'retain', count: a.text.length });
+      if (b) bRemain = b; // put b back
+      a = nextA();
+      b = nextB();
+      continue;
+    }
+
+    // b inserts: b' gets the insert, a' retains over it
+    if (b && b.type === 'insert') {
+      bPrime.push({ type: 'insert', text: b.text });
+      aPrime.push({ type: 'retain', count: b.text.length });
+      if (a) aRemain = a; // put a back
+      a = nextA();
+      b = nextB();
+      continue;
+    }
+
+    if (a === null || b === null) {
+      throw new Error('Operation length mismatch during transform');
+    }
+
+    // Both are retain or delete from here
+    if (a.type === 'retain' && b.type === 'retain') {
+      const min = Math.min(a.count, b.count);
+      aPrime.push({ type: 'retain', count: min });
+      bPrime.push({ type: 'retain', count: min });
+      if (a.count > min) aRemain = { type: 'retain', count: a.count - min };
+      if (b.count > min) bRemain = { type: 'retain', count: b.count - min };
+    } else if (a.type === 'delete' && b.type === 'delete') {
+      const min = Math.min(a.count, b.count);
+      // Both delete the same chars - they cancel out (no output for either)
+      if (a.count > min) aRemain = { type: 'delete', count: a.count - min };
+      if (b.count > min) bRemain = { type: 'delete', count: b.count - min };
+    } else if (a.type === 'delete' && b.type === 'retain') {
+      const min = Math.min(a.count, b.count);
+      aPrime.push({ type: 'delete', count: min });
+      // b skips over deleted chars
+      if (a.count > min) aRemain = { type: 'delete', count: a.count - min };
+      if (b.count > min) bRemain = { type: 'retain', count: b.count - min };
+    } else if (a.type === 'retain' && b.type === 'delete') {
+      const min = Math.min(a.count, b.count);
+      bPrime.push({ type: 'delete', count: min });
+      // a skips over deleted chars
+      if (a.count > min) aRemain = { type: 'retain', count: a.count - min };
+      if (b.count > min) bRemain = { type: 'delete', count: b.count - min };
+    }
+
+    a = nextA();
+    b = nextB();
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/**
+ * Compose two operations into a single operation.
+ * compose(a, b) produces an operation c such that apply(doc, c) === apply(apply(doc, a), b)
+ */
+export function compose(
+  aComponents: OpComponent[],
+  bComponents: OpComponent[]
+): OpComponent[] {
+  const result: OpComponent[] = [];
+
+  let ai = 0;
+  let bi = 0;
+  let aRemain: OpComponent | null = null;
+  let bRemain: OpComponent | null = null;
+
+  function nextA(): OpComponent | null {
+    if (aRemain) {
+      const r = aRemain;
+      aRemain = null;
+      return r;
+    }
+    if (ai < aComponents.length) return aComponents[ai++];
+    return null;
+  }
+
+  function nextB(): OpComponent | null {
+    if (bRemain) {
+      const r = bRemain;
+      bRemain = null;
+      return r;
+    }
+    if (bi < bComponents.length) return bComponents[bi++];
+    return null;
+  }
+
+  let a = nextA();
+  let b = nextB();
+
+  while (a !== null || b !== null) {
+    // a deletes: output delete, put b back
+    if (a && a.type === 'delete') {
+      result.push({ type: 'delete', count: a.count });
+      if (b) bRemain = b;
+      a = nextA();
+      b = nextB();
+      continue;
+    }
+
+    // b inserts: output insert, put a back
+    if (b && b.type === 'insert') {
+      result.push({ type: 'insert', text: b.text });
+      if (a) aRemain = a;
+      a = nextA();
+      b = nextB();
+      continue;
+    }
+
+    if (a === null || b === null) {
+      throw new Error('Compose length mismatch');
+    }
+
+    if (a.type === 'retain' && b.type === 'retain') {
+      const min = Math.min(a.count, b.count);
+      result.push({ type: 'retain', count: min });
+      if (a.count > min) aRemain = { type: 'retain', count: a.count - min };
+      if (b.count > min) bRemain = { type: 'retain', count: b.count - min };
+    } else if (a.type === 'insert' && b.type === 'retain') {
+      const min = Math.min(a.text.length, b.count);
+      result.push({ type: 'insert', text: a.text.slice(0, min) });
+      if (a.text.length > min) aRemain = { type: 'insert', text: a.text.slice(min) };
+      if (b.count > min) bRemain = { type: 'retain', count: b.count - min };
+    } else if (a.type === 'insert' && b.type === 'delete') {
+      const min = Math.min(a.text.length, b.count);
+      // insert then delete cancels out
+      if (a.text.length > min) aRemain = { type: 'insert', text: a.text.slice(min) };
+      if (b.count > min) bRemain = { type: 'delete', count: b.count - min };
+    } else if (a.type === 'retain' && b.type === 'delete') {
+      const min = Math.min(a.count, b.count);
+      result.push({ type: 'delete', count: min });
+      if (a.count > min) aRemain = { type: 'retain', count: a.count - min };
+      if (b.count > min) bRemain = { type: 'delete', count: b.count - min };
+    }
+
+    a = nextA();
+    b = nextB();
+  }
+
+  return normalize(result);
+}
+
+/** Validate operation components and return error message if invalid */
+export function validateOperation(components: unknown): string | null {
+  if (!Array.isArray(components)) {
+    return 'Operation components must be an array';
+  }
+
+  for (let i = 0; i < components.length; i++) {
+    const c = components[i];
+    if (typeof c !== 'object' || c === null) {
+      return `Component ${i}: must be an object`;
+    }
+
+    const comp = c as Record<string, unknown>;
+    if (!('type' in comp)) {
+      return `Component ${i}: missing 'type' field`;
+    }
+
+    switch (comp.type) {
+      case 'retain':
+        if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {
+          return `Component ${i}: retain count must be a non-negative integer`;
+        }
+        break;
+      case 'insert':
+        if (typeof comp.text !== 'string') {
+          return `Component ${i}: insert text must be a string`;
+        }
+        break;
+      case 'delete':
+        if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {
+          return `Component ${i}: delete count must be a non-negative integer`;
+        }
+        break;
+      default:
+        return `Component ${i}: unknown type '${String(comp.type)}'`;
+    }
+  }
+
+  return null;
+}
