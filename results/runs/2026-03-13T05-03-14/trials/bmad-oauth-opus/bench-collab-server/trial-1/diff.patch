e(ws1) as ErrorMessage;\n    expect(error.type).toBe('error');\n  });\n\n  it('should reject malformed messages', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1 } = await connectClient(docId);\n\n    ws1.send('not valid json{{{');\n\n    const error = await waitForMessage(ws1) as ErrorMessage;\n    expect(error.type).toBe('error');\n  });\n\n  it('should reject operations with invalid component types', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1 } = await connectClient(docId);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 1,\n      components: [\n        { type: 'unknown_op', count: 5 },\n      ],\n    }));\n\n    const error = await waitForMessage(ws1) as ErrorMessage;\n    expect(error.type).toBe('error');\n  });\n\n  it('should handle client disconnect gracefully', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1 } = await connectClient(docId);\n    const { ws: ws2, sync: sync2 } = await connectClient(docId);\n\n    // Disconnect client 1\n    ws1.close();\n\n    // Wait a bit for disconnect to process\n    await new Promise((resolve) => setTimeout(resolve, 100));\n\n    // Client 2 should still be able to send operations\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync2.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: '!' },\n      ],\n    }));\n\n    const ack = await waitForMessage(ws2) as AckMessage;\n    expect(ack.type).toBe('ack');\n\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello!');\n  });\n\n  it('should create version history for each operation', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1, sync: sync1 } = await connectClient(docId);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion