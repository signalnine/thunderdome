+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YYmcgvh11NB3WHdwjM7Sd7","type":"tool_result","content":"     1→import { WebSocket, WebSocketServer } from 'ws';\n     2→import { IncomingMessage } from 'http';\n     3→import { DocumentStore } from './db.js';\n     4→import {\n     5→  OpComponent,\n     6→  apply,\n     7→  transform,\n     8→  inputLength,\n     9→  validateOperation,\n    10→} from './ot.js';\n    11→\n    12→/** Messages sent from client to server */\n    13→export interface ClientMessage {\n    14→  type: 'operation';\n    15→  /** The version this operation was created against */\n    16→  baseVersion: number;\n    17→  /** The operation components */\n    18→  components: OpComponent[];\n    19→}\n    20→\n    21→/** Messages sent from server to client */\n    22→export type ServerMessage =\n    23→  | { type: 'sync'; content: string; version: number; clientId: string }\n    24→  | { type: 'operation'; components: OpComponent[]; version: number; clientId: string }\n    25→  | { type: 'ack'; version: number }\n    26→  | { type: 'error'; message: string };\n    27→\n    28→interface ClientConnection {\n    29→  ws: WebSocket;\n    30→  clientId: string;\n    31→  documentId: string;\n    32→}\n    33→\n    34→interface DocumentSession {\n    35→  /** Current document content in memory */\n    36→  content: string;\n    37→  /** Current version number */\n    38→  version: number;\n    39→  /** History of operations indexed by the version they produced */\n    40→  operationLog: Map<number, OpComponent[]>;\n    41→  /** Connected clients */\n    42→  clients: Map<string, ClientConnection>;\n    43→}\n    44→\n    45→export class CollaborationManager {\n    46→  private store: DocumentStore;\n    47→  private sessions: Map<string, DocumentSession> = new Map();\n    48→  private wss: WebSocketServer | null = null;\n    49→  private clientCounter = 0;\n    50→\n    51→  constructor(store: DocumentStore) {\n    52→    this.store = store;\n    53→  }\n    54→\n    55→  setupWebSocket(wss: WebSocketServer): void {\n    56→    this.wss = wss;\n    57→\n    58→    wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n    59→      const url = req.url;\n    60→      if (!url) {\n    61→        this.sendError(ws, 'No URL provided');\n    62→        ws.close();\n    63→        return;\n    64→      }\n    65→\n    66→      // Extract document ID from URL path: /ws/documents/:id\n    67→      const match = url.match(/\\/ws\\/documents\\/([^/?]+)/);\n    68→      if (!match) {\n    69→        this.sendError(ws, 'Invalid WebSocket URL. Expected /ws/documents/:id');\n    70→        ws.close();\n    71→        return;\n    72→      }\n    73→\n    74→      const documentId = match[1];\n    75→      this.handleConnection(ws, documentId);\n    76→    });\n    77→  }\n    78→\n    79→  private handleConnection(ws: WebSocket, documentId: string): void {\n    80→    // Check document exists\n    81→    const doc = this.store.getDocument(documentId);\n    82→    if (!doc) {\n    83→      this.sendError(ws, 'Document not found');\n    84→      ws.close();\n    85→      return;\n    86→    }\n    87→\n    88→    const clientId = `client-${++this.clientCounter}`;\n    89→\n    90→    // Get or create session\n    91→    let session = this.sessions.get(documentId);\n    92→    if (!session) {\n    93→      const latestVersion = this.store.getLatestVersion(documentId);\n    94→      session = {\n    95→        content: doc.content,\n    96→        version: latestVersion ? latestVersion.version : 1,\n    97→        operationLog: new Map(),\n    98→        clients: new Map(),\n    99→      };\n   100→      this.sessions.set(documentId, session);\n   101→    }\n   102→\n   103→    const connection: ClientConnection = { ws, clientId, documentId };\n   104→    session.clients.set(clientId, connection);\n   105→\n   106→    // Send sync message with current state\n   107→    this.send(ws, {\n   108→      type: 'sync',\n   109→      content: session.content,\n   110→      version: session.version,\n   111→      clientId,\n   112→    });\n   113→\n   114→    ws.on('message', (data) => {\n   115→      try {\n   116→        const message = JSON.parse(data.toString()) as ClientMessage;\n   117→        this.handleMessage(connection, message);\n   118→      } catch (err) {\n   119→        this.sendError(ws, `Invalid message: ${err instanceof Error ? err.message : String(err)}`);\n   120→      }\n   121→    });\n   122→\n   123→    ws.on('close', () => {\n   124→      this.handleDisconnect(connection);\n   125→    });\n   126→\n   127→    ws.on('error', () => {\n   128→      this.handleDisconnect(connection);\n   129→    });\n   130→  }\n   131→\n   132→  private handleMessage(connection: ClientConnection, message: ClientMessage): void {\n   133→    if (message.type !== 'operation') {\n   134→      this.sendError(connection.ws, `Unknown message type: ${(message as { type: string }).type}`);\n   135→      return;\n   136→    }\n   137→\n   138→    // Validate the operation\n   139→    const validationError = validateOperation(message.components);\n   140→    if (validationError) {\n   141→      this.sendError(connection.ws, `Invalid operation: ${validationError}`);\n   142→      return;\n   143→    }\n   144→\n   145→    if (typeof message.baseVersion !== 'number' || !Number.isInteger(message.baseVersion) || message.baseVersion < 0) {\n   146→      this.sendError(connection.ws, 'baseVersion must be a non-negative integer');\n   147→      return;\n   148→    }\n   149→\n   150→    const session = this.sessions.get(connection.documentId);\n   151→    if (!session) {\n   152→      this.sendError(connection.ws, 'Document session not found');\n   153→      return;\n   154→    }\n   155→\n   156→    if (message.baseVersion > session.version) {\n   157→      this.sendError(connection.ws, `baseVersion ${message.baseVersion} is ahead of server version ${session.version}`);\n   158→      return;\n   159→    }\n   160→\n   161→    let components = message.components as OpComponent[];\n   162→\n   163→    // Transform against any operations that happened between baseVersion and current version\n   164→    for (let v = message.baseVersion + 1; v <= session.version; v++) {\n   165→      const serverOp = session.operationLog.get(v);\n   166→      if (!serverOp) {\n   167→        this.sendError(connection.ws, `Missing operation for version ${v} in log`);\n   168→        return;\n   169→      }\n   170→      try {\n   171→        const [clientPrime] = transform(components, serverOp);\n   172→        components = clientPrime;\n   173→      } catch (err) {\n   174→        this.sendError(\n   175→          connection.ws,\n   176→          `Transform failed: ${err instanceof Error ? err.message : String(err)}`\n   177→        );\n   178→        return;\n   179→      }\n   180→    }\n   181→\n   182→    // Validate that the transformed operation matches the current document length\n   183→    const opInputLen = inputLength(components);\n   184→    if (opInputLen !== session.content.length) {\n   185→      this.sendError(\n   186→        connection.ws,\n   187→        `Operation input length (${opInputLen}) does not match document length (${session.content.length})`\n   188→      );\n   189→      return;\n   190→    }\n   191→\n   192→    // Apply the transformed operation\n   193→    try {\n   194→      session.content = apply(session.content, components);\n   195→    } catch (err) {\n   196→      this.sendError(\n   197→        connection.ws,\n   198→        `Apply failed: ${err instanceof Error ? err.message : String(err)}`\n   199→      );\n   200→      return;\n   201→    }\n   202→\n   203→    session.version++;\n   204→    session.operationLog.set(session.version, components);\n   205→\n   206→    // Persist to database\n   207→    this.store.updateDocumentContent(\n   208→      connection.documentId,\n   209→      session.content,\n   210→      JSON.stringify(components)\n   211→    );\n   212→\n   213→    // Acknowledge to the sender\n   214→    this.send(connection.ws, {\n   215→      type: 'ack',\n   216→      version: session.version,\n   217→    });\n   218→\n   219→    // Broadcast to other clients\n   220→    for (const [cid, client] of session.clients) {\n   221→      if (cid !== connection.clientId && client.ws.readyState === WebSocket.OPEN) {\n   222→        this.send(client.ws, {\n   223→          type: 'operation',\n   224→          components,\n   225→          version: session.version,\n   226→          clientId: connection.clientId,\n   227→        });\n   228→      }\n   229→    }\n   230→  }\n   231→\n   232→  private handleDisconnect(connection: ClientConnection): void {\n   233→    const session = this.sessions.get(connection.documentId);\n   234→    if (session) {\n   235→      session.clients.delete(connection.clientId);\n   236→      // Clean up session if no more clients\n   237→      if (session.clients.size === 0) {\n   238→        this.sessions.delete(connection.documentId);\n   239→      }\n   240→    }\n   241→  }\n   242→\n   243→  private send(ws: WebSocket, message: ServerMessage): void {\n   244→    if (ws.readyState === WebSocket.OPEN) {\n   245→      ws.send(JSON.stringify(message));\n   246→    }\n   247→  }\n   248→\n   249→  private sendError(ws: WebSocket, message: string): void {\n   250→    this.send(ws, { type: 'error', message });\n   251→  }\n   252→\n   253→  /** Close all connections and clean up */\n   254→  closeAll(): void {\n   255→    for (const session of this.sessions.values()) {\n   256→      for (const client of session.clients.values()) {\n   257→        client.ws.close();\n   258→      }\n   259→    }\n   260→    this.sessions.clear();\n   261→    if (this.wss) {\n   262→      this.wss.close();\n   263→      this.wss = null;\n   264→    }\n   265→  }\n   266→\n   267→  /** Get number of active sessions (for testing) */\n   268→  getSessionCount(): number {\n   269→    return this.sessions.size;\n   270→  }\n   271→\n   272→  /** Get number of clients connected to a document (for testing) */\n   273→  getClientCount(documentId: string): number {\n   274→    return this.sessions.get(documentId)?.clients.size ?? 0;\n   275→  }\n   276→}\n   277→"}]},"parent_tool_use_id":"toolu_01KHWzF3RVdsXKWqp8HchrYp","session_id":"4507f320-b808-4e74-bda1-a4565da48d2e","uuid":"345e014b-6f10-4806-9802-5ab7f6dedf4b"}
