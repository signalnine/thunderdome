.handleDisconnect(connection);\n    });\n\n    ws.on('error', () => {\n      this.handleDisconnect(connection);\n    });\n  }\n\n  private handleMessage(connection: ClientConnection, message: ClientMessage): void {\n    if (message.type !== 'operation') {\n      this.sendError(connection.ws, `Unknown message type: ${(message as { type: string }).type}`);\n      return;\n    }\n\n    // Validate the operation\n    const validationError = validateOperation(message.components);\n    if (validationError) {\n      this.sendError(connection.ws, `Invalid operation: ${validationError}`);\n      return;\n    }\n\n    if (typeof message.baseVersion !== 'number' || !Number.isInteger(message.baseVersion) || message.baseVersion < 0) {\n      this.sendError(connection.ws, 'baseVersion must be a non-negative integer');\n      return;\n    }\n\n    const session = this.sessions.get(connection.documentId);\n    if (!session) {\n      this.sendError(connection.ws, 'Document session not found');\n      return;\n    }\n\n    if (message.baseVersion > session.version) {\n      this.sendError(connection.ws, `baseVersion ${message.baseVersion} is ahead of server version ${session.version}`);\n      return;\n    }\n\n    let components = message.components as OpComponent[];\n\n    // Transform against any operations that happened between baseVersion and current version\n    for (let v = message.baseVersion + 1; v <= session.version; v++) {\n      const serverOp = session.operationLog.get(v);\n      if (!serverOp) {\n        this.sendError(connection.ws, `Missing operation for version ${v} in log`);\n        return;\n      }\n      try {\n        const [clientPrime] = transform(components, serverOp);\n        components = clientPrime;\n      } catch (err) {\n        this.sendError(\n          connection.ws,\n          `Transform failed: ${err instanceof Error ? err.message : String(err)}`\n        );\n        return;\n      }\n    }\n\n    // Validate that the transformed operation matches the current document length\n    const opInputLen = inputLength(components);\n    if (opInputLen !== session.content.length) {\n      this.sendError(\n        connection.ws,\n        `Operation input length (${opInputLen}) does not match document length (${session.content.length})`\n      );\n      return;\n    }\n\n    // Apply the transformed operation\n    try {\n      session.content = apply(session.content, components);\n    } catch (err) {\n      this.sendError(\n        connection.ws,\n        `Apply failed: ${err instanceof Error ? err.message : String(err)}`\n      );\n      return;\n    }\n\n    session.version++;\n    session.operationLog.set(session.version, components);\n\n    // Persist to database\n    this.store.updateDocumentContent(\n      connection.documentId,\n      session.content,\n      JSON.stringify(components)\n    );\n\n    // Acknowledge to the sender\n    this.send(connection.ws, {\n      type: 'ack',\n      version: session.version,\n    });\n\n    // Broadcast to other clients\n    for (const [cid, client] of session.clients) {\n      if (cid !== connection.clientId && client.ws.readyState === WebSocket.OPEN) {\n        this.send(client.ws, {\n          type: 'operation',\n          components,\n          version: session.version,\n          clientId: connection.clientId,\n        });\n      }\n    }\n  }\n\n  private handleDisconnect(connection: ClientConnection): void {\n    const session = this.sessions.get(connection.documentId);\n    if (session) {\n      session.clients.delete(connection.clientId);\n      // Clean up session if no more clients\n      if (session.clients.size === 0) {\n        this.sessions.delete(connection.documentId);\n      }\n    }\n  }\n\n  private send(ws: WebSocket, message: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(message));\n    }\n  }\n\n  private sendError(ws: WebSocket, message: string): void {\n    this.send(ws, { type: 'error', message });\n  }\n\n  /** Close all connections and clean up */\n  closeAll(): void {\n    for (const session of this.sessions.values()) {\n      for (const client of session.clients.values()) {\n        client.ws.close();\n      }\n    }\n    this.sessions.clear();\n    if (this.wss) {\n      this.wss.close();\n      this.wss = null;\n    }\n  }\n\n  /** Get number of active sessions (for testing) */\n  getSessionCount(): number {\n    return this.sessions.size;\n  }\n\n  /** Get number of clients connected to a document (for testing) */\n  getClientCount(documentId: string): number {\n    return this.sessions.get(documentId)?.clients.size ?? 0;\n  }\n}\n","structuredPatch":[],"originalFile":null}}
