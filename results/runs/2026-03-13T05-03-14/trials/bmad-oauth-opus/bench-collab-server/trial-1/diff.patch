+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+describe('REST API', () => {
+  let app: AppInstance;
+
+  beforeEach(async () => {
+    app = createApp(); // in-memory DB
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  describe('GET /health', () => {
+    it('should return ok', async () => {
+      const res = await request(app.app).get('/health');
+      expect(res.status).toBe(200);
+      expect(res.body.status).toBe('ok');
+    });
+  });
+
+  describe('POST /documents', () => {
+    it('should create a document', async () => {
+      const res = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'Hello world' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello world');
+      expect(res.body.id).toBeDefined();
+    });
+
+    it('should create a document with empty content', async () => {
+      const res = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Empty Doc' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.content).toBe('');
+    });
+
+    it('should reject document without title', async () => {
+      const res = await request(app.app)
+        .post('/documents')
+        .send({ content: 'No title' });
+
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('GET /documents', () => {
+    it('should list documents', async () => {
+      await request(app.app).post('/documents').send({ title: 'Doc 1' });
+      await request(app.app).post('/documents').send({ title: 'Doc 2' });
+
+      const res = await request(app.app).get('/documents');
+      expect(res.status).toBe(200);
+      expect(res.body).toHaveLength(2);
+    });
+
+    it('should return empty array when no documents', async () => {
+      const res = await request(app.app).get('/documents');
+      expect(res.status).toBe(200);
+      expect(res.body).toEqual([]);
+    });
+  });
+
+  describe('GET /documents/:id', () => {
+    it('should get a specific document', async () => {
+      const created = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Test', content: 'body' });
+
+      const res = await request(app.app).get(`/documents/${created.body.id}`);
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('Test');
+      expect(res.body.content).toBe('body');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      const res = await request(app.app).get('/documents/nonexistent');
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('PUT /documents/:id', () => {
+    it('should update a document', async () => {
+      const created = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Original', content: 'old content' });
+
+      const res = await request(app.app)
+        .put(`/documents/${created.body.id}`)
+        .send({ title: 'Updated', content: 'new content' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('Updated');
+      expect(res.body.content).toBe('new content');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      const res = await request(app.app)
+        .put('/documents/nonexistent')
+        .send({ title: 'X', content: 'Y' });
+      expect(res.status).toBe(404);
+    });
+
+    it('should reject missing title', async () => {
+      const created = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Test', content: '' });
+
+      const res = await request(app.app)
+        .put(`/documents/${created.body.id}`)
+        .send({ content: 'no title' });
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('DELETE /documents/:id', () => {
+    it('should delete a document', async () => {
+      const created = await request(app.app)
+        .post('/documents')
+        .send({ title: 'To Delete' });
+
+      const res = await request(app.app).delete(`/documents/${created.body.id}`);
+      expect(res.status).toBe(204);
+
+      const getRes = await request(app.app).get(`/documents/${created.body.id}`);
+      expect(getRes.status).toBe(404);
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      const res = await request(app.app).delete('/documents/nonexistent');
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('GET /documents/:id/versions', () => {
+    it('should return version history', async () => {
+      const created = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Versioned', content: 'v1' });
+
+      const res = await request(app.app)
+        .get(`/documents/${created.body.id}/versions`);
+
+      expect(res.status).toBe(200);
+      expect(res.body).toHaveLength(1);
+      expect(res.body[0].version).toBe(1);
+      expect(res.body[0].content).toBe('v1');
+    });
+
+    it('should return 404 for non-existent document versions', async () => {
+      const res = await request(app.app).get('/documents/nonexistent/versions');
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('GET /documents/:id/versions/:version', () => {
+    it('should return a specific version', async () => {
+      const created = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Versioned', content: 'initial' });
+
+      const res = await request(app.app)
+        .get(`/documents/${created.body.id}/versions/1`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.version).toBe(1);
+      expect(res.body.content).toBe('initial');
+    });
+
+    it('should return 404 for non-existent version', async () => {
+      const created = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Versioned', content: 'initial' });
+
+      const res = await request(app.app)
+        .get(`/documents/${created.body.id}/versions/99`);
+      expect(res.status).toBe(404);
+    });
+
+    it('should return 400 for invalid version number', async () => {
+      const created = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Versioned', content: 'initial' });
+
+      const res = await request(app.app)
+        .get(`/documents/${created.body.id}/versions/abc`);
+      expect(res.status).toBe(400);
+    });
+  });
+});
