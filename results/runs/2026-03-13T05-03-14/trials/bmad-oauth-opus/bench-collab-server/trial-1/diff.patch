nimport { createApp, AppInstance } from '../src/server.js';\n\ninterface SyncMessage {\n  type: 'sync';\n  content: string;\n  version: number;\n  clientId: string;\n}\n\ninterface AckMessage {\n  type: 'ack';\n  version: number;\n}\n\ninterface OperationMessage {\n  type: 'operation';\n  components: Array<{ type: string; count?: number; text?: string }>;\n  version: number;\n  clientId: string;\n}\n\ninterface ErrorMessage {\n  type: 'error';\n  message: string;\n}\n\ntype ServerMessage = SyncMessage | AckMessage | OperationMessage | ErrorMessage;\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<ServerMessage> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('Timeout waiting for message')), 5000);\n    ws.once('message', (data) => {\n      clearTimeout(timeout);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction waitForMessageOfType(ws: WebSocket, type: string): Promise<ServerMessage> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error(`Timeout waiting for ${type} message`)), 5000);\n    const handler = (data: WebSocket.RawData) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === type) {\n        clearTimeout(timeout);\n        ws.removeListener('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let app: AppInstance;\n  let port: number;\n  const clients: WebSocket[] = [];\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    for (const ws of clients) {\n      if (ws.readyState === WebSocket.OPEN) {\n        ws.close();\n      }\n    }\n    clients.length = 0;\n    await app.stop();\n  });\n\n  async function createDoc(title: string, content: string = ''): Promise<string> {\n    const res = await request(app.app)\n      .post('/documents')\n      .send({ title, content });\n    return res.body.id;\n  }\n\n  async function connectClient(docId: string): Promise<{ ws: WebSocket; sync: SyncMessage }> {\n    const ws = await connectWs(port, docId);\n    clients.push(ws);\n    const sync = await waitForMessage(ws) as SyncMessage;\n    return { ws, sync };\n  }\n\n  it('should send sync message on connection', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { sync } = await connectClient(docId);\n\n    expect(sync.type).toBe('sync');\n    expect(sync.content).toBe('hello');\n    expect(sync.version).toBe(1);\n    expect(sync.clientId).toBeDefined();\n  });\n\n  it('should reject connection to non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    clients.push(ws);\n\n    const msg = await new Promise<ServerMessage>((resolve) => {\n      ws.on('message', (data) => {\n        resolve(JSON.parse(data.toString()));\n      });\n    });\n\n    expect(msg.type).toBe('error');\n  });\n\n  it('should apply an insert operation and broadcast', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1, sync: sync1 } = await connectClient(docId);\n    const { ws: ws2 } = await connectClient(docId);\n\n    // Client 1 sends an insert at position 5\n    const broadcastPromise = waitForMessageOfType(ws2, 'operation');\n    const ackPromise = waitForMessage(ws1);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync1.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' world' },\n      ],\n    }));\n\n    const ack = await ackPromise as AckMessage;\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    const broadcast = await broadcastPromise as OperationMessage;\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(2);\n\n    // Verify document persisted correctly\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n  });\n\n  it('should apply a delete operation', async () => {\n    const docId = await createDoc('Test', 'hello world');\n    const { ws: ws1, sync: sync1 } = await connectClient(docId);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync1.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'delete', count: 6 },\n      ],\n    }));\n\n    const ack = await waitForMessage(ws1) as AckMessage;\n    expect(ack.type).toBe('ack');\n\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello');\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1, sync: sync1 } = await connectClient(docId);\n    const { ws: ws2, sync: sync2 } = await connectClient(docId);\n\n    // Both clients send operations against version 1\n    // Client 1: insert \" world\" at end -> \"hello world\"\n    // Client 2: insert \"say \" at beginning -> \"say hello\"\n\n    const ack1Promise = waitForMessageOfType(ws1, 'ack');\n    const broadcast1to2Promise = waitForMessageOfType(ws2, 'operation');\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync1.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' world' },\n      ],\n    }));\n\n    await ack1Promise;\n    await broadcast1to2Promise;\n\n    // Now client 2 sends its operation (still based on version 1)\n    const ack2Promise = waitForMessageOfType(ws2, 'ack');\n    const broadcast2to1Promise = waitForMessageOfType(ws1, 'operation');\n\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync2.version,\n      components: [\n        { type: 'insert', text: 'say ' },\n        { type: 'retain', count: 5 },\n      ],\n    }));\n\n    await ack2Promise;\n    await broadcast2to1Promise;\n\n    // Verify final document state - both edits preserved\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('say hello world');\n  });\n\n  it('should handle rapid sequential operations from one client', async () => {\n    const docId = await createDoc('Test', '');\n    const { ws: ws1 } = await connectClient(docId);\n\n    // Send \"H\" then \"e\" then \"l\" then \"l\" then \"o\"\n    for (let i = 0; i < 5; i++) {\n      const char = 'Hello'[i];\n      ws1.send(JSON.stringify({\n        type: 'operation',\n        baseVersion: 1 + i,\n        components: [\n          { type: 'retain', count: i },\n          { type: 'insert', text: char },\n        ],\n      }));\n\n      const ack = await waitForMessage(ws1) as AckMessage;\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(2 + i);\n    }\n\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('Hello');\n  });\n\n  it('should reject invalid operations gracefully', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1 } = await connectClient(docId);\n\n    // Send invalid operation (wrong input length)\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 1,\n      components: [\n        { type: 'retain', count: 100 },\n      ],\n    }));\n\n    const error = await waitForMessage(ws1) as ErrorMessage;\n    expect(error.type).toBe('error');\n  });\n\n  it('should reject malformed messages', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1 } = await connectClient(docId);\n\n    ws1.send('not valid json{{{');\n\n    const error = await waitForMessage(ws1) as ErrorMessage;\n    expect(error.type).toBe('error');\n  });\n\n  it('should reject operations with invalid component types', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1 } = await connectClient(docId);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 1,\n      components: [\n        { type: 'unknown_op', count: 5 },\n      ],\n    }));\n\n    const error = await waitForMessage(ws1) as ErrorMessage;\n    expect(error.type).toBe('error');\n  });\n\n  it('should handle client disconnect gracefully', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1 } = await connectClient(docId);\n    const { ws: ws2, sync: sync2 } = await connectClient(docId);\n\n    // Disconnect client 1\n    ws1.close();\n\n    // Wait a bit for disconnect to process\n    await new Promise((resolve) => setTimeout(resolve, 100));\n\n    // Client 2 should still be able to send operations\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync2.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: '!' },\n      ],\n    }));\n\n    const ack = await waitForMessage(ws2) as AckMessage;\n    expect(ack.type).toBe('ack');\n\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello!');\n  });\n\n  it('should create version history for each operation', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1, sync: sync1 } = await connectClient(docId);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync1.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' world' },\n      ],\n    }));\n\n    await waitForMessage(ws1);\n\n    const versionsRes = await request(app.app)\n      .get(`/documents/${docId}/versions`);\n\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);\n    expect(versionsRes.body[0].content).toBe('hello');\n    expect(versionsRes.body[1].content).toBe('hello world');\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const docId = await createDoc('Test', '');\n    const connections: Array<{ ws: WebSocket; sync: SyncMessage }> = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      connections.push(await connectClient(docId));\n    }\n\n    // Each client inserts a character sequentially to avoid race conditions\n    let expectedVersion = 1;\n    for (let i = 0; i < 10; i++) {\n      const { ws } = connections[i];\n      const char = String(i);\n\n      ws.send(JSON.stringify({\n        type: 'operation',\n        baseVersion: expectedVersion,\n        components: [\n          { type: 'retain', count: i },\n          { type: 'insert', text: char },\n        ],\n      }));\n\n      // Wait for ack\n      const ack = await waitForMessageOfType(ws, 'ack') as AckMessage;\n      expect(ack.type).toBe('ack');\n      expectedVersion = ack.version;\n\n      // Drain broadcasts from other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          await waitForMessageOfType(connections[j].ws, 'operation');\n        }\n      }\n    }\n\n    // Verify final state\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('0123456789');\n  });\n\n  it('should reject operation with baseVersion ahead of server', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1 } = await connectClient(docId);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 999,\n      components: [\n        { type: 'retain', count: 5 },\n      ],\n    }));\n\n    const error = await waitForMessage(ws1) as ErrorMessage;\n    expect(error.type).toBe('error');\n    expect(error.message).toContain('ahead');\n  });\n\n  it('should handle invalid WebSocket URL', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/invalid/path`);\n    clients.push(ws);\n\n    const msg = await new Promise<ServerMessage>((resolve) => {\n      ws.on('message', (data) => {\n        resolve(JSON.parse(data.toString()));\n      });\n    });\n\n    expect(msg.type).toBe('error');\n  });\n\n  it('should persist changes across sessions', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1, sync: sync1 } = await connectClient(docId);\n\n    // Make an edit\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync1.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' world' },\n      ],\n    }));\n\n    await waitForMessage(ws1);\n    ws1.close();\n\n    // Wait for disconnect\n    await new Promise((r) => setTimeout(r, 100));\n\n    // Reconnect - should see the updated content\n    const { sync: sync2 } = await connectClient(docId);\n    expect(sync2.content).toBe('hello world');\n  });\n});\n","structuredPatch":[{"oldStart":29,"oldLines":10,"newStart":29,"newLines":44,"lines":[" "," type ServerMessage = SyncMessage | AckMessage | OperationMessage | ErrorMessage;"," ","-function connectWs(port: number, docId: string): Promise<WebSocket> {","+/**","+ * Connect a WebSocket and return both the WebSocket and a promise for the first","+ * message. The message listener is attached before waiting for 'open' so no","+ * messages are missed.","+ */","+function connectWs(port: number, docId: string): Promise<{ ws: WebSocket; firstMessage: Promise<ServerMessage> }> {","   return new Promise((resolve, reject) => {","     const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);","-    ws.on('open', () => resolve(ws));","+","+    // Buffered message queue so nothing is lost","+    const messageQueue: ServerMessage[] = [];","+    let messageWaiter: ((msg: S