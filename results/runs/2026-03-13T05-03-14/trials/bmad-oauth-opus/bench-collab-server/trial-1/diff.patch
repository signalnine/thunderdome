cumentStore {\n  private db: Database.Database;\n\n  // Prepared statements\n  private stmtInsertDoc: Database.Statement;\n  private stmtGetDoc: Database.Statement;\n  private stmtListDocs: Database.Statement;\n  private stmtUpdateDoc: Database.Statement;\n  private stmtDeleteDoc: Database.Statement;\n  private stmtInsertVersion: Database.Statement;\n  private stmtGetVersions: Database.Statement;\n  private stmtGetLatestVersion: Database.Statement;\n  private stmtGetVersion: Database.Statement;\n\n  constructor(db: Database.Database) {\n    this.db = db;\n\n    this.stmtInsertDoc = db.prepare(\n      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`\n    );\n\n    this.stmtGetDoc = db.prepare(\n      `SELECT * FROM documents WHERE id = ?`\n    );\n\n    this.stmtListDocs = db.prepare(\n      `SELECT * FROM documents ORDER BY updated_at DESC`\n    );\n\n    this.stmtUpdateDoc = db.prepare(\n      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`\n    );\n\n    this.stmtDeleteDoc = db.prepare(\n      `DELETE FROM documents WHERE id = ?`\n    );\n\n    this.stmtInsertVersion = db.prepare(\n      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`\n    );\n\n    this.stmtGetVersions = db.prepare(\n      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`\n    );\n\n    this.stmtGetLatestVersion = db.prepare(\n      `SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1`\n    );\n\n    this.stmtGetVersion = db.prepare(\n      `SELECT * FROM versions WHERE document_id = ? AND version = ?`\n    );\n  }\n\n  createDocument(title: string, content: string = ''): DocumentRow {\n    const id = crypto.randomUUID();\n    this.stmtInsertDoc.run(id, title, content);\n    // Save initial version\n    this.stmtInsertVersion.run(id, 1, content, null);\n    return this.stmtGetDoc.get(id) as DocumentRow;\n  }\n\n  getDocument(id: string): DocumentRow | undefined {\n 