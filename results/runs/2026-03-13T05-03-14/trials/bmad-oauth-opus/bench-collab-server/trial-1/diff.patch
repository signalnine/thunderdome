+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, normalize, inputLength, outputLength, validateOperation, OpComponent } from '../src/ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply insert at beginning', () => {
+      const doc = 'hello';
+      const ops: OpComponent[] = [
+        { type: 'insert', text: 'say ' },
+        { type: 'retain', count: 5 },
+      ];
+      expect(apply(doc, ops)).toBe('say hello');
+    });
+
+    it('should apply insert at end', () => {
+      const doc = 'hello';
+      const ops: OpComponent[] = [
+        { type: 'retain', count: 5 },
+        { type: 'insert', text: ' world' },
+      ];
+      expect(apply(doc, ops)).toBe('hello world');
+    });
+
+    it('should apply insert in middle', () => {
+      const doc = 'helo';
+      const ops: OpComponent[] = [
+        { type: 'retain', count: 2 },
+        { type: 'insert', text: 'l' },
+        { type: 'retain', count: 2 },
+      ];
+      expect(apply(doc, ops)).toBe('hello');
+    });
+
+    it('should apply delete at beginning', () => {
+      const doc = 'say hello';
+      const ops: OpComponent[] = [
+        { type: 'delete', count: 4 },
+        { type: 'retain', count: 5 },
+      ];
+      expect(apply(doc, ops)).toBe('hello');
+    });
+
+    it('should apply delete at end', () => {
+      const doc = 'hello world';
+      const ops: OpComponent[] = [
+        { type: 'retain', count: 5 },
+        { type: 'delete', count: 6 },
+      ];
+      expect(apply(doc, ops)).toBe('hello');
+    });
+
+    it('should apply on empty document', () => {
+      const ops: OpComponent[] = [
+        { type: 'insert', text: 'hello' },
+      ];
+      expect(apply('', ops)).toBe('hello');
+    });
+
+    it('should apply delete entire document', () => {
+      const ops: OpComponent[] = [
+        { type: 'delete', count: 5 },
+      ];
+      expect(apply('hello', ops)).toBe('');
+    });
+
+    it('should throw when input length does not match', () => {
+      const ops: OpComponent[] = [
+        { type: 'retain', count: 10 },
+      ];
+      expect(() => apply('hello', ops)).toThrow('does not match document length');
+    });
+  });
+
+  describe('transform', () => {
+    it('should transform two inserts at same position', () => {
+      // Both insert at beginning of "hello"
+      const a: OpComponent[] = [
+        { type: 'insert', text: 'A' },
+        { type: 'retain', count: 5 },
+      ];
+      const b: OpComponent[] = [
+        { type: 'insert', text: 'B' },
+        { type: 'retain', count: 5 },
+      ];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const doc = 'hello';
+      // apply a then b' should equal apply b then a'
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+      // a goes first (left wins): "ABhello"
+      expect(result1).toBe('ABhello');
+    });
+
+    it('should transform inserts at different positions', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [
+        { type: 'retain', count: 1 },
+        { type: 'insert', text: 'X' },
+        { type: 'retain', count: 4 },
+      ];
+      const b: OpComponent[] = [
+        { type: 'retain', count: 4 },
+        { type: 'insert', text: 'Y' },
+        { type: 'retain', count: 1 },
+      ];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+      expect(result1).toBe('hXellYo');
+    });
+
+    it('should transform insert vs delete', () => {
+      const doc = 'hello';
+      // a: insert 'X' at position 2
+      const a: OpComponent[] = [
+        { type: 'retain', count: 2 },
+        { type: 'insert', text: 'X' },
+        { type: 'retain', count: 3 },
+      ];
+      // b: delete chars at position 1-3 ("ell")
+      const b: OpComponent[] = [
+        { type: 'retain', count: 1 },
+        { type: 'delete', count: 3 },
+        { type: 'retain', count: 1 },
+      ];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+    });
+
+    it('should transform two overlapping deletes', () => {
+      const doc = 'hello world';
+      // a: delete "llo" (positions 2-4)
+      const a: OpComponent[] = [
+        { type: 'retain', count: 2 },
+        { type: 'delete', count: 3 },
+        { type: 'retain', count: 6 },
+      ];
+      // b: delete "lo w" (positions 3-6)
+      const b: OpComponent[] = [
+        { type: 'retain', count: 3 },
+        { type: 'delete', count: 4 },
+        { type: 'retain', count: 4 },
+      ];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+      expect(result1).toBe(result2);
+    });
+
+    it('should handle identity operations', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [{ type: 'retain', count: 5 }];
+      const b: OpComponent[] = [{ type: 'retain', count: 5 }];
+      const [aPrime, bPrime] = transform(a, b);
+
+      expect(apply(apply(doc, a), bPrime)).toBe('hello');
+      expect(apply(apply(doc, b), aPrime)).toBe('hello');
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two insertions', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [
+        { type: 'retain', count: 5 },
+        { type: 'insert', text: ' world' },
+      ];
+      const b: OpComponent[] = [
+        { type: 'retain', count: 11 },
+        { type: 'insert', text: '!' },
+      ];
+      const composed = compose(a, b);
+      expect(apply(doc, composed)).toBe(apply(apply(doc, a), b));
+    });
+
+    it('should compose insert then delete', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [
+        { type: 'insert', text: 'XX' },
+        { type: 'retain', count: 5 },
+      ];
+      const b: OpComponent[] = [
+        { type: 'delete', count: 2 },
+        { type: 'retain', count: 5 },
+      ];
+      const composed = compose(a, b);
+      expect(apply(doc, composed)).toBe(apply(apply(doc, a), b));
+    });
+  });
+
+  describe('normalize', () => {
+    it('should merge adjacent retains', () => {
+      const result = normalize([
+        { type: 'retain', count: 3 },
+        { type: 'retain', count: 5 },
+      ]);
+      expect(result).toEqual([{ type: 'retain', count: 8 }]);
+    });
+
+    it('should merge adjacent inserts', () => {
+      const result = normalize([
+        { type: 'insert', text: 'hel' },
+        { type: 'insert', text: 'lo' },
+      ]);
+      expect(result).toEqual([{ type: 'insert', text: 'hello' }]);
+    });
+
+    it('should remove zero-length ops', () => {
+      const result = normalize([
+        { type: 'retain', count: 0 },
+        { type: 'retain', count: 5 },
+        { type: 'delete', count: 0 },
+        { type: 'insert', text: '' },
+      ]);
+      expect(result).toEqual([{ type: 'retain', count: 5 }]);
+    });
+  });
+
+  describe('inputLength / outputLength', () => {
+    it('should calculate correct input length', () => {
+      const ops: OpComponent[] = [
+        { type: 'retain', count: 3 },
+        { type: 'insert', text: 'abc' },
+        { type: 'delete', count: 2 },
+      ];
+      expect(inputLength(ops)).toBe(5);
+    });
+
+    it('should calculate correct output length', () => {
+      const ops: OpComponent[] = [
+        { type: 'retain', count: 3 },
+        { type: 'insert', text: 'abc' },
+        { type: 'delete', count: 2 },
+      ];
+      expect(outputLength(ops)).toBe(6);
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should accept valid operations', () => {
+      expect(validateOperation([
+        { type: 'retain', count: 5 },
+        { type: 'insert', text: 'hello' },
+        { type: 'delete', count: 3 },
+      ])).toBeNull();
+    });
+
+    it('should reject non-array', () => {
+      expect(validateOperation('not an array')).not.toBeNull();
+    });
+
+    it('should reject missing type', () => {
+      expect(validateOperation([{ count: 5 }])).not.toBeNull();
+    });
+
+    it('should reject unknown type', () => {
+      expect(validateOperation([{ type: 'unknown' }])).not.toBeNull();
+    });
+
+    it('should reject negative retain count', () => {
+      expect(validateOperation([{ type: 'retain', count: -1 }])).not.toBeNull();
+    });
+
+    it('should reject non-string insert text', () => {
+      expect(validateOperation([{ type: 'insert', text: 5 }])).not.toBeNull();
+    });
+  });
+});
