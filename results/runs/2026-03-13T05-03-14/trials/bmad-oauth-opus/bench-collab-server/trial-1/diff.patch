({\n      type: 'operation',\n      baseVersion: sync1.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' world' },\n      ],\n    }));\n\n    const ack = await ackPromise as AckMessage;\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    const broadcast = await broadcastPromise as OperationMessage;\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(2);\n\n    // Verify document persisted correctly\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n  });\n\n  it('should apply a delete operation', async () => {\n    const docId = await createDoc('Test', 'hello world');\n    const { ws: ws1, sync: sync1 } = await connectClient(docId);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync1.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'delete', count: 6 },\n      ],\n    }));\n\n    const ack = await waitForMessage(ws1) as AckMessage;\n    expect(ack.type).toBe('ack');\n\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello');\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const { ws: ws1, sync: sync1 } = await connectClient(docId);\n    const { ws: ws2, sync: sync2 } = await connectClient(docId);\n\n    // Both clients send operations against version 1\n    // Client 1: insert \" world\" at end -> \"hello world\"\n    // Client 2: insert \"say \" at beginning -> \"say hello\"\n\n    const ack1Promise = waitForMessageOfType(ws1, 'ack');\n    const broadcast1to2Promise = waitForMessageOfType(ws2, 'operation');\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: sync1.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', tex