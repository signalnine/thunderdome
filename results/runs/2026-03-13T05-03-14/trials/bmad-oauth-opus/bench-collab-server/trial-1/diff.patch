+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp, AppInstance } from '../src/server.js';
+
+interface SyncMessage {
+  type: 'sync';
+  content: string;
+  version: number;
+  clientId: string;
+}
+
+interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+interface OperationMessage {
+  type: 'operation';
+  components: Array<{ type: string; count?: number; text?: string }>;
+  version: number;
+  clientId: string;
+}
+
+interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+type ServerMessage = SyncMessage | AckMessage | OperationMessage | ErrorMessage;
+
+/**
+ * Connect a WebSocket and return both the WebSocket and a promise for the first
+ * message. The message listener is attached before waiting for 'open' so no
+ * messages are missed.
+ */
+function connectWs(port: number, docId: string): Promise<{ ws: WebSocket; firstMessage: Promise<ServerMessage> }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);
+
+    // Buffered message queue so nothing is lost
+    const messageQueue: ServerMessage[] = [];
+    let messageWaiter: ((msg: ServerMessage) => void) | null = null;
+
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString()) as ServerMessage;
+      if (messageWaiter) {
+        const waiter = messageWaiter;
+        messageWaiter = null;
+        waiter(msg);
+      } else {
+        messageQueue.push(msg);
+      }
+    });
+
+    const firstMessage = new Promise<ServerMessage>((res, rej) => {
+      const timeout = setTimeout(() => rej(new Error('Timeout waiting for first message')), 5000);
+      if (messageQueue.length > 0) {
+        clearTimeout(timeout);
+        res(messageQueue.shift()!);
+      } else {
+        messageWaiter = (msg) => {
+          clearTimeout(timeout);
+          res(msg);
+        };
+      }
+    });
+
+    ws.on('open', () => resolve({ ws, firstMessage }));
+    ws.on('error', reject);
+  });
+}
+
+function waitForMessage(ws: WebSocket): Promise<ServerMessage> {
+  return new Promise((resolve, reject) => {
+    const timeout = setTimeout(() => reject(new Error('Timeout waiting for message')), 5000);
+    ws.once('message', (data) => {
+      clearTimeout(timeout);
+      resolve(JSON.parse(data.toString()));
+    });
+  });
+}
+
+function waitForMessageOfType(ws: WebSocket, type: string): Promise<ServerMessage> {
+  return new Promise((resolve, reject) => {
+    const timeout = setTimeout(() => reject(new Error(`Timeout waiting for ${type} message`)), 5000);
+    const handler = (data: WebSocket.RawData) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === type) {
+        clearTimeout(timeout);
+        ws.removeListener('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+  });
+}
+
