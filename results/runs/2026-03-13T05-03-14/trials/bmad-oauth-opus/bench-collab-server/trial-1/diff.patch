+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JBHdyzqhMWvHVPsMFg85gF","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { readFileSync } from 'fs';\n     3→import { resolve, dirname } from 'path';\n     4→import { fileURLToPath } from 'url';\n     5→import crypto from 'crypto';\n     6→\n     7→const __filename = fileURLToPath(import.meta.url);\n     8→const __dirname = dirname(__filename);\n     9→\n    10→export interface DocumentRow {\n    11→  id: string;\n    12→  title: string;\n    13→  content: string;\n    14→  created_at: string;\n    15→  updated_at: string;\n    16→}\n    17→\n    18→export interface VersionRow {\n    19→  id: number;\n    20→  document_id: string;\n    21→  version: number;\n    22→  content: string;\n    23→  operation: string | null;\n    24→  created_at: string;\n    25→}\n    26→\n    27→export function createDatabase(dbPath?: string): Database.Database {\n    28→  const db = new Database(dbPath ?? ':memory:');\n    29→  db.pragma('journal_mode = WAL');\n    30→  db.pragma('foreign_keys = ON');\n    31→\n    32→  const schemaPath = resolve(__dirname, '..', 'schema.sql');\n    33→  const schema = readFileSync(schemaPath, 'utf-8');\n    34→  db.exec(schema);\n    35→\n    36→  return db;\n    37→}\n    38→\n    39→export class DocumentStore {\n    40→  private db: Database.Database;\n    41→\n    42→  // Prepared statements\n    43→  private stmtInsertDoc: Database.Statement;\n    44→  private stmtGetDoc: Database.Statement;\n    45→  private stmtListDocs: Database.Statement;\n    46→  private stmtUpdateDoc: Database.Statement;\n    47→  private stmtDeleteDoc: Database.Statement;\n    48→  private stmtInsertVersion: Database.Statement;\n    49→  private stmtGetVersions: Database.Statement;\n    50→  private stmtGetLatestVersion: Database.Statement;\n    51→  private stmtGetVersion: Database.Statement;\n    52→\n    53→  constructor(db: Database.Database) {\n    54→    this.db = db;\n    55→\n    56→    this.stmtInsertDoc = db.prepare(\n    57→      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`\n    58→    );\n    59→\n    60→    this.stmtGetDoc = db.prepare(\n    61→      `SELECT * FROM documents WHERE id = ?`\n    62→    );\n    63→\n    64→    this.stmtListDocs = db.prepare(\n    65→      `SELECT * FROM documents ORDER BY updated_at DESC`\n    66→    );\n    67→\n    68→    this.stmtUpdateDoc = db.prepare(\n    69→      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`\n    70→    );\n    71→\n    72→    this.stmtDeleteDoc = db.prepare(\n    73→      `DELETE FROM documents WHERE id = ?`\n    74→    );\n    75→\n    76→    this.stmtInsertVersion = db.prepare(\n    77→      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`\n    78→    );\n    79→\n    80→    this.stmtGetVersions = db.prepare(\n    81→      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`\n    82→    );\n    83→\n    84→    this.stmtGetLatestVersion = db.prepare(\n    85→      `SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1`\n    86→    );\n    87→\n    88→    this.stmtGetVersion = db.prepare(\n    89→      `SELECT * FROM versions WHERE document_id = ? AND version = ?`\n    90→    );\n    91→  }\n    92→\n    93→  createDocument(title: string, content: string = ''): DocumentRow {\n    94→    const id = crypto.randomUUID();\n    95→    this.stmtInsertDoc.run(id, title, content);\n    96→    // Save initial version\n    97→    this.stmtInsertVersion.run(id, 1, content, null);\n    98→    return this.stmtGetDoc.get(id) as DocumentRow;\n    99→  }\n   100→\n   101→  getDocument(id: string): DocumentRow | undefined {\n   102→    return this.stmtGetDoc.get(id) as DocumentRow | undefined;\n   103→  }\n   104→\n   105→  listDocuments(): DocumentRow[] {\n   106→    return this.stmtListDocs.all() as DocumentRow[];\n   107→  }\n   108→\n   109→  updateDocument(id: string, title: string, content: string): DocumentRow | undefined {\n   110→    const result = this.stmtUpdateDoc.run(title, content, id);\n   111→    if (result.changes === 0) return undefined;\n   112→    return this.stmtGetDoc.get(id) as DocumentRow;\n   113→  }\n   114→\n   115→  updateDocumentContent(id: string, content: string, operation?: string): DocumentRow | undefined {\n   116→    const doc = this.getDocument(id);\n   117→    if (!doc) return undefined;\n   118→\n   119→    this.stmtUpdateDoc.run(doc.title, content, id);\n   120→\n   121→    const latestVersion = this.getLatestVersion(id);\n   122→    const nextVersion = latestVersion ? latestVersion.version + 1 : 1;\n   123→    this.stmtInsertVersion.run(id, nextVersion, content, operation ?? null);\n   124→\n   125→    return this.stmtGetDoc.get(id) as DocumentRow;\n   126→  }\n   127→\n   128→  deleteDocument(id: string): boolean {\n   129→    const result = this.stmtDeleteDoc.run(id);\n   130→    return result.changes > 0;\n   131→  }\n   132→\n   133→  getVersions(documentId: string): VersionRow[] {\n   134→    return this.stmtGetVersions.all(documentId) as VersionRow[];\n   135→  }\n   136→\n   137→  getLatestVersion(documentId: string): VersionRow | undefined {\n   138→    return this.stmtGetLatestVersion.get(documentId) as VersionRow | undefined;\n   139→  }\n   140→\n   141→  getVersion(documentId: string, version: number): VersionRow | undefined {\n   142→    return this.stmtGetVersion.get(documentId, version) as VersionRow | undefined;\n   143→  }\n   144→\n   145→  close(): void {\n   146→    this.db.close();\n   147→  }\n   148→}\n   149→"}]},"parent_tool_use_id":"toolu_01KHWzF3RVdsXKWqp8HchrYp","session_id":"4507f320-b808-4e74-bda1-a4565da48d2e","uuid":"ae51c2c6-2d71-4e94-aed7-c145a91b611f"}
