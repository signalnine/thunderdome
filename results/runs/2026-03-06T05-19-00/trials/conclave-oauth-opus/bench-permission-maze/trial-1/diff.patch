', () => {\n  let app: Express;\n  let token: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    token = await registerAndLogin(app, 'alice');\n  });\n\n  describe('POST /folders', () => {\n    it('should create a folder', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'My Folder' });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('My Folder');\n      expect(res.body).toHaveProperty('id');\n      expect(res.body.parentId).toBeNull();\n    });\n\n    it('should create a nested folder', async () => {\n      const parent = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Parent' });\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n      expect(res.status).toBe(201);\n      expect(res.body.parentId).toBe(parent.body.id);\n    });\n\n    it('should reject missing name', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({});\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject non-existent parent', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: 'nonexistent' });\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('GET /folders/:id', () => {\n    it('should get a folder with children and documents', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Parent' });\n      await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: folder.body.id });\n      await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'content', folderId: folder.body.id });\n\n      const res = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.children).toHaveLength(1);\n      expect(res.body.documents).toHaveLength(1);\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .get('/folders/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(404);\n    });\n\n    it('should deny access to unauthorized user', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Private' });\n      const bobToken = await registerAndLogin(app, 'bob');\n      const res = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('PUT /folders/:id', () => {\n    it('should update folder name', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Old Name' });\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'New Name' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('New Name');\n    });\n\n    it('should deny update to viewer', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Folder' });\n      const bobToken = await registerAndLogin(app, 'bob');\n      // Get bob's user id\n      const bobReg = await request(app).post('/auth/register').send({ username: 'bob2', password: 'p' });\n      // Share with bob as viewer - first get bob's id\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ userId: (await request(app).post('/auth/login').send({ username: 'bob', password: 'pass123' })).body.token ? '' : '', role: 'viewer' });\n      // Actually we need bob's user ID, let's do it properly\n    });\n  });\n\n  describe('DELETE /folders/:id', () => {\n    it('should delete a folder', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'ToDelete' });\n      const res = await request(app)\n        .delete(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(204);\n\n      const getRes = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(getRes.status).toBe(404);\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .delete('/folders/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(404);\n    });\n  });\n});\n","numLines":162,"startLine":1,"totalLines":162}}}
