.body.id);\n    });\n\n    it('should reject missing name', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({});\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject non-existent parent', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Child', parentId: 'nonexistent' });\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('GET /folders/:id', () => {\n    it('should get a folder with children and documents', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Parent' });\n      await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Child', parentId: folder.body.id });\n      await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ title: 'Doc', content: 'content', folderId: folder.body.id });\n\n      const res = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${alice.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.children).toHaveLength(1);\n      expect(res.body.documents).toHaveLength(1);\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .get('/folders/nonexistent')\n        .set('Authorization', `Bearer ${alice.token}`);\n      expect(res.status).toBe(404);\n    });\n\n    it('should deny access to unauthorized user', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Private' });\n      const bob = await registerAndLogin(app, 'bob');\n      const res = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('PUT /folders/:id', () => {\n    it('should update folder name', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Old Name' });\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'New Name' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('New Name');\n    });\n\n    it('should deny update to viewer', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Folder' });\n      const bob = await registerAndLogin(app, 'bob');\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ name: 'Changed' });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('DELETE /folders/:id', () => {\n    it('should delete a folder', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'ToDelete' });\n      const res = await request(app)\n        .delete(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${alice.token}`);\n      expect(res.status).toBe(204);\n\n      const getRes = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${alice.token}`);\n      expect(getRes.status).toBe(404);\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .delete('/folders/nonexistent')\n        .set('Authorization', `Bearer ${alice.token}`);\n      expect(res.status).toBe(404);\n    });\n\n    it('should deny delete to non-owner', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Protected' });\n      const bob = await registerAndLogin(app, 'bob');\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'editor' });\n      const res = await request(app)\n        .delete(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(403);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":11,"oldLines":18,"newStart":11,"newLines":18,"lines":[" "," describe('Folders', () => {","   let app: Express;","-  let token: string;","+  let alice: { token: string; userId: string };"," ","   beforeEach(async () => {","     app = createApp();","-    token = await registerAndLogin(app, 'alice');","+    alice = await registerAndLogin(app, 'alice');","   });"," ","   describe('POST /folders', () => {","     it('should create a folder', async () => {","       const res = await request(app)","         .post('/folders')","-        .set('Authorization', `Bearer ${token}`)","+        .set('Authorization', `Bearer ${alice.token}`)","         .send({ name: 'My Folder' });","       expect(res.status).toBe(201);","       expect(res.body.name).toBe('My Folder');"]},{"oldStart":33,"oldLines":11,"newStart":33,"newLines":11,"lines":["     it('should create a nested folder', async () => {","       const parent = await request(app)","         .post('/folders')","-        .set('Authorization', `Bearer ${token}`)",