pp)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ content: 'test', folderId });\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject missing folderId', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'test' });\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject non-existent folder', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'test', folderId: 'nonexistent' });\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject if user lacks edit access to folder', async () => {\n      const bob = await registerAndLogin(app, 'bob');\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ title: 'Doc', content: 'test', folderId });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('GET /documents/:id', () => {\n    it('should get a document', async () => {\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'content', folderId });\n      const res = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('Doc');\n    });\n\n    it('should return 404 for non-existent', async () => {\n      const res = await request(app)\n        .get('/documents/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(404);\n    });\n\n    it('should deny access to unauthorized user', async () => {\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Private', content: 'secret', folderId });\n      const bob = await registerAndLogin(app, 'bob');\n      const res = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('PUT /documents/:id', () => {\n    it('should update a document', async () => {\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'old', folderId });\n      const res = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Updated', content: 'new content' });\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('Updated');\n      expect(res.body.content).toBe('new content');\n    });\n\n    it('should return 404 for non-existent', async () => {\n      const res = await request(app)\n        .put('/documents/nonexistent')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'X' });\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('DELETE /documents/:id', () => {\n    it('should delete a document', async () => {\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'del', folderId });\n      const res = await request(app)\n        .delete(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(204);\n    });\n\n    it('should deny delete to non-owner', async () => {\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'x', folderId });\n      const bob = await registerAndLogin(app, 'bob');\n      // Share folder with bob