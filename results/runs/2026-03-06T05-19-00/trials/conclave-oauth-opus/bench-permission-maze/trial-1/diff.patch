+
+async function registerAndLogin(app: Express, username: string, password = 'pass123') {
+  const reg = await request(app).post('/auth/register').send({ username, password });
+  const login = await request(app).post('/auth/login').send({ username, password });
+  return { token: login.body.token as string, userId: reg.body.id as string };
+}
+
+describe('Folders', () => {
+  let app: Express;
+  let alice: { token: string; userId: string };
+
+  beforeEach(async () => {
+    app = createApp();
+    alice = await registerAndLogin(app, 'alice');
+  });
+
+  describe('POST /folders', () => {
+    it('should create a folder', async () => {
+      const res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'My Folder' });
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe('My Folder');
+      expect(res.body).toHaveProperty('id');
+      expect(res.body.parentId).toBeNull();
+    });
+
+    it('should create a nested folder', async () => {
+      const parent = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'Parent' });
+      const res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'Child', parentId: parent.body.id });
+      expect(res.status).toBe(201);
+      expect(res.body.parentId).toBe(parent.body.id);
+    });
+
+    it('should reject missing name', async () => {
+      const res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({});
+      expect(res.status).toBe(400);
+    });
+
+    it('should reject non-existent parent', async () => {
+      const res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'Child', parentId: 'nonexistent' });
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('GET /folders/:id', () => {
