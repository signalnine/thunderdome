@@ -0,0 +1,165 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import type { Express } from 'express';
+import { createApp } from '../app.js';
+
+async function registerAndLogin(app: Express, username: string, password = 'pass123') {
+  const reg = await request(app).post('/auth/register').send({ username, password });
+  const login = await request(app).post('/auth/login').send({ username, password });
+  return { token: login.body.token as string, userId: reg.body.id as string };
+}
+
+describe('Documents', () => {
+  let app: Express;
+  let token: string;
+  let userId: string;
+  let folderId: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const user = await registerAndLogin(app, 'alice');
+    token = user.token;
+    userId = user.userId;
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'TestFolder' });
+    folderId = folder.body.id;
+  });
+
+  describe('POST /documents', () => {
+    it('should create a document', async () => {
+      const res = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'My Doc', content: 'Hello world', folderId });
+      expect(res.status).toBe(201);
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('Hello world');
+      expect(res.body.folderId).toBe(folderId);
+      expect(res.body.ownerId).toBe(userId);
+      expect(res.body).toHaveProperty('createdAt');
+      expect(res.body).toHaveProperty('updatedAt');
+    });
+
+    it('should reject missing title', async () => {
+      const res = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ content: 'test', folderId });
+      expect(res.status).toBe(400);
+    });
+
+    it('should reject missing folderId', async () => {
+      const res = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'test' });
+      expect(res.status).toBe(400);
+    });
+
+    it('should reject non-existent folder', async () => {
+      const res = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'test', folderId: 'nonexistent' });
+      expect(res.status).toBe(404);
+    });
+
+    it('should reject if user lacks edit access to folder', async () => {
+      const bob = await registerAndLogin(app, 'bob');
+      const res = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${bob.token}`)
+        .send({ title: 'Doc', content: 'test', folderId });
+      expect(res.status).toBe(403);
+    });
+  });
+
+  describe('GET /documents/:id', () => {
+    it('should get a document', async () => {
+      const doc = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'content', folderId });
+      const res = await request(app)
+        .get(`/documents/${doc.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('Doc');
+    });
+
+    it('should return 404 for non-existent', async () => {
+      const res = await request(app)
+        .get('/documents/nonexistent')
+        .set('Authorization', `Bearer ${token}`);
+      expect(res.status).toBe(404);
+    });
+
+    it('should deny access to unauthorized user', async () => {
+      const doc = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Private', content: 'secret', folderId });
+      const bob = await registerAndLogin(app, 'bob');
+      const res = await request(app)
+        .get(`/documents/${doc.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`);
+      expect(res.status).toBe(403);
+    });
+  });
+
+  describe('PUT /documents/:id', () => {
+    it('should update a document', async () => {
+      const doc = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'old', folderId });
+      const res = await request(app)
+        .put(`/documents/${doc.body.id}`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Updated', content: 'new content' });
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('Updated');
+      expect(res.body.content).toBe('new content');
+    });
+
+    it('should return 404 for non-existent', async () => {
+      const res = await request(app)
+        .put('/documents/nonexistent')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'X' });
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('DELETE /documents/:id', () => {
+    it('should delete a document', async () => {
+      const doc = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'del', folderId });
+      const res = await request(app)
+        .delete(`/documents/${doc.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+      expect(res.status).toBe(204);
+    });
+
+    it('should deny delete to non-owner', async () => {
+      const doc = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'x', folderId });
+      const bob = await registerAndLogin(app, 'bob');
+      // Share folder with bob as editor
+      await request(app)
+        .post(`/folders/${folderId}/share`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ userId: bob.userId, role: 'editor' });
+      const res = await request(app)
+        .delete(`/documents/${doc.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`);
+      expect(res.status).toBe(403);
+    });
+  });
+});
