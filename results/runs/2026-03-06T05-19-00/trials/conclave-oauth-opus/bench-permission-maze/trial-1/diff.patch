@@ -0,0 +1,140 @@
+import { Router } from 'express';
+import crypto from 'node:crypto';
+import { Store } from '../types.js';
+import { AuthRequest } from '../middleware.js';
+import { getEffectiveRole, canRead, canEdit, canDelete } from '../permissions.js';
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+
+  router.post('/', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const { title, content, folderId } = req.body;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId!, 'folder', folderId);
+    if (!canEdit(role)) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+    const id = crypto.randomUUID();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId!,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'create',
+      userId: userId!,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  router.get('/:id', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId!, 'document', doc.id);
+    if (!canRead(role)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  router.put('/:id', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId!, 'document', doc.id);
+    if (!canEdit(role)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    if (req.body.title !== undefined) doc.title = req.body.title;
+    if (req.body.content !== undefined) doc.content = req.body.content;
+    doc.updatedAt = new Date().toISOString();
+
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'update',
+      userId: userId!,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.json(doc);
+  });
+
+  router.delete('/:id', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId!, 'document', doc.id);
+    if (!canDelete(role)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    store.documents.delete(doc.id);
+
+    // Remove permissions for this document
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === 'document' && p.resourceId === doc.id)
+    );
+
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'delete',
+      userId: userId!,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
