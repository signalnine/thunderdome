uest(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'viewer' });\n    expect(share.status).toBe(201);\n\n    // Bob can now read document (inherited from folder)\n    const allowed = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(allowed.status).toBe(200);\n    expect(allowed.body.title).toBe('README');\n  });\n\n  it('permission cascade through nested folders', async () => {\n    const alice = await registerAndLogin(app, 'alice');\n    const bob = await registerAndLogin(app, 'bob');\n\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Parent' });\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Deep Doc', content: 'nested', folderId: child.body.id });\n\n    // Share parent folder with Bob\n    await request(app)\n      .post(`/folders/${parent.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'viewer' });\n\n    // Bob can read child folder\n    const childAccess = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(childAccess.status).toBe(200);\n\n    // Bob can read document in child folder\n    const docAccess = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(docAccess.status).toBe(200);\n  });\n\n  it('most permissive role wins', async () => {\n    const alice = await registerAndLogin(app, 'alice');\n    const bob = await registerAndLogin(app, 'bob');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'text', folderId: folder.body.id });\n\n    // Give Bob viewer on folder\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'viewer' });\n\n    // Give Bob editor on document directly\n    await request(app)\n      .post(`/documents/${doc.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'editor' });\n\n    // Bob should be able to edit the document (editor > viewer)\n    const update = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ content: 'updated by bob' });\n    expect(update.status).toBe(200);\n    expect(update.body.content).toBe('updated by bob');\n  });\n\n  it('owner always has full access without explicit permission', async () => {\n    const alice = await registerAndLogin(app, 'alice');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Mine' });\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'My Doc', content: 'own', folderId: folder.body.id });\n\n    // Owner can read, update, delete without any explicit permission entries\n    const read = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n    expect(read.status).toBe(200);\n\n    const update = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ content: 'updated' });\n    expect(update.status).toBe(200);\n\n    const del = await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n    expect(del.status).toBe(204);\n  });\n\n  it('activity log captures all actions', async () => {\n    const alice = await registerAndLogin(app, 'alice');\n    const bob = await registerAndLogin(app, 'bob');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Tracked' });\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Tracked Doc', content: 'v1', folderId: folder.body.id });\n    await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ content: 'v2' });\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'viewer' });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    const actions = res.body.map((e: { action: string }) => e.action);\n    expect(actions).toContain('create');\n    expect(actions).toContain('update');\n    expect(actions).toContain('share');\n  });\n\n  it('deleting folder cascades to child documents and folders', async () => {\n    const alice = await registerAndLogin(app, 'alice');\n\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Parent' });\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Nested', content: 'c', folderId: child.body.id });\n\n    await request(app)\n      .delete(`/folders/${parent.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    const childRes = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n    expect(childRes.status).toBe(404);\n\n    const docRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n    expect(docRes.status).toBe(404);\n  });\n\n  it('update existing share permission', async () => {\n    const alice = await registerAndLogin(app, 'alice');\n    const bob = await registerAndLogin(app, 'bob');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    // Share as viewer\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'viewer' });\n\n    // Bob can read but not edit\n    const readRes = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(readRes.status).toBe(200);\n\n    const editRes = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Changed' });\n    expect(editRes.status).toBe(403);\n\n    // Upgrade to editor\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ userId: bob.userId, role: 'editor' });\n\n    // Now Bob can edit\n    const editRes2 = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Changed' });\n    expect(editRes2.status).toBe(200);\n    expect(editRes2.body.name).toBe('Changed');\n  });\n});\n","structuredPatch":[],"originalFile":null}}
