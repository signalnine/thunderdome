+
+export function activityRoutes(store: Store): Router {
+  const router = Router();
+
+  router.get('/', (req, res) => {
+    let entries = store.activity;
+
+    if (req.query.resourceType) {
+      entries = entries.filter(e => e.resourceType === req.query.resourceType);
+    }
+    if (req.query.action) {
+      entries = entries.filter(e => e.action === req.query.action);
+    }
+
+    res.json(entries);
+  });
+
+  return router;
+}
