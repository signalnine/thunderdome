@@ -0,0 +1,164 @@
+import { Router } from 'express';
+import crypto from 'node:crypto';
+import { Store } from '../types.js';
+import { AuthRequest } from '../middleware.js';
+import { getEffectiveRole, canRead, canEdit, canDelete } from '../permissions.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+
+  router.post('/', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const { name, parentId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId !== undefined && parentId !== null) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      const role = getEffectiveRole(store, userId!, 'folder', parentId);
+      if (!canEdit(role)) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = crypto.randomUUID();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId!,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'create',
+      userId: userId!,
+      resourceType: 'folder',
+      resourceId: id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(201).json(folder);
+  });
+
+  router.get('/:id', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId!, 'folder', folder.id);
+    if (!canRead(role)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const children = Array.from(store.folders.values()).filter(f => f.parentId === folder.id);
+    const documents = Array.from(store.documents.values()).filter(d => d.folderId === folder.id);
+
+    res.json({ ...folder, children, documents });
+  });
+
+  router.put('/:id', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId!, 'folder', folder.id);
+    if (!canEdit(role)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    if (req.body.name !== undefined) folder.name = req.body.name;
+    if (req.body.parentId !== undefined) folder.parentId = req.body.parentId;
+
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'update',
+      userId: userId!,
+      resourceType: 'folder',
+      resourceId: folder.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.json(folder);
+  });
+
+  router.delete('/:id', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId!, 'folder', folder.id);
+    if (!canDelete(role)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Delete child documents
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === folder.id) {
+        store.documents.delete(docId);
+      }
+    }
+
+    // Delete child folders recursively
+    const deleteChildFolders = (parentId: string) => {
+      for (const [fId, f] of store.folders) {
+        if (f.parentId === parentId) {
+          // Delete docs in child folder
+          for (const [docId, doc] of store.documents) {
+            if (doc.folderId === fId) {
+              store.documents.delete(docId);
+            }
+          }
+          deleteChildFolders(fId);
+          store.folders.delete(fId);
+        }
+      }
+    };
+    deleteChildFolders(folder.id);
+
+    // Remove permissions for this folder
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === 'folder' && p.resourceId === folder.id)
+    );
+
+    store.folders.delete(folder.id);
+
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'delete',
+      userId: userId!,
+      resourceType: 'folder',
+      resourceId: folder.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..3883ca0
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,128 @@
+import { Router } from 'express';
+import crypto from 'node:crypto';
+import { Store, Role, ResourceType } from '../types.js';
+import { AuthRequest } from '../middleware.js';
+import { getEffectiveRole, canShare, canShareRole, canRead } from '../permissions.js';
+
+function shareResource(store: Store, resourceType: ResourceType) {
+  const router = Router({ mergeParams: true });
+
+  router.post('/:id/share', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const { userId: targetUserId, role } = req.body;
+    const resourceId = req.params.id;
+
+    if (!targetUserId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+
+    const validRoles: Role[] = ['viewer', 'editor', 'owner'];
+    if (!validRoles.includes(role)) {
+      res.status(400).json({ error: 'Role must be viewer, editor, or owner' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder' && !store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (resourceType === 'document' && !store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    // Check target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Check permissions
+    const userRole = getEffectiveRole(store, userId!, resourceType, resourceId);
+    if (!canShare(userRole)) {
+      res.status(403).json({ error: 'You do not have permission to share this resource' });
+      return;
+    }
+    if (!canShareRole(userRole, role)) {
+      res.status(403).json({ error: 'You cannot assign this role' });
+      return;
+    }
+
+    // Check if permission already exists and update it
+    const existing = store.permissions.find(
+      p => p.resourceType === resourceType && p.resourceId === resourceId && p.userId === targetUserId
+    );
+    if (existing) {
+      existing.role = role;
+      store.activity.push({
+        id: crypto.randomUUID(),
+        action: 'share',
+        userId: userId!,
+        resourceType,
+        resourceId,
+        timestamp: new Date().toISOString(),
+        details: `Updated role to ${role} for user ${targetUserId}`,
+      });
+      res.json(existing);
+      return;
+    }
+
+    const permission = {
+      id: crypto.randomUUID(),
+      resourceType,
+      resourceId,
+      userId: targetUserId,
+      role: role as Role,
+    };
+    store.permissions.push(permission);
+
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'share',
+      userId: userId!,
+      resourceType,
+      resourceId,
+      timestamp: new Date().toISOString(),
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(201).json(permission);
+  });
+
+  router.get('/:id/share', (req, res) => {
+    const { userId } = req as AuthRequest;
+    const resourceId = req.params.id;
+
+    // Check resource exists
+    if (resourceType === 'folder' && !store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (resourceType === 'document' && !store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId!, resourceType, resourceId);
+    if (!canRead(role)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const permissions = store.permissions.filter(
+      p => p.resourceType === resourceType && p.resourceId === resourceId
+    );
+    res.json(permissions);
+  });
+
+  return router;
+}
+
+export function sharingRoutes(store: Store): Router {
+  const router = Router();
+  router.use('/folders', shareResource(store, 'folder'));
+  router.use('/documents', shareResource(store, 'document'));
+  return router;
+}
