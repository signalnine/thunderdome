+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('should count cells for basic example with one splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('should count cells for two-splitter example', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('should handle no splitters', () => {
+    const grid = [
+      ['S'],
+      ['.'],
+      ['.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('should handle source only', () => {
+    expect(countBeamCells([['S']])).toBe(1);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('should count paths for basic example', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('should count paths for two-splitter example', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('should return 1n for no splitters', () => {
+    const grid = [
+      ['S'],
+      ['.'],
+      ['.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('should return 1n for source only', () => {
+    expect(countBeamPaths([['S']])).toBe(1n);
+  });
+});
