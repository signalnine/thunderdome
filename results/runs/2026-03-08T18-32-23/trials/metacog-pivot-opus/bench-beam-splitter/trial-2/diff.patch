+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  throw new Error('No source found');
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [srcRow, srcCol] = findSource(grid);
+
+  const visited = new Set<string>();
+  // Track (row, col, dir) to avoid re-processing identical beam states
+  const seen = new Set<string>();
+
+  const beams: Beam[] = [{ row: srcRow, col: srcCol, dir: 'down' }];
+  visited.add(`${srcRow},${srcCol}`);
+  seen.add(`${srcRow},${srcCol},down`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+
+    if (grid[row][col] === '^') {
+      // Splitter: produce two diagonal beams
+      const dirs: Direction[] = ['down-left', 'down-right'];
+      for (const newDir of dirs) {
+        const [nr, nc] = advance(row, col, newDir);
+        if (inBounds(nr, nc, rows, cols)) {
+          const key = `${nr},${nc},${newDir}`;
+          if (!seen.has(key)) {
+            seen.add(key);
+            visited.add(`${nr},${nc}`);
+            beams.push({ row: nr, col: nc, dir: newDir });
+          }
+        }
+      }
+    } else {
+      // Continue in current direction
+      const [nr, nc] = advance(row, col, dir);
+      if (inBounds(nr, nc, rows, cols)) {
+        const key = `${nr},${nc},${dir}`;
+        if (!seen.has(key)) {
+          seen.add(key);
+          visited.add(`${nr},${nc}`);
+          beams.push({ row: nr, col: nc, dir: dir });
+        }
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Trace a beam from a starting position/direction until it hits a splitter or exits the grid.
+ * Returns the splitter position it hits, or null if it exits.
+ */
+function traceBeam(
+  startRow: number, startCol: number, dir: Direction,
+  rows: number, cols: number, grid: string[][]
+): [number, number] | null {
+  let r = startRow;
+  let c = startCol;
+
+  // eslint-disable-next-line no-constant-condition
+  while (true) {
+    // If current cell is a splitter (and it's not the source), the beam lands here
+    if (grid[r][c] === '^') {
+      return [r, c];
+    }
+
+    const [nr, nc] = advance(r, c, dir);
+    if (!inBounds(nr, nc, rows, cols)) {
+      return null; // beam exits
+    }
+    r = nr;
+    c = nc;
+  }
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [srcRow, srcCol] = findSource(grid);
+
+  // Build a DAG: for each splitter, find where its two output beams go.
+  // Also find where the initial source beam goes.
+  // Then use DP to count paths.
+
+  // A "node" is either the source or a splitter.
+  // An edge leads to another splitter or to "exit" (beam leaves grid).
+  // We count the number of paths from source to exits.
+
+  // For the source: the beam goes straight down from (srcRow, srcCol).
+  // We need to trace from the cell below the source (or the source itself if it's a splitter,
+  // but S is always on top row and is 'S' not '^').
+
+  // Step 1: Trace from source downward
+  // The beam starts at (srcRow, srcCol) going down. The source cell is 'S', not a splitter.
+  // So we advance to (srcRow+1, srcCol) and continue.
+
+  // We'll use memoization: for each (row, col) of a splitter, compute the number of exit paths.
+  const memo = new Map<string, bigint>();
+
+  function countFromSplitter(r: number, c: number): bigint {
+    const key = `${r},${c}`;
+    if (memo.has(key)) return memo.get(key)!;
+
+    // Temporarily set to 0 to handle cycles (shouldn't happen since beams only go down)
+    memo.set(key, 0n);
+
+    let total = 0n;
+    const dirs: Direction[] = ['down-left', 'down-right'];
+
+    for (const dir of dirs) {
+      const [nr, nc] = advance(r, c, dir);
+      if (!inBounds(nr, nc, rows, cols)) {
+        // Beam immediately exits — this is one path
+        total += 1n;
+        continue;
+      }
+
+      // Trace this beam until it hits a splitter or exits
+      const result = traceBeam(nr, nc, dir, rows, cols, grid);
+      if (result === null) {
+        // Beam exits the grid — one path
+        total += 1n;
+      } else {
+        // Beam hits another splitter
+        total += countFromSplitter(result[0], result[1]);
+      }
+    }
+
+    memo.set(key, total);
+    return total;
+  }
+
+  // Trace the initial beam from source
+  const [nextRow, nextCol] = advance(srcRow, srcCol, 'down');
+  if (!inBounds(nextRow, nextCol, rows, cols)) {
+    // Source beam immediately exits
+    return 1n;
+  }
+
+  const firstHit = traceBeam(nextRow, nextCol, 'down', rows, cols, grid);
+  if (firstHit === null) {
+    // Beam passes through grid without hitting any splitter — one path
+    return 1n;
+  }
+
+  return countFromSplitter(firstHit[0], firstHit[1]);
+}
