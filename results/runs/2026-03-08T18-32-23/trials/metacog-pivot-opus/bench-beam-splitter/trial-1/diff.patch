+// Beam directions
+const DOWN = 0;
+const DOWN_LEFT = 1;
+const DOWN_RIGHT = 2;
+
+type Direction = typeof DOWN | typeof DOWN_LEFT | typeof DOWN_RIGHT;
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case DOWN: return [row + 1, col];
+    case DOWN_LEFT: return [row + 1, col - 1];
+    case DOWN_RIGHT: return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+/**
+ * Count distinct cells visited by any beam.
+ * Uses state deduplication: track unique (row, col, direction) to avoid
+ * exponential blowup from splitters.
+ */
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  const seen = new Set<string>(); // (row, col, dir) states already processed
+
+  // Start: beam at source going DOWN
+  const [sr, sc] = source;
+  visited.add(`${sr},${sc}`);
+
+  // Active beams: process row by row
+  let activeBeams: Beam[] = [{ row: sr, col: sc, dir: DOWN }];
+
+  while (activeBeams.length > 0) {
+    const nextBeams: Beam[] = [];
+    const nextSeen = new Set<string>();
+
+    for (const beam of activeBeams) {
+      const [nr, nc] = nextPos(beam.row, beam.col, beam.dir);
+
+      if (!inBounds(nr, nc, rows, cols)) continue;
+
+      const cell = grid[nr][nc];
+      visited.add(`${nr},${nc}`);
+
+      if (cell === '^') {
+        // Splitter: produce down-left and down-right beams
+        const keyL = `${nr},${nc},${DOWN_LEFT}`;
+        const keyR = `${nr},${nc},${DOWN_RIGHT}`;
+        if (!seen.has(keyL) && !nextSeen.has(keyL)) {
+          nextSeen.add(keyL);
+          nextBeams.push({ row: nr, col: nc, dir: DOWN_LEFT });
+        }
+        if (!seen.has(keyR) && !nextSeen.has(keyR)) {
+          nextSeen.add(keyR);
+          nextBeams.push({ row: nr, col: nc, dir: DOWN_RIGHT });
+        }
+      } else {
+        // Continue in same direction
+        const key = `${nr},${nc},${beam.dir}`;
+        if (!seen.has(key) && !nextSeen.has(key)) {
+          nextSeen.add(key);
+          nextBeams.push({ row: nr, col: nc, dir: beam.dir });
+        }
+      }
+    }
+
+    for (const k of nextSeen) seen.add(k);
+    activeBeams = nextBeams;
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count total distinct source-to-exit paths.
+ * Instead of enumerating paths (could be 2^50), track beam counts per state.
+ * Each (col, direction) state carries a bigint count of how many paths
+ * flow through it. When a splitter is hit, the count splits to both branches.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  const [sr, sc] = source;
+
+  // Map from state key "(col,dir)" to count of paths through that state
+  // Process row by row, stepping beams forward
+  let currentBeams = new Map<string, bigint>();
+  currentBeams.set(`${sc},${DOWN}`, 1n);
+
+  let currentRow = sr;
+  let totalPaths = 0n;
+
+  while (currentBeams.size > 0) {
+    const nextBeams = new Map<string, bigint>();
+
+    for (const [key, count] of currentBeams) {
+      const parts = key.split(',');
+      const col = parseInt(parts[0]);
+      const dir = parseInt(parts[1]) as Direction;
+
+      const [nr, nc] = nextPos(currentRow, col, dir);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        // Beam exits grid — these are completed paths
+        totalPaths += count;
+        continue;
+      }
+
+      const cell = grid[nr][nc];
+
+      if (cell === '^') {
+        // Split into two directions
+        const keyL = `${nc},${DOWN_LEFT}`;
+        const keyR = `${nc},${DOWN_RIGHT}`;
+        nextBeams.set(keyL, (nextBeams.get(keyL) ?? 0n) + count);
+        nextBeams.set(keyR, (nextBeams.get(keyR) ?? 0n) + count);
+      } else {
+        // Continue same direction
+        const nkey = `${nc},${dir}`;
+        nextBeams.set(nkey, (nextBeams.get(nkey) ?? 0n) + count);
+      }
+    }
+
+    currentBeams = nextBeams;
+    currentRow++;
+  }
+
+  return totalPaths;
+}
