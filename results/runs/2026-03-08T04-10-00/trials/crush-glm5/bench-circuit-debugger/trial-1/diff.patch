+    expect(simulate(gates, { x: 1, y: 0 })).toEqual({ x: 1, y: 0, z: 0 });
+    expect(simulate(gates, { x: 0, y: 1 })).toEqual({ x: 0, y: 1, z: 0 });
+    expect(simulate(gates, { x: 0, y: 0 })).toEqual({ x: 0, y: 0, z: 0 });
+  });
+
+  it('should simulate a simple OR gate', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'x', in2: 'y', out: 'z' },
+    ];
+    expect(simulate(gates, { x: 1, y: 1 })).toEqual({ x: 1, y: 1, z: 1 });
+    expect(simulate(gates, { x: 1, y: 0 })).toEqual({ x: 1, y: 0, z: 1 });
+    expect(simulate(gates, { x: 0, y: 1 })).toEqual({ x: 0, y: 1, z: 1 });
+    expect(simulate(gates, { x: 0, y: 0 })).toEqual({ x: 0, y: 0, z: 0 });
+  });
+
+  it('should simulate a simple XOR gate', () => {
+    const gates: Gate[] = [
