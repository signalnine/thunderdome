@@ -0,0 +1,249 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates.
+ * Returns the final value of every wire after all gates have been processed.
+ */
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+
+  const gateDependencies = new Map<Gate, Set<string>>();
+  for (const gate of gates) {
+    gateDependencies.set(gate, new Set([gate.in1, gate.in2]));
+  }
+
+  const queue = [...gates];
+
+  while (queue.length > 0) {
+    let progress = false;
+
+    for (let i = 0; i < queue.length; i++) {
+      const gate = queue[i];
+      const deps = gateDependencies.get(gate)!;
+
+      let canProcess = true;
+      for (const dep of deps) {
+        if (!(dep in wires)) {
+          canProcess = false;
+          break;
+        }
+      }
+
+      if (canProcess) {
+        const in1 = wires[gate.in1];
+        const in2 = wires[gate.in2];
+
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = in1 & in2;
+            break;
+          case 'OR':
+            result = in1 | in2;
+            break;
+          case 'XOR':
+            result = in1 ^ in2;
+            break;
+        }
+
+        wires[gate.out] = result;
+        queue.splice(i, 1);
+        progress = true;
+        break;
+      }
+    }
+
+    if (!progress && queue.length > 0) {
+      throw new Error('Circular dependency detected or missing inputs');
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find swapped wires in a binary adder circuit.
+ * Returns 8 wire names that are involved in 4 pairs of swaps.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const gateByOutput = new Map<string, Gate>();
+  const gatesByInput = new Map<string, Gate[]>();
+
+  for (const gate of gates) {
+    gateByOutput.set(gate.out, gate);
+
+    if (!gatesByInput.has(gate.in1)) gatesByInput.set(gate.in1, []);
+    if (!gatesByInput.has(gate.in2)) gatesByInput.set(gate.in2, []);
+
+    gatesByInput.get(gate.in1)!.push(gate);
+    gatesByInput.get(gate.in2)!.push(gate);
+  }
+
+  const zWires = [...gateByOutput.keys()]
+    .filter(w => w.startsWith('z'))
+    .sort((a, b) => parseInt(a.slice(1)) - parseInt(b.slice(1)));
+
+  const maxBit = zWires.length - 2;
+  const finalZ = zWires[zWires.length - 1];
+
+  const suspicious = new Set<string>();
+
+  // ===== Identify special gates =====
+
+  // Map from bit position to partial XOR output wire
+  const partialXorOutputs = new Map<number, string>();
+
+  for (const gate of gates) {
+    const xyBit = getXYpairBit(gate.in1, gate.in2);
+    if (xyBit !== -1 && gate.op === 'XOR') {
+      partialXorOutputs.set(xyBit, gate.out);
+    }
+  }
+
+  // ===== Rule 1: Check z outputs =====
+
+  // z00 must be XOR(x00, y00)
+  const z00Gate = gateByOutput.get('z00');
+  if (z00Gate) {
+    if (z00Gate.op !== 'XOR' || getXYpairBit(z00Gate.in1, z00Gate.in2) !== 0) {
+      suspicious.add('z00');
+    }
+  }
+
+  // zNN (N > 0, not final) must be XOR with correct inputs
+  for (let bit = 1; bit <= maxBit; bit++) {
+    const zWire = `z${bit.toString().padStart(2, '0')}`;
+    const gate = gateByOutput.get(zWire);
+
+    if (gate) {
+      if (gate.op !== 'XOR') {
+        suspicious.add(zWire);
+      } else if (getXYpairBit(gate.in1, gate.in2) !== -1) {
+        // Direct x/y inputs - wrong!
+        suspicious.add(zWire);
+      }
+    }
+  }
+
+  // Final z must be OR
+  const finalZGate = gateByOutput.get(finalZ);
+  if (finalZGate && finalZGate.op !== 'OR') {
+    suspicious.add(finalZ);
+  }
+
+  // ===== Rule 2: XOR(xN, yN) for N > 0 should NOT output to z =====
+  for (const gate of gates) {
+    if (gate.op !== 'XOR') continue;
+
+    const xyBit = getXYpairBit(gate.in1, gate.in2);
+    if (xyBit > 0 && gate.out.startsWith('z')) {
+      suspicious.add(gate.out);
+    }
+  }
+
+  // ===== Rule 3: Find wires that should be z outputs =====
+  if (suspicious.size > 0) {
+    // Find XOR(x00, y00) that doesn't output to z00
+    for (const gate of gates) {
+      if (gate.op === 'XOR' && getXYpairBit(gate.in1, gate.in2) === 0 && gate.out !== 'z00') {
+        suspicious.add(gate.out);
+      }
+    }
+
+    // Find XOR gates that look like zNN (N > 0) outputs
+    for (const gate of gates) {
+      if (gate.op !== 'XOR' || gate.out.startsWith('z')) continue;
+
+      if (isZGateStructure(gate, gateByOutput)) {
+        suspicious.add(gate.out);
+      }
+    }
+
+    // Find OR gates that could be final carry
+    if (suspicious.has(finalZ)) {
+      for (const gate of gates) {
+        if (gate.op !== 'OR' || gate.out.startsWith('z')) continue;
+
+        const in1Gate = gateByOutput.get(gate.in1);
+        const in2Gate = gateByOutput.get(gate.in2);
+
+        if (in1Gate && in2Gate && in1Gate.op === 'AND' && in2Gate.op === 'AND') {
+          suspicious.add(gate.out);
+        }
+      }
+    }
+  }
+
+  // ===== Rule 4: Check carry chain connections =====
+  // For each bit N > 0, verify partial XOR feeds into correct z gate
+
+  for (let bit = 1; bit <= maxBit; bit++) {
+    const partialOut = partialXorOutputs.get(bit);
+
+    if (partialOut) {
+      const consumers = gatesByInput.get(partialOut) || [];
+      const xorConsumers = consumers.filter(g => g.op === 'XOR');
+
+      // If partial XOR feeds into a z XOR but that XOR outputs to wrong z, flag it
+      for (const xorConsumer of xorConsumers) {
+        const expectedZWire = `z${bit.toString().padStart(2, '0')}`;
+        if (xorConsumer.out.startsWith('z') && xorConsumer.out !== expectedZWire) {
+          suspicious.add(xorConsumer.out);
+        }
+      }
+    }
+  }
+
+  // ===== Rule 5: Check for gates with self-referential inputs =====
+  // A gate that has an input with the same name as its output is suspicious
+  // This can happen when a wire is swapped with one of its dependencies
+  for (const gate of gates) {
+    if (gate.in1 === gate.out || gate.in2 === gate.out) {
+      suspicious.add(gate.out);
+    }
+  }
+
+  return [...suspicious].sort();
+}
+
+/**
+ * Check if a gate has the structure of a zNN gate (N > 0)
+ * A zNN gate is XOR where one input is from XOR(xN, yN) and one from carry
+ */
+function isZGateStructure(gate: Gate, gateByOutput: Map<string, Gate>): boolean {
+  const in1Gate = gateByOutput.get(gate.in1);
+  const in2Gate = gateByOutput.get(gate.in2);
+
+  if (!in1Gate || !in2Gate) return false;
+
+  // One input should be from XOR(xN, yN)
+  const in1IsPartialXor = in1Gate.op === 'XOR' && getXYpairBit(in1Gate.in1, in1Gate.in2) > 0;
+  const in2IsPartialXor = in2Gate.op === 'XOR' && getXYpairBit(in2Gate.in1, in2Gate.in2) > 0;
+
+  // One input should be from carry (AND or OR)
+  const in1IsCarry = in1Gate.op === 'OR' || in1Gate.op === 'AND';
+  const in2IsCarry = in2Gate.op === 'OR' || in2Gate.op === 'AND';
+
+  return (in1IsPartialXor && in2IsCarry) || (in2IsPartialXor && in1IsCarry);
+}
+
+function getXYpairBit(in1: string, in2: string): number {
+  const match1 = in1.match(/^x(\d+)$/);
+  const match2 = in2.match(/^y(\d+)$/);
+  if (match1 && match2 && match1[1] === match2[1]) {
+    return parseInt(match1[1]);
+  }
+
+  const match3 = in1.match(/^y(\d+)$/);
+  const match4 = in2.match(/^x(\d+)$/);
+  if (match3 && match4 && match3[1] === match4[1]) {
+    return parseInt(match3[1]);
+  }
+
+  return -1;
+}
