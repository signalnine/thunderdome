+    expect(simulate(gates, { x: 0, y: 0, z: 1 })).toEqual({ x: 0, y: 0, z: 1, a: 0, out: 1 });
+  });
+
+  it('should simulate a 4-bit adder', () => {
+    // 4-bit adder from the spec
+    const gates: Gate[] = [
+      // Bit 0: half adder
