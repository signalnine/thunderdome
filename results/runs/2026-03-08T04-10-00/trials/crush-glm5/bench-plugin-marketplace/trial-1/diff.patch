+import type { DepsService, DependencyNode, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTree(name: string, registry: RegistryService): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const dependencies: DependencyNode[] = [];
+    for (const depName of Object.keys(manifest.dependencies)) {
+      dependencies.push(buildTree(depName, registry));
+    }
+
+    return {
+      name,
+      version: manifest.version,
+      dependencies,
+    };
+  }
+
+  function detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const cycles: string[][] = [];
+    const visited = new Set<string>();
+    const recursionStack = new Set<string>();
+    const path: string[] = [];
+
+    function dfs(node: string): boolean {
+      visited.add(node);
+      recursionStack.add(node);
+      path.push(node);
+
+      const manifest = registry.get(node);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          if (!visited.has(depName)) {
+            if (dfs(depName)) {
+              return true;
+            }
+          } else if (recursionStack.has(depName)) {
+            const cycleStart = path.indexOf(depName);
+            cycles.push(path.slice(cycleStart));
+            return true;
+          }
+        }
+      }
+
+      path.pop();
+      recursionStack.delete(node);
+      return false;
+    }
+
+    dfs(name);
+
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  function topologicalSort(name: string, registry: RegistryService): string[] {
+    const result: string[] = [];
+    const visited = new Set<string>();
+
+    function dfs(node: string): void {
+      if (visited.has(node)) {
+        return;
+      }
+      visited.add(node);
+
+      const manifest = registry.get(node);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          dfs(depName);
+        }
+      }
+
+      result.push(node);
+    }
+
+    dfs(name);
+    return result;
+  }
+
+  function flattenDependencies(name: string, registry: RegistryService): string[] {
+    const result: string[] = [];
+    const visited = new Set<string>();
+
+    function dfs(node: string): void {
+      const manifest = registry.get(node);
+      if (!manifest) {
+        return;
+      }
+
+      for (const depName of Object.keys(manifest.dependencies)) {
+        if (!visited.has(depName)) {
+          visited.add(depName);
+          result.push(depName);
+          dfs(depName);
+        }
+      }
+    }
+
+    dfs(name);
+    return result;
+  }
+
+  function hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return detectCycles(name, registry) !== null;
+  }
+
+  return {
+    buildTree,
+    detectCycles,
+    topologicalSort,
+    flattenDependencies,
+    hasCircularDependency,
+  };
+}
