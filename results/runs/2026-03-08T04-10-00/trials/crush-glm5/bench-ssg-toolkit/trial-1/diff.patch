@@ -0,0 +1,50 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx: BuildContext): void => {
+        const tagMap = new Map<string, typeof ctx.files>();
+
+        // Build tag index from files
+        for (const file of ctx.files) {
+          if (file.tags) {
+            for (const tag of file.tags) {
+              const normalizedTag = tag.toLowerCase();
+              if (!tagMap.has(normalizedTag)) {
+                tagMap.set(normalizedTag, []);
+              }
+              tagMap.get(normalizedTag)!.push(file);
+            }
+          }
+        }
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: (ctx: BuildContext): void => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, typeof ctx.files>;
+
+        if (!tagMap) return;
+
+        // Generate tag listing pages
+        for (const [tag, files] of tagMap) {
+          let html = '<!DOCTYPE html>\n<html>\n<head>\n';
+          html += `<title>Tag: ${tag}</title>\n`;
+          html += '</head>\n<body>\n';
+          html += `<h1>Tag: ${tag}</h1>\n`;
+          html += '<ul>\n';
+
+          for (const file of files) {
+            html += `<li><a href="/${file.slug}.html">${file.title}</a></li>\n`;
+          }
+
+          html += '</ul>\n</body>\n</html>';
+          ctx.output.set(`tags/${tag}.html`, html);
+        }
+      },
+    },
+  };
+}
