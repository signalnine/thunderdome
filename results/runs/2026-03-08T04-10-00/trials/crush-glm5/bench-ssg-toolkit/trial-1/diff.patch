+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+        const assets: string[] = [];
+
+        // Rewrite relative img src URLs
+        content = content.replace(/<img\s+src="\.\/([^"]+)"/g, (match, assetPath) => {
+          assets.push(assetPath);
+          return `<img src="/assets/${assetPath}"`;
+        });
+
+        // Rewrite relative a href URLs
+        content = content.replace(/<a\s+href="\.\/([^"]+)"/g, (match, assetPath) => {
+          assets.push(assetPath);
+          return `<a href="/assets/${assetPath}"`;
+        });
+
+        // Update asset manifest in ctx.data
+        if (assets.length > 0) {
+          const existingManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+          const existingAssets = existingManifest?.assets || [];
+          ctx.data.set('asset-manifest', {
+            assets: [...existingAssets, ...assets],
+          });
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
