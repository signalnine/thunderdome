+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        if (!file.content) {
+          return { ...file, content: '' };
+        }
+
+        let content = file.content;
+
+        // Process admonition containers before markdown
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        const { processedContent, footnotes } = processFootnotes(content);
+
+        // Convert markdown to HTML
+        const htmlContent = await marked(processedContent);
+
+        // Append footnotes section if any
+        let finalContent = htmlContent;
+        if (footnotes.length > 0) {
+          finalContent += '\n<section class="footnotes">\n<ol>\n';
+          for (const fn of footnotes) {
+            finalContent += `<li id="fn-${fn.id}">${fn.text}</li>\n`;
+          }
+          finalContent += '</ol>\n</section>';
+        }
+
+        return { ...file, content: finalContent };
+      },
+    },
+  };
+}
+
+interface Footnote {
+  id: number;
+  text: string;
+}
+
+function processFootnotes(content: string): { processedContent: string; footnotes: Footnote[] } {
+  const footnotes: Footnote[] = [];
+  const footnoteDefs: Record<string, string> = {};
+
+  // Extract footnote definitions: [^1]: This is the footnote.
+  const defRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  let match;
+  while ((match = defRegex.exec(content)) !== null) {
+    footnoteDefs[match[1]] = match[2];
+    footnotes.push({ id: parseInt(match[1]), text: match[2] });
+  }
+
+  // Remove footnote definitions from content
+  let processedContent = content.replace(defRegex, '').trim();
+
+  // Replace footnote references: [^1] -> <sup><a href="#fn-1">1</a></sup>
+  const refRegex = /\[\^(\d+)\]/g;
+  processedContent = processedContent.replace(refRegex, '<sup><a href="#fn-$1">$1</a></sup>');
+
+  return { processedContent, footnotes };
+}
+
+function processAdmonitions(content: string): string {
+  // Process :::note, :::warning, :::tip containers
+  const types = ['note', 'warning', 'tip'];
+
+  for (const type of types) {
+    const regex = new RegExp(`:::${type}\\n([\\s\\S]*?)\\n:::`, 'g');
+    content = content.replace(regex, (_, innerContent) => {
+      return `<div class="admonition admonition-${type}">\n${innerContent}\n</div>`;
+    });
+  }
+
+  return content;
+}
