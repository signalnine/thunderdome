diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..80696fb
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,116 @@
+import * as fs from 'fs';
+import * as path from 'path';
+
+export interface Entry {
+  taskName: string;
+  startTime: string;
+  endTime: string | null;
+}
+
+interface StoredData {
+  entries: Entry[];
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: Entry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = [];
+    this.load();
+  }
+
+  private load(): void {
+    if (fs.existsSync(this.filePath)) {
+      const data = fs.readFileSync(this.filePath, 'utf-8');
+      try {
+        const parsed: StoredData = JSON.parse(data);
+        this.entries = parsed.entries || [];
+      } catch {
+        this.entries = [];
+      }
+    } else {
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    if (!fs.existsSync(dir)) {
+      fs.mkdirSync(dir, { recursive: true });
+    }
+    const data: StoredData = { entries: this.entries };
+    fs.writeFileSync(this.filePath, JSON.stringify(data, null, 2), 'utf-8');
+  }
+
+  start(taskName: string): Entry {
+    if (taskName === '') {
+      throw new Error('Task name cannot be empty');
+    }
+
+    const activeIndex = this.entries.findIndex((e) => e.endTime === null);
+    if (activeIndex !== -1) {
+      this.entries[activeIndex].endTime = new Date().toISOString();
+    }
+
+    const entry: Entry = {
+      taskName,
+      startTime: new Date().toISOString(),
+      endTime: null,
+    };
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): Entry {
+    const activeIndex = this.entries.findIndex((e) => e.endTime === null);
+    if (activeIndex === -1) {
+      throw new Error('No active task to stop');
+    }
+
+    this.entries[activeIndex].endTime = new Date().toISOString();
+    this.save();
+    return this.entries[activeIndex];
+  }
+
+  getActiveTask(): Entry | null {
+    const active = this.entries.find((e) => e.endTime === null);
+    return active ?? null;
+  }
+
+  getLog(options?: { since?: Date }): Entry[] {
+    if (!options?.since) {
+      return [...this.entries];
+    }
+
+    const sinceTime = options.since.getTime();
+    return this.entries.filter((entry) => {
+      if (entry.endTime === null) {
+        return true;
+      }
+      const startTime = new Date(entry.startTime).getTime();
+      const endTime = new Date(entry.endTime).getTime();
+      return startTime >= sinceTime || endTime >= sinceTime;
+    });
+  }
+
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const startTime = new Date(entry.startTime).getTime();
+      const endTime = entry.endTime ? new Date(entry.endTime).getTime() : now;
+      const duration = endTime - startTime;
+
+      if (summary[entry.taskName] === undefined) {
+        summary[entry.taskName] = 0;
+      }
+      summary[entry.taskName] += duration;
+    }
+
+    return summary;
+  }
+}
