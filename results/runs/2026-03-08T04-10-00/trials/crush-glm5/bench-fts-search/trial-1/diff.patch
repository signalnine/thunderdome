+// Escape special FTS5 characters and build a safe query
+function buildFtsQuery(q: string): string {
+  // If it's a quoted phrase, keep it as is
+  if (/^".*"$/.test(q)) {
+    return q;
+  }
+  
+  // Remove or replace characters that are problematic for FTS5
+  // Keep only alphanumeric, spaces, and basic safe characters
+  // FTS5 has issues with: " * ^ ( ) - & + ' < > / \ { } [ ] ! @ # $ % ~ ` = | :
+  let escaped = q.replace(/[^a-zA-Z0-9\s]/g, ' ');
+  // Remove SQL-like keywords that could cause issues
+  escaped = escaped.replace(/\b(AND|OR|NOT)\b/gi, ' ');
+  escaped = escaped.trim();
+  
+  if (!escaped) {
+    return '""'; // Return empty phrase query if nothing left
+  }
+  
+  // Split into terms and join with space for simpler matching
+  const terms = escaped.split(/\s+/).filter(t => t.length > 0);
+  return terms.join(' ');
+}
