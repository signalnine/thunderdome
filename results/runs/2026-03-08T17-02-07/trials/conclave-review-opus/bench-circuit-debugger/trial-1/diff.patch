    const b = rname(`b${p}`);\n   136→      gates.push({ op: 'AND', in1: t, in2: c_prev, out: b });\n   137→      gates.push({ op: 'OR', in1: a, in2: b, out: rname(`c${p}`) });\n   138→    }\n   139→\n   140→    gates.push({\n   141→      op: 'OR',\n   142→      in1: rname(`c${pad(numBits - 1)}`),\n   143→      in2: rname(`c${pad(numBits - 1)}`),\n   144→      out: `z${pad(numBits)}`,\n   145→    });\n   146→\n   147→    return { gates, wireMap };\n   148→  }\n   149→\n   150→  function swapWires(gates: Gate[], wireA: string, wireB: string): void {\n   151→    const gateA = gates.find((g) => g.out === wireA);\n   152→    const gateB = gates.find((g) => g.out === wireB);\n   153→    if (gateA && gateB) {\n   154→      gateA.out = wireB;\n   155→      gateB.out = wireA;\n   156→    }\n   157→  }\n   158→\n   159→  it('should find swapped wires in a small adder', () => {\n   160→    const gates = makeAdder(8);\n   161→    swapWires(gates, 'z01', 'a01');\n   162→    swapWires(gates, 'z03', 't03');\n   163→    swapWires(gates, 'c05', 'b05');\n   164→    swapWires(gates, 'z07', 'a07');\n   165→\n   166→    const result = findSwappedWires(gates);\n   167→    expect(result).toEqual(\n   168→      ['a01', 'a07', 'b05', 'c05', 't03', 'z01', 'z03', 'z07'].sort()\n   169→    );\n   170→  });\n   171→\n   172→  it('should find swapped wires in a larger adder', () => {\n   173→    const gates = makeAdder(20);\n   174→    swapWires(gates, 'z05', 'c05');\n   175→    swapWires(gates, 't10', 'a10');\n   176→    swapWires(gates, 'b15', 'z15');\n   177→    swapWires(gates, 'z19', 'c18');\n   178→\n   179→    const result = findSwappedWires(gates);\n   180→    expect(result).toEqual(\n   181→      ['a10', 'b15', 'c05', 'c18', 't10', 'z05', 'z15', 'z19'].sort()\n   182→    );\n   183→  });\n   184→\n   185→  it('should handle 45-bit adder within time limit', () => {\n   186→    const gates = makeAdder(45);\n   187→    swapWires(gates, 'z02', 'a02');\n   188→    swapWires(gates, 'c10', 'b