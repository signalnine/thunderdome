orkingGates) {\n    60→    for (const w of [g.in1, g.in2, g.out]) {\n    61→      const m = w.match(/^[xy](\\d+)$/);\n    62→      if (m) {\n    63→        const n = parseInt(m[1], 10);\n    64→        if (n > maxBit) maxBit = n;\n    65→      }\n    66→    }\n    67→  }\n    68→  const numBits = maxBit + 1;\n    69→\n    70→  function pad(n: number): string {\n    71→    return n.toString().padStart(2, '0');\n    72→  }\n    73→\n    74→  // Find a gate by op and exact two inputs (order-insensitive)\n    75→  function findGate(op: string, inA: string, inB: string): Gate | undefined {\n    76→    for (const g of workingGates) {\n    77→      if (\n    78→        g.op === op &&\n    79→        ((g.in1 === inA && g.in2 === inB) ||\n    80→          (g.in1 === inB && g.in2 === inA))\n    81→      ) {\n    82→        return g;\n    83→      }\n    84→    }\n    85→    return undefined;\n    86→  }\n    87→\n    88→  // Find all gates by op that have a specific wire as input\n    89→  function findGatesWithInput(op: string, wire: string): Gate[] {\n    90→    return workingGates.filter(\n    91→      (g) => g.op === op && (g.in1 === wire || g.in2 === wire)\n    92→    );\n    93→  }\n    94→\n    95→  // Get the other input of a gate given one known input\n    96→  function otherInput(gate: Gate, knownInput: string): string {\n    97→    return gate.in1 === knownInput ? gate.in2 : gate.in1;\n    98→  }\n    99→\n   100→  const swapped: Set<string> = new Set();\n   101→\n   102→  function doSwap(wireA: string, wireB: string): void {\n   103→    const gateA = gateByOutput.get(wireA);\n   104→    const gateB = gateByOutput.get(wireB);\n   105→    if (gateA && gateB) {\n   106→      swapped.add(wireA);\n   107→      swapped.add(wireB);\n   108→      gateA.out = wireB;\n   109→      gateB.out = wireA;\n   110→      gateByOutput.set(wireA, gateB);\n   111→      gateByOutput.set(wireB, gateA);\n   112→    }\n   113→  }\n   114→\n   115→  // Trace the ripple-carry adder structure bit by bit\n   116→  // Bit 0 (half adder):\n   117→  //   x00 XOR y00 -> z00\n   118→  //   x00 AND y00 -> carry\n   119→  //\n   120→  // Bit i >= 1 (full adder):\n   121→  //   x_i XOR y_i -> partial_sum\n   122→  //   partial_sum XOR carry_in -> z_i\n   123→  //   x_i AND y_i -> generate\n   124→  //   partial_sum AND carry_in -> propagate\n   125→  //   generate OR propagate -> carry_out\n   126→\n   127→  let carry = '';\n   128→\n   129→  for (let bit = 0; bit < numBits; bit++) {\n   130→    const x = `x${pad(bit)}`;\n   131→    const y = `y${pad(bit)}`;\n   132→    const z = `z${pad(bit)}`;\n   133→\n   134→    if (bit === 0) {\n   135→      // Half adder\n   136→      const xorGate = findGate('XOR', x, y);\n   137→      if (!xorGate) continue;\n   138→\n   139→      if (xorGate.out !== z) {\n   140→        doSwap(xorGate.out, z);\n   141→      }\n   142→\n   143→      const andGate = findGate('AND', x, y);\n   144→      if (andGate) {\n   145→        carry = andGate.out;\n   146→      }\n   147→    } else {\n   148→      // Full adder\n   149→      // Step 1: Find partial sum gate (x_i XOR y_i)\n   150→      const xorXY = findGate('XOR', x, y);\n   151→      if (!xorXY) continue;\n   152→\n   153→      let partialSum = xorXY.out;\n   154→\n   155→      // Step 2: Find sum gate (partialSum XOR carry -> z_i)\n   156→      let sumGate = findGate('XOR', partialSum, carry);\n   157→\n   158→      if (!sumGate) {\n   159→        // Either partialSum or carry is swapped with something.\n   160→        // Strategy: find the XOR gate that uses carry as input (other than xorXY)\n   161→        const xorUsingCarry = findGatesWithInput('XOR', carry).filter(\n   162→          (g) => g !== xorXY\n   163→        );\n   164→        // Find the XOR gate that uses partialSum as input (other than xorXY)\n   165→        const xorUsingPartial = findGatesWithInput('XOR', partialSum).filter(\n   166→          (g) => g !== xorXY\n   167→        );\n   168→\n   169→        if (xo