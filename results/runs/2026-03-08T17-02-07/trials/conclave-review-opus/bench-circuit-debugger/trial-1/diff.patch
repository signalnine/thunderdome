+
+  function pad(n: number): string {
+    return n.toString().padStart(2, '0');
+  }
+
+  // Find a gate by op and exact two inputs (order-insensitive)
+  function findGate(op: string, inA: string, inB: string): Gate | undefined {
+    for (const g of workingGates) {
+      if (
+        g.op === op &&
+        ((g.in1 === inA && g.in2 === inB) ||
+          (g.in1 === inB && g.in2 === inA))
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Find all gates by op that have a specific wire as input
+  function findGatesWithInput(op: string, wire: string): Gate[] {
+    return workingGates.filter(
+      (g) => g.op === op && (g.in1 === wire || g.in2 === wire)
+    );
+  }
+
+  // Get the other input of a gate given one known input
+  function otherInput(gate: Gate, knownInput: string): string {
+    return gate.in1 === knownInput ? gate.in2 : gate.in1;
+  }
+
+  const swapped: Set<string> = new Set();
+
+  function doSwap(wireA: string, wireB: string): void {
+    const gateA = gateByOutput.get(wireA);
+    const gateB = gateByOutput.get(wireB);
+    if (gateA && gateB) {
+      swapped.add(wireA);
+      swapped.add(wireB);
+      gateA.out = wireB;
+      gateB.out = wireA;
+      gateByOutput.set(wireA, gateB);
+      gateByOutput.set(wireB, gateA);
+    }
+  }
+
+  // Trace the ripple-carry adder structure bit by bit
+  // Bit 0 (half adder):
+  //   x00 XOR y00 -> z00
+  //   x00 AND y00 -> carry
+  //
+  // Bit i >= 1 (full adder):
+  //   x_i XOR y_i -> partial_sum
+  //   partial_sum XOR carry_in -> z_i
+  //   x_i AND y_i -> generate
+  //   partial_sum AND carry_in -> propagate
+  //   generate OR propagate -> carry_out
+
+  let carry = '';
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const x = `x${pad(bit)}`;
+    const y = `y${pad(bit)}`;
+    const z = `z${pad(bit)}`;
+
+    if (bit === 0) {
+      // Half adder
+      const xorGate = findGate('XOR', x, y);
+      if (!xorGate) continue;
+
+      if (xorGate.out !== z) {
+        doSwap(xorGate.out, z);
+      }
+
+      const andGate = findGate('AND', x, y);
+      if (andGate) {
+        carry = andGate.out;
+      }
+    } else {
+      // Full adder
+      // Step 1: Find partial sum gate (x_i XOR y_i)
+      const xorXY = findGate('XOR', x, y);
+      if (!xorXY) continue;
+
+      let partialSum = xorXY.out;
+
+      // Step 2: Find sum gate (partialSum XOR carry -> z_i)
+      let sumGate = findGate('XOR', partialSum, carry);
+
+      if (!sumGate) {
+        // Either partialSum or carry is swapped with something.
+        // Strategy: find the XOR gate that uses carry as input (other than xorXY)
+        const xorUsingCarry = findGatesWithInput('XOR', carry).filter(
+          (g) => g !== xorXY
+        );
+        // Find the XOR gate that uses partialSum as input (other than xorXY)
+        const xorUsingPartial = findGatesWithInput('XOR', partialSum).filter(
+          (g) => g !== xorXY
+        );
+
+        if (xorUsingCarry.length === 1) {
+          // Found an XOR using carry. Its other input should be partialSum but isn't.
+          // So partialSum was swapped with the actual other input.
+          const actual = otherInput(xorUsingCarry[0], carry);
+          doSwap(partialSum, actual);
+          partialSum = actual;
+          sumGate = xorUsingCarry[0];
+        } else if (xorUsingPartial.length === 1) {
+          // Found an XOR using partialSum. Its other input should be carry but isn't.
+          // So carry was swapped with the actual other input.
+          const actual = otherInput(xorUsingPartial[0], partialSum);
+          doSwap(carry, actual);
+          carry = actual;
+          sumGate = xorUsingPartial[0];
+        }
+      }
+
+      if (sumGate && sumGate.out !== z) {
+        doSwap(sumGate.out, z);
+      }
+
+      // Step 3: Find generate gate (x_i AND y_i)
+      const genGate = findGate('AND', x, y);
+
+      // Step 4: Find propagate gate (partialSum AND carry)
+      const propGate = findGate('AND', partialSum, carry);
+
+      // Step 5: Find carry-out gate (generate OR propagate)
+      if (genGate && propGate) {
+        const orGate = findGate('OR', genGate.out, propGate.out);
+        if (orGate) {
+          carry = orGate.out;
+        } else {
+          // One of genGate.out or propGate.out is swapped
+          const orUsingGen = findGatesWithInput('OR', genGate.out);
+          const orUsingProp = findGatesWithInput('OR', propGate.out);
+
+          if (orUsingGen.length === 1 && orUsingProp.length === 0) {
+            const actual = otherInput(orUsingGen[0], genGate.out);
+            doSwap(propGate.out, actual);
+            carry = orUsingGen[0].out;
+          } else if (orUsingProp.length === 1 && orUsingGen.length === 0) {
+            const actual = otherInput(orUsingProp[0], propGate.out);
+            doSwap(genGate.out, actual);
+            carry = orUsingProp[0].out;
+          } else if (orUsingGen.length === 1 && orUsingProp.length === 1) {
+            // Both found OR gates but they're different. Pick the right one.
+            // The one with genGate's output is more likely the correct carry chain
+            const actual = otherInput(orUsingGen[0], genGate.out);
+            doSwap(propGate.out, actual);
+            carry = orUsingGen[0].out;
+          }
+        }
+      } else if (genGate && !propGate) {
+        // Find the OR gate using genGate.out and infer carry
+        const orUsingGen = findGatesWithInput('OR', genGate.out);
+        if (orUsingGen.length === 1) {
+          carry = orUsingGen[0].out;
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
