ctural violations, we identify swaps.\n\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const xWire = `x${pad(bit)}`;\n    const yWire = `y${pad(bit)}`;\n    const zWire = `z${pad(bit)}`;\n\n    if (bit === 0) {\n      // Half adder: x00 XOR y00 -> z00\n      const xorGate = findGate('XOR', xWire, yWire);\n      if (xorGate) {\n        if (xorGate.out !== zWire) {\n          // xorGate.out and zWire's owner are swapped\n          swapped.add(xorGate.out);\n          swapped.add(zWire);\n          // Fix the swap in our working copy\n          swapOutputs(xorGate.out, zWire);\n        }\n      }\n\n      // x00 AND y00 -> carry\n      const andGate = findGate('AND', xWire, yWire);\n      if (andGate) {\n        carry = andGate.out;\n      }\n    } else {\n      // Full adder for bit i:\n      // Step 1: x_i XOR y_i -> t_i\n      const xorGate = findGate('XOR', xWire, yWire);\n      if (!xorGate) continue;\n\n      let tWire = xorGate.out;\n\n      // Step 2: t_i XOR carry -> z_i\n      let sumGate = findGate('XOR', tWire, carry);\n\n      if (!sumGate) {\n        // One of tWire or carry might be swapped.\n        // Try to find an XOR gate that uses carry\n        const xorWithCarry = findGateWithInput('XOR', carry);\n        if (\n          xorWithCarry &&\n          xorWithCarry !== xorGate &&\n          xorWithCarry.in1 !== carry.replace(/./g, '') // sanity\n        ) {\n          // The other input of xorWithCarry should be tWire, but it's not.\n          // So tWire is swapped with whatever the other input is.\n          const otherInput =\n            xorWithCarry.in1 === carry\n              ? xorWithCarry.in2\n              : xorWithCarry.in1;\n          swapped.add(tWire);\n          swapped.add(otherInput);\n          swapOutputs(tWire, otherInput);\n          tWire = otherInput;\n          sumGate = xorWithCarry;\n        } else {\n          // Try finding XOR gate with tWire\n          const xorWithT = findGateWithInput('XOR', tWir