+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates given initial wire values.
+ * Returns the final value of every wire.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let progress = true;
+  while (remaining.length > 0 && progress) {
+    progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a binary adder circuit.
+ * Returns a sorted array of wire names.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Build lookup structures
+  // Map from output wire name to gate
+  const gateByOutput = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOutput.set(g.out, g);
+  }
+
+  // Find a gate by its operation and input wires (order-independent)
+  function findGate(
+    op: Gate['op'],
+    in1: string,
+    in2: string
+  ): Gate | undefined {
+    for (const g of gates) {
+      if (
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) ||
+          (g.in1 === in2 && g.in2 === in1))
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Find a gate by operation and one known input wire
+  function findGateByOpAndOneInput(
+    op: Gate['op'],
+    knownInput: string
+  ): Gate | undefined {
+    for (const g of gates) {
+      if (g.op === op && (g.in1 === knownInput || g.in2 === knownInput)) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Determine number of input bits by looking at x-prefixed wires
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2, g.out]) {
+      if (w.startsWith('x') || w.startsWith('y')) {
+        const num = parseInt(w.substring(1), 10);
+        if (num > maxBit) maxBit = num;
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+
+  const swapped = new Set<string>();
+
+  function swap(a: string, b: string): void {
+    // Find the gates that output a and b, and swap their outputs
+    const gA = gateByOutput.get(a)!;
+    const gB = gateByOutput.get(b)!;
+    gA.out = b;
+    gB.out = a;
+    gateByOutput.delete(a);
+    gateByOutput.delete(b);
+    gateByOutput.set(a, gB);
+    gateByOutput.set(b, gA);
+    swapped.add(a);
+    swapped.add(b);
+  }
+
+  function pad(n: number): string {
+    return n.toString().padStart(2, '0');
+  }
+
+  // Walk the adder structure bit by bit
+  // For bit 0: half adder
+  //   x00 XOR y00 -> z00
+  //   x00 AND y00 -> c00 (carry)
+  // For bit i > 0: full adder
+  //   xNN XOR yNN -> tNN (partial sum)
+  //   tNN XOR carry_in -> zNN (sum)
+  //   xNN AND yNN -> aNN (generate)
+  //   tNN AND carry_in -> bNN (propagate)
+  //   aNN OR bNN -> cNN (carry out)
+
+  let carry = '';
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const xWire = 'x' + pad(bit);
+    const yWire = 'y' + pad(bit);
+    const zWire = 'z' + pad(bit);
+
+    if (bit === 0) {
+      // Half adder: x00 XOR y00 -> z00
+      const xorGate = findGate('XOR', xWire, yWire);
+      if (!xorGate) throw new Error(`Missing XOR gate for bit ${bit}`);
+
+      if (xorGate.out !== zWire) {
+        // The XOR gate's output is swapped with something
+        swap(xorGate.out, zWire);
+      }
+
+      // x00 AND y00 -> carry
+      const andGate = findGate('AND', xWire, yWire);
+      if (!andGate) throw new Error(`Missing AND gate for bit ${bit}`);
+
+      carry = andGate.out;
+    } else {
+      // Full adder
+      // Step 1: find xNN XOR yNN -> partial sum
+      const xorInputGate = findGate('XOR', xWire, yWire);
+      if (!xorInputGate)
+        throw new Error(`Missing input XOR gate for bit ${bit}`);
+
+      let partialSum = xorInputGate.out;
+
+      // Step 2: find partialSum XOR carry -> zNN
+      let xorCarryGate = findGate('XOR', partialSum, carry);
+
+      if (!xorCarryGate) {
+        // One of partialSum or carry might be swapped.
+        // Try to find XOR gate that uses carry as an input
+        const xorWithCarry = findGateByOpAndOneInput('XOR', carry);
+        if (xorWithCarry && xorWithCarry !== xorInputGate) {
+          // The other input of this gate should be partialSum, but it isn't.
+          // So partialSum wire is swapped with whatever the other input is.
+          const otherInput =
+            xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;
+          swap(partialSum, otherInput);
+          partialSum = otherInput;
+          xorCarryGate = xorWithCarry;
+        } else {
+          // Try to find XOR gate that uses partialSum as an input
+          const xorWithPartial = findGateByOpAndOneInput('XOR', partialSum);
+          if (xorWithPartial && xorWithPartial !== xorInputGate) {
+            const otherInput =
+              xorWithPartial.in1 === partialSum
+                ? xorWithPartial.in2
+                : xorWithPartial.in1;
+            swap(carry, otherInput);
+            carry = otherInput;
+            xorCarryGate = xorWithPartial;
+          } else {
+            throw new Error(`Cannot find sum XOR gate for bit ${bit}`);
+          }
+        }
+      }
+
+      // Check output of XOR carry gate should be zNN
+      if (xorCarryGate.out !== zWire) {
+        swap(xorCarryGate.out, zWire);
+      }
+
+      // Step 3: xNN AND yNN -> generate carry
+      const andInputGate = findGate('AND', xWire, yWire);
+      if (!andInputGate)
+        throw new Error(`Missing input AND gate for bit ${bit}`);
+      const generate = andInputGate.out;
+
+      // Step 4: partialSum AND carry -> propagate carry
+      const andCarryGate = findGate('AND', partialSum, carry);
+      if (!andCarryGate)
+        throw new Error(`Missing carry AND gate for bit ${bit}`);
+      const propagate = andCarryGate.out;
+
+      // Step 5: generate OR propagate -> carry out
+      const orGate = findGate('OR', generate, propagate);
+      if (!orGate) {
+        // One of generate or propagate might be swapped
+        // Try finding OR gate with generate
+        const orWithGen = findGateByOpAndOneInput('OR', generate);
+        if (orWithGen) {
+          const otherInput =
+            orWithGen.in1 === generate ? orWithGen.in2 : orWithGen.in1;
+          swap(propagate, otherInput);
+          carry = orWithGen.out;
+        } else {
+          const orWithProp = findGateByOpAndOneInput('OR', propagate);
+          if (orWithProp) {
+            const otherInput =
+              orWithProp.in1 === propagate ? orWithProp.in2 : orWithProp.in1;
+            swap(generate, otherInput);
+            carry = orWithProp.out;
+          } else {
+            throw new Error(`Cannot find carry OR gate for bit ${bit}`);
+          }
+        }
+      } else {
+        carry = orGate.out;
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
