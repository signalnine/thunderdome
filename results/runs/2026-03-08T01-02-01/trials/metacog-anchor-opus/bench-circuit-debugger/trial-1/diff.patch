, b: 0, d: 1 });\n    expect(result.c).toBe(1); // 1 XOR 0 = 1\n    expect(result.e).toBe(1); // 1 AND 1 = 1\n  });\n\n  it('should simulate a 2-bit adder (0+0)', () => {\n    const gates: Gate[] = make2BitAdder();\n    const result = simulate(gates, {\n      x00: 0, x01: 0,\n      y00: 0, y01: 0,\n    });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n  });\n\n  it('should simulate a 2-bit adder (1+1=2)', () => {\n    const gates: Gate[] = make2BitAdder();\n    const result = simulate(gates, {\n      x00: 1, x01: 0,\n      y00: 1, y01: 0,\n    });\n    // 1 + 1 = 2 = 010\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n  });\n\n  it('should simulate a 2-bit adder (3+3=6)', () => {\n    const gates: Gate[] = make2BitAdder();\n    const result = simulate(gates, {\n      x00: 1, x01: 1,\n      y00: 1, y01: 1,\n    });\n    // 3 + 3 = 6 = 110\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n  });\n\n  it('should simulate a 4-bit adder from the spec (7+9=16)', () => {\n    const gates: Gate[] = make4BitAdder();\n    const result = simulate(gates, {\n      x00: 1, x01: 1, x02: 1, x03: 0, // 7\n      y00: 1, y01: 0, y02: 0, y03: 1, // 9\n    });\n    // 7 + 9 = 16 = 10000\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(0);\n    expect(result.z04).toBe(1);\n  });\n\n  it('should simulate a 4-bit adder (15+15=30)', () => {\n    const gates: Gate[] = make4BitAdder();\n    const result = simulate(gates, {\n      x00: 1, x01: 1, x02: 1, x03: 1, // 15\n      y00: 1, y01: 1, y02: 1, y03: 1, // 15\n    });\n    // 15 + 15 = 30 = 11110\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in a 4-bit adder with z01 and a01 swapped', () => {\n    const gates: Gate[] = make4BitAdder();\n    // Swap z01 output with a01 output\n    swapOutputs(gates, 'z01', 'a01');\n    // Need 4 swaps total, so add 3 more\n    swapOutputs(gates, 'z02', 'b02');\n    swapOutputs(gates, 'z03', 'c02');\n    swapOutputs(gates, 'z04', 'c03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'b02', 'c02', 'c03', 'z01', 'z02', 'z03', 'z04'].sort()\n    );\n  });\n\n  it('should find swapped wires in a larger adder', () => {\n    const numBits = 8;\n    const { gates, wireNames } = makeNBitAdder(numBits);\n\n    // Create 4 swaps\n    // Swap t01 (partial sum of bit 1) with z01\n    swapOutputs(gates, wireNames.t[1], wireNames.z[1]);\n    // Swap a03 (generate carry of bit 3) with b03 (propagate carry of bit 3)\n    swapOutputs(gates, wireNames.a[3], wireNames.b[3]);\n    // Swap z05 with c04\n    swapOutputs(gates, wireNames.z[5], wireNames.c[4]);\n    // Swap t07 with z07\n    swapOutputs(gates, wireNames.t[7], wireNames.z[7]);\n\n    const result = findSwappedWires(gates);\n    const expected = [\n      wireNames.t[1], wireNames.z[1],\n      wireNames.a[3], wireNames.b[3],\n      wireNames.z[5], wireNames.c[4],\n      wireNames.t[7], wireNames.z[7],\n    ].sort();\n\n    expect(result).toEqual(expected);\n  });\n\n  it('should handle 45-bit adder with swaps in under 5 seconds', () => {\n    const numBits = 45;\n    const { gates, wireNames } = makeNBitAdder(numBits);\n\n    // 4 swaps spread across the circuit\n    swapOutputs(gates, wireNames.z[0], wireNames.c[0]);\n    swapOutputs(gates, wireNames.t[10], wireNames.z[10]);\n    swapOutputs(gates, wireNames.a[20], wireNames.b[20]);\n    swapOutputs(gates, wireNames.z[44], wireNames.c[43]);\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n\n    const expected = [\n      wireNames.z[0], wireNames.c[0],\n      wireNames.t[10], wireNames.z[10],\n      wireNames.a[20], wireNames.b[20],\n      wireNames.z[44], wireNames.c[43],\n    ].sort();\n\n    expect(result).toEqual(expected);\n  });\n\n  it('should find swaps when carry wire is swapped', () => {\n    const numBits = 8;\n    const { gates, wireNames } = makeNBitAdder(numBits);\n\n    // Swap carry output with something else\n    swapOutputs(gates, wireNames.c[1], wireNames.z[2]);\n    swapOutputs(gates, wireNames.c[3], wireNames.z[4]);\n    swapOutputs(gates, wireNames.t[5], wireNames.z[5]);\n    swapOutputs(gates, wireNames.a[7], wireNames.b[7]);\n\n    const result = findSwappedWires(gates);\n    const expected = [\n      wireNames.c[1], wireNames.z[2],\n      wireNames.c[3], wireNames.z[4],\n      wireNames.t[5], wireNames.z[5],\n      wireNames.a[7], wireNames.b[7],\n    ].sort();\n\n    expect(result).toEqual(expected);\n  });\n});\n\n// Helper: build a 2-bit adder\nfunction make2BitAdder(): Gate[] {\n  return [\n    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n    { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n    { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n    { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n  ];\n}\n\n// Helper: build the 4-bit adder from the spec\nfunction make4BitAdder(): Gate[] {\n  return [\n    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n\n    { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n    { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n    { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n    { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n\n    { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n    { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n    { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n    { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n    { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n\n    { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n    { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n    { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n    { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n    { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n  ];\n}\n\n// Helper: build an N-bit adder with named wires, returning wire name mappings\nfunction makeNBitAdder(numBits: number): {\n  gates: Gate[];\n  wireNames: {\n    t: Record<number, string>;\n    a: Record<number, string>;\n    b: Record<number, string>;\n    c: Record<number, string>;\n    z: Record<number, string>;\n  };\n} {\n  const gates: Gate[] = [];\n  const t: Record<number, string> = {};\n  const a: Record<number, string> = {};\n  const b: Record<number, string> = {};\n  const c: Record<number, string> = {};\n  const z: Record<number, string> = {};\n\n  const pad = (n: number) => n.toString().padStart(2, '0');\n\n  // Use random-ish but deterministic wire names for internal wires\n  function rndWire(prefix: string, bit: number): string {\n    return `${prefix}_${pad(bit)}`;\n  }\n\n  for (let i = 0; i < numBits; i++) {\n    const x = 'x' + pad(i);\n    const y = 'y' + pad(i);\n    const zWire = 'z' + pad(i);\n    z[i] = zWire;\n\n    if (i === 0) {\n      gates.push({ op: 'XOR', in1: x, in2: y, out: zWire });\n      c[0] = rndWire('c', 0);\n      gates.push({ op: 'AND', in1: x, in2: y, out: c[0] });\n    } else {\n      t[i] = rndWire('t', i);\n      gates.push({ op: 'XOR', in1: x, in2: y, out: t[i] });\n      gates.push({ op: 'XOR', in1: t[i], in2: c[i - 1], out: zWire });\n\n      a[i] = rndWire('a', i);\n      gates.push({ op: 'AND', in1: x, in2: y, out: a[i] });\n\n      b[i] = rndWire('b', i);\n      gates.push({ op: 'AND', in1: t[i], in2: c[i - 1], out: b[i] });\n\n      if (i === numBits - 1) {\n        // Last bit: carry becomes the final z output\n        const finalZ = 'z' + pad(i + 1);\n        z[i + 1] = finalZ;\n        gates.push({ op: 'OR', in1: a[i], in2: b[i], out: finalZ });\n      } else {\n        c[i] = rndWire('c', i);\n        gates.push({ op: 'OR', in1: a[i], in2: b[i], out: c[i] });\n      }\n    }\n  }\n\n  // Shuffle gates to make order non-trivial\n  for (let i = gates.length - 1; i > 0; i--) {\n    const j = (i * 7 + 3) % (i + 1);\n    [gates[i], gates[j]] = [gates[j], gates[i]];\n  }\n\n  return { gates, wireNames: { t, a, b, c, z } };\n}\n\n// Helper: swap outputs of two gates\nfunction swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n  const g1 = gates.find((g) => g.out === wire1);\n  const g2 = gates.find((g) => g.out === wire2);\n  if (!g1 || !g2) throw new Error(`Cannot find gates with outputs ${wire1} and ${wire2}`);\n  g1.out = wire2;\n  g2.out = wire1;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":244,"cache_read_input_tokens":24308,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":244},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3a1b38f2-d83f-482e-9035-396476110670","uuid":"cc8a1b47-33dc-4ba2-85a4-597cd535e30f"}
