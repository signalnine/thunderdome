@@ -0,0 +1,100 @@
+import { EventBus } from '../bus.js';
+import { AnalyticsService, Events, OrderCreatedEvent, PaymentProcessedEvent, CartUpdatedEvent, PaymentStatus } from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  const revenue = { total: 0 };
+  const uniqueCarts = new Set<string>();
+  const orderCount = { count: 0 };
+  const orderToCart = new Map<string, string>();
+  const orderToTotal = new Map<string, number>();
+  const cartToItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+  const productQuantities = new Map<string, number>();
+
+  function incrementEvent(eventType: string): void {
+    const current = eventCounts.get(eventType) || 0;
+    eventCounts.set(eventType, current + 1);
+  }
+
+  bus.on(Events.PRODUCT_CREATED, () => {
+    incrementEvent(Events.PRODUCT_CREATED);
+  });
+
+  bus.on(Events.INVENTORY_UPDATED, () => {
+    incrementEvent(Events.INVENTORY_UPDATED);
+  });
+
+  bus.on(Events.LOW_STOCK_ALERT, () => {
+    incrementEvent(Events.LOW_STOCK_ALERT);
+  });
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as CartUpdatedEvent;
+    uniqueCarts.add(event.cartId);
+    cartToItems.set(event.cartId, event.items);
+    incrementEvent(Events.CART_UPDATED);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderCount.count++;
+    orderToCart.set(event.orderId, event.cartId);
+    orderToTotal.set(event.orderId, event.total);
+
+    const items = cartToItems.get(event.cartId);
+    if (items) {
+      for (const item of items) {
+        const current = productQuantities.get(item.productId) || 0;
+        productQuantities.set(item.productId, current + item.quantity);
+      }
+    }
+
+    incrementEvent(Events.ORDER_CREATED);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, () => {
+    incrementEvent(Events.ORDER_STATUS_CHANGED);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      const orderId = event.orderId;
+      const orderTotal = orderToTotal.get(orderId);
+      if (orderTotal !== undefined) {
+        revenue.total += orderTotal;
+      }
+    }
+    incrementEvent(Events.PAYMENT_PROCESSED);
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, () => {
+    incrementEvent(Events.NOTIFICATION_SENT);
+  });
+
+  bus.on(Events.ANALYTICS_EVENT, () => {
+    incrementEvent(Events.ANALYTICS_EVENT);
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) || 0;
+    },
+
+    getRevenue(): number {
+      return revenue.total;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCarts.size === 0) return 0;
+      return orderCount.count / uniqueCarts.size;
+    },
+
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> {
+      return Array.from(productQuantities.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    }
+  };
+}
