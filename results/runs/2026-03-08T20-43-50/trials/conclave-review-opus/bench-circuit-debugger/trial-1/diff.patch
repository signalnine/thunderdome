pected);\n  });\n\n  it('test 16: finds swaps in 45-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(45, 322);\n    const pairs = pickDetectableSwapPairs(correct, 45, 422);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 522);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n});\n\ndescribe('Group 5: Edge cases', () => {\n  it('test 17: detects swap involving the final carry (z[N])', async () => {\n    const { findSwappedWires } = await discover();\n    const n = 16;\n    const correct = generateCorrectAdder(n, 330);\n    const cats = categorizeWires(correct, n);\n    const rng = seededRandom(430);\n\n    shuffleArray(cats.z, rng);\n    shuffleArray(cats.a, rng);\n    shuffleArray(cats.b, rng);\n\n    // finalZ ↔ regular z is detectable (OR↔XOR both violate rule 1)\n    // Remaining 3 pairs use standard detectable combos\n    const pairs: [string, string][] = [\n      [cats.finalZ, cats.z[0]],    // final carry ↔ z-output\n      [cats.z[1], cats.a[0]],      // z ↔ generate\n      [cats.z[2], cats.b[0]],      // z ↔ propagate\n      [cats.a[1], cats.b[1]],      // generate ↔ propagate — wait, NOT detectable!\n    ];\n\n    // Fix: use t↔a instead of a↔b\n    shuffleArray(cats.t, rng);\n    pairs[3] = [cats.t[0], cats.a[2]];  // partial-sum ↔ generate\n\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 530);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 18: detects swaps using z↔carry cross-category', async () => {\n    const { findSwappedWires } = await discover();\n    const n = 16;\n    const correct = generateCorrectAdder(n, 331);\n    const cats = categorizeWires(correct, n);\n    const rng = seededRandom(431);\n\n    shuffleArray(cats.z, rng);\n    shuffleArray(cats.t, rng);\n    shuffleArray(cats.a, rng);\n    shuffleArray(cats.b, rng);\n    shuffleArray(cats.c, rng);\n\n    // z↔c is detectable (non-input XOR→non-z = rule2, OR→z = rule1)\n    const pairs: [string, string][] = [\n      [cats.z[0], cats.c[0]],     // z ↔ carry\n      [cats.z[1], cats.a[0]],     // z ↔ generate\n      [cats.t[0], cats.b[0]],     // partial-sum ↔ propagate\n      [cats.t[1], cats.a[1]],     // partial-sum ↔ generate\n    ];\n\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 531);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 19: detects z-wire swapped with non-input AND wire', async () => {\n    const { findSwappedWires } = await discover();\n    const n = 20;\n    const correct = generateCorrectAdder(n, 332);\n    const cats = categorizeWires(correct, n);\n    const rng = seededRandom(432);\n\n    shuffleArray(cats.z, rng);\n    shuffleArray(cats.t, rng);\n    shuffleArray(cats.a, rng);\n    shuffleArray(cats.b, rng);\n\n    // All z↔propagate swaps\n    const pairs: [string, string][] = [\n      [cats.z[0], cats.b[0]],     // z ↔ propagate\n      [cats.z[1], cats.b[1]],     // z ↔ propagate\n      [cats.t[0], cats.a[0]],     // partial-sum ↔ generate\n      [cats.t[1], cats.a[1]],     // partial-sum ↔ generate\n    ];\n\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 532);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n});\n\ndescribe('Group 6: Performance', () => {\n  it('test 20: solves a 45-bit adder in under 5 seconds', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(45, 340);\n    const pairs = pickDetectableSwapPairs(correct, 45, 440);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 540);\n\n    const start = performance.now();\n    const result = findSwappedWires(shuffled);\n    const elapsed = performance.now() - start;\n\n    const expected = pairs.flat().sort();\n    expect(result).toEqual(expected);\n    expect(elapsed).toBeLessThan(5000);\n  });\n});","is_error":false}]},"parent_tool_use_id":null,"session_id":"c81cafb3-f750-4da1-bc93-50c47d6b5e35","uuid":"c1df430d-1373-422a-a5c3-4ee0e215c8d2","tool_use_result":{"stdout":"import { describe, it, expect } from 'vitest';\nimport { discover, type Gate } from './_discovery.js';\n\n// ─── Seeded PRNG (xorshift32) ─────────────────────────────────────────────────\n\nfunction seededRandom(seed: number): () => number {\n  let state = seed | 0 || 1;\n  return () => {\n    state ^= state << 13;\n    state ^= state >> 17;\n    state ^= state << 5;\n    return (state >>> 0) / 0x100000000;\n  };\n}\n\n// ─── Circuit Generator ────────────────────────────────────────────────────────\n\nfunction randomWireName(rng: () => number, usedNames: Set<string>): string {\n  const chars = 'abcdefghijklmnopqrstuvw';\n  let name: string;\n  do {\n    name = '';\n    for (let i = 0; i < 3; i++) {\n      name += chars[Math.floor(rng() * chars.length)];\n    }\n  } while (usedNames.has(name));\n  usedNames.add(name);\n  return name;\n}\n\nfunction generateCorrectAdder(n: number, seed: number): Gate[] {\n  const rng = seededRandom(seed);\n  const gates: Gate[] = [];\n  const usedNames = new Set<string>();\n\n  // Reserve x/y/z names\n  for (let i = 0; i < n; i++) {\n    const pad = String(i).padStart(2, '0');\n    usedNames.add(`x${pad}`);\n    usedNames.add(`y${pad}`);\n    usedNames.add(`z${pad}`);\n  }\n  usedNames.add(`z${String(n).padStart(2, '0')}`);\n\n  // Bit 0: half adder\n  const x0 = 'x00', y0 = 'y00', z0 = 'z00';\n  const c0 = randomWireName(rng, usedNames);\n  gates.push({ op: 'XOR', in1: x0, in2: y0, out: z0 });\n  gates.push({ op: 'AND', in1: x0, in2: y0, out: c0 });\n\n  let carry = c0;\n\n  // Bits 1..n-1: full adders\n  for (let i = 1; i < n; i++) {\n    const pad = String(i).padStart(2, '0');\n    const xi = `x${pad}`, yi = `y${pad}`, zi = `z${pad}`;\n    const t = randomWireName(rng, usedNames);\n    const a = randomWireName(rng, usedNames);\n    const b = randomWireName(rng, usedNames);\n    const c = randomWireName(rng, usedNames);\n\n    gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });\n    gates.push({ op: 'XOR', in1: t, in2: carry, out: zi });\n    gates.push({ op: 'AND', in1: xi, in2: yi, out: a });\n    gates.push({ op: 'AND', in1: t, in2: carry, out: b });\n    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n\n    carry = c;\n  }\n\n  // Final carry → z[n]\n  const finalZ = `z${String(n).padStart(2, '0')}`;\n  for (const gate of gates) {\n    if (gate.out === carry) gate.out = finalZ;\n    if (gate.in1 === carry) gate.in1 = finalZ;\n    if (gate.in2 === carry) gate.in2 = finalZ;\n  }\n\n  return gates;\n}\n\nfunction applySwaps(gates: Gate[], pairs: [string, string][]): Gate[] {\n  const swapMap = new Map<string, string>();\n  for (const [a, b] of pairs) {\n    swapMap.set(a, b);\n    swapMap.set(b, a);\n  }\n  return gates.map((g) => ({\n    ...g,\n    out: swapMap.get(g.out) ?? g.out,\n  }));\n}\n\nfunction shuffleGates(gates: Gate[], seed: number): Gate[] {\n  const rng = seededRandom(seed);\n  const arr = [...gates];\n  for (let i = arr.length - 1; i > 0; i--) {\n    const j = Math.floor(rng() * (i + 1));\n    [arr[i], arr[j]] = [arr[j], arr[i]];\n  }\n  return arr;\n}\n\nfunction shuffleArray(arr: string[], rng: () => number): void {\n  for (let i = arr.length - 1; i > 0; i--) {\n    const j = Math.floor(rng() * (i + 1));\n    [arr[i], arr[j]] = [arr[j], arr[i]];\n  }\n}\n\n/**\n * Categorize gate output wires by their structural role in the adder.\n * Only swaps between certain categories are detectable by structural rules.\n *\n * Detectable cross-category pairs:\n *   z ↔ {t, a, b, c}\n *   t ↔ {a, b}\n *   finalZ ↔ z\n *\n * NOT detectable: t↔c, a↔b, a↔c, b↔c, same↔same\n */\nfunction categorizeWires(gates: Gate[], n: number) {\n  const finalZ = `z${String(n).padStart(2, '0')}`;\n  const z: string[] = [];  // output XOR → z (not z00, not finalZ)\n  const t: string[] = [];  // input XOR → partial sum (not bit0)\n  const a: string[] = [];  // input AND → generate (not bit0)\n  const b: string[] = [];  // non-input AND → propagate\n  const c: string[] = [];  // OR → carry\n\n  for (const gate of gates) {\n    const isBit0 =\n      (gate.in1 === 'x00' || gate.in1 === 'y00') &&\n      (gate.in2 === 'x00' || gate.in2 === 'y00');\n    if (isBit0) continue;\n    if (gate.out === finalZ) continue;\n\n    const hasXY =\n      gate.in1.startsWith('x') || gate.in1.startsWith('y') ||\n      gate.in2.startsWith('x') || gate.in2.startsWith('y');\n\n    if (gate.out.startsWith('z')) z.push(gate.out);\n    else if (gate.op === 'XOR' && hasXY) t.push(gate.out);\n    else if (gate.op === 'AND' && hasXY) a.push(gate.out);\n    else if (gate.op === 'AND') b.push(gate.out);\n    else if (gate.op === 'OR') c.push(gate.out);\n  }\n\n  return { z, t, a, b, c, finalZ };\n}\n\n/**\n * Pick 4 swap pairs guaranteed to be detectable by structural analysis.\n * Cycles through: z↔a, z↔b, t↔a, t↔b (all proven detectable).\n */\nfunction pickDetectableSwapPairs(\n  gates: Gate[],\n  n: number,\n  seed: number,\n): [string, string][] {\n  const rng = seededRandom(seed);\n  const cats = categorizeWires(gates, n);\n\n  // Shuffle each category\n  shuffleArray(cats.z, rng);\n  shuffleArray(cats.t, rng);\n  shuffleArray(cats.a, rng);\n  shuffleArray(cats.b, rng);\n  shuffleArray(cats.c, rng);\n\n  // Cross-category templates (all verified detectable)\n  const pairs: [string, string][] = [\n    [cats.z[0], cats.a[0]],   // z ↔ generate\n    [cats.z[1], cats.b[0]],   // z ↔ propagate\n    [cats.t[0], cats.a[1]],   // partial-sum ↔ generate\n    [cats.t[1], cats.b[1]],   // partial-sum ↔ propagate\n  ];\n\n  return pairs;\n}\n\n/** Build inputs for an N-bit adder with given X and Y values */\nfunction makeInputs(n: number, x: bigint, y: bigint): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < n; i++) {\n    const pad = String(i).padStart(2, '0');\n    inputs[`x${pad}`] = Number((x >> BigInt(i)) & 1n);\n    inputs[`y${pad}`] = Number((y >> BigInt(i)) & 1n);\n  }\n  return inputs;\n}\n\n/** Read z-wires from simulation output as a bigint */\nfunction readZ(wires: Record<string, number>, n: number): bigint {\n  let result = 0n;\n  for (let i = 0; i <= n; i++) {\n    const pad = String(i).padStart(2, '0');\n    const bit = wires[`z${pad}`];\n    if (bit) result |= BigInt(bit) << BigInt(i);\n  }\n  return result;\n}\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe('Group 1: Simulation', () => {\n  it('test 1: simulates a single AND gate', async () => {\n    const { simulate } = await discover();\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toMatchObject({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toMatchObject({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toMatchObject({ a: 0, b: 0, c: 0 });\n  });\n\n  it('test 2: simulates OR and XOR gates', async () => {\n    const { simulate } = await discover();\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'd' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.c).toBe(1);\n    expect(result.d).toBe(1);\n\n    const result2 = simulate(gates, { a: 1, b: 1 });\n    expect(result2.c).toBe(1);\n    expect(result2.d).toBe(0);\n  });\n\n  it('test 3: simulates a chain of dependent gates', async () => {\n    const { simulate } = await discover();\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 't', in2: 'c', out: 'out' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 't' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, c: 1 });\n    expect(result.t).toBe(1);\n    expect(result.out).toBe(0);\n  });\n\n  it('test 4: simulates a correct 4-bit adder (3 + 5 = 8)', async () => {\n    const { simulate } = await discover();\n    const gates = generateCorrectAdder(4, 100);\n    const inputs = makeInputs(4, 3n, 5n);\n    const result = simulate(gates, inputs);\n    expect(readZ(result, 4)).toBe(8n);\n  });\n\n  it('test 5: simulates a correct 8-bit adder (200 + 100 = 300)', async () => {\n    const { simulate } = await discover();\n    const gates = generateCorrectAdder(8, 200);\n    const inputs = makeInputs(8, 200n, 100n);\n    const result = simulate(gates, inputs);\n    expect(readZ(result, 8)).toBe(300n);\n  });\n});\n\ndescribe('Group 2: Small swap detection (8-12 bits)', () => {\n  it('test 6: finds swaps in 8-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(8, 301);\n    const pairs = pickDetectableSwapPairs(correct, 8, 401);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 501);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 7: finds swaps in 10-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(10, 302);\n    const pairs = pickDetectableSwapPairs(correct, 10, 402);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 502);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 8: finds swaps in 12-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorr