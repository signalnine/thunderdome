;\n    if (gate) {\n      if (gate.op !== 'XOR') {\n        // This z-wire is wrong - it should be produced by a XOR\n        swapped.add(zWire);\n      } else if (hasXYInputs(gate)) {\n        // A z-wire produced by a XOR with x/y inputs is wrong\n        // (should be second XOR in full adder, not first)\n        swapped.add(zWire);\n      }\n    }\n  }\n\n  // Rule 2: Non-input XOR gates must output to z-wires\n  for (const g of gates) {\n    if (g.op === 'XOR' && !hasXYInputs(g) && !g.out.startsWith('z')) {\n      swapped.add(g.out);\n    }\n  }\n\n  // Rule 3: XOR gates with x/y inputs (partial sums, except bit 0) must feed\n  // into both a XOR and an AND gate\n  for (const g of gates) {\n    if (g.op === 'XOR' && hasXYInputs(g) && g.out !== 'z00') {\n      const consumers = findConsumers(g.out);\n      const consumerOps = consumers.map(c => c.op);\n      if (!consumerOps.includes('XOR') || !consumerOps.includes('AND')) {\n        // This partial sum wire isn't being used correctly\n        // Only flag if it's not already flagged and not a z-wire\n        if (!g.out.startsWith('z')) {\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // Rule 4: AND gates with x/y inputs (generate carry, except bit 0) must\n  // feed into an OR gate\n  for (const g of gates) {\n    if (g.op === 'AND' && hasXYInputs(g)) {\n      // Skip bit 0 - its AND output is the initial carry\n      const inputs = [g.in1, g.in2].sort();\n      if (inputs[0] === 'x00' || inputs[1] === 'x00') continue;\n\n      const consumers = findConsumers(g.out);\n      const consumerOps = consumers.map(c => c.op);\n      if (!consumerOps.includes('OR')) {\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // Rule 5: AND gates without x/y inputs (propagate carry) must feed into OR\n  for (const g of gates) {\n    if (g.op === 'AND' && !hasXYInputs(g)) {\n      const consumers = findConsumers(g.out);\n      const consumerOps = consumers.map(c => c.op);\n      if (!consumerOps.includes('OR')) {\n        // Unless this is the final carry output\n        if (g.out !== finalZ) {\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // Rule 6: OR gates must not output to z-wires (except finalZ)\n  for (const g of gates) {\n    if (g.op === 'OR' && g.out.startsWith('z') && g.out !== finalZ) {\n      swapped.add(g.out);\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[],"originalFile":null}}
