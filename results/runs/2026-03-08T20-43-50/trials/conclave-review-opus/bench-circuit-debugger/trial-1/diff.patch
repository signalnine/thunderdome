ires (i.e., it's the second XOR in a full adder stage).\n * 2. Every XOR gate whose inputs are NOT x/y must output to a z-wire.\n * 3. A XOR gate with x/y inputs (partial sum) must be used as input to\n *    both a XOR gate (producing z) and an AND gate (producing propagate carry).\n * 4. An AND gate with x/y inputs (generate carry) must feed into an OR gate.\n * 5. An AND gate without x/y inputs (propagate carry) must feed into an OR gate.\n * 6. The final carry (OR output for the highest bit) should be z[N].\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Find the number of bits by looking at x-inputs\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      if (inp.startsWith('x') || inp.startsWith('y')) {\n        const num = parseInt(inp.slice(1), 10);\n        if (num > maxBit) maxBit = num;\n      }\n    }\n  }\n  const n = maxBit + 1; // number of input bits\n  const finalZ = `z${String(n).padStart(2, '0')}`;\n\n  // Helper: check if a wire is an x or y input\n  function isXY(wire: string): boolean {\n    return wire.startsWith('x') || wire.startsWith('y');\n  }\n\n  // Helper: check if a gate has x/y inputs\n  function hasXYInputs(gate: Gate): boolean {\n    return isXY(gate.in1) || isXY(gate.in2);\n  }\n\n  // Helper: find all gates that use a given wire as input\n  function findConsumers(wire: string): Gate[] {\n    return gates.filter(g => g.in1 === wire || g.in2 === wire);\n  }\n\n  // Rule 1: z-outputs (except z00 and finalZ) must come from non-input XOR gates\n  for (let i = 1; i < n; i++) {\n    const zWire = `z${String(i).padStart(2, '0')}`;\n    const gate = gateByOutput.get(zWire);\n    if (gate) {\n      if (gate.op !== 'XOR') {\n        // This z-wire is wrong - it should be produced by a XOR\n        swapped.add(zWire);\n      } else if (hasXYInputs(gate)) {\n        // A z-wire produced by a XOR with x/y inputs is wrong\n        // (should be second XOR in full adder, not first)\n        swapped.add(zWire);\n      }\n    }\n  }\n\n  // Rule 2: Non-input XOR gates must output to z-wires\n  for (const g of gates) {\n    if (g.op === 'XOR' && !hasXYInputs(g) && !g.out.startsWith('z')) {\n      swapped.add(g.out);\n    }\n  }\n\n  // Rule 3: XOR gates with x/y inputs (partial sums, except bit 0) must feed\n  // into both a XOR and an AND gate\n  for (const g of gates) {\n    if (g.op === 'XOR' && hasXYInputs(g) && g.out !== 'z00') {\n      const consumers = findConsumers(g.out);\n      const consumerOps = consumers.map(c => c.op);\n      if (!consumerOps.includes('XOR') || !consumerOps.includes('AND')) {\n        // This partial sum wire isn't being used correctly\n        // Only flag if it's not already flagged and not a z-wire\n        if (!g.out.startsWith('z')) {\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // Rule 4: AND gates with x/y inputs (generate carry, except bit 0) must\n  // feed into an OR gate\n  for (const g of gates) {\n    if (g.op === 'AND' && hasXYInputs(g)) {\n      // Skip bit 0 - its AND output is the initial carry\n      const inputs = [g.in1, g.in2].sort();\n      if (inputs[0] === 'x00' || inputs[1] === 'x00') continue;\n\n      const consumers = findConsumers(g.out);\n      const consumerOps = consumers.map(c => c.op);\n      if (!consumerOps.includes('OR')) {\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // Rule 5: AND gates without x/y inputs (propagate carry) must feed into OR\n  for (const g of gates) {\n    if (g.op === 'AND' && !hasXYInputs(g)) {\n      const consumers = findConsumers(g.out);\n      const consumerOps = consumers.map(c => c.op);\n      if (!consumerOps.includes('OR')) {\n        // Unless this is the final carry output\n        if (g.out !== finalZ) {\n          swapped.add(g.out);\n