emaining 3 pairs use standard detectable combos\n   431→    const pairs: [string, string][] = [\n   432→      [cats.finalZ, cats.z[0]],    // final carry ↔ z-output\n   433→      [cats.z[1], cats.a[0]],      // z ↔ generate\n   434→      [cats.z[2], cats.b[0]],      // z ↔ propagate\n   435→      [cats.a[1], cats.b[1]],      // generate ↔ propagate — wait, NOT detectable!\n   436→    ];\n   437→\n   438→    // Fix: use t↔a instead of a↔b\n   439→    shuffleArray(cats.t, rng);\n   440→    pairs[3] = [cats.t[0], cats.a[2]];  // partial-sum ↔ generate\n   441→\n   442→    const broken = applySwaps(correct, pairs);\n   443→    const shuffled = shuffleGates(broken, 530);\n   444→\n   445→    const expected = pairs.flat().sort();\n   446→    const result = findSwappedWires(shuffled);\n   447→    expect(result).toEqual(expected);\n   448→  });\n   449→\n   450→  it('test 18: detects swaps using z↔carry cross-category', async () => {\n   451→    const { findSwappedWires } = await discover();\n   452→    const n = 16;\n   453→    const correct = generateCorrectAdder(n, 331);\n   454→    const cats = categorizeWires(correct, n);\n   455→    const rng = seededRandom(431);\n   456→\n   457→    shuffleArray(cats.z, rng);\n   458→    shuffleArray(cats.t, rng);\n   459→    shuffleArray(cats.a, rng);\n   460→    shuffleArray(cats.b, rng);\n   461→    shuffleArray(cats.c, rng);\n   462→\n   463→    // z↔c is detectable (non-input XOR→non-z = rule2, OR→z = rule1)\n   464→    const pairs: [string, string][] = [\n   465→      [cats.z[0], cats.c[0]],     // z ↔ carry\n   466→      [cats.z[1], cats.a[0]],     // z ↔ generate\n   467→      [cats.t[0], cats.b[0]],     // partial-sum ↔ propagate\n   468→      [cats.t[1], cats.a[1]],     // partial-sum ↔ generate\n   469→    ];\n   470→\n   471→    const broken = applySwaps(correct, pairs);\n   472→    const shuffled = shuffleGates(broken, 531);\n   473→\n   474→    const expected = pairs.flat().sort();\n   475→    const result = findSwapped