+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WgE7MhcFGTvxxYxNedYsws","type":"tool_result","content":"import { describe, it, expect } from 'vitest';\nimport { discover, type Gate } from './_discovery.js';\n\n// РћђРћђРћђ Seeded PRNG (xorshift32) РћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђ\n\nfunction seededRandom(seed: number): () => number {\n  let state = seed | 0 || 1;\n  return () => {\n    state ^= state << 13;\n    state ^= state >> 17;\n    state ^= state << 5;\n    return (state >>> 0) / 0x100000000;\n  };\n}\n\n// РћђРћђРћђ Circuit Generator РћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђ\n\nfunction randomWireName(rng: () => number, usedNames: Set<string>): string {\n  const chars = 'abcdefghijklmnopqrstuvw';\n  let name: string;\n  do {\n    name = '';\n    for (let i = 0; i < 3; i++) {\n      name += chars[Math.floor(rng() * chars.length)];\n    }\n  } while (usedNames.has(name));\n  usedNames.add(name);\n  return name;\n}\n\nfunction generateCorrectAdder(n: number, seed: number): Gate[] {\n  const rng = seededRandom(seed);\n  const gates: Gate[] = [];\n  const usedNames = new Set<string>();\n\n  // Reserve x/y/z names\n  for (let i = 0; i < n; i++) {\n    const pad = String(i).padStart(2, '0');\n    usedNames.add(`x${pad}`);\n    usedNames.add(`y${pad}`);\n    usedNames.add(`z${pad}`);\n  }\n  usedNames.add(`z${String(n).padStart(2, '0')}`);\n\n  // Bit 0: half adder\n  const x0 = 'x00', y0 = 'y00', z0 = 'z00';\n  const c0 = randomWireName(rng, usedNames);\n  gates.push({ op: 'XOR', in1: x0, in2: y0, out: z0 });\n  gates.push({ op: 'AND', in1: x0, in2: y0, out: c0 });\n\n  let carry = c0;\n\n  // Bits 1..n-1: full adders\n  for (let i = 1; i < n; i++) {\n    const pad = String(i).padStart(2, '0');\n    const xi = `x${pad}`, yi = `y${pad}`, zi = `z${pad}`;\n    const t = randomWireName(rng, usedNames);\n    const a = randomWireName(rng, usedNames);\n    const b = randomWireName(rng, usedNames);\n    const c = randomWireName(rng, usedNames);\n\n    gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });\n    gates.push({ op: 'XOR', in1: t, in2: carry, out: zi });\n    gates.push({ op: 'AND', in1: xi, in2: yi, out: a });\n    gates.push({ op: 'AND', in1: t, in2: carry, out: b });\n    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n\n    carry = c;\n  }\n\n  // Final carry Рєњ z[n]\n  const finalZ = `z${String(n).padStart(2, '0')}`;\n  for (const gate of gates) {\n    if (gate.out === carry) gate.out = finalZ;\n    if (gate.in1 === carry) gate.in1 = finalZ;\n    if (gate.in2 === carry) gate.in2 = finalZ;\n  }\n\n  return gates;\n}\n\nfunction applySwaps(gates: Gate[], pairs: [string, string][]): Gate[] {\n  const swapMap = new Map<string, string>();\n  for (const [a, b] of pairs) {\n    swapMap.set(a, b);\n    swapMap.set(b, a);\n  }\n  return gates.map((g) => ({\n    ...g,\n    out: swapMap.get(g.out) ?? g.out,\n  }));\n}\n\nfunction shuffleGates(gates: Gate[], seed: number): Gate[] {\n  const rng = seededRandom(seed);\n  const arr = [...gates];\n  for (let i = arr.length - 1; i > 0; i--) {\n    const j = Math.floor(rng() * (i + 1));\n    [arr[i], arr[j]] = [arr[j], arr[i]];\n  }\n  return arr;\n}\n\nfunction shuffleArray(arr: string[], rng: () => number): void {\n  for (let i = arr.length - 1; i > 0; i--) {\n    const j = Math.floor(rng() * (i + 1));\n    [arr[i], arr[j]] = [arr[j], arr[i]];\n  }\n}\n\n/**\n * Categorize gate output wires by their structural role in the adder.\n * Only swaps between certain categories are detectable by structural rules.\n *\n * Detectable cross-category pairs:\n *   z Рєћ {t, a, b, c}\n *   t Рєћ {a, b}\n *   finalZ Рєћ z\n *\n * NOT detectable: tРєћc, aРєћb, aРєћc, bРєћc, sameРєћsame\n */\nfunction categorizeWires(gates: Gate[], n: number) {\n  const finalZ = `z${String(n).padStart(2, '0')}`;\n  const z: string[] = [];  // output XOR Рєњ z (not z00, not finalZ)\n  const t: string[] = [];  // input XOR Рєњ partial sum (not bit0)\n  const a: string[] = [];  // input AND Рєњ generate (not bit0)\n  const b: string[] = [];  // non-input AND Рєњ propagate\n  const c: string[] = [];  // OR Рєњ carry\n\n  for (const gate of gates) {\n    const isBit0 =\n      (gate.in1 === 'x00' || gate.in1 === 'y00') &&\n      (gate.in2 === 'x00' || gate.in2 === 'y00');\n    if (isBit0) continue;\n    if (gate.out === finalZ) continue;\n\n    const hasXY =\n      gate.in1.startsWith('x') || gate.in1.startsWith('y') ||\n      gate.in2.startsWith('x') || gate.in2.startsWith('y');\n\n    if (gate.out.startsWith('z')) z.push(gate.out);\n    else if (gate.op === 'XOR' && hasXY) t.push(gate.out);\n    else if (gate.op === 'AND' && hasXY) a.push(gate.out);\n    else if (gate.op === 'AND') b.push(gate.out);\n    else if (gate.op === 'OR') c.push(gate.out);\n  }\n\n  return { z, t, a, b, c, finalZ };\n}\n\n/**\n * Pick 4 swap pairs guaranteed to be detectable by structural analysis.\n * Cycles through: zРєћa, zРєћb, tРєћa, tРєћb (all proven detectable).\n */\nfunction pickDetectableSwapPairs(\n  gates: Gate[],\n  n: number,\n  seed: number,\n): [string, string][] {\n  const rng = seededRandom(seed);\n  const cats = categorizeWires(gates, n);\n\n  // Shuffle each category\n  shuffleArray(cats.z, rng);\n  shuffleArray(cats.t, rng);\n  shuffleArray(cats.a, rng);\n  shuffleArray(cats.b, rng);\n  shuffleArray(cats.c, rng);\n\n  // Cross-category templates (all verified detectable)\n  const pairs: [string, string][] = [\n    [cats.z[0], cats.a[0]],   // z Рєћ generate\n    [cats.z[1], cats.b[0]],   // z Рєћ propagate\n    [cats.t[0], cats.a[1]],   // partial-sum Рєћ generate\n    [cats.t[1], cats.b[1]],   // partial-sum Рєћ propagate\n  ];\n\n  return pairs;\n}\n\n/** Build inputs for an N-bit adder with given X and Y values */\nfunction makeInputs(n: number, x: bigint, y: bigint): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < n; i++) {\n    const pad = String(i).padStart(2, '0');\n    inputs[`x${pad}`] = Number((x >> BigInt(i)) & 1n);\n    inputs[`y${pad}`] = Number((y >> BigInt(i)) & 1n);\n  }\n  return inputs;\n}\n\n/** Read z-wires from simulation output as a bigint */\nfunction readZ(wires: Record<string, number>, n: number): bigint {\n  let result = 0n;\n  for (let i = 0; i <= n; i++) {\n    const pad = String(i).padStart(2, '0');\n    const bit = wires[`z${pad}`];\n    if (bit) result |= BigInt(bit) << BigInt(i);\n  }\n  return result;\n}\n\n// РћђРћђРћђ Tests РћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђ\n\ndescribe('Group 1: Simulation', () => {\n  it('test 1: simulates a single AND gate', async () => {\n    const { simulate } = await discover();\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toMatchObject({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toMatchObject({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toMatchObject({ a: 0, b: 0, c: 0 });\n  });\n\n  it('test 2: simulates OR and XOR gates', async () => {\n    const { simulate } = await discover();\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'd' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.c).toBe(1);\n    expect(result.d).toBe(1);\n\n    const result2 = simulate(gates, { a: 1, b: 1 });\n    expect(result2.c).toBe(1);\n    expect(result2.d).toBe(0);\n  });\n\n  it('test 3: simulates a chain of dependent gates', async () => {\n    const { simulate } = await discover();\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 't', in2: 'c', out: 'out' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 't' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, c: 1 });\n    expect(result.t).toBe(1);\n    expect(result.out).toBe(0);\n  });\n\n  it('test 4: simulates a correct 4-bit adder (3 + 5 = 8)', async () => {\n    const { simulate } = await discover();\n    const gates = generateCorrectAdder(4, 100);\n    const inputs = makeInputs(4, 3n, 5n);\n    const result = simulate(gates, inputs);\n    expect(readZ(result, 4)).toBe(8n);\n  });\n\n  it('test 5: simulates a correct 8-bit adder (200 + 100 = 300)', async () => {\n    const { simulate } = await discover();\n    const gates = generateCorrectAdder(8, 200);\n    const inputs = makeInputs(8, 200n, 100n);\n    const result = simulate(gates, inputs);\n    expect(readZ(result, 8)).toBe(300n);\n  });\n});\n\ndescribe('Group 2: Small swap detection (8-12 bits)', () => {\n  it('test 6: finds swaps in 8-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(8, 301);\n    const pairs = pickDetectableSwapPairs(correct, 8, 401);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 501);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 7: finds swaps in 10-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(10, 302);\n    const pairs = pickDetectableSwapPairs(correct, 10, 402);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 502);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 8: finds swaps in 12-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(12, 303);\n    const pairs = pickDetectableSwapPairs(correct, 12, 403);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 503);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 9: cross-validates Рђћ fixing found swaps makes adder work', async () => {\n    const { simulate, findSwappedWires } = await discover();\n    const n = 10;\n    const correct = generateCorrectAdder(n, 304);\n    const pairs = pickDetectableSwapPairs(correct, n, 404);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 504);\n\n    // Broken circuit gives wrong answer\n    const inputs = makeInputs(n, 500n, 523n);\n    const brokenResult = simulate(shuffled, inputs);\n    const brokenZ = readZ(brokenResult, n);\n\n    // Find swaps\n    const found = findSwappedWires(shuffled);\n    expect(found.length).toBe(8);\n\n    // Fix: reverse the known swaps and verify circuit works\n    const swapMap = new Map<string, string>();\n    for (const [a, b] of pairs) {\n      swapMap.set(a, b);\n      swapMap.set(b, a);\n    }\n    const fixed = shuffled.map((g) => ({\n      ...g,\n      out: swapMap.get(g.out) ?? g.out,\n    }));\n\n    const fixedResult = simulate(fixed, inputs);\n    const fixedZ = readZ(fixedResult, n);\n    expect(fixedZ).toBe(1023n); // 500 + 523 = 1023\n    expect(brokenZ).not.toBe(1023n);\n  });\n});\n\ndescribe('Group 3: Medium swap detection (20-32 bits)', () => {\n  it('test 10: finds swaps in 20-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(20, 310);\n    const pairs = pickDetectableSwapPairs(correct, 20, 410);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 510);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 11: finds swaps in 24-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(24, 311);\n    const pairs = pickDetectableSwapPairs(correct, 24, 411);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 511);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 12: finds swaps in 28-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(28, 312);\n    const pairs = pickDetectableSwapPairs(correct, 28, 412);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 512);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 13: finds swaps in 32-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(32, 313);\n    const pairs = pickDetectableSwapPairs(correct, 32, 413);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 513);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n});\n\ndescribe('Group 4: Large swap detection (40-45 bits)', () => {\n  it('test 14: finds swaps in 40-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(40, 320);\n    const pairs = pickDetectableSwapPairs(correct, 40, 420);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 520);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 15: finds swaps in 44-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(44, 321);\n    const pairs = pickDetectableSwapPairs(correct, 44, 421);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 521);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 16: finds swaps in 45-bit adder', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(45, 322);\n    const pairs = pickDetectableSwapPairs(correct, 45, 422);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 522);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n});\n\ndescribe('Group 5: Edge cases', () => {\n  it('test 17: detects swap involving the final carry (z[N])', async () => {\n    const { findSwappedWires } = await discover();\n    const n = 16;\n    const correct = generateCorrectAdder(n, 330);\n    const cats = categorizeWires(correct, n);\n    const rng = seededRandom(430);\n\n    shuffleArray(cats.z, rng);\n    shuffleArray(cats.a, rng);\n    shuffleArray(cats.b, rng);\n\n    // finalZ Рєћ regular z is detectable (ORРєћXOR both violate rule 1)\n    // Remaining 3 pairs use standard detectable combos\n    const pairs: [string, string][] = [\n      [cats.finalZ, cats.z[0]],    // final carry Рєћ z-output\n      [cats.z[1], cats.a[0]],      // z Рєћ generate\n      [cats.z[2], cats.b[0]],      // z Рєћ propagate\n      [cats.a[1], cats.b[1]],      // generate Рєћ propagate Рђћ wait, NOT detectable!\n    ];\n\n    // Fix: use tРєћa instead of aРєћb\n    shuffleArray(cats.t, rng);\n    pairs[3] = [cats.t[0], cats.a[2]];  // partial-sum Рєћ generate\n\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 530);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 18: detects swaps using zРєћcarry cross-category', async () => {\n    const { findSwappedWires } = await discover();\n    const n = 16;\n    const correct = generateCorrectAdder(n, 331);\n    const cats = categorizeWires(correct, n);\n    const rng = seededRandom(431);\n\n    shuffleArray(cats.z, rng);\n    shuffleArray(cats.t, rng);\n    shuffleArray(cats.a, rng);\n    shuffleArray(cats.b, rng);\n    shuffleArray(cats.c, rng);\n\n    // zРєћc is detectable (non-input XORРєњnon-z = rule2, ORРєњz = rule1)\n    const pairs: [string, string][] = [\n      [cats.z[0], cats.c[0]],     // z Рєћ carry\n      [cats.z[1], cats.a[0]],     // z Рєћ generate\n      [cats.t[0], cats.b[0]],     // partial-sum Рєћ propagate\n      [cats.t[1], cats.a[1]],     // partial-sum Рєћ generate\n    ];\n\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 531);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n\n  it('test 19: detects z-wire swapped with non-input AND wire', async () => {\n    const { findSwappedWires } = await discover();\n    const n = 20;\n    const correct = generateCorrectAdder(n, 332);\n    const cats = categorizeWires(correct, n);\n    const rng = seededRandom(432);\n\n    shuffleArray(cats.z, rng);\n    shuffleArray(cats.t, rng);\n    shuffleArray(cats.a, rng);\n    shuffleArray(cats.b, rng);\n\n    // All zРєћpropagate swaps\n    const pairs: [string, string][] = [\n      [cats.z[0], cats.b[0]],     // z Рєћ propagate\n      [cats.z[1], cats.b[1]],     // z Рєћ propagate\n      [cats.t[0], cats.a[0]],     // partial-sum Рєћ generate\n      [cats.t[1], cats.a[1]],     // partial-sum Рєћ generate\n    ];\n\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 532);\n\n    const expected = pairs.flat().sort();\n    const result = findSwappedWires(shuffled);\n    expect(result).toEqual(expected);\n  });\n});\n\ndescribe('Group 6: Performance', () => {\n  it('test 20: solves a 45-bit adder in under 5 seconds', async () => {\n    const { findSwappedWires } = await discover();\n    const correct = generateCorrectAdder(45, 340);\n    const pairs = pickDetectableSwapPairs(correct, 45, 440);\n    const broken = applySwaps(correct, pairs);\n    const shuffled = shuffleGates(broken, 540);\n\n    const start = performance.now();\n    const result = findSwappedWires(shuffled);\n    const elapsed = performance.now() - start;\n\n    const expected = pairs.flat().sort();\n    expect(result).toEqual(expected);\n    expect(elapsed).toBeLessThan(5000);\n  });\n});","is_error":false}]},"parent_tool_use_id":"toolu_01PqRarNtYieFP42NRhu2BDy","session_id":"4d65e4a5-2507-4e36-a74a-701aca7d06c3","uuid":"64459329-d0ad-44f2-bcad-fdab85654a61"}
