+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CXE6sCUAwU1TLRinJvjwkt","type":"tool_result","content":"/**\n * Discovery layer for the circuit debugger implementation.\n *\n * Dynamically imports from ../src/ and tries to find simulate and\n * findSwappedWires functions regardless of how the implementor exported them.\n */\n\nexport interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport interface CircuitAPI {\n  simulate: (gates: Gate[], inputs: Record<string, number>) => Record<string, number>;\n  findSwappedWires: (gates: Gate[]) => string[];\n}\n\nconst SIMULATE_ALIASES = ['simulate', 'evaluate', 'run', 'runCircuit', 'exec', 'execute', 'process', 'compute'];\nconst FIND_SWAPS_ALIASES = [\n  'findSwappedWires', 'findSwaps', 'detectSwaps', 'diagnose',\n  'findSwapped', 'detectSwappedWires', 'findBrokenWires', 'solve',\n  'debug', 'debugCircuit', 'repair', 'analyze',\n];\n\nfunction findFunction(obj: any, aliases: string[]): ((...args: any[]) => any) | null {\n  for (const name of aliases) {\n    if (typeof obj[name] === 'function') return obj[name].bind(obj);\n  }\n  return null;\n}\n\nasync function tryImport(): Promise<any> {\n  const paths = [\n    '../src/index.js',\n    '../src/circuit.js',\n    '../src/solver.js',\n    '../src/debugger.js',\n    '../src/index.ts',\n    '../src/circuit.ts',\n    '../src/solver.ts',\n    '../src/debugger.ts',\n  ];\n  for (const p of paths) {\n    try {\n      return await import(p);\n    } catch {\n      // try next\n    }\n  }\n  throw new Error('Could not import circuit debugger from any of: ' + paths.join(', '));\n}\n\nfunction extractFromObject(obj: any): { sim: Function | null; swaps: Function | null } {\n  return {\n    sim: findFunction(obj, SIMULATE_ALIASES),\n    swaps: findFunction(obj, FIND_SWAPS_ALIASES),\n  };\n}\n\nexport async function discover(): Promise<CircuitAPI> {\n  const mod = await tryImport();\n\n  // 1. Direct named exports\n  let { sim, swaps } = extractFromObject(mod);\n  if (sim && swaps) return { simulate: sim as any, findSwappedWires: swaps as any };\n\n  // 2. Class exports: CircuitDebugger, Circuit, Solver\n  const classNames = [\n    'CircuitDebugger', 'Circuit', 'Solver', 'CircuitSolver',\n    'Debugger', 'WireDebugger', 'AdderDebugger',\n  ];\n  for (const name of classNames) {\n    if (mod[name] && typeof mod[name] === 'function') {\n      try {\n        const instance = new mod[name]();\n        const result = extractFromObject(instance);\n        if (result.sim && result.swaps) {\n          return { simulate: result.sim as any, findSwappedWires: result.swaps as any };\n        }\n      } catch {\n        // try next\n      }\n    }\n  }\n\n  // 3. Factory functions\n  const factoryNames = [\n    'createSolver', 'createDebugger', 'create', 'createCircuit',\n    'createCircuitDebugger', 'makeDebugger', 'makeSolver',\n  ];\n  for (const name of factoryNames) {\n    if (typeof mod[name] === 'function') {\n      try {\n        const instance = mod[name]();\n        const result = extractFromObject(instance);\n        if (result.sim && result.swaps) {\n          return { simulate: result.sim as any, findSwappedWires: result.swaps as any };\n        }\n      } catch {\n        // try next\n      }\n    }\n  }\n\n  // 4. Default export\n  const def = mod.default;\n  if (def) {\n    if (typeof def === 'function') {\n      // Could be a class\n      try {\n        const instance = new def();\n        const result = extractFromObject(instance);\n        if (result.sim && result.swaps) {\n          return { simulate: result.sim as any, findSwappedWires: result.swaps as any };\n        }\n      } catch {\n        // Not a class, try as factory\n        try {\n          const instance = def();\n          const result = extractFromObject(instance);\n          if (result.sim && result.swaps) {\n            return { simulate: result.sim as any, findSwappedWires: result.swaps as any };\n          }\n        } catch {\n          // skip\n        }\n      }\n    } else if (typeof def === 'object') {\n      const result = extractFromObject(def);\n      if (result.sim && result.swaps) {\n        return { simulate: result.sim as any, findSwappedWires: result.swaps as any };\n      }\n    }\n  }\n\n  // 5. Partial: maybe simulate is named export but swaps is on a class\n  if (!sim) sim = findFunction(mod, SIMULATE_ALIASES);\n  if (!swaps) swaps = findFunction(mod, FIND_SWAPS_ALIASES);\n\n  // Try finding missing ones from any exported object\n  for (const key of Object.keys(mod)) {\n    const val = mod[key];\n    if (val && typeof val === 'object') {\n      if (!sim) sim = findFunction(val, SIMULATE_ALIASES);\n      if (!swaps) swaps = findFunction(val, FIND_SWAPS_ALIASES);\n    }\n  }\n\n  if (!sim) throw new Error('Could not find simulate function. Tried: ' + SIMULATE_ALIASES.join(', '));\n  if (!swaps) throw new Error('Could not find findSwappedWires function. Tried: ' + FIND_SWAPS_ALIASES.join(', '));\n\n  return { simulate: sim as any, findSwappedWires: swaps as any };\n}","is_error":false}]},"parent_tool_use_id":"toolu_01PqRarNtYieFP42NRhu2BDy","session_id":"4d65e4a5-2507-4e36-a74a-701aca7d06c3","uuid":"70fe8477-0f7c-4061-8828-24475ba3150b"}
