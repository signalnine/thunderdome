+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([
+      'gen02', 'gen04', 'prop07', 'tmp04', 'tmp05', 'z02', 'z05', 'z08',
+    ].sort());
+  });
+
+  it('handles a 45-bit adder within time limit', () => {
+    const gates = buildCorrectAdder(45);
+    swapOutputs(gates, 'z10', 'gen10');     // z <-> a
+    swapOutputs(gates, 'z20', 'tmp20');     // z <-> t
+    swapOutputs(gates, 'prop30', 'z30');    // b <-> z
+    swapOutputs(gates, 'tmp41', 'prop41');  // t <-> b
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toEqual([
+      'gen10', 'prop30', 'prop41', 'tmp20', 'tmp41', 'z10', 'z20', 'z30',
+    ].sort());
+  });
+
+  it('returns a sorted array of wire names', () => {
+    const gates = buildCorrectAdder(4);
+    swapOutputs(gates, 'z01', 'gen01');     // z <-> a
+    swapOutputs(gates, 'z03', 'prop03');    // z <-> b
+    swapOutputs(gates, 'z00', 'tmp01');     // z <-> t
+    swapOutputs(gates, 'tmp02', 'gen02');   // t <-> a
+
+    const result = findSwappedWires(gates);
+    const sorted = [...result].sort();
+    expect(result).toEqual(sorted);
+  });
+});
