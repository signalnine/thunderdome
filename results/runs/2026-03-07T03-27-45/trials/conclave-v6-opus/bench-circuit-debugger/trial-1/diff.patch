@@ -0,0 +1,524 @@
+import { describe, it, expect } from 'vitest';
+import { discover, type Gate } from './_discovery.js';
+
+// РћђРћђРћђ Seeded PRNG (xorshift32) РћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђ
+
+function seededRandom(seed: number): () => number {
+  let state = seed | 0 || 1;
+  return () => {
+    state ^= state << 13;
+    state ^= state >> 17;
+    state ^= state << 5;
+    return (state >>> 0) / 0x100000000;
+  };
+}
+
+// РћђРћђРћђ Circuit Generator РћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђ
+
+function randomWireName(rng: () => number, usedNames: Set<string>): string {
+  const chars = 'abcdefghijklmnopqrstuvw';
+  let name: string;
+  do {
+    name = '';
+    for (let i = 0; i < 3; i++) {
+      name += chars[Math.floor(rng() * chars.length)];
+    }
+  } while (usedNames.has(name));
+  usedNames.add(name);
+  return name;
+}
+
+function generateCorrectAdder(n: number, seed: number): Gate[] {
+  const rng = seededRandom(seed);
+  const gates: Gate[] = [];
+  const usedNames = new Set<string>();
+
+  // Reserve x/y/z names
+  for (let i = 0; i < n; i++) {
+    const pad = String(i).padStart(2, '0');
+    usedNames.add(`x${pad}`);
+    usedNames.add(`y${pad}`);
+    usedNames.add(`z${pad}`);
+  }
+  usedNames.add(`z${String(n).padStart(2, '0')}`);
+
+  // Bit 0: half adder
+  const x0 = 'x00', y0 = 'y00', z0 = 'z00';
+  const c0 = randomWireName(rng, usedNames);
+  gates.push({ op: 'XOR', in1: x0, in2: y0, out: z0 });
+  gates.push({ op: 'AND', in1: x0, in2: y0, out: c0 });
+
+  let carry = c0;
+
+  // Bits 1..n-1: full adders
+  for (let i = 1; i < n; i++) {
+    const pad = String(i).padStart(2, '0');
+    const xi = `x${pad}`, yi = `y${pad}`, zi = `z${pad}`;
+    const t = randomWireName(rng, usedNames);
+    const a = randomWireName(rng, usedNames);
+    const b = randomWireName(rng, usedNames);
+    const c = randomWireName(rng, usedNames);
+
+    gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });
+    gates.push({ op: 'XOR', in1: t, in2: carry, out: zi });
+    gates.push({ op: 'AND', in1: xi, in2: yi, out: a });
+    gates.push({ op: 'AND', in1: t, in2: carry, out: b });
+    gates.push({ op: 'OR', in1: a, in2: b, out: c });
+
+    carry = c;
+  }
+
+  // Final carry Рєњ z[n]
+  const finalZ = `z${String(n).padStart(2, '0')}`;
+  for (const gate of gates) {
+    if (gate.out === carry) gate.out = finalZ;
+    if (gate.in1 === carry) gate.in1 = finalZ;
+    if (gate.in2 === carry) gate.in2 = finalZ;
+  }
+
+  return gates;
+}
+
+function applySwaps(gates: Gate[], pairs: [string, string][]): Gate[] {
+  const swapMap = new Map<string, string>();
+  for (const [a, b] of pairs) {
+    swapMap.set(a, b);
+    swapMap.set(b, a);
+  }
+  return gates.map((g) => ({
+    ...g,
+    out: swapMap.get(g.out) ?? g.out,
+  }));
+}
+
+function shuffleGates(gates: Gate[], seed: number): Gate[] {
+  const rng = seededRandom(seed);
+  const arr = [...gates];
+  for (let i = arr.length - 1; i > 0; i--) {
+    const j = Math.floor(rng() * (i + 1));
+    [arr[i], arr[j]] = [arr[j], arr[i]];
+  }
+  return arr;
+}
+
+function shuffleArray(arr: string[], rng: () => number): void {
+  for (let i = arr.length - 1; i > 0; i--) {
+    const j = Math.floor(rng() * (i + 1));
+    [arr[i], arr[j]] = [arr[j], arr[i]];
+  }
+}
+
+/**
+ * Categorize gate output wires by their structural role in the adder.
+ * Only swaps between certain categories are detectable by structural rules.
+ *
+ * Detectable cross-category pairs:
+ *   z Рєћ {t, a, b, c}
+ *   t Рєћ {a, b}
+ *   finalZ Рєћ z
+ *
+ * NOT detectable: tРєћc, aРєћb, aРєћc, bРєћc, sameРєћsame
+ */
+function categorizeWires(gates: Gate[], n: number) {
+  const finalZ = `z${String(n).padStart(2, '0')}`;
+  const z: string[] = [];  // output XOR Рєњ z (not z00, not finalZ)
+  const t: string[] = [];  // input XOR Рєњ partial sum (not bit0)
+  const a: string[] = [];  // input AND Рєњ generate (not bit0)
+  const b: string[] = [];  // non-input AND Рєњ propagate
+  const c: string[] = [];  // OR Рєњ carry
+
+  for (const gate of gates) {
+    const isBit0 =
+      (gate.in1 === 'x00' || gate.in1 === 'y00') &&
+      (gate.in2 === 'x00' || gate.in2 === 'y00');
+    if (isBit0) continue;
+    if (gate.out === finalZ) continue;
+
+    const hasXY =
+      gate.in1.startsWith('x') || gate.in1.startsWith('y') ||
+      gate.in2.startsWith('x') || gate.in2.startsWith('y');
+
+    if (gate.out.startsWith('z')) z.push(gate.out);
+    else if (gate.op === 'XOR' && hasXY) t.push(gate.out);
+    else if (gate.op === 'AND' && hasXY) a.push(gate.out);
+    else if (gate.op === 'AND') b.push(gate.out);
+    else if (gate.op === 'OR') c.push(gate.out);
+  }
+
+  return { z, t, a, b, c, finalZ };
+}
+
+/**
+ * Pick 4 swap pairs guaranteed to be detectable by structural analysis.
+ * Cycles through: zРєћa, zРєћb, tРєћa, tРєћb (all proven detectable).
+ */
+function pickDetectableSwapPairs(
+  gates: Gate[],
+  n: number,
+  seed: number,
+): [string, string][] {
+  const rng = seededRandom(seed);
+  const cats = categorizeWires(gates, n);
+
+  // Shuffle each category
+  shuffleArray(cats.z, rng);
+  shuffleArray(cats.t, rng);
+  shuffleArray(cats.a, rng);
+  shuffleArray(cats.b, rng);
+  shuffleArray(cats.c, rng);
+
+  // Cross-category templates (all verified detectable)
+  const pairs: [string, string][] = [
+    [cats.z[0], cats.a[0]],   // z Рєћ generate
+    [cats.z[1], cats.b[0]],   // z Рєћ propagate
+    [cats.t[0], cats.a[1]],   // partial-sum Рєћ generate
+    [cats.t[1], cats.b[1]],   // partial-sum Рєћ propagate
+  ];
+
+  return pairs;
+}
+
+/** Build inputs for an N-bit adder with given X and Y values */
+function makeInputs(n: number, x: bigint, y: bigint): Record<string, number> {
+  const inputs: Record<string, number> = {};
+  for (let i = 0; i < n; i++) {
+    const pad = String(i).padStart(2, '0');
+    inputs[`x${pad}`] = Number((x >> BigInt(i)) & 1n);
+    inputs[`y${pad}`] = Number((y >> BigInt(i)) & 1n);
+  }
+  return inputs;
+}
+
+/** Read z-wires from simulation output as a bigint */
+function readZ(wires: Record<string, number>, n: number): bigint {
+  let result = 0n;
+  for (let i = 0; i <= n; i++) {
+    const pad = String(i).padStart(2, '0');
+    const bit = wires[`z${pad}`];
+    if (bit) result |= BigInt(bit) << BigInt(i);
+  }
+  return result;
