' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toMatchObject({ c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toMatchObject({ c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toMatchObject({ c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toMatchObject({ c: 0 });\n  });\n\n  it('handles gates in dependency order', () => {\n    // a XOR b -> t, t AND c -> out\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'a', in2: 'b', out: 't' },\n      { op: 'AND', in1: 't', in2: 'c', out: 'out' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, c: 1 });\n    expect(result).toMatchObject({ t: 1, out: 1 });\n  });\n\n  it('handles gates listed out of dependency order', () => {\n    // Gates listed with dependency second, but should still resolve\n    const gates: Gate[] = [\n      { op: 'AND', in1: 't', in2: 'c', out: 'out' },\n      { op: 'XOR', in1: 'a', in2: 'b', out: 't' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, c: 1 });\n    expect(result).toMatchObject({ t: 1, out: 1 });\n  });\n\n  it('simulates a 2-bit adder correctly', () => {\n    // 2-bit adder: x=3 (11), y=1 (01) => z=4 (100)\n    const gates: Gate[] = [\n      // Bit 0: half adder\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1: full adder\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    // x=3 (x00=1, x01=1), y=1 (y00=1, y01=0)\n    // Expected: z=4 (z00=0, z01=0, z02=1)\n    const result = simulate(gates, {\n      x00: 1, x01: 1,\n      y00: 1, y01: 0,\n    });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(1);\n  });\n});\n\nfunction pad(n: number): string {\n  return n.toString().padStart(2, '0');\n}\n\nfunction buildCorrectAdder(bits: number): Gate[] {\n  const gates: Gate[] = [];\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'carry00' });\n\n  for (let i = 1; i < bits; i++) {\n    const idx = pad(i);\n    const prevCarry = 'carry' + pad(i - 1);\n    gates.push({ op: 'XOR', in1: `x${idx}`, in2: `y${idx}`, out: `tmp${idx}` });\n    gates.push({ op: 'XOR', in1: `tmp${idx}`, in2: prevCarry, out: `z${idx}` });\n    gates.push({ op: 'AND', in1: `x${idx}`, in2: `y${idx}`, out: `gen${idx}` });\n    gates.push({ op: 'AND', in1: `tmp${idx}`, in2: prevCarry, out: `prop${idx}` });\n    gates.push({ op: 'OR', in1: `gen${idx}`, in2: `prop${idx}`, out: `carry${idx}` });\n  }\n\n  // Final carry becomes MSB output Рђћ find the carry gate and rename its output\n  const lastCarryName = 'carry' + pad(bits - 1);\n  const lastCarryGate = gates.find(g => g.out === lastCarryName)!;\n  lastCarryGate.out = 'z' + pad(bits);\n\n  return gates;\n}\n\nfunction swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n  const g1 = gates.find(g => g.out === wire1)!;\n  const g2 = gates.find(g => g.out === wire2)!;\n  g1.out = wire2;\n  g2.out = wire1;\n}\n\ndescribe('findSwappedWires', () => {\n  it('detects swapped wires in a small adder', () => {\n    const gates = buildCorrectAdder(4);\n    // Swap z01 with gen01 (z <-> a: detectable)\n    swapOutputs(gates, 'z01', 'gen01');\n    // Swap prop02 with z03 (b <-> z: detectable)\n    swapOutputs(gates, 'prop02', 'z03');\n    // Swap tmp02 with gen02 (t <-> a: detectable)\n    swapOutputs(gates, 'tmp02', 'gen02');\n    // Swap z00 with tmp01 (z <-> t: detectable)\n    swapOutputs(gates, 'z00', 'tmp01');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([\n      'gen01', 'gen02', 'prop02', 'tmp01', 'tmp02', 'z00', 'z01', 'z03',\n    ].sort());\n  });\n\n  it('detects swapped wires in a larger adder (10 bits)', () => {\n    const gates = buildCorrectAdder(10);\n    // 4 swaps (all detectable cross-category)\n    swapOutputs(gates, 'z02', 'gen02');     // z <-> a\n    swapOutputs(gates, 'z05', 'tmp05');     // z <-> t\n    swapOutputs(gates, 'prop07', 'z08');    // b <-> z\n    swapOutputs(gates, 'tmp04', 'gen04');   // t <-> a\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([\n      'gen02', 'gen04', 'prop07', 'tmp04', 'tmp05', 'z02', 'z05', 'z08',\n    ].sort());\n  });\n\n  it('handles a 45-bit adder within time limit', () => {\n    const gates = buildCorrectAdder(45);\n    swapOutputs(gates, 'z10', 'gen10');     // z <-> a\n    swapOutputs(gates, 'z20', 'tmp20');     // z <-> t\n    swapOutputs(gates, 'prop30', 'z30');    // b <-> z\n    swapOutputs(gates, 'tmp41', 'prop41');  // t <-> b\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual([\n      'gen10', 'prop30', 'prop41', 'tmp20', 'tmp41', 'z10', 'z20', 'z30',\n    ].sort());\n  });\n\n  it('returns a sorted array of wire names', () => {\n    const gates = buildCorrectAdder(4);\n    swapOutputs(gates, 'z01', 'gen01');     // z <-> a\n    swapOutputs(gates, 'z03', 'prop03');    // z <-> b\n    swapOutputs(gates, 'z00', 'tmp01');     // z <-> t\n    swapOutputs(gates, 'tmp02', 'gen02');   // t <-> a\n\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n});\n","numLines":176,"startLine":1,"totalLines":176}}}
