ets/doc.pdf\"');\n    49→    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n    50→  });\n    51→\n    52→  it('leaves absolute URLs unchanged', async () => {\n    53→    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    54→    const ctx = makeCtx();\n    55→    const result = await plugin.hooks.transformContent!(file, ctx);\n    56→    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n    57→  });\n    58→\n    59→  it('generates asset manifest in ctx.data', async () => {\n    60→    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    61→    const ctx = makeCtx();\n    62→    await plugin.hooks.transformContent!(file, ctx);\n    63→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    64→    expect(manifest).toBeDefined();\n    65→    expect(manifest.assets).toContain('photo.jpg');\n    66→  });\n    67→\n    68→  it('handles files with no asset references', async () => {\n    69→    const file = makeFile({ content: '<p>No assets here</p>' });\n    70→    const ctx = makeCtx();\n    71→    const result = await plugin.hooks.transformContent!(file, ctx);\n    72→    expect(result.content).toBe('<p>No assets here</p>');\n    73→  });\n    74→\n    75→  it('handles multiple assets in one file', async () => {\n    76→    const file = makeFile({\n    77→      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    78→    });\n    79→    const ctx = makeCtx();\n    80→    await plugin.hooks.transformContent!(file, ctx);\n    81→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    82→    expect(manifest.assets).toContain('a.png');\n    83→    expect(manifest.assets).toContain('b.jpg');\n    84→    expect(manifest.assets).toContain('c.pdf');\n    85→  });\n    86→\n    87→  it('asset manifest includes all discovered assets', async () => {\n    88→    const ctx = makeCtx();\n    89→   