+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Sqi2YHHioaqxRraFbZ4ZT","type":"tool_result","content":"     1→export interface SiteConfig {\n     2→  title: string;\n     3→  baseUrl: string;\n     4→  outputDir: string;\n     5→  contentDir: string;\n     6→  templateDir: string;\n     7→}\n     8→\n     9→export interface ContentFile {\n    10→  slug: string;\n    11→  title: string;\n    12→  content: string;        // raw content (markdown or html)\n    13→  metadata: Record<string, unknown>;\n    14→  date?: string;\n    15→  tags?: string[];\n    16→  template?: string;\n    17→}\n    18→\n    19→export interface BuildContext {\n    20→  config: SiteConfig;\n    21→  files: ContentFile[];\n    22→  output: Map<string, string>;  // output path -> rendered content\n    23→  assets: Map<string, Buffer>;  // output path -> binary data\n    24→  data: Map<string, unknown>;   // shared plugin data store\n    25→}\n    26→\n    27→export interface PluginHooks {\n    28→  beforeBuild?: (ctx: BuildContext) => Promise<void> | void;\n    29→  transformContent?: (file: ContentFile, ctx: BuildContext) => Promise<ContentFile> | ContentFile;\n    30→  afterBuild?: (ctx: BuildContext) => Promise<void> | void;\n    31→}\n    32→\n    33→export interface Plugin {\n    34→  name: string;\n    35→  version: string;\n    36→  dependencies: string[];  // names of plugins this depends on\n    37→  hooks: PluginHooks;\n    38→}\n    39→\n    40→export interface Template {\n    41→  name: string;\n    42→  render: (content: string, data: Record<string, unknown>) => string;\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_01JnscGhY59oJF8DhBgE4AtX","session_id":"a2e1c65c-b858-4fc9-9632-74bb2bca2dd6","uuid":"a87a4c0b-373a-4736-9bf1-bf4cceb30d72"}
