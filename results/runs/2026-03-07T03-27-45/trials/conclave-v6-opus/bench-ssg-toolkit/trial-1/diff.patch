ipeline', 'search-index'],\n+    hooks: {\n+      afterBuild(ctx: BuildContext): void {\n+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n+        const assetPaths = manifest ? manifest.assets : [];\n+\n+        const routes: Array<{ path: string; handler: string }> = [];\n+\n+        // Add asset routes\n+        for (const asset of assetPaths) {\n+          routes.push({ path: `/assets/${asset}`, handler: 'asset' });\n+        }\n+\n+        // Add content routes for HTML outputs\n+        for (const key of ctx.output.keys()) {\n+          if (key.endsWith('.html')) {\n+            routes.push({ path: `/${key}`, handler: 'static' });\n+          }\n+        }\n+\n+        const config: DevServerConfig = {\n+          port: 3000,\n+          routes,\n+          assetPaths,\n+          searchIndexPath: '/search-index.json',\n+        };\n+\n+        ctx.data.set('dev-server-config', config);\n+      },\n+    },\n+  };\n+}\ndiff --git a/src/plugins/markdown-ext.ts b/src/plugins/markdown-ext.ts\nnew file mode 100644\nindex 0000000..9118b76\n--- /dev/null\n+++ b/src/plugins/markdown-ext.ts\n@@ -0,0 +1,118 @@\n+import { Plugin, ContentFile, BuildContext } from '../core/types.js';\n+\n+function processFootnotes(content: string): string {\n+  // Collect footnote definitions: [^N]: text\n+  const footnoteDefRegex = /^\\[\\^(\\d+)\\]:\\s*(.+)$/gm;\n+  const footnotes: Map<string, string> = new Map();\n+  let match: RegExpExecArray | null;\n+\n+  while ((match = footnoteDefRegex.exec(content)) !== null) {\n+    footnotes.set(match[1], match[2]);\n+  }\n+\n+  if (footnotes.size === 0) return content;\n+\n+  // Remove footnote definitions from content\n+  let result = content.replace(/^\\[\\^(\\d+)\\]:\\s*(.+)$/gm, '').trim();\n+\n+  // Replace footnote references [^N] with superscript links\n+  result = result.replace(/\\[\\^(\\d+)\\]/g, (_m, num) => {\n+    return `<sup><a href=\"#fn-${num}\">${num}</a></sup>`;\n+  });\n+\n+  // Add footnotes section at bottom\n+  const items = Array.from(footnotes.entries())\n+    .map(([num, text]) => `<li id=\"fn-${num}\">${text}</li>`)\n+    .join('\\n');\n+\n+  result += `\\n<section class=\"footnotes\">\\n<ol>\\n${items}\\n</ol>\\n</section>`;\n+\n+  return result;\n+}\n+\n+function processAdmonitions(content: string): string {\n+  return content.replace(\n+    /:::(\\w+)\\n([\\s\\S]*?):::/g,\n+    (_m, type, body) => `<div class=\"admonition admonition-${type}\">\\n${body.trim()}\\n</div>`\n+  );\n+}\n+\n+function markdownToHtml(content: string): string {\n+  // Process headings\n+  let html = content.replace(/^### (.+)$/gm, '<h3>$1</h3>');\n+  html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');\n+  html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');\n+\n+  // Process bold\n+  html = html.replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n+\n+  // Process italic\n+  html = html.replace(/\\*(.+?)\\*/g, '<em>$1</em>');\n+\n+  // Process paragraphs: wrap non-tag lines separated by blank lines\n+  const lines = html.split('\\n');\n+  const result: string[] = [];\n+  let currentParagraph: string[] = [];\n+\n+  const flushParagraph = () => {\n+    if (currentParagraph.length > 0) {\n+      const text = currentParagraph.join(' ').trim();\n+      if (text) {\n+        // Don't wrap if it already starts with an HTML block element\n+        if (/^<(h[1-6]|div|section|ol|ul|li|pre|blockquote|table|hr|p)[>\\s]/.test(text)) {\n+          result.push(text);\n+        } else {\n+          result.push(`<p>${text}</p>`);\n+        }\n+      }\n+      currentParagraph = [];\n+    }\n+  };\n+\n+  for (const line of lines) {\n+    if (line.trim() === '') {\n+      flushParagraph();\n+    } else {\n+      currentParagraph.push(line);\n+    }\n+  }\n+  flushParagraph();\n+\n+  return result.join('\\n');\n+}\n+\n+export function createMarkdownExtPlugin(): Plugin {\n+  return {\n+    name: 'markdown-ext',\n+    version: '1.0.0',\n+    dependencies: [],\n+    hooks: {\n+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {\n+        let content = file.content;\n+\n+        if (!content) {\n+          return { ...file, content: '' };\n+        }\n+\n+        // If content already contains HTML block elements, preserve it\n+        if (/^<[a-z][\\s\\S]*>/i.test(content.trim())) {\n+          // Process admonitions and footnotes even in HTML\n+          content = processAdmonitions(content);\n+          content = processFootnotes(content);\n+          return { ...file, content };\n+        }\n+\n+        // Process admonitions before markdown conversion\n+        content = processAdmonitions(content);\n+\n+        // Process footnotes before markdown conversion\n+        content = processFootnotes(content);\n+\n+        // Convert markdown to HTML\n+        content = markdownToHtml(content);\n+\n+        return { ...file, content };\n+      },\n+    },\n+  };\n+}\ndiff --git a/src/plugins/rss-feed.ts b/src/plugins/rss-feed.ts\nnew file mode 100644\nindex 0000000..0842d36\n--- /dev/null\n+++ b/src/plugins/rss-feed.ts\n@@ -0,0 +1,68 @@\n+import { Plugin, BuildContext, ContentFile } from '../core/types.js';\n+\n+function escapeXml(str: string): string {\n+  return str\n+    .replace(/&/g, '&amp;')\n+    .replace(/</g, '&lt;')\n+    .replace(/>/g, '&gt;')\n+    .replace(/\"/g, '&quot;')\n+    .replace(/'/g, '&apos;');\n+}\n+\n+export function createRssFeedPlugin(): Plugin {\n+  return {\n+    name: 'rss-feed',\n+    version: '1.0.0',\n+    dependencies: ['markdown-ext', 'taxonomy'],\n+    hooks: {\n+      afterBuild(ctx: BuildContext): void {\n+        const { config, files } = ctx;\n+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;\n+\n+        // Sort files by date, newest first. Files without dates go last.\n+        const sorted = [...files].sort((a, b) => {\n+          if (!a.date && !b.date) return 0;\n+          if (!a.date) return 1;\n+          if (!b.date) return -1;\n+          return new Date(b.date).getTime() - new Date(a.date).getTime();\n+        });\n+\n+        const items = sorted.map(file => {\n+          // Find tags for this file\n+          const fileTags: string[] = [];\n+          if (tagMap) {\n+            for (const [tag, tagFiles] of tagMap) {\n+              if (tagFiles.some(f => f.slug === file.slug)) {\n+                fileTags.push(tag);\n+              }\n+            }\n+          }\n+\n+          const categoryTags = fileTags\n+            .map(t => `      <category>${escapeXml(t)}</category>`)\n+            .join('\\n');\n+\n+          const pubDate = file.date ? `      <pubDate>${file.date}</pubDate>\\n` : '';\n+\n+          return `    <item>\n+      <title>${escapeXml(file.title)}</title>\n+      <link>${config.baseUrl}/${file.slug}.html</link>\n+${pubDate}      <description><![CDATA[${file.content}]]></description>\n+${categoryTags ? categoryTags + '\\n' : ''}    </item>`;\n+        }).join('\\n');\n+\n+        const feed = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n+<rss version=\"2.0\">\n+  <channel>\n+    <title>${escapeXml(config.title)}</title>\n+    <link>${config.baseUrl}</link>\n+    <description>${escapeXml(config.title)}</description>\n+${items}\n+  </channel>\n+</rss>`;\n+\n+        ctx.output.set('feed.xml', feed);\n+      },\n+    },\n+  };\n+}\ndiff --git a/src/plugins/search-index.ts b/src/plugins/search-index.ts\nnew file mode 100644\nindex 0000000..1f47a95\n--- /dev/null\n+++ b/src/plugins/search-index.ts\n@@ -0,0 +1,32 @@\n+import { Plugin, BuildContext } from '../core/types.js';\n+\n+function stripHtml(html: string): string {\n+  return html.replace(/<[^>]+>/g, '').trim();\n+}\n+\n+export function createSearchIndexPlugin(): Plugin {\n+  return {\n+    name: 'search-index',\n+    version: '1.0.0',\n+    dependencies: ['markdown-ext', 'syntax-highlight'],\n+    hooks: {\n+      afterBuild(ctx: BuildContext): void {\n+        const index = ctx.files.map(file => {\n+          const entry: Record<string, unknown> = {\n+            slug: file.slug,\n+            title: file.title,\n+            content: stripHtml(file.content),\n+          };\n+\n+          if (file.tags) {\n+            entry.tags = file.tags;\n+          }\n+\n+          return entry;\n+        });\n+\n+        ctx.output.set('search-index.json', JSON.stringify(index));\n+      },\n+    },\n+  };\n+}\ndiff --git a/src/plugins/sitemap.ts b/src/plugins/sitemap.ts\nnew file mode 100644\nindex 0000000..029efd4\n--- /dev/null\n+++ b/src/plugins/sitemap.ts\n@@ -0,0 +1,32 @@\n+import { Plugin, BuildContext } from '../core/types.js';\n+\n+export function createSitemapPlugin(): Plugin {\n+  return {\n+    name: 'sitemap',\n+    version: '1.0.0',\n+    dependencies: ['taxonomy', 'rss-feed'],\n+    hooks: {\n+      afterBuild(ctx: BuildContext): void {\n+        const { config, output } = ctx;\n+        const urls: string[] = [];\n+\n+        // Collect all output paths (excluding sitemap.xml itself)\n+        for (const key of output.keys()) {\n+          if (key === 'sitemap.xml') continue;\n+          urls.push(`${config.baseUrl}/${key}`);\n+        }\n+\n+        const urlEntries = urls\n+          .map(url => `  <url>\\n    <loc>${url}</loc>\\n  </url>`)\n+          .join('\\n');\n+\n+        const sitemap = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n+<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n+${urlEntries}\n+</urlset>`;\n+\n+        ctx.output.set('sitemap.xml', sitemap);\n+      },\n+    },\n+  };\n+}\ndiff --git a/src/plugins/syntax-highlight.ts b/src/plugins/syntax-highlight.ts\nnew file mode 100644\nindex 0000000..bdbf0a0\n--- /dev/null\n+++ b/src/plugins/syntax-highlight.ts\n@@ -0,0 +1,23 @@\n+import { Plugin, ContentFile, BuildContext } from '../core/types.js';\n+\n+export function createSyntaxHighlightPlugin(): Plugin {\n+  return {\n+    name: 'syntax-highlight',\n+    version: '1.0.0',\n+    dependencies: [],\n+    hooks: {\n+      transformC