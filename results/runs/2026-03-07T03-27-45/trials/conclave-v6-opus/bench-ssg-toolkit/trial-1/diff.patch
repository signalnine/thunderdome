+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GDEeQfd5egRDe76ap47kix","type":"tool_result","content":"     1→import { BuildContext, ContentFile, Plugin, SiteConfig, Template } from './types.js';\n     2→\n     3→export class BuildEngine {\n     4→  private plugins: Plugin[] = [];\n     5→  private templates: Map<string, Template> = new Map();\n     6→\n     7→  constructor(private config: SiteConfig) {}\n     8→\n     9→  registerPlugin(plugin: Plugin): void {\n    10→    this.plugins.push(plugin);\n    11→  }\n    12→\n    13→  registerTemplate(template: Template): void {\n    14→    this.templates.set(template.name, template);\n    15→  }\n    16→\n    17→  // Resolve plugin execution order using topological sort\n    18→  resolvePluginOrder(): Plugin[] {\n    19→    const sorted: Plugin[] = [];\n    20→    const visited = new Set<string>();\n    21→    const visiting = new Set<string>();\n    22→    const pluginMap = new Map(this.plugins.map(p => [p.name, p]));\n    23→\n    24→    const visit = (name: string) => {\n    25→      if (visited.has(name)) return;\n    26→      if (visiting.has(name)) {\n    27→        throw new Error(`Circular dependency detected: ${name}`);\n    28→      }\n    29→      visiting.add(name);\n    30→      const plugin = pluginMap.get(name);\n    31→      if (plugin) {\n    32→        for (const dep of plugin.dependencies) {\n    33→          if (!pluginMap.has(dep)) {\n    34→            throw new Error(`Missing dependency: ${name} requires ${dep}`);\n    35→          }\n    36→          visit(dep);\n    37→        }\n    38→      }\n    39→      visiting.delete(name);\n    40→      visited.add(name);\n    41→      if (plugin) sorted.push(plugin);\n    42→    };\n    43→\n    44→    for (const plugin of this.plugins) {\n    45→      visit(plugin.name);\n    46→    }\n    47→    return sorted;\n    48→  }\n    49→\n    50→  async build(files: ContentFile[]): Promise<BuildContext> {\n    51→    const ctx: BuildContext = {\n    52→      config: this.config,\n    53→      files: [...files],\n    54→      output: new Map(),\n    55→      assets: new Map(),\n    56→      data: new Map(),\n    57→    };\n    58→\n    59→    const orderedPlugins = this.resolvePluginOrder();\n    60→\n    61→    // beforeBuild hooks\n    62→    for (const plugin of orderedPlugins) {\n    63→      if (plugin.hooks.beforeBuild) {\n    64→        await plugin.hooks.beforeBuild(ctx);\n    65→      }\n    66→    }\n    67→\n    68→    // transformContent hooks (applied to each file in plugin order)\n    69→    for (const plugin of orderedPlugins) {\n    70→      if (plugin.hooks.transformContent) {\n    71→        const transformed: ContentFile[] = [];\n    72→        for (const file of ctx.files) {\n    73→          transformed.push(await plugin.hooks.transformContent(file, ctx));\n    74→        }\n    75→        ctx.files = transformed;\n    76→      }\n    77→    }\n    78→\n    79→    // Render templates\n    80→    for (const file of ctx.files) {\n    81→      const templateName = file.template || 'default';\n    82→      const template = this.templates.get(templateName);\n    83→      if (template) {\n    84→        const rendered = template.render(file.content, {\n    85→          title: file.title,\n    86→          slug: file.slug,\n    87→          date: file.date,\n    88→          tags: file.tags,\n    89→          ...file.metadata,\n    90→          siteTitle: this.config.title,\n    91→          baseUrl: this.config.baseUrl,\n    92→        });\n    93→        ctx.output.set(`${file.slug}.html`, rendered);\n    94→      } else {\n    95→        ctx.output.set(`${file.slug}.html`, file.content);\n    96→      }\n    97→    }\n    98→\n    99→    // afterBuild hooks\n   100→    for (const plugin of orderedPlugins) {\n   101→      if (plugin.hooks.afterBuild) {\n   102→        await plugin.hooks.afterBuild(ctx);\n   103→      }\n   104→    }\n   105→\n   106→    return ctx;\n   107→  }\n   108→\n   109→  getPlugins(): Plugin[] {\n   110→    return [...this.plugins];\n   111→  }\n   112→\n   113→  getTemplates(): Map<string, Template> {\n   114→    return new Map(this.templates);\n   115→  }\n   116→}\n   117→"}]},"parent_tool_use_id":null,"session_id":"a2e1c65c-b858-4fc9-9632-74bb2bca2dd6","uuid":"d8087a93-67de-4691-b69d-dbd33099722a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/core/engine.ts","content":"import { BuildContext, ContentFile, Plugin, SiteConfig, Template } from './types.js';\n\nexport class BuildEngine {\n  private plugins: Plugin[] = [];\n  private templates: Map<string, Template> = new Map();\n\n  constructor(private config: SiteConfig) {}\n\n  registerPlugin(plugin: Plugin): void {\n    this.plugins.push(plugin);\n  }\n\n  registerTemplate(template: Template): void {\n    this.templates.set(template.name, template);\n  }\n\n  // Resolve plugin execution order using topological sort\n  resolvePluginOrder(): Plugin[] {\n    const sorted: Plugin[] = [];\n    const visited = new Set<string>();\n    const visiting = new Set<string>();\n    const pluginMap = new Map(this.plugins.map(p => [p.name, p]));\n\n    const visit = (name: string) => {\n      if (visited.has(name)) return;\n      if (visiting.has(name)) {\n        throw new Error(`Circular dependency detected: ${name}`);\n      }\n      visiting.add(name);\n      const plugin = pluginMap.get(name);\n      if (plugin) {\n        for (const dep of plugin.dependencies) {\n          if (!pluginMap.has(dep)) {\n            throw new Error(`Missing dependency: ${name} requires ${dep}`);\n          }\n          visit(dep);\n        }\n      }\n      visiting.delete(name);\n      visited.add(name);\n      if (plugin) sorted.push(plugin);\n    };\n\n    for (const plugin of this.plugins) {\n      visit(plugin.name);\n    }\n    return sorted;\n  }\n\n  async build(files: ContentFile[]): Promise<BuildContext> {\n    const ctx: BuildContext = {\n      config: this.config,\n      files: [...files],\n      output: new Map(),\n      assets: new Map(),\n      data: new Map(),\n    };\n\n    const orderedPlugins = this.resolvePluginOrder();\n\n    // beforeBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.beforeBuild) {\n        await plugin.hooks.beforeBuild(ctx);\n      }\n    }\n\n    // transformContent hooks (applied to each file in plugin order)\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.transformContent) {\n        const transformed: ContentFile[] = [];\n        for (const file of ctx.files) {\n          transformed.push(await plugin.hooks.transformContent(file, ctx));\n        }\n        ctx.files = transformed;\n      }\n    }\n\n    // Render templates\n    for (const file of ctx.files) {\n      const templateName = file.template || 'default';\n      const template = this.templates.get(templateName);\n      if (template) {\n        const rendered = template.render(file.content, {\n          title: file.title,\n          slug: file.slug,\n          date: file.date,\n          tags: file.tags,\n          ...file.metadata,\n          siteTitle: this.config.title,\n          baseUrl: this.config.baseUrl,\n        });\n        ctx.output.set(`${file.slug}.html`, rendered);\n      } else {\n        ctx.output.set(`${file.slug}.html`, file.content);\n      }\n    }\n\n    // afterBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.afterBuild) {\n        await plugin.hooks.afterBuild(ctx);\n      }\n    }\n\n    return ctx;\n  }\n\n  getPlugins(): Plugin[] {\n    return [...this.plugins];\n  }\n\n  getTemplates(): Map<string, Template> {\n    return new Map(this.templates);\n  }\n}\n","numLines":117,"startLine":1,"totalLines":117}}}
