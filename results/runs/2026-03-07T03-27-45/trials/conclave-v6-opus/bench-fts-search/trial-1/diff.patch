+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TGMkxV7oDsGyaDh2WpxM9L","type":"tool_result","content":"     1→import { Request, Response, NextFunction } from 'express';\n     2→\n     3→export class NotFoundError extends Error {\n     4→  statusCode = 404;\n     5→  constructor(message = 'Resource not found') {\n     6→    super(message);\n     7→    this.name = 'NotFoundError';\n     8→  }\n     9→}\n    10→\n    11→export class ValidationError extends Error {\n    12→  statusCode = 400;\n    13→  constructor(message = 'Validation failed') {\n    14→    super(message);\n    15→    this.name = 'ValidationError';\n    16→  }\n    17→}\n    18→\n    19→export function errorHandler(\n    20→  err: Error,\n    21→  _req: Request,\n    22→  res: Response,\n    23→  _next: NextFunction\n    24→): void {\n    25→  if (err instanceof NotFoundError) {\n    26→    res.status(err.statusCode).json({ error: err.message });\n    27→  } else if (err instanceof ValidationError) {\n    28→    res.status(err.statusCode).json({ error: err.message });\n    29→  } else {\n    30→    console.error(err);\n    31→    res.status(500).json({ error: 'Internal server error' });\n    32→  }\n    33→}\n    34→"}]},"parent_tool_use_id":"toolu_015hUWzvMVuTyL1eZZWCibjU","session_id":"4fa652b6-6e6b-4848-af3a-09e47ef149b2","uuid":"83d4ab94-ffeb-48f8-b8cd-12a9f5b9a030"}
