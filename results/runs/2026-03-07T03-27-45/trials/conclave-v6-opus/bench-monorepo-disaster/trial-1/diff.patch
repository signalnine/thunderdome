\n    59→  const result = userIdSchema.safeParse(id);\n    60→  if (result.success) {\n    61→    return { success: true, data: result.data };\n    62→  }\n    63→  return {\n    64→    success: false,\n    65→    errors: result.error.errors.map((e) => e.message),\n    66→  };\n    67→}\n    68→"}]},"parent_tool_use_id":null,"session_id":"73106b6f-edfc-45da-a813-c8ddd071da25","uuid":"7ea5e360-25d7-4317-9032-b0abf8b3753d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/core/src/validation.ts","content":"/**\n * Schema validation using zod.\n * Uses z.pipe() for string-to-number coercion (requires zod >= 3.22).\n */\n\nimport { z } from 'zod';\nimport type { Role } from './types.js';\n\nexport const roleSchema = z.enum(['admin', 'user', 'viewer']);\n\nexport const createUserSchema = z.object({\n  name: z\n    .string()\n    .min(1, 'Name is required')\n    .max(100, 'Name must be 100 characters or less'),\n  email: z.string().email('Invalid email address'),\n  role: roleSchema,\n});\n\nexport const userIdSchema = z\n  .string()\n  .pipe(z.coerce.number().int().positive('User ID must be a positive integer'));\n\nexport const userFiltersSchema = z.object({\n  role: roleSchema.optional(),\n  search: z.string().optional(),\n  limit: z\n    .string()\n    .pipe(z.coerce.number().int().min(1).max(100))\n    .optional()\n    .default('20'),\n  offset: z\n    .string()\n    .pipe(z.coerce.number().int().min(0))\n    .optional()\n    .default('0'),\n});\n\nexport function validateCreateUser(data: unknown): {\n  success: boolean;\n  data?: { name: string; email: string; role: Role };\n  errors?: string[];\n} {\n  const result = createUserSchema.safeParse(data);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n\nexport function validateUserId(id: string): {\n  success: boolean;\n  data?: number;\n  errors?: string[];\n} {\n  const result = userIdSchema.safeParse(id);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n","numLines":68,"startLine":1,"totalLines":68}}}
