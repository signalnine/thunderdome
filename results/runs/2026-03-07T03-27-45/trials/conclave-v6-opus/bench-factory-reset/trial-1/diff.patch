  53→    if (!pivotCols.includes(col)) {\n    54→      freeCols.push(col);\n    55→    }\n    56→  }\n    57→\n    58→  return { pivotCols, freeCols, matrix: m };\n    59→}\n    60→\n    61→function modInverse(a: number, mod: number): number {\n    62→  if (mod === 1) return 0;\n    63→  let [old_r, r] = [a % mod, mod];\n    64→  let [old_s, s] = [1, 0];\n    65→  while (r !== 0) {\n    66→    const q = Math.floor(old_r / r);\n    67→    [old_r, r] = [r, old_r - q * r];\n    68→    [old_s, s] = [s, old_s - q * s];\n    69→  }\n    70→  return ((old_s % mod) + mod) % mod;\n    71→}\n    72→\n    73→/**\n    74→ * Precompute the affine relationship: solution = baseVec + coeffMatrix * freeVarVec (mod p)\n    75→ *\n    76→ * baseVec[i] = value of variable i when all free vars are 0\n    77→ * coeffMatrix[i][j] = derivative of variable i w.r.t. free variable j\n    78→ *\n    79→ * For pivot variable at row r (pivot col = pivotCols[r]):\n    80→ *   value = rref[r][numCols] - sum_j(rref[r][freeCols[j]] * freeVals[j])\n    81→ *   So: baseVec[pivotCols[r]] = rref[r][numCols]\n    82→ *       coeffMatrix[pivotCols[r]][j] = (mod - rref[r][freeCols[j]]) % mod\n    83→ *\n    84→ * For free variable freeCols[j]:\n    85→ *   value = freeVals[j]\n    86→ *   So: baseVec[freeCols[j]] = 0\n    87→ *       coeffMatrix[freeCols[j]][j] = 1, others = 0\n    88→ */\n    89→function precomputeAffine(\n    90→  numCols: number,\n    91→  pivotCols: number[],\n    92→  freeCols: number[],\n    93→  rref: number[][],\n    94→  mod: number\n    95→): { baseVec: number[]; coeffMatrix: number[][] } {\n    96→  const numFree = freeCols.length;\n    97→  const baseVec = new Array(numCols).fill(0);\n    98→  const coeffMatrix: number[][] = Array.from({ length: numCols }, () =>\n    99→    new Array(numFree).fill(0)\n   100→  );\n   101→\n   102→  // Pivot variables\n   103→  for (let r = 0; r < pivotCols.length; r++) {\n   104→    const pc = pivotCols[r];\n   105→    baseVec[pc] = rref[r][num