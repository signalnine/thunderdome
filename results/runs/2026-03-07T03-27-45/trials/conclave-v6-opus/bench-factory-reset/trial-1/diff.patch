um=1), b0=0,b1=1 (sum=1), b0=2,b1=4 (sum=6), etc.\n    // Min sum = 1, lexicographically smallest: [0, 1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('returns lexicographically smallest when tied on total', () => {\n    // Button 0: [0], Button 1: [0]\n    // Target: [2], mod 5\n    // b0=0,b1=2 (sum=2), b0=1,b1=1 (sum=2), b0=2,b1=0 (sum=2)\n    // Lex smallest: [0, 2]\n    const result = solveCounter([2], [[0], [0]], 5);\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('handles two independent counters', () => {\n    // Button 0: [0], Button 1: [1]\n    // Target: [2, 3], mod 5\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  it('handles overlapping buttons', () => {\n    // Button 0: [0, 1], Button 1: [1, 2]\n    // Target: [1, 2, 1], mod 3\n    // b0 + 0 = 1 → b0 = 1\n    // b0 + b1 = 2 → b1 = 1\n    // 0 + b1 = 1 → b1 = 1 ✓\n    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 3);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('handles no buttons with non-zero target', () => {\n    const result = solveCounter([1], [], 3);\n    expect(result).toBeNull();\n  });\n\n  it('handles no buttons with zero target', () => {\n    const result = solveCounter([0, 0], [], 3);\n    expect(result).toEqual([]);\n  });\n\n  it('handles mod 2 (equivalent to toggle)', () => {\n    // Button 0: [0, 1], Button 1: [1, 2]\n    // Target: [1, 0, 1], mod 2\n    const result = solveCounter([1, 0, 1], [[0, 1], [1, 2]], 2);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('handles larger modulus', () => {\n    // Button 0: [0], mod 97\n    // Target: [50]\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n  });\n\n  it('handles system requiring modular inverse', () => {\n    // Button 0: [0, 1], Button 1: [0]\n    // Target: [0, 1], mod 5\n    // b0 + b1 ≡ 0 mod 5, b0 ≡ 1 mod 5\n    // b0 = 1, b1 = 4\n    const result =