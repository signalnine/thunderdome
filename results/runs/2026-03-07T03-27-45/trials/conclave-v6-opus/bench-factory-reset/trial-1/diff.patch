: number[][],\n  numFree: number\n): number[] {\n  // Compute base bitmask and XOR masks for each free variable\n  // Use BigInt for bitmasks since numButtons can be up to 40\n  let baseMask = 0n;\n  for (let i = 0; i < numButtons; i++) {\n    if (baseVec[i] === 1) baseMask |= 1n << BigInt(i);\n  }\n\n  const freeXorMasks: bigint[] = new Array(numFree);\n  for (let j = 0; j < numFree; j++) {\n    let mask = 0n;\n    for (let i = 0; i < numButtons; i++) {\n      if (coeffMatrix[i][j] === 1) mask |= 1n << BigInt(i);\n    }\n    freeXorMasks[j] = mask;\n  }\n\n  const halfA = Math.min(numFree, Math.floor(numFree / 2));\n  const halfB = numFree - halfA;\n\n  // Enumerate first half: for each mask of free vars 0..halfA-1,\n  // compute the XOR pattern and popcount\n  const sizeA = 1 << halfA;\n  const halfAResults: { xorMask: bigint; popcount: number; freeAssign: number }[] = [];\n\n  for (let assign = 0; assign < sizeA; assign++) {\n    let xorMask = 0n;\n    for (let j = 0; j < halfA; j++) {\n      if ((assign >> j) & 1) xorMask ^= freeXorMasks[j];\n    }\n    // The actual solution mask for this half is baseMask ^ xorMask\n    // but we'll combine with second half, so just store the xor contribution\n    halfAResults.push({ xorMask, popcount: popcount64(xorMask), freeAssign: assign });\n  }\n\n  // For each popcount, keep only the entry that gives the lexicographically\n  // smallest solution when XOR'd with base\n  // Actually, we need to consider the FULL combination. Let's just enumerate both halves\n  // and combine. With up to 2^20 * 2^20 = 2^40, that's too much.\n  //\n  // Better approach: group first-half results by their XOR mask. For each second-half\n  // assignment, we know what the total solution mask is: baseMask ^ xorA ^ xorB.\n  // We want to minimize popcount(baseMask ^ xorA ^ xorB).\n  //\n  // This is equivalent to: for each xorB, find xorA that minimizes\n  // popcount(baseMask ^ xorB ^ xorA).\n  //\n  // Let targetMask = baseMask ^ xorB. We want x