sult).toEqual([0]);\n  }, 5000);\n});","originalFile":"import { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter } from './index.js';\n\ndescribe('solveToggle', () => {\n  it('returns empty array when target is all off', () => {\n    const result = solveToggle({\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('returns single button when it exactly matches target', () => {\n    const result = solveToggle({\n      target: [true, true, false],\n      buttons: [[0, 1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('returns null when no solution exists (example from spec)', () => {\n    // From TASK.md: target [T, T, F, T] with given buttons has no solution\n    const result = solveToggle({\n      target: [true, true, false, true],\n      buttons: [\n        [0, 1],    // button 0\n        [1, 2, 3], // button 1\n        [0, 3],    // button 2\n      ],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('returns minimum number of button presses', () => {\n    // Button 0 toggles [0], Button 1 toggles [0, 1], Button 2 toggles [1]\n    // Target: [true, true]\n    // Solution with 1 press: button 1 → [on, on] ✓\n    // Solution with 2 presses: buttons 0, 2 → [on, off] then [on, on] ✓\n    // Should return [1] (fewer presses)\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [0, 1], [1]],\n    });\n    expect(result).toEqual([1]);\n  });\n\n  it('returns lexicographically smallest when tied on press count', () => {\n    // Two buttons that each independently solve the puzzle\n    // Button 0 toggles [0], Button 1 toggles [0]\n    // Target: [true]\n    // Both [0] and [1] are solutions with 1 press\n    // Should return [0] (lexicographically smaller)\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('handles two buttons needed', () => {\n    // Button 0 toggles [0], Button 1 toggles [1]\n    // Target: [true, true]\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('handles overlapping toggles correctly', () => {\n    // Button 0: [0, 1], Button 1: [1, 2]\n    // Target: [true, false, true]\n    // Press both: light 0 toggled by b0, light 1 toggled by b0 and b1 (cancel), light 2 by b1\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('returns null when target is impossible with given buttons', () => {\n    // Button 0 toggles [0, 1] — only option\n    // Target: [true, false] — impossible (can't toggle just one)\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0, 1]],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('handles single light single button', () => {\n    expect(solveToggle({ target: [true], buttons: [[0]] })).toEqual([0]);\n    expect(solveToggle({ target: [false], buttons: [[0]] })).toEqual([]);\n  });\n\n  it('handles no buttons with non-zero target', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('handles no buttons with zero target', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('handles larger system', () => {\n    // 5 lights, 5 buttons each toggling one light\n    const result = solveToggle({\n      target: [true, false, true, false, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    });\n    expect(result).toEqual([0, 2, 4]);\n  });\n\n  it('prefers fewer presses over smaller indices', () => {\n    // Button 0: [0, 1, 2] — solves in 1 press\n    // Buttons 1,2,3: [0], [1], [2] — solves in 3 presses\n    // Target: [true, true, true]\n    const result = solveToggle({\n      target: [true, true, true],\n      buttons: [[0, 1, 2], [0], [1], [2]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('sorted ascending in result', () => {\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[1], [0]],\n    });\n    // Buttons 0 (toggles light 1) and 1 (toggles light 0) — need both\n    expect(result).toEqual([0, 1]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('returns all zeros when target is all zeros', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('returns single button press for simple case', () => {\n    // Button 0 increments counter 0. Target: counter 0 = 3. Mod 5.\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('handles modular arithmetic', () => {\n    // Button 0 increments counter 0. Target: counter 0 = 0. Mod 5.\n    // Press 0 times (already 0) or 5 times (wraps to 0, but max is modulus-1=4)\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('returns null when no solution exists', () => {\n    // Button 0 increments [0, 1]. Target: [1, 0]. Mod 3.\n    // Pressing x times: counter 0 = x mod 3, counter 1 = x mod 3.\n    // Need counter 0 = 1, counter 1 = 0 → x=1 and x=0, contradiction.\n    const result = solveCounter([1, 0], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('minimizes total presses', () => {\n    // Button 0: [0], Button 1: [0]\n    // Target: [1], mod 5\n    // Solutions: b0=1,b1=0 (sum=1), b0=0,b1=1 (sum=1), b0=2,b1=4 (sum=6), etc.\n    // Min sum = 1, lexicographically smallest: [0, 1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('returns lexicographically smallest when tied on total', () => {\n    // Button 0: [0], Button 1: [0]\n    // Target: [2], mod 5\n    // b0=0,b1=2 (sum=2), b0=1,b1=1 (sum=2), b0=2,b1=0 (sum=2)\n    // Lex smallest: [0, 2]\n    const result = solveCounter([2], [[0], [0]], 5);\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('handles two independent counters', () => {\n    // Button 0: [0], Button 1: [1]\n    // Target: [2, 3], mod 5\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  it('handles overlapping buttons', () => {\n    // Button 0: [0, 1], Button 1: [1, 2]\n    // Target: [1, 2, 1], mod 3\n    // b0 + 0 = 1 → b0 = 1\n    // b0 + b1 = 2 → b1 = 1\n    // 0 + b1 = 1 → b1 = 1 ✓\n    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 3);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('handles no buttons with non-zero target', () => {\n    const result = solveCounter([1], [], 3);\n    expect(result).toBeNull();\n  });\n\n  it('handles no buttons with zero target', () => {\n    const result = solveCounter([0, 0], [], 3);\n    expect(result).toEqual([]);\n  });\n\n  it('handles mod 2 (equivalent to toggle)', () => {\n    // Button 0: [0, 1], Button 1: [1, 2]\n    // Target: [1, 0, 1], mod 2\n    const result = solveCounter([1, 0, 1], [[0, 1], [1, 2]], 2);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('handles larger modulus', () => {\n    // Button 0: [0], mod 97\n    // Target: [50]\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n  });\n\n  it('handles system requiring modular inverse', () => {\n    // Button 0: [0, 1], Button 1: [0]\n    // Target: [0, 1], mod 5\n    // b0 + b1 ≡ 0 mod 5, b0 ≡ 1 mod 5\n    // b0 = 1, b1 = 4\n    const result = solveCounter([0, 1], [[0, 1], [0]], 5);\n    expect(result).toEqual([1, 4]);\n  });\n});\n","structuredPatch":[{"oldStart":137,"oldLines":6,"newStart":137,"newLines":38,"lines":["     // Buttons 0 (toggles light 1) and 1 (toggles light 0) — need both","     expect(result).toEqual([0, 1]);","   });","+","+  it('handles many buttons with many free var