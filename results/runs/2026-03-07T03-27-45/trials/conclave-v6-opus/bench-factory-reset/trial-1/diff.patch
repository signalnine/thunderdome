@@ -0,0 +1,412 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function gaussianElimination(
+  numRows: number,
+  numCols: number,
+  matrix: number[][],
+  mod: number
+): { pivotCols: number[]; freeCols: number[]; matrix: number[][] } | null {
+  const m = matrix.map(row => row.slice());
+  const pivotCols: number[] = [];
+  let pivotRow = 0;
+
+  for (let col = 0; col < numCols && pivotRow < numRows; col++) {
+    let found = -1;
+    for (let row = pivotRow; row < numRows; row++) {
+      if (m[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [m[pivotRow], m[found]] = [m[found], m[pivotRow]];
+    pivotCols.push(col);
+
+    const inv = modInverse(m[pivotRow][col], mod);
+    for (let j = 0; j <= numCols; j++) {
+      m[pivotRow][j] = (m[pivotRow][j] * inv) % mod;
+    }
+
+    for (let row = 0; row < numRows; row++) {
+      if (row === pivotRow || m[row][col] === 0) continue;
+      const factor = m[row][col];
+      for (let j = 0; j <= numCols; j++) {
+        m[row][j] = ((m[row][j] - factor * m[pivotRow][j]) % mod + mod) % mod;
+      }
+    }
+
+    pivotRow++;
+  }
+
+  for (let row = pivotRow; row < numRows; row++) {
+    if (m[row][numCols] !== 0) {
+      return null;
+    }
+  }
+
+  const freeCols: number[] = [];
+  for (let col = 0; col < numCols; col++) {
+    if (!pivotCols.includes(col)) {
+      freeCols.push(col);
+    }
+  }
+
+  return { pivotCols, freeCols, matrix: m };
+}
+
+function modInverse(a: number, mod: number): number {
+  if (mod === 1) return 0;
+  let [old_r, r] = [a % mod, mod];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % mod) + mod) % mod;
+}
+
+function precomputeAffine(
+  numCols: number,
+  pivotCols: number[],
+  freeCols: number[],
+  rref: number[][],
+  mod: number
+): { baseVec: number[]; coeffMatrix: number[][] } {
+  const numFree = freeCols.length;
+  const baseVec = new Array(numCols).fill(0);
+  const coeffMatrix: number[][] = Array.from({ length: numCols }, () =>
+    new Array(numFree).fill(0)
+  );
+
+  for (let r = 0; r < pivotCols.length; r++) {
+    const pc = pivotCols[r];
+    baseVec[pc] = rref[r][numCols];
+    for (let j = 0; j < numFree; j++) {
+      coeffMatrix[pc][j] = (mod - rref[r][freeCols[j]]) % mod;
+    }
+  }
+
+  for (let j = 0; j < numFree; j++) {
+    coeffMatrix[freeCols[j]][j] = 1;
+  }
+
+  return { baseVec, coeffMatrix };
+}
+
+function computeSolution(
+  baseVec: number[],
+  coeffMatrix: number[][],
+  freeVals: number[],
+  mod: number
+): number[] {
+  const n = baseVec.length;
+  const sol = new Array(n);
+  for (let i = 0; i < n; i++) {
+    let val = baseVec[i];
+    for (let j = 0; j < freeVals.length; j++) {
+      val += coeffMatrix[i][j] * freeVals[j];
+    }
+    sol[i] = ((val % mod) + mod) % mod;
+  }
+  return sol;
+}
+
+function popcount64(n: bigint): number {
+  let count = 0;
+  while (n > 0n) {
+    n &= n - 1n;
+    count++;
+  }
+  return count;
+}
+
+function lexCompareArrays(a: number[], b: number[]): number {
+  const len = Math.max(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    const av = i < a.length ? a[i] : -1;
+    const bv = i < b.length ? b[i] : -1;
+    if (av !== bv) return av - bv;
+  }
+  return 0;
+}
+
+function lexCompareResult(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
+
+// ==================== solveToggle (GF(2)) ====================
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (target.every(t => !t)) return [];
+  if (numButtons === 0) return null;
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  const result = gaussianElimination(numLights, numButtons, matrix, 2);
+  if (result === null) return null;
+
+  const { pivotCols, freeCols, matrix: rref } = result;
+  const numFree = freeCols.length;
+  const { baseVec, coeffMatrix } = precomputeAffine(
+    numButtons, pivotCols, freeCols, rref, 2
+  );
+
+  if (numFree <= 20) {
+    return solveToggleDirect(numButtons, baseVec, coeffMatrix, numFree);
+  }
+  return solveToggleBranchAndBound(numButtons, baseVec, coeffMatrix, numFree);
+}
+
+function solveToggleDirect(
+  numButtons: number,
+  baseVec: number[],
+  coeffMatrix: number[][],
+  numFree: number
+): number[] {
+  let bestPressed: number[] | null = null;
+  let bestCount = Infinity;
+
+  const totalCombinations = 1 << numFree;
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const freeVals = new Array(numFree);
+    for (let i = 0; i < numFree; i++) {
+      freeVals[i] = (mask >> i) & 1;
+    }
+
+    const sol = computeSolution(baseVec, coeffMatrix, freeVals, 2);
+    const pressed: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if (sol[i] === 1) pressed.push(i);
+    }
+
+    if (pressed.length < bestCount ||
+        (pressed.length === bestCount && bestPressed !== null &&
+         lexCompareArrays(pressed, bestPressed) < 0)) {
+      bestPressed = pressed;
+      bestCount = pressed.length;
+    }
+  }
+
+  return bestPressed!;
+}
+
+function solveToggleBranchAndBound(
+  numButtons: number,
+  baseVec: number[],
+  coeffMatrix: number[][],
+  numFree: number
+): number[] {
+  // Represent solution as bigint bitmask for efficient XOR and popcount
+  let baseMask = 0n;
+  for (let i = 0; i < numButtons; i++) {
+    if (baseVec[i] === 1) baseMask |= 1n << BigInt(i);
+  }
+
+  const freeXorMasks: bigint[] = new Array(numFree);
+  for (let j = 0; j < numFree; j++) {
+    let mask = 0n;
+    for (let i = 0; i < numButtons; i++) {
+      if (coeffMatrix[i][j] === 1) mask |= 1n << BigInt(i);
+    }
+    freeXorMasks[j] = mask;
+  }
+
+  // Precompute cumulative reachable masks for pruning
+  const cumulativeReachable: bigint[] = new Array(numFree + 1);
+  cumulativeReachable[numFree] = 0n;
+  for (let j = numFree - 1; j >= 0; j--) {
+    cumulativeReachable[j] = cumulativeReachable[j + 1] | freeXorMasks[j];
+  }
+
+  let bestCount = numButtons + 1;
+  let bestSol: number[] | null = null;
+
+  function branchAndBound(depth: number, currentMask: bigint): void {
+    if (depth === numFree) {
+      const count = popcount64(currentMask);
+      if (count < bestCount) {
+        bestCount = count;
+        const sol: number[] = [];
+        for (let i = 0; i < numButtons; i++) {
+          if ((currentMask >> BigInt(i)) & 1n) sol.push(i);
+        }
+        bestSol = sol;
+      } else if (count === bestCount) {
+        const sol: number[] = [];
+        for (let i = 0; i < numButtons; i++) {
+          if ((currentMask >> BigInt(i)) & 1n) sol.push(i);
+        }
+        if (bestSol !== null && lexCompareArrays(sol, bestSol) < 0) {
+          bestSol = sol;
+        }
+      }
+      return;
+    }
+
+    const reachable = cumulativeReachable[depth];
+    const unreachableOn = currentMask & ~reachable;
+    const lowerBound = popcount64(unreachableOn);
+
+    if (lowerBound >= bestCount) return;
+
+    // Try f=0 first for lex-smallest preference
+    branchAndBound(depth + 1, currentMask);
+    branchAndBound(depth + 1, currentMask ^ freeXorMasks[depth]);
+  }
+
+  branchAndBound(0, baseMask);
+  return bestSol!;
+}
+
+// ==================== solveCounter (GF(p)) ====================
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (lights.every(v => v === 0)) return new Array(numButtons).fill(0);
+  if (numButtons === 0) return null;
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = lights[i] % modulus;
+    matrix.push(row);
+  }
+
+  const result = gaussianElimination(numCounters, numButtons, matrix, modulus);
+  if (result === null) return null;
+
+  const { pivotCols, freeCols, matrix: rref } = result;
+  const numFree = freeCols.length;
+  const { baseVec, coeffMatrix } = precomputeAffine(
+    numButtons, pivotCols, freeCols, rref, modulus
+  );
+
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (totalCombinations <= 2_000_000) {
+    return solveCounterDirect(numButtons, baseVec, coeffMatrix, numFree, modulus);
+  }
+  return solveCounterBranchAndBound(numButtons, baseVec, coeffMatrix, numFree, modulus);
+}
+
+function solveCounterDirect(
+  numButtons: number,
+  baseVec: number[],
+  coeffMatrix: number[][],
+  numFree: number,
+  mod: number
+): number[] {
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  const totalCombinations = Math.pow(mod, numFree);
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    const freeVals = new Array(numFree);
+    let temp = combo;
+    for (let i = 0; i < numFree; i++) {
+      freeVals[i] = temp % mod;
+      temp = Math.floor(temp / mod);
+    }
+
+    const sol = computeSolution(baseVec, coeffMatrix, freeVals, mod);
+    const sum = sol.reduce((a, b) => a + b, 0);
+
+    if (sum < bestSum ||
+        (sum === bestSum && bestSolution !== null &&
+         lexCompareResult(sol, bestSolution) < 0)) {
+      bestSolution = sol.slice();
+      bestSum = sum;
+    }
+  }
+
+  return bestSolution!;
+}
+
+function solveCounterBranchAndBound(
+  numButtons: number,
+  baseVec: number[],
+  coeffMatrix: number[][],
+  numFree: number,
+  mod: number
+): number[] {
+  let bestSum = Infinity;
+  let bestSol: number[] | null = null;
+  const freeVals = new Array(numFree).fill(0);
+
+  // Precompute which variables depend on which free vars (remaining from depth onward)
+  // dependsOnFrom[depth][i] = true if variable i depends on any free var >= depth
+  const dependsOnFrom: boolean[][] = new Array(numFree + 1);
+  dependsOnFrom[numFree] = new Array(numButtons).fill(false);
+  for (let d = numFree - 1; d >= 0; d--) {
+    dependsOnFrom[d] = new Array(numButtons);
+    for (let i = 0; i < numButtons; i++) {
+      dependsOnFrom[d][i] = dependsOnFrom[d + 1][i] || coeffMatrix[i][d] !== 0;
+    }
+  }
+
+  function branchAndBound(depth: number): void {
+    if (depth === numFree) {
+      const sol = computeSolution(baseVec, coeffMatrix, freeVals, mod);
+      const sum = sol.reduce((a, b) => a + b, 0);
+      if (sum < bestSum || (sum === bestSum && bestSol !== null && lexCompareResult(sol, bestSol) < 0)) {
+        bestSum = sum;
+        bestSol = sol.slice();
+      }
+      return;
+    }
+
+    // Compute lower bound: sum of fixed variables' actual values
+    let lb = 0;
+    for (let i = 0; i < numButtons; i++) {
+      if (!dependsOnFrom[depth][i]) {
+        let val = baseVec[i];
+        for (let j = 0; j < depth; j++) {
+          val += coeffMatrix[i][j] * freeVals[j];
+        }
+        lb += ((val % mod) + mod) % mod;
+      }
+    }
+    if (lb >= bestSum) return;
+
+    for (let v = 0; v < mod; v++) {
+      freeVals[depth] = v;
+      branchAndBound(depth + 1);
+    }
+  }
+
+  branchAndBound(0);
+  return bestSol!;
+}
