g distance for high bits.\n  // This is still potentially slow.\n  //\n  // PRACTICAL SOLUTION: Since we're dealing with ≤ 40 buttons and the problem\n  // says \"complete in under 5 seconds\", let's use a smarter enumeration.\n  //\n  // For GF(2), the cost function (popcount) decomposes per bit. Each bit i of the\n  // solution is: baseVec[i] XOR (sum of coeffMatrix[i][j] * f_j mod 2).\n  // The cost of bit i is its value (0 or 1).\n  //\n  // We want to minimize sum_i (baseVec[i] XOR linearFunc_i(f)).\n  //\n  // Each linearFunc_i is a linear function of f over GF(2). The total cost is:\n  // sum_i baseVec[i] + sum_i (linearFunc_i(f) * (1 - 2*baseVec[i]))\n  // where the second part adjusts based on whether flipping helps.\n  //\n  // Actually: if baseVec[i] = 0, cost contribution is linearFunc_i(f) (we pay 1 if it becomes 1)\n  //           if baseVec[i] = 1, cost contribution is 1 - linearFunc_i(f) (we pay 1 if it stays 1)\n  //\n  // Total cost = sum_{i: base=1} 1 - sum_{i: base=1} linearFunc_i(f) + sum_{i: base=0} linearFunc_i(f)\n  //            = |{i: base=1}| + sum_i sign_i * linearFunc_i(f)\n  //   where sign_i = +1 if base=0, -1 if base=1\n  //\n  // This means minimizing popcount is equivalent to maximizing:\n  //   sum_{i: base=1} linearFunc_i(f) - sum_{i: base=0} linearFunc_i(f)\n  //\n  // Each linearFunc_i(f) = XOR of f_j where coeffMatrix[i][j] = 1.\n  //\n  // This is maximizing a sum of ±1 * (XOR of subset of free vars), which is\n  // still an optimization over GF(2) and doesn't simplify easily.\n  //\n  // Let's just do MITM properly: 2^20 * lookups.\n  // Store all first-half results in a map: xorMask -> best assignment.\n  // For each second-half assignment, scan all first-half entries.\n  // With 2^20 ≈ 1M entries and 2^20 second-half, that's 10^12 — too slow.\n  //\n  // Practical alternative for ≤ 40 free vars:\n  // Use iterative optimization (coordinate descent over GF(2)).\n  // For each free variable, try flipping it and see if popcount improves.\n  // This is O(numFree * numButtons) per iteration, converges quickly.\n  // Not guaranteed optimal, but practical.\n  //\n  // For guaranteed optimality: use branch-and-bound with the linear structure.\n\n  // Let's use branch and bound. At each level, we decide the value of one free variable.\n  // We compute a lower bound on the number of presses for the remaining variables.\n\n  let bestCount = numButtons + 1;\n  let bestSol: number[] | null = null;\n  const freeVals = new Array(numFree).fill(0);\n\n  function branchAndBound(depth: number, currentMask: bigint): void {\n    if (depth === numFree) {\n      const count = popcount64(currentMask);\n      if (count < bestCount) {\n        bestCount = count;\n        const sol: number[] = [];\n        for (let i = 0; i < numButtons; i++) {\n          if ((currentMask >> BigInt(i)) & 1n) sol.push(i);\n        }\n        bestSol = sol;\n      } else if (count === bestCount) {\n        const sol: number[] = [];\n        for (let i = 0; i < numButtons; i++) {\n          if ((currentMask >> BigInt(i)) & 1n) sol.push(i);\n        }\n        if (bestSol !== null && lexCompareArrays(sol, bestSol) < 0) {\n          bestSol = sol;\n        }\n      }\n      return;\n    }\n\n    // Try both values for this free variable\n    // Lower bound: even with optimal remaining choices, each remaining free variable\n    // can at best flip some bits. But computing a tight lower bound is complex.\n    // Simple bound: current popcount minus remaining variables can't go below 0.\n    // Better: for remaining bits, each free var can change some set of bits.\n    // The maximum reduction from remaining vars is bounded by the number of bits\n    // that the remaining vars can reach.\n\n    const currentCount = popcount64(currentMask);\n\n    // Compute how many bits can potentially be changed by remaining free vars\n    let reachableMask = 0n;\n    for (let j = depth; j < numFree; j++) {\n      reachableMask |= freeXorMasks[j];\n    }\n    const reachableBits = popcount64(reachableMask);\n    // Lower bound: bits that are ON and unreachable stay ON,\n    //              bits that are OFF and unreachable stay OFF.\n    // So minimum possible = max(0, currentCount - reachableBits)\n    // (we can turn off at most reachableBits of the ON bits)\n    const lowerBound = Math.max(0, currentCount - reachableBits);\n\n    if (lowerBound >= bestCount) return;\n\n    // Try f[depth] = 0 first (prefer 0 for lex smallest)\n    branchAndBound(depth + 1, currentMask);\n\n    // Try f[depth] = 1\n    branchAndBound(depth + 1, currentMask ^ freeXorMasks[depth]);\n  }\n\n  branchAndBound(0, baseMask);\n\n  return bestSol!;\n}\n\nfunction popcount64(n: bigint): number {\n  let count = 0;\n  while (n > 0n) {\n    n &= n - 1n;\n    count++;\n  }\n  return count;\n}\n\nfunction lexCompareArrays(a: number[], b: number[]): number {\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const av = i < a.length ? a[i] : -1;\n    const bv = i < b.length ? b[i] : -1;\n    if (av !== bv) return av - bv;\n  }\n  return 0;\n}\n\n// ==================== solveCounter (GF(p)) ====================\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  if (lights.every(v => v === 0)) return new Array(numButtons).fill(0);\n  if (numButtons === 0) return null;\n\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = lights[i] % modulus;\n    matrix.push(row);\n  }\n\n  const result = gaussianElimination(numCounters, numButtons, matrix, modulus);\n  if (result === null) return null;\n\n  const { pivotCols, freeCols, matrix: rref } = result;\n  const numFree = freeCols.length;\n\n  const { baseVec, coeffMatrix } = precomputeAffine(\n    numButtons, pivotCols, freeCols, rref, modulus\n  );\n\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (totalCombinations <= 2_000_000) {\n    return solveCounterDirect(numButtons, baseVec, coeffMatrix, numFree, modulus);\n  } else {\n    return solveCounterOptimized(numButtons, baseVec, coeffMatrix, numFree, modulus);\n  }\n}\n\nfunction solveCounterDirect(\n  numButtons: number,\n  baseVec: number[],\n  coeffMatrix: number[][],\n  numFree: number,\n  mod: number\n): number[] {\n  let bestSolution: number[] | null = null;\n  let bestSum = Infinity;\n\n  const totalCombinations = Math.pow(mod, numFree);\n  for (let combo = 0; combo < totalCombinations; combo++) {\n    const freeVals = new Array(numFree);\n    let temp = combo;\n    for (let i = 0; i < numFree; i++) {\n      freeVals[i] = temp % mod;\n      temp = Math.floor(temp / mod);\n    }\n\n    const sol = computeSolution(baseVec, coeffMatrix, freeVals, mod);\n    const sum = sol.reduce((a, b) => a + b, 0);\n\n    if (sum < bestSum ||\n        (sum === bestSum && bestSolution !== null &&\n         lexCompareResult(sol, bestSolution) < 0)) {\n      bestSolution = sol.slice();\n      bestSum = sum;\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction solveCounterOptimized(\n  numButtons: number,\n  baseVec: number[],\n  coeffMatrix: number[][],\n  numFree: number,\n  mod: number\n): number[] {\n  // For large search spaces, use branch-and-bound with per-variable optimization.\n  // Each variable x_i = (baseVec[i] + sum_j coeffMatrix[i][j] * f_j) mod p\n  // Cost = sum_i x_i\n  //\n  // For each variable i, its contribution to cost is a function of the free variables.\n  // Given partial assignment of free vars, we can compute the partial cost and\n  // bound the remaining cost.\n\n  let bestSum = Infinity;\n  let bestSol: number[] | null = null;\n  const freeVals = new Array(numFree).fill(0);\n\n  // Prec