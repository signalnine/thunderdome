 pivotRow; row < numRows; row++) {\n    if (m[row][numCols] !== 0) {\n      return null; // Inconsistent system\n    }\n  }\n\n  const freeCols: number[] = [];\n  for (let col = 0; col < numCols; col++) {\n    if (!pivotCols.includes(col)) {\n      freeCols.push(col);\n    }\n  }\n\n  return { pivotCols, freeCols, matrix: m };\n}\n\nfunction modInverse(a: number, mod: number): number {\n  if (mod === 1) return 0;\n  // Extended Euclidean algorithm\n  let [old_r, r] = [a % mod, mod];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return ((old_s % mod) + mod) % mod;\n}\n\n/**\n * Given the reduced matrix and free variable assignments, compute the full solution.\n */\nfunction backSubstitute(\n  numCols: number,\n  pivotCols: number[],\n  matrix: number[][],\n  freeValues: Map<number, number>,\n  mod: number\n): number[] {\n  const solution = new Array(numCols).fill(0);\n\n  // Set free variables\n  for (const [col, val] of freeValues) {\n    solution[col] = val;\n  }\n\n  // Back-substitute pivot variables\n  for (let i = pivotCols.length - 1; i >= 0; i--) {\n    const pivotCol = pivotCols[i];\n    let val = matrix[i][numCols]; // RHS\n    for (let j = 0; j < numCols; j++) {\n      if (j !== pivotCol) {\n        val = ((val - matrix[i][j] * solution[j]) % mod + mod) % mod;\n      }\n    }\n    solution[pivotCol] = val % mod;\n  }\n\n  return solution;\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Check if target is all false — no buttons needed\n  if (target.every(t => !t)) return [];\n  if (numButtons === 0) return null;\n\n  // Build augmented matrix [A|b] over GF(2)\n  // Rows = lights, Columns = buttons, values in {0, 1}\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n  