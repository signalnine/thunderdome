   found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [m[pivotRow], m[found]] = [m[found], m[pivotRow]];\n    pivotCols.push(col);\n\n    const inv = modInverse(m[pivotRow][col], mod);\n    for (let j = 0; j <= numCols; j++) {\n      m[pivotRow][j] = (m[pivotRow][j] * inv) % mod;\n    }\n\n    for (let row = 0; row < numRows; row++) {\n      if (row === pivotRow || m[row][col] === 0) continue;\n      const factor = m[row][col];\n      for (let j = 0; j <= numCols; j++) {\n        m[row][j] = ((m[row][j] - factor * m[pivotRow][j]) % mod + mod) % mod;\n      }\n    }\n\n    pivotRow++;\n  }\n\n  for (let row = pivotRow; row < numRows; row++) {\n    if (m[row][numCols] !== 0) {\n      return null;\n    }\n  }\n\n  const freeCols: number[] = [];\n  for (let col = 0; col < numCols; col++) {\n    if (!pivotCols.includes(col)) {\n      freeCols.push(col);\n    }\n  }\n\n  return { pivotCols, freeCols, matrix: m };\n}\n\nfunction modInverse(a: number, mod: number): number {\n  if (mod === 1) return 0;\n  let [old_r, r] = [a % mod, mod];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return ((old_s % mod) + mod) % mod;\n}\n\n/**\n * Precompute the affine relationship: solution = baseVec + coeffMatrix * freeVarVec (mod p)\n *\n * baseVec[i] = value of variable i when all free vars are 0\n * coeffMatrix[i][j] = derivative of variable i w.r.t. free variable j\n *\n * For pivot variable at row r (pivot col = pivotCols[r]):\n *   value = rref[r][numCols] - sum_j(rref[r][freeCols[j]] * freeVals[j])\n *   So: baseVec[pivotCols[r]] = rref[r][numCols]\n *       coeffMatrix[pivotCols[r]][j] = (mod - rref[r][freeCols[j]]) % mod\n *\n * For free variable freeCols[j]:\n *   value = freeVals[j]\n *   So: baseVec[freeCols[j]] = 0\n *       coeffMatrix[freeCols[j]][j] = 1, others = 0\n */\nfunction precomputeAffine(\n  numCols: number,