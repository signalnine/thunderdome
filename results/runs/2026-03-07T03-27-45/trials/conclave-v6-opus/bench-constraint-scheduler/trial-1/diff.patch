y graph: for each event, which events depend on it\n  const dependents = new Map<string, string[]>();\n  for (const event of events) {\n    for (const prereq of event.prerequisites ?? []) {\n      if (!dependents.has(prereq)) {\n        dependents.set(prereq, []);\n      }\n      dependents.get(prereq)!.push(event.id);\n    }\n  }\n\n  // Try to maximize number of events scheduled using backtracking with pruning\n  const bestResult = findBestSchedule(order, rooms, options, gap, eventMap);\n\n  return bestResult;\n}\n\nfunction topologicalSort(events: Event[], eventMap: Map<string, Event>): string[] {\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  const result: string[] = [];\n\n  for (const event of events) {\n    color.set(event.id, WHITE);\n  }\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event) {\n      for (const prereq of event.prerequisites ?? []) {\n        if (prereq === id) {\n          throw new Error(`Prerequisite cycle detected: event \"${id}\" references itself`);\n        }\n        const c = color.get(prereq);\n        if (c === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event \"${prereq}\"`);\n        }\n        if (c === WHITE) {\n          dfs(prereq);\n        }\n      }\n    }\n    color.set(id, BLACK);\n    result.push(id);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n\n  return result;\n}\n\ninterface RoomState {\n  // Sorted list of [startTime, endTime] for events assigned to this room\n  slots: [number, number][];\n}\n\nfunction findBestSchedule(\n  order: string[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n  eventMap: Map<string, Event>,\n): ScheduleResult {\n  // For each event in topological order, we try to assign it to a room+time.\n  // We use a greedy approach with smart ordering, and backtracking for optimization.\n\n  // First, determine which events can potentially be scheduled (capacity-wise)\n  const validRoomsForEvent = new Map<string, Room[]>();\n  for (const eventId of order) {\n    const event = eventMap.get(eventId)!;\n    const attendees = event.attendees ?? 1;\n    const validRooms = rooms.filter(r => r.capacity >= attendees);\n    validRoomsForEvent.set(eventId, validRooms);\n  }\n\n  // Sort events: most constrained first (fewest valid rooms, then longest duration)\n  // But respect topological order: prerequisites must come before dependents\n  const topoIndex = new Map<string, number>();\n  for (let i = 0; i < order.length; i++) {\n    topoIndex.set(order[i], i);\n  }\n\n  const sortedEvents = [...order].sort((a, b) => {\n    // First respect topological order\n    const topoA = topoIndex.get(a)!;\n    const topoB = topoIndex.get(b)!;\n\n    // Check if a is a transitive prerequisite of b or vice versa\n    if (isPrerequisiteOf(a, b, eventMap)) return -1;\n    if (isPrerequisiteOf(b, a, eventMap)) return 1;\n\n    // For unrelated events, sort by most constrained first\n    const roomsA = validRoomsForEvent.get(a)?.length ?? 0;\n    const roomsB = validRoomsForEvent.get(b)?.length ?? 0;\n    if (roomsA !== roomsB) return roomsA - roomsB;\n\n    // Longer duration = harder to place = schedule first\n    const durA = eventMap.get(a)!.duration;\n    const durB = eventMap.get(b)!.duration;\n    if (durA !== durB) return durB - durA;\n\n    return topoA - topoB;\n  });\n\n  // Use greedy + backtracking approach\n  const roomStates = new Map<string, RoomState>();\n  for (const room of rooms) {\n    roomStates.set(room.id, { slots: [] });\n  }\n  const assignments = new Map<string, Assignment>();\n  const scheduledSet = new Set<string>();\n\n  // Try to greedily schedule each event\n  scheduleEvents(sortedEvents, 0, eventMap, rooms, validRoomsForEvent, roomStates, assignments, scheduledSet, options, gap);\n\n  // Collect results\n  const assignmentList: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  for (const eventId of order) {\n    const assignment = assignments.get(eventId);\n    if (assignment) {\n      assignmentList.push(assignment);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return { assignments: assignmentList, unscheduled };\n}\n\nfunction isPrerequisiteOf(a: string, b: string, eventMap: Map<string, Event>): boolean {\n  const visited = new Set<string>();\n  const queue = [b];\n  while (queue.length > 0) {\n    const current = queue.pop()!;\n    if (visited.has(current)) continue;\n    visited.add(current);\n    const event = eventMap.get(current);\n    if (!event) continue;\n    for (const prereq of event.prerequisites ?? []) {\n      if (prereq === a) return true;\n      queue.push(prereq);\n    }\n  }\n  return false;\n}\n\nfunction scheduleEvents(\n  eventIds: string[],\n  index: number,\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  validRoomsForEvent: Map<string, Room[]>,\n  roomStates: Map<string, RoomState>,\n  assignments: Map<string, Assignment>,\n  scheduledSet: Set<string>,\n  options: ScheduleOptions,\n  gap: number,\n): void {\n  if (index >= eventIds.length) return;\n\n  const eventId = eventIds[index];\n  const event = eventMap.get(eventId)!;\n\n  // Check if all prerequisites are scheduled\n  const prereqsMet = (event.prerequisites ?? []).every(p => scheduledSet.has(p));\n  if (!prereqsMet) {\n    // Skip this event - prerequisites not met, mark as unscheduled\n    scheduleEvents(eventIds, index + 1, eventMap, rooms, validRoomsForEvent, roomStates, assignments, scheduledSet, options, gap);\n    return;\n  }\n\n  // Calculate earliest start based on prerequisites\n  let earliestStart = options.startTime;\n  for (const prereqId of event.prerequisites ?? []) {\n    const prereqAssignment = assignments.get(prereqId);\n    if (prereqAssignment) {\n      earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n    }\n  }\n\n  // Get valid rooms, try preferred room first\n  const validRooms = validRoomsForEvent.get(eventId) ?? [];\n  const orderedRooms = orderRoomsByPreference(validRooms, event.preferredRoom);\n\n  // Try each room, find earliest slot\n  let bestPlacement: { roomId: string; startTime: number } | null = null;\n\n  for (const room of orderedRooms) {\n    const startTime = findEarliestSlot(roomStates.get(room.id)!, earliestStart, event.duration, options.endTime, gap);\n    if (startTime !== null) {\n      if (bestPlacement === null || startTime < bestPlacement.startTime || (room.id === event.preferredRoom && startTime <= bestPlacement.startTime)) {\n        bestPlacement = { roomId: room.id, startTime };\n      }\n    }\n  }\n\n  // Try with and without placing this event (for optimization)\n  // Strategy: try placing the event, then try skipping it, keep the one with more assignments\n  if (bestPlacement !== null) {\n    // Try placing\n    const endTime = bestPlacement.startTime + event.duration;\n    const assignment: Assignment = {\n      eventId,\n      roomId: bestPlacement.roomId,\n      startTime: bestPlacement.startTime,\n      endTime,\n    };\n\n    // Save state\n    const roomState = roomStates.get(bestPlacement.roomId)!;\n    const slotIndex = insertSlot(roomState, bestPlacement.startTime, endTime);\n\n    assignments.set(eventId, assignment);\n    scheduledSet.add(eventId);\n\n    // Count remaining schedulable with this placement\n    const savedAssignments = new Map(assignments);\n    const savedScheduled = new Set(scheduledSet);\n    const savedStates = saveRoomStates(roomStates);\n\n    scheduleEvents(eventIds, index + 1, eventMap, rooms, validRoomsForEvent, roomStates, assignments, scheduledSet, options, gap);\n    const withCount = assignments.size;\n\n    // Try without placing (only if it might help - when there are events competing for same resources)\n    // Only backtrack if this is a constrained scenario\n    if (eventIds.length - index > assignments.size - savedAssignments.size + 1) {\n      const withAssignments = new Map(assignments);\n      const withScheduled = new Set(scheduledSet);\n\n      // Restore state to before placing\n      restoreRoomStates(roomStates, savedStates);\n      assignments.clear();\n      for (const [k, v] of savedAssignments) {\n        if (k !== eventId) assignments.set(k, v);\n      }\n      scheduledSet.clear();\n      for (const s of savedScheduled) {\n        if (s !== eventId) scheduledSet.add(s);\n      }\n      // Remove the slot we inserted\n      roomStates.get(bestPlacement.roomId)!.slots.splice(slotIndex, 1);\n\n      scheduleEvents(eventIds, index + 1, eventMap, rooms, validRoomsForEvent, roomStates, assignments, scheduledSet, options, gap);\n      const withoutCount = assignments.size;\n\n      if (withCount >= withoutCount) {\n        // Placing was better or equal, restore with-placement\n        restoreRoomStates(roomStates, savedStates);\n        assignments.clear();\n        for (const [k, v] of withAssignments) assignments.set(k, v);\n        scheduledSet.clear();\n        for (const s of withScheduled) scheduledSet.add(s);\n      }\n      // Otherwise keep the without-placement result (already in state)\n    }\n  } else {\n    // Cannot place, continue with rest\n    scheduleEvents(eventIds, index + 1, eventMap, rooms, validRoomsForEvent, roomStates, assignments, scheduledSet, options, gap);\n  }\n}\n\nfunction orderRoomsByPreference(rooms: Room[], preferredRoom?: string): Room[] {\n  if (!preferredRoom) return rooms;\n  const preferred = rooms.filter(r => r.id === preferredRoom);\n  const others = rooms.filter(r => r.id !== preferredRoom);\n  return [...preferred, ...others];\n}\n\nfunction findEarliestSlot(\n  roomState: RoomState,\n  earliestStart: number,\n  duration: number,\n  endTime: number,\n  gap: number,\n): number | null {\n  const slots = roomState.slots;\n\n  if (slots.length === 0) {\n    // Room is empty, check if event fits\n    if (earliestStart + duration <