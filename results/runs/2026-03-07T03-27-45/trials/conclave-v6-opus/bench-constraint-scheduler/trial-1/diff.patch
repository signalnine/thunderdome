+    it('handles many events in limited time', () => {
+      // 8 hour window, 10 events each 60 mins, 15 min gap, 1 room
+      // Max fit: floor(480 / 75) = 6 events (60+15=75 each, last needs no gap)
+      // Actually: 6 * 60 + 5 * 15 = 435 <= 480. 7 * 60 + 6 * 15 = 510 > 480
+      const events: Event[] = Array.from({ length: 10 }, (_, i) =>
+        makeEvent({ id: `e${i}`, duration: 60 })
+      );
+      const rooms: Room[] = [makeRoom({ id: 'r1' })];
+
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments.length).toBe(6);
+      expect(result.unscheduled.length).toBe(4);
+    });
+
+    it('prerequisite event that cannot be scheduled makes dependent unscheduled', () => {
+      const events: Event[] = [
+        makeEvent({ id: 'e1', attendees: 100 }), // too big for any room
+        makeEvent({ id: 'e2', prerequisites: ['e1'] }),
+      ];
+      const rooms: Room[] = [makeRoom({ id: 'r1', capacity: 10 })];
+
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.unscheduled).toContain('e1');
+      expect(result.unscheduled).toContain('e2');
+    });
+  });
+});
