+import { describe, it, expect } from 'vitest';
+import { schedule } from './scheduler.js';
+import type { Event, Room, ScheduleOptions } from './types.js';
+
+const defaultOptions: ScheduleOptions = {
+  startTime: 540, // 9:00 AM
+  endTime: 1020,  // 5:00 PM
+};
+
+function makeRoom(overrides: Partial<Room> & { id: string }): Room {
+  return { name: overrides.id, capacity: 50, ...overrides };
+}
+
+function makeEvent(overrides: Partial<Event> & { id: string }): Event {
+  return { name: overrides.id, duration: 60, ...overrides };
+}
