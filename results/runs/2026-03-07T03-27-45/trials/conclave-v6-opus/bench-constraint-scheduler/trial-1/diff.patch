sult.assignments[0].endTime - result.assignments[0].startTime).toBe(60);\n    });\n\n    it('schedules multiple events into multiple rooms', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 60 }),\n        makeEvent({ id: 'e2', duration: 60 }),\n      ];\n      const rooms: Room[] = [\n        makeRoom({ id: 'r1' }),\n        makeRoom({ id: 'r2' }),\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('returns empty assignments and unscheduled for no events', () => {\n      const result = schedule([], [makeRoom({ id: 'r1' })], defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('default attendees is 1', () => {\n      const events: Event[] = [makeEvent({ id: 'e1' })]; // no attendees specified\n      const rooms: Room[] = [makeRoom({ id: 'r1', capacity: 1 })];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n  });\n\n  describe('room capacity constraint', () => {\n    it('does not schedule an event into a room that is too small', () => {\n      const events: Event[] = [makeEvent({ id: 'e1', attendees: 30 })];\n      const rooms: Room[] = [makeRoom({ id: 'r1', capacity: 20 })];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('assigns event to a room with sufficient capacity', () => {\n      const events: Event[] = [makeEvent({ id: 'e1', attendees: 25 })];\n      const rooms: Room[] = [\n        makeRoom({ id: 'r1', capacity: 10 }),\n        makeRoom({ id: 'r2', capacity: 30 }),\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n\n    it('allows exact capacity match', () => {\n      const events: Event[] = [makeEvent({ id: 'e1', attendees: 20 })];\n      const rooms: Room[] = [makeRoom({ id: 'r1', capacity: 20 })];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('time window constraint', () => {\n    it('does not schedule an event that does not fit in the time window', () => {\n      const events: Event[] = [makeEvent({ id: 'e1', duration: 600 })]; // 10 hours\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 600, // only 1 hour window\n      };\n\n      const result = schedule(events, [makeRoom({ id: 'r1' })], options);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('schedules event that exactly fits the time window', () => {\n      const events: Event[] = [makeEvent({ id: 'e1', duration: 60 })];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 600,\n      };\n\n      const result = schedule(events, [makeRoom({ id: 'r1' })], options);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(600);\n    });\n  });\n\n  describe('room gap constraint', () => {\n    it('enforces default 15-minute gap between events in same room', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 60 }),\n        makeEvent({ id: 'e2', duration: 60 }),\n      ];\n      const rooms: Room[] = [makeRoom({ id: 'r1' })];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n      // gap between end of first and start of second must be >= 15\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('uses custom gap when specified', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 60 }),\n        makeEvent({ id: 'e2', duration: 60 }),\n      ];\n      const rooms: Room[] = [makeRoom({ id: 'r1' })];\n      const options: ScheduleOptions = { ...defaultOptions, gap: 30 };\n\n      const result = schedule(events, rooms, options);\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n    });\n\n    it('does not enforce gap between events in different rooms', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 60 }),\n        makeEvent({ id: 'e2', duration: 60 }),\n      ];\n      const rooms: Room[] = [\n        makeRoom({ id: 'r1' }),\n        makeRoom({ id: 'r2' }),\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      // Events can start at the same time in different rooms\n      const r1Event = result.assignments.find(a => a.roomId === 'r1')!;\n      const r2Event = result.assignments.find(a => a.roomId === 'r2')!;\n      // They should be in different rooms; no gap needed\n      expect(r1Event.roomId).not.toBe(r2Event.roomId);\n    });\n\n    it('marks event unscheduled when gap prevents fitting in window', () => {\n      // 2-hour window, two 55-min events with 15-min gap = 125 min needed but only 120 available\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 55 }),\n        makeEvent({ id: 'e2', duration: 55 }),\n      ];\n      const rooms: Room[] = [makeRoom({ id: 'r1' })];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 660, // 2 hour window\n      };\n\n      const result = schedule(events, rooms, options);\n\n      // Only 1 event should fit: 55 + 15 + 55 = 125 > 120\n      expect(result.assignments).toHaveLength(1);\n      expect(result.unscheduled).toHaveLength(1);\n    });\n  });\n\n  describe('prerequisite ordering', () => {\n    it('schedules prerequisite event before dependent event', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 60 }),\n        makeEvent({ id: 'e2', duration: 60, prerequisites: ['e1'] }),\n      ];\n      const rooms: Room[] = [makeRoom({ id: 'r1' })];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(e2.startTime).toBeGreaterThanOrEqual(e1.endTime);\n    });\n\n    it('enforces gap between prerequisite and dependent event', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 60 }),\n        makeEvent({ id: 'e2', duration: 60, prerequisites: ['e1'] }),\n      ];\n      const rooms: Room[] = [\n        makeRoom({ id: 'r1' }),\n        makeRoom({ id: 'r2' }),\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      // Even in different rooms, prerequisite gap applies\n      expect(e2.startTime).toBeGreaterThanOrEqual(e1.endTime + 15);\n    });\n\n    it('handles chain of prerequisites', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 30 }),\n        makeEvent({ id: 'e2', duration: 30, prerequisites: ['e1'] }),\n        makeEvent({ id: 'e3', duration: 30, prerequisites: ['e2'] }),\n      ];\n      const rooms: Room[] = [makeRoom({ id: 'r1' })];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const e3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(e2.startTime).toBeGreaterThanOrEqual(e1.endTime + 15);\n      expect(e3.startTime).toBeGreaterThanOrEqual(e2.endTime + 15);\n    });\n\n    it('handles multiple prerequisites for one event', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 30 }),\n        makeEvent({ id: 'e2', duration: 30 }),\n        makeEvent({ id: 'e3', duration: 30, prerequisites: ['e1', 'e2'] }),\n      ];\n      const rooms: Room[] = [\n        makeRoom({ id: 'r1' }),\n        makeRoom({ id: 'r2' }),\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const e3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(e3.startTime).toBeGreaterThanOrEqual(e1.endTime + 15);\n      expect(e3.startTime).toBeGreaterThanOrEqual(e2.endTime + 15);\n    });\n  });\n\n  describe('prerequisite cycle detection', () => {\n    it('throws error for self-referencing prerequisite', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', prerequisites: ['e1'] }),\n      ];\n      const rooms: Room[] = [makeRoom({ id: 'r1' })];\n\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it('throws error for two-event cycle', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', prerequisites: ['e2'] }),\n        makeEvent({ id: 'e2', prerequisites: ['e1'] }),\n      ];\n      const rooms: Room[] = [makeRoom({ id: 'r1' })];\n\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it('throws error for multi-event cycle', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', prerequisites: ['e3'] }),\n        makeEvent({ id: 'e2', prerequisites: ['e1'] }),\n        makeEvent({ id: 'e3', prerequisites: ['e2'] }),\n      ];\n      const rooms: Room[] = [makeRoom({ id: 'r1' })];\n\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n  });\n\n  describe('preferred room', () => {\n    it('assigns event to preferred room when possible', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', preferredRoom: 'r2' }),\n      ];\n      const rooms: Room[] = [\n        makeRoom({ id: 'r1' }),\n        makeRoom({ id: 'r2' }),\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n\n    it('falls back to another room when preferred room is too small', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', attendees: 30, preferredRoom: 'r1' }),\n      ];\n      const rooms: Room[] = [\n        makeRoom({ id: 'r1', capacity: 10 }),\n        makeRoom({ id: 'r2', capacity: 50 }),\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n\n    it('falls back when preferred room is fully booked', () => {\n      const events: Event[] = [\n        makeEvent({ id: 'e1', duration: 480, preferredRoom: 'r1' }), // fills the day\n        makeEvent({ id: 'e2', duration: 60, preferredRoom: 'r1' }),\n      ];\n      const rooms: Room[] = [\n        makeRoom({ id: 'r1' }),\n        makeRoom({ id: 'r2' }),\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const e2 =