+describe('schedule', () => {
+  describe('basic scheduling', () => {
+    it('schedules a single event into a single room', () => {
+      const events: Event[] = [makeEvent({ id: 'e1' })];
+      const rooms: Room[] = [makeRoom({ id: 'r1' })];
+
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0].eventId).toBe('e1');
+      expect(result.assignments[0].roomId).toBe('r1');
+      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);
+      expect(result.assignments[0].endTime).toBeLessThanOrEqual(1020);
+      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+    });
+
+    it('schedules multiple events into multiple rooms', () => {
+      const events: Event[] = [
+        makeEvent({ id: 'e1', duration: 60 }),
+        makeEvent({ id: 'e2', duration: 60 }),
+      ];
+      const rooms: Room[] = [
+        makeRoom({ id: 'r1' }),
+        makeRoom({ id: 'r2' }),
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('returns empty assignments and unscheduled for no events', () => {
+      const result = schedule([], [makeRoom({ id: 'r1' })], defaultOptions);
+
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('default attendees is 1', () => {
+      const events: Event[] = [makeEvent({ id: 'e1' })]; // no attendees specified
+      const rooms: Room[] = [makeRoom({ id: 'r1', capacity: 1 })];
+
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+  });
+
+  describe('room capacity constraint', () => {
+    it('does not schedule an event into a room that is too small', () => {
+      const events: Event[] = [makeEvent({ id: 'e1', attendees: 30 })];
+      const rooms: Room[] = [makeRoom({ id: 'r1', capacity: 20 })];
+
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+
+    it('assigns event to a room with sufficient capacity', () => {
+      const events: Event[] = [makeEvent({ id: 'e1', attendees: 25 })];
+      const rooms: Room[] = [
+        makeRoom({ id: 'r1', capacity: 10 }),
+        makeRoom({ id: 'r2', capacity: 30 }),
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).toBe('r2');
+    });
+
+    it('allows exact capacity match', () => {
+      const events: Event[] = [makeEvent({ id: 'e1', attendees: 20 })];
+      const rooms: Room[] = [makeRoom({ id: 'r1', capacity: 20 })];
+
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+    });
+  });
+
+  describe('time window constraint', () => {
+    it('does not schedule an event that does not fit in the time window', () => {
+      const events: Event[] = [makeEvent({ id: 'e1', duration: 600 })]; // 10 hours
+      const options: ScheduleOptions = {
+        startTime: 540,
+        endTime: 600, // only 1 hour window
+      };
+
+      const result = schedule(events, [makeRoom({ id: 'r1' })], options);
+
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+
+    it('schedules event that exactly fits the time window', () => {
