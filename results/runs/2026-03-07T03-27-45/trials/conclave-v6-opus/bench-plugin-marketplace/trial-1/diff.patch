lse for nonexistent review', () => {\n    expect(reviews.removeReview(9999)).toBe(false);\n  });\n\n  test('getReviewsByUser returns reviews by a specific user', () => {\n    reviews.addReview({\n      pluginName: 'a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 4,\n      comment: 'a',\n    });\n    reviews.addReview({\n      pluginName: 'b',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'b',\n    });\n    reviews.addReview({\n      pluginName: 'a',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 3,\n      comment: 'c',\n    });\n    const userReviews = reviews.getReviewsByUser('user1');\n    expect(userReviews).toHaveLength(2);\n    expect(userReviews.every(r => r.userId === 'user1')).toBe(true);\n  });\n\n  test('getReviewCount returns count for a plugin', () => {\n    reviews.addReview({\n      pluginName: 'test',\n      pluginVersion: '1.0.0',\n      userId: 'u1',\n      rating: 4,\n      comment: 'a',\n    });\n    reviews.addReview({\n      pluginName: 'test',\n      pluginVersion: '1.0.0',\n      userId: 'u2',\n      rating: 5,\n      comment: 'b',\n    });\n    expect(reviews.getReviewCount('test')).toBe(2);\n  });\n\n  test('getReviewCount returns 0 for unknown plugin', () => {\n    expect(reviews.getReviewCount('nonexistent')).toBe(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":377,"cache_read_input_tokens":37793,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":377},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"87693b9d-61a4-48ec-bc8e-12f5393c970a","uuid":"6fcbe446-d4af-4616-bb15-c11161620d06"}
