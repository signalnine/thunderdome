@@ -0,0 +1,114 @@
+import { describe, test, expect } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: 'result = 42',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  test('returns all service instances', () => {
+    const mp = createMarketplace();
+    expect(mp.registry).toBeDefined();
+    expect(mp.resolver).toBeDefined();
+    expect(mp.runner).toBeDefined();
+    expect(mp.reviews).toBeDefined();
+    expect(mp.deps).toBeDefined();
+    expect(mp.installPlugin).toBeDefined();
+  });
+});
+
+describe('installPlugin', () => {
+  test('installs a plugin with no dependencies', async () => {
+    const mp = createMarketplace();
+    const manifest = makeManifest({ entryPoint: 'result = "installed"' });
+    const result = await mp.installPlugin(manifest);
+    expect(result.sandboxResult.success).toBe(true);
+    expect(result.sandboxResult.output).toBe('installed');
+    expect(result.resolvedDependencies).toEqual([]);
+  });
+
+  test('registers the plugin in the registry', async () => {
+    const mp = createMarketplace();
+    const manifest = makeManifest();
+    await mp.installPlugin(manifest);
+    const found = mp.registry.get('test-plugin');
+    expect(found).not.toBeNull();
+    expect(found!.name).toBe('test-plugin');
+  });
+
+  test('resolves dependencies during install', async () => {
+    const mp = createMarketplace();
+    // Register dependency first
+    mp.registry.register(makeManifest({ name: 'dep-lib', version: '1.2.0', entryPoint: 'result = true' }));
+
+    const manifest = makeManifest({
+      name: 'app',
+      dependencies: { 'dep-lib': '^1.0.0' },
+      entryPoint: 'result = "app"',
+    });
+
+    const result = await mp.installPlugin(manifest);
+    expect(result.resolvedDependencies).toHaveLength(1);
+    expect(result.resolvedDependencies[0].name).toBe('dep-lib');
+    expect(result.resolvedDependencies[0].version).toBe('1.2.0');
+  });
+
+  test('rejects plugin with missing name', async () => {
+    const mp = createMarketplace();
+    const manifest = makeManifest({ name: '' });
+    await expect(mp.installPlugin(manifest)).rejects.toThrow();
+  });
+
+  test('rejects plugin with missing version', async () => {
+    const mp = createMarketplace();
+    const manifest = makeManifest({ version: '' });
+    await expect(mp.installPlugin(manifest)).rejects.toThrow();
+  });
+
+  test('rejects plugin with missing entryPoint', async () => {
+    const mp = createMarketplace();
+    const manifest = makeManifest({ entryPoint: '' });
+    await expect(mp.installPlugin(manifest)).rejects.toThrow();
+  });
+
+  test('rejects plugin with circular dependencies', async () => {
+    const mp = createMarketplace();
+    // Create circular: a -> b -> a
+    mp.registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' }, entryPoint: 'result = true' }));
+    mp.registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' }, entryPoint: 'result = true' }));
+
+    const manifest = makeManifest({
+      name: 'c',
+      dependencies: { a: '^1.0.0' },
+      entryPoint: 'result = true',
+    });
+
+    await expect(mp.installPlugin(manifest)).rejects.toThrow(/circular/i);
+  });
+
+  test('executes the entryPoint in sandbox', async () => {
+    const mp = createMarketplace();
+    const manifest = makeManifest({ entryPoint: 'result = 2 + 2' });
+    const result = await mp.installPlugin(manifest);
+    expect(result.sandboxResult.success).toBe(true);
+    expect(result.sandboxResult.output).toBe(4);
+  });
+
+  test('returns sandbox error for bad entryPoint', async () => {
+    const mp = createMarketplace();
+    const manifest = makeManifest({ entryPoint: 'throw new Error("fail")' });
+    const result = await mp.installPlugin(manifest);
+    expect(result.sandboxResult.success).toBe(false);
+    expect(result.sandboxResult.error).toContain('fail');
+  });
+});
