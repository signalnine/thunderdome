@@ -0,0 +1,135 @@
+import { describe, test, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { DepsService, RegistryService, PluginManifest } from '../types.js';
+
+function makeManifest(
+  name: string,
+  deps: Record<string, string> = {},
+  version = '1.0.0'
+): PluginManifest {
+  return {
+    name,
+    version,
+    description: `${name} plugin`,
+    author: 'tester',
+    dependencies: deps,
+    entryPoint: 'result = true',
+    permissions: [],
+  };
+}
+
+describe('DepsService', () => {
+  let deps: DepsService;
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    deps = createDepsService();
+    registry = createRegistry();
+  });
+
+  test('buildTree returns a node with no dependencies for leaf plugin', () => {
+    registry.register(makeManifest('leaf'));
+    const tree = deps.buildTree('leaf', registry);
+    expect(tree.name).toBe('leaf');
+    expect(tree.version).toBe('1.0.0');
+    expect(tree.dependencies).toEqual([]);
+  });
+
+  test('buildTree returns nested dependency tree', () => {
+    registry.register(makeManifest('app', { lib: '^1.0.0' }));
+    registry.register(makeManifest('lib', { util: '^1.0.0' }));
+    registry.register(makeManifest('util'));
+
+    const tree = deps.buildTree('app', registry);
+    expect(tree.name).toBe('app');
+    expect(tree.dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].name).toBe('lib');
+    expect(tree.dependencies[0].dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].dependencies[0].name).toBe('util');
+  });
+
+  test('detectCycles returns null when no cycles', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b'));
+    expect(deps.detectCycles('a', registry)).toBeNull();
+  });
+
+  test('detectCycles returns cycle path when circular dependency exists', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', { a: '^1.0.0' }));
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles!.length).toBeGreaterThan(0);
+    // The cycle should contain both a and b
+    const flat = cycles!.flat();
+    expect(flat).toContain('a');
+    expect(flat).toContain('b');
+  });
+
+  test('hasCircularDependency returns true for circular deps', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', { a: '^1.0.0' }));
+    expect(deps.hasCircularDependency('a', registry)).toBe(true);
+  });
+
+  test('hasCircularDependency returns false for no circular deps', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b'));
+    expect(deps.hasCircularDependency('a', registry)).toBe(false);
+  });
+
+  test('topologicalSort returns correct order', () => {
+    registry.register(makeManifest('app', { lib: '^1.0.0', util: '^1.0.0' }));
+    registry.register(makeManifest('lib', { util: '^1.0.0' }));
+    registry.register(makeManifest('util'));
+
+    const sorted = deps.topologicalSort('app', registry);
+    // util must come before lib, lib must come before app
+    const utilIdx = sorted.indexOf('util');
+    const libIdx = sorted.indexOf('lib');
+    const appIdx = sorted.indexOf('app');
+    expect(utilIdx).toBeLessThan(libIdx);
+    expect(libIdx).toBeLessThan(appIdx);
+  });
+
+  test('topologicalSort returns single element for leaf', () => {
+    registry.register(makeManifest('leaf'));
+    expect(deps.topologicalSort('leaf', registry)).toEqual(['leaf']);
+  });
+
+  test('flattenDependencies returns all transitive deps', () => {
+    registry.register(makeManifest('app', { lib: '^1.0.0' }));
+    registry.register(makeManifest('lib', { util: '^1.0.0' }));
+    registry.register(makeManifest('util'));
+
+    const flat = deps.flattenDependencies('app', registry);
+    expect(flat).toContain('lib');
+    expect(flat).toContain('util');
+  });
+
+  test('flattenDependencies returns empty for leaf plugin', () => {
+    registry.register(makeManifest('leaf'));
+    expect(deps.flattenDependencies('leaf', registry)).toEqual([]);
+  });
+
+  test('flattenDependencies does not include duplicates', () => {
+    // diamond dependency: app -> lib1, lib2; lib1 -> util; lib2 -> util
+    registry.register(makeManifest('app', { lib1: '^1.0.0', lib2: '^1.0.0' }));
+    registry.register(makeManifest('lib1', { util: '^1.0.0' }));
+    registry.register(makeManifest('lib2', { util: '^1.0.0' }));
+    registry.register(makeManifest('util'));
+
+    const flat = deps.flattenDependencies('app', registry);
+    const uniqueCount = new Set(flat).size;
+    expect(flat.length).toBe(uniqueCount);
+  });
+
+  test('detectCycles detects indirect cycles', () => {
+    registry.register(makeManifest('a', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', { c: '^1.0.0' }));
+    registry.register(makeManifest('c', { a: '^1.0.0' }));
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+  });
+});
