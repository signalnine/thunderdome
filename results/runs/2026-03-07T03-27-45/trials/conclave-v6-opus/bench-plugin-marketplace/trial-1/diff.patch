esolve(constraints, available);\n    expect(resolved).toHaveLength(2);\n    expect(resolved.find(r => r.name === 'foo')).toEqual({\n      name: 'foo',\n      version: '1.5.0',\n      satisfies: '^1.0.0',\n    });\n    expect(resolved.find(r => r.name === 'bar')).toEqual({\n      name: 'bar',\n      version: '2.3.5',\n      satisfies: '~2.3.0',\n    });\n  });\n\n  test('resolve throws when no version satisfies constraint', () => {\n    const constraints: VersionConstraint[] = [\n      { name: 'foo', range: '^5.0.0' },\n    ];\n    const available = {\n      foo: ['1.0.0', '2.0.0'],\n    };\n    expect(() => resolver.resolve(constraints, available)).toThrow();\n  });\n\n  test('resolve throws when plugin not found in available', () => {\n    const constraints: VersionConstraint[] = [\n      { name: 'missing', range: '^1.0.0' },\n    ];\n    const available = {};\n    expect(() => resolver.resolve(constraints, available)).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":372,"cache_read_input_tokens":32958,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":372},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"87693b9d-61a4-48ec-bc8e-12f5393c970a","uuid":"e1dbf93f-a198-45fc-a7c8-7f39a5718974"}
