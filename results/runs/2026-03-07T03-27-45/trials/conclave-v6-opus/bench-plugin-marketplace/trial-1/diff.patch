+  };
+}
+
+describe('RegistryService', () => {
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  test('register and get a plugin', () => {
+    const manifest = makeManifest();
+    registry.register(manifest);
+    const result = registry.get('test-plugin');
+    expect(result).toEqual(manifest);
+  });
+
+  test('get returns null for unknown plugin', () => {
+    expect(registry.get('nonexistent')).toBeNull();
+  });
+
+  test('getVersion returns specific version', () => {
+    const v1 = makeManifest({ version: '1.0.0' });
+    const v2 = makeManifest({ version: '2.0.0' });
+    registry.register(v1);
+    registry.register(v2);
+    expect(registry.getVersion('test-plugin', '1.0.0')).toEqual(v1);
+    expect(registry.getVersion('test-plugin', '2.0.0')).toEqual(v2);
+  });
+
+  test('getVersion returns null for unknown version', () => {
+    registry.register(makeManifest());
+    expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();
+  });
+
+  test('get returns latest registered version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const result = registry.get('test-plugin');
+    expect(result!.version).toBe('2.0.0');
+  });
+
+  test('list returns all plugins (latest versions)', () => {
+    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'a', version: '2.0.0' }));
+    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));
+    const list = registry.list();
+    expect(list).toHaveLength(2);
+    expect(list.map(p => p.name).sort()).toEqual(['a', 'b']);
+  });
+
+  test('search finds plugins by name', () => {
+    registry.register(makeManifest({ name: 'auth-plugin' }));
+    registry.register(makeManifest({ name: 'logging-plugin' }));
+    registry.register(makeManifest({ name: 'auth-middleware' }));
+    const results = registry.search('auth');
+    expect(results).toHaveLength(2);
