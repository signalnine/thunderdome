ts.ORDER_CREATED, {\n        orderId: 'order1',\n        userId: 'user1',\n        cartId: 'cart1',\n        total: 50,\n      });\n\n      await bus.emit(Events.ORDER_STATUS_CHANGED, {\n        orderId: 'order1',\n        status: OrderStatus.CONFIRMED,\n        previousStatus: OrderStatus.PENDING,\n      });\n\n      expect(notifications.getNotifications('user1')).toEqual([]);\n    });\n  });\n\n  describe('payment notifications', () => {\n    it('records notification when payment is processed for subscribed user', async () => {\n      notifications.subscribe('user1');\n\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'order1',\n        userId: 'user1',\n        cartId: 'cart1',\n        total: 50,\n      });\n\n      await bus.emit(Events.PAYMENT_PROCESSED, {\n        orderId: 'order1',\n        status: PaymentStatus.SUCCESS,\n        transactionId: 'tx1',\n      });\n\n      const notifs = notifications.getNotifications('user1');\n      expect(notifs).toHaveLength(1);\n      expect(notifs[0].type).toBe('payment');\n    });\n  });\n\n  describe('getNotifications', () => {\n    it('returns empty array for unknown user', () => {\n      expect(notifications.getNotifications('unknown')).toEqual([]);\n    });\n\n    it('returns notifications with timestamps', async () => {\n      notifications.subscribe('user1');\n\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'order1',\n        userId: 'user1',\n        cartId: 'cart1',\n        total: 50,\n      });\n\n      await bus.emit(Events.ORDER_STATUS_CHANGED, {\n        orderId: 'order1',\n        status: OrderStatus.SHIPPED,\n        previousStatus: OrderStatus.CONFIRMED,\n      });\n\n      const notifs = notifications.getNotifications('user1');\n      expect(notifs).toHaveLength(1);\n      expect(notifs[0].timestamp).toBeDefined();\n      expect(typeof notifs[0].timestamp).toBe('number');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage"