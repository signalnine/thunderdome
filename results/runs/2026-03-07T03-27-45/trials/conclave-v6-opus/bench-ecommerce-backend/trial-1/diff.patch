+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01VEKTRacQX6C6arTrLsPDF4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XcZxLC8SCvyiSMwvth15iE","name":"Write","input":{"file_path":"/workspace/tests/analytics.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  describe('getEventCount', () => {\n    it('counts events by type', async () => {\n      await bus.emit(Events.PRODUCT_CREATED, {\n        productId: 'p1',\n        name: 'Widget',\n        price: 10,\n        category: 'gadgets',\n      });\n      await bus.emit(Events.PRODUCT_CREATED, {\n        productId: 'p2',\n        name: 'Gizmo',\n        price: 20,\n        category: 'gadgets',\n      });\n\n      expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    });\n\n    it('returns 0 for untracked event type', () => {\n      expect(analytics.getEventCount('nonexistent')).toBe(0);\n    });\n  });\n\n  describe('getRevenue', () => {\n    it('tracks revenue from successful payments', async () => {\n      await bus.emit(Events.PAYMENT_PROCESSED, {\n        orderId: 'order1',\n        status: PaymentStatus.SUCCESS,\n        transactionId: 'tx1',\n      });\n\n      // Need to also track the order amount - analytics listens to ORDER_CREATED for amounts\n      // Actually, let's re-think: the PaymentProcessedEvent doesn't carry amount.\n      // Revenue tracking needs to correlate with order totals from ORDER_CREATED events.\n\n      // First create order\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'order1',\n        userId: 'user1',\n        cartId: 'cart1',\n        total: 100,\n      });\n\n      await bus.emit(Events.PAYMENT_PROCESSED, {\n        orderId: 'order1',\n        status: PaymentStatus.SUCCESS,\n        transactionId: 'tx1',\n      });\n\n      expect(analytics.getRevenue()).toBe(100);\n    });\n\n    it('does not count failed payments', async () => {\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'order1',\n        userId: 'user1',\n        cartId: 'cart1',\n        total: 100,\n      });\n\n      await bus.emit(Events.PAYMENT_PROCESSED, {\n        orderId: 'order1',\n        status: PaymentStatus.FAILED,\n        error: 'declined',\n      });\n\n      expect(analytics.getRevenue()).toBe(0);\n    });\n\n    it('returns 0 when no payments', () => {\n      expect(analytics.getRevenue()).toBe(0);\n    });\n  });\n\n  describe('getConversionRate', () => {\n    it('calculates orders / unique carts', async () => {\n      // Create 4 carts (from CART_UPDATED events with unique cartIds)\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart1', userId: 'u1', items: [] });\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart2', userId: 'u2', items: [] });\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart3', userId: 'u3', items: [] });\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart4', userId: 'u4', items: [] });\n\n      // Create 2 orders\n      await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'cart1', total: 10 });\n      await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'cart2', total: 20 });\n\n      expect(analytics.getConversionRate()).toBe(0.5); // 2 orders / 4 carts\n    });\n\n    it('returns 0 when no carts', () => {\n      expect(analytics.getConversionRate()).toBe(0);\n    });\n\n    it('does not double-count carts from duplicate events', async () => {\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart1', userId: 'u1', items: [{ productId: 'p1', quantity: 2 }] });\n\n      await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'cart1', total: 10 });\n\n      expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 unique cart\n    });\n  });\n\n  describe('getTopProducts', () => {\n    it('ranks products by order quantity', async () => {\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'o1',\n        userId: 'u1',\n        cartId: 'cart1',\n        total: 100,\n      });\n\n      // Analytics needs to know what products are in an order.\n      // It can track this via CART_UPDATED events before ORDER_CREATED.\n      // The ORDER_CREATED event has a cartId - analytics needs to correlate.\n\n      // Let's set up carts first\n      await bus.emit(Events.CART_UPDATED, {\n        cartId: 'cart1',\n        userId: 'u1',\n        items: [\n          { productId: 'p1', quantity: 3 },\n          { productId: 'p2', quantity: 1 },\n        ],\n      });\n\n      await bus.emit(Events.CART_UPDATED, {\n        cartId: 'cart2',\n        userId: 'u2',\n        items: [\n          { productId: 'p2', quantity: 5 },\n        ],\n      });\n\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'o1',\n        userId: 'u1',\n        cartId: 'cart1',\n        total: 50,\n      });\n\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'o2',\n        userId: 'u2',\n        cartId: 'cart2',\n        total: 100,\n      });\n\n      const top = analytics.getTopProducts(2);\n      expect(top).toHaveLength(2);\n      // p2 has 5+1=6 total, p1 has 3\n      // Wait - the first ORDER_CREATED was before cart data. Let me restructure.\n      // Actually the cart events come first, then order events reference them.\n      expect(top[0].productId).toBe('p2');\n      expect(top[0].count).toBe(6);\n      expect(top[1].productId).toBe('p1');\n      expect(top[1].count).toBe(3);\n    });\n\n    it('limits results', async () => {\n      await bus.emit(Events.CART_UPDATED, {\n        cartId: 'cart1',\n        userId: 'u1',\n        items: [\n          { productId: 'p1', quantity: 3 },\n          { productId: 'p2', quantity: 1 },\n          { productId: 'p3', quantity: 2 },\n        ],\n      });\n\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'o1',\n        userId: 'u1',\n        cartId: 'cart1',\n        total: 50,\n      });\n\n      const top = analytics.getTopProducts(1);\n      expect(top).toHaveLength(1);\n      expect(top[0].productId).toBe('p1');\n      expect(top[0].count).toBe(3);\n    });\n\n    it('returns empty array when no orders', () => {\n      expect(analytics.getTopProducts(5)).toEqual([]);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":449,"cache_read_input_tokens":56325,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":449},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e63d89f8-9b83-4182-a13a-a5accfc0399a","uuid":"0acf8efb-b5b4-4b64-b0d9-cecc5800e9ec"}
