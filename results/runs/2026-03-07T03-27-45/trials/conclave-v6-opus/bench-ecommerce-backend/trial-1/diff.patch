nique cartIds)\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart1', userId: 'u1', items: [] });\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart2', userId: 'u2', items: [] });\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart3', userId: 'u3', items: [] });\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart4', userId: 'u4', items: [] });\n\n      // Create 2 orders\n      await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'cart1', total: 10 });\n      await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'cart2', total: 20 });\n\n      expect(analytics.getConversionRate()).toBe(0.5); // 2 orders / 4 carts\n    });\n\n    it('returns 0 when no carts', () => {\n      expect(analytics.getConversionRate()).toBe(0);\n    });\n\n    it('does not double-count carts from duplicate events', async () => {\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });\n      await bus.emit(Events.CART_UPDATED, { cartId: 'cart1', userId: 'u1', items: [{ productId: 'p1', quantity: 2 }] });\n\n      await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'cart1', total: 10 });\n\n      expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 unique cart\n    });\n  });\n\n  describe('getTopProducts', () => {\n    it('ranks products by order quantity', async () => {\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'o1',\n        userId: 'u1',\n        cartId: 'cart1',\n        total: 100,\n      });\n\n      // Analytics needs to know what products are in an order.\n      // It can track this via CART_UPDATED events before ORDER_CREATED.\n      // The ORDER_CREATED event has a cartId - analytics needs to correlate.\n\n      // Let's set up carts first\n      await bus.emit(Events.CART_UPDATED, {\n        cartId: 'cart1',\n        userId: 'u1',\n        items: [\n          { productId: 'p1', quantity: 3 },\n          { productId: 'p2', quantity: 1 },\n        ],\n      });\n\n      await bus.emit(Events.CART_UPDATED, {\n        cartId: 'cart2',\n        userId: 'u2',\n        items: [\n          { productId: 'p2', quantity: 5 },\n        ],\n      });\n\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'o1',\n        userId: 'u1',\n        cartId: 'cart1',\n        total: 50,\n      });\n\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'o2',\n        userId: 'u2',\n        cartId: 'cart2',\n        total: 100,\n      });\n\n      const top = analytics.getTopProducts(2);\n      expect(top).toHaveLength(2);\n      // p2 has 5+1=6 total, p1 has 3\n      // Wait - the first ORDER_CREATED was before cart data. Let me restructure.\n      // Actually the cart events come first, then order events reference them.\n      expect(top[0].productId).toBe('p2');\n      expect(top[0].count).toBe(6);\n      expect(top[1].productId).toBe('p1');\n      expect(top[1].count).toBe(3);\n    });\n\n    it('limits results', async () => {\n      await bus.emit(Events.CART_UPDATED, {\n        cartId: 'cart1',\n        userId: 'u1',\n        items: [\n          { productId: 'p1', quantity: 3 },\n          { productId: 'p2', quantity: 1 },\n          { productId: 'p3', quantity: 2 },\n        ],\n      });\n\n      await bus.emit(Events.ORDER_CREATED, {\n        orderId: 'o1',\n        userId: 'u1',\n        cartId: 'cart1',\n        total: 50,\n      });\n\n      const top = analytics.getTopProducts(1);\n      expect(top).toHaveLength(1);\n      expect(top[0].productId).toBe('p1');\n      expect(top[0].count).toBe(3);\n    });\n\n    it('returns empty array when no orders', () => {\n      expect(analytics.getTopProducts(5)).toEqual([]);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":117,"oldLines":18,"newStart":117,"newLines":7,"lines":[" ","   describe('getTopProducts', () => {","     it('ranks products by order quantity', async () => {","-      await bu