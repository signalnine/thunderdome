new file mode 100644
index 0000000..8524ca7
--- /dev/null
+++ b/src/inventory/index.ts
@@ -0,0 +1,72 @@
+import { EventBus } from '../bus.js';
+import { InventoryService, Events, InventoryUpdatedEvent, LowStockAlertEvent } from '../types.js';
+
+interface StockEntry {
+  quantity: number;
+  threshold: number;
+}
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  const stock = new Map<string, StockEntry>();
+
+  function getEntry(productId: string): StockEntry {
+    let entry = stock.get(productId);
+    if (!entry) {
+      entry = { quantity: 0, threshold: 0 };
+      stock.set(productId, entry);
+    }
+    return entry;
+  }
+
+  function checkLowStock(productId: string, entry: StockEntry): void {
+    if (entry.threshold > 0 && entry.quantity < entry.threshold) {
+      void bus.emit(Events.LOW_STOCK_ALERT, {
+        productId,
+        currentQuantity: entry.quantity,
+        threshold: entry.threshold,
+      } satisfies LowStockAlertEvent);
+    }
+  }
+
+  return {
+    setStock(productId: string, quantity: number): void {
+      const entry = getEntry(productId);
+      entry.quantity = quantity;
+      void bus.emit(Events.INVENTORY_UPDATED, {
+        productId,
+        quantity,
+      } satisfies InventoryUpdatedEvent);
+      checkLowStock(productId, entry);
+    },
+
+    getStock(productId: string): number {
+      return stock.get(productId)?.quantity ?? 0;
+    },
+
+    reserve(productId: string, quantity: number): boolean {
+      const entry = stock.get(productId);
+      if (!entry || entry.quantity < quantity) return false;
+      entry.quantity -= quantity;
+      void bus.emit(Events.INVENTORY_UPDATED, {
+        productId,
+        quantity: entry.quantity,
+      } satisfies InventoryUpdatedEvent);
+      checkLowStock(productId, entry);
+      return true;
+    },
+
+    release(productId: string, quantity: number): void {
+      const entry = getEntry(productId);
+      entry.quantity += quantity;
+      void bus.emit(Events.INVENTORY_UPDATED, {
+        productId,
+        quantity: entry.quantity,
+      } satisfies InventoryUpdatedEvent);
+    },
+
+    setLowStockThreshold(productId: string, threshold: number): void {
+      const entry = getEntry(productId);
+      entry.threshold = threshold;
+    },
+  };
+}
diff --git a/src/notifications/index.ts b/src/notifications/index.ts
new file mode 100644
index 0000000..c55029a
--- /dev/null
+++ b/src/notifications/index.ts
@@ -0,0 +1,72 @@
+import { EventBus } from '../bus.js';
+import {
+  NotificationService,
+  Events,
+  OrderCreatedEvent,
+  OrderStatusChangedEvent,
+  PaymentProcessedEvent,
+} from '../types.js';
+
+interface Notification {
+  type: string;
+  message: string;
+  timestamp: number;
+}
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const subscribers = new Set<string>();
+  const notifications = new Map<string, Notification[]>();
+  const orderToUser = new Map<string, string>();
+
+  function addNotification(userId: string, type: string, message: string): void {
+    if (!subscribers.has(userId)) return;
+    let list = notifications.get(userId);
+    if (!list) {
+      list = [];
+      notifications.set(userId, list);
+    }
+    list.push({ type, message, timestamp: Date.now() });
+  }
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const event = payload as OrderCreatedEvent;
+    orderToUser.set(event.orderId, event.userId);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {
+    const event = payload as OrderStatusChangedEvent;
+    const userId = orderToUser.get(event.orderId);
+    if (userId) {
+      addNotification(
+        userId,
+        'order_status',
+        `Order ${event.orderId} status changed from ${event.previousStatus} to ${event.status}`,
+      );
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const event = payload as PaymentProcessedEvent;
+    const userId = orderToUser.get(event.orderId);
+    if (userId) {
+      addNotification(
+        userId,
+        'payment',
+        `Payment for order ${event.orderId}: ${event.status}`,
+      );
+    }
+  });
+
+  return {
+    subscribe(userId: string): void {
+      subscribers.add(userId);
+      if (!notifications.has(userId)) {
+        notifications.set(userId, []);
+      }
+    },
+
+    getNotifications(userId: string) {
+      return (notifications.get(userId) ?? []).map(n => ({ ...n }));
+    },
+  };
+}
