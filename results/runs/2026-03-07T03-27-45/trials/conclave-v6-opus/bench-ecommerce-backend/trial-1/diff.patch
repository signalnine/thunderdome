+++ b/src/orders/index.ts
@@ -0,0 +1,53 @@
+import { v4 as uuid } from 'uuid';
+import { EventBus } from '../bus.js';
+import { OrderService, OrderStatus, Events, OrderCreatedEvent, OrderStatusChangedEvent } from '../types.js';
+
+interface Order {
+  id: string;
+  userId: string;
+  cartId: string;
+  status: OrderStatus;
+  total: number;
+}
+
+export function createOrderService(bus: EventBus): OrderService {
+  const orders = new Map<string, Order>();
+
+  return {
+    createOrder(userId: string, cartId: string, total: number): string {
+      const id = uuid();
+      orders.set(id, { id, userId, cartId, status: OrderStatus.PENDING, total });
+      void bus.emit(Events.ORDER_CREATED, {
+        orderId: id,
+        userId,
+        cartId,
+        total,
+      } satisfies OrderCreatedEvent);
+      return id;
+    },
+
+    getOrder(orderId: string) {
+      const o = orders.get(orderId);
+      if (!o) return null;
+      return { id: o.id, userId: o.userId, status: o.status, total: o.total };
+    },
+
+    updateStatus(orderId: string, status: OrderStatus): void {
+      const o = orders.get(orderId);
+      if (!o) return;
+      const previousStatus = o.status;
+      o.status = status;
+      void bus.emit(Events.ORDER_STATUS_CHANGED, {
+        orderId,
+        status,
+        previousStatus,
+      } satisfies OrderStatusChangedEvent);
+    },
+
+    listOrders(userId: string) {
+      return Array.from(orders.values())
+        .filter(o => o.userId === userId)
+        .map(o => ({ id: o.id, status: o.status, total: o.total }));
+    },
+  };
+}
diff --git a/src/payment/index.ts b/src/payment/index.ts
new file mode 100644
index 0000000..5332809
--- /dev/null
+++ b/src/payment/index.ts
@@ -0,0 +1,54 @@
+import { v4 as uuid } from 'uuid';
+import { EventBus } from '../bus.js';
+import { PaymentService, PaymentStatus, Events, PaymentProcessedEvent } from '../types.js';
+
+export interface PaymentOptions {
+  simulateFailure?: boolean;
+  simulateTimeout?: boolean;
+}
+
+export function createPaymentService(bus: EventBus, options?: PaymentOptions): PaymentService {
+  const transactions = new Map<string, { orderId: string; amount: number; refunded: boolean }>();
+
+  return {
+    async processPayment(orderId: string, amount: number) {
+      if (options?.simulateTimeout) {
+        const result = { status: PaymentStatus.TIMEOUT, error: 'Payment timed out' };
+        await bus.emit(Events.PAYMENT_PROCESSED, {
+          orderId,
+          status: PaymentStatus.TIMEOUT,
+          error: 'Payment timed out',
+        } satisfies PaymentProcessedEvent);
+        return result;
+      }
+
+      if (options?.simulateFailure) {
+        const result = { status: PaymentStatus.FAILED, error: 'Payment failed' };
+        await bus.emit(Events.PAYMENT_PROCESSED, {
+          orderId,
+          status: PaymentStatus.FAILED,
+          error: 'Payment failed',
+        } satisfies PaymentProcessedEvent);
+        return result;
+      }
+
+      const transactionId = uuid();
+      transactions.set(transactionId, { orderId, amount, refunded: false });
+
+      const result = { status: PaymentStatus.SUCCESS, transactionId };
+      await bus.emit(Events.PAYMENT_PROCESSED, {
+        orderId,
+        status: PaymentStatus.SUCCESS,
+        transactionId,
+      } satisfies PaymentProcessedEvent);
+      return result;
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      const tx = transactions.get(transactionId);
+      if (!tx || tx.refunded) return false;
+      tx.refunded = true;
+      return true;
+    },
+  };
+}
