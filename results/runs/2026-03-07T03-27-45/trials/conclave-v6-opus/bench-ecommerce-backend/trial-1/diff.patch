ring): void {\n      subscribers.add(userId);\n      if (!notifications.has(userId)) {\n        notifications.set(userId, []);\n      }\n    },\n\n    getNotifications(userId: string) {\n      return (notifications.get(userId) ?? []).map(n => ({ ...n }));\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":255,"cache_read_input_tokens":54370,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":255},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e63d89f8-9b83-4182-a13a-a5accfc0399a","uuid":"a0eb0e6d-ebd3-4932-8731-badc78cd4b29"}
