rs', () => {\n    it('lists orders for a user', () => {\n      orders.createOrder('user1', 'cart1', 10);\n      orders.createOrder('user2', 'cart2', 20);\n      orders.createOrder('user1', 'cart3', 30);\n\n      const list = orders.listOrders('user1');\n      expect(list).toHaveLength(2);\n      expect(list.every(o => 'id' in o && 'status' in o && 'total' in o)).toBe(true);\n    });\n\n    it('returns empty array for user with no orders', () => {\n      expect(orders.listOrders('nobody')).toEqual([]);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
