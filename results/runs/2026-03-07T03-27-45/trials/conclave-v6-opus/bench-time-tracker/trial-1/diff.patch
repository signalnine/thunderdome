onst tracker = new TimeTracker({ filePath: trackPath(makeTempPath()) });\n    expect(() => tracker.stop()).toThrow();\n  });\n});\n\ndescribe(\"TimeTracker - Starting and Stopping Timers\", () => {\n  test(\"start creates an entry with task name and startTime\", () => {\n    const tracker = new TimeTracker({ filePath: trackPath(makeTempPath()) });\n    const before = new Date();\n    const entry = tracker.start(\"coding\");\n    const after = new Date();\n\n    expect(entry.task).toBe(\"coding\");\n    expect(entry.endTime).toBeNull();\n    const startDate = new Date(entry.startTime);\n    expect(startDate.getTime()).toBeGreaterThanOrEqual(before.getTime());\n    expect(startDate.getTime()).toBeLessThanOrEqual(after.getTime());\n  });\n\n  test(\"stop sets endTime on the running entry\", () => {\n    const tracker = new TimeTracker({ filePath: trackPath(makeTempPath()) });\n    tracker.start(\"coding\");\n    const before = new Date();\n    const entry = tracker.stop();\n    const after = new Date();\n\n    expect(entry.task).toBe(\"coding\");\n    expect(entry.endTime).not.toBeNull();\n    const endDate = new Date(entry.endTime!);\n    expect(endDate.getTime()).toBeGreaterThanOrEqual(before.getTime());\n    expect(endDate.getTime()).toBeLessThanOrEqual(after.getTime());\n  });\n\n  test(\"starting a new timer auto-stops the previous one\", () => {\n    const tracker = new TimeTracker({ filePath: trackPath(makeTempPath()) });\n    tracker.start(\"task1\");\n    const entry2 = tracker.start(\"task2\");\n\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(2);\n    expect(entries[0].task).toBe(\"task1\");\n    expect(entries[0].endTime).not.toBeNull();\n    expect(entries[1].task).toBe(\"task2\");\n    expect(entries[1].endTime).toBeNull();\n    expect(entry2.task).toBe(\"task2\");\n  });\n\n  test(\"stop after auto-stop throws error (only one running)\", () => {\n    const tracker = new TimeTracker({ filePath: trackPath(makeTempPath()) });\n    tracker.start(\"task1\");\n    tracker.start(\"task2\");\n    tracker.stop(); // stops task2\n    expect(() => tracker.stop()).toThrow(); // nothing running\n  });\n});\n\ndescribe(\"TimeTracker - Persistence\", () => {\n  test(\"entries persist to JSON file and can be reloaded\", () => {\n    const filePath = trackPath(makeTempPath());\n    const tracker1 = new TimeTracker({ filePath });\n    tracker1.start(\"coding\");\n    tracker1.stop();\n    tracker1.start(\"review\");\n    tracker1.stop();\n\n    const tracker2 = new TimeTracker({ filePath });\n    const entries = tracker2.getEntries();\n    expect(entries).toHaveLength(2);\n    expect(entries[0].task).toBe(\"coding\");\n    expect(entries[1].task).toBe(\"review\");\n  });\n\n  test(\"auto-creates directories for persistence path\", () => {\n    const filePath = trackPath(makeTempNestedPath());\n    const tracker = new TimeTracker({ filePath });\n    tracker.start(\"coding\");\n    tracker.stop();\n\n    expect(fs.existsSync(filePath)).toBe(true);\n    const data = JSON.parse(fs.readFileSync(filePath, \"utf-8\"));\n    expect(data).toHaveLength(1);\n  });\n\n  test(\"handles missing file gracefully on first load\", () => {\n    const filePath = trackPath(makeTempPath());\n    // Don't create any file beforehand\n    const tracker = new TimeTracker({ filePath });\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(0);\n  });\n});\n\ndescribe(\"TimeTracker - Querying Entries\", () => {\n  test(\"getEntries returns all entries\", () => {\n    const tracker = new TimeTracker({ filePath: trackPath(makeTempPath()) });\n    tracker.start(\"task1\");\n    tracker.stop();\n    tracker.start(\"task2\");\n    tracker.stop();\n    tracker.start(\"task3\");\n    tracker.stop();\n\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(3);\n  });\n\n  test(\"getEntries filters by from date\", () => {\n    const filePath = trackPath(makeTempPath());\n    // Manually write entries with known dates\n    const entries = [\n      { task: \"old\", startTime: \"2024-01-01T00:00:00.000Z\", endTime: \"2024-01-01T01:00:00.000Z\" },\n      { task: \"new\", startTime: \"2024-06-01T00:00:00.000Z\", endTime: \"2024-06-01T01:00:00.000Z\" },\n    ];\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, JSON.stringify(entries));\n\n    const tracker = new TimeTracker({ filePath });\n    const filtered = tracker.getEntries({ from: new Date(\"2024-03-01T00:00:00.000Z\") });\n    expect(filtered).toHaveLength(1);\n    expect(filtered[0].task).toBe(\"new\");\n  });\n\n  test(\"getEntries filters by to date\", () => {\n    const filePath = trackPath(makeTempPath());\n    const entries = [\n      { task: \"old\", startTime: \"2024-01-01T00:00:00.000Z\", endTime: \"2024-01-01T01:00:00.000Z\" },\n      { task: \"new\", startTime: \"2024-06-01T00:00:00.000Z\", endTime: \"2024-06-01T01:00:00.000Z\" },\n    ];\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, JSON.stringify(entries));\n\n    const tracker = new TimeTracker({ filePath });\n    const filtered = tracker.getEntries({ to: new Date(\"2024-03-01T00:00:00.000Z\") });\n    expect(filtered).toHaveLength(1);\n    expect(filtered[0].task).toBe(\"old\");\n  });\n\n  test(\"getEntries filters by from and to date\", () => {\n    const filePath = trackPath(makeTempPath());\n    const entries = [\n      { task: \"jan\", startTime: \"2024-01-15T00:00:00.000Z\", endTime: \"2024-01-15T01:00:00.000Z\" },\n      { task: \"mar\", startTime: \"2024-03-15T00:00:00.000Z\", endTime: \"2024-03-15T01:00:00.000Z\" },\n      { task: \"jun\", startTime: \"2024-06-15T00:00:00.000Z\", endTime: \"2024-06-15T01:00:00.000Z\" },\n    ];\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, JSON.stringify(entries));\n\n    const tracker = new TimeTracker({ filePath });\n    const filtered = tracker.getEntries({\n      from: new Date(\"2024-02-01T00:00:00.000Z\"),\n      to: new Date(\"2024-05-01T00:00:00.000Z\"),\n    });\n    expect(filtered).toHaveLength(1);\n    expect(filtered[0].task).toBe(\"mar\");\n  });\n});\n\ndescribe(\"TimeTracker - Summarizing Time\", () => {\n  test(\"getSummary returns total ms per task\", () => {\n    const filePath = trackPath(makeTempPath());\n    const entries = [\n      { task: \"coding\", startTime: \"2024-01-01T00:00:00.000Z\", endTime: \"2024-01-01T01:00:00.000Z\" },\n      { task: \"review\", startTime: \"2024-01-01T01:00:00.000Z\", endTime: \"2024-01-01T01:30:00.000Z\" },\n      { task: \"coding\", startTime: \"2024-01-01T02:00:00.000Z\", endTime: \"2024-01-01T03:00:00.000Z\" },\n    ];\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, JSON.stringify(entries));\n\n    const tracker = new TimeTracker({ filePath });\n    const summary = tracker.getSummary();\n    expect(summary[\"coding\"]).toBe(2 * 60 * 60 * 1000); // 2 hours\n    expect(summary[\"review\"]).toBe(30 * 60 * 1000); // 30 minutes\n  });\n\n  test(\"getSummary uses current time for running tasks\", () => {\n    const tracker = new TimeTracker({ filePath: trackPath(makeTempPath()) });\n    const before = Date.now();\n    tracker.start(\"running-task\");\n    const summary = tracker.getSummary();\n    const after = Date.now();\n\n    expect(summary[\"running-task\"]).toBeGreaterThanOrEqual(0);\n    expect(summary[\"running-task\"]).toBeLessThanOrEqual(after - before + 10); // small tolerance\n  });\n});\n\ndescribe(\"TimeTracker - Unicode Support\", () => {\n  test(\"handles unicode task names\", () => {\n    const tracker = new TimeTracker({ filePath: trackPath(makeTempPath()) });\n    tracker.start(\"编码任务\");\n    tracker.stop();\n\n    const entries = tracker.getEntries();\n    expect(entries[0].task).toBe(\"编码任务\");\n  });\n\n  test(\"handles emoji task names\", () => {\n    const tracker = new TimeTracker({ filePath: 