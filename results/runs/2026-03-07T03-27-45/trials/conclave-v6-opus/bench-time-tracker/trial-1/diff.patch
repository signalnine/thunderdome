+export interface TimeEntry {
+  task: string;
+  startTime: string;
+  endTime: string | null;
+}
+
+export interface TimeTrackerOptions {
+  filePath: string;
+}
+
+export interface DateRangeFilter {
+  from?: Date;
+  to?: Date;
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
