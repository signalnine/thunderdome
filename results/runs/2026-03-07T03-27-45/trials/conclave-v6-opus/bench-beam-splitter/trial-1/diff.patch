@@ -0,0 +1,106 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+function findSource(grid: string[][]): [number, number] {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return [0, col];
+  }
+  throw new Error('No source found');
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sRow, sCol] = findSource(grid);
+  const visited = new Set<string>();
+  visited.add(`${sRow},${sCol}`);
+
+  const seen = new Set<string>();
+  const queue: Array<[number, number, Direction]> = [[sRow, sCol, 'down']];
+
+  while (queue.length > 0) {
+    const [r, c, dir] = queue.pop()!;
+    const key = `${r},${c},${dir}`;
+    if (seen.has(key)) continue;
+    seen.add(key);
+
+    const [nr, nc] = advance(r, c, dir);
+    if (!inBounds(nr, nc, rows, cols)) continue;
+
+    visited.add(`${nr},${nc}`);
+
+    if (grid[nr][nc] === '^') {
+      queue.push([nr, nc, 'down-left']);
+      queue.push([nr, nc, 'down-right']);
+    } else {
+      queue.push([nr, nc, dir]);
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sRow, sCol] = findSource(grid);
+
+  // Process beams row by row. For each beam state (col, direction), track path count.
+  // Use a map from "col,dir" to bigint path count.
+  // Process one step at a time, advancing all beams.
+  type BeamState = string; // "col,dir"
+
+  let current = new Map<BeamState, bigint>();
+  current.set(`${sCol},down`, 1n);
+
+  let totalPaths = 0n;
+  let currentRow = sRow;
+
+  while (current.size > 0 && currentRow < rows) {
+    const next = new Map<BeamState, bigint>();
+
+    for (const [stateKey, count] of current) {
+      const commaIdx = stateKey.lastIndexOf(',');
+      const col = parseInt(stateKey.substring(0, commaIdx));
+      const dir = stateKey.substring(commaIdx + 1) as Direction;
+
+      const [nr, nc] = advance(currentRow, col, dir);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        totalPaths += count;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        const leftKey = `${nc},down-left`;
+        const rightKey = `${nc},down-right`;
+        next.set(leftKey, (next.get(leftKey) ?? 0n) + count);
+        next.set(rightKey, (next.get(rightKey) ?? 0n) + count);
+      } else {
+        const nextKey = `${nc},${dir}`;
+        next.set(nextKey, (next.get(nextKey) ?? 0n) + count);
+      }
+    }
+
+    current = next;
+    currentRow++;
+  }
+
+  // Any beams still active after processing last row exit the grid
+  for (const count of current.values()) {
+    totalPaths += count;
+  }
+
+  return totalPaths;
+}
