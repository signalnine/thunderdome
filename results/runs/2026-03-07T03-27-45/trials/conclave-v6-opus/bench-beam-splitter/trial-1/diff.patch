+import { describe, test, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  test('single source cell with no rows below', () => {
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  test('beam travels straight down with no splitters', () => {
+    // S
+    // .
+    // .
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('beam hits one splitter and splits', () => {
+    // . S . . .
+    // . . . . .
+    // . ^ . . .
+    // . . . . .
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2)
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  test('beam hits two splitters in cascade', () => {
+    // . S . . .
+    // . ^ . . .
+    // ^ . ^ . .
+    // . . . . .
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) — (3,-1) is out of bounds
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  test('beam absorbed when going out of bounds left', () => {
+    // S .
+    // ^ .
+    // . .
+    const grid = [
+      ['S', '.'],
+      ['^', '.'],
+      ['.', '.'],
+    ];
+    // (0,0), (1,0) hit splitter. down-left (2,-1) absorbed, down-right (2,1) visits.
+    // Visited: (0,0), (1,0), (2,1)
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('beam absorbed when going out of bounds right', () => {
+    // . S
+    // . ^
+    // . .
+    const grid = [
+      ['.', 'S'],
+      ['.', '^'],
+      ['.', '.'],
+    ];
+    // (0,1), (1,1) hit splitter. down-left (2,0), down-right (2,2) absorbed.
+    // Visited: (0,1), (1,1), (2,0)
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('multiple beams on same cell count once', () => {
+    // . . S . .
+    // . . ^ . .
+    // . ^ . ^ .
+    // . . . . .
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '^', '.', '^', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // (0,2), (1,2), (2,1), (2,3)
+    // From (2,1): (3,0), (3,2)
+    // From (2,3): (3,2), (3,4)
+    // (3,2) visited by two beams but counts once
+    // Visited: (0,2), (1,2), (2,1), (2,3), (3,0), (3,2), (3,4) = 7
+    expect(countBeamCells(grid)).toBe(7);
+  });
+
+  test('splitter with diagonal incoming beam still splits', () => {
+    // . S .
+    // . ^ .
+    // . . ^
+    // . . .
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '^', '.'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // (0,1) -> (1,1) splitter -> (2,0) down-left, (2,2) down-right hits splitter
+    // (2,2) splitter -> (3,1) down-left, (3,3) absorbed
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1)
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  test('empty grid with just source on single row', () => {
+    const grid = [['.','.','S','.','.']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+});
+
+describe('countBeamPaths', () => {
+  test('single source with no room to exit returns 1 path (exits below grid)', () => {
+    // S on single row: beam goes down, exits immediately
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('beam travels straight down with no splitters - 1 path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('beam hits one splitter - 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('beam hits two splitters in cascade - 4 paths', () => {
+    // . S . . .
+    // . ^ . . .
+    // ^ . ^ . .
+    // . . . . .
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Split at (1,1) -> 2 beams
+    // Each hits a splitter at (2,0) and (2,2) -> 4 beams total
+    // All 4 exit (including (3,-1) which is absorbed = exits grid)
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  test('absorbed beams still count as paths', () => {
+    // S .
+    // ^ .
+    const grid = [
+      ['S', '.'],
+      ['^', '.'],
+    ];
+    // Beam goes to (1,0) splitter. down-left (2,-1) absorbed, down-right (2,1) absorbed
+    // 2 paths both exit the grid
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('three levels of splitters - 6 paths', () => {
+    // . . . S . . .
+    // . . . ^ . . .
+    // . . ^ . ^ . .
+    // . ^ . . . ^ .
+    // . . . . . . .
+    const grid = [
+      ['.', '.', '.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '.'],
+      ['.', '^', '.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.', '.', '.'],
+    ];
+    // (0,3) -> (1,3) split
+    // left -> (2,2) split, right -> (2,4) split
+    // From (2,2): left->(3,1) split, right->(3,3) no split
+    // From (2,4): left->(3,3) no split, right->(3,5) split
+    // From (3,1) split: 2 paths exit
+    // From (3,3): 1 path (from 2,2) + 1 path (from 2,4) = 2 separate beams, each 1 path
+    // From (3,5) split: 2 paths exit
+    // Total: 2 + 1 + 1 + 2 = 6
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+
+  test('splitter where one branch goes out of bounds still counts', () => {
+    // S .
+    // ^ .
+    // . .
+    const grid = [
+      ['S', '.'],
+      ['^', '.'],
+      ['.', '.'],
+    ];
+    // Splits: down-left absorbed at (2,-1), down-right exits at bottom from (2,1)
+    // Both count as paths
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('diagonal beam hits splitter producing more paths', () => {
+    // . S .
+    // . ^ .
+    // . . ^
+    // . . .
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '^', '.'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // (0,1) -> (1,1) split -> 2 beams
+    // left beam (2,0) exits at (3,-1) absorbed -> 1 path
+    // right beam (2,2) hits splitter -> 2 more paths
+    // Total: 3 paths
+    expect(countBeamPaths(grid)).toBe(3n);
+  });
+
+  test('chain of splitters where right branch hits next splitter', () => {
+    // S at (0,0), splitter at (1,0), down-right goes to (2,1).
+    // Splitter at (2,1), down-right goes to (3,2), etc.
+    // Each splitter: down-left exits (goes left), down-right hits next splitter.
+    // With 5 splitters in a chain: total paths = 5 (from left exits) + 1 (final right) = 6
+    const rows = 8;
+    const cols = 8;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][0] = 'S';
+    // Chain: (1,0), (2,1), (3,2), (4,3), (5,4)
+    for (let i = 0; i < 5; i++) {
+      grid[1 + i][i] = '^';
+    }
+    // Splitter (1,0): left -> (2,-1) absorbed=exit, right -> (2,1) hits splitter
+    // Splitter (2,1): left -> (3,0) exits at bottom, right -> (3,2) hits splitter
+    // Splitter (3,2): left -> (4,1) exits, right -> (4,3) hits splitter
+    // Splitter (4,3): left -> (5,2) exits, right -> (5,4) hits splitter
+    // Splitter (5,4): left -> (6,3) exits, right -> (6,5) exits
+    // Total: 6 paths
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+});
+
+describe('performance', () => {
+  test('200x200 grid with 50 splitters completes in under 5 seconds', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+
+    // Place 50 splitters in a binary tree pattern
+    // Level 0: splitter at (2, 100)
+    // Level 1: splitters at (4, 99) and (4, 101)
+    // Level 2: splitters at (6, 98), (6, 100), (6, 100), (6, 102)
+    // etc. - but we need to avoid duplicates and stay in bounds
+    // Instead, place a chain of 50 splitters where right branch hits next
+    for (let i = 0; i < 50; i++) {
+      const r = 2 + i;
+      const c = 100 + i;
+      if (r < rows && c < cols) {
+        grid[r][c] = '^';
+      }
+    }
+
+    const start = performance.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+  });
+
+  test('200x200 grid with binary tree of splitters', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+
+    // Place splitters in a complete binary tree pattern
+    // This creates exponential paths: 2^depth
+    const positions: Array<[number, number]> = [[1, 100]];
+    let placed = 0;
+    for (const [r, c] of positions) {
+      if (placed >= 50) break;
+      if (r >= rows || c < 0 || c >= cols) continue;
+      grid[r][c] = '^';
+      placed++;
+      // Left child: beam goes down-left, so next splitter at (r+1, c-1)
+      if (r + 1 < rows && c - 1 >= 0) positions.push([r + 1, c - 1]);
+      // Right child: beam goes down-right, so next splitter at (r+1, c+1)
+      if (r + 1 < rows && c + 1 < cols) positions.push([r + 1, c + 1]);
+    }
+
+    const start = performance.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+  });
+});
