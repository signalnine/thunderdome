lls(grid)).toBe(3);\n  });\n\n  test('beam hits one splitter and splits', () => {\n    // . S . . .\n    // . . . . .\n    // . ^ . . .\n    // . . . . .\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2)\n    expect(countBeamCells(grid)).toBe(5);\n  });\n\n  test('beam hits two splitters in cascade', () => {\n    // . S . . .\n    // . ^ . . .\n    // ^ . ^ . .\n    // . . . . .\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) — (3,-1) is out of bounds\n    expect(countBeamCells(grid)).toBe(6);\n  });\n\n  test('beam absorbed when going out of bounds left', () => {\n    // S .\n    // ^ .\n    // . .\n    const grid = [\n      ['S', '.'],\n      ['^', '.'],\n      ['.', '.'],\n    ];\n    // (0,0), (1,0) hit splitter. down-left (2,-1) absorbed, down-right (2,1) visits.\n    // Visited: (0,0), (1,0), (2,1)\n    expect(countBeamCells(grid)).toBe(3);\n  });\n\n  test('beam absorbed when going out of bounds right', () => {\n    // . S\n    // . ^\n    // . .\n    const grid = [\n      ['.', 'S'],\n      ['.', '^'],\n      ['.', '.'],\n    ];\n    // (0,1), (1,1) hit splitter. down-left (2,0), down-right (2,2) absorbed.\n    // Visited: (0,1), (1,1), (2,0)\n    expect(countBeamCells(grid)).toBe(3);\n  });\n\n  test('multiple beams on same cell count once', () => {\n    // . . S . .\n    // . . ^ . .\n    // . ^ . ^ .\n    // . . . . .\n    const grid = [\n      ['.', '.', 'S', '.', '.'],\n      ['.', '.', '^', '.', '.'],\n      ['.', '^', '.', '^', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // (0,2), (1,2), (2,1), (2,3)\n    // From (2,1): (3,0), (3,2)\n    // From (2,3): (3,2), (3,4)\n    // (3,2) visited by two beams but counts once\n  