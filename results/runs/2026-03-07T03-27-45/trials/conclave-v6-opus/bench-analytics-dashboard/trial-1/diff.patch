+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../app.js';
+import type { Express } from 'express';
+
+describe('Event Routes', () => {
+  let app: Express;
+  let token: string;
+  let token2: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+
+    const res = await request(app)
+      .post('/api/auth/register')
+      .send({ email: 'test@example.com', password: 'pass', tenantId: 'tenant-1' });
+    token = res.body.token;
+
+    const res2 = await request(app)
+      .post('/api/auth/register')
+      .send({ email: 'other@example.com', password: 'pass', tenantId: 'tenant-2' });
+    token2 = res2.body.token;
+  });
+
+  describe('POST /api/events', () => {
+    it('ingests a single event', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'page_view', properties: { url: '/home' } });
+
+      expect(res.status).toBe(201);
+      expect(res.body.id).toBeDefined();
+      expect(res.body.name).toBe('page_view');
+      expect(res.body.tenant_id).toBe('tenant-1');
+    });
+
+    it('ingests event with timestamp', async () => {
+      const ts = '2024-01-15T10:30:00Z';
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'click', timestamp: ts });
+
+      expect(res.status).toBe(201);
+      expect(res.body.timestamp).toBe(ts);
+    });
+
+    it('rejects unauthenticated requests', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .send({ name: 'page_view' });
+
+      expect(res.status).toBe(401);
+    });
+
+    it('rejects events without a name', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ properties: { url: '/home' } });
+
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('POST /api/events/batch', () => {
+    it('ingests a batch of events', async () => {
+      const events = [
+        { name: 'page_view', properties: { url: '/home' } },
+        { name: 'page_view', properties: { url: '/about' } },
+        { name: 'click', properties: { button: 'signup' } },
+      ];
+
+      const res = await request(app)
+        .post('/api/events/batch')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ events });
+
+      expect(res.status).toBe(201);
+      expect(res.body.inserted).toBe(3);
+    });
+
+    it('rejects empty batch', async () => {
+      const res = await request(app)
+        .post('/api/events/batch')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ events: [] });
+
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('Tenant isolation', () => {
+    it('events are isolated by tenant', async () => {
+      await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'page_view' });
+
+      await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token2}`)
+        .send({ name: 'page_view' });
+
+      // Query from tenant 1 should only see 1 event
+      const res = await request(app)
+        .post('/api/query')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ type: 'count', event: 'page_view' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.count).toBe(1);
+    });
+  });
+});
