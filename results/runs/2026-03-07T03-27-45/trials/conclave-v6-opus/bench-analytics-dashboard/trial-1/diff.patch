diff --git a/src/__tests__/auth.test.ts b/src/__tests__/auth.test.ts
new file mode 100644
index 0000000..bc00579
--- /dev/null
+++ b/src/__tests__/auth.test.ts
@@ -0,0 +1,158 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../app.js';
+import type { Express } from 'express';
+
+describe('Auth Routes', () => {
+  let app: Express;
+
+  beforeEach(() => {
+    app = createApp(':memory:');
+  });
+
+  describe('POST /api/auth/register', () => {
+    it('registers a new user and returns a token', async () => {
+      const res = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant-1' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.token).toBeDefined();
+      expect(res.body.user.email).toBe('test@example.com');
+      expect(res.body.user.tenant_id).toBe('tenant-1');
+      expect(res.body.user.role).toBe('viewer');
+      expect(res.body.user.password_hash).toBeUndefined();
+    });
+
+    it('rejects duplicate email', async () => {
+      await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant-1' });
+
+      const res = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'test@example.com', password: 'password456', tenantId: 'tenant-1' });
+
+      expect(res.status).toBe(409);
+    });
+
+    it('rejects missing fields', async () => {
+      const res = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'test@example.com' });
+
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('POST /api/auth/login', () => {
+    beforeEach(async () => {
+      await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant-1' });
+    });
+
+    it('logs in with valid credentials', async () => {
+      const res = await request(app)
+        .post('/api/auth/login')
+        .send({ email: 'test@example.com', password: 'password123' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.token).toBeDefined();
+    });
+
+    it('rejects invalid password', async () => {
+      const res = await request(app)
+        .post('/api/auth/login')
+        .send({ email: 'test@example.com', password: 'wrongpassword' });
+
+      expect(res.status).toBe(401);
+    });
+
+    it('rejects non-existent user', async () => {
+      const res = await request(app)
+        .post('/api/auth/login')
+        .send({ email: 'nobody@example.com', password: 'password123' });
+
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('GET /api/auth/me', () => {
+    it('returns user profile with valid token', async () => {
+      const registerRes = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant-1' });
+
+      const token = registerRes.body.token;
+
+      const res = await request(app)
+        .get('/api/auth/me')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.email).toBe('test@example.com');
+      expect(res.body.tenant_id).toBe('tenant-1');
+    });
+
+    it('rejects unauthenticated requests', async () => {
+      const res = await request(app).get('/api/auth/me');
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('PUT /api/auth/users/:id/role', () => {
+    it('admin can change user role', async () => {
+      const adminRes = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'admin@example.com', password: 'password123', tenantId: 'tenant-1', role: 'admin' });
+      const adminToken = adminRes.body.token;
+
+      const userRes = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'user@example.com', password: 'password123', tenantId: 'tenant-1' });
+      const userId = userRes.body.user.id;
+
+      const res = await request(app)
+        .put(`/api/auth/users/${userId}/role`)
+        .set('Authorization', `Bearer ${adminToken}`)
+        .send({ role: 'editor' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.role).toBe('editor');
+    });
+
+    it('non-admin cannot change roles', async () => {
+      const userRes = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'user@example.com', password: 'password123', tenantId: 'tenant-1' });
+      const userToken = userRes.body.token;
+
+      const res = await request(app)
+        .put(`/api/auth/users/${userRes.body.user.id}/role`)
+        .set('Authorization', `Bearer ${userToken}`)
+        .send({ role: 'admin' });
+
+      expect(res.status).toBe(403);
+    });
+
+    it('cannot change role of user in different tenant', async () => {
+      const adminRes = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'admin@example.com', password: 'password123', tenantId: 'tenant-1', role: 'admin' });
+      const adminToken = adminRes.body.token;
+
+      const otherRes = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'other@example.com', password: 'password123', tenantId: 'tenant-2' });
+      const otherId = otherRes.body.user.id;
+
+      const res = await request(app)
+        .put(`/api/auth/users/${otherId}/role`)
+        .set('Authorization', `Bearer ${adminToken}`)
+        .send({ role: 'editor' });
+
+      expect(res.status).toBe(404);
+    });
+  });
+});
