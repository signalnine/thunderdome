+import { Router, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import type { AuthenticatedRequest } from '../types.js';
+import { authenticate } from '../middleware.js';
+
+const router = Router();
+
+router.post('/', authenticate, (req: AuthenticatedRequest, res: Response) => {
+  const { name, properties, timestamp, session_id } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: 'Event name is required' });
+    return;
+  }
+
+  const db = req.db!;
+  const id = uuidv4();
+  const tenantId = req.user!.tenantId;
+  const userId = req.user!.userId;
+  const ts = timestamp || new Date().toISOString();
+  const props = properties ? JSON.stringify(properties) : '{}';
+
+  db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, tenantId, name, props, ts, userId, session_id || null);
+
+  res.status(201).json({ id, tenant_id: tenantId, name, properties: props, timestamp: ts });
+});
+
+router.post('/batch', authenticate, (req: AuthenticatedRequest, res: Response) => {
+  const { events } = req.body;
+
+  if (!events || !Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: 'Non-empty events array is required' });
+    return;
+  }
+
+  const db = req.db!;
+  const tenantId = req.user!.tenantId;
+  const userId = req.user!.userId;
+
+  const insert = db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  );
+
+  const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string; session_id?: string }>) => {
+    for (const evt of evts) {
+      const id = uuidv4();
+      const ts = evt.timestamp || new Date().toISOString();
+      const props = evt.properties ? JSON.stringify(evt.properties) : '{}';
+      insert.run(id, tenantId, evt.name, props, ts, userId, evt.session_id || null);
+    }
+  });
+
+  insertMany(events);
+
+  res.status(201).json({ inserted: events.length });
+});
+
+export default router;
