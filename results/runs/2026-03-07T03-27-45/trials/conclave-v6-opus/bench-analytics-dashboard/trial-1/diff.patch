diff --git a/src/routes/query.ts b/src/routes/query.ts
new file mode 100644
index 0000000..e3b0144
--- /dev/null
+++ b/src/routes/query.ts
@@ -0,0 +1,94 @@
+import { Router, Response } from 'express';
+import type { AuthenticatedRequest } from '../types.js';
+import { authenticate } from '../middleware.js';
+
+const router = Router();
+
+router.post('/', authenticate, (req: AuthenticatedRequest, res: Response) => {
+  const { type, event, dateFrom, dateTo, interval, property } = req.body;
+  const db = req.db!;
+  const tenantId = req.user!.tenantId;
+
+  if (!type || !event) {
+    res.status(400).json({ error: 'type and event are required' });
+    return;
+  }
+
+  switch (type) {
+    case 'count': {
+      let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?';
+      const params: (string)[] = [tenantId, event];
+
+      if (dateFrom) {
+        sql += ' AND timestamp >= ?';
+        params.push(dateFrom);
+      }
+      if (dateTo) {
+        sql += ' AND timestamp <= ?';
+        params.push(dateTo);
+      }
+
+      const result = db.prepare(sql).get(...params) as { count: number };
+      res.json({ count: result.count });
+      break;
+    }
+
+    case 'timeseries': {
+      let groupExpr: string;
+      if (interval === 'hour') {
+        groupExpr = "strftime('%Y-%m-%dT%H:00:00Z', timestamp)";
+      } else {
+        // default to day
+        groupExpr = "strftime('%Y-%m-%d', timestamp)";
+      }
+
+      let sql = `SELECT ${groupExpr} as period, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+      const params: string[] = [tenantId, event];
+
+      if (dateFrom) {
+        sql += ' AND timestamp >= ?';
+        params.push(dateFrom);
+      }
+      if (dateTo) {
+        sql += ' AND timestamp <= ?';
+        params.push(dateTo);
+      }
+
+      sql += ` GROUP BY period ORDER BY period ASC`;
+
+      const rows = db.prepare(sql).all(...params) as Array<{ period: string; count: number }>;
+      res.json({ data: rows });
+      break;
+    }
+
+    case 'breakdown': {
+      if (!property) {
+        res.status(400).json({ error: 'property is required for breakdown queries' });
+        return;
+      }
+
+      let sql = `SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+      const params: string[] = [property, tenantId, event];
+
+      if (dateFrom) {
+        sql += ' AND timestamp >= ?';
+        params.push(dateFrom);
+      }
+      if (dateTo) {
+        sql += ' AND timestamp <= ?';
+        params.push(dateTo);
+      }
+
+      sql += ' GROUP BY value ORDER BY count DESC';
+
+      const rows = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;
+      res.json({ data: rows });
+      break;
+    }
+
+    default:
+      res.status(400).json({ error: `Unknown query type: ${type}` });
+  }
+});
+
+export default router;
