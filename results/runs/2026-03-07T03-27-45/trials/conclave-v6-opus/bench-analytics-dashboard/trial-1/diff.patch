me = ?`;\n      const params: string[] = [property, tenantId, event];\n\n      if (dateFrom) {\n        sql += ' AND timestamp >= ?';\n        params.push(dateFrom);\n      }\n      if (dateTo) {\n        sql += ' AND timestamp <= ?';\n        params.push(dateTo);\n      }\n\n      sql += ' GROUP BY value ORDER BY count DESC';\n\n      const rows = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;\n      res.json({ data: rows });\n      break;\n    }\n\n    default:\n      res.status(400).json({ error: `Unknown query type: ${type}` });\n  }\n});\n\nexport default router;\n","numLines":95,"startLine":1,"totalLines":95}}}
