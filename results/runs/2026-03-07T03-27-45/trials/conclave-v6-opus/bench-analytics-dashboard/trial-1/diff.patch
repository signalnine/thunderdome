@@ -0,0 +1,161 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../app.js';
+import type { Express } from 'express';
+
+describe('Dashboard Routes', () => {
+  let app: Express;
+  let token: string;
+  let token2: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+
+    const res = await request(app)
+      .post('/api/auth/register')
+      .send({ email: 'test@example.com', password: 'pass', tenantId: 'tenant-1' });
+    token = res.body.token;
+
+    const res2 = await request(app)
+      .post('/api/auth/register')
+      .send({ email: 'other@example.com', password: 'pass', tenantId: 'tenant-2' });
+    token2 = res2.body.token;
+  });
+
+  describe('POST /api/dashboards', () => {
+    it('creates a dashboard', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'My Dashboard', config: { theme: 'dark' } });
+
+      expect(res.status).toBe(201);
+      expect(res.body.id).toBeDefined();
+      expect(res.body.name).toBe('My Dashboard');
+      expect(res.body.tenant_id).toBe('tenant-1');
+    });
+
+    it('rejects without name', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({});
+
+      expect(res.status).toBe(400);
+    });
+
+    it('rejects unauthenticated', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .send({ name: 'test' });
+
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('GET /api/dashboards', () => {
+    it('lists dashboards for tenant', async () => {
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Dashboard 1' });
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Dashboard 2' });
+
+      // Other tenant dashboard
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token2}`)
+        .send({ name: 'Other Dashboard' });
+
+      const res = await request(app)
+        .get('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.length).toBe(2);
+    });
+  });
+
+  describe('GET /api/dashboards/:id', () => {
+    it('returns a dashboard by id', async () => {
+      const createRes = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'My Dashboard' });
+
+      const res = await request(app)
+        .get(`/api/dashboards/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('My Dashboard');
+    });
+
+    it('cannot access other tenant dashboard', async () => {
+      const createRes = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token2}`)
+        .send({ name: 'Other Dashboard' });
+
+      const res = await request(app)
+        .get(`/api/dashboards/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('PUT /api/dashboards/:id', () => {
+    it('updates a dashboard', async () => {
+      const createRes = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Old Name' });
+
+      const res = await request(app)
+        .put(`/api/dashboards/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'New Name', config: { updated: true } });
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('New Name');
+    });
+  });
+
+  describe('DELETE /api/dashboards/:id', () => {
+    it('deletes a dashboard', async () => {
+      const createRes = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'To Delete' });
+
+      const res = await request(app)
+        .delete(`/api/dashboards/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(204);
+
+      const getRes = await request(app)
+        .get(`/api/dashboards/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(getRes.status).toBe(404);
+    });
+
+    it('cannot delete other tenant dashboard', async () => {
+      const createRes = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token2}`)
+        .send({ name: 'Other' });
+
+      const res = await request(app)
+        .delete(`/api/dashboards/${createRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(404);
+    });
+  });
+});
