@@ -0,0 +1,172 @@
+import type { WebSocket, RawData } from 'ws';
+import type { IncomingMessage } from 'http';
+import { randomUUID } from 'crypto';
+import type { DocDatabase } from './db.js';
+import { transformOp, applyOp, type Operation } from './ot.js';
+
+interface Client {
+  id: string;
+  ws: WebSocket;
+  documentId: string;
+}
+
+export interface WsHandler {
+  handleConnection(ws: WebSocket, req: IncomingMessage): void;
+  closeAll(): void;
+  getClientCount(documentId: string): number;
+}
+
+export function createWsHandler(db: DocDatabase): WsHandler {
+  const clients = new Map<string, Client>();
+
+  function getDocumentClients(documentId: string): Client[] {
+    const result: Client[] = [];
+    for (const client of clients.values()) {
+      if (client.documentId === documentId) {
+        result.push(client);
+      }
+    }
+    return result;
+  }
+
+  function send(ws: WebSocket, data: unknown): void {
+    if (ws.readyState === ws.OPEN) {
+      ws.send(JSON.stringify(data));
+    }
+  }
+
+  function handleMessage(client: Client, raw: RawData): void {
+    let msg: { type: string; version?: number; operation?: Operation };
+    try {
+      msg = JSON.parse(raw.toString());
+    } catch {
+      send(client.ws, { type: 'error', message: 'Invalid JSON' });
+      return;
+    }
+
+    if (msg.type !== 'operation') {
+      send(client.ws, { type: 'error', message: `Unknown message type: ${msg.type}` });
+      return;
+    }
+
+    if (typeof msg.version !== 'number' || !msg.operation) {
+      send(client.ws, { type: 'error', message: 'Missing version or operation' });
+      return;
+    }
+
+    const op = msg.operation;
+    if (!validateOperation(op)) {
+      send(client.ws, { type: 'error', message: 'Invalid operation' });
+      return;
+    }
+
+    const doc = db.getDocument(client.documentId);
+    if (!doc) {
+      send(client.ws, { type: 'error', message: 'Document not found' });
+      return;
+    }
+
+    const currentVersion = db.getLatestVersion(client.documentId);
+
+    // Transform against all operations since client's version
+    let transformed = op;
+    if (msg.version < currentVersion) {
+      const serverOps = db.getOperationsSince(client.documentId, msg.version);
+      for (const serverVersion of serverOps) {
+        const serverOp = JSON.parse(serverVersion.operation!) as Operation;
+        transformed = transformOp(transformed, serverOp);
+      }
+    }
+
+    // Apply to document
+    const newContent = applyOp(doc.content, transformed);
+    const newVersion = currentVersion + 1;
+
+    // Persist
+    db.updateContent(client.documentId, newContent);
+    db.saveVersion(client.documentId, newVersion, newContent, transformed);
+
+    // Acknowledge to sender
+    send(client.ws, { type: 'ack', version: newVersion });
+
+    // Broadcast to other clients
+    const others = getDocumentClients(client.documentId);
+    for (const other of others) {
+      if (other.id !== client.id) {
+        send(other.ws, {
+          type: 'operation',
+          version: newVersion,
+          operation: transformed,
+          clientId: client.id,
+        });
+      }
+    }
+  }
+
+  function validateOperation(op: unknown): op is Operation {
+    if (!op || typeof op !== 'object') return false;
+    const o = op as Record<string, unknown>;
+    if (o.type === 'insert') {
+      return typeof o.position === 'number' && o.position >= 0 && typeof o.text === 'string' && o.text.length > 0;
+    }
+    if (o.type === 'delete') {
+      return typeof o.position === 'number' && o.position >= 0 && typeof o.count === 'number' && o.count > 0;
+    }
+    return false;
+  }
+
+  return {
+    handleConnection(ws: WebSocket, req: IncomingMessage): void {
+      // Extract document ID from URL path: /ws/:documentId
+      const url = req.url || '';
+      const match = url.match(/\/ws\/([^/?]+)/);
+      if (!match) {
+        send(ws, { type: 'error', message: 'Invalid WebSocket path. Use /ws/:documentId' });
+        ws.close();
+        return;
+      }
+
+      const documentId = match[1];
+      const doc = db.getDocument(documentId);
+      if (!doc) {
+        send(ws, { type: 'error', message: 'Document not found' });
+        ws.close();
+        return;
+      }
+
+      const clientId = randomUUID();
+      const client: Client = { id: clientId, ws, documentId };
+      clients.set(clientId, client);
+
+      // Send sync message with current document state
+      const currentVersion = db.getLatestVersion(documentId);
+      send(ws, {
+        type: 'sync',
+        content: doc.content,
+        version: currentVersion,
+        clientId,
+      });
+
+      ws.on('message', (data) => handleMessage(client, data));
+
+      ws.on('close', () => {
+        clients.delete(clientId);
+      });
+
+      ws.on('error', () => {
+        clients.delete(clientId);
+      });
+    },
+
+    closeAll(): void {
+      for (const client of clients.values()) {
+        client.ws.close();
+      }
+      clients.clear();
+    },
+
+    getClientCount(documentId: string): number {
+      return getDocumentClients(documentId).length;
+    },
+  };
+}
