+import express from 'express';
+import http from 'http';
+import { WebSocketServer } from 'ws';
+import { createDb, type DocDatabase } from './db.js';
+import { createRoutes } from './routes.js';
+import { createWsHandler } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+  db: DocDatabase;
+  server?: http.Server;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const app = express();
+  const db = createDb(dbPath);
+
+  app.use(express.json());
+  app.use(createRoutes(db));
+
+  let httpServer: http.Server | undefined;
+  let wss: WebSocketServer | undefined;
+  const wsHandler = createWsHandler(db);
+
+  const instance: AppInstance = {
+    app,
+    db,
+
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        httpServer = http.createServer(app);
+        wss = new WebSocketServer({ server: httpServer });
+
+        wss.on('connection', (ws, req) => {
+          wsHandler.handleConnection(ws, req);
+        });
+
+        httpServer.listen(port ?? 0, () => {
+          const addr = httpServer!.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : 0;
+          resolve(actualPort);
+        });
+
+        instance.server = httpServer;
+      });
+    },
+
+    async stop(): Promise<void> {
+      wsHandler.closeAll();
+      if (wss) {
+        wss.close();
+      }
+      if (httpServer) {
+        await new Promise<void>((resolve) => httpServer!.close(() => resolve()));
+      }
+      db.close();
+    },
+  };
+
+  return instance;
+}
