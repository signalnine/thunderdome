\nnew file mode 100644\nindex 0000000..6c6beb0\n--- /dev/null\n+++ b/src/ot.ts\n@@ -0,0 +1,99 @@\n+export interface InsertOp {\n+  type: 'insert';\n+  position: number;\n+  text: string;\n+}\n+\n+export interface DeleteOp {\n+  type: 'delete';\n+  position: number;\n+  count: number;\n+}\n+\n+export type Operation = InsertOp | DeleteOp;\n+\n+export function applyOp(doc: string, op: Operation): string {\n+  if (op.type === 'insert') {\n+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);\n+  }\n+  // delete\n+  return doc.slice(0, op.position) + doc.slice(op.position + op.count);\n+}\n+\n+/**\n+ * Transform clientOp against serverOp.\n+ * Returns a new operation that, when applied after serverOp,\n+ * achieves the same intent as clientOp on the original document.\n+ */\n+export function transformOp(clientOp: Operation, serverOp: Operation): Operation {\n+  if (clientOp.type === 'insert' && serverOp.type === 'insert') {\n+    return transformInsertInsert(clientOp, serverOp);\n+  }\n+  if (clientOp.type === 'insert' && serverOp.type === 'delete') {\n+    return transformInsertDelete(clientOp, serverOp);\n+  }\n+  if (clientOp.type === 'delete' && serverOp.type === 'insert') {\n+    return transformDeleteInsert(clientOp, serverOp);\n+  }\n+  // delete vs delete\n+  return transformDeleteDelete(clientOp as DeleteOp, serverOp as DeleteOp);\n+}\n+\n+function transformInsertInsert(client: InsertOp, server: InsertOp): InsertOp {\n+  if (client.position < server.position) {\n+    return { ...client };\n+  }\n+  // client.position >= server.position: shift right by server insert length\n+  return { ...client, position: client.position + server.text.length };\n+}\n+\n+function transformInsertDelete(client: InsertOp, server: DeleteOp): InsertOp {\n+  if (client.position <= server.position) {\n+    return { ...client };\n+  }\n+  const serverEnd = server.position + server.count;\n+  if (client.position >= serverEnd) {\n+    return { ...client, position: clien