et(`/documents/${doc.body.id}`);\n    // Both insertions must be preserved\n    expect(res.body.content).toContain('AAA');\n    expect(res.body.content).toContain('BBB');\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\ndescribe('error handling', () => {\n  test('rejects invalid JSON', async () => {\n    const doc = await request(app.app).post('/documents').send({ title: 'Test', content: '' });\n    const { ws } = await connectWs(doc.body.id);\n\n    const errorPromise = waitForMessage(ws, 'error');\n    ws.send('not json');\n    const error = await errorPromise;\n    expect(error.message).toContain('Invalid JSON');\n\n    ws.close();\n  });\n\n  test('rejects unknown message type', async () => {\n    const doc = await request(app.app).post('/documents').send({ title: 'Test', content: '' });\n    const { ws } = await connectWs(doc.body.id);\n\n    const errorPromise = waitForMessage(ws, 'error');\n    ws.send(JSON.stringify({ type: 'unknown' }));\n    const error = await errorPromise;\n    expect(error.message).toContain('Unknown message type');\n\n    ws.close();\n  });\n\n  test('rejects operation without version', async () => {\n    const doc = await request(app.app).post('/documents').send({ title: 'Test', content: '' });\n    const { ws } = await connectWs(doc.body.id);\n\n    const errorPromise = waitForMessage(ws, 'error');\n    ws.send(JSON.stringify({ type: 'operation', operation: { type: 'insert', position: 0, text: 'hi' } }));\n    const error = await errorPromise;\n    expect(error.message).toContain('Missing version');\n\n    ws.close();\n  });\n\n  test('rejects invalid operation type', async () => {\n    const doc = await request(app.app).post('/documents').send({ title: 'Test', content: '' });\n    const { ws } = await connectWs(doc.body.id);\n\n    const errorPromise = waitForMessage(ws, 'error');\n    ws.send(JSON.stringify({ type: 'operation', version: 0, operation: { type: 'invalid', position: 0 } }));\n    const error = await errorPromise;\n    expect(error.message).toContain('Invalid operation');\n\n    ws.close();\n  });\n});\n\ndescribe('version history', () => {\n  test('operations create version entries', async () => {\n    const doc = await request(app.app).post('/documents').send({ title: 'Test', content: '' });\n    const { ws, sync } = await connectWs(doc.body.id);\n\n    let ackPromise = waitForMessage(ws, 'ack');\n    sendOp(ws, sync.version, { type: 'insert', position: 0, text: 'hello' });\n    await ackPromise;\n\n    ackPromise = waitForMessage(ws, 'ack');\n    sendOp(ws, 1, { type: 'insert', position: 5, text: ' world' });\n    await ackPromise;\n\n    ws.close();\n\n    const res = await request(app.app).get(`/documents/${doc.body.id}/versions`);\n    expect(res.body).toHaveLength(2);\n    expect(res.body[0].version).toBe(1);\n    expect(res.body[0].content).toBe('hello');\n    expect(res.body[1].version).toBe(2);\n    expect(res.body[1].content).toBe('hello world');\n  });\n});\n\ndescribe('persistence', () => {\n  test('documents persist across server restarts', async () => {\n    const tmpPath = `/tmp/test-persist-${Date.now()}.sqlite`;\n\n    // Create and populate\n    const app1 = createApp(tmpPath);\n    const port1 = await app1.start(0);\n\n    const doc = await request(app1.app).post('/documents').send({ title: 'Persistent', content: 'hello' });\n    const docId = doc.body.id;\n\n    const ws = new WebSocket(`ws://localhost:${port1}/ws/${docId}`);\n    await new Promise<void>((resolve) => {\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'sync') resolve();\n      });\n    });\n\n    const ackPromise = new Promise<void>((resolve) => {\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'ack') resolve();\n      });\n    });\n    ws.send(JSON.stringify({ type: 'operation', version: 0, operation: { type: 'insert', position: 5, text: ' world' } }));\n    await ackPromise;\n\n    ws.close();\n    await app1.stop();\n\n    // Reopen\n    const app2 = createApp(tmpPath);\n    const port2 = await app2.start(0);\n\n    const res = await request(app2.app).get(`/documents/${docId}`);\n    expect(res.body.title).toBe('Persistent');\n    expect(res.body.content).toBe('hello world');\n\n    const versions = await request(app2.app).get(`/documents/${docId}/versions`);\n    expect(versions.body).toHaveLength(1);\n\n    await app2.stop();\n\n    // Cleanup\n    try { require('fs').unlinkSync(tmpPath); } catch { /* ignore */ }\n  });\n});\n\ndescribe('10 concurrent clients', () => {\n  test('handles 10 clients on the same document without corruption', async () => {\n    const doc = await request(app.app).post('/documents').send({ title: 'Concurrent', content: '' });\n    const docId = doc.body.id;\n\n    // Connect 10 clients\n    const connections: { ws: WebSocket; sync: { content: string; version: number; clientId: string } }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const conn = await connectWs(docId);\n      connections.push(conn);\n    }\n\n    // Each client sends one insert operation sequentially\n    for (let i = 0; i < 10; i++) {\n      const { ws } = connections[i];\n      const ackPromise = waitForMessage(ws, 'ack');\n      // Each client inserts its number at position 0 based on current version\n      sendOp(ws, i, { type: 'insert', position: 0, text: `${i}` });\n      await ackPromise;\n    }\n\n    // Wait a bit for all broadcasts to settle\n    await new Promise((r) => setTimeout(r, 100));\n\n    // Verify document has all 10 characters\n    const res = await request(app.app).get(`/documents/${docId}`);\n    expect(res.body.content).toHaveLength(10);\n\n    // All digits should be present\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(`${i}`);\n    }\n\n    // Clean up\n    for (const { ws } of connections) {\n      ws.close();\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null}}
