 = server.position + server.count;\n  if (client.position >= serverEnd) {\n    return { ...client, position: client.position - server.count };\n  }\n  // Client insert is within server delete range - place at delete position\n  return { ...client, position: server.position };\n}\n\nfunction transformDeleteInsert(client: DeleteOp, server: InsertOp): DeleteOp {\n  if (server.position >= client.position + client.count) {\n    // Server insert is after client delete range\n    return { ...client };\n  }\n  if (server.position <= client.position) {\n    // Server insert is before or at client delete start\n    return { ...client, position: client.position + server.text.length };\n  }\n  // Server insert is within client delete range\n  // Expand the delete to cover the same original characters plus skip the inserted text\n  return { ...client, count: client.count + server.text.length };\n}\n\nfunction transformDeleteDelete(client: DeleteOp, server: DeleteOp): DeleteOp {\n  const clientEnd = client.position + client.count;\n  const serverEnd = server.position + server.count;\n\n  if (clientEnd <= server.position) {\n    // Client range is entirely before server range\n    return { ...client };\n  }\n  if (client.position >= serverEnd) {\n    // Client range is entirely after server range\n    return { ...client, position: client.position - server.count };\n  }\n\n  // Overlapping ranges\n  // Calculate how many chars the server already deleted from client's range\n  const overlapStart = Math.max(client.position, server.position);\n  const overlapEnd = Math.min(clientEnd, serverEnd);\n  const overlapCount = Math.max(0, overlapEnd - overlapStart);\n\n  const newCount = client.count - overlapCount;\n  const newPosition = Math.min(client.position, server.position);\n\n  // If client starts after server, adjust position\n  if (client.position >= server.position) {\n    return { type: 'delete', position: server.position, count: newCount };\n  }\n\n  // Client starts before server\n  return { type: 'delete', position: client.position, count: newCount };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":437,"cache_read_input_tokens":34264,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":437},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"164c53a8-5915-46cb-a242-8bc0591b9675","uuid":"4496361f-2753-45bf-8b5d-a9dea25042b7"}
