+import { describe, test, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import express from 'express';
+import { createDb, type DocDatabase } from './db.js';
+import { createRoutes } from './routes.js';
+
+let db: DocDatabase;
+let app: express.Express;
+
+beforeEach(() => {
+  db = createDb(); // in-memory
+  app = express();
+  app.use(express.json());
+  app.use(createRoutes(db));
+});
+
+afterEach(() => {
+  db.close();
+});
+
+describe('POST /documents', () => {
+  test('creates a document', async () => {
+    const res = await request(app)
+      .post('/documents')
+      .send({ title: 'Test Doc', content: 'hello' })
+      .expect(201);
+
+    expect(res.body.id).toBeDefined();
+    expect(res.body.title).toBe('Test Doc');
+    expect(res.body.content).toBe('hello');
+  });
+
+  test('creates a document with default empty content', async () => {
+    const res = await request(app)
+      .post('/documents')
+      .send({ title: 'Empty Doc' })
+      .expect(201);
+
+    expect(res.body.content).toBe('');
+  });
+
+  test('returns 400 if title is missing', async () => {
+    await request(app)
+      .post('/documents')
+      .send({ content: 'no title' })
+      .expect(400);
+  });
+});
+
+describe('GET /documents', () => {
+  test('lists all documents', async () => {
+    await request(app).post('/documents').send({ title: 'Doc 1' });
+    await request(app).post('/documents').send({ title: 'Doc 2' });
+
+    const res = await request(app).get('/documents').expect(200);
+    expect(res.body).toHaveLength(2);
+  });
+
+  test('returns empty array when no documents', async () => {
+    const res = await request(app).get('/documents').expect(200);
+    expect(res.body).toEqual([]);
+  });
+});
+
+describe('GET /documents/:id', () => {
+  test('gets a document by id', async () => {
+    const created = await request(app).post('/documents').send({ title: 'Test' });
+    const res = await request(app).get(`/documents/${created.body.id}`).expect(200);
+    expect(res.body.title).toBe('Test');
+  });
+
+  test('returns 404 for nonexistent document', async () => {
+    await request(app).get('/documents/nonexistent').expect(404);
+  });
+});
+
+describe('PUT /documents/:id', () => {
+  test('updates document title', async () => {
+    const created = await request(app).post('/documents').send({ title: 'Old' });
+    const res = await request(app)
+      .put(`/documents/${created.body.id}`)
+      .send({ title: 'New' })
+      .expect(200);
+    expect(res.body.title).toBe('New');
+  });
+
+  test('updates document content', async () => {
+    const created = await request(app).post('/documents').send({ title: 'Test', content: 'old' });
+    const res = await request(app)
+      .put(`/documents/${created.body.id}`)
+      .send({ content: 'new' })
+      .expect(200);
+    expect(res.body.content).toBe('new');
+  });
+
+  test('returns 404 for nonexistent document', async () => {
+    await request(app)
+      .put('/documents/nonexistent')
+      .send({ title: 'x' })
+      .expect(404);
+  });
+});
+
+describe('DELETE /documents/:id', () => {
+  test('deletes a document', async () => {
+    const created = await request(app).post('/documents').send({ title: 'Delete Me' });
+    await request(app).delete(`/documents/${created.body.id}`).expect(204);
+    await request(app).get(`/documents/${created.body.id}`).expect(404);
+  });
+
+  test('returns 404 for nonexistent document', async () => {
+    await request(app).delete('/documents/nonexistent').expect(404);
+  });
+});
+
+describe('GET /documents/:id/versions', () => {
+  test('returns version history', async () => {
+    const created = await request(app).post('/documents').send({ title: 'Doc', content: '' });
+    const docId = created.body.id;
+    db.saveVersion(docId, 1, 'a', { type: 'insert', position: 0, text: 'a' });
+    db.saveVersion(docId, 2, 'ab', { type: 'insert', position: 1, text: 'b' });
+
+    const res = await request(app).get(`/documents/${docId}/versions`).expect(200);
+    expect(res.body).toHaveLength(2);
+    expect(res.body[0].version).toBe(1);
+    expect(res.body[1].version).toBe(2);
+  });
+
+  test('returns 404 for nonexistent document', async () => {
+    await request(app).get('/documents/nonexistent/versions').expect(404);
+  });
+});
