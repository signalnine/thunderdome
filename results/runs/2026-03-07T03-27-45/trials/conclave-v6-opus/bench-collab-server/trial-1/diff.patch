+    const transformedB = transformOp(opB, opA);
+    const resultAB = applyOp(docA, transformedB);
+
+    // Apply B then transformed A
+    const docB = applyOp(doc, opB);
+    const transformedA = transformOp(opA, opB);
+    const resultBA = applyOp(docB, transformedA);
+
+    expect(resultAB).toBe(resultBA);
+    expect(resultAB).toContain('beautiful');
+    expect(resultAB).toContain('Oh, ');
+  });
+
+  test('insert and delete converge regardless of order', () => {
+    const doc = 'hello world';
+    const opA: Operation = { type: 'insert', position: 5, text: ' dear' };
+    const opB: Operation = { type: 'delete', position: 6, count: 5 }; // delete 'world'
+
+    const docA = applyOp(doc, opA);
+    const transformedB = transformOp(opB, opA);
+    const resultAB = applyOp(docA, transformedB);
+
+    const docB = applyOp(doc, opB);
+    const transformedA = transformOp(opA, opB);
+    const resultBA = applyOp(docB, transformedA);
+
+    expect(resultAB).toBe(resultBA);
+    expect(resultAB).toContain('dear');
+  });
+
+  test('two concurrent deletes converge regardless of order', () => {
+    const doc = 'hello beautiful world';
+    const opA: Operation = { type: 'delete', position: 5, count: 10 }; // delete ' beautiful'
+    const opB: Operation = { type: 'delete', position: 15, count: 6 }; // delete ' world'
+
+    const docA = applyOp(doc, opA);
+    const transformedB = transformOp(opB, opA);
+    const resultAB = applyOp(docA, transformedB);
+
+    const docB = applyOp(doc, opB);
+    const transformedA = transformOp(opA, opB);
+    const resultBA = applyOp(docB, transformedA);
+
+    expect(resultAB).toBe(resultBA);
+    expect(resultAB).toBe('hello');
+  });
+});
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..6c6beb0
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,99 @@
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export function applyOp(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);
+  }
+  // delete
+  return doc.slice(0, op.position) + doc.slice(op.position + op.count);
+}
+
+/**
+ * Transform clientOp against serverOp.
+ * Returns a new operation that, when applied after serverOp,
+ * achieves the same intent as clientOp on the original document.
+ */
+export function transformOp(clientOp: Operation, serverOp: Operation): Operation {
+  if (clientOp.type === 'insert' && serverOp.type === 'insert') {
+    return transformInsertInsert(clientOp, serverOp);
+  }
+  if (clientOp.type === 'insert' && serverOp.type === 'delete') {
+    return transformInsertDelete(clientOp, serverOp);
+  }
+  if (clientOp.type === 'delete' && serverOp.type === 'insert') {
+    return transformDeleteInsert(clientOp, serverOp);
+  }
+  // delete vs delete
+  return transformDeleteDelete(clientOp as DeleteOp, serverOp as DeleteOp);
+}
+
+function transformInsertInsert(client: InsertOp, server: InsertOp): InsertOp {
+  if (client.position < server.position) {
+    return { ...client };
+  }
+  // client.position >= server.position: shift right by server insert length
+  return { ...client, position: client.position + server.text.length };
+}
+
+function transformInsertDelete(client: InsertOp, server: DeleteOp): InsertOp {
+  if (client.position <= server.position) {
+    return { ...client };
+  }
+  const serverEnd = server.position + server.count;
+  if (client.position >= serverEnd) {
+    return { ...client, position: client.position - server.count };
+  }
+  // Client insert is within server delete range - place at delete position
+  return { ...client, position: server.position };
+}
+
+function transformDeleteInsert(client: DeleteOp, server: InsertOp): DeleteOp {
+  if (server.position >= client.position + client.count) {
+    // Server insert is after client delete range
+    return { ...client };
+  }
+  if (server.position <= client.position) {
+    // Server insert is before or at client delete start
+    return { ...client, position: client.position + server.text.length };
+  }
+  // Server insert is within client delete range
+  // Expand the delete to cover the same original characters plus skip the inserted text
+  return { ...client, count: client.count + server.text.length };
+}
+
+function transformDeleteDelete(client: DeleteOp, server: DeleteOp): DeleteOp {
+  const clientEnd = client.position + client.count;
+  const serverEnd = server.position + server.count;
+
+  if (clientEnd <= server.position) {
+    // Client range is entirely before server range
+    return { ...client };
+  }
+  if (client.position >= serverEnd) {
+    // Client range is entirely after server range
+    return { ...client, position: client.position - server.count };
+  }
+
+  // Overlapping ranges
+  // Calculate how many chars the server already deleted from client's range
+  const overlapStart = Math.max(client.position, server.position);
+  const overlapEnd = Math.min(clientEnd, serverEnd);
+  const overlapCount = Math.max(0, overlapEnd - overlapStart);
+
+  const newCount = client.count - overlapCount;
+  const newPos = client.position >= server.position ? server.position : client.position;
+
+  return { type: 'delete', position: newPos, count: newCount };
+}
