new file mode 100644
index 0000000..f521c95
--- /dev/null
+++ b/src/db.test.ts
@@ -0,0 +1,134 @@
+import { describe, test, expect, beforeEach, afterEach } from 'vitest';
+import { createDb, type DocDatabase } from './db.js';
+import fs from 'fs';
+import path from 'path';
+import { fileURLToPath } from 'url';
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+
+let db: DocDatabase;
+const testDbPath = path.join(__dirname, 'test-db.sqlite');
+
+beforeEach(() => {
+  if (fs.existsSync(testDbPath)) fs.unlinkSync(testDbPath);
+  db = createDb(testDbPath);
+});
+
+afterEach(() => {
+  db.close();
+  if (fs.existsSync(testDbPath)) fs.unlinkSync(testDbPath);
+});
+
+describe('document CRUD', () => {
+  test('create document returns document with id', () => {
+    const doc = db.createDocument('Test Doc', 'initial content');
+    expect(doc.id).toBeDefined();
+    expect(doc.title).toBe('Test Doc');
+    expect(doc.content).toBe('initial content');
+    expect(doc.created_at).toBeDefined();
+    expect(doc.updated_at).toBeDefined();
+  });
+
+  test('create document with empty content', () => {
+    const doc = db.createDocument('Empty Doc');
+    expect(doc.content).toBe('');
+  });
+
+  test('get document by id', () => {
+    const created = db.createDocument('Test Doc', 'content');
+    const found = db.getDocument(created.id);
+    expect(found).toEqual(created);
+  });
+
+  test('get nonexistent document returns undefined', () => {
+    const found = db.getDocument('nonexistent-id');
+    expect(found).toBeUndefined();
+  });
+
+  test('list documents returns all', () => {
+    db.createDocument('Doc 1', 'a');
+    db.createDocument('Doc 2', 'b');
+    const docs = db.listDocuments();
+    expect(docs).toHaveLength(2);
+  });
+
+  test('update document title and content', () => {
+    const doc = db.createDocument('Old Title', 'old content');
+    const updated = db.updateDocument(doc.id, { title: 'New Title', content: 'new content' });
+    expect(updated!.title).toBe('New Title');
+    expect(updated!.content).toBe('new content');
+  });
+
+  test('update nonexistent document returns undefined', () => {
+    const result = db.updateDocument('nonexistent', { title: 'x' });
+    expect(result).toBeUndefined();
+  });
+
+  test('delete document', () => {
+    const doc = db.createDocument('To Delete', '');
+    const deleted = db.deleteDocument(doc.id);
+    expect(deleted).toBe(true);
+    expect(db.getDocument(doc.id)).toBeUndefined();
+  });
+
+  test('delete nonexistent document returns false', () => {
+    expect(db.deleteDocument('nonexistent')).toBe(false);
+  });
+});
+
+describe('version history', () => {
+  test('saving a version records it', () => {
+    const doc = db.createDocument('Doc', 'v0');
+    db.saveVersion(doc.id, 1, 'v1 content', { type: 'insert', position: 0, text: 'x' });
+    const versions = db.getVersions(doc.id);
+    expect(versions).toHaveLength(1);
+    expect(versions[0].version).toBe(1);
+    expect(versions[0].content).toBe('v1 content');
+  });
+
+  test('get versions returns them in order', () => {
+    const doc = db.createDocument('Doc', '');
+    db.saveVersion(doc.id, 1, 'v1', { type: 'insert', position: 0, text: 'a' });
+    db.saveVersion(doc.id, 2, 'v2', { type: 'insert', position: 1, text: 'b' });
+    db.saveVersion(doc.id, 3, 'v3', { type: 'insert', position: 2, text: 'c' });
+    const versions = db.getVersions(doc.id);
+    expect(versions).toHaveLength(3);
+    expect(versions[0].version).toBe(1);
+    expect(versions[2].version).toBe(3);
+  });
+
+  test('get latest version number', () => {
+    const doc = db.createDocument('Doc', '');
+    expect(db.getLatestVersion(doc.id)).toBe(0);
+    db.saveVersion(doc.id, 1, 'v1', { type: 'insert', position: 0, text: 'a' });
+    expect(db.getLatestVersion(doc.id)).toBe(1);
+    db.saveVersion(doc.id, 2, 'v2', { type: 'insert', position: 1, text: 'b' });
+    expect(db.getLatestVersion(doc.id)).toBe(2);
+  });
+
+  test('get operations since version', () => {
+    const doc = db.createDocument('Doc', '');
+    db.saveVersion(doc.id, 1, 'v1', { type: 'insert', position: 0, text: 'a' });
+    db.saveVersion(doc.id, 2, 'v2', { type: 'insert', position: 1, text: 'b' });
+    db.saveVersion(doc.id, 3, 'v3', { type: 'insert', position: 2, text: 'c' });
+    const ops = db.getOperationsSince(doc.id, 1);
+    expect(ops).toHaveLength(2);
+    expect(ops[0].version).toBe(2);
+    expect(ops[1].version).toBe(3);
+  });
+});
+
+describe('persistence', () => {
+  test('data survives close and reopen', () => {
+    const doc = db.createDocument('Persistent', 'hello');
+    db.saveVersion(doc.id, 1, 'hello world', { type: 'insert', position: 5, text: ' world' });
+    db.close();
+
+    const db2 = createDb(testDbPath);
+    const found = db2.getDocument(doc.id);
+    expect(found!.title).toBe('Persistent');
+    const versions = db2.getVersions(doc.id);
+    expect(versions).toHaveLength(1);
+    db2.close();
+  });
+});
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..e79c6a6
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,140 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import type { Operation } from './ot.js';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export interface DocDatabase {
+  createDocument(title: string, content?: string): Document;
+  getDocument(id: string): Document | undefined;
+  listDocuments(): Document[];
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined;
+  deleteDocument(id: string): boolean;
+  saveVersion(docId: string, version: number, content: string, operation: Operation): void;
+  getVersions(docId: string): Version[];
+  getLatestVersion(docId: string): number;
+  getOperationsSince(docId: string, sinceVersion: number): Version[];
+  updateContent(docId: string, content: string): void;
+  close(): void;
+}
+
+export function createDb(dbPath?: string): DocDatabase {
+  const db = new Database(dbPath || ':memory:');
+
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      operation TEXT,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      UNIQUE(document_id, version)
+    );
+  `);
+
+  const stmts = {
+    insertDoc: db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    ),
+    getDoc: db.prepare('SELECT * FROM documents WHERE id = ?'),
+    listDocs: db.prepare('SELECT * FROM documents ORDER BY updated_at DESC'),
+    updateDoc: db.prepare(
+      'UPDATE documents SET title = COALESCE(?, title), content = COALESCE(?, content), updated_at = datetime(\'now\') WHERE id = ?'
+    ),
+    deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),
+    insertVersion: db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    ),
+    getVersions: db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    ),
+    getLatestVersion: db.prepare(
+      'SELECT MAX(version) as max_version FROM versions WHERE document_id = ?'
+    ),
+    getOpsSince: db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC'
+    ),
+    updateContent: db.prepare(
+      'UPDATE documents SET content = ?, updated_at = datetime(\'now\') WHERE id = ?'
+    ),
+  };
+
+  return {
+    createDocument(title: string, content: string = ''): Document {
+      const id = randomUUID();
+      stmts.insertDoc.run(id, title, content);
+      return stmts.getDoc.get(id) as Document;
+    },
+
+    getDocument(id: string): Document | undefined {
+      return stmts.getDoc.get(id) as Document | undefined;
+    },
+
+    listDocuments(): Document[] {
+      return stmts.listDocs.all() as Document[];
+    },
+
+    updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+      const result = stmts.updateDoc.run(updates.title ?? null, updates.content ?? null, id);
+      if (result.changes === 0) return undefined;
+      return stmts.getDoc.get(id) as Document;
+    },
+
+    deleteDocument(id: string): boolean {
+      const result = stmts.deleteDoc.run(id);
+      return result.changes > 0;
+    },
+
+    saveVersion(docId: string, version: number, content: string, operation: Operation): void {
+      stmts.insertVersion.run(docId, version, content, JSON.stringify(operation));
+    },
+
+    getVersions(docId: string): Version[] {
+      return stmts.getVersions.all(docId) as Version[];
+    },
+
+    getLatestVersion(docId: string): number {
+      const row = stmts.getLatestVersion.get(docId) as { max_version: number | null };
+      return row.max_version ?? 0;
+    },
+
+    getOperationsSince(docId: string, sinceVersion: number): Version[] {
+      return stmts.getOpsSince.all(docId, sinceVersion) as Version[];
+    },
+
+    updateContent(docId: string, content: string): void {
+      stmts.updateContent.run(content, docId);
+    },
+
+    close(): void {
+      db.close();
+    },
+  };
+}
