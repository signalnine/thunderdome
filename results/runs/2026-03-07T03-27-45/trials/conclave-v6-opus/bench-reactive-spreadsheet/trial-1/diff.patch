@@ -0,0 +1,295 @@
+import { parse, extractDependencies, ASTNode } from './parser.js';
+
+export class Spreadsheet {
+  private rawValues: Map<string, string | number | boolean> = new Map();
+  private computedValues: Map<string, string | number | boolean | null> = new Map();
+  private formulas: Map<string, ASTNode> = new Map();
+  private dependencies: Map<string, Set<string>> = new Map();
+  private dependents: Map<string, Set<string>> = new Map();
+
+  private normalizeRef(cell: string): string {
+    return cell.toUpperCase();
+  }
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = this.normalizeRef(cell);
+
+    // Remove old dependencies
+    this.clearDependencies(ref);
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.slice(1);
+      const ast = parse(formulaStr);
+      const deps = this.resolveDependencyRefs(extractDependencies(ast));
+
+      // Check for circular references
+      this.checkCircular(ref, deps);
+
+      this.rawValues.set(ref, value);
+      this.formulas.set(ref, ast);
+      this.setDependencies(ref, deps);
+      this.recompute(ref);
+    } else {
+      this.rawValues.set(ref, value);
+      this.formulas.delete(ref);
+      this.computedValues.set(ref, value);
+    }
+
+    this.propagate(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const ref = this.normalizeRef(cell);
+    if (!this.rawValues.has(ref)) return null;
+    return this.computedValues.get(ref) ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, string | number | boolean | null> {
+    const result = new Map<string, string | number | boolean | null>();
+    for (const ref of this.rawValues.keys()) {
+      result.set(ref, this.computedValues.get(ref) ?? null);
+    }
+    return result;
+  }
+
+  private clearDependencies(ref: string): void {
+    const oldDeps = this.dependencies.get(ref);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        const depSet = this.dependents.get(dep);
+        if (depSet) depSet.delete(ref);
+      }
+    }
+    this.dependencies.delete(ref);
+  }
+
+  private setDependencies(ref: string, deps: string[]): void {
+    const depSet = new Set(deps);
+    this.dependencies.set(ref, depSet);
+    for (const dep of depSet) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+  }
+
+  private resolveDependencyRefs(deps: string[]): string[] {
+    const resolved: string[] = [];
+    for (const dep of deps) {
+      if (dep.includes(':')) {
+        const [start, end] = dep.split(':');
+        const cells = this.expandRange(start, end);
+        resolved.push(...cells);
+      } else {
+        resolved.push(dep);
+      }
+    }
+    return resolved;
+  }
+
+  private checkCircular(ref: string, deps: string[]): void {
+    const visited = new Set<string>();
+    const stack = [...deps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === ref) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const nextDeps = this.dependencies.get(current);
+      if (nextDeps) {
+        for (const d of nextDeps) {
+          stack.push(d);
+        }
+      }
+    }
+  }
+
+  private recompute(ref: string): void {
+    const ast = this.formulas.get(ref);
+    if (ast) {
+      this.computedValues.set(ref, this.evaluate(ast));
+    }
+  }
+
+  private propagate(changed: string): void {
+    const visited = new Set<string>();
+    const order: string[] = [];
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      order.push(ref);
+    };
+
+    const directDependents = this.dependents.get(changed);
+    if (directDependents) {
+      for (const dep of directDependents) {
+        visit(dep);
+      }
+    }
+
+    // Topological order: reverse so dependencies come first
+    order.reverse();
+    for (const ref of order) {
+      this.recompute(ref);
+    }
+  }
+
+  private evaluate(node: ASTNode): string | number | boolean {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cellRef': {
+        const val = this.get(node.ref);
+        return val === null ? 0 : val;
+      }
+      case 'unary': {
+        const operand = this.evaluate(node.operand);
+        if (node.op === '-') return -(operand as number);
+        return operand;
+      }
+      case 'binop':
+        return this.evaluateBinop(node.op, node.left, node.right);
+      case 'funcCall':
+        return this.evaluateFunction(node.name, node.args);
+      case 'range':
+        throw new Error('Ranges can only be used as function arguments');
+    }
+  }
+
+  private evaluateBinop(op: string, left: ASTNode, right: ASTNode): string | number | boolean {
+    const l = this.evaluate(left);
+    const r = this.evaluate(right);
+    const ln = l as number;
+    const rn = r as number;
+    switch (op) {
+      case '+': return ln + rn;
+      case '-': return ln - rn;
+      case '*': return ln * rn;
+      case '/': return ln / rn;
+      case '>': return ln > rn;
+      case '<': return ln < rn;
+      case '>=': return ln >= rn;
+      case '<=': return ln <= rn;
+      case '=': return l === r;
+      case '<>': return l !== r;
+      default:
+        throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  private evaluateFunction(name: string, args: ASTNode[]): string | number | boolean {
+    switch (name) {
+      case 'SUM': {
+        const values = this.collectNumericValues(args);
+        return values.reduce((sum, v) => sum + v, 0);
+      }
+      case 'AVERAGE': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return values.reduce((sum, v) => sum + v, 0) / values.length;
+      }
+      case 'MIN': {
+        const values = this.collectNumericValues(args);
+        return Math.min(...values);
+      }
+      case 'MAX': {
+        const values = this.collectNumericValues(args);
+        return Math.max(...values);
+      }
+      case 'COUNT': {
+        const values = this.collectNumericValues(args);
+        return values.length;
+      }
+      case 'IF': {
+        if (args.length !== 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evaluate(args[0]);
+        return condition ? this.evaluate(args[1]) : this.evaluate(args[2]);
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+
+  private collectNumericValues(args: ASTNode[]): number[] {
+    const values: number[] = [];
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = this.expandRange(arg.start, arg.end);
+        for (const cellRef of cells) {
+          const val = this.get(cellRef);
+          if (typeof val === 'number') values.push(val);
+        }
+      } else {
+        const val = this.evaluate(arg);
+        if (typeof val === 'number') values.push(val);
+      }
+    }
+    return values;
+  }
+
+  private expandRange(start: string, end: string): string[] {
+    const startCol = this.colToIndex(this.extractCol(start));
+    const startRow = this.extractRow(start);
+    const endCol = this.colToIndex(this.extractCol(end));
+    const endRow = this.extractRow(end);
+
+    const minCol = Math.min(startCol, endCol);
+    const maxCol = Math.max(startCol, endCol);
+    const minRow = Math.min(startRow, endRow);
+    const maxRow = Math.max(startRow, endRow);
+
+    const cells: string[] = [];
+    for (let col = minCol; col <= maxCol; col++) {
+      for (let row = minRow; row <= maxRow; row++) {
+        cells.push(this.indexToCol(col) + row);
+      }
+    }
+    return cells;
+  }
+
+  private extractCol(ref: string): string {
+    return ref.replace(/[0-9]/g, '');
+  }
+
+  private extractRow(ref: string): number {
+    return parseInt(ref.replace(/[A-Z]/gi, ''), 10);
+  }
+
+  private colToIndex(col: string): number {
+    let index = 0;
+    for (let i = 0; i < col.length; i++) {
+      index = index * 26 + (col.charCodeAt(i) - 64);
+    }
+    return index;
+  }
+
+  private indexToCol(index: number): string {
+    let col = '';
+    while (index > 0) {
+      const remainder = (index - 1) % 26;
+      col = String.fromCharCode(65 + remainder) + col;
+      index = Math.floor((index - 1) / 26);
+    }
+    return col;
+  }
+}
