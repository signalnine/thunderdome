    59→    if (ch === '>' || ch === '<') {\n    60→      if (i + 1 < input.length && (input[i + 1] === '=' || (ch === '<' && input[i + 1] === '>'))) {\n    61→        tokens.push({ type: 'compare', value: input[i] + input[i + 1] });\n    62→        i += 2;\n    63→      } else {\n    64→        tokens.push({ type: 'compare', value: ch });\n    65→        i++;\n    66→      }\n    67→      continue;\n    68→    }\n    69→\n    70→    // = as comparison (only when not at the very start, i.e., after tokenization of '=' prefix)\n    71→    if (ch === '=') {\n    72→      tokens.push({ type: 'compare', value: '=' });\n    73→      i++;\n    74→      continue;\n    75→    }\n    76→\n    77→    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {\n    78→      tokens.push({ type: 'op', value: ch });\n    79→      i++;\n    80→      continue;\n    81→    }\n    82→\n    83→    // Numbers\n    84→    if (ch >= '0' && ch <= '9') {\n    85→      let num = '';\n    86→      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {\n    87→        num += input[i];\n    88→        i++;\n    89→      }\n    90→      tokens.push({ type: 'number', value: num });\n    91→      continue;\n    92→    }\n    93→\n    94→    // Identifiers and cell references\n    95→    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {\n    96→      let ident = '';\n    97→      while (i < input.length && ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z') || (input[i] >= '0' && input[i] <= '9'))) {\n    98→        ident += input[i];\n    99→        i++;\n   100→      }\n   101→      const upper = ident.toUpperCase();\n   102→      if (upper === 'TRUE' || upper === 'FALSE') {\n   103→        tokens.push({ type: 'boolean', value: upper });\n   104→      } else if (/^[A-Z]+[0-9]+$/.test(upper)) {\n   105→        tokens.push({ type: 'cellRef', value: upper });\n   106→      } else {\n   107→        tokens.push({ type: 'ident', value