llectNumericValues(args);\n        return values.length;\n      }\n      case 'IF': {\n        if (args.length !== 3) throw new Error('IF requires 3 arguments');\n        const condition = this.evaluate(args[0]);\n        return condition ? this.evaluate(args[1]) : this.evaluate(args[2]);\n      }\n      default:\n        throw new Error(`Unknown function: ${name}`);\n    }\n  }\n\n  private collectNumericValues(args: ASTNode[]): number[] {\n    const values: number[] = [];\n    for (const arg of args) {\n      if (arg.type === 'range') {\n        const cells = this.expandRange(arg.start, arg.end);\n        for (const cellRef of cells) {\n          const val = this.get(cellRef);\n          if (typeof val === 'number') values.push(val);\n        }\n      } else {\n        const val = this.evaluate(arg);\n        if (typeof val === 'number') values.push(val);\n      }\n    }\n    return values;\n  }\n\n  expandRange(start: string, end: string): string[] {\n    const startCol = this.colToIndex(this.extractCol(start));\n    const startRow = this.extractRow(start);\n    const endCol = this.colToIndex(this.extractCol(end));\n    const endRow = this.extractRow(end);\n\n    const minCol = Math.min(startCol, endCol);\n    const maxCol = Math.max(startCol, endCol);\n    const minRow = Math.min(startRow, endRow);\n    const maxRow = Math.max(startRow, endRow);\n\n    const cells: string[] = [];\n    for (let col = minCol; col <= maxCol; col++) {\n      for (let row = minRow; row <= maxRow; row++) {\n        cells.push(this.indexToCol(col) + row);\n      }\n    }\n    return cells;\n  }\n\n  private extractCol(ref: string): string {\n    return ref.replace(/[0-9]/g, '');\n  }\n\n  private extractRow(ref: string): number {\n    return parseInt(ref.replace(/[A-Z]/gi, ''), 10);\n  }\n\n  private colToIndex(col: string): number {\n    let index = 0;\n    for (let i = 0; i < col.length; i++) {\n      index = index * 26 + (col.charCodeAt(i) - 64);\n    }\n    return index;\n  }\n\n  