 ref = this.normalizeRef(cell);\n\n    // Remove old dependencies\n    this.clearDependencies(ref);\n\n    if (typeof value === 'string' && value.startsWith('=')) {\n      const formulaStr = value.slice(1);\n      const ast = parse(formulaStr);\n      const deps = this.resolveDependencyRefs(extractDependencies(ast));\n\n      // Check for circular references\n      this.checkCircular(ref, deps);\n\n      this.rawValues.set(ref, value);\n      this.formulas.set(ref, ast);\n      this.setDependencies(ref, deps);\n      this.recompute(ref);\n    } else {\n      this.rawValues.set(ref, value);\n      this.formulas.delete(ref);\n      this.computedValues.set(ref, value);\n    }\n\n    this.propagate(ref);\n  }\n\n  get(cell: string): string | number | boolean | null {\n    const ref = this.normalizeRef(cell);\n    if (!this.rawValues.has(ref)) return null;\n    return this.computedValues.get(ref) ?? null;\n  }\n\n  getDisplay(cell: string): string {\n    const value = this.get(cell);\n    if (value === null) return '';\n    return String(value);\n  }\n\n  getCells(): Map<string, any> {\n    const result = new Map<string, any>();\n    for (const ref of this.rawValues.keys()) {\n      result.set(ref, this.computedValues.get(ref) ?? null);\n    }\n    return result;\n  }\n\n  private clearDependencies(ref: string): void {\n    const oldDeps = this.dependencies.get(ref);\n    if (oldDeps) {\n      for (const dep of oldDeps) {\n        const depSet = this.dependents.get(dep);\n        if (depSet) depSet.delete(ref);\n      }\n    }\n    this.dependencies.delete(ref);\n  }\n\n  private setDependencies(ref: string, deps: string[]): void {\n    const depSet = new Set(deps);\n    this.dependencies.set(ref, depSet);\n    for (const dep of depSet) {\n      if (!this.dependents.has(dep)) {\n        this.dependents.set(dep, new Set());\n      }\n      this.dependents.get(dep)!.add(ref);\n    }\n  }\n\n  private resolveDependencyRefs(deps: string[]): string[] {\n    const resolved: string[] = [];\n    for (const dep of deps) {\n      if (dep.includes(':')) {\n        const [start, end] = dep.split(':');\n        const cells = this.expandRange(start, end);\n        resolved.push(...cells);\n      } else {\n        resolved.push(dep);\n      }\n    }\n    return resolved;\n  }\n\n  private checkCircular(ref: string, deps: string[]): void {\n    const visited = new Set<string>();\n    const stack = [...deps];\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === ref) {\n        throw new Error(`Circular reference detected involving ${ref}`);\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n      const nextDeps = this.dependencies.get(current);\n      if (nextDeps) {\n        for (const d of nextDeps) {\n          stack.push(d);\n        }\n      }\n    }\n  }\n\n  private recompute(ref: string): void {\n    const ast = this.formulas.get(ref);\n    if (ast) {\n      this.computedValues.set(ref, this.evaluate(ast));\n    }\n  }\n\n  private propagate(changed: string): void {\n    const visited = new Set<string>();\n    const order: string[] = [];\n\n    const visit = (ref: string): void => {\n      if (visited.has(ref)) return;\n      visited.add(ref);\n      const deps = this.dependents.get(ref);\n      if (deps) {\n        for (const dep of deps) {\n          visit(dep);\n        }\n      }\n      order.push(ref);\n    };\n\n    const directDependents = this.dependents.get(changed);\n    if (directDependents) {\n      for (const dep of directDependents) {\n        visit(dep);\n      }\n    }\n\n    // Topological order: reverse so dependencies come first\n    order.reverse();\n    for (const ref of order) {\n      this.recompute(ref);\n    }\n  }\n\n  private evaluate(node: ASTNode): string | number | boolean {\n    switch (node.type) {\n      case 'number':\n        return node.value;\n      case 'string':\n        return node.value;\n      case 'boolean':\n        return node.