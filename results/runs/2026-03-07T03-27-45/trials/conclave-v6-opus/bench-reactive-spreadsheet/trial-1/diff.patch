        stack.push(d);\n        }\n      }\n    }\n  }\n\n  private recompute(ref: string): void {\n    const ast = this.formulas.get(ref);\n    if (ast) {\n      this.computedValues.set(ref, this.evaluate(ast));\n    }\n  }\n\n  private propagate(changed: string): void {\n    const visited = new Set<string>();\n    const order: string[] = [];\n\n    const visit = (ref: string): void => {\n      if (visited.has(ref)) return;\n      visited.add(ref);\n      const deps = this.dependents.get(ref);\n      if (deps) {\n        for (const dep of deps) {\n          visit(dep);\n        }\n      }\n      order.push(ref);\n    };\n\n    const directDependents = this.dependents.get(changed);\n    if (directDependents) {\n      for (const dep of directDependents) {\n        visit(dep);\n      }\n    }\n\n    // Topological order: reverse so dependencies come first\n    order.reverse();\n    for (const ref of order) {\n      this.recompute(ref);\n    }\n  }\n\n  private evaluate(node: ASTNode): string | number | boolean {\n    switch (node.type) {\n      case 'number':\n        return node.value;\n      case 'string':\n        return node.value;\n      case 'boolean':\n        return node.value;\n      case 'cellRef': {\n        const val = this.get(node.ref);\n        return val === null ? 0 : val;\n      }\n      case 'unary': {\n        const operand = this.evaluate(node.operand);\n        if (node.op === '-') return -(operand as number);\n        return operand;\n      }\n      case 'binop':\n        return this.evaluateBinop(node.op, node.left, node.right);\n      case 'funcCall':\n        return this.evaluateFunction(node.name, node.args);\n      case 'range':\n        throw new Error('Ranges can only be used as function arguments');\n    }\n  }\n\n  private evaluateBinop(op: string, left: ASTNode, right: ASTNode): string | number | boolean {\n    const l = this.evaluate(left);\n    const r = this.evaluate(right);\n    const ln = l as number;\n    const rn = r as number;\