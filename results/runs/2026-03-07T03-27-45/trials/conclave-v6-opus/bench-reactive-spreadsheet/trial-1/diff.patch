t(() => sheet.set('B1', '=A1+1')).toThrow();\n    });\n\n    it('detects indirect circular reference through multiple cells', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=C1');\n      sheet.set('B1', '=A1');\n      expect(() => sheet.set('C1', '=B1')).toThrow();\n    });\n\n    it('does not throw for non-circular dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=B1+1');\n      expect(sheet.get('C1')).toBe(12);\n    });\n  });\n\n  describe('getDisplay', () => {\n    it('displays number', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 42);\n      expect(sheet.getDisplay('A1')).toBe('42');\n    });\n\n    it('displays string', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 'hello');\n      expect(sheet.getDisplay('A1')).toBe('hello');\n    });\n\n    it('displays boolean', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', true);\n      expect(sheet.getDisplay('A1')).toBe('true');\n    });\n\n    it('displays empty string for empty cell', () => {\n      const sheet = new Spreadsheet();\n      expect(sheet.getDisplay('A1')).toBe('');\n    });\n\n    it('displays computed formula result', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.getDisplay('A3')).toBe('30');\n    });\n  });\n\n  describe('getCells', () => {\n    it('returns empty map for empty spreadsheet', () => {\n      const sheet = new Spreadsheet();\n      expect(sheet.getCells().size).toBe(0);\n    });\n\n    it('returns all non-empty cells with computed values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      const cells = sheet.getCells();\n      expect(cells.size).toBe(3);\n      expect(cells.get('A1')).toBe(10);\n      expect(cells.get('A2')).toBe(20);\n      expect(cells.get('A3')).toBe(30);\n    });\n  });\n\n  describe('edge cases', () => {\n    it('handles multi-letter column references (AA1)', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 42);\n      expect(sheet.get('AA1')).toBe(42);\n    });\n\n    it('handles formula with multi-letter column reference', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 10);\n      sheet.set('AB1', 20);\n      sheet.set('AC1', '=AA1+AB1');\n      expect(sheet.get('AC1')).toBe(30);\n    });\n\n    it('handles Z column and beyond', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('Z1', 100);\n      sheet.set('AA1', '=Z1+1');\n      expect(sheet.get('AA1')).toBe(101);\n    });\n\n    it('handles formula referencing cell set later', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('B1', '=A1+1');\n      expect(sheet.get('B1')).toBe(1); // A1 is empty, treated as 0\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(11);\n    });\n\n    it('handles nested function calls', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 10);\n      sheet.set('A3', 15);\n      sheet.set('B1', '=IF(SUM(A1:A3)>20, MAX(A1:A3), MIN(A1:A3))');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('example from spec works end-to-end', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n      expect(sheet.getDisplay('A3')).toBe('30');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(70);\n\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n    });\n  });\n});","originalFile":"import { describe, it, expect } from 'vitest';\nimport { Spreadsheet } from '../index.js';\n\ndescribe('Spreadsheet', () => {\n  describe('basic cell operations', () => {\n    it('returns null for empty cells', () => {\n      const sheet = new Spreadsheet();\n      expect(sheet.get('A1')).toBeNull();\n    });\n\n    it('stores and retrieves a number', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 42);\n      expect(sheet.get('A1')).toBe(42);\n    });\n\n    it('stores and retrieves a decimal number', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 3.14);\n      expect(sheet.get('A1')).toBe(3.14);\n    });\n\n    it('stores and retrieves a string', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 'hello');\n      expect(sheet.get('A1')).toBe('hello');\n    });\n\n    it('stores and retrieves a boolean true', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', true);\n      expect(sheet.get('A1')).toBe(true);\n    });\n\n    it('stores and retrieves a boolean false', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', false);\n      expect(sheet.get('A1')).toBe(false);\n    });\n\n    it('overwrites existing cell values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A1', 20);\n      expect(sheet.get('A1')).toBe(20);\n    });\n\n    it('stores values in different cells independently', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('B1', 2);\n      sheet.set('A2', 3);\n      expect(sheet.get('A1')).toBe(1);\n      expect(sheet.get('B1')).toBe(2);\n      expect(sheet.get('A2')).toBe(3);\n    });\n\n    it('handles cell references case-insensitively', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('a1', 42);\n      expect(sheet.get('A1')).toBe(42);\n    });\n  });\n\n  describe('formula evaluation', () => {\n    it('evaluates a simple addition formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('evaluates a subtraction formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1-A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('evaluates a multiplication formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 6);\n      sheet.set('A3', '=A1*A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('evaluates a division formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 100);\n      sheet.set('A2', 4);\n      sheet.set('A3', '=A1/A2');\n      expect(sheet.get('A3')).toBe(25);\n    });\n\n    it('evaluates formulas with numeric literals', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=2+3');\n      expect(sheet.get('A1')).toBe(5);\n    });\n\n    it('respects operator precedence (multiplication before addition)', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=2+3*4');\n      expect(sheet.get('A1')).toBe(14);\n    });\n\n    it('respects parentheses for grouping', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=(2+3)*4');\n      expect(sheet.get('A1')).toBe(20);\n    });\n\n    it('evaluates nested parentheses', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=((2+3)*4)+1');\n      expect(sheet.get('A1')).toBe(21);\n    });\n\n    it('evaluates a formula referencing another formula cell', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', '=A1+5');\n      sheet.set('A3', '=A2*2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('evaluates formula with cell reference and literal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+5');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('treats empty cell as 0 in arithmetic', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1+5');\n      expect(sheet.get('A1')).toBe(5);\n    });\n\n    it('handles unary negation', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=-5');\n      expect(sheet.get('A1')).toBe(-5);\n    });\n\n    it('handles formula with mixed cell ref and multiplication', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=(A1+A2)*2');\n      expect(sheet.get('A3')).toBe(60);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":154,"oldLines":4,"newStart":154,"newLines":371,"lines":["       expect(sheet.get('A3')).toBe(60);","     });","   });","+","+  describe('comparison operators and IF', () => {","+    it('evaluates greater than', () => {","+      const sheet = new Spreadsheet();","+      sheet.set('A1', 10);","+      sheet.set('A2', 5);","+      sheet.set('A3', '=A1>A2');","+      expect(sheet.get('A3')).toBe(true);","+    });","+","+    it('evaluates less than', () => {","+      const sheet = new Spreadsheet();","+      sheet.set('A1', 3);","+      sheet.set('A2', 5);","+      sheet.set('A3', '=A1<A2');","+      expect(sheet.get('A3')).toBe(true);","+    });","+","+    it('evaluates greater than or equal', () => {","+      const sheet = new Spreadsheet();","+      sheet.set('A1', 5);","+      sheet.set('A2', 5);","+      sheet.set('A3', '=A1>=A2');","+      expect(sheet.get('A3')).toBe(true);","+    });","+","+    it('evaluates less than or equal', () => {","+      const sheet = new Spreadsheet();","+      sheet.set('A1', 5);","+      sheet.set('A2', 10);","+      sheet.set('A3', '=A1<=A2');","+      expect(sheet.get('A3')).toBe(true);","+    });","+","+    it('evaluates equality with =', () => {","+      const sheet = new Spreadsheet();","+      sheet.set('A1', 5);","+      sheet.set('A2', 5);",