a35-4848-a9cd-3c873a805b18","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/routes/folders.ts","content":"import { Router } from 'express';\nimport crypto from 'node:crypto';\nimport type { Request } from 'express';\nimport type { Store } from '../store.js';\nimport { hasRole } from '../permissions.js';\n\ninterface AuthRequest extends Request {\n  userId: string;\n}\n\nexport function foldersRouter(store: Store): Router {\n  const router = Router();\n\n  router.post('/', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const { name, parentId } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: 'Name is required' });\n      return;\n    }\n\n    if (parentId && !store.folders.has(parentId)) {\n      res.status(404).json({ error: 'Parent folder not found' });\n      return;\n    }\n\n    const id = crypto.randomUUID();\n    const now = new Date().toISOString();\n    const folder = {\n      id,\n      name,\n      parentId: parentId || null,\n      ownerId: userId,\n      createdAt: now,\n      updatedAt: now,\n    };\n    store.folders.set(id, folder);\n\n    // Auto-assign owner permission\n    store.permissions.push({\n      id: crypto.randomUUID(),\n      resourceType: 'folder',\n      resourceId: id,\n      userId,\n      role: 'owner',\n    });\n\n    res.status(201).json(folder);\n  });\n\n  router.get('/:id', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'folder', folder.id, 'viewer')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    // Include children and documents\n    const children = Array.from(store.folders.values()).filter(f => f.parentId === folder.id);\n    const documents = Array.from(store.documents.values()).filter(d => d.folderId === folder.id);\n\n    res.json({ ...folder, children, documents });\n  });\n\n  router.put('/:id', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'folder', folder.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    if (req.body.name) {\n      folder.name = req.body.name;\n    }\n    folder.updatedAt = new Date().toISOString();\n\n    res.json(folder);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'folder', folder.id, 'owner')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    store.folders.delete(folder.id);\n    res.status(204).send();\n  });\n\n  return router;\n}\n","numLines":115,"startLine":1,"totalLines":115}}}
