c', content: 'Content', folderId: folder.body.id });\n\n      const shareRes = await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      expect(shareRes.status).toBe(200);\n\n      // Bob should now be able to read the document\n      const getRes = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n      expect(getRes.body.title).toBe('Doc');\n    });\n\n    test('editor can share a document', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'Content', folderId: folder.body.id });\n\n      // Share with bob as editor\n      await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      // Register charlie\n      const charlie = await registerAndLogin(app, 'charlie', 'charliepass');\n\n      // Bob (editor) shares with charlie\n      const shareRes = await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ userId: charlie.userId, role: 'viewer' });\n\n      expect(shareRes.status).toBe(200);\n    });\n\n    test('viewer cannot share a document', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'Content', folderId: folder.body.id });\n\n      // Share with bob as viewer\n      await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      const charlie = await registerAndLogin(app, 'charlie', 'charliepass');\n\n      // Bob (viewer) tries to share with charlie\n      const shareRes = await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ userId: charlie.userId, role: 'viewer' });\n\n      expect(shareRes.status).toBe(403);\n    });\n\n    test('returns 404 for non-existent document', async () => {\n      const res = await request(app)\n        .post('/documents/nonexistent/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      expect(res.status).toBe(404);\n    });\n\n    test('returns 400 for invalid role', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'Content', folderId: folder.body.id });\n\n      const res = await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'superadmin' });\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  describe('POST /folders/:id/share', () => {\n    test('owner can share a folder with another user', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      const shareRes = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      expect(shareRes.status).toBe(200);\n\n      // Bob should now be able to read the folder\n      const getRes = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n      expect(getRes.body.name).toBe('Shared Folder');\n    });\n\n    test('sharing folder grants access to documents inside it', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Inner Doc', content: 'Content', folderId: folder.body.id });\n\n      // Share folder with Bob as viewer\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Bob should be able to read the document inside the folder\n      const getRes = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n      expect(getRes.body.title).toBe('Inner Doc');\n    });\n  });\n\n  describe('Most permissive role', () => {\n    test('takes the most permissive role from multiple sources', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'Content', folderId: folder.body.id });\n\n      // Share folder with Bob as viewer\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Share document directly with Bob as editor\n      await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      // Bob should be able to edit the document (editor > viewer)\n      const updateRes = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ title: 'Updated' });\n\n      expect(updateRes.status).toBe(200);\n      expect(updateRes.body.title).toBe('Updated');\n    });\n  });\n});\n","structuredPatch":[{"oldStart":12,"oldLines":7,"newStart":12,"newLines":6,"lines":[" describe('Sharing', () => {","   let app: Express;","   let aliceToken: string;","-  let aliceId: string;","   let bobToken: string;","   let bobId: string;"," "]}],"userModified":false,"replaceAll":false}}
