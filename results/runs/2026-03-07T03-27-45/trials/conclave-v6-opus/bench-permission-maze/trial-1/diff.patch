+import { describe, test, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import type { Express } from 'express';
+
+async function registerAndLogin(app: Express, username = 'alice', password = 'pass123') {
+  const regRes = await request(app).post('/auth/register').send({ username, password });
+  const loginRes = await request(app).post('/auth/login').send({ username, password });
+  return { token: loginRes.body.token as string, userId: regRes.body.id as string };
+}
+
+describe('Permission Inheritance', () => {
+  let app: Express;
+  let aliceToken: string;
+  let bobToken: string;
+  let bobId: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const alice = await registerAndLogin(app, 'alice', 'alicepass');
+    aliceToken = alice.token;
+    const bob = await registerAndLogin(app, 'bob', 'bobpass');
+    bobToken = bob.token;
+    bobId = bob.userId;
+  });
+
+  test('nested folder inherits parent folder permissions', async () => {
+    const parent = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Parent' });
+
+    const child = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Child', parentId: parent.body.id });
+
+    // Share parent with Bob as viewer
+    await request(app)
+      .post(`/folders/${parent.body.id}/share`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ userId: bobId, role: 'viewer' });
+
+    // Bob should be able to read the child folder
+    const res = await request(app)
+      .get(`/folders/${child.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('Child');
+  });
+
+  test('documents inherit permissions from deeply nested folders', async () => {
+    const grandparent = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Grandparent' });
+
+    const parent = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Parent', parentId: grandparent.body.id });
+
+    const child = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Child', parentId: parent.body.id });
+
+    const doc = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Deep Doc', content: 'Content', folderId: child.body.id });
+
+    // Share grandparent with Bob as editor
+    await request(app)
+      .post(`/folders/${grandparent.body.id}/share`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ userId: bobId, role: 'editor' });
+
+    // Bob should be able to edit the deeply nested document
+    const updateRes = await request(app)
+      .put(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ title: 'Updated Deep Doc' });
+
+    expect(updateRes.status).toBe(200);
+    expect(updateRes.body.title).toBe('Updated Deep Doc');
+  });
+
+  test('most permissive role wins across folder and direct permissions', async () => {
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    const doc = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Content', folderId: folder.body.id });
+
+    // Share folder with Bob as viewer
+    await request(app)
+      .post(`/folders/${folder.body.id}/share`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ userId: bobId, role: 'viewer' });
+
+    // Bob can read but not edit
+    const readRes = await request(app)
+      .get(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+    expect(readRes.status).toBe(200);
+
+    const editRes1 = await request(app)
+      .put(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ title: 'Nope' });
+    expect(editRes1.status).toBe(403);
+
+    // Now share document directly with Bob as editor
+    await request(app)
+      .post(`/documents/${doc.body.id}/share`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ userId: bobId, role: 'editor' });
+
+    // Now Bob can edit (editor > viewer)
+    const editRes2 = await request(app)
+      .put(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ title: 'Updated' });
+    expect(editRes2.status).toBe(200);
+  });
+
+  test('user without any permissions cannot access nested resources', async () => {
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Private Folder' });
+
+    const doc = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Private Doc', content: 'Secret', folderId: folder.body.id });
+
+    // Bob has no permissions at all
+    const folderRes = await request(app)
+      .get(`/folders/${folder.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+    expect(folderRes.status).toBe(403);
+
+    const docRes = await request(app)
+      .get(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+    expect(docRes.status).toBe(403);
+  });
+
+  test('sharing a child folder does not grant access to parent', async () => {
+    const parent = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Parent' });
+
+    const child = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Child', parentId: parent.body.id });
+
+    // Share child with Bob
+    await request(app)
+      .post(`/folders/${child.body.id}/share`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ userId: bobId, role: 'viewer' });
+
+    // Bob can read child
+    const childRes = await request(app)
+      .get(`/folders/${child.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+    expect(childRes.status).toBe(200);
+
+    // Bob cannot read parent
+    const parentRes = await request(app)
+      .get(`/folders/${parent.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+    expect(parentRes.status).toBe(403);
+  });
+});
diff --git a/src/middleware/auth.ts b/src/middleware/auth.ts
