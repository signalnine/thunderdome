+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RQsQEQ4eowcWNazbZB9EZY","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NcoRQdX93xJCH4gstRmmxj","name":"Write","input":{"file_path":"/workspace/src/documents.test.ts","content":"import { describe, test, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport { createApp } from './app.js';\nimport type { Express } from 'express';\n\nasync function registerAndLogin(app: Express, username = 'alice', password = 'pass123') {\n  await request(app).post('/auth/register').send({ username, password });\n  const loginRes = await request(app).post('/auth/login').send({ username, password });\n  return loginRes.body.token as string;\n}\n\nasync function createFolder(app: Express, token: string, name: string, parentId?: string) {\n  const res = await request(app)\n    .post('/folders')\n    .set('Authorization', `Bearer ${token}`)\n    .send({ name, parentId });\n  return res.body;\n}\n\ndescribe('Documents', () => {\n  let app: Express;\n  let token: string;\n  let folderId: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    token = await registerAndLogin(app);\n    const folder = await createFolder(app, token, 'Test Folder');\n    folderId = folder.id;\n  });\n\n  describe('POST /documents', () => {\n    test('creates a document and returns 201', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Hello world', folderId });\n\n      expect(res.status).toBe(201);\n      expect(res.body).toHaveProperty('id');\n      expect(res.body.title).toBe('My Doc');\n      expect(res.body.content).toBe('Hello world');\n      expect(res.body.folderId).toBe(folderId);\n      expect(res.body).toHaveProperty('ownerId');\n    });\n\n    test('returns 400 when title is missing', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ content: 'Some text', folderId });\n\n      expect(res.status).toBe(400);\n    });\n\n    test('returns 400 when folderId is missing', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Some text' });\n\n      expect(res.status).toBe(400);\n    });\n\n    test('returns 404 when folder does not exist', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Some text', folderId: 'nonexistent' });\n\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('GET /documents/:id', () => {\n    test('returns a document by id', async () => {\n      const created = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Hello', folderId });\n\n      const res = await request(app)\n        .get(`/documents/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('My Doc');\n      expect(res.body.content).toBe('Hello');\n    });\n\n    test('returns 404 for non-existent document', async () => {\n      const res = await request(app)\n        .get('/documents/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(404);\n    });\n\n    test('returns 403 when user has no access', async () => {\n      const created = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Private', content: 'Secret', folderId });\n\n      const bobToken = await registerAndLogin(app, 'bob', 'bobpass');\n\n      const res = await request(app)\n        .get(`/documents/${created.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('PUT /documents/:id', () => {\n    test('updates a document', async () => {\n      const created = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Old Title', content: 'Old Content', folderId });\n\n      const res = await request(app)\n        .put(`/documents/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'New Title', content: 'New Content' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('New Title');\n      expect(res.body.content).toBe('New Content');\n    });\n\n    test('returns 403 when non-editor tries to update', async () => {\n      const created = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Protected', content: 'Content', folderId });\n\n      const bobToken = await registerAndLogin(app, 'bob', 'bobpass');\n\n      const res = await request(app)\n        .put(`/documents/${created.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ title: 'Hacked' });\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('DELETE /documents/:id', () => {\n    test('deletes a document and returns 204', async () => {\n      const created = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'To Delete', content: 'Bye', folderId });\n\n      const res = await request(app)\n        .delete(`/documents/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(204);\n\n      const getRes = await request(app)\n        .get(`/documents/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(getRes.status).toBe(404);\n    });\n\n    test('re