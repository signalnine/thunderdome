m 'express';\nimport crypto from 'node:crypto';\nimport type { Request } from 'express';\nimport type { Store } from '../store.js';\nimport { hasRole } from '../permissions.js';\n\ninterface AuthRequest extends Request {\n  userId: string;\n}\n\nexport function documentsRouter(store: Store): Router {\n  const router = Router();\n\n  router.post('/', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const { title, content, folderId } = req.body;\n\n    if (!title || !folderId) {\n      res.status(400).json({ error: 'Title and folderId are required' });\n      return;\n    }\n\n    if (!store.folders.has(folderId)) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    const id = crypto.randomUUID();\n    const now = new Date().toISOString();\n    const doc = {\n      id,\n      title,\n      content: content || '',\n      folderId,\n      ownerId: userId,\n      createdAt: now,\n      updatedAt: now,\n    };\n    store.documents.set(id, doc);\n\n    // Auto-assign owner permission\n    store.permissions.push({\n      id: crypto.randomUUID(),\n      resourceType: 'document',\n      resourceId: id,\n      userId,\n      role: 'owner',\n    });\n\n    res.status(201).json(doc);\n  });\n\n  router.get('/:id', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'viewer')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    res.json(doc);\n  });\n\n  router.put('/:id', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    if (req.body.title !== undefined) {\n      doc.title = req.body.title;\n    }\n    if (req.body.content !== undefined) {\n      doc.content = req.body.content;\n    }\n    doc.updatedAt = new Date().toISOString();\n\n    res.json(doc);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'owner')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    store.documents.delete(doc.id);\n    res.status(204).send();\n  });\n\n  return router;\n}\n","numLines":115,"startLine":1,"totalLines":115}}}
