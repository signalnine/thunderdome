enied' });\n      return;\n    }\n\n    res.json(doc);\n  });\n\n  router.put('/:id', (req, res) => {\n    const userId = req.userId!;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    if (req.body.title !== undefined) {\n      doc.title = req.body.title;\n    }\n    if (req.body.content !== undefined) {\n      doc.content = req.body.content;\n    }\n    doc.updatedAt = new Date().toISOString();\n\n    // Log activity\n    store.activity.push({\n      id: crypto.randomUUID(),\n      action: 'document_updated',\n      userId,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: doc.updatedAt,\n    });\n\n    res.json(doc);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const userId = req.userId!;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'owner')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    store.documents.delete(doc.id);\n\n    // Log activity\n    store.activity.push({\n      id: crypto.randomUUID(),\n      action: 'document_deleted',\n      userId,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: new Date().toISOString(),\n    });\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1931,"cache_read_input_tokens":65572,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1931},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"p