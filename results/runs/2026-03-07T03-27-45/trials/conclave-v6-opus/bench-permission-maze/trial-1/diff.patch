res) => {\n    const { userId } = req as AuthRequest;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    if (req.body.title !== undefined) {\n      doc.title = req.body.title;\n    }\n    if (req.body.content !== undefined) {\n      doc.content = req.body.content;\n    }\n    doc.updatedAt = new Date().toISOString();\n\n    res.json(doc);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const { userId } = req as AuthRequest;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'owner')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    store.documents.delete(doc.id);\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":496,"cache_read_input_tokens":41797,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":496},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7cccab6c-6eb7-4896-8d8c-f45c0c7d18df","uuid":"8ab4b575-a3dd-4d5e-82d7-f0f11c13b20f"}
