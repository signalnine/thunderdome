@@ -0,0 +1,22 @@
+import type { Request, Response, NextFunction } from 'express';
+import type { Store } from '../store.js';
+
+export function authMiddleware(store: Store) {
+  return (req: Request, res: Response, next: NextFunction): void => {
+    const header = req.headers.authorization;
+    if (!header || !header.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const token = header.slice(7);
+    const userId = store.tokens.get(token);
+    if (!userId) {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+
+    req.userId = userId;
+    next();
+  };
+}
diff --git a/src/permissions.ts b/src/permissions.ts
new file mode 100644
index 0000000..c8eb814
--- /dev/null
+++ b/src/permissions.ts
@@ -0,0 +1,73 @@
+import type { Store } from './store.js';
+import type { Role } from './types.js';
+
+const ROLE_LEVEL: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+  let bestLevel = 0;
+
+  // Check direct permissions
+  for (const perm of store.permissions) {
+    if (perm.resourceType === resourceType && perm.resourceId === resourceId && perm.userId === userId) {
+      const level = ROLE_LEVEL[perm.role];
+      if (level > bestLevel) {
+        bestLevel = level;
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // If document, check folder permissions (walk up the hierarchy)
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);
+      if (folderRole) {
+        const level = ROLE_LEVEL[folderRole];
+        if (level > bestLevel) {
+          bestLevel = level;
+          bestRole = folderRole;
+        }
+      }
+    }
+  }
+
+  // If folder, check parent folder permissions (walk up the hierarchy)
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);
+      if (parentRole) {
+        const level = ROLE_LEVEL[parentRole];
+        if (level > bestLevel) {
+          bestLevel = level;
+          bestRole = parentRole;
+        }
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  minimumRole: Role
+): boolean {
+  const effective = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effective) return false;
+  return ROLE_LEVEL[effective] >= ROLE_LEVEL[minimumRole];
+}
