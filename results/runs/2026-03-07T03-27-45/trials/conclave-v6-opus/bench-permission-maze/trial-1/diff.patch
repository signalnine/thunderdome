@@ -0,0 +1,125 @@
+import { Router } from 'express';
+import crypto from 'node:crypto';
+import type { Store } from '../store.js';
+import { hasRole } from '../permissions.js';
+import type { Role } from '../types.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function sharingRouter(store: Store): Router {
+  const router = Router();
+
+  router.post('/documents/:id/share', (req, res) => {
+    const userId = req.userId!;
+    const { id } = req.params;
+    const { userId: targetUserId, role } = req.body;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!targetUserId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    if (!hasRole(store, userId, 'document', id, 'editor')) {
+      res.status(403).json({ error: 'Access denied. Must be editor or owner to share' });
+      return;
+    }
+
+    // Remove existing permission for this user/resource if any
+    const existingIdx = store.permissions.findIndex(
+      p => p.resourceType === 'document' && p.resourceId === id && p.userId === targetUserId
+    );
+    if (existingIdx >= 0) {
+      store.permissions.splice(existingIdx, 1);
+    }
+
+    store.permissions.push({
+      id: crypto.randomUUID(),
+      resourceType: 'document',
+      resourceId: id,
+      userId: targetUserId,
+      role,
+    });
+
+    // Log activity
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'share',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: new Date().toISOString(),
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(200).json({ message: 'Document shared successfully' });
+  });
+
+  router.post('/folders/:id/share', (req, res) => {
+    const userId = req.userId!;
+    const { id } = req.params;
+    const { userId: targetUserId, role } = req.body;
+
+    const folder = store.folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!targetUserId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    if (!hasRole(store, userId, 'folder', id, 'editor')) {
+      res.status(403).json({ error: 'Access denied. Must be editor or owner to share' });
+      return;
+    }
+
+    // Remove existing permission for this user/resource if any
+    const existingIdx = store.permissions.findIndex(
+      p => p.resourceType === 'folder' && p.resourceId === id && p.userId === targetUserId
+    );
+    if (existingIdx >= 0) {
+      store.permissions.splice(existingIdx, 1);
+    }
+
+    store.permissions.push({
+      id: crypto.randomUUID(),
+      resourceType: 'folder',
+      resourceId: id,
+      userId: targetUserId,
+      role,
+    });
+
+    // Log activity
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'share',
+      userId,
+      resourceType: 'folder',
+      resourceId: id,
+      timestamp: new Date().toISOString(),
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(200).json({ message: 'Folder shared successfully' });
+  });
+
+  return router;
+}
