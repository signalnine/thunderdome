+import { Router } from 'express';
+import crypto from 'node:crypto';
+import type { Store } from '../store.js';
+
+export function authRouter(store: Store): Router {
+  const router = Router();
+
+  router.post('/register', (req, res) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    const existing = Array.from(store.users.values()).find(u => u.username === username);
+    if (existing) {
+      res.status(409).json({ error: 'Username already exists' });
+      return;
+    }
+
+    const id = crypto.randomUUID();
+    const user = {
+      id,
+      username,
+      password,
+      createdAt: new Date().toISOString(),
+    };
+    store.users.set(id, user);
+
+    res.status(201).json({ id: user.id, username: user.username });
+  });
+
+  router.post('/login', (req, res) => {
+    const { username, password } = req.body;
+
+    const user = Array.from(store.users.values()).find(u => u.username === username);
+    if (!user || user.password !== password) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = crypto.randomUUID();
+    store.tokens.set(token, user.id);
+
+    res.status(200).json({ token });
+  });
+
+  return router;
+}
