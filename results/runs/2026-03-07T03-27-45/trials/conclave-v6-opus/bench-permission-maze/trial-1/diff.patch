new file mode 100644
index 0000000..fbacad7
--- /dev/null
+++ b/src/activity.test.ts
@@ -0,0 +1,147 @@
+import { describe, test, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import type { Express } from 'express';
+
+async function registerAndLogin(app: Express, username = 'alice', password = 'pass123') {
+  const regRes = await request(app).post('/auth/register').send({ username, password });
+  const loginRes = await request(app).post('/auth/login').send({ username, password });
+  return { token: loginRes.body.token as string, userId: regRes.body.id as string };
+}
+
+describe('Activity Log', () => {
+  let app: Express;
+  let aliceToken: string;
+  let aliceId: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const alice = await registerAndLogin(app);
+    aliceToken = alice.token;
+    aliceId = alice.userId;
+  });
+
+  test('logs document creation', async () => {
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    expect(res.status).toBe(200);
+    expect(Array.isArray(res.body)).toBe(true);
+
+    const createEntry = res.body.find((e: { action: string }) => e.action === 'document_created');
+    expect(createEntry).toBeDefined();
+    expect(createEntry.userId).toBe(aliceId);
+    expect(createEntry).toHaveProperty('timestamp');
+    expect(createEntry.resourceType).toBe('document');
+  });
+
+  test('logs document update', async () => {
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    const doc = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });
+
+    await request(app)
+      .put(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Updated' });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    const updateEntry = res.body.find((e: { action: string }) => e.action === 'document_updated');
+    expect(updateEntry).toBeDefined();
+    expect(updateEntry.resourceId).toBe(doc.body.id);
+  });
+
+  test('logs document deletion', async () => {
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    const doc = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });
+
+    await request(app)
+      .delete(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    const deleteEntry = res.body.find((e: { action: string }) => e.action === 'document_deleted');
+    expect(deleteEntry).toBeDefined();
+  });
+
+  test('logs sharing events', async () => {
+    const bob = await registerAndLogin(app, 'bob', 'bobpass');
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ name: 'Folder' });
+
+    const doc = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });
+
+    await request(app)
+      .post(`/documents/${doc.body.id}/share`)
+      .set('Authorization', `Bearer ${aliceToken}`)
+      .send({ userId: bob.userId, role: 'viewer' });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    const shareEntry = res.body.find((e: { action: string }) => e.action === 'share');
+    expect(shareEntry).toBeDefined();
+    expect(shareEntry.userId).toBe(aliceId);
+  });
