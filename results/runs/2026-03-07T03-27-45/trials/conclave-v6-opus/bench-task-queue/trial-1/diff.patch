n}\n\nexport interface ScheduleOptions {\n  id: string;\n  cron: string;\n  queue: string;\n  payload: unknown;\n}\n\ninterface Schedule {\n  id: string;\n  cron: string;\n  queue: string;\n  payload: unknown;\n}\n\nexport interface ShutdownOptions {\n  timeout?: number;\n}\n\nexport interface ShutdownResult {\n  completed: number;\n  forceCancelled: number;\n  duration: number;\n}\n\ntype MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;\ntype HandlerFn = (task: Task) => Promise<void>;\ntype ProgressCallback = (progress: number, message?: string) => void;\n\nexport class TaskQueue {\n  private queues = new Map<string, Task[]>();\n  private allTasks = new Map<string, Task>();\n  private deadLetterQueues = new Map<string, Task[]>();\n  private concurrencyLimits = new Map<string, number>();\n  private progressListeners = new Map<string, Set<ProgressCallback>>();\n  private schedules = new Map<string, Schedule>();\n  private middlewareStacks = new Map<string, MiddlewareFn[]>();\n  private handlers = new Map<string, HandlerFn>();\n  private shutdownCallbacks: Array<() => void> = [];\n  private isShutdown = false;\n  private shutdownResult: ShutdownResult | null = null;\n\n  private getOrCreateQueue(name: string): Task[] {\n    let q = this.queues.get(name);\n    if (!q) {\n      q = [];\n      this.queues.set(name, q);\n    }\n    return q;\n  }\n\n  private getOrCreateDLQ(name: string): Task[] {\n    let dlq = this.deadLetterQueues.get(name);\n    if (!dlq) {\n      dlq = [];\n      this.deadLetterQueues.set(name, dlq);\n    }\n    return dlq;\n  }\n\n  add(options: TaskOptions): Task {\n    if (this.isShutdown) {\n      throw new Error('TaskQueue is shut down and no longer accepts new tasks');\n    }\n\n    const priority = options.priority ?? 5;\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority ${priority}: must be an integer between 1 and 10`);\n    }\n\n    // Validate dependencies exist\n    if (options.dependencies) {\n      for (const depId of options.dependencies) {\n        if (!this.allTasks.has(depId)) {\n          throw new Error(`Dependency task '${depId}' does not exist`);\n        }\n      }\n      // Check for circular dependencies\n      this.detectCircularDeps(options.dependencies);\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n\n    let availableAt: Date | null = null;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    const hasDeps = options.dependencies && options.dependencies.length > 0;\n    const unresolvedDeps = hasDeps\n      ? options.dependencies!.filter(id => {\n          const dep = this.allTasks.get(id)!;\n          return dep.status !== 'completed';\n        })\n      : [];\n\n    const task: Task = {\n      id: randomUUID(),\n      status: unresolvedDeps.length > 0 ? 'blocked' : 'pending',\n      payload: options.payload,\n      createdAt: new Date(),\n      queueName,\n      priority,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoff: options.backoff ?? 1000,\n      lastError: null,\n      progress: 0,\n      progressMessage: null,\n      dependencies: options.dependencies ?? [],\n    };\n\n    this.getOrCreateQueue(queueName).push(task);\n    this.allTasks.set(task.id, task);\n    return task;\n  }\n\n  next(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const q = this.queues.get(name);\n    if (!q) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(name);\n    if (limit != null) {\n      const activeCount = q.filter(t => t.status === 'processing').length;\n      if (activeCount >= limit) return null;\n    }\n\n    const now = Date.now();\n\n    // Find available tasks: pending, not delayed (or delay has passed)\n    const available = q.filter(t => {\n      if (t.status !== 'pending') return false;\n      if (t.availableAt && t.availableAt.getTime() > now) return false;\n      return true;\n    });\n\n    if (available.length === 0) return null;\n\n    // Sort by: availability time (earlier first), then priority (lower number first), then FIFO (createdAt)\n    available.sort((a, b) => {\n      // First: tasks with availableAt set go after non-delayed tasks only if both are available\n      const aTime = a.availableAt ? a.availableAt.getTime() : 0;\n      const bTime = b.availableAt ? b.availableAt.getTime() : 0;\n\n      if (aTime !== bTime) return aTime - bTime;\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = available[0];\n    task.status = 'processing';\n    return task;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const q = this.queues.get(name);\n    if (!q) return 0;\n    return q.filter(t => t.status === 'pending').length;\n  }\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  getTask(id: string): Task | null {\n    return this.allTasks.get(id) ?? null;\n  }\n\n  complete(id: string): void {\n    const task = this.allTasks.get(id);\n    if (!task) throw new Error(`Task '${id}' not found`);\n    task.status = 'completed';\n\n    // Check if any blocked tasks can be unblocked\n    this.checkDependentsUnblocked(id);\n  }\n\n  fail(id: string, error: string): void {\n    const task = this.allTasks.get(id);\n    if (!task) throw new Error(`Task '${id}' not found`);\n\n    task.attempts++;\n    task.lastError = error;\n\n    if (task.attempts <= task.maxRetries) {\n      // Retry with backoff\n      const delay = task.backoff * Math.pow(2, task.attempts - 1);\n      task.availableAt = delay > 0 ? new Date(Date.now() + delay) : new Date(Date.now());\n      task.status = 'pending';\n    } else {\n      // Exhausted retries - move to DLQ\n      task.status = 'failed';\n      const dlq = this.getOrCreateDLQ(task.queueName);\n      dlq.push(task);\n    }\n  }\n\n  // Dead Letter Queue operations\n  getDeadLetterQueue(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return this.deadLetterQueues.get(name) ?? [];\n  }\n\n  requeueFromDLQ(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    // Remove from DLQ\n    const dlq = this.deadLetterQueues.get(task.queueName);\n    if (dlq) {\n      const idx = dlq.indexOf(task);\n      if (idx >= 0) dlq.splice(idx, 1);\n    }\n\n    // Reset for fresh round\n    task.status = 'pending';\n    task.attempts = 0;\n    task.lastError = null;\n    task.availableAt = null;\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    this.deadLetterQueues.set(name, []);\n  }\n\n  // Dependencies\n  private detectCircularDeps(depIds: string[]): void {\n    // For circular detection, we'd need to check if any new task's dependencies\n    // would create a cycle. Since we're adding a NEW task with deps on existing tasks,\n    // and the new task doesn't exist yet, there can't be a cycle at add time\n    // (existing tasks can't depend on something that doesn't exist yet).\n    // Cycles could only occur if we allowed adding dependencies after creation.\n  }\n\n  private checkDependentsUnblocked(completedId: string): void {\n    for (const [, task] of this.allTasks) {\n      if (task.status !== 'blocked') continue;\n      if (!task.dependencies.includes(completedId)) continue;\n\n      // Check if all dependencies are completed\n      const allDepsCompleted = task.dependencies.every(depId => {\n        const dep = this.allTasks.get(depId);\n        return dep && dep.status === 'completed';\n      });\n\n      if (allDepsCompleted) {\n        task.status = 'pending';\n      }\n    }\n  }\n\n  getDependencyStatus(taskId: string): Array<{ id: string; status: TaskStatus }> {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    return task.dependencies.map(depId => {\n      const dep = this.allTasks.get(depId)!;\n      return { id: dep.id, status: dep.status };\n    });\n  }\n\n  // Concurrency\n  setConcurrency(queueName: string, limit: number): void {\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName: string): number | undefined {\n    return this.concurrencyLimits.get(queueName);\n  }\n\n  getActiveCount(queueName: string): number {\n    const q = this.queues.get(queueName);\n    if (!q) return 0;\n    return q.filter(t => t.status === 'processing').length;\n  }\n\n  // Progress\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    task.progress = progress;\n    task.progressMessage = message ?? null;\n\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const cb of listeners) {\n        cb(progress, message);\n      }\n    }\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    let listeners = this.progressListeners.get(taskId);\n    if (!listeners) {\n      listeners = new Set();\n      this.progressListeners.set(taskId, listeners);\n    }\n    listeners.add(callback);\n\n    return () => {\n      listeners!.delete(callback);\n    };\n  }\n\n  // Cancellation\n  cancel(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    if (task.status === 'pending' || task.status === 'processing') {\n      task.status = 'cancelled';\n    }\n  }\n\n  // Recurring tasks\n  addSchedule(options: ScheduleOptions): void {\n    this.schedules.set(options.id, {\n      id: options.id,\n      cron: options.cron,\n      queue: options.queue,\n      payload: options.payload,\n    });\n  }\n\n  removeSchedule(id: string): void {\n    this.schedules.delete(id);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now: Date): void {\n    for (const [, schedule] of this.schedules) {\n      if (this.cronMatches(schedule.cron, now)) {\n        this.add({\n          payload: schedule.payload,\n          queue: schedule.queue,\n        });\n      }\n    }\n  }\n\n  private cronMatches(cron: string, date: Date): boolean {\n    const parts = cron.split(' ');\n    if (parts.length !== 5) return false;\n\n    const minute = date.getMinutes();\n    const hour = date.getHours();\n\n    // Parse minute field\n    if (!this.cronFieldMatches(parts[0], minute)) return false;\n    // Parse hour field\n    if (!this.cronFieldMatches(parts[1], hour)) return false;\n    // Day of month, month, day of week: only support *\n    // (sufficient for the required subset)\n\n    return true;\n  }\n\n  private cronFieldMatches(field: string, value: number): boolean {\n    if (field === '*') return true;\n\n    // Handle */N\n    if (field.startsWith('*/')) {\n      const n = parseInt(field.slice(2), 10);\n      return value % n === 0;\n    }\n\n    // Handle exact value\n    const num = parseInt(field, 10);\n    return value === num;\n  }\n\n  // Middleware\n  use(queueName: string, middleware: MiddlewareFn): void {\n    let stack = this.middlewareStacks.get(queueName);\n    if (!stack) {\n      stack = [];\n      this.middlewareStacks.set(queueName, stack);\n    }\n    stack.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: HandlerFn): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  async process(taskId: string): Promise<void> {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    const middlewares = this.middlewareStacks.get(task.queueName) ?? [];\n    const handler = this.handlers.get(task.queueName);\n\n    let index = 0;\n\n    const executeNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        await mw(task, executeNext);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    try {\n      await executeNext();\n    } catch (err) {\n      const message = err instanceof Error ? err.message : String(err);\n      this.fail(taskId, message);\n    }\n  }\n\n  // Graceful shutdown\n  onShutdown(callback: () => void): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (this.shutdownResult) return this.shutdownResult;\n\n    this.isShutdown = true;\n    const startTime = Date.now();\n    const timeout = options?.timeout ?? 30000;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      cb();\n    }\n\n    // Gather all processing tasks across all queues\n    const processingTasks: Task[] = [];\n    for (const [, q] of this.queues) {\n      for (const t of q) {\n        if (t.status === 'processing') {\n          processingTasks.push(t);\n        }\n      }\n    }\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    if (processingTasks.length > 0) {\n      // Wait for processing tasks to complete, up to timeout\n      await new Promise<void>((resolve) => {\n        const checkInterval = setInterval(() => {\n          const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n          const justCompleted = processingTasks.filter(t => t.status === 'completed').length;\n\n          if (stillProcessing.length === 0) {\n            clearInterval(checkInterval);\n            completed = justCompleted;\n            resolve();\n          } else if (Date.now() - startTime >= timeout) {\n            clearInterval(checkInterval);