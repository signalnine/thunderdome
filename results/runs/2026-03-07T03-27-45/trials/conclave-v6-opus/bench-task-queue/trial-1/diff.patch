+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Af563Lkxt5hThuAnHqPsjZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TMXz99hdbJ5q8MWPBBHpzr","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, test, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  test('adds a task and returns a task object with id, status, payload, createdAt', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'hello' });\n    expect(task).toBeDefined();\n    expect(typeof task.id).toBe('string');\n    expect(task.id.length).toBeGreaterThan(0);\n    expect(task.status).toBe('pending');\n    expect(task.payload).toBe('hello');\n    expect(task.createdAt).toBeInstanceOf(Date);\n  });\n\n  test('each task has a unique id', () => {\n    const tq = new TaskQueue();\n    const t1 = tq.add({ payload: 'a' });\n    const t2 = tq.add({ payload: 'b' });\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  test('retrieves tasks in FIFO order', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'first' });\n    tq.add({ payload: 'second' });\n    tq.add({ payload: 'third' });\n\n    const t1 = tq.next();\n    expect(t1!.payload).toBe('first');\n    expect(t1!.status).toBe('processing');\n\n    const t2 = tq.next();\n    expect(t2!.payload).toBe('second');\n\n    const t3 = tq.next();\n    expect(t3!.payload).toBe('third');\n  });\n\n  test('returns null when no tasks are available', () => {\n    const tq = new TaskQueue();\n    expect(tq.next()).toBeNull();\n  });\n\n  test('returns null after all tasks have been retrieved', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'only' });\n    tq.next();\n    expect(tq.next()).toBeNull();\n  });\n\n  test('size returns number of pending tasks', () => {\n    const tq = new TaskQueue();\n    expect(tq.size()).toBe(0);\n    tq.add({ payload: 'a' });\n    tq.add({ payload: 'b' });\n    expect(tq.size()).toBe(2);\n    tq.next(); // moves one to processing\n    expect(tq.size()).toBe(1);\n  });\n});\n\ndescribe('Phase 2: Named Queues', () => {\n  test('adds tasks to a named queue', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x', queue: 'emails' });\n    expect(task.payload).toBe('x');\n  });\n\n  test('named queues are independent', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'email-task', queue: 'emails' });\n    tq.add({ payload: 'sms-task', queue: 'sms' });\n\n    const fromEmail = tq.next('emails');\n    expect(fromEmail!.payload).toBe('email-task');\n\n    const fromSms = tq.next('sms');\n    expect(fromSms!.payload).toBe('sms-task');\n  });\n\n  test('default queue is used when no name given', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'default-task' });\n    const task = tq.next();\n    expect(task!.payload).toBe('default-task');\n  });\n\n  test('returns null for non-existent queue', () => {\n    const tq = new TaskQueue();\n    expect(tq.next('nonexistent')).toBeNull();\n  });\n\n  test('returns null for empty queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', queue: 'q1' });\n    tq.next('q1');\n    expect(tq.next('q1')).toBeNull();\n  });\n\n  test('lists all queue names', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'a', queue: 'alpha' });\n    tq.add({ payload: 'b', queue: 'beta' });\n    const names = tq.getQueueNames();\n    expect(names).toContain('alpha');\n    expect(names).toContain('beta');\n  });\n\n  test('size works per queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'a', queue: 'q1' });\n    tq.add({ payload: 'b', queue: 'q1' });\n    tq.add({ payload: 'c', queue: 'q2' });\n    expect(tq.size('q1')).toBe(2);\n    expect(tq.size('q2')).toBe(1);\n  });\n});\n\ndescribe('Phase 3: Priority', () => {\n  test('higher priority tasks (lower number) are returned first', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'low', priority: 10 });\n    tq.add({ payload: 'high', priority: 1 });\n    tq.add({ payload: 'mid', priority: 5 });\n\n    expect(tq.next()!.payload).toBe('high');\n    expect(tq.next()!.payload).toBe('mid');\n    expect(tq.next()!.payload).toBe('low');\n  });\n\n  test('default priority is 5', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    expect(task.priority).toBe(5);\n  });\n\n  test('same priority maintains FIFO order', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'first', priority: 3 });\n    tq.add({ payload: 'second', priority: 3 });\n    tq.add({ payload: 'third', priority: 3 });\n\n    expect(tq.next()!.payload).toBe('first');\n    expect(tq.next()!.payload).toBe('second');\n    expect(tq.next()!.payload).toBe('third');\n  });\n\n  test('invalid priority throws error', () => {\n    const tq = new TaskQueue();\n    expect(() => tq.add({ payload: 'x', priority: 0 })).toThrow();\n    expect(() => tq.add({ payload: 'x', priority: 11 })).toThrow();\n    expect(() => tq.add({ payload: 'x', priority: -1 })).toThrow();\n  });\n\n  test('priority is per-queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'q1-low', priority: 10, queue: 'q1' });\n    tq.add({ payload: 'q1-high', priority: 1, queue: 'q1' });\n    tq.add({ payload: 'q2-mid', priority: 5, queue: 'q2' });\n\n    expect(tq.next('q1')!.payload).toBe('q1-high');\n    expect(tq.next('q2')!.payload).toBe('q2-mid');\n  });\n\n  test('task exposes priority', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x', priority: 3 });\n    expect(task.priority).toBe(3);\n  });\n});\n\ndescribe('Phase 4: Delayed Tasks', () => {\n  test('delayed task is not returned before its availability time', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'delayed', delay: 100000 });\n    expect(tq.next()).toBeNull();\n  });\n\n  test('delayed task is returned after availability time', () => {\n    const tq = new TaskQueue();\n    const now = Date.now();\n    tq.add({ payload: 'delayed', availableAt: new Date(now - 1000) });\n    const task = tq.next();\n    expect(task).not.toBeNull();\n    expect(task!.payload).toBe('delayed');\n  });\n\n  test('non-delayed tasks are preferred over not-yet-available delayed tasks', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'delayed', delay: 100000 });\n    tq.add({ payload: 'immediate' });\n    expect(tq.next()!.payload).toBe('immediate');\n    expect(tq.next()).toBeNull(); // delayed not ready\n  });\n\n  test('multiple delayed tasks ordered by availability then priority then FIFO', () => {\n    const tq = new TaskQueue();\n    const now = Date.now();\n    tq.add({ payload: 'later', availableAt: new Date(now - 500) });\n    tq.add({ payload: 'earlier', availableAt: new Date(now - 1000) });\n    expect(tq.next()!.payload).toBe('earlier');\n    expect(tq.next()!.payload).toBe('later');\n  });\n\n  test('task exposes availableAt', () => {\n    const tq = new TaskQueue();\n    const futureDate = new Date(Date.now() + 10000);\n    const task = tq.add({ payload: 'x', availableAt: futureDate });\n    expect(task.availableAt).toEqual(futureDate);\n  });\n\n  test('delay creates availableAt from now', () => {\n    const tq = new TaskQueue();\n    const before = Date.now();\n    const task = tq.add({ payload: 'x', delay: 5000 });\n    const after = Date.now();\n    expect(task.availableAt!.getTime()).toBeGreaterThanOrEqual(before + 5000);\n    expect(task.availableAt!.getTime()).toBeLessThanOrEqual(after + 5000);\n  });\n\n  test('delays work with named queues', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'delayed', delay: 100000, queue: 'q1' });\n    tq.add({ payload: 'immediate', queue: 'q1' });\n    expect(tq.next('q1')!.payload).toBe('immediate');\n  });\n});\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  test('complete marks a task as completed', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    tq.complete(task.id);\n    expect(tq.getTask(task.id)!.status).toBe('completed');\n  });\n\n  test('fail marks a task as failed and retries with delay', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 3, backoff: 1000 });\n    const task = tq.next()!;\n    tq.fail(task.id, 'oops');\n\n    // Task should be re-queued as pending with a delay\n    const retried = tq.getTask(task.id)!;\n    expect(retried.status).toBe('pending');\n    expect(retried.attempts).toBe(1);\n    expect(retried.availableAt).toBeDefined();\n    expect(retried.lastError).toBe('oops');\n  });\n\n  test('exponential backoff: delay doubles each attempt', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 3, backoff: 1000 });\n\n    // Attempt 1\n    let task = tq.next()!;\n    const baseTime = Date.now();\n    tq.fail(task.id, 'e1');\n    let t = tq.getTask(task.id)!;\n    // backoff = 1000 * 2^0 = 1000\n    expect(t.availableAt!.getTime()).toBeGreaterThanOrEqual(baseTime + 1000 - 50);\n  });\n\n  test('default maxRetries is 3', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    expect(task.maxRetries).toBe(3);\n  });\n\n  test('default backoff is 1000ms', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    expect(task.backoff).toBe(1000);\n  });\n\n  test('task tracks attempts', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    expect(task.attempts).toBe(0);\n  });\n\n  test('retried tasks keep original queue and priority', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', queue: 'myq', priority: 2, maxRetries: 3, backoff: 0 });\n    const task = tq.next('myq')!;\n    tq.fail(task.id, 'err');\n    const retried = tq.getTask(task.id)!;\n    expect(retried.queueName).toBe('myq');\n    expect(retried.priority).toBe(2);\n  });\n\n  test('task remains failed after all retries exhausted', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 1, backoff: 0 });\n\n    let task = tq.next()!;\n    tq.fail(task.id, 'err1');\n\n    // 1 retry - make it available immediately\n    const retried = tq.getTask(task.id)!;\n    expect(retried.status).toBe('pending');\n\n    // force availability for test\n    retried.availableAt = new Date(Date.now() - 1);\n    task = tq.next()!;\n    tq.fail(task.id, 'err2');\n\n    const final = tq.getTask(task.id)!;\n    expect(final.status).toBe('failed');\n    expect(final.attempts).toBe(2);\n  });\n});\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  test('task moves to DLQ after exhausting retries', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 0, backoff: 0 });\n    const task = tq.next()!;\n    tq.fail(task.id, 'fatal');\n\n    const dlq = tq.getDeadLetterQueue();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].id).toBe(task.id);\n    expect(dlq[0].lastError).toBe('fatal');\n  });\n\n  test('dead letter queue is per named queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', queue: 'q1', maxRetries: 0 });\n    tq.add({ payload: 'y', queue: 'q2', maxRetries: 0 });\n\n    tq.fail(tq.next('q1')!.id, 'e1');\n    tq.fail(tq.next('q2')!.id, 'e2');\n\n    expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n  });\n\n  test('dead-lettered tasks retain error info and fail count', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 1, backoff: 0 });\n    let task = tq.next()!;\n    tq.fail(task.id, 'err1');\n\n    // make available again\n    tq.getTask(task.id)!.availableAt = new Date(Date.now() - 1);\n    task = tq.next()!;\n    tq.fail(task.id, 'err2');\n\n    const dlq = tq.getDeadLetterQueue();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].lastError).toBe('err2');\n    expect(dlq[0].attempts).toBe(2);\n  });\n\n  test('requeue from DLQ back to original queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 0, queue: 'myq' });\n    const task = tq.next('myq')!;\n    tq.fail(task.id, 'err');\n\n    expect(tq.getDeadLetterQueue('myq')).toHaveLength(1);\n\n    tq.requeueFromDLQ(task.id);\n\n    expect(tq.getDeadLetterQueue('myq')).toHaveLength(0);\n    const requeued = tq.getTask(task.id)!;\n    expect(requeued.status).toBe('pending');\n    expect(requeued.attempts).toBe(0);\n  });\n\n  test('clear DLQ for a queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'a', maxRetries: 0 });\n    tq.add({ payload: 'b', maxRetries: 0 });\n    tq.fail(tq.next()!.id, 'e');\n    tq.fail(tq.next()!.id, 'e');\n\n    expect(tq.getDeadLetterQueue()).toHaveLength(2);\n    tq.clearDeadLetterQueue();\n    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n  });\n});\n\ndescribe('Phase 7: Task Dependencies', () => {\n  test('task with dependencies starts as blocked', () => {\n    const tq = new TaskQueue();\n    const dep = tq.add({ payload: 'dep' });\n    const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n    expect(task.status).toBe('blocked');\n  });\n\n  test('blocked task is not returned by next', () => {\n    const tq = new TaskQueue();\n    const dep = tq.add({ payload: 'dep' });\n    tq.add({ payload: 'main', dependencies: [dep.id] });\n    const next = tq.next();\n    expect(next!.payload).toBe('dep');\n    expect(tq.next()).toBeNull(); // main is blocked\n  });\n\n  test('completing dependency unblocks dependent task', () => {\n    const tq = new TaskQueue();\n    const dep = tq.add({ payload: 'dep' });\n    const main = tq.add({ payload: 'main', dependencies: [dep.id] });\n\n    const processing = tq.next()!;\n    tq.complete(processing.id);\n\n    expect(tq.getTask(main.id)!.status).toBe('pending');\n    const next = tq.next();\n    expect(next!.payload).toBe('main');\n  });\n\n  test('circular dependencies are rejected', () => {\n    const tq = new TaskQueue();\n    const a = tq.add({ payload: 'a' });\n    const b = tq.add({ payload: 'b', dependencies: [a.id] });\n    expect(() => tq.add({ payload: 'c', dependencies: [b.id, a.id] })).not.toThrow();\n\n    // Direct circular: can't depend on self (would need to be implemented differently)\n    // Indirect: a depends on something that depends on a\n  });\n\n  test('depending on non-existent task throws error', () => {\n    const tq = new TaskQueue();\n    expect(() => tq.add({ payload: 'x', dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  test('failed dependency keeps dependents blocked', () => {\n    const tq = new TaskQueue();\n    const dep = tq.add({ payload: 'dep', maxRetries: 0 });\n    tq.add({ payload: 'main', dependencies: [dep.id] });\n\n    tq.fail(tq.next()!.id, 'err');\n    expect(tq.next()).toBeNull();\n  });\n\n  test('can inspect dependency status', () => {\n    const tq = new TaskQueue();\n    const dep1 = tq.add({ payload: 'dep1' });\n    const dep2 = tq.add({ payload: 'dep2' });\n    const main = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n\n    const deps = tq.getDependencyStatus(main.id);\n    expect(deps).toHaveLength(2);\n    expect(deps.some(d => d.id === dep1.id && d.status === 'pending')).toBe(true);\n    expect(deps.some(d => d.id === dep2.id && d.status === 'pending')).toBe(true);\n  });\n\n  test('detects indirect circular dependencies', () => {\n    const tq = new TaskQueue();\n    const a = tq.add({ payload: 'a' });\n    const b = tq.add({ payload: 'b', dependencies: [a.id] });\n    const c = tq.add({ payload: 'c', dependencies: [b.id] });\n    // Now try to make a depend on c - this creates a->b->c->a cycle\n    // We need to test this differently since a is already added without deps\n    // Instead, test by creating the cycle at add time\n    expect(() => {\n      // d depends on c, and e depends on d\n      const d = tq.add({ payload: 'd', dependencies: [c.id] });\n      // Try to create a task that depends on d and that d depends on\n      // Actually: create circular by having e depend on d and f depend on e, then try g depending on f and d depending on g\n    }).not.toThrow();\n  });\n});\n\ndescribe('Phase 8: Concurrency Control', () => {\n  test('limits concurrent processing tasks', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 2);\n    tq.add({ payload: 'a' });\n    tq.add({ payload: 'b' });\n    tq.add({ payload: 'c' });\n\n    expect(tq.next()).not.toBeNull(); // 1 processing\n    expect(tq.next()).not.toBeNull(); // 2 processing\n    expect(tq.next()).toBeNull(); // at limit\n  });\n\n  test('completing a task frees a concurrency slot', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 1);\n    tq.add({ payload: 'a' });\n    tq.add({ payload: 'b' });\n\n    const task = tq.next()!;\n    expect(tq.next()).toBeNull(); // at limit\n\n    tq.complete(task.id);\n    expect(tq.next()).not.toBeNull(); // slot freed\n  });\n\n  test('failing a task frees a concurrency slot', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 1);\n    tq.add({ payload: 'a', maxRetries: 0 });\n    tq.add({ payload: 'b' });\n\n    const task = tq.next()!;\n    expect(tq.next()).toBeNull();\n\n    tq.fail(task.id, 'err');\n    expect(tq.next()).not.toBeNull(); // slot freed\n  });\n\n  test('default is unlimited concurrency', () => {\n    const tq = new TaskQueue();\n    for (let i = 0; i < 100; i++) {\n      tq.add({ payload: i });\n    }\n    for (let i = 0; i < 100; i++) {\n      expect(tq.next()).not.toBeNull();\n    }\n  });\n\n  test('can query concurrency limit and active count', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 5);\n    tq.add({ payload: 'a' });\n    tq.add({ payload: 'b' });\n    tq.next();\n\n    expect(tq.getConcurrency('default')).toBe(5);\n    expect(tq.getActiveCount('default')).toBe(1);\n  });\n\n  test('concurrency respects priority ordering', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 1);\n    tq.add({ payload: 'low', priority: 10 });\n    tq.add({ payload: 'high', priority: 1 });\n\n    const task = tq.next()!;\n    expect(task.payload).toBe('high');\n  });\n});\n\ndescribe('Phase 9: Progress and Cancellation', () => {\n  test('report progress on a processing task', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    tq.updateProgress(task.id, 50, 'halfway');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.progress).toBe(50);\n    expect(updated.progressMessage).toBe('halfway');\n  });\n\n  test('subscribe to progress updates', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    const updates: Array<{ progress: number; message?: string }> = [];\n    tq.onProgress(task.id, (progress, message) => {\n      updates.push({ progress, message });\n    });\n\n    tq.updateProgress(task.id, 25, 'quarter');\n    tq.updateProgress(task.id, 75, 'three quarters');\n\n    expect(updates).toHaveLength(2);\n    expect(updates[0].progress).toBe(25);\n    expect(updates[1].progress).toBe(75);\n  });\n\n  test('unsubscribe from progress updates', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    const updates: number[] = [];\n    const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n    tq.updateProgress(task.id, 50);\n    unsub();\n    tq.updateProgress(task.id, 100);\n\n    expect(updates).toHaveLength(1);\n  });\n\n  test('cancel a pending task', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    tq.cancel(task.id);\n\n    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    expect(tq.next()).toBeNull();\n  });\n\n  test('cancel a processing task', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    tq.cancel(task.id);\n    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n  });\n\n  test('cancelled tasks are never retried', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 3 });\n    const task = tq.next()!;\n    tq.cancel(task.id);\n\n    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    expect(tq.next()).toBeNull();\n  });\n});\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  test('create a schedule and tick enqueues a task', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'every-5-min',\n      cron: '*/5 * * * *',\n      queue: 'default',\n      payload: { type: 'cleanup' },\n    });\n\n    // Set time to a 5-minute boundary\n    const schedules = tq.getSchedules();\n    expect(schedules).toHaveLength(1);\n    expect(schedules[0].id).toBe('every-5-min');\n  });\n\n  test('tick enqueues tasks when schedule is due', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'every-min',\n      cron: '*/1 * * * *',\n      queue: 'default',\n      payload: { type: 'ping' },\n    });\n\n    // Tick with a time that matches (any exact minute)\n    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n    tq.tick(atMinute);\n\n    expect(tq.size()).toBe(1);\n    const task = tq.next()!;\n    expect(task.payload).toEqual({ type: 'ping' });\n  });\n\n  test('tick does not enqueue if not due', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'hourly',\n      cron: '0 * * * *',\n      queue: 'default',\n      payload: 'hourly-task',\n    });\n\n    // Tick at :30 past - not on the hour\n    const notOnHour = new Date(2025, 0, 1, 12, 30, 0);\n    tq.tick(notOnHour);\n    expect(tq.size()).toBe(0);\n  });\n\n  test('remove a schedule stops future enqueuing', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'sched1',\n      cron: '*/1 * * * *',\n      queue: 'default',\n      payload: 'x',\n    });\n    tq.removeSchedule('sched1');\n\n    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n    tq.tick(atMinute);\n    expect(tq.size()).toBe(0);\n  });\n\n  test('list active schedules', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({ id: 's1', cron: '*/1 * * * *', queue: 'default', payload: 'a' });\n    tq.addSchedule({ id: 's2', cron: '0 0 * * *', queue: 'daily', payload: 'b' });\n\n    const schedules = tq.getSchedules();\n    expect(schedules).toHaveLength(2);\n  });\n\n  test('recurring tasks are regular tasks subject to queue rules', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 1);\n    tq.addSchedule({\n      id: 's1',\n      cron: '*/1 * * * *',\n      queue: 'default',\n      payload: 'recurring',\n    });\n\n    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n    tq.tick(atMinute);\n\n    const task = tq.next()!;\n    expect(task.payload).toBe('recurring');\n    expect(task.status).toBe('processing');\n  });\n\n  test('daily at midnight cron expression', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'daily',\n      cron: '0 0 * * *',\n      queue: 'default',\n      payload: 'daily',\n    });\n\n    const midnight = new Date(2025, 0, 1, 0, 0, 0);\n    tq.tick(midnight);\n    expect(tq.size()).toBe(1);\n\n    const notMidnight = new Date(2025, 0, 1, 12, 0, 0);\n    tq.tick(notMidnight);\n    expect(tq.size()).toBe(1); // still just 1\n  });\n});\n\ndescribe('Phase 11: Middleware Pipeline', () => {\n  test('middleware is called when processing a task', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('default', async (task, next) => {\n      calls.push('middleware1');\n      await next();\n    });\n\n    tq.setHandler('default', async (task) => {\n      calls.push('handler');\n    });\n\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(calls).toEqual(['middleware1', 'handler']);\n  });\n\n  test('middleware executes in registration order', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('default', async (task, next) => {\n      calls.push('first');\n      await next();\n    });\n\n    tq.use('default', async (task, next) => {\n      calls.push('second');\n      await next();\n    });\n\n    tq.setHandler('default', async () => {\n      calls.push('handler');\n    });\n\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(calls).toEqual(['first', 'second', 'handler']);\n  });\n\n  test('middleware that does not call next skips processing', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('default', async (_task, _next) => {\n      calls.push('blocker');\n      // does NOT call next\n    });\n\n    tq.setHandler('default', async () => {\n      calls.push('handler');\n    });\n\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(calls).toEqual(['blocker']);\n  });\n\n  test('middleware can modify the task', async () => {\n    const tq = new TaskQueue();\n\n    tq.use('default', async (task, next) => {\n      (task as any).metadata = { injected: true };\n      await next();\n    });\n\n    let receivedTask: any;\n    tq.setHandler('default', async (task) => {\n      receivedTask = task;\n    });\n\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(receivedTask.metadata).toEqual({ injected: true });\n  });\n\n  test('middleware error marks task as failed', async () => {\n    const tq = new TaskQueue();\n\n    tq.use('default', async (_task, _next) => {\n      throw new Error('middleware-error');\n    });\n\n    tq.setHandler('default', async () => {});\n\n    tq.add({ payload: 'x', maxRetries: 0 });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(tq.getTask(task.id)!.status).toBe('failed');\n  });\n\n  test('each queue has independent middleware', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('q1', async (task, next) => {\n      calls.push('q1-middleware');\n      await next();\n    });\n\n    tq.setHandler('q1', async () => { calls.push('q1-handler'); });\n    tq.setHandler('q2', async () => { calls.push('q2-handler'); });\n\n    tq.add({ payload: 'x', queue: 'q1' });\n    tq.add({ payload: 'y', queue: 'q2' });\n\n    await tq.process(tq.next('q1')!.id);\n    await tq.process(tq.next('q2')!.id);\n\n    expect(calls).toEqual(['q1-middleware', 'q1-handler', 'q2-handler']);\n  });\n});\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  test('shutdown stops accepting new tasks', async () => {\n    const tq = new TaskQueue();\n    await tq.shutdown();\n    expect(() => tq.add({ payload: 'x' })).toThrow();\n  });\n\n  test('shutdown waits for processing tasks to complete', async () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    // Complete the task asynchronously\n    setTimeout(() => tq.complete(task.id), 50);\n\n    const result = await tq.shutdown({ timeout: 5000 });\n    expect(result.completed).toBe(1);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  test('shutdown force-cancels tasks that exceed timeout', async () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    tq.next()!; // starts processing but never completes\n\n    const result = await tq.shutdown({ timeout: 50 });\n    expect(result.forceCancelled).toBe(1);\n  });\n\n  test('shutdown completes immediately if no tasks processing', async () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' }); // pending, not processing\n    const before = Date.now();\n    const result = await tq.shutdown();\n    const elapsed 