n).toBeGreaterThanOrEqual(0);\n  });\n});\n","structuredPatch":[{"oldStart":800,"oldLines":11,"newStart":800,"newLines":11,"lines":["     const tq = new TaskQueue();"," ","     tq.use('default', async (task, next) => {","-      (task as any).metadata = { injected: true };","+      task.metadata = { injected: true };","       await next();","     });"," ","-    let receivedTask: any;","+    let receivedTask: Record<string, unknown> | undefined;","     tq.setHandler('default', async (task) => {","       receivedTask = task;","     });"]},{"oldStart":813,"oldLines":7,"newStart":813,"newLines":7,"lines":["     const task = tq.next()!;","     await tq.process(task.id);"," ","-    expect(receivedTask.metadata).toEqual({ injected: true });","+    expect(receivedTask!.metadata).toEqual({ injected: true });","   });"," ","   test('middleware error marks task as failed', async () => {"]}],"userModified":false,"replaceAll":false}}
