unt', () => {\n   342→    const tq = new TaskQueue();\n   343→    tq.add({ payload: 'x', maxRetries: 1, backoff: 0 });\n   344→    let task = tq.next()!;\n   345→    tq.fail(task.id, 'err1');\n   346→\n   347→    // make available again\n   348→    tq.getTask(task.id)!.availableAt = new Date(Date.now() - 1);\n   349→    task = tq.next()!;\n   350→    tq.fail(task.id, 'err2');\n   351→\n   352→    const dlq = tq.getDeadLetterQueue();\n   353→    expect(dlq).toHaveLength(1);\n   354→    expect(dlq[0].lastError).toBe('err2');\n   355→    expect(dlq[0].attempts).toBe(2);\n   356→  });\n   357→\n   358→  test('requeue from DLQ back to original queue', () => {\n   359→    const tq = new TaskQueue();\n   360→    tq.add({ payload: 'x', maxRetries: 0, queue: 'myq' });\n   361→    const task = tq.next('myq')!;\n   362→    tq.fail(task.id, 'err');\n   363→\n   364→    expect(tq.getDeadLetterQueue('myq')).toHaveLength(1);\n   365→\n   366→    tq.requeueFromDLQ(task.id);\n   367→\n   368→    expect(tq.getDeadLetterQueue('myq')).toHaveLength(0);\n   369→    const requeued = tq.getTask(task.id)!;\n   370→    expect(requeued.status).toBe('pending');\n   371→    expect(requeued.attempts).toBe(0);\n   372→  });\n   373→\n   374→  test('clear DLQ for a queue', () => {\n   375→    const tq = new TaskQueue();\n   376→    tq.add({ payload: 'a', maxRetries: 0 });\n   377→    tq.add({ payload: 'b', maxRetries: 0 });\n   378→    tq.fail(tq.next()!.id, 'e');\n   379→    tq.fail(tq.next()!.id, 'e');\n   380→\n   381→    expect(tq.getDeadLetterQueue()).toHaveLength(2);\n   382→    tq.clearDeadLetterQueue();\n   383→    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n   384→  });\n   385→});\n   386→\n   387→describe('Phase 7: Task Dependencies', () => {\n   388→  test('task with dependencies starts as blocked', () => {\n   389→    const tq = new TaskQueue();\n   390→    const dep = tq.add({ payload: 'dep' });\n   391→    const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n   392→    expect(task.status).toBe('blocked');\n   393→  });\n   394→\n   395→  test('blocked task is not returned by next', () => {\n   396→    const tq = new TaskQueue();\n   397→    const dep = tq.add({ payload: 'dep' });\n   398→    tq.add({ payload: 'main', dependencies: [dep.id] });\n   399→    const next = tq.next();\n   400→    expect(next!.payload).toBe('dep');\n   401→    expect(tq.next()).toBeNull(); // main is blocked\n   402→  });\n   403→\n   404→  test('completing dependency unblocks dependent task', () => {\n   405→    const tq = new TaskQueue();\n   406→    const dep = tq.add({ payload: 'dep' });\n   407→    const main = tq.add({ payload: 'main', dependencies: [dep.id] });\n   408→\n   409→    const processing = tq.next()!;\n   410→    tq.complete(processing.id);\n   411→\n   412→    expect(tq.getTask(main.id)!.status).toBe('pending');\n   413→    const next = tq.next();\n   414→    expect(next!.payload).toBe('main');\n   415→  });\n   416→\n   417→  test('circular dependencies are rejected', () => {\n   418→    const tq = new TaskQueue();\n   419→    const a = tq.add({ payload: 'a' });\n   420→    const b = tq.add({ payload: 'b', dependencies: [a.id] });\n   421→    expect(() => tq.add({ payload: 'c', dependencies: [b.id, a.id] })).not.toThrow();\n   422→\n   423→    // Direct circular: can't depend on self (would need to be implemented differently)\n   424→    // Indirect: a depends on something that depends on a\n   425→  });\n   426→\n   427→  test('depending on non-existent task throws error', () => {\n   428→    const tq = new TaskQueue();\n   429→    expect(() => tq.add({ payload: 'x', dependencies: ['nonexistent'] })).toThrow();\n   430→  });\n   431→\n   432→  test('failed dependency keeps dependents blocked', () => {\n   433→    const tq = new TaskQueue();\n   434→    const dep = tq.add({ payload: 'dep', maxRetries: 0 });\n   435→    tq.add({ payload: 'main', dependencies: [dep.id] });\n   436→\n   437→    tq.fail(tq.next()!.id, 'err');\n   438→    expect(tq.next()).toBeNull();\n   439→  });\n   440→\n   441→  test('can inspect dependency status', () => {\n   442→    const tq = new TaskQueue();\n   443→    const dep1 = tq.add({ payload: 'dep1' });\n   444→    const dep2 = tq.add({ payload: 'dep2' });\n   445→    const main = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n   446→\n   447→    const deps = tq.getDependencyStatus(main.id);\n   448→    expect(deps).toHaveLength(2);\n   449→    expect(deps.some(d => d.id === dep1.id && d.status === 'pending')).toBe(true);\n   450→    expect(deps.some(d => d.id === dep2.id && d.status === 'pending')).toBe(true);\n   451→  });\n   452→\n   453→  test('detects indirect circular dependencies', () => {\n   454→    const tq = new TaskQueue();\n   455→    const a = tq.add({ payload: 'a' });\n   456→    const b = tq.add({ payload: 'b', dependencies: [a.id] });\n   457→    const c = tq.add({ payload: 'c', dependencies: [b.id] });\n   458→    // Now try to make a depend on c - this creates a->b->c->a cycle\n   459→    // We need to test this differently since a is already added without deps\n   460→    // Instead, test by creating the cycle at add time\n   461→    expect(() => {\n   462→      // d depends on c, and e depends on d\n   463→      const d = tq.add({ payload: 'd', dependencies: [c.id] });\n   464→      // Try to create a task that depends on d and that d depends on\n   465→      // Actually: create circular by having e depend on d and f depend on e, then try g depending on f and d depending on g\n   466→    }).not.toThrow();\n   467→  });\n   468→});\n   469→\n   470→describe('Phase 8: Concurrency Control', () => {\n   471→  test('limits concurrent processing tasks', () => {\n   472→    const tq = new TaskQueue();\n   473→    tq.setConcurrency('default', 2);\n   474→    tq.add({ payload: 'a' });\n   475→    tq.add({ payload: 'b' });\n   476→    tq.add({ payload: 'c' });\n   477→\n   478→    expect(tq.next()).not.toBeNull(); // 1 processing\n   479→    expect(tq.next()).not.toBeNull(); // 2 processing\n   480→    expect(tq.next()).toBeNull(); // at limit\n   481→  });\n   482→\n   483→  test('completing a task frees a concurrency slot', () => {\n   484→    const tq = new TaskQueue();\n   485→    tq.setConcurrency('default', 1);\n   486→    tq.add({ payload: 'a' });\n   487→    tq.add({ payload: 'b' });\n   488→\n   489→    const task = tq.next()!;\n   490→    expect(tq.next()).toBeNull(); // at limit\n   491→\n   492→    tq.complete(task.id);\n   493→    expect(tq.next()).not.toBeNull(); // slot freed\n   494→  });\n   495→\n   496→  test('failing a task frees a concurrency slot', () => {\n   497→    const tq = new TaskQueue();\n   498→    tq.setConcurrency('default', 1);\n   499→    tq.add({ payload: 'a', maxRetries: 0 });\n   500→    tq.add({ payload: 'b' });\n   501→\n   502→    const task = tq.next()!;\n   503→    expect(tq.next()).toBeNull();\n   504→\n   505→    tq.fail(task.id, 'err');\n   506→    expect(tq.next()).not.toBeNull(); // slot freed\n   507→  });\n   508→\n   509→  test('default is unlimited concurrency', () => {\n   510→    const tq = new TaskQueue();\n   511→    for (let i = 0; i < 100; i++) {\n   512→      tq.add({ payload: i });\n   513→    }\n   514→    for (let i = 0; i < 100; i++) {\n   515→      expect(tq.next()).not.toBeNull();\n   516→    }\n   517→  });\n   518→\n   519→  test('can query concurrency limit and active count', () => {\n   520→    const tq = new TaskQueue();\n   521→    tq.setConcurrency('default', 5);\n   522→    tq.add({ payload: 'a' });\n   523→    tq.add({ payload: 'b' });\n   524→    tq.next();\n   525→\n   526→    expect(tq.getConcurrency('default')).toBe(5);\n   527→    expect(tq.getActiveCount('default')).toBe(1);\n   528→  });\n   529→\n   530→  test('concurrency respects priority ordering', () => {\n   531→    const tq = new TaskQueue();\n   532→    tq.setConcurrency('default', 1);\n   533→    tq.add({ payload: 'low', priority: 10 });\n   534→    tq.add({ payload: 'high', priority: 1 });\n   535→\n   536→    const task = tq.next()!;\n   537→    expect(task.payload).toBe('high');\n   538→  });\n   539→});\n   540→\n   541→describe('Phase 9: Progress and Cancellation', () => {\n   542→  test('report progress on a processing task', () => {\n   543→    const tq = new TaskQueue();\n   544→    tq.add({ payload: 'x' });\n   545→    const task = tq.next()!;\n   546→\n   547→    tq.updateProgress(task.id, 50, 'halfway');\n   548→    const updated = tq.getTask(task.id)!;\n   549→    expect(updated.progress).toBe(50);\n   550→    expect(updated.progressMessage).toBe('halfway');\n   551→  });\n   552→\n   553→  test('subscribe to progress updates', () => {\n   554→    const tq = new TaskQueue();\n   555→    tq.add({ payload: 'x' });\n   556→    const task = tq.next()!;\n   557→\n   558→    const updates: Array<{ progress: number; message?: string }> = [];\n   559→    tq.onProgress(task.id, (progress, message) => {\n   560→      updates.push({ progress, message });\n   561→    });\n   562→\n   563→    tq.updateProgress(task.id, 25, 'quarter');\n   564→    tq.updateProgress(task.id, 75, 'three quarters');\n   565→\n   566→    expect(updates).toHaveLength(2);\n   567→    expect(updates[0].progress).toBe(25);\n   568→    expect(updates[1].progress).toBe(75);\n   569→  });\n   570→\n   571→  test('unsubscribe from progress updates', () => {\n   572→    const tq = new TaskQueue();\n   573→    tq.add({ payload: 'x' });\n   574→    const task = tq.next()!;\n   575→\n   576→    const updates: number[] = [];\n   577→    const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n   578→\n   579→    tq.updateProgress(task.id, 50);\n   580→    unsub();\n   581→    tq.updateProgress(task.id, 100);\n   582→\n   583→    expect(updates).toHaveLength(1);\n   584→  });\n   585→\n   586→  test('cancel a pending task', () => {\n   587→    const tq = new TaskQueue();\n   588→    const task = tq.add({ payload: 'x' });\n   589→    tq.cancel(task.id);\n   590→\n   591→    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n   592→    expect(tq.next()).toBeNull();\n   593→  });\n   594→\n   595→  test('cancel a processing task', () => {\n   596→    const tq = new TaskQueue();\n   597→    tq.add({ payload: 'x' });\n   598→    const task = tq.next()!;\n   599→    tq.cancel(task.id);\n   600→    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n   601→  });\n   602→\n   603→  test('cancelled tasks are never retried', () => {\n   604→    const tq = new TaskQueue();\n   605→    tq.add({ payload: 'x', maxRetries: 3 });\n   606→    const task = tq.next()!;\n   607→    tq.cancel(task.id);\n   608→\n   609→    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n   610→    expect(tq.next()).toBeNull();\n   611→  });\n   612→});\n   613→\n   614→describe('Phase 10: Recurring Tasks', () => {\n   615→  test('create a schedule and tick enqueues a task', () => {\n   616→    const tq = new TaskQueue();\n   617→    tq.addSchedule({\n   618→      id: 'every-5-min',\n   619→      cron: '*/5 * * * *',\n   620→      queue: 'default',\n   621→      payload: { type: 'cleanup' },\n   622→    });\n   623→\n   624→    // Set time to a 5-minute boundary\n   625→    const schedules = tq.getSchedules();\n   626→    expect(schedules).toHaveLength(1);\n   627→    expect(schedules[0].id).toBe('every-5-min');\n   628→  });\n   629→\n   630→  test('tick enqueues tasks when schedule is due', () => {\n   631→    const tq = new TaskQueue();\n   632→    tq.addSchedule({\n   633→      id: 'every-min',\n   634→      cron: '*/1 * * * *',\n   635→      queue: 'default',\n   636→      payload: { type: 'ping' },\n   637→    });\n   638→\n   639→    // Tick with a time that matches (any exact minute)\n   640→    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n   641→    tq.tick(atMinute);\n   642→\n   643→    expect(tq.size()).toBe(1);\n   644→    const task = tq.next()!;\n   645→    expect(task.payload).toEqual({ type: 'ping' });\n   646→  });\n   647→\n   648→  test('tick does not enqueue if not due', () => {\n   649→    const tq = new TaskQueue();\n   650→    tq.addSchedule({\n   651→      id: 'hourly',\n   652→      cron: '0 * * * *',\n   653→      queue: 'default',\n   654→      payload: 'hourly-task',\n   655→    });\n   656→\n   657→    // Tick at :30 past - not on the hour\n   658→    const notOnHour = new Date(2025, 0, 1, 12, 30, 0);\n   659→    tq.tick(notOnHour);\n   660→    expect(tq.size()).toBe(0);\n   661→  });\n   662→\n   663→  test('remove a schedule stops future enqueuing', () => {\n   664→    const tq = new TaskQueue();\n   665→    tq.addSchedule({\n   666→      id: 'sched1',\n   667→      cron: '*/1 * * * *',\n   668→      queue: 'default',\n   669→      payload: 'x',\n   670→    });\n   671→    tq.removeSchedule('sched1');\n   672→\n   673→    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n   674→    tq.tick(atMinute);\n   675→    expect(tq.size()).toBe(0);\n   676→  });\n   677→\n   678→  test('list active schedules', () => {\n   679→    const tq = new TaskQueue();\n   680→    tq.addSchedule({ id: 's1', cron: '*/1 * * * *', queue: 'default', payload: 'a' });\n   681→    tq.addSchedule({ id: 's2', cron: '0 0 * * *', queue: 'daily', payload: 'b' });\n   682→\n   683→    const schedules = tq.getSchedules();\n   684→    expect(schedules).toHaveLength(2);\n   685→  });\n   686→\n   687→  test('recurring tasks are regular tasks subject to queue rules', () => {\n   688→    const tq = new TaskQueue();\n   689→    tq.setConcurrency('default', 1);\n   690→    tq.addSchedule({\n   691→      id: 's1',\n   692→      cron: '*/1 * * * *',\n   693→      queue: 'default',\n   694→      payload: 'recurring',\n   695→    });\n   696→\n   697→    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n   698→    tq.tick(atMinute);\n   699→\n   700→    const task = tq.next()!;\n   701→    expect(task.payload).toBe('recurring');\n   702→    expect(task.status).toBe('processing');\n   703→  });\n   704→\n   705→  test('daily at midnight cron expression', () => {\n   706→    const tq = new TaskQueue();\n   707→    tq.addSchedule({\n   708→      id: 'daily',\n   709→      cron: '0 0 * * *',\n   710→      queue: 'default',\n   711→      payload: 'daily',\n   712→    });\n   713→\n   714→    const midnight = new Date(2025, 0, 1, 0, 0, 0);\n   715→    tq.tick(midnight);\n   716→    expect(tq.size()).toBe(1);\n   717→\n   718→    const notMidnight = new Date(2025, 0, 1, 12, 0, 0);\n   719→    tq.tick(notMidnight);\n   720→    expect(tq.size()).toBe(1); // still just 1\n   721→  });\n   722→});\n   723→\n   724→describe('Phase 11: Middleware Pipeline', () => {\n   725→  test('middleware is called when processing a task', async () => {\n   726→    const tq = new TaskQueue();\n   727→    const calls: string[] = [];\n   728→\n   729→    tq.use('default', async (task, next) => {\n   730→      calls.push('middleware1');\n   731→      await next();\n   732→    });\n   733→\n   734→    tq.setHandler('default', async (task) => {\n   735→      calls.push('handler');\n   736→    });\n   737→\n   738→    tq.add({ payload: 'x' });\n   739→    const task = tq.next()!;\n   740→    await tq.process(task.id);\n   741→\n   742→    expect(calls).toEqual(['middleware1', 'handler']);\n   743→  });\n   744→\n   745→  test('middleware executes in registration order', async () => {\n   746→    const tq = new TaskQueue();\n   747→    const calls: string[] = [];\n   748→\n   749→    tq.use('default', async (task, next) => {\n   750→      calls.push('first');\n   751→      await next();\n   752→    });\n   753→\n   754→    tq.use('default', async (task, next) => {\n   755→      calls.push('second');\n   756→      await next();\n   757→    });\n   758→\n   759→    tq.setHandler('default', async () => {\n   760→      calls.push('handler');\n   761→    });\n   762→\n   763→    tq.add({ payload: 'x' });\n   764→    const task = tq.next()!;\n   765→    await tq.process(task.id);\n   766→\n   767→    expect(calls).toEqual(['first', 'second', 'handler']);\n   768→  });\n   769→\n   770→  test('middleware that does not call next skips processing', async () => {\n   771→    const tq = new TaskQueue();\n   772→    const calls: string[] = [];\n   773→\n   774→    tq.use('default', async (_task, _next) => {\n   775→      calls.push('blocker');\n   776→      // does NOT call next\n   777→    });\n   778→\n   779→    tq.setHandler('default', async () => {\n   780→      calls.push('handler');\n   781→    });\n   782→\n   783→    tq.add({ payload: 'x' });\n   784→    const task = tq.next()!;\n   785→    await tq.process(task.id);\n   786→\n   787→    expect(calls).toEqual(['blocker']);\n   788→  });\n   789→\n   790→  test('middleware can modify the task', async () => {\n   791→    const tq = new TaskQueue();\n   792→\n   793→    tq.use('default', async (task, next) => {\n   794→      (task as any).metadata = { injected: true };\n   795→      await next();\n   796→    });\n   797→\n   798→    let receivedTask: any;\n   799→    tq.setHandler('default', async (task) => {\n   800→      receivedTask = task;\n   801→    });\n   802→\n   803→    tq.add({ payload: 'x' });\n   804→    const task = tq.next()!;\n   805→    await tq.process(task.id);\n   806→\n   807→    expect(receivedTask.metadata).toEqual({ injected: true });\n   808→  });\n   809→\n   810→  test('middleware error marks task as failed', async () => {\n   811→    const tq = new TaskQueue();\n   812→\n   813→    tq.use('default', async (_task, _next) => {\n   814→      throw new Error('middleware-error');\n   815→    });\n   816→\n   817→    tq.setHandler('default', async () => {});\n   818→\n   819→    tq.add({ payload: 'x', maxRetries: 0 });\n   820→    const task = tq.next()!;\n   821→    await tq.process(task.id);\n   822→\n   823→    expect(tq.getTask(task.id)!.status).toBe('failed');\n   824→  });\n   825→\n   826→  test('each queue has independent middleware', async () => {\n   827→    const tq = new TaskQueue();\n   828→    const calls: string[] = [];\n   829→\n   830→    tq.use('q1', async (task, next) => {\n   831→      calls.push('q1-middleware');\n   832→      await next();\n   833→    });\n   834→\n   835→    tq.setHandler('q1', async () => { calls.push('q1-handler'); });\n   836→    tq.setHandler('q2', async () => { calls.push('q2-handler'); });\n   837→\n   838→    tq.add({ payload: 'x', queue: 'q1' });\n   839→    tq.add({ payload: 'y', queue: 'q2' });\n   840→\n   841→    await tq.process(tq.next('q1')!.id);\n   842→    await tq.process(tq.next('q2')!.id);\n   843→\n   844→    expect(calls).toEqual(['q1-middleware', 'q1-handler', 'q2-handler']);\n   845→  });\n   846→});\n   847→\n   848→describe('Phase 12: Graceful Shutdown', () => {\n   849→  test('shutdown stops accepting new tasks', async () => {\n   850→    const tq = new TaskQueue();\n   851→    await tq.shutdown();\n   852→    expect(() => tq.add({ payload: 'x' })).toThrow();\n   853→  });\n   854→\n   855→  test('shutdown waits for processing tasks to complete', async () => {\n   856→    const tq = new TaskQueue();\n   857→    tq.add({ payload: 'x' });\n   858→    const task = tq.next()!;\n   859→\n   860→    // Complete the task asynchronously\n   861→    setTimeout(() => tq.complete(task.id), 50);\n   862→\n   863→    const result = await tq.shutdown({ timeout: 5000 });\n   864→    expect(result.completed).toBe(1);\n   865→    expect(result.forceCancelled).toBe(0);\n   866→  });\n   867→\n   868→  test('shutdown force-cancels tasks that exceed timeout', async () => {\n   869→    const tq = new TaskQueue();\n   870→    tq.add({ payload: 'x' });\n   871→    tq.next()!; // starts processing but never completes\n   872→\n   873→    const result = await tq.shutdown({ timeout: 50 });\n   874→    expect(result.forceCancelled).toBe(1);\n   875→  });\n   876→\n   877→  test('shutdown completes immediately if no tasks processing', async () => {\n   878→    const tq = new TaskQueue();\n   879→    tq.add({ payload: 'x' }); // pending, not processing\n   880→    const before = Date.now();\n   881→    const result = await tq.shutdown();\n   882→    const elapsed = Date.now() - before;\n   883→    expect(elapsed).toBeLessThan(100);\n   884→    expect(result.completed).toBe(0);\n   885→  });\n   886→\n   887→  test('calling shutdown multiple times returns same result', async () => {\n   888→    const tq = new TaskQueue();\n   889→    const r1 = await tq.shutdown();\n   890→    const r2 = await tq.shutdown();\n   891→    expect(r1).toEqual(r2);\n   892→  });\n   893→\n   894→  test('shutdown callbacks are invoked', async () => {\n   895→    const tq = new TaskQueue();\n   896→    const called: string[] = [];\n   897→    tq.onShutdown(() => { called.push('cb1'); });\n   898→    tq.onShutdown(() => { called.push('cb2'); });\n   899→\n   900→    await tq.shutdown();\n   901→    expect(called).toEqual(['cb1', 'cb2']);\n   902→  });\n   903→\n   904→  test('shutdown result includes duration', async () => {\n   905→    const tq = new TaskQueue();\n   906→    const result = await tq.shutdown();\n   907→    expect(typeof result.duration).toBe('number');\n   908→    expect(result.duration).toBeGreaterThanOrEqual(0);\n   909→  });\n   910→});\n   911→"}]},"parent_tool_use_id":null,"session_id":"0490614c-768c-4866-acee-66d51e083bfa","uuid":"4e6617f1-4c4f-46c6-9ffa-71cab88a6754","tool_use_result":{"type":"update","filePath":"/workspace/src/task-queue.test.ts","content":"import { describe, test, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  test('adds a task and returns a task object with id, status, payload, createdAt', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'hello' });\n    expect(task).toBeDefined();\n    expect(typeof task.id).toBe('string');\n    expect(task.id.length).toBeGreaterThan(0);\n    expect(task.status).toBe('pending');\n    expect(task.payload).toBe('hello');\n    expect(task.createdAt).toBeInstanceOf(Date);\n  });\n\n  test('each task has a unique id', () => {\n    const tq = new TaskQueue();\n    const t1 = tq.add({ payload: 'a' });\n    const t2 = tq.add({ payload: 'b' });\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  test('retrieves tasks in FIFO order', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'first' });\n    tq.add({ payload: 'second' });\n    tq.add({ payload: 'third' });\n\n    const t1 = tq.next();\n    expect(t1!.payload).toBe('first');\n    expect(t1!.status).toBe('processing');\n\n    const t2 = tq.next();\n    expect(t2!.payload).toBe('second');\n\n    const t3 = tq.next();\n    expect(t3!.payload).toBe('third');\n  });\n\n  test('returns null when no tasks are available', () => {\n    const tq = new TaskQueue();\n    expect(tq.next()).toBeNull();\n  });\n\n  test('returns null after all tasks have been retrieved', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'only' });\n    tq.next();\n    expect(tq.next()).toBeNull();\n  });\n\n  test('size returns number of pending tasks', () => {\n    const tq = new TaskQueue();\n    expect(tq.size()).toBe(0);\n    tq.add({ payload: 'a' });\n    tq.add({ payload: 'b' });\n    expect(tq.size()).toBe(2);\n    tq.next(); // moves one to processing\n    expect(tq.size()).toBe(1);\n  });\n});\n\ndescribe('Phase 2: Named Queues', () => {\n  test('adds tasks to a named queue', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x', queue: 'emails' });\n    expect(task.payload).toBe('x');\n  });\n\n  test('named queues are independent', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'email-task', queue: 'emails' });\n    tq.add({ payload: 'sms-task', queue: 'sms' });\n\n    const fromEmail = tq.next('emails');\n    expect(fromEmail!.payload).toBe('email-task');\n\n    const fromSms = tq.next('sms');\n    expect(fromSms!.payload).toBe('sms-task');\n  });\n\n  test('default queue is used when no name given', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'default-task' });\n    const task = tq.next();\n    expect(task!.payload).toBe('default-task');\n  });\n\n  test('returns null for non-existent queue', () => {\n    const tq = new TaskQueue();\n    expect(tq.next('nonexistent')).toBeNull();\n  });\n\n  test('returns null for empty queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', queue: 'q1' });\n    tq.next('q1');\n    expect(tq.next('q1')).toBeNull();\n  });\n\n  test('lists all queue names', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'a', queue: 'alpha' });\n    tq.add({ payload: 'b', queue: 'beta' });\n    const names = tq.getQueueNames();\n    expect(names).toContain('alpha');\n    expect(names).toContain('beta');\n  });\n\n  test('size works per queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'a', queue: 'q1' });\n    tq.add({ payload: 'b', queue: 'q1' });\n    tq.add({ payload: 'c', queue: 'q2' });\n    expect(tq.size('q1')).toBe(2);\n    expect(tq.size('q2')).toBe(1);\n  });\n});\n\ndescribe('Phase 3: Priority', () => {\n  test('higher priority tasks (lower number) are returned first', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'low', priority: 10 });\n    tq.add({ payload: 'high', priority: 1 });\n    tq.add({ payload: 'mid', priority: 5 });\n\n    expect(tq.next()!.payload).toBe('high');\n    expect(tq.next()!.payload).toBe('mid');\n    expect(tq.next()!.payload).toBe('low');\n  });\n\n  test('default priority is 5', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    expect(task.priority).toBe(5);\n  });\n\n  test('same priority maintains FIFO order', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'first', priority: 3 });\n    tq.add({ payload: 'second', priority: 3 });\n    tq.add({ payload: 'third', priority: 3 });\n\n    expect(tq.next()!.payload).toBe('first');\n    expect(tq.next()!.payload).toBe('second');\n    expect(tq.next()!.payload).toBe('third');\n  });\n\n  test('invalid priority throws error', () => {\n    const tq = new TaskQueue();\n    expect(() => tq.add({ payload: 'x', priority: 0 })).toThrow();\n    expect(() => tq.add({ payload: 'x', priority: 11 })).toThrow();\n    expect(() => tq.add({ payload: 'x', priority: -1 })).toThrow();\n  });\n\n  test('priority is per-queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'q1-low', priority: 10, queue: 'q1' });\n    tq.add({ payload: 'q1-high', priority: 1, queue: 'q1' });\n    tq.add({ payload: 'q2-mid', priority: 5, queue: 'q2' });\n\n    expect(tq.next('q1')!.payload).toBe('q1-high');\n    expect(tq.next('q2')!.payload).toBe('q2-mid');\n  });\n\n  test('task exposes priority', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x', priority: 3 });\n    expect(task.priority).toBe(3);\n  });\n});\n\ndescribe('Phase 4: Delayed Tasks', () => {\n  test('delayed task is not returned before its availability time', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'delayed', delay: 100000 });\n    expect(tq.next()).toBeNull();\n  });\n\n  test('delayed task is returned after availability time', () => {\n    const tq = new TaskQueue();\n    const now = Date.now();\n    tq.add({ payload: 'delayed', availableAt: new Date(now - 1000) });\n    const task = tq.next();\n    expect(task).not.toBeNull();\n    expect(task!.payload).toBe('delayed');\n  });\n\n  test('non-delayed tasks are preferred over not-yet-available delayed tasks', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'delayed', delay: 100000 });\n    tq.add({ payload: 'immediate' });\n    expect(tq.next()!.payload).toBe('immediate');\n    expect(tq.next()).toBeNull(); // delayed not ready\n  });\n\n  test('multiple delayed tasks ordered by availability then priority then FIFO', () => {\n    const tq = new TaskQueue();\n    const now = Date.now();\n    tq.add({ payload: 'later', availableAt: new Date(now - 500) });\n    tq.add({ payload: 'earlier', availableAt: new Date(now - 1000) });\n    expect(tq.next()!.payload).toBe('earlier');\n    expect(tq.next()!.payload).toBe('later');\n  });\n\n  test('task exposes availableAt', () => {\n    const tq = new TaskQueue();\n    const futureDate = new Date(Date.now() + 10000);\n    const task = tq.add({ payload: 'x', availableAt: futureDate });\n    expect(task.availableAt).toEqual(futureDate);\n  });\n\n  test('delay creates availableAt from now', () => {\n    const tq = new TaskQueue();\n    const before = Date.now();\n    const task = tq.add({ payload: 'x', delay: 5000 });\n    const after = Date.now();\n    expect(task.availableAt!.getTime()).toBeGreaterThanOrEqual(before + 5000);\n    expect(task.availableAt!.getTime()).toBeLessThanOrEqual(after + 5000);\n  });\n\n  test('delays work with named queues', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'delayed', delay: 100000, queue: 'q1' });\n    tq.add({ payload: 'immediate', queue: 'q1' });\n    expect(tq.next('q1')!.payload).toBe('immediate');\n  });\n});\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  test('complete marks a task as completed', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    tq.complete(task.id);\n    expect(tq.getTask(task.id)!.status).toBe('completed');\n  });\n\n  test('fail marks a task as failed and retries with delay', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 3, backoff: 1000 });\n    const task = tq.next()!;\n    tq.fail(task.id, 'oops');\n\n    // Task should be re-queued as pending with a delay\n    const retried = tq.getTask(task.id)!;\n    expect(retried.status).toBe('pending');\n    expect(retried.attempts).toBe(1);\n    expect(retried.availableAt).toBeDefined();\n    expect(retried.lastError).toBe('oops');\n  });\n\n  test('exponential backoff: delay doubles each attempt', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 3, backoff: 1000 });\n\n    // Attempt 1\n    let task = tq.next()!;\n    const baseTime = Date.now();\n    tq.fail(task.id, 'e1');\n    let t = tq.getTask(task.id)!;\n    // backoff = 1000 * 2^0 = 1000\n    expect(t.availableAt!.getTime()).toBeGreaterThanOrEqual(baseTime + 1000 - 50);\n  });\n\n  test('default maxRetries is 3', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    expect(task.maxRetries).toBe(3);\n  });\n\n  test('default backoff is 1000ms', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    expect(task.backoff).toBe(1000);\n  });\n\n  test('task tracks attempts', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    expect(task.attempts).toBe(0);\n  });\n\n  test('retried tasks keep original queue and priority', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', queue: 'myq', priority: 2, maxRetries: 3, backoff: 0 });\n    const task = tq.next('myq')!;\n    tq.fail(task.id, 'err');\n    const retried = tq.getTask(task.id)!;\n    expect(retried.queueName).toBe('myq');\n    expect(retried.priority).toBe(2);\n  });\n\n  test('task remains failed after all retries exhausted', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 1, backoff: 0 });\n\n    let task = tq.next()!;\n    tq.fail(task.id, 'err1');\n\n    // 1 retry - make it available immediately\n    const retried = tq.getTask(task.id)!;\n    expect(retried.status).toBe('pending');\n\n    // force availability for test\n    retried.availableAt = new Date(Date.now() - 1);\n    task = tq.next()!;\n    tq.fail(task.id, 'err2');\n\n    const final = tq.getTask(task.id)!;\n    expect(final.status).toBe('failed');\n    expect(final.attempts).toBe(2);\n  });\n});\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  test('task moves to DLQ after exhausting retries', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 0, backoff: 0 });\n    const task = tq.next()!;\n    tq.fail(task.id, 'fatal');\n\n    const dlq = tq.getDeadLetterQueue();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].id).toBe(task.id);\n    expect(dlq[0].lastError).toBe('fatal');\n  });\n\n  test('dead letter queue is per named queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', queue: 'q1', maxRetries: 0 });\n    tq.add({ payload: 'y', queue: 'q2', maxRetries: 0 });\n\n    tq.fail(tq.next('q1')!.id, 'e1');\n    tq.fail(tq.next('q2')!.id, 'e2');\n\n    expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n    expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n  });\n\n  test('dead-lettered tasks retain error info and fail count', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 1, backoff: 0 });\n    let task = tq.next()!;\n    tq.fail(task.id, 'err1');\n\n    // make available again\n    tq.getTask(task.id)!.availableAt = new Date(Date.now() - 1);\n    task = tq.next()!;\n    tq.fail(task.id, 'err2');\n\n    const dlq = tq.getDeadLetterQueue();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].lastError).toBe('err2');\n    expect(dlq[0].attempts).toBe(2);\n  });\n\n  test('requeue from DLQ back to original queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 0, queue: 'myq' });\n    const task = tq.next('myq')!;\n    tq.fail(task.id, 'err');\n\n    expect(tq.getDeadLetterQueue('myq')).toHaveLength(1);\n\n    tq.requeueFromDLQ(task.id);\n\n    expect(tq.getDeadLetterQueue('myq')).toHaveLength(0);\n    const requeued = tq.getTask(task.id)!;\n    expect(requeued.status).toBe('pending');\n    expect(requeued.attempts).toBe(0);\n  });\n\n  test('clear DLQ for a queue', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'a', maxRetries: 0 });\n    tq.add({ payload: 'b', maxRetries: 0 });\n    tq.fail(tq.next()!.id, 'e');\n    tq.fail(tq.next()!.id, 'e');\n\n    expect(tq.getDeadLetterQueue()).toHaveLength(2);\n    tq.clearDeadLetterQueue();\n    expect(tq.getDeadLetterQueue()).toHaveLength(0);\n  });\n});\n\ndescribe('Phase 7: Task Dependencies', () => {\n  test('task with dependencies starts as blocked', () => {\n    const tq = new TaskQueue();\n    const dep = tq.add({ payload: 'dep' });\n    const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n    expect(task.status).toBe('blocked');\n  });\n\n  test('blocked task is not returned by next', () => {\n    const tq = new TaskQueue();\n    const dep = tq.add({ payload: 'dep' });\n    tq.add({ payload: 'main', dependencies: [dep.id] });\n    const next = tq.next();\n    expect(next!.payload).toBe('dep');\n    expect(tq.next()).toBeNull(); // main is blocked\n  });\n\n  test('completing dependency unblocks dependent task', () => {\n    const tq = new TaskQueue();\n    const dep = tq.add({ payload: 'dep' });\n    const main = tq.add({ payload: 'main', dependencies: [dep.id] });\n\n    const processing = tq.next()!;\n    tq.complete(processing.id);\n\n    expect(tq.getTask(main.id)!.status).toBe('pending');\n    const next = tq.next();\n    expect(next!.payload).toBe('main');\n  });\n\n  test('circular dependencies are rejected', () => {\n    const tq = new TaskQueue();\n    const a = tq.add({ payload: 'a' });\n    const b = tq.add({ payload: 'b', dependencies: [a.id] });\n    expect(() => tq.add({ payload: 'c', dependencies: [b.id, a.id] })).not.toThrow();\n\n    // Direct circular: can't depend on self (would need to be implemented differently)\n    // Indirect: a depends on something that depends on a\n  });\n\n  test('depending on non-existent task throws error', () => {\n    const tq = new TaskQueue();\n    expect(() => tq.add({ payload: 'x', dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  test('failed dependency keeps dependents blocked', () => {\n    const tq = new TaskQueue();\n    const dep = tq.add({ payload: 'dep', maxRetries: 0 });\n    tq.add({ payload: 'main', dependencies: [dep.id] });\n\n    tq.fail(tq.next()!.id, 'err');\n    expect(tq.next()).toBeNull();\n  });\n\n  test('can inspect dependency status', () => {\n    const tq = new TaskQueue();\n    const dep1 = tq.add({ payload: 'dep1' });\n    const dep2 = tq.add({ payload: 'dep2' });\n    const main = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n\n    const deps = tq.getDependencyStatus(main.id);\n    expect(deps).toHaveLength(2);\n    expect(deps.some(d => d.id === dep1.id && d.status === 'pending')).toBe(true);\n    expect(deps.some(d => d.id === dep2.id && d.status === 'pending')).toBe(true);\n  });\n\n  test('detects indirect circular dependencies', () => {\n    const tq = new TaskQueue();\n    const a = tq.add({ payload: 'a' });\n    const b = tq.add({ payload: 'b', dependencies: [a.id] });\n    const c = tq.add({ payload: 'c', dependencies: [b.id] });\n    // Now try to make a depend on c - this creates a->b->c->a cycle\n    // We need to test this differently since a is already added without deps\n    // Instead, test by creating the cycle at add time\n    expect(() => {\n      // d depends on c, and e depends on d\n      const d = tq.add({ payload: 'd', dependencies: [c.id] });\n      // Try to create a task that depends on d and that d depends on\n      // Actually: create circular by having e depend on d and f depend on e, then try g depending on f and d depending on g\n    }).not.toThrow();\n  });\n});\n\ndescribe('Phase 8: Concurrency Control', () => {\n  test('limits concurrent processing tasks', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 2);\n    tq.add({ payload: 'a' });\n    tq.add({ payload: 'b' });\n    tq.add({ payload: 'c' });\n\n    expect(tq.next()).not.toBeNull(); // 1 processing\n    expect(tq.next()).not.toBeNull(); // 2 processing\n    expect(tq.next()).toBeNull(); // at limit\n  });\n\n  test('completing a task frees a concurrency slot', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 1);\n    tq.add({ payload: 'a' });\n    tq.add({ payload: 'b' });\n\n    const task = tq.next()!;\n    expect(tq.next()).toBeNull(); // at limit\n\n    tq.complete(task.id);\n    expect(tq.next()).not.toBeNull(); // slot freed\n  });\n\n  test('failing a task frees a concurrency slot', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 1);\n    tq.add({ payload: 'a', maxRetries: 0 });\n    tq.add({ payload: 'b' });\n\n    const task = tq.next()!;\n    expect(tq.next()).toBeNull();\n\n    tq.fail(task.id, 'err');\n    expect(tq.next()).not.toBeNull(); // slot freed\n  });\n\n  test('default is unlimited concurrency', () => {\n    const tq = new TaskQueue();\n    for (let i = 0; i < 100; i++) {\n      tq.add({ payload: i });\n    }\n    for (let i = 0; i < 100; i++) {\n      expect(tq.next()).not.toBeNull();\n    }\n  });\n\n  test('can query concurrency limit and active count', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 5);\n    tq.add({ payload: 'a' });\n    tq.add({ payload: 'b' });\n    tq.next();\n\n    expect(tq.getConcurrency('default')).toBe(5);\n    expect(tq.getActiveCount('default')).toBe(1);\n  });\n\n  test('concurrency respects priority ordering', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 1);\n    tq.add({ payload: 'low', priority: 10 });\n    tq.add({ payload: 'high', priority: 1 });\n\n    const task = tq.next()!;\n    expect(task.payload).toBe('high');\n  });\n});\n\ndescribe('Phase 9: Progress and Cancellation', () => {\n  test('report progress on a processing task', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    tq.updateProgress(task.id, 50, 'halfway');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.progress).toBe(50);\n    expect(updated.progressMessage).toBe('halfway');\n  });\n\n  test('subscribe to progress updates', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    const updates: Array<{ progress: number; message?: string }> = [];\n    tq.onProgress(task.id, (progress, message) => {\n      updates.push({ progress, message });\n    });\n\n    tq.updateProgress(task.id, 25, 'quarter');\n    tq.updateProgress(task.id, 75, 'three quarters');\n\n    expect(updates).toHaveLength(2);\n    expect(updates[0].progress).toBe(25);\n    expect(updates[1].progress).toBe(75);\n  });\n\n  test('unsubscribe from progress updates', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    const updates: number[] = [];\n    const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n    tq.updateProgress(task.id, 50);\n    unsub();\n    tq.updateProgress(task.id, 100);\n\n    expect(updates).toHaveLength(1);\n  });\n\n  test('cancel a pending task', () => {\n    const tq = new TaskQueue();\n    const task = tq.add({ payload: 'x' });\n    tq.cancel(task.id);\n\n    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    expect(tq.next()).toBeNull();\n  });\n\n  test('cancel a processing task', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    tq.cancel(task.id);\n    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n  });\n\n  test('cancelled tasks are never retried', () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x', maxRetries: 3 });\n    const task = tq.next()!;\n    tq.cancel(task.id);\n\n    expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    expect(tq.next()).toBeNull();\n  });\n});\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  test('create a schedule and tick enqueues a task', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'every-5-min',\n      cron: '*/5 * * * *',\n      queue: 'default',\n      payload: { type: 'cleanup' },\n    });\n\n    // Set time to a 5-minute boundary\n    const schedules = tq.getSchedules();\n    expect(schedules).toHaveLength(1);\n    expect(schedules[0].id).toBe('every-5-min');\n  });\n\n  test('tick enqueues tasks when schedule is due', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'every-min',\n      cron: '*/1 * * * *',\n      queue: 'default',\n      payload: { type: 'ping' },\n    });\n\n    // Tick with a time that matches (any exact minute)\n    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n    tq.tick(atMinute);\n\n    expect(tq.size()).toBe(1);\n    const task = tq.next()!;\n    expect(task.payload).toEqual({ type: 'ping' });\n  });\n\n  test('tick does not enqueue if not due', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'hourly',\n      cron: '0 * * * *',\n      queue: 'default',\n      payload: 'hourly-task',\n    });\n\n    // Tick at :30 past - not on the hour\n    const notOnHour = new Date(2025, 0, 1, 12, 30, 0);\n    tq.tick(notOnHour);\n    expect(tq.size()).toBe(0);\n  });\n\n  test('remove a schedule stops future enqueuing', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'sched1',\n      cron: '*/1 * * * *',\n      queue: 'default',\n      payload: 'x',\n    });\n    tq.removeSchedule('sched1');\n\n    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n    tq.tick(atMinute);\n    expect(tq.size()).toBe(0);\n  });\n\n  test('list active schedules', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({ id: 's1', cron: '*/1 * * * *', queue: 'default', payload: 'a' });\n    tq.addSchedule({ id: 's2', cron: '0 0 * * *', queue: 'daily', payload: 'b' });\n\n    const schedules = tq.getSchedules();\n    expect(schedules).toHaveLength(2);\n  });\n\n  test('recurring tasks are regular tasks subject to queue rules', () => {\n    const tq = new TaskQueue();\n    tq.setConcurrency('default', 1);\n    tq.addSchedule({\n      id: 's1',\n      cron: '*/1 * * * *',\n      queue: 'default',\n      payload: 'recurring',\n    });\n\n    const atMinute = new Date(2025, 0, 1, 12, 5, 0);\n    tq.tick(atMinute);\n\n    const task = tq.next()!;\n    expect(task.payload).toBe('recurring');\n    expect(task.status).toBe('processing');\n  });\n\n  test('daily at midnight cron expression', () => {\n    const tq = new TaskQueue();\n    tq.addSchedule({\n      id: 'daily',\n      cron: '0 0 * * *',\n      queue: 'default',\n      payload: 'daily',\n    });\n\n    const midnight = new Date(2025, 0, 1, 0, 0, 0);\n    tq.tick(midnight);\n    expect(tq.size()).toBe(1);\n\n    const notMidnight = new Date(2025, 0, 1, 12, 0, 0);\n    tq.tick(notMidnight);\n    expect(tq.size()).toBe(1); // still just 1\n  });\n});\n\ndescribe('Phase 11: Middleware Pipeline', () => {\n  test('middleware is called when processing a task', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('default', async (task, next) => {\n      calls.push('middleware1');\n      await next();\n    });\n\n    tq.setHandler('default', async (task) => {\n      calls.push('handler');\n    });\n\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(calls).toEqual(['middleware1', 'handler']);\n  });\n\n  test('middleware executes in registration order', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('default', async (task, next) => {\n      calls.push('first');\n      await next();\n    });\n\n    tq.use('default', async (task, next) => {\n      calls.push('second');\n      await next();\n    });\n\n    tq.setHandler('default', async () => {\n      calls.push('handler');\n    });\n\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(calls).toEqual(['first', 'second', 'handler']);\n  });\n\n  test('middleware that does not call next skips processing', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('default', async (_task, _next) => {\n      calls.push('blocker');\n      // does NOT call next\n    });\n\n    tq.setHandler('default', async () => {\n      calls.push('handler');\n    });\n\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(calls).toEqual(['blocker']);\n  });\n\n  test('middleware can modify the task', async () => {\n    const tq = new TaskQueue();\n\n    tq.use('default', async (task, next) => {\n      (task as any).metadata = { injected: true };\n      await next();\n    });\n\n    let receivedTask: any;\n    tq.setHandler('default', async (task) => {\n      receivedTask = task;\n    });\n\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(receivedTask.metadata).toEqual({ injected: true });\n  });\n\n  test('middleware error marks task as failed', async () => {\n    const tq = new TaskQueue();\n\n    tq.use('default', async (_task, _next) => {\n      throw new Error('middleware-error');\n    });\n\n    tq.setHandler('default', async () => {});\n\n    tq.add({ payload: 'x', maxRetries: 0 });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(tq.getTask(task.id)!.status).toBe('failed');\n  });\n\n  test('each queue has independent middleware', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('q1', async (task, next) => {\n      calls.push('q1-middleware');\n      await next();\n    });\n\n    tq.setHandler('q1', async () => { calls.push('q1-handler'); });\n    tq.setHandler('q2', async () => { calls.push('q2-handler'); });\n\n    tq.add({ payload: 'x', queue: 'q1' });\n    tq.add({ payload: 'y', queue: 'q2' });\n\n    await tq.process(tq.next('q1')!.id);\n    await tq.process(tq.next('q2')!.id);\n\n    expect(calls).toEqual(['q1-middleware', 'q1-handler', 'q2-handler']);\n  });\n});\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  test('shutdown stops accepting new tasks', async () => {\n    const tq = new TaskQueue();\n    await tq.shutdown();\n    expect(() => tq.add({ payload: 'x' })).toThrow();\n  });\n\n  test('shutdown waits for processing tasks to complete', async () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    // Complete the task asynchronously\n    setTimeout(() => tq.complete(task.id), 50);\n\n    const result = await tq.shutdown({ timeout: 5000 });\n    expect(result.completed).toBe(1);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  test('shutdown force-cancels tasks that exceed timeout', async () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    tq.next()!; // starts processing but never completes\n\n    const result = await tq.shutdown({ timeout: 50 });\n    expect(result.forceCancelled).toBe(1);\n  });\n\n  test('shutdown completes immediately if no tasks processing', async () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' }); // pending, not processing\n    const before = Date.now();\n    const result = await tq.shutdown();\n    const elapsed = Date.now() - before;\n    expect(elapsed).toBeLessThan(100);\n    expect(result.completed).toBe(0);\n  });\n\n  test('calling shutdown multiple times returns same result', async () => {\n    const tq = new TaskQueue();\n    const r1 = await tq.shutdown();\n    const r2 = await tq.shutdown();\n    expect(r1).toEqual(r2);\n  });\n\n  test('shutdown callbacks are invoked', async () => {\n    const tq = new TaskQueue();\n    const called: string[] = [];\n    tq.onShutdown(() => { called.push('cb1'); });\n    tq.onShutdown(() => { called.push('cb2'); });\n\n    await tq.shutdown();\n    expect(called).toEqual(['cb1', 'cb2']);\n  });\n\n  test('shutdown result includes duration', async () => {\n    const tq = new TaskQueue();\n    const result = await tq.shutdown();\n    expect(typeof result.duration).toBe('number');\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { describe, test, expect } from 'vitest';","+import { describe, test, expect, vi, beforeEach } from 'vitest';"," import { TaskQueue } from './task-queue.js';"," "," describe('Phase 1: Basic FIFO Queue', () => {"]},{"oldStart":116,"oldLines":3,"newStart":116,"newLines":795,"lines":["     expect(tq.size('q2')).toBe(1);","   });"," });","+","+describe('Phase 3: Priority', () => {","+  test('higher priority tasks (lower number) are returned first', () => {","+    const tq = new TaskQueue();","+    tq.add({ payload: 'low', priority: 10 });","+    tq.add({ payload: 'high', priority: 1 });","+    tq.add({ payload: 'mid', priority: 5 });","+","+    expect(tq.next()!.payload).toBe('high');","+    expect(tq.next()!.payload).toBe('mid');","+    expect(tq.next()!.payload).toBe('low');","+  });","+","+  test('default priority is 5', () => {","+    const tq = new TaskQueue();","+    const task = tq.add({ payload: 'x' });","+    expect(task.priority).toBe(5);","+  });","+","+  test('same priority maintains FIFO order', () => {","+    const tq = new TaskQueue();","+    tq.add({ payload: 'first', priority: 3 });","+    tq.add({ payload: 'second', priority: 3 });","+    tq.add({ payload: 'third', priority: 3 });","+","+    expect(tq.next()!.payload).toBe('first');","+    expect(tq.next()!.payload).toBe('second');","+    expect(tq.next()!.payload).toBe('third');","+  });","+","+  test('invalid priority throws error', () => {","+    const tq = new TaskQueue();","+    expect(() => tq.add({ payload: 'x', priority: 0 })).toThrow();","+    expect(() => tq.add({ payload: 'x', priority: 11 })).toThrow();","+    expect(() => tq.add({ payload: 'x', priority: -1 })).toThrow();","+  });","+","+  test('priority is per-queue', () => {","+    const tq = new TaskQueue();","+    tq.add({ payload: 'q1-low', priority: 10, q