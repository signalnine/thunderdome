yload: 'x' });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(receivedTask.metadata).toEqual({ injected: true });\n  });\n\n  test('middleware error marks task as failed', async () => {\n    const tq = new TaskQueue();\n\n    tq.use('default', async (_task, _next) => {\n      throw new Error('middleware-error');\n    });\n\n    tq.setHandler('default', async () => {});\n\n    tq.add({ payload: 'x', maxRetries: 0 });\n    const task = tq.next()!;\n    await tq.process(task.id);\n\n    expect(tq.getTask(task.id)!.status).toBe('failed');\n  });\n\n  test('each queue has independent middleware', async () => {\n    const tq = new TaskQueue();\n    const calls: string[] = [];\n\n    tq.use('q1', async (task, next) => {\n      calls.push('q1-middleware');\n      await next();\n    });\n\n    tq.setHandler('q1', async () => { calls.push('q1-handler'); });\n    tq.setHandler('q2', async () => { calls.push('q2-handler'); });\n\n    tq.add({ payload: 'x', queue: 'q1' });\n    tq.add({ payload: 'y', queue: 'q2' });\n\n    await tq.process(tq.next('q1')!.id);\n    await tq.process(tq.next('q2')!.id);\n\n    expect(calls).toEqual(['q1-middleware', 'q1-handler', 'q2-handler']);\n  });\n});\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  test('shutdown stops accepting new tasks', async () => {\n    const tq = new TaskQueue();\n    await tq.shutdown();\n    expect(() => tq.add({ payload: 'x' })).toThrow();\n  });\n\n  test('shutdown waits for processing tasks to complete', async () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x' });\n    const task = tq.next()!;\n\n    // Complete the task asynchronously\n    setTimeout(() => tq.complete(task.id), 50);\n\n    const result = await tq.shutdown({ timeout: 5000 });\n    expect(result.completed).toBe(1);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  test('shutdown force-cancels tasks that exceed timeout', async () => {\n    const tq = new TaskQueue();\n    tq.add({ payload: 'x