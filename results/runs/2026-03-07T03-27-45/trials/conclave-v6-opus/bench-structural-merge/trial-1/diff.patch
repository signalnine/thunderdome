+      store.update('doc1', { a: { b: { c: 'ours' } } });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts[0].path).toBe('a.b.c');
+      expect(result.conflicts[0].base).toBe(1);
+    });
+
+    test('merge with new document on source branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { title: 'new doc' });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ title: 'new doc' });
+      expect(store.get('doc1')).toEqual({ title: 'new doc' });
+    });
+
+    test('merge with document deleted on source branch', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.delete('doc1');
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    test('merge with document deleted on current branch keeps it deleted', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.createBranch('feature');
+      store.delete('doc1');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    test('merged field shows ours for conflicted fields', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 'theirs', b: 20 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 'ours', b: 2 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // merged uses ours for conflicts, theirs for non-conflicting
+      expect(result.merged['doc1']).toEqual({ a: 'ours', b: 20 });
+    });
+
+    test('merge handles multiple documents independently', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10 });
+      store.update('doc2', { b: 20 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 10 });
+      expect(result.merged['doc2']).toEqual({ b: 20 });
+      expect(store.get('doc1')).toEqual({ a: 10 });
+      expect(store.get('doc2')).toEqual({ b: 20 });
+    });
+
+    test('merge handles new fields added on one side', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 2 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });
+    });
+
+    test('merge handles fields removed on one side', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1 });
+    });
+
+    test('merge treats arrays as atomic values', () => {
+      store.create('doc1', { items: [1, 2, 3] });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { items: [1, 2, 3, 4] });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ items: [1, 2, 3, 4] });
+    });
+
+    test('merge conflict on arrays changed differently', () => {
+      store.create('doc1', { items: [1, 2, 3] });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { items: [4, 5, 6] });
+      store.switchBranch('main');
+      store.update('doc1', { items: [7, 8, 9] });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts[0].path).toBe('items');
+    });
+
+    test('merge does not apply when there are conflicts', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 'theirs' });
+      store.switchBranch('main');
+      store.update('doc1', { a: 'ours' });
+      store.merge('feature');
+      // Branch unchanged
+      expect(store.get('doc1')).toEqual({ a: 'ours' });
+    });
+  });
+});
