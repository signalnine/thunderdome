+/* eslint-disable @typescript-eslint/no-explicit-any */
+import { describe, test, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './store.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Document CRUD', () => {
+    test('create stores a document retrievable by get', () => {
+      store.create('doc1', { title: 'Hello' });
+      expect(store.get('doc1')).toEqual({ title: 'Hello' });
+    });
+
+    test('create throws if document ID already exists', () => {
+      store.create('doc1', { title: 'Hello' });
+      expect(() => store.create('doc1', { title: 'World' })).toThrow();
+    });
+
+    test('get throws if document does not exist', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    test('get returns a deep clone, not the same reference', () => {
+      const content = { nested: { value: 1 } };
+      store.create('doc1', content);
+      const retrieved = store.get('doc1') as any;
+      retrieved.nested.value = 999;
+      expect((store.get('doc1') as any).nested.value).toBe(1);
+    });
+
+    test('create deep clones the input', () => {
+      const content = { nested: { value: 1 } } as any;
+      store.create('doc1', content);
+      content.nested.value = 999;
+      expect((store.get('doc1') as any).nested.value).toBe(1);
+    });
+
+    test('update replaces document content', () => {
+      store.create('doc1', { title: 'v1' });
+      store.update('doc1', { title: 'v2' });
+      expect(store.get('doc1')).toEqual({ title: 'v2' });
+    });
+
+    test('update throws if document does not exist', () => {
+      expect(() => store.update('nonexistent', { title: 'v1' })).toThrow();
+    });
+
+    test('delete removes a document', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    test('delete throws if document does not exist', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    test('delete throws if document already deleted', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+  });
+
+  describe('Version History', () => {
+    test('getHistory returns versions in chronological order', () => {
+      store.create('doc1', { title: 'v1' });
+      store.update('doc1', { title: 'v2' });
+      store.update('doc1', { title: 'v3' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ title: 'v1' });
+      expect(history[1].content).toEqual({ title: 'v2' });
+      expect(history[2].content).toEqual({ title: 'v3' });
+    });
+
+    test('getHistory returns versions with unique IDs', () => {
+      store.create('doc1', { title: 'v1' });
+      store.update('doc1', { title: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+
+    test('getHistory returns versions with timestamps', () => {
+      store.create('doc1', { title: 'v1' });
+      const history = store.getHistory('doc1');
+      expect(typeof history[0].timestamp).toBe('number');
+      expect(history[0].timestamp).toBeGreaterThan(0);
+    });
+
+    test('getHistory throws for nonexistent document', () => {
+      expect(() => store.getHistory('nonexistent')).toThrow();
+    });
+
+    test('getHistory returns deep clones', () => {
+      store.create('doc1', { title: 'v1' });
+      const history = store.getHistory('doc1');
+      (history[0].content as any).title = 'mutated';
+      expect((store.getHistory('doc1')[0].content as any).title).toBe('v1');
+    });
+
+    test('getVersion returns content at a specific version', () => {
+      store.create('doc1', { title: 'v1' });
+      store.update('doc1', { title: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ title: 'v1' });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ title: 'v2' });
+    });
+
+    test('getVersion throws for nonexistent document', () => {
+      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();
+    });
+
+    test('getVersion throws for nonexistent version', () => {
+      store.create('doc1', { title: 'v1' });
+      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();
+    });
+  });
+
+  describe('Branching', () => {
+    test('default branch is main', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    test('listBranches returns main by default', () => {
+      expect(store.listBranches()).toEqual(['main']);
+    });
+
+    test('createBranch creates a new branch from current', () => {
+      store.createBranch('feature');
+      expect(store.listBranches()).toContain('feature');
+      expect(store.listBranches()).toContain('main');
+    });
+
+    test('switchBranch changes the active branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    test('switchBranch throws for nonexistent branch', () => {
+      expect(() => store.switchBranch('nonexistent')).toThrow();
+    });
+
+    test('createBranch throws for duplicate name', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    test('new branch inherits documents from source branch', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ title: 'Hello' });
+    });
+
+    test('changes on one branch are not visible on other', () => {
+      store.create('doc1', { title: 'original' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { title: 'modified' });
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ title: 'original' });
+    });
+
+    test('createBranch from a specific branch', () => {
+      store.create('doc1', { title: 'main-doc' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { title: 'feature-doc' });
+      store.createBranch('feature2', 'feature');
+      store.switchBranch('feature2');
+      expect(store.get('doc1')).toEqual({ title: 'feature-doc' });
+    });
+
+    test('branch state is isolated for new documents', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { title: 'feature-only' });
+      store.switchBranch('main');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    test('branch state is isolated for deletes', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.delete('doc1');
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ title: 'Hello' });
+    });
+  });
+
+  describe('Merging', () => {
+    test('merge with no changes is a no-op', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.createBranch('feature');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toEqual([]);
+      expect(Object.keys(result.merged)).toHaveLength(0);
+    });
+
+    test('merge applies changes from source branch only', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toEqual([]);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 2 });
+    });
+
+    test('merge applies changes from current branch only (already applied)', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      // Only current (main) changed
+      store.update('doc1', { a: 10, b: 2 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toEqual([]);
+      // main already has the change, merge is essentially a no-op for this doc
+    });
+
+    test('merge combines non-conflicting changes from both sides', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2, c: 3 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20, c: 3 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toEqual([]);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });
+    });
+
+    test('merge detects conflicts when both sides change same field differently', () => {
+      store.create('doc1', { a: 1 });
