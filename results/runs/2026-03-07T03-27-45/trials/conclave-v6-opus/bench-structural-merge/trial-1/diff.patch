1')).toEqual({ a: 'ours' });\n    });\n  });\n});","originalFile":"import { describe, test, expect, beforeEach } from 'vitest';\nimport { DocumentStore } from './store.js';\n\ndescribe('DocumentStore', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  describe('Document CRUD', () => {\n    test('create stores a document retrievable by get', () => {\n      store.create('doc1', { title: 'Hello' });\n      expect(store.get('doc1')).toEqual({ title: 'Hello' });\n    });\n\n    test('create throws if document ID already exists', () => {\n      store.create('doc1', { title: 'Hello' });\n      expect(() => store.create('doc1', { title: 'World' })).toThrow();\n    });\n\n    test('get throws if document does not exist', () => {\n      expect(() => store.get('nonexistent')).toThrow();\n    });\n\n    test('get returns a deep clone, not the same reference', () => {\n      const content = { nested: { value: 1 } };\n      store.create('doc1', content);\n      const retrieved = store.get('doc1') as any;\n      retrieved.nested.value = 999;\n      expect((store.get('doc1') as any).nested.value).toBe(1);\n    });\n\n    test('create deep clones the input', () => {\n      const content = { nested: { value: 1 } } as any;\n      store.create('doc1', content);\n      content.nested.value = 999;\n      expect((store.get('doc1') as any).nested.value).toBe(1);\n    });\n\n    test('update replaces document content', () => {\n      store.create('doc1', { title: 'v1' });\n      store.update('doc1', { title: 'v2' });\n      expect(store.get('doc1')).toEqual({ title: 'v2' });\n    });\n\n    test('update throws if document does not exist', () => {\n      expect(() => store.update('nonexistent', { title: 'v1' })).toThrow();\n    });\n\n    test('delete removes a document', () => {\n      store.create('doc1', { title: 'Hello' });\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    test('delete throws if document does not exist', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    test('delete throws if document already deleted', () => {\n      store.create('doc1', { title: 'Hello' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n  });\n\n  describe('Version History', () => {\n    test('getHistory returns versions in chronological order', () => {\n      store.create('doc1', { title: 'v1' });\n      store.update('doc1', { title: 'v2' });\n      store.update('doc1', { title: 'v3' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ title: 'v1' });\n      expect(history[1].content).toEqual({ title: 'v2' });\n      expect(history[2].content).toEqual({ title: 'v3' });\n    });\n\n    test('getHistory returns versions with unique IDs', () => {\n      store.create('doc1', { title: 'v1' });\n      store.update('doc1', { title: 'v2' });\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n\n    test('getHistory returns versions with timestamps', () => {\n      store.create('doc1', { title: 'v1' });\n      const history = store.getHistory('doc1');\n      expect(typeof history[0].timestamp).toBe('number');\n      expect(history[0].timestamp).toBeGreaterThan(0);\n    });\n\n    test('getHistory throws for nonexistent document', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    test('getHistory returns deep clones', () => {\n      store.create('doc1', { title: 'v1' });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).title = 'mutated';\n      expect((store.getHistory('doc1')[0].content as any).title).toBe('v1');\n    });\n\n    test('getVersion returns content at a specific version', () => {\n      store.create('doc1', { title: 'v1' });\n      store.update('doc1', { title: 'v2' }