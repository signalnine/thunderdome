reate(id: string, content: object): void {\n    const branch = this.getCurrentBranchState();\n    const existing = branch.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document '${id}' already exists`);\n    }\n    const cloned = structuredClone(content);\n    const version: Version = {\n      id: this.nextVersionId(),\n      timestamp: Date.now(),\n      content: structuredClone(cloned),\n    };\n    branch.set(id, { versions: [version], deleted: false });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchState();\n    const doc = branch.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    return structuredClone(doc.versions[doc.versions.length - 1].content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchState();\n    const doc = branch.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    const cloned = structuredClone(content);\n    const version: Version = {\n      id: this.nextVersionId(),\n      timestamp: Date.now(),\n      content: structuredClone(cloned),\n    };\n    doc.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getCurrentBranchState();\n    const doc = branch.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    doc.deleted = true;\n  }\n\n  getHistory(_id: string): Version[] {\n    throw new Error('Not implemented');\n  }\n\n  getVersion(_id: string, _versionId: string): object {\n    throw new Error('Not implemented');\n  }\n\n  createBranch(_name: string, _fromBranch?: string): void {\n    throw new Error('Not implemented');\n  }\n\n  switchBranch(_name: string): void {\n    throw new Error('Not implemented');\n  }\n\n  getBranch(): string {\n    throw new Error('Not implemented');\n  }\n\n  listBranches(): string[] {\n    throw new Error('Not implemented');\n  }\n\n  merge(_sourceBranch: string): MergeResult {\n    throw new Error('Not implemented');\n  }\n}\n","structuredPatch":[{"oldStart":72,"oldLines":12,"newStart":72,"newLines":26,"lines":["     doc.deleted = true;","   }"," ","-  getHistory(_id: string): Version[] {","-    throw new Error('Not implemented');","+  getHistory(id: string): Version[] {","+    const branch = this.getCurrentBranchState();","+    const doc = branch.get(id);","+    if (!doc) {","+      throw new Error(`Document '${id}' not found`);","+    }","+    return doc.versions.map(v => structuredClone(v));","   }"," ","-  getVersion(_id: string, _versionId: string): object {","-    throw new Error('Not implemented');","+  getVersion(id: string, versionId: string): object {","+    const branch = this.getCurrentBranchState();","+    const doc = branch.get(id);","+    if (!doc) {","+      throw new Error(`Document '${id}' not found`);","+    }","+    const version = doc.versions.find(v => v.id === versionId);","+    if (!version) {","+      throw new Error(`Version '${versionId}' not found for document '${id}'`);","+    }","+    return structuredClone(version.content);","   }"," ","   createBranch(_name: string, _fromBranch?: string): void {"]}],"userModified":false,"replaceAll":false}}
