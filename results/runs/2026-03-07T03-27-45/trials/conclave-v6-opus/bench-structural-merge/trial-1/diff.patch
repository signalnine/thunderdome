n History', () => {\n    test('getHistory returns versions in chronological order', () => {\n      store.create('doc1', { title: 'v1' });\n      store.update('doc1', { title: 'v2' });\n      store.update('doc1', { title: 'v3' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ title: 'v1' });\n      expect(history[1].content).toEqual({ title: 'v2' });\n      expect(history[2].content).toEqual({ title: 'v3' });\n    });\n\n    test('getHistory returns versions with unique IDs', () => {\n      store.create('doc1', { title: 'v1' });\n      store.update('doc1', { title: 'v2' });\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n\n    test('getHistory returns versions with timestamps', () => {\n      store.create('doc1', { title: 'v1' });\n      const history = store.getHistory('doc1');\n      expect(typeof history[0].timestamp).toBe('number');\n      expect(history[0].timestamp).toBeGreaterThan(0);\n    });\n\n    test('getHistory throws for nonexistent document', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    test('getHistory returns deep clones', () => {\n      store.create('doc1', { title: 'v1' });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).title = 'mutated';\n      expect((store.getHistory('doc1')[0].content as any).title).toBe('v1');\n    });\n\n    test('getVersion returns content at a specific version', () => {\n      store.create('doc1', { title: 'v1' });\n      store.update('doc1', { title: 'v2' });\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ title: 'v1' });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ title: 'v2' });\n    });\n\n    test('getVersion throws for nonexistent document', () => {\n      expect(() => store.getVersion('nonexistent', 'v1'