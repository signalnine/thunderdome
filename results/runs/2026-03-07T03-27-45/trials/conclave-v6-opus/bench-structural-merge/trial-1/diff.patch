+++ b/src/store.ts
@@ -0,0 +1,317 @@
+import type { DocumentStore as IDocumentStore, Version, MergeResult, Conflict } from './types.js';
+import { threeWayMerge } from './merge.js';
+
+interface DocumentState {
+  versions: Version[];
+  deleted: boolean;
+}
+
+type BranchState = Map<string, DocumentState>;
+
+export class DocumentStore implements IDocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+  private versionCounter: number = 0;
+  // Maps childBranch -> parentBranch -> snapshot of parent at fork time
+  private branchBases: Map<string, Map<string, BranchState>> = new Map();
+
+  constructor() {
+    this.branches.set('main', new Map());
+  }
+
+  private getCurrentBranchState(): BranchState {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  private nextVersionId(): string {
+    return `v${++this.versionCounter}`;
+  }
+
+  private cloneBranchState(state: BranchState): BranchState {
+    const clone: BranchState = new Map();
+    for (const [id, doc] of state) {
+      clone.set(id, {
+        versions: doc.versions.map(v => structuredClone(v)),
+        deleted: doc.deleted,
+      });
+    }
+    return clone;
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document '${id}' already exists`);
+    }
+    const cloned = structuredClone(content);
+    const version: Version = {
+      id: this.nextVersionId(),
+      timestamp: Date.now(),
+      content: structuredClone(cloned),
+    };
+    branch.set(id, { versions: [version], deleted: false });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    return structuredClone(doc.versions[doc.versions.length - 1].content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    const cloned = structuredClone(content);
+    const version: Version = {
+      id: this.nextVersionId(),
+      timestamp: Date.now(),
+      content: structuredClone(cloned),
+    };
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.get(id);
+    if (!doc) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    return doc.versions.map(v => structuredClone(v));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.get(id);
+    if (!doc) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version '${versionId}' not found for document '${id}'`);
+    }
+    return structuredClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch '${name}' already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch '${sourceName}' not found`);
+    }
+    const cloned = this.cloneBranchState(source);
+    this.branches.set(name, cloned);
+    // Record the base snapshot for future merges
+    const bases = new Map<string, BranchState>();
+    bases.set(sourceName, this.cloneBranchState(source));
+    this.branchBases.set(name, bases);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch '${name}' not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  private getBaseState(childBranch: string, parentBranch: string): BranchState | null {
+    // Check if childBranch was forked from parentBranch
+    const bases = this.branchBases.get(childBranch);
+    if (bases && bases.has(parentBranch)) {
+      return bases.get(parentBranch)!;
+    }
+    // Check if parentBranch was forked from childBranch
+    const reverseBases = this.branchBases.get(parentBranch);
+    if (reverseBases && reverseBases.has(childBranch)) {
+      return reverseBases.get(childBranch)!;
+    }
+    return null;
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch '${sourceBranch}' not found`);
+    }
+    const current = this.getCurrentBranchState();
+    const base = this.getBaseState(sourceBranch, this.currentBranch);
+
+    // Collect all document IDs across base, ours, theirs
+    const allDocIds = new Set<string>();
+    if (base) {
+      for (const id of base.keys()) allDocIds.add(id);
+    }
+    for (const id of current.keys()) allDocIds.add(id);
+    for (const id of source.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+    let hasChanges = false;
+
+    for (const docId of allDocIds) {
+      const baseDoc = base ? base.get(docId) : undefined;
+      const oursDoc = current.get(docId);
+      const theirsDoc = source.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted
+        ? baseDoc.versions[baseDoc.versions.length - 1].content
+        : null;
+      const oursContent = oursDoc && !oursDoc.deleted
+        ? oursDoc.versions[oursDoc.versions.length - 1].content
+        : null;
+      const theirsContent = theirsDoc && !theirsDoc.deleted
+        ? theirsDoc.versions[theirsDoc.versions.length - 1].content
+        : null;
+
+      const oursExists = oursContent !== null;
+      const theirsExists = theirsContent !== null;
+
+      // Determine what changed
+      const oursChanged = !this.deepEqualContent(baseContent, oursContent);
+      const theirsChanged = !this.deepEqualContent(baseContent, theirsContent);
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes on either side - skip
+        continue;
+      }
+
+      if (oursChanged && !theirsChanged) {
+        // Only ours changed - already applied, just include in merged if there was a change
+        if (oursExists) {
+          merged[docId] = structuredClone(oursContent!);
+        }
+        hasChanges = true;
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        // Only theirs changed - apply theirs
+        hasChanges = true;
+        if (theirsExists) {
+          merged[docId] = structuredClone(theirsContent!);
+        }
+        continue;
+      }
+
+      // Both changed
+      if (this.deepEqualContent(oursContent, theirsContent)) {
+        // Both changed to same thing - no conflict
+        if (oursExists) {
+          merged[docId] = structuredClone(oursContent!);
+        }
+        hasChanges = true;
+        continue;
+      }
+
+      // Both changed differently
+      if (!oursExists && !theirsExists) {
+        // Both deleted - no conflict
+        hasChanges = true;
+        continue;
+      }
+
+      if (!oursExists || !theirsExists) {
+        // One deleted, other modified - treat as conflict at document level
+        // For now: if one side deleted and other modified, take the action
+        if (!theirsExists) {
+          // Theirs deleted, ours modified — keep ours
+          merged[docId] = structuredClone(oursContent!);
+        } else {
+          // Ours deleted, theirs modified — keep deleted (ours wins)
+        }
+        hasChanges = true;
+        continue;
+      }
+
+      // Both exist and both modified — three-way merge on content
+      const baseObj = baseContent ?? {};
+      const result = threeWayMerge(docId, baseObj, oursContent!, theirsContent!);
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+      hasChanges = true;
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied && hasChanges) {
+      // Apply the merge to current branch
+      for (const docId of allDocIds) {
+        const baseDoc = base ? base.get(docId) : undefined;
+        const oursDoc = current.get(docId);
+        const theirsDoc = source.get(docId);
+
+        const baseContent = baseDoc && !baseDoc.deleted
+          ? baseDoc.versions[baseDoc.versions.length - 1].content
+          : null;
+        const theirsContent = theirsDoc && !theirsDoc.deleted
+          ? theirsDoc.versions[theirsDoc.versions.length - 1].content
+          : null;
+        const theirsExists = theirsContent !== null;
+        const theirsChanged = !this.deepEqualContent(baseContent, theirsContent);
+
+        if (!theirsChanged) continue;
+
+        if (docId in merged) {
+          // Apply merged content
+          const mergedContent = merged[docId];
+          if (oursDoc && !oursDoc.deleted) {
+            // Update existing doc
+            const version: Version = {
+              id: this.nextVersionId(),
+              timestamp: Date.now(),
+              content: structuredClone(mergedContent),
+            };
+            oursDoc.versions.push(version);
+          } else {
+            // Create new doc on current branch
+            const version: Version = {
+              id: this.nextVersionId(),
+              timestamp: Date.now(),
+              content: structuredClone(mergedContent),
+            };
+            current.set(docId, { versions: [version], deleted: false });
+          }
+        } else if (theirsChanged && !theirsExists) {
+          // Document was deleted on source
+          if (oursDoc) {
+            oursDoc.deleted = true;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  private deepEqualContent(a: object | null, b: object | null): boolean {
+    if (a === null && b === null) return true;
+    if (a === null || b === null) return false;
+    return JSON.stringify(a) === JSON.stringify(b);
+  }
+}
