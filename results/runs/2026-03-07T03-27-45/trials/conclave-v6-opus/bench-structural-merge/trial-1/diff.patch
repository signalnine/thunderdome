ry[0].timestamp).toBeGreaterThan(0);\n    });\n\n    test('getHistory throws for nonexistent document', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    test('getHistory returns deep clones', () => {\n      store.create('doc1', { title: 'v1' });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).title = 'mutated';\n      expect((store.getHistory('doc1')[0].content as any).title).toBe('v1');\n    });\n\n    test('getVersion returns content at a specific version', () => {\n      store.create('doc1', { title: 'v1' });\n      store.update('doc1', { title: 'v2' });\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ title: 'v1' });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ title: 'v2' });\n    });\n\n    test('getVersion throws for nonexistent document', () => {\n      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();\n    });\n\n    test('getVersion throws for nonexistent version', () => {\n      store.create('doc1', { title: 'v1' });\n      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n    });\n  });\n\n  describe('Branching', () => {\n    test('default branch is main', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    test('listBranches returns main by default', () => {\n      expect(store.listBranches()).toEqual(['main']);\n    });\n\n    test('createBranch creates a new branch from current', () => {\n      store.createBranch('feature');\n      expect(store.listBranches()).toContain('feature');\n      expect(store.listBranches()).toContain('main');\n    });\n\n    test('switchBranch changes the active branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    test('switchBranch throws for nonexistent branch', () => {\n      expect(() => store.switchBranch('nonex