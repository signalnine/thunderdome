+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+import type { Machine } from './index.js';
+
+/** Helper: verify toggle solution is correct */
+function verifyToggle(machine: Machine, result: number[]): void {
+  const state = new Array(machine.target.length).fill(false);
+  for (const btn of result) {
+    for (const light of machine.buttons[btn]) {
+      state[light] = !state[light];
+    }
+  }
+  expect(state).toEqual(machine.target);
+}
+
+/** Helper: verify counter solution is correct */
+function verifyCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+  result: number[]
+): void {
+  const state = new Array(lights.length).fill(0);
+  for (let j = 0; j < buttons.length; j++) {
+    for (const counter of buttons[j]) {
+      state[counter] = (state[counter] + result[j]) % modulus;
+    }
+  }
+  expect(state).toEqual(lights);
+}
+
+describe('solveToggle', () => {
+  it('returns null for the spec example (inconsistent system)', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('returns empty array when target is all false', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('solves a simple single-button case', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    verifyToggle(machine, result!);
+  });
+
+  it('solves identity mapping (each button toggles one light)', () => {
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0], [1], [2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 2]);
+    verifyToggle(machine, result!);
+  });
+
+  it('returns minimum presses with lex-smallest tiebreak', () => {
+    // Both buttons toggle light 0. Need light 0 on.
+    // Solutions: press [0] or press [1]. Both 1 press. Lex smallest = [0].
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles no buttons with non-trivial target', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('handles no buttons with all-false target', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles no lights', () => {
+    const machine: Machine = {
+      target: [],
+      buttons: [[], []],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('returns null for unsolvable 3-button 3-light system', () => {
+    // All parity combinations are even → can't reach [T,T,T]
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a system with 2 solutions, picks fewer presses', () => {
+    // 2 lights, 2 buttons. Button 0: [0,1], Button 1: [0,1]
+    // target: [false, false]. Solutions: press none (0 presses) or press both (2 presses).
+    // Min = 0 presses → []
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [[0, 1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('solves a 4-light system correctly', () => {
+    // target: [true, false, true, false]
+    // button 0: [0, 2], button 1: [1, 3], button 2: [0, 1, 2, 3]
+    // Press button 0: [T,F,T,F] ✓ — just 1 press
+    const machine: Machine = {
+      target: [true, false, true, false],
+      buttons: [[0, 2], [1, 3], [0, 1, 2, 3]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    verifyToggle(machine, result!);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zeros', () => {
+    expect(solveCounter([0, 0, 0], [[0], [1], [2]], 5)).toEqual([0, 0, 0]);
+  });
+
+  it('solves simple identity case mod 5', () => {
+    const result = solveCounter([3, 0, 2], [[0], [1], [2]], 5);
+    expect(result).toEqual([3, 0, 2]);
+    verifyCounter([3, 0, 2], [[0], [1], [2]], 5, result!);
+  });
+
+  it('returns null when no solution exists', () => {
+    // Two buttons both affect counter 0 only. Target: counter 0=1, counter 1=1.
+    // No button affects counter 1 → can't reach target.
+    expect(solveCounter([1, 1], [[0], [0]], 3)).toBeNull();
+  });
+
+  it('finds minimum total presses', () => {
+    // target=[2], buttons=[[0],[0]], mod 3
+    // b0+b1 ≡ 2 (mod 3). Solutions: (0,2)sum=2, (1,1)sum=2, (2,0)sum=2.
+    // All same cost=2, lex smallest = [0,2]
+    const result = solveCounter([2], [[0], [0]], 3);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('handles modulus 2', () => {
+    // target=[1,0], button 0 affects [0,1], button 1 affects [1]
+    // b0 ≡ 1 (counter 0), b0+b1 ≡ 0 (counter 1) → b1=1
+    const result = solveCounter([1, 0], [[0, 1], [1]], 2);
+    expect(result).toEqual([1, 1]);
+    verifyCounter([1, 0], [[0, 1], [1]], 2, result!);
+  });
+
+  it('handles larger modulus (97)', () => {
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+
+  it('finds minimum presses with free variables mod 5', () => {
+    // 1 counter, 2 buttons both affecting counter 0. target=3, mod 5.
+    // b0+b1 ≡ 3 (mod 5). Solutions: (0,3)=3, (1,2)=3, (2,1)=3, (3,0)=3, (4,4)=8.
+    // Min sum=3, lex smallest=[0,3]
+    const result = solveCounter([3], [[0], [0]], 5);
+    expect(result).toEqual([0, 3]);
+  });
+
+  it('handles no buttons with zero target', () => {
+    expect(solveCounter([0, 0], [], 7)).toEqual([]);
+  });
+
+  it('handles no buttons with non-zero target', () => {
+    expect(solveCounter([1], [], 7)).toBeNull();
+  });
+
+  it('handles no counters', () => {
+    expect(solveCounter([], [[], []], 5)).toEqual([0, 0]);
+  });
+
+  it('handles multiple free variables with minimum cost selection', () => {
+    // 1 counter, 3 buttons all affecting counter 0. target=1, mod 3.
+    // b0+b1+b2 ≡ 1 (mod 3). Want minimum sum.
+    // Best: one button pressed once, others 0. Min sum=1.
+    // Lex smallest: [0,0,1]
+    const result = solveCounter([1], [[0], [0], [0]], 3);
+    expect(result).toEqual([0, 0, 1]);
+    verifyCounter([1], [[0], [0], [0]], 3, result!);
+  });
+});
+
+describe('performance', () => {
+  it('solves 40x40 toggle system within 5 seconds', () => {
+    const n = 40;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i, (i + 1) % n]);
+    }
+    const target = new Array(n).fill(true);
+
+    const start = Date.now();
+    const result = solveToggle({ target, buttons });
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      verifyToggle({ target, buttons }, result);
+    }
+  });
+
+  it('solves 40x40 counter system mod 97 within 5 seconds', () => {
+    const n = 40;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i, (i + 1) % n]);
+    }
+    const lights = Array.from({ length: n }, (_, i) => (i * 7) % 97);
+
+    const start = Date.now();
+    const result = solveCounter(lights, buttons, 97);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      verifyCounter(lights, buttons, 97, result);
+    }
+  });
+});
