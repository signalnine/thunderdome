@@ -0,0 +1,288 @@
+import { mod, modInverse } from './modular.js';
+
+/**
+ * Solve a linear system Ax = b over GF(p).
+ *
+ * Returns the solution minimizing sum of values.
+ * If lexLargest is true, prefers lex-largest raw vector on ties (useful for
+ * toggle puzzles where lex-smallest pressed set = lex-largest raw vector).
+ * Otherwise prefers lex-smallest raw vector.
+ * Returns null if no solution exists.
+ */
+export function solveLinearSystem(
+  matrix: number[][],
+  target: number[],
+  numVars: number,
+  modulus: number,
+  lexLargest: boolean = false
+): number[] | null {
+  const numEqs = matrix.length;
+
+  // Handle edge case: no variables
+  if (numVars === 0) {
+    // Check if all targets are 0
+    for (let i = 0; i < numEqs; i++) {
+      if (mod(target[i] ?? 0, modulus) !== 0) return null;
+    }
+    return [];
+  }
+
+  // Build augmented matrix [A | b]
+  const aug: number[][] = [];
+  for (let i = 0; i < numEqs; i++) {
+    const row = new Array(numVars + 1);
+    for (let j = 0; j < numVars; j++) {
+      row[j] = mod(matrix[i]?.[j] ?? 0, modulus);
+    }
+    row[numVars] = mod(target[i] ?? 0, modulus);
+    aug.push(row);
+  }
+
+  // Gaussian elimination to RREF
+  const pivotCols: number[] = [];
+  let pivotRow = 0;
+
+  for (let col = 0; col < numVars && pivotRow < numEqs; col++) {
+    // Find pivot row for this column
+    let found = -1;
+    for (let row = pivotRow; row < numEqs; row++) {
+      if (aug[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue; // This column is a free variable
+
+    // Swap rows
+    if (found !== pivotRow) {
+      [aug[pivotRow], aug[found]] = [aug[found], aug[pivotRow]];
+    }
+
+    // Scale pivot row so leading entry = 1
+    const inv = modInverse(aug[pivotRow][col], modulus);
+    for (let j = 0; j <= numVars; j++) {
+      aug[pivotRow][j] = mod(aug[pivotRow][j] * inv, modulus);
+    }
+
+    // Eliminate this column in all other rows
+    for (let row = 0; row < numEqs; row++) {
+      if (row === pivotRow || aug[row][col] === 0) continue;
+      const factor = aug[row][col];
+      for (let j = 0; j <= numVars; j++) {
+        aug[row][j] = mod(aug[row][j] - factor * aug[pivotRow][j], modulus);
+      }
+    }
+
+    pivotCols.push(col);
+    pivotRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  // Check consistency: rows below rank with nonzero RHS
+  for (let row = rank; row < numEqs; row++) {
+    if (aug[row][numVars] !== 0) return null;
+  }
+
+  // Identify free variables
+  const isPivotCol = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numVars; col++) {
+    if (!isPivotCol.has(col)) freeVars.push(col);
+  }
+
+  // If no free variables, unique solution
+  if (freeVars.length === 0) {
+    const solution = new Array(numVars).fill(0);
+    for (let i = 0; i < rank; i++) {
+      solution[pivotCols[i]] = aug[i][numVars];
+    }
+    return solution;
+  }
+
+  // Compute full solution from free variable assignment
+  const computeSolution = (freeValues: number[]): number[] => {
+    const sol = new Array(numVars).fill(0);
+    for (let i = 0; i < freeVars.length; i++) {
+      sol[freeVars[i]] = freeValues[i];
+    }
+    for (let i = 0; i < rank; i++) {
+      let val = aug[i][numVars];
+      for (let fi = 0; fi < freeVars.length; fi++) {
+        val = mod(val - aug[i][freeVars[fi]] * freeValues[fi], modulus);
+      }
+      sol[pivotCols[i]] = val;
+    }
+    return sol;
+  };
+
+  const solutionCost = (sol: number[]): number => {
+    let sum = 0;
+    for (let i = 0; i < sol.length; i++) sum += sol[i];
+    return sum;
+  };
+
+  const isBetter = (candidate: number[], best: number[]): boolean => {
+    const cc = solutionCost(candidate);
+    const bc = solutionCost(best);
+    if (cc !== bc) return cc < bc;
+    // Lex comparison: smallest or largest depending on mode
+    for (let i = 0; i < candidate.length; i++) {
+      if (candidate[i] !== best[i]) {
+        return lexLargest ? candidate[i] > best[i] : candidate[i] < best[i];
+      }
+    }
+    return false;
+  };
+
+  const k = freeVars.length;
+
+  // Estimate search space
+  // Use log to avoid overflow for large modulus^k
+  const logSearchSize = k * Math.log2(modulus);
+
+  if (logSearchSize <= 21) {
+    // Direct enumeration (up to ~2M combinations)
+    return enumerateDirect(k, modulus, computeSolution, isBetter);
+  }
+
+  // Meet-in-the-middle
+  return meetInTheMiddle(
+    k, modulus, rank, aug, pivotCols, freeVars, numVars, computeSolution, isBetter, lexLargest
+  );
+}
+
+/**
+ * Direct enumeration of all free variable assignments.
+ */
+function enumerateDirect(
+  k: number,
+  modulus: number,
+  computeSolution: (freeValues: number[]) => number[],
+  isBetter: (candidate: number[], best: number[]) => boolean
+): number[] {
+  let best: number[] | null = null;
+  const freeValues = new Array(k).fill(0);
+  let done = false;
+
+  while (!done) {
+    const sol = computeSolution(freeValues);
+    if (best === null || isBetter(sol, best)) {
+      best = sol;
+    }
+
+    // Increment (odometer, last index first)
+    let carry = true;
+    for (let i = k - 1; i >= 0 && carry; i--) {
+      freeValues[i]++;
+      if (freeValues[i] >= modulus) {
+        freeValues[i] = 0;
+      } else {
+        carry = false;
+      }
+    }
+    if (carry) done = true;
+  }
+
+  return best!;
+}
+
+/**
+ * Meet-in-the-middle for larger search spaces.
+ * Split free variables into two halves, enumerate each half,
+ * combine to find optimal solution.
+ */
+function meetInTheMiddle(
+  k: number,
+  modulus: number,
+  rank: number,
+  aug: number[][],
+  pivotCols: number[],
+  freeVars: number[],
+  numVars: number,
+  computeSolution: (freeValues: number[]) => number[],
+  isBetter: (candidate: number[], best: number[]) => boolean,
+  lexLargest: boolean
+): number[] {
+  const halfA = Math.ceil(k / 2);
+  const halfB = k - halfA;
+
+  // For MITM, we enumerate halfA assignments and store them grouped by
+  // their "partial signature" (contribution to pivot variables).
+  // Then for each halfB assignment, we iterate the halfA groups to find the best combo.
+
+  // Compute partial contribution of half-A free vars to each pivot equation
+  const freeA = freeVars.slice(0, halfA);
+
+  const computePartialA = (vals: number[]): number[] => {
+    const partial = new Array(rank);
+    for (let i = 0; i < rank; i++) {
+      let s = 0;
+      for (let j = 0; j < freeA.length; j++) {
+        s += aug[i][freeA[j]] * vals[j];
+      }
+      partial[i] = mod(s, modulus);
+    }
+    return partial;
+  };
+
+  // Build halfA table: signature → best {cost of free vars, values}
+  const halfATable = new Map<string, { costFree: number; values: number[] }>();
+  const valsA = new Array(halfA).fill(0);
+  const halfASize = Math.pow(modulus, halfA);
+
+  for (let idx = 0; idx < halfASize; idx++) {
+    // Decode index
+    let tmp = idx;
+    for (let i = halfA - 1; i >= 0; i--) {
+      valsA[i] = tmp % modulus;
+      tmp = Math.floor(tmp / modulus);
+    }
+
+    const sig = computePartialA(valsA);
+    const key = sig.join(',');
+    let costFree = 0;
+    for (let i = 0; i < halfA; i++) costFree += valsA[i];
+
+    const existing = halfATable.get(key);
+    const lexCmp = compareLexArr(valsA, existing?.values ?? []);
+    const lexBetter = lexLargest ? lexCmp > 0 : lexCmp < 0;
+    if (!existing || costFree < existing.costFree ||
+        (costFree === existing.costFree && lexBetter)) {
+      halfATable.set(key, { costFree, values: [...valsA] });
+    }
+  }
+
+  // For each halfB assignment, find the best combination
+  let best: number[] | null = null;
+  const valsB = new Array(halfB).fill(0);
+  const halfBSize = Math.pow(modulus, halfB);
+
+  for (let idx = 0; idx < halfBSize; idx++) {
+    let tmp = idx;
+    for (let i = halfB - 1; i >= 0; i--) {
+      valsB[i] = tmp % modulus;
+      tmp = Math.floor(tmp / modulus);
+    }
+
+    // Try each halfA signature
+    for (const [_key, halfAEntry] of halfATable) {
+      // Compute full free values and solution
+      const allFree = [...halfAEntry.values, ...valsB];
+      const sol = computeSolution(allFree);
+
+      if (best === null || isBetter(sol, best)) {
+        best = sol;
+      }
+    }
+  }
+
+  return best!;
+}
+
+function compareLexArr(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
