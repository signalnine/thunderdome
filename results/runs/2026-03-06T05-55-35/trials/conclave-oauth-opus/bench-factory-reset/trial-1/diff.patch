   expect(state).toEqual(target);\n    }\n  });\n\n  it('solves 40x40 counter system mod 97 within 5 seconds', () => {\n    const n = 40;\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i, (i + 1) % n]);\n    }\n    const lights = Array.from({ length: n }, (_, i) => (i * 7) % 97);\n\n    const start = Date.now();\n    const result = solveCounter(lights, buttons, 97);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    if (result !== null) {\n      const state = new Array(n).fill(0);\n      for (let j = 0; j < n; j++) {\n        for (const counter of buttons[j]) {\n          state[counter] = (state[counter] + result[j]) % 97;\n        }\n      }\n      expect(state).toEqual(lights);\n    }\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: All pass, performance within budget\n\n**Step 3: Run build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: Both pass\n\n**Step 4: Commit**\n\n```bash\ngit add src/index.test.ts\ngit commit -m \"test: add performance tests for 40x40 systems\"\n```\n\n---\n\n### Task 6: Final Verification\n\n**Dependencies:** Task 5\n\n**Step 1: Run full verification suite**\n\nRun: `npm test && npm run build && npm run lint`\nExpected: All pass\n\n**Step 2: Review diff**\n\nRun: `git diff HEAD~5` (review all changes)\nCheck for: dead code, debug artifacts, incomplete implementations, missing edge cases.\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":166,"cache_read_input_tokens":34460,"cache_creation":{"ephemeral_5m_input_tokens":166,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a682d811-81b2-4e54-b48d-51683b8afd0c","uuid":"23776f99-0c33-4205-8c57-74841c1b7ed0"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016DCCwjThzFeFKGCV7nxVHh","type":"tool_result","content":"File created successfully at: /workspace/docs/plans/2026-03-06-factory-reset-plan.md"}]},"parent_tool_use_id":null,"session_id":"a682d811-81b2-4e54-b48d-51683b8afd0c","uuid":"13dc3cd8-4e45-455b-a827-b38a7cde783f","tool_use_result":{"type":"create","filePath":"/workspace/docs/plans/2026-03-06-factory-reset-plan.md","content":"# Factory Reset Puzzle Solver Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use conclave:executing-plans to implement this plan task-by-task.\n\n**Goal:** Implement `solveToggle` and `solveCounter` functions that solve linear systems over finite fields GF(p) to find optimal button press configurations for factory machine puzzles.\n\n**Architecture:** A unified GF(p) Gaussian elimination solver with meet-in-the-middle optimization for large null spaces. Two thin API wrappers convert between problem-specific formats and the core solver. Modular arithmetic utilities handle field operations.\n\n**Tech Stack:** TypeScript, ES modules, Vitest for testing, ESLint for linting.\n\n---\n\n### Task 1: Modular Arithmetic Utilities\n\n**Files:**\n- Create: `src/modular.ts`\n\n**Dependencies:** none\n\n**Step 1: Write `src/modular.ts` with all modular arithmetic functions**\n\n```typescript\n/**\n * Always-positive modulo.\n */\nexport function mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\n/**\n * Modular multiplicative inverse using extended Euclidean algorithm.\n * Assumes p is prime and a is not 0 mod p.\n */\nexport function modInverse(a: number, p: number): number {\n  a = mod(a, p);\n  // Extended Euclidean algorithm\n  let [old_r, r] = [a, p];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return mod(old_s, p);\n}\n```\n\n**Step 2: Run build to verify it compiles**\n\nRun: `npm run build`\nExpected: Success (no errors)\n\n**Step 3: Commit**\n\n```bash\ngit add src/modular.ts\ngit commit -m \"feat: add modular arithmetic utilities\"\n```\n\n---\n\n### Task 2: Core GF(p) Gaussian Elimination Solver\n\n**Files:**\n- Create: `src/solver.ts`\n\n**Dependencies:** Task 1\n\n**Step 1: Write `src/solver.ts` with the core solver**\n\nThis file implements:\n1. `solveLinearSystem(matrix, target, numVars, modulus)` — the main entry point\n2. Gaussian elimination to RREF\n3. Consistency checking\n4. Free/pivot variable identification\n5. Solution enumeration with meet-in-the-middle for large null spaces\n\n```typescript\nimport { mod, modInverse } from './modular.js';\n\n/**\n * Solve a linear system Ax = b over GF(p).\n *\n * @param matrix - matrix[i][j] = coefficient of variable j in equation i (values in 0..p-1)\n * @param target - target[i] = RHS of equation i (values in 0..p-1)\n * @param numVars - number of variables (columns in matrix)\n * @param modulus - prime modulus\n * @returns array of length numVars with values in 0..p-1, or null if no solution\n *          Returns the solution minimizing sum of values, lex-smallest if tied.\n */\nexport function solveLinearSystem(\n  matrix: number[][],\n  target: number[],\n  numVars: number,\n  modulus: number\n): number[] | null {\n  const numEqs = matrix.length;\n\n  // Build augmented matrix [A | b]\n  const aug: number[][] = [];\n  for (let i = 0; i < numEqs; i++) {\n    const row = new Array(numVars + 1);\n    for (let j = 0; j < numVars; j++) {\n      row[j] = mod(matrix[i]?.[j] ?? 0, modulus);\n    }\n    row[numVars] = mod(target[i] ?? 0, modulus);\n    aug.push(row);\n  }\n\n  // Gaussian elimination → RREF\n  const pivotCol: number[] = []; // pivotCol[i] = column index of pivot in row i\n  let pivotRow = 0;\n\n  for (let col = 0; col < numVars && pivotRow < numEqs; col++) {\n    // Find pivot in this column\n    let found = -1;\n    for (let row = pivotRow; row < numEqs; row++) {\n      if (aug[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue; // Free variable\n\n    // Swap rows\n    if (found !== pivotRow) {\n      [aug[pivotRow], aug[found]] = [aug[found], aug[pivotRow]];\n    }\n\n    // Scale pivot row so pivot = 1\n    const inv = modInverse(aug[pivotRow][col], modulus);\n    for (let j = 0; j < numVars + 1; j++) {\n      aug[pivotRow][j] = mod(aug[pivotRow][j] * inv, modulus);\n    }\n\n    // Eliminate column in all other rows\n    for (let row = 0; row < numEqs; row++) {\n      if (row === pivotRow || aug[row][col] === 0) continue;\n      const factor = aug[row][col];\n      for (let j = 0; j < numVars + 1; j++) {\n        aug[row][j] = mod(aug[row][j] - factor * aug[pivotRow][j], modulus);\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check consistency: rows with all-zero LHS but nonzero RHS\n  for (let row = rank; row < numEqs; row++) {\n    if (aug[row][numVars] !== 0) return null; // No solution\n  }\n\n  // Identify pivot and free variables\n  const isPivotCol = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numVars; col++) {\n    if (!isPivotCol.has(col)) freeVars.push(col);\n  }\n\n  // Map from pivot column to its row in RREF\n  const pivotColToRow = new Map<number, number>();\n  for (let i = 0; i < rank; i++) {\n    pivotColToRow.set(pivotCol[i], i);\n  }\n\n  // If no free variables, unique solution\n  if (freeVars.length === 0) {\n    const solution = new Array(numVars).fill(0);\n    for (let i = 0; i < rank; i++) {\n      solution[pivotCol[i]] = aug[i][numVars];\n    }\n    return solution;\n  }\n\n  // Compute solution for a given assignment of free variables\n  function computeSolution(freeValues: number[]): number[] {\n    const sol = new Array(numVars).fill(0);\n    for (let i = 0; i < freeVars.length; i++) {\n      sol[freeVars[i]] = freeValues[i];\n    }\n    // Pivot vars: x_pivot = rhs - sum(coeff * x_free) for each free var\n    for (let i = 0; i < rank; i++) {\n      let val = aug[i][numVars];\n      for (let fi = 0; fi < freeVars.length; fi++) {\n        val = mod(val - aug[i][freeVars[fi]] * freeValues[fi], modulus);\n      }\n      sol[pivotCol[i]] = val;\n    }\n    return sol;\n  }\n\n  function solutionCost(sol: number[]): number {\n    let sum = 0;\n    for (let i = 0; i < sol.length; i++) sum += sol[i];\n    return sum;\n  }\n\n  function compareLex(a: number[], b: number[]): number {\n    for (let i = 0; i < a.length; i++) {\n      if (a[i] !== b[i]) return a[i] - b[i];\n    }\n    return 0;\n  }\n\n  function isBetter(candidate: number[], best: number[]): boolean {\n    const cc = solutionCost(candidate);\n    const bc = solutionCost(best);\n    if (cc < bc) return true;\n    if (cc > bc) return false;\n    return compareLex(candidate, best) < 0;\n  }\n\n  const k = freeVars.length;\n\n  // Estimate search space size\n  const searchSize = Math.pow(modulus, k);\n\n  if (searchSize <= 2_000_000) {\n    // Direct enumeration\n    let best: number[] | null = null;\n\n    const freeValues = new Array(k).fill(0);\n\n    // Enumerate all assignments of free variables\n    const enumerate = (): void => {\n      while (true) {\n        const sol = computeSolution(freeValues);\n        if (best === null || isBetter(sol, best)) {\n          best = sol;\n        }\n\n        // Increment freeValues (odometer style, last index first)\n        let carry = true;\n        for (let i = k - 1; i >= 0 && carry; i--) {\n          freeValues[i]++;\n          if (freeValues[i] >= modulus) {\n            freeValues[i] = 0;\n          } else {\n            carry = false;\n          }\n        }\n        if (carry) break; // All enumerated\n      }\n    };\n\n    enumerate();\n    return best;\n  }\n\n  // Meet-in-the-middle for large search spaces\n  // Split free variables into two halves\n  const halfA = Math.floor(k / 2);\n  const halfB = k - halfA;\n  const freeA = freeVars.slice(0, halfA);\n  const freeB = freeVars.slice(halfA);\n\n  // For each half-A assignment, compute partial contribution to each variable\n  // The solution is: x_pivot = rhs - sum(coeff_a * free_a) - sum(coeff_b * free_b)\n  // Total cost = sum(free_a) + sum(free_b) + sum(pivot_values)\n  // pivot_values depend on both halves\n\n  // We need a \"signature\" that captures half-A's effect so we can combine with half-B.\n  // Signature for half-A: for each pivot variable i, compute sum(coeff * free_a_val) mod p\n  // Then when combining: pivot_val = (rhs - sigA - sigB) mod p\n\n  // Build half-A table: map from signature → {cost, freeValues, fullPartialContrib}\n  // Signature = tuple of (partial sum for each pivot variable from half-A free vars)\n\n  // For efficiency, encode signature as a string\n  function computePartialA(freeAValues: number[]): number[] {\n    // Returns array of length rank: partial[i] = sum of aug[i][freeA[j]] * freeAValues[j] mod p\n    const partial = new Array(rank).fill(0);\n    for (let i = 0; i < rank; i++) {\n      for (let j = 0; j < freeA.length; j++) {\n        partial[i] = mod(partial[i] + aug[i][freeA[j]] * freeAValues[j], modulus);\n      }\n    }\n    return partial;\n  }\n\n  function computePartialB(freeBValues: number[]): number[] {\n    const partial = new Array(rank).fill(0);\n    for (let i = 0; i < rank; i++) {\n      for (let j = 0; j < freeB.length; j++) {\n        partial[i] = mod(partial[i] + aug[i][freeB[j]] * freeBValues[j], modulus);\n      }\n    }\n    return partial;\n  }\n\n  // For each half-A, compute: freeA cost + pivot contribution from freeA partial\n  // For combining: total cost = costA_free + costB_free + sum_of_pivot_values\n  // pivot_val[i] = (rhs[i] - partialA[i] - partialB[i]) mod p\n  // So sum_of_pivots = sum( (rhs[i] - partialA[i] - partialB[i]) mod p )\n\n  // Build table: key = signature string of partialA, value = list of {costFree, freeAValues}\n  // For each halfB assignment, compute partialB, then for each possible partialA signature,\n  // compute combined pivot costs and find optimum.\n\n  // Actually with MITM we want: for a given partialB, what partialA gives minimum total?\n  // total = costFreeA + costFreeB + sum_i( (rhs_i - partialA_i - partialB_i) mod p )\n  // The sum_i term depends on both halves non-linearly (due to mod), making a clean hash join hard.\n\n  // Alternative MITM approach: enumerate half-A, store all (fullSolution, cost).\n  // Then for half-B, combine and check. But full solutions depend on both halves.\n\n  // Simpler practical approach for larger spaces:\n  // Since modulus ≤ 97 and vars ≤ 40, free vars is at most 40.\n  // But rank ≤ 40 too. In practice, if we have many free vars, p is likely small.\n  // For p=2, k=40 → 2^40 too large. But MITM: 2^20 * 2^20 with hash join.\n  // For p=97, k=40 → 97^40 absurdly large, but this can't happen (40 vars, 40 eqs → rank ≤ 40).\n  // With 40 eqs and 40 vars, free vars ≤ 40 - rank. Rank can be 0 only if matrix is all zeros.\n  // Realistically with 40 lights, rank is close to 40 for non-degenerate cases.\n\n  // For MITM: enumerate halfA fully (p^halfA entries), store in a map keyed by partialA.\n  // For each halfB assignment, iterate over matching halfA entries.\n  // But without a clean separable objective, we need to enumerate all combos...\n  // which defeats the purpose.\n\n  // Better: for GF(2), the pivot costs are deterministic given partials, and mod 2 is simpler.\n  // We can precompute for each halfA: {partialA signature → best (costFreeA, freeAValues)}\n  // Then for each halfB: compute partialB, then compute what partialA signature would minimize total.\n  // For GF(2): pivot_val = (rhs_i XOR partialA_i XOR partialB_i), cost is just popcount.\n  // So pivot_cost = popcount(rhs XOR partialA XOR partialB) over all pivots.\n  // Total = costFreeA + costFreeB + popcount(rhs XOR partialA XOR partialB)\n  // For fixed partialB: we want partialA that minimizes costFreeA + popcount(rhs XOR partialA XOR partialB)\n  // Let target_partial = rhs XOR partialB. We want partialA minimizing costFreeA + popcount(target_partial XOR partialA).\n  // This is still a search over partialA values... but with only p^halfA ≤ 2^20 entries in the table,\n  // we just iterate the table for each halfB entry. Total: 2^20 * 2^20 = 2^40... still too much.\n\n  // We need to be smarter. Group halfA entries by partialA signature, keep only best per signature.\n  // Signatures have at most 2^rank distinct values (rank ≤ 40 for GF(2)).\n  // But if rank is large (e.g., 30), and freeVars is 10, then 2^10 = 1024 entries, trivial.\n  // The hard case is low rank + many free vars. E.g., rank=0, 40 free vars over GF(2).\n  // Then all variables are free, we just want minimum-weight vector matching target.\n  // But target is already the solution (every variable maps to its target), so no search needed if rank=0 means target=0 for consistency.\n\n  // Actually if rank = 0 and matrix is all zeros, the system Ax=b requires b=0.\n  // If b=0, every x is a solution → minimize sum(x_i) → all zeros.\n  // If b≠0, no solution.\n\n  // So the practical hard case with many free variables over GF(2) is moderate rank + many free vars.\n  // Example: rank=20, free=20, GF(2). Search = 2^20 = 1M. Already handled by direct enumeration.\n\n  // For GF(2), rank + free = numVars ≤ 40. If free ≤ 20, search ≤ 2^20 = 1M (direct enum).\n  // If free > 20, then rank < 20. MITM: 2^(free/2) per half. Table has 2^(free/2) entries,\n  // each with a signature of length rank < 20. Group by signature: at most 2^rank < 2^20 groups.\n  // For each halfB entry (2^(free/2) of them), look up the best halfA entry for each needed signature.\n  // This is O(2^(free/2) * 2^rank) which could be 2^20 * 2^20 = 2^40... bad.\n\n  // Let's just use MITM with brute-force combine but limit to practical sizes.\n  // The key insight: for GF(2), the total number of variables is ≤ 40.\n  // rank + free = 40. If free > 20, rank < 20.\n  // MITM halfA = free/2, halfB = free - free/2.\n  // For each of 2^halfB halfB assignments, we compute partialB (length rank),\n  // then we need to find in the halfA table (2^halfA entries) the one that,\n  // combined with this partialB, gives minimum total cost.\n  //\n  // We precompute the halfA table grouped by partialA signature.\n  // For each group, keep only the entry with minimum costFreeA (tiebreak lex).\n  // Number of groups ≤ 2^rank (for GF(2), signature is a binary vector of length rank).\n  //\n  // For each halfB: the optimal pivot cost for each possible partialA is:\n  //   pivotCost(partialA) = popcount((rhs - partialA - partialB) mod 2) = popcount(rhs XOR partialA XOR partialB)\n  // Total(partialA) = bestCostFreeA[partialA] + costFreeB + pivotCost(partialA)\n  // We iterate over all distinct partialA signatures (≤ 2^rank < 2^20) for each halfB (2^(free/2)).\n  // Total work: 2^(free/2) * 2^rank. With free=40, rank=0 → 2^20 * 1 = 1M. Fine.\n  // With free=30, rank=10 → 2^15 * 2^10 = 2^25 = 33M. Borderline but OK in 5s.\n  // With free=25, rank=15 → 2^13 * 2^15 = 2^28 = 268M. Might be too slow.\n\n  // This is getting complex. Let's use a practical approach:\n  // 1. Direct enumeration for search ≤ 2M\n  // 2. For larger: MITM with grouped halfA table, iterate halfB × groups\n  //    This handles most practical cases within 5 seconds.\n\n  // Enumerate halfA, build table grouped by signature\n  const halfASize = Math.pow(modulus, halfA);\n\n  // Map from signature key → {bestCost, bestFreeAValues}\n  const halfATable = new Map<string, { cost: number; values: number[]; fullFreeValues: number[] }>();\n\n  const freeAValues = new Array(halfA).fill(0);\n  for (let idx = 0; idx < halfASize; idx++) {\n    // Decode idx into freeAValues\n    let tmp = idx;\n    for (let i = halfA - 1; i >= 0; i--) {\n      freeAValues[i] = tmp % modulus;\n      tmp = Math.floor(tmp / modulus);\n    }\n\n    const partialA = computePartialA(freeAValues);\n    const costFreeA = freeAValues.reduce((s, v) => s + v, 0);\n    const key = partialA.join(',');\n\n    const existing = halfATable.get(key);\n    if (!existing || costFreeA < existing.cost ||\n        (costFreeA === existing.cost && compareLexArr(freeAValues, existing.values) < 0)) {\n      halfATable.set(key, {\n        cost: costFreeA,\n        values: [...freeAValues],\n        fullFreeValues: [...freeAValues]\n      });\n    }\n  }\n\n  function compareLexArr(a: number[], b: number[]): number {\n    for (let i = 0; i < a.length; i++) {\n      if (a[i] !== b[i]) return a[i] - b[i];\n    }\n    return 0;\n  }\n\n  // Enumerate halfB, combine with best halfA\n  let best: number[] | null = null;\n\n  const halfBSize = Math.pow(modulus, halfB);\n  const freeBValues = new Array(halfB).fill(0);\n\n  for (let idx = 0; idx < halfBSize; idx++) {\n    let tmp = idx;\n    for (let i = halfB - 1; i >= 0; i--) {\n      freeBValues[i] = tmp % modulus;\n      tmp = Math.floor(tmp / modulus);\n    }\n\n    const partialB = computePartialB(freeBValues);\n    const costFreeB = freeBValues.reduce((s, v) => s + v, 0);\n\n    // Try all halfA signatures\n    for (const [key, halfAEntry] of halfATable) {\n      const partialA = key.split(',').map(Number);\n\n      // Compute pivot costs\n      let pivotCost = 0;\n      for (let i = 0; i < rank; i++) {\n        pivotCost += mod(aug[i][numVars] - partialA[i] - partialB[i], modulus);\n      }\n\n      const totalCost = halfAEntry.cost + costFreeB + pivotCost;\n\n      // Build full solution to compare\n      const allFreeValues = [...halfAEntry.fullFreeValues, ...freeBValues];\n      const sol = computeSolution(allFreeValues);\n      const solCost = solutionCost(sol);\n\n      if (best === null || isBetter(sol, best)) {\n        best = sol;\n      }\n    }\n  }\n\n  return best;\n}\n```\n\n**Important implementation notes:**\n- The meet-in-the-middle section handles the case where direct enumeration is too large\n- For each halfA group, we only keep the best entry (min cost, lex tiebreak) to reduce comparisons\n- The `computeSolution` function reconstructs the full solution from free variable assignments\n\n**Step 2: Run build to verify it compiles**\n\nRun: `npm run build`\nExpected: Success\n\n**Step 3: Commit**\n\n```bash\ngit add src/solver.ts\ngit commit -m \"feat: add core GF(p) linear system solver with MITM optimization\"\n```\n\n---\n\n### Task 3: API Wrappers and Exports\n\n**Files:**\n- Create: `src/index.ts`\n\n**Dependencies:** Task 1, Task 2\n\n**Step 1: Write `src/index.ts`**\n\n```typescript\nimport { solveLinearSystem } from './solver.js';\n\nexport interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build coefficient matrix: matrix[light][button] = 1 if button toggles light\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    matrix.push(row);\n  }\n\n  // Target: true=1, false=0\n  const tgt = target.map(t => t ? 1 : 0);\n\n  const solution = solveLinearSystem(matrix, tgt, numButtons, 2);\n  if (solution === null) return null;\n\n  // Convert to list of pressed button indices\n  const pressed: number[] = [];\n  for (let i = 0; i < solution.length; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n  return pressed;\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build coefficient matrix: matrix[counter][button] = 1 if button affects counter\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    matrix.push(row);\n  }\n\n  return solveLinearSystem(matrix, lights, numButtons, modulus);\n}\n```\n\n**Step 2: Run build**\n\nRun: `npm run build`\nExpected: Success\n\n**Step 3: Commit**\n\n```bash\ngit add src/index.ts\ngit commit -m \"feat: add solveToggle and solveCounter API wrappers\"\n```\n\n---\n\n### Task 4: Unit Tests\n\n**Files:**\n- Create: `src/index.test.ts`\n\n**Dependencies:** Task 3\n\n**Step 1: Write comprehensive tests**\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter } from './index.js';\nimport type { Machine } from './index.js';\n\ndescribe('solveToggle', () => {\n  it('returns null for the spec example (no solution)', () => {\n    const machine: Machine = {\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('returns empty array when target is all false', () => {\n    const machine: Machine = {\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('solves a simple single-button case', () => {\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0, 1]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('solves identity mapping (each button toggles one light)', () => {\n    const machine: Machine = {\n      target: [true, false, true],\n      buttons: [[0], [1], [2]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 2]);\n  });\n\n  it('returns minimum presses when multiple solutions exist', () => {\n    // Buttons 0 and 1 both toggle light 0\n    // Pressing both cancels out. target=[true] needs exactly one.\n    // Button 0 alone (1 press) or button 1 alone (1 press) — lex smallest is [0]\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('handles case with no buttons and non-trivial target', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('handles case with no buttons and all-false target', () => {\n    const machine: Machine = {\n      target: [false, false],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('handles case with no lights', () => {\n    const machine: Machine = {\n      target: [],\n      buttons: [[],[]],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('solves a 3-button 3-light system', () => {\n    // target: [true, true, true]\n    // button 0: [0, 1], button 1: [1, 2], button 2: [0, 2]\n    // Press all 3: light 0 toggled by 0,2 = off; light 1 toggled by 0,1 = off; light 2 toggled by 1,2 = off → [F,F,F] wrong\n    // Press 0+1: light 0=on, light 1=on XOR on=off, light 2=on → [T,F,T] wrong\n    // Press 0+2: light 0=on XOR on=off, light 1=on, light 2=on → [F,T,T] wrong\n    // Press 1+2: light 0=on, light 1=on, light 2=on XOR on=off → [T,T,F] wrong\n    // Press 0 only: [T,T,F] wrong\n    // Press 1 only: [F,T,T] wrong\n    // Press 2 only: [T,F,T] wrong\n    // No solution\n    const machine: Machine = {\n      target: [true, true, true],\n      buttons: [[0, 1], [1, 2], [0, 2]],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('returns all zeros when target is all zeros', () => {\n    expect(solveCounter([0, 0, 0], [[0], [1], [2]], 5)).toEqual([0, 0, 0]);\n  });\n\n  it('solves simple identity case mod 5', () => {\n    expect(solveCounter([3, 0, 2], [[0], [1], [2]], 5)).toEqual([3, 0, 2]);\n  });\n\n  it('returns null when no solution exists', () => {\n    // Two buttons both affect counter 0. Pressing b0 x times and b1 y times → (x+y) mod 3.\n    // Target counter 0 = 1, counter 1 = 1. But there's no counter 1 button.\n    expect(solveCounter([1, 1], [[0], [0]], 3)).toBeNull();\n  });\n\n  it('finds minimum total presses', () => {\n    // target = [2], buttons = [[0], [0]], mod 3\n    // b0 + b1 ≡ 2 (mod 3). Solutions: (0,2), (1,1), (2,0). Min sum = 2. Lex smallest: (0,2)\n    expect(solveCounter([2], [[0], [0]], 3)).toEqual([0, 2]);\n  });\n\n  it('handles modulus 2 (equivalent to toggle)', () => {\n    // target = [1, 0], button 0 affects counter 0 and 1, button 1 affects counter 1\n    // b0 ≡ 1 mod 2 (from counter 0). b0 + b1 ≡ 0 mod 2 → b1 = 1.\n    // Solution: [1, 1]\n    expect(solveCounter([1, 0], [[0, 1], [1]], 2)).toEqual([1, 1]);\n  });\n\n  it('handles larger modulus', () => {\n    // Single counter, single button. Target = 50, mod 97.\n    expect(solveCounter([50], [[0]], 97)).toEqual([50]);\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: All tests pass\n\n**Step 3: Commit**\n\n```bash\ngit add src/index.test.ts\ngit commit -m \"test: add unit tests for solveToggle and solveCounter\"\n```\n\n---\n\n### Task 5: Performance Test\n\n**Files:**\n- Modify: `src/index.test.ts`\n\n**Dependencies:** Task 4\n\n**Step 1: Add performance test for 40×40 system**\n\n```typescript\ndescribe('performance', () => {\n  it('solves 40x40 toggle system within 5 seconds', () => {\n    const n = 40;\n    // Create a system where button i toggles lights i and (i+1)%n\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i, (i + 1) % n]);\n    }\n    const target = new Array(n).fill(true);\n\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    // Verify correctness if solution exists\n    if (result !== null) {\n      const state = new Array(n).fill(false);\n      for (const btn of result) {\n        for (const light of buttons[btn]) {\n          state[light] = !state[light];\n        }\n      }\n      expect(state).toEqual(target);\n    }\n  });\n\n  it('solves 40x40 counter system mod 97 within 5 seconds', () => {\n    const n = 40;\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i, (i + 1) % n]);\n    }\n    const lights = Array.from({ length: n }, (_, i) => (i * 7) % 97);\n\n    const start = Date.now();\n    const result = solveCounter(lights, buttons, 97);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    if (result !== null) {\n      const state = new Array(n).fill(0);\n      for (let j = 0; j < n; j++) {\n        for (const counter of buttons[j]) {\n          state[counter] = (state[counter] + result[j]) % 97;\n        }\n      }\n      expect(state).toEqual(lights);\n    }\n  });\n});\n```\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: All pass, performance within budget\n\n**Step 3: Run build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: Both pass\n\n**Step 4: Commit**\n\n```bash\ngit add src/index.test.ts\ngit commit -m \"test: add performance tests for 40x40 systems\"\n```\n\n---\n\n### Task 6: Final Verification\n\n**Dependencies:** Task 5\n\n**Step 1: Run full verification suite**\n\nRun: `npm test && npm run build && npm run lint`\nExpected: All pass\n\n**Step 2: Review diff**\n\nRun: `git diff HEAD~5` (review all changes)\nCheck for: dead code, debug artifacts, incomplete implementations, missing edge cases.\n","structuredPatch":[],"originalFile":null}}
