+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  // ── CRUD ──
+
+  describe('create', () => {
+    it('creates and retrieves a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('throws if document already exists', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.create('doc1', { a: 2 })).toThrow();
+    });
+
+    it('deep clones content on create', () => {
+      const obj = { nested: { val: 1 } };
+      store.create('doc1', obj);
+      obj.nested.val = 999;
+      expect(store.get('doc1')).toEqual({ nested: { val: 1 } });
+    });
+  });
+
+  describe('get', () => {
+    it('throws for non-existent document', () => {
+      expect(() => store.get('nope')).toThrow();
+    });
+
+    it('returns deep clone', () => {
+      store.create('doc1', { list: [1, 2, 3] });
+      const a = store.get('doc1') as any;
+      a.list.push(4);
+      expect(store.get('doc1')).toEqual({ list: [1, 2, 3] });
+    });
+  });
+
+  describe('update', () => {
+    it('updates document content', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 2, b: 3 });
+    });
+
+    it('throws for non-existent document', () => {
+      expect(() => store.update('nope', {})).toThrow();
+    });
+
+    it('throws for deleted document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.update('doc1', { a: 2 })).toThrow();
+    });
+  });
+
+  describe('delete', () => {
+    it('deletes a document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('throws for non-existent document', () => {
+      expect(() => store.delete('nope')).toThrow();
+    });
+
+    it('throws when deleting already deleted document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+  });
+
+  // ── Version History ──
+
+  describe('getHistory', () => {
+    it('returns versions in chronological order', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ v: 1 });
+      expect(history[1].content).toEqual({ v: 2 });
+      expect(history[2].content).toEqual({ v: 3 });
+    });
+
+    it('each version has unique id and timestamp', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+      expect(typeof history[0].timestamp).toBe('number');
+    });
+
+    it('throws for unknown document', () => {
+      expect(() => store.getHistory('nope')).toThrow();
+    });
+  });
+
+  describe('getVersion', () => {
+    it('retrieves a specific version', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });
+    });
+
+    it('throws for unknown version', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.getVersion('doc1', 'bad-id')).toThrow();
+    });
+
+    it('throws for unknown document', () => {
+      expect(() => store.getVersion('nope', 'v1')).toThrow();
+    });
+  });
+
+  // ── Branching ──
+
+  describe('branching', () => {
+    it('default branch is main', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('creates and switches branches', () => {
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      expect(store.getBranch()).toBe('dev');
+    });
+
+    it('lists branches', () => {
+      store.createBranch('dev');
+      store.createBranch('feature');
+      expect(store.listBranches()).toEqual(expect.arrayContaining(['main', 'dev', 'feature']));
+    });
+
+    it('throws when creating duplicate branch', () => {
+      store.createBranch('dev');
+      expect(() => store.createBranch('dev')).toThrow();
+    });
+
+    it('throws when switching to non-existent branch', () => {
+      expect(() => store.switchBranch('nope')).toThrow();
+    });
+
+    it('branch from specific branch', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.update('doc1', { a: 2 });
+      store.createBranch('feature', 'dev');
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+
+    it('isolates changes between branches', () => {
+      store.create('doc1', { val: 'main' });
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.update('doc1', { val: 'dev' });
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ val: 'main' });
+    });
+
+    it('new branch has snapshot of source', () => {
+      store.create('doc1', { x: 1 });
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      expect(store.get('doc1')).toEqual({ x: 1 });
+    });
+
+    it('document created on branch not visible on main', () => {
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.create('doc2', { new: true });
+      store.switchBranch('main');
+      expect(() => store.get('doc2')).toThrow();
+    });
+  });
+
+  // ── Merging ──
+
+  describe('merge', () => {
+    it('merges changes from source into current branch', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.update('doc1', { a: 1, b: 20 });
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc1')).toEqual({ a: 1, b: 20 });
+    });
+
+    it('merges non-overlapping changes from both sides', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('dev');
+
+      store.update('doc1', { a: 10, b: 2, c: 3 }); // main changes a
+
+      store.switchBranch('dev');
+      store.update('doc1', { a: 1, b: 2, c: 30 }); // dev changes c
+
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc1')).toEqual({ a: 10, b: 2, c: 30 });
+    });
+
+    it('detects conflicts when both sides change same field differently', () => {
+      store.create('doc1', { x: 'base' });
+      store.createBranch('dev');
+      store.update('doc1', { x: 'main-change' });
+      store.switchBranch('dev');
+      store.update('doc1', { x: 'dev-change' });
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0]).toMatchObject({
+        documentId: 'doc1',
+        path: 'x',
+        base: 'base',
+        ours: 'main-change',
+        theirs: 'dev-change',
+      });
+      // Current branch should be unchanged when there are conflicts
+      expect(store.get('doc1')).toEqual({ x: 'main-change' });
+    });
+
+    it('no conflict when both sides change same field to same value', () => {
+      store.create('doc1', { x: 'old' });
+      store.createBranch('dev');
+      store.update('doc1', { x: 'same' });
+      store.switchBranch('dev');
+      store.update('doc1', { x: 'same' });
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc1')).toEqual({ x: 'same' });
+    });
+
+    it('handles new document on source branch', () => {
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.create('newDoc', { fresh: true });
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(store.get('newDoc')).toEqual({ fresh: true });
+    });
+
+    it('handles new document on target branch (no conflict)', () => {
+      store.createBranch('dev');
+      store.create('mainDoc', { from: 'main' });
+      store.switchBranch('dev');
+      store.create('devDoc', { from: 'dev' });
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(store.get('mainDoc')).toEqual({ from: 'main' });
+      expect(store.get('devDoc')).toEqual({ from: 'dev' });
+    });
+
+    it('handles delete on source branch', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.delete('doc1');
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('handles deep nested merge', () => {
+      store.create('doc1', { a: { b: { c: 1, d: 2 }, e: 3 } });
+      store.createBranch('dev');
+      store.update('doc1', { a: { b: { c: 10, d: 2 }, e: 3 } }); // main changes a.b.c
+      store.switchBranch('dev');
+      store.update('doc1', { a: { b: { c: 1, d: 20 }, e: 3 } }); // dev changes a.b.d
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: { b: { c: 10, d: 20 }, e: 3 } });
+    });
+
+    it('deep nested conflict', () => {
+      store.create('doc1', { a: { b: { c: 'base' } } });
+      store.createBranch('dev');
+      store.update('doc1', { a: { b: { c: 'main' } } });
+      store.switchBranch('dev');
+      store.update('doc1', { a: { b: { c: 'dev' } } });
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts[0].path).toBe('a.b.c');
+    });
+
+    it('merged field contains result even with conflicts (favoring ours)', () => {
+      store.create('doc1', { x: 'base', y: 1 });
+      store.createBranch('dev');
+      store.update('doc1', { x: 'main', y: 1 });
+      store.switchBranch('dev');
+      store.update('doc1', { x: 'dev', y: 1 });
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(false);
+      expect(result.merged['doc1']).toEqual({ x: 'main', y: 1 });
+    });
+
+    it('handles multiple documents independently', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { b: 2 });
+      store.createBranch('dev');
+      store.update('doc1', { a: 10 }); // main changes doc1
+      store.switchBranch('dev');
+      store.update('doc2', { b: 20 }); // dev changes doc2
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 10 });
+      expect(store.get('doc2')).toEqual({ b: 20 });
+    });
+
+    it('throws when merging non-existent branch', () => {
+      expect(() => store.merge('nope')).toThrow();
+    });
+
+    it('fast-forward merge with no changes', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('dev');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('field added on one side only', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.update('doc1', { a: 1, newField: 'hello' });
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, newField: 'hello' });
+    });
+
+    it('field removed on one side only', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.update('doc1', { a: 1 }); // remove b
+      store.switchBranch('main');
+      const result = store.merge('dev');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1 });
+    });
+  });
+});
