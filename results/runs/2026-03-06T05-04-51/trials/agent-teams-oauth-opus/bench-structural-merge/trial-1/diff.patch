+++ b/src/types.ts
@@ -0,0 +1,31 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: any;
+  ours: any;
+  theirs: any;
+}
+
+export interface DocumentState {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+export interface BranchData {
+  documents: Map<string, DocumentState>;
+  /** Snapshot of documents at the time each child branch forked off */
+  forkPoints: Map<string, Map<string, DocumentState>>;
+}
