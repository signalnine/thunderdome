+++ b/src/index.ts
@@ -0,0 +1,317 @@
+import type { Version, MergeResult, Conflict, DocumentState, BranchData } from './types.js';
+import { deepClone, threeWayMerge } from './merge.js';
+
+export type { Version, MergeResult, Conflict };
+
+let versionCounter = 0;
+function nextVersionId(): string {
+  return `v${++versionCounter}`;
+}
+
+function cloneDocState(state: DocumentState): DocumentState {
+  return {
+    content: deepClone(state.content),
+    versions: state.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: state.deleted,
+  };
+}
+
+function cloneDocMap(docs: Map<string, DocumentState>): Map<string, DocumentState> {
+  const result = new Map<string, DocumentState>();
+  for (const [id, state] of docs) {
+    result.set(id, cloneDocState(state));
+  }
+  return result;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      forkPoints: new Map(),
+    });
+  }
+
+  // ── Document CRUD ──
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: nextVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version: Version = {
+      id: nextVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    doc.deleted = true;
+  }
+
+  // ── Version History ──
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ── Branching ──
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+    const snapshot = cloneDocMap(source.documents);
+    const newBranch: BranchData = {
+      documents: cloneDocMap(source.documents),
+      forkPoints: new Map(),
+    };
+    this.branches.set(name, newBranch);
+
+    // Record the fork point on BOTH branches so either can be merged into the other
+    source.forkPoints.set(name, snapshot);
+    newBranch.forkPoints.set(sourceName, cloneDocMap(source.documents));
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ── Merging ──
+
+  merge(sourceBranch: string): MergeResult {
+    const targetName = this.currentBranch;
+    const target = this.getCurrentBranchData();
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+
+    // Get common ancestor (fork point)
+    const baseSnapshot = target.forkPoints.get(sourceBranch);
+    const base: Map<string, DocumentState> = baseSnapshot ?? new Map();
+
+    const allDocIds = new Set([
+      ...base.keys(),
+      ...target.documents.keys(),
+      ...source.documents.keys(),
+    ]);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseDoc = base.get(docId);
+      const oursDoc = target.documents.get(docId);
+      const theirsDoc = source.documents.get(docId);
+
+      const baseExists = baseDoc && !baseDoc.deleted;
+      const oursExists = oursDoc && !oursDoc.deleted;
+      const theirsExists = theirsDoc && !theirsDoc.deleted;
+
+      const baseContent = baseExists ? baseDoc.content as Record<string, unknown> : undefined;
+      const oursContent = oursExists ? oursDoc.content as Record<string, unknown> : undefined;
+      const theirsContent = theirsExists ? theirsDoc.content as Record<string, unknown> : undefined;
+
+      // Determine what changed
+      const oursChanged = !docStatesEqual(baseDoc, oursDoc);
+      const theirsChanged = !docStatesEqual(baseDoc, theirsDoc);
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes on either side - keep as is
+        if (oursExists && oursContent) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        // Only source branch changed this doc
+        if (theirsExists && theirsContent) {
+          merged[docId] = deepClone(theirsContent) as object;
+        }
+        // If theirs deleted it, don't include in merged
+        continue;
+      }
+
+      if (oursChanged && !theirsChanged) {
+        // Only target branch changed this doc
+        if (oursExists && oursContent) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+        continue;
+      }
+
+      // Both changed - need structural merge
+      if (oursExists && theirsExists && oursContent && theirsContent) {
+        const baseObj = (baseContent ?? {}) as Record<string, unknown>;
+        const result = threeWayMerge(baseObj, oursContent, theirsContent, docId);
+        merged[docId] = result.merged as object;
+        conflicts.push(...result.conflicts);
+      } else if (docStatesEqual(oursDoc, theirsDoc)) {
+        // Both made the same change (e.g. both deleted)
+        if (oursExists && oursContent) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+      } else {
+        // One deleted, other modified - conflict
+        conflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent ? deepClone(baseContent) : undefined,
+          ours: oursContent ? deepClone(oursContent) : undefined,
+          theirs: theirsContent ? deepClone(theirsContent) : undefined,
+        });
+        // Favor ours
+        if (oursExists && oursContent) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+      }
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existingDoc = target.documents.get(docId);
+          if (existingDoc && !existingDoc.deleted) {
+            // Check if content actually changed
+            const mergedContent = merged[docId];
+            existingDoc.content = deepClone(mergedContent);
+            const version: Version = {
+              id: nextVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(mergedContent),
+            };
+            existingDoc.versions.push(version);
+          } else {
+            // Document is new to this branch (came from source)
+            const version: Version = {
+              id: nextVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(merged[docId]),
+            };
+            target.documents.set(docId, {
+              content: deepClone(merged[docId]),
+              versions: existingDoc ? [...existingDoc.versions, version] : [version],
+              deleted: false,
+            });
+          }
+        } else {
+          // Document was deleted in the merge
+          const existingDoc = target.documents.get(docId);
+          if (existingDoc && !existingDoc.deleted) {
+            existingDoc.deleted = true;
+          }
+        }
+      }
+
+      // Update fork point so subsequent merges use the new state as base
+      target.forkPoints.set(sourceBranch, cloneDocMap(target.documents));
+      const sourceBranchData = this.branches.get(sourceBranch)!;
+      sourceBranchData.forkPoints.set(targetName, cloneDocMap(target.documents));
+    }
+
+    return { merged, conflicts, applied };
+  }
+
+  // ── Private helpers ──
+
+  private getCurrentBranchData(): BranchData {
+    return this.branches.get(this.currentBranch)!;
+  }
+}
+
+function docStatesEqual(
+  a: DocumentState | undefined,
+  b: DocumentState | undefined,
+): boolean {
+  if (!a && !b) return true;
+  if (!a || !b) return false;
+  if (a.deleted && b.deleted) return true;
+  if (a.deleted !== b.deleted) return false;
+  return JSON.stringify(a.content) === JSON.stringify(b.content);
+}
diff --git a/src/merge.ts b/src/merge.ts
new file mode 100644
index 0000000..b3bf3bb
--- /dev/null
+++ b/src/merge.ts
@@ -0,0 +1,112 @@
+import type { Conflict } from './types.js';
+
+function isPlainObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (Array.isArray(a)) {
+    if (!Array.isArray(b) || a.length !== b.length) return false;
+    return a.every((v, i) => deepEqual(v, b[i]));
+  }
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    return keysA.every(k => k in b && deepEqual(a[k], b[k]));
+  }
+  return false;
+}
+
+export function deepClone<T>(val: T): T {
+  if (val === null || typeof val !== 'object') return val;
+  if (Array.isArray(val)) return val.map(v => deepClone(v)) as T;
+  const result: Record<string, unknown> = {};
+  for (const key of Object.keys(val as Record<string, unknown>)) {
+    result[key] = deepClone((val as Record<string, unknown>)[key]);
+  }
+  return result as T;
+}
+
+/**
+ * Three-way structural merge of JSON objects.
+ * base = common ancestor, ours = current branch, theirs = source branch.
+ * Returns the merged object and any conflicts found.
+ */
+export function threeWayMerge(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  documentId: string,
+): { merged: Record<string, unknown>; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+  const merged = mergeObjects(base, ours, theirs, '', documentId, conflicts);
+  return { merged, conflicts };
+}
+
+function mergeObjects(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  prefix: string,
+  documentId: string,
+  conflicts: Conflict[],
+): Record<string, unknown> {
+  const result: Record<string, unknown> = {};
+  const allKeys = new Set([...Object.keys(base), ...Object.keys(ours), ...Object.keys(theirs)]);
+
+  for (const key of allKeys) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    const bVal = base[key];
+    const oVal = ours[key];
+    const tVal = theirs[key];
+
+    const oChanged = !deepEqual(bVal, oVal);
+    const tChanged = !deepEqual(bVal, tVal);
+
+    if (!oChanged && !tChanged) {
+      // Neither side changed
+      if (key in base) result[key] = deepClone(bVal);
+      else if (key in ours) result[key] = deepClone(oVal);
+      else result[key] = deepClone(tVal);
+    } else if (oChanged && !tChanged) {
+      // Only ours changed
+      if (key in ours) {
+        result[key] = deepClone(oVal);
+      }
+      // If key was deleted from ours (not in ours), don't include it
+    } else if (!oChanged && tChanged) {
+      // Only theirs changed
+      if (key in theirs) {
+        result[key] = deepClone(tVal);
+      }
+      // If key was deleted from theirs, don't include it
+    } else {
+      // Both changed
+      if (deepEqual(oVal, tVal)) {
+        // Both changed to the same value
+        if (key in ours) {
+          result[key] = deepClone(oVal);
+        }
+      } else if (isPlainObject(bVal) && isPlainObject(oVal) && isPlainObject(tVal)) {
+        // Both changed an object - recurse
+        result[key] = mergeObjects(bVal, oVal, tVal, path, documentId, conflicts);
+      } else {
+        // Conflict - favor ours for the merged result
+        conflicts.push({
+          documentId,
+          path,
+          base: deepClone(bVal),
+          ours: deepClone(oVal),
+          theirs: deepClone(tVal),
+        });
+        result[key] = deepClone(oVal);
+      }
+    }
+  }
+
+  return result;
+}
