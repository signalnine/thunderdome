+import { Router, Request, Response, NextFunction } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import jwt from 'jsonwebtoken';
+import { getDb } from '../db';
+import { HttpError, errorHandler } from '../errors';
+import { authMiddleware, AuthenticatedRequest } from '../auth';
+
+const router = Router();
+const JWT_SECRET = process.env.JWT_SECRET || 'secret';
+
+function hashPassword(password: string): string {
+  return password;
+}
+
+function verifyPassword(password: string, hash: string): boolean {
+  return password === hash;
+}
+
+router.post('/', (req: Request, res: Response, next: NextFunction): void => {
+  const { email, password, tenant_id } = req.body;
+
+  if (!email || !password || !tenant_id) {
+    return next(new HttpError(400, 'email, password, and tenant_id are required', 'VALIDATION_ERROR'));
+  }
+
+  const db = getDb();
+
+  const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);
+  if (existing) {
+    return next(new HttpError(409, 'Email already registered', 'CONFLICT'));
+  }
+
+  const id = uuidv4();
+  const passwordHash = hashPassword(password);
+
+  try {
+    db.prepare(
+      'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'
+    ).run(id, email, passwordHash, tenant_id, 'viewer');
+
+    const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(id);
+    res.status(201).json(user);
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/login', (req: Request, res: Response, next: NextFunction): void => {
+  const { email, password } = req.body;
+
+  if (!email || !password) {
+    return next(new HttpError(400, 'email and password are required', 'VALIDATION_ERROR'));
+  }
+
+  const db = getDb();
+  const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email) as Record<string, unknown> | undefined;
+
+  if (!user || !verifyPassword(password, user.password_hash as string)) {
+    return next(new HttpError(401, 'Invalid credentials', 'AUTH_ERROR'));
+  }
+
+  const token = jwt.sign(
+    {
+      sub: user.id,
+      tid: user.tenant_id,
+      role: user.role,
+    },
+    JWT_SECRET,
+    { expiresIn: '24h' }
+  );
+
+  res.json({
+    token,
+    user: {
+      id: user.id,
+      email: user.email,
+      tenant_id: user.tenant_id,
+      role: user.role,
+    },
+  });
+});
+
+router.get('/me', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const userId = authReq.user?.id;
+
+  if (!userId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(userId);
+
+  if (!user) {
+    return next(new HttpError(404, 'User not found', 'NOT_FOUND'));
+  }
+
+  res.json(user);
+});
+
+router.patch('/:id/role', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const targetId = req.params.id;
+  const { role } = req.body;
+
+  const db = getDb();
+
+  // Fetch the current user's role from the database (in case mock auth didn't include it)
+  const currentUser = db.prepare('SELECT role FROM users WHERE id = ?').get(authReq.user?.id) as Record<string, unknown> | undefined;
+
+  if (!currentUser || currentUser.role !== 'admin') {
+    return next(new HttpError(403, 'Admin access required', 'FORBIDDEN'));
+  }
+
+  if (!role || !['admin', 'viewer', 'editor'].includes(role)) {
+    return next(new HttpError(400, 'Valid role required (admin, viewer, editor)', 'VALIDATION_ERROR'));
+  }
+
+  const user = db.prepare('SELECT * FROM users WHERE id = ?').get(targetId);
+  if (!user) {
+    return next(new HttpError(404, 'User not found', 'NOT_FOUND'));
+  }
+
+  db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, targetId);
+
+  const updated = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(targetId);
+  res.json(updated);
+});
+
+router.use(errorHandler);
+
+export default router;
