@@ -0,0 +1,84 @@
+import { Router, Request, Response, NextFunction } from 'express';
+import { getDb } from '../db';
+import { HttpError, errorHandler } from '../errors';
+import { authMiddleware, AuthenticatedRequest } from '../auth';
+
+const router = Router();
+
+router.get('/events', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const format = req.query.format as string;
+  const tenantId = authReq.user?.tenantId;
+
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  if (!format || !['json', 'csv'].includes(format)) {
+    return next(new HttpError(400, 'Invalid format. Use json or csv', 'VALIDATION_ERROR'));
+  }
+
+  const db = getDb();
+  const events = db.prepare('SELECT * FROM events WHERE tenant_id = ?').all(tenantId) as Record<string, unknown>[];
+
+  if (format === 'json') {
+    const parsedEvents = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties as string),
+    }));
+    res.json(parsedEvents);
+  } else {
+    const headers = ['id', 'tenant_id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+    const csvRows = [headers.join(',')];
+
+    for (const event of events) {
+      const row = headers.map((h) => {
+        const value = event[h];
+        if (value === null || value === undefined) return '';
+        const str = String(value);
+        if (str.includes(',') || str.includes('"') || str.includes('\n')) {
+          return `"${str.replace(/"/g, '""')}"`;
+        }
+        return str;
+      });
+      csvRows.push(row.join(','));
+    }
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.send(csvRows.join('\n'));
+  }
+});
+
+router.get('/dashboard/:id', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const dashboardId = req.params.id;
+  const tenantId = authReq.user?.tenantId;
+
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(dashboardId, tenantId);
+
+  if (!dashboard) {
+    return next(new HttpError(404, 'Dashboard not found', 'NOT_FOUND'));
+  }
+
+  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboardId) as Record<string, unknown>[];
+
+  res.json({
+    dashboard: {
+      ...dashboard,
+      config: JSON.parse((dashboard as Record<string, unknown>).config as string),
+    },
+    widgets: widgets.map((w) => ({
+      ...w,
+      config: JSON.parse(w.config as string),
+    })),
+  });
+});
+
+router.use(errorHandler);
+
+export default router;
