+
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(dashboardId, tenantId) as Record<string, unknown> | undefined;
+
+  if (!dashboard) {
+    return next(new HttpError(404, 'Dashboard not found', 'NOT_FOUND'));
+  }
+
+  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboardId) as Record<string, unknown>[];
+
+  res.json({
+    ...dashboard,
+    widgets: widgets.map((w) => ({
+      ...w,
+      config: JSON.parse(w.config as string),
+    })),
+  });
+});
+
+router.patch('/:id', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const dashboardId = req.params.id;
+  const { name, config } = req.body;
+  const tenantId = authReq.user?.tenantId;
+
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(dashboardId, tenantId);
+
+  if (!existing) {
+    return next(new HttpError(404, 'Dashboard not found', 'NOT_FOUND'));
+  }
+
+  const updates: string[] = [];
+  const values: (string | null)[] = [];
+
+  if (name !== undefined) {
+    updates.push('name = ?');
+    values.push(name);
+  }
+  if (config !== undefined) {
+    updates.push('config = ?');
+    values.push(JSON.stringify(config));
+  }
+
+  if (updates.length > 0) {
+    updates.push("updated_at = datetime('now')");
+    values.push(dashboardId);
+    db.prepare(`UPDATE dashboards SET ${updates.join(', ')} WHERE id = ?`).run(...values);
+  }
+
+  const updated = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(dashboardId);
+  res.json(updated);
