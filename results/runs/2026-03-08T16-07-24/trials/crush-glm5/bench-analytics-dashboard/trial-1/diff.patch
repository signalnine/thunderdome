+router.post('/count', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const { event_name, start, end } = req.body;
+
+  if (!event_name) {
+    return next(new HttpError(400, 'event_name is required', 'VALIDATION_ERROR'));
+  }
+
+  const tenantId = authReq.user?.tenantId;
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?';
+  const params: (string | number)[] = [tenantId, event_name];
+
+  if (start) {
+    query += ' AND timestamp >= ?';
+    params.push(start);
+  }
+  if (end) {
+    query += ' AND timestamp <= ?';
+    params.push(end);
+  }
+
+  const result = db.prepare(query).get(...params) as Record<string, number>;
+  res.json({ count: result.count });
+});
+
+router.post('/timeseries', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const { event_name, bucket, start, end } = req.body;
+
+  if (!event_name) {
+    return next(new HttpError(400, 'event_name is required', 'VALIDATION_ERROR'));
+  }
+
+  const tenantId = authReq.user?.tenantId;
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const bucketFormat = bucket === 'hour' ? '%Y-%m-%d %H:00:00' : '%Y-%m-%d';
+
+  let query = `
+    SELECT strftime('${bucketFormat}', timestamp) as bucket, COUNT(*) as count
+    FROM events
+    WHERE tenant_id = ? AND name = ?
+  `;
+  const params: (string | number)[] = [tenantId, event_name];
+
+  if (start) {
+    query += ' AND timestamp >= ?';
+    params.push(start);
+  }
+  if (end) {
+    query += ' AND timestamp <= ?';
+    params.push(end);
+  }
+
+  query += " GROUP BY strftime('" + bucketFormat + "', timestamp) ORDER BY bucket";
+
+  const results = db.prepare(query).all(...params) as Array<{ bucket: string; count: number }>;
+  res.json({ data: results });
+});
+
+router.post('/breakdown', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const { event_name, property_key, start, end } = req.body;
+
+  if (!event_name || !property_key) {
+    return next(new HttpError(400, 'event_name and property_key are required', 'VALIDATION_ERROR'));
+  }
+
+  const tenantId = authReq.user?.tenantId;
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+
+  let query = `
+    SELECT properties, COUNT(*) as count
+    FROM events
+    WHERE tenant_id = ? AND name = ?
+  `;
+  const params: (string | number)[] = [tenantId, event_name];
+
+  if (start) {
+    query += ' AND timestamp >= ?';
+    params.push(start);
+  }
+  if (end) {
+    query += ' AND timestamp <= ?';
+    params.push(end);
+  }
+
+  query += ' GROUP BY properties';
+
+  const results = db.prepare(query).all(...params) as Array<{ properties: string; count: number }>;
+
+  const breakdown: Array<{ property_value: string; count: number }> = [];
+  const aggregated: Record<string, number> = {};
+
+  for (const row of results) {
+    const props = JSON.parse(row.properties) as Record<string, unknown>;
+    const value = props[property_key];
+    const stringValue = value !== undefined ? String(value) : '(none)';
+
+    if (aggregated[stringValue]) {
+      aggregated[stringValue] += row.count;
+    } else {
+      aggregated[stringValue] = row.count;
+    }
+  }
+
+  for (const [property_value, count] of Object.entries(aggregated)) {
+    breakdown.push({ property_value, count });
+  }
+
+  breakdown.sort((a, b) => b.count - a.count);
+  res.json({ data: breakdown });
+});
+
+router.post('/funnel', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const { steps, start, end } = req.body;
+
+  if (!steps || !Array.isArray(steps) || steps.length === 0) {
+    return next(new HttpError(400, 'steps array is required', 'VALIDATION_ERROR'));
+  }
+
+  const tenantId = authReq.user?.tenantId;
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const stepResults: Array<{ step: string; count: number }> = [];
+
+  for (const step of steps) {
+    let query = `
+      SELECT COUNT(DISTINCT session_id) as count
+      FROM events
+      WHERE tenant_id = ? AND name = ?
+    `;
+    const params: (string | number)[] = [tenantId, step];
+
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    const result = db.prepare(query).get(...params) as Record<string, number>;
+    stepResults.push({ step, count: result.count });
+  }
+
+  res.json({ steps: stepResults });
+});
+
+router.use(errorHandler);
+
+export default router;
