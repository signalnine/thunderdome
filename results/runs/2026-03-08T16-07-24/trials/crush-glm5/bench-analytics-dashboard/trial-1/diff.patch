+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id);
+    res.status(201).json(dashboard);
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.get('/', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const tenantId = authReq.user?.tenantId;
+
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(tenantId);
