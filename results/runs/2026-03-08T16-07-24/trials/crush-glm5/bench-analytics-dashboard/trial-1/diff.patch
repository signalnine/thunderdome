+
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(dashboardId, tenantId);
+
+  if (!existing) {
+    return next(new HttpError(404, 'Dashboard not found', 'NOT_FOUND'));
+  }
+
+  db.prepare('DELETE FROM widgets WHERE dashboard_id = ?').run(dashboardId);
+  db.prepare('DELETE FROM dashboards WHERE id = ?').run(dashboardId);
+
+  res.status(204).send();
+});
+
+router.post('/:id/widgets', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const dashboardId = req.params.id;
+  const { type, config, position_x, position_y, width, height } = req.body;
+  const tenantId = authReq.user?.tenantId;
+
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+    return next(new HttpError(400, 'Valid widget type required', 'VALIDATION_ERROR'));
+  }
+
+  const db = getDb();
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(dashboardId, tenantId);
+
+  if (!dashboard) {
+    return next(new HttpError(404, 'Dashboard not found', 'NOT_FOUND'));
+  }
+
+  const id = uuidv4();
+  const widgetConfig = JSON.stringify(config || {});
+
+  try {
+    db.prepare(
+      'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, dashboardId, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);
+
+    const widget = db.prepare('SELECT * FROM widgets WHERE id = ?').get(id);
+    res.status(201).json(widget);
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.delete('/:dashboardId/widgets/:widgetId', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const { dashboardId, widgetId } = req.params;
+  const tenantId = authReq.user?.tenantId;
+
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(dashboardId, tenantId);
+
+  if (!dashboard) {
+    return next(new HttpError(404, 'Dashboard not found', 'NOT_FOUND'));
+  }
+
+  const widget = db.prepare('SELECT * FROM widgets WHERE id = ? AND dashboard_id = ?').get(widgetId, dashboardId);
+
+  if (!widget) {
+    return next(new HttpError(404, 'Widget not found', 'NOT_FOUND'));
+  }
+
+  db.prepare('DELETE FROM widgets WHERE id = ?').run(widgetId);
+  res.status(204).send();
