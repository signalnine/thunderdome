+import { Router, Request, Response, NextFunction } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db';
+import { HttpError, errorHandler } from '../errors';
+import { authMiddleware, AuthenticatedRequest } from '../auth';
+
+const router = Router();
+
+router.post('/', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const { name, properties, timestamp, user_id, session_id } = req.body;
+
+  if (!name) {
+    return next(new HttpError(400, 'Event name is required', 'VALIDATION_ERROR'));
+  }
+
+  const tenantId = authReq.user?.tenantId;
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const eventTimestamp = timestamp || new Date().toISOString();
+  const eventProperties = JSON.stringify(properties || {});
+
+  try {
+    db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, user_id || null, session_id || null);
+
+    const event = db.prepare('SELECT * FROM events WHERE id = ?').get(id) as Record<string, unknown> | undefined;
+    const parsedEvent = {
+      ...event,
+      properties: JSON.parse(event?.properties as string),
+    };
+    res.status(201).json(parsedEvent);
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/batch', authMiddleware, (req: Request, res: Response, next: NextFunction): void => {
+  const authReq = req as AuthenticatedRequest;
+  const { events } = req.body;
+
+  if (!events || !Array.isArray(events) || events.length === 0) {
+    return next(new HttpError(400, 'Events array is required and must not be empty', 'VALIDATION_ERROR'));
+  }
+
+  const tenantId = authReq.user?.tenantId;
+  if (!tenantId) {
+    return next(new HttpError(401, 'Unauthorized', 'AUTH_ERROR'));
+  }
+
+  const db = getDb();
+  const insert = db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  );
+
+  const insertedEvents: Record<string, unknown>[] = [];
+
+  const insertMany = db.transaction(() => {
+    for (const event of events) {
+      if (!event.name) {
+        throw new HttpError(400, 'Each event must have a name', 'VALIDATION_ERROR');
+      }
+
+      const id = uuidv4();
+      const eventTimestamp = event.timestamp || new Date().toISOString();
+      const eventProperties = JSON.stringify(event.properties || {});
+
+      insert.run(
+        id,
+        tenantId,
+        event.name,
+        eventProperties,
+        eventTimestamp,
+        event.user_id || null,
+        event.session_id || null
+      );
+
+      insertedEvents.push({
+        id,
+        tenant_id: tenantId,
+        name: event.name,
+        properties: event.properties || {},
+        timestamp: eventTimestamp,
+        user_id: event.user_id || null,
+        session_id: event.session_id || null,
+      });
+    }
+  });
+
+  try {
+    insertMany();
+    res.status(201).json({
+      inserted: insertedEvents.length,
+      events: insertedEvents,
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.use(errorHandler);
+
+export default router;
