@@ -0,0 +1,60 @@
+import { Request, Response, NextFunction } from 'express';
+import jwt from 'jsonwebtoken';
+import { HttpError } from './errors';
+import { AuthUser } from './types';
+
+const JWT_SECRET = process.env.JWT_SECRET || 'secret';
+
+export interface AuthenticatedRequest extends Request {
+  user?: AuthUser;
+}
+
+export function authMiddleware(
+  req: Request,
+  _res: Response,
+  next: NextFunction
+): void {
+  const authReq = req as AuthenticatedRequest;
+
+  // If user is already set by a previous middleware (e.g., mock auth in tests), skip JWT verification
+  if (authReq.user) {
+    return next();
+  }
+
+  const authHeader = req.headers.authorization;
+
+  if (!authHeader) {
+    return next(new HttpError(401, 'Authorization header required', 'AUTH_ERROR'));
+  }
+
+  const parts = authHeader.split(' ');
+  if (parts.length !== 2 || parts[0] !== 'Bearer') {
+    return next(new HttpError(401, 'Invalid authorization format', 'AUTH_ERROR'));
+  }
+
+  const token = parts[1];
+
+  try {
+    const decoded = jwt.verify(token, JWT_SECRET) as jwt.JwtPayload;
+    authReq.user = {
+      id: decoded.sub as string,
+      tenantId: decoded.tid as string,
+      role: decoded.role as string,
+    };
+    next();
+  } catch {
+    return next(new HttpError(401, 'Invalid or expired token', 'AUTH_ERROR'));
+  }
+}
+
+export function requireAdmin(
+  req: Request,
+  _res: Response,
+  next: NextFunction
+): void {
+  const authReq = req as AuthenticatedRequest;
+  if (!authReq.user || authReq.user.role !== 'admin') {
+    return next(new HttpError(403, 'Admin access required', 'FORBIDDEN'));
+  }
+  next();
+}
