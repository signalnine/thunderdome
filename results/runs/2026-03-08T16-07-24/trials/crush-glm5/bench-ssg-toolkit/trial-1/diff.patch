@@ -0,0 +1,53 @@
+import { Plugin, BuildContext, ContentFile } from '../core/types.js';
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: async (ctx: BuildContext): Promise<void> => {
+        const tagMap = new Map<string, ContentFile[]>();
+
+        // Build tag index from files
+        for (const file of ctx.files) {
+          if (file.tags && file.tags.length > 0) {
+            for (const tag of file.tags) {
+              const normalizedTag = tag.toLowerCase();
+              if (!tagMap.has(normalizedTag)) {
+                tagMap.set(normalizedTag, []);
+              }
+              tagMap.get(normalizedTag)!.push(file);
+            }
+          }
+        }
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+
+        if (!tagMap) return;
+
+        // Generate tag listing pages
+        for (const [tag, files] of tagMap) {
+          const links = files.map(f => `<li><a href="/${f.slug}.html">${f.title}</a></li>`).join('\n');
+          const tagPage = `<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <title>${tag} | ${ctx.config.title}</title>
+</head>
+<body>
+  <h1>Tag: ${tag}</h1>
+  <ul>
+${links}
+  </ul>
+</body>
+</html>`;
+          ctx.output.set(`tags/${tag}.html`, tagPage);
+        }
+      },
+    },
+  };
+}
