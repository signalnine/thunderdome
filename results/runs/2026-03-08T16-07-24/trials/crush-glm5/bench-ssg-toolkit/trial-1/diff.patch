+import { Plugin, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const { config, files } = ctx;
+
+        // Sort files by date, newest first
+        const sortedFiles = [...files].sort((a, b) => {
+          if (!a.date && !b.date) return 0;
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return new Date(b.date).getTime() - new Date(a.date).getTime();
+        });
+
+        let itemsXml = '';
+        for (const file of sortedFiles) {
+          const link = `${config.baseUrl}/${file.slug}.html`;
+          const pubDate = file.date ? new Date(file.date).toUTCString() : '';
+
+          let categories = '';
+          if (file.tags && file.tags.length > 0) {
+            categories = file.tags.map(tag => `    <category>${tag}</category>`).join('\n');
+          }
+
+          itemsXml += `  <item>
+    <title>${escapeXml(file.title)}</title>
+    <link>${link}</link>
+${pubDate ? `    <pubDate>${pubDate}</pubDate>\n` : ''}${categories}    <description><![CDATA[${file.content}]]></description>
+  </item>
+`;
+        }
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+<channel>
+  <title>${escapeXml(config.title)}</title>
+  <link>${config.baseUrl}</link>
+  <description>${escapeXml(config.title)} feed</description>
+${itemsXml}</channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
