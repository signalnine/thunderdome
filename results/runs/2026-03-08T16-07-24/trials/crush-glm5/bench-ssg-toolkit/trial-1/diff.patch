@@ -0,0 +1,86 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import { marked } from 'marked';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        let content = file.content;
+
+        // Process admonition containers (:::note, :::warning, :::tip)
+        content = processAdmonitions(content);
+
+        // Process footnotes and convert markdown to HTML
+        const { html, footnotes } = await processMarkdownWithFootnotes(content);
+
+        // Append footnotes section if there are any
+        let finalContent = html;
+        if (footnotes.length > 0) {
+          finalContent += '\n<section class="footnotes">\n<ol>\n';
+          for (const fn of footnotes) {
+            finalContent += `<li id="fn-${fn.id}">${fn.text}</li>\n`;
+          }
+          finalContent += '</ol>\n</section>';
+        }
+
+        return {
+          ...file,
+          content: finalContent,
+        };
+      },
+    },
+  };
+}
+
+interface Footnote {
+  id: number;
+  text: string;
+}
+
+async function processMarkdownWithFootnotes(content: string): Promise<{ html: string; footnotes: Footnote[] }> {
+  const footnotes: Footnote[] = [];
+  const footnoteMap = new Map<string, number>();
+
+  // Extract footnote definitions [^id]: text
+  const footnoteDefRegex = /^\[\^(\w+)\]:\s*(.+)$/gm;
+  let match;
+  while ((match = footnoteDefRegex.exec(content)) !== null) {
+    const id = footnotes.length + 1;
+    footnoteMap.set(match[1], id);
+    footnotes.push({ id, text: match[2] });
+  }
+
+  // Remove footnote definitions from content
+  content = content.replace(footnoteDefRegex, '');
+
+  // Convert markdown to HTML using marked
+  let html = await marked(content);
+
+  // Replace footnote references [^id] with superscript links
+  html = html.replace(/\[\^(\w+)\]/g, (_, id) => {
+    const num = footnoteMap.get(id);
+    if (num !== undefined) {
+      return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+    }
+    return '';
+  });
+
+  return { html, footnotes };
+}
+
+function processAdmonitions(content: string): string {
+  // Process :::note, :::warning, :::tip containers
+  const admonitionTypes = ['note', 'warning', 'tip'];
+
+  for (const type of admonitionTypes) {
+    const regex = new RegExp(`:::${type}\\n([\\s\\S]*?)\\n:::`, 'g');
+    content = content.replace(regex, (_, innerContent) => {
+      return `<div class="admonition admonition-${type}">\n${innerContent}\n</div>`;
+    });
+  }
+
+  return content;
+}
