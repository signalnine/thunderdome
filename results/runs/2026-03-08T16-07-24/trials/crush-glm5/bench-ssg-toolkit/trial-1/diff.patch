+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, ctx: BuildContext): Promise<ContentFile> => {
+        let content = file.content;
+        const assets: string[] = [];
+
+        // Rewrite relative URLs in src attributes
+        content = content.replace(/src="\.\/([^"]+)"/g, (_, path) => {
+          assets.push(path);
+          return `src="/assets/${path}"`;
+        });
+
+        // Rewrite relative URLs in href attributes
+        content = content.replace(/href="\.\/([^"]+)"/g, (_, path) => {
+          assets.push(path);
+          return `href="/assets/${path}"`;
+        });
+
+        // Update asset manifest
+        if (assets.length > 0) {
+          const existingManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+          const existingAssets = existingManifest?.assets || [];
+          ctx.data.set('asset-manifest', {
+            assets: [...existingAssets, ...assets],
+          });
+        }
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
