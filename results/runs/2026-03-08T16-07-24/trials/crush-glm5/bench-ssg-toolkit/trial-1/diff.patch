+import { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string | null;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const { output, data } = ctx;
+
+        // Get asset manifest from asset-pipeline
+        const assetManifest = data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assetPaths = assetManifest?.assets || [];
+
+        // Build routes for assets
+        const assetRoutes = assetPaths.map(asset => ({
+          path: `/assets/${asset}`,
+          handler: 'asset',
+        }));
+
+        // Build routes for content pages
+        const contentRoutes: Array<{ path: string; handler: string }> = [];
+        for (const [path] of output) {
+          contentRoutes.push({
+            path: `/${path}`,
+            handler: 'static',
+          });
+        }
+
+        // Check for search index
+        const searchIndexPath = output.has('search-index.json') ? '/search-index.json' : null;
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes: [...assetRoutes, ...contentRoutes],
+          assetPaths,
+          searchIndexPath,
+        };
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
