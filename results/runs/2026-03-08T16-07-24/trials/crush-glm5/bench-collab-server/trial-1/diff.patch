@@ -0,0 +1,97 @@
+import type { Operation, InsertOperation, DeleteOperation } from './models.js';
+
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    return content.slice(0, op.position) + op.text + content.slice(op.position);
+  } else {
+    return content.slice(0, op.position) + content.slice(op.position + op.count);
+  }
+}
+
+export function transformOperation(op: Operation, against: Operation): Operation {
+  // Transform op based on a prior operation (against)
+  if (against.type === 'insert') {
+    // Prior insert shifts positions after the insertion point
+    if (op.type === 'insert') {
+      if (op.position >= against.position) {
+        return { ...op, position: op.position + against.text.length };
+      }
+    } else {
+      // op is delete
+      if (op.position >= against.position) {
+        return { ...op, position: op.position + against.text.length };
+      } else if (op.position + op.count > against.position) {
+        // Delete spans the insert point - adjust count and position
+        return { ...op, position: op.position, count: op.count + against.text.length };
+      }
+    }
+  } else {
+    // against is delete
+    const deleteEnd = against.position + against.count;
+    if (op.type === 'insert') {
+      if (op.position > against.position) {
+        if (op.position >= deleteEnd) {
+          return { ...op, position: op.position - against.count };
+        } else {
+          // Insert within deleted range - move to delete start
+          return { ...op, position: against.position };
+        }
+      }
+    } else {
+      // op is delete
+      if (op.position >= deleteEnd) {
+        // Both deletes are after the deleted range
+        return { ...op, position: op.position - against.count };
+      } else if (op.position + op.count <= against.position) {
+        // Both deletes are before the deleted range
+        return op;
+      } else {
+        // Deletes overlap - need to adjust
+        const opEnd = op.position + op.count;
+        let newPosition = op.position;
+        let newCount = op.count;
+        
+        if (op.position < against.position) {
+          // op starts before against
+          if (opEnd <= deleteEnd) {
+            // op ends within against
+            newCount = against.position - op.position;
+          } else {
+            // op extends beyond against
+            newCount = op.count - against.count;
+          }
+        } else {
+          // op starts within against
+          newPosition = against.position;
+          if (opEnd > deleteEnd) {
+            newCount = opEnd - deleteEnd;
+          } else {
+            newCount = 0;
+          }
+        }
+        return { ...op, position: newPosition, count: Math.max(0, newCount) };
+      }
+    }
+  }
+  return op;
+}
+
+export function validateOperation(op: Operation, contentLength: number): boolean {
+  if (op.type === 'insert') {
+    return op.position >= 0 && op.position <= contentLength && typeof op.text === 'string';
+  } else {
+    return (
+      op.position >= 0 &&
+      op.count >= 0 &&
+      op.position + op.count <= contentLength
+    );
+  }
+}
+
+export function isInsert(op: Operation): op is InsertOperation {
+  return op.type === 'insert';
+}
+
+export function isDelete(op: Operation): op is DeleteOperation {
+  return op.type === 'delete';
+}
