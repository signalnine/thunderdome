+++ b/src/ws.ts
@@ -0,0 +1,235 @@
+import WebSocket, { WebSocketServer } from 'ws';
+import type http from 'http';
+import type Database from 'better-sqlite3';
+import type { Operation, Document } from './models.js';
+import { applyOperation, transformOperation, validateOperation } from './ot.js';
+import { generateId } from './db.js';
+
+interface ClientInfo {
+  ws: WebSocket;
+  docId: string;
+  connectionId: string;
+}
+
+interface PendingOperation {
+  operation: Operation;
+  baseVersion: number;
+}
+
+export class CollabWebSocketServer {
+  private wss: WebSocketServer;
+  private db: Database.Database;
+  private rooms: Map<string, Set<WebSocket>> = new Map();
+  private clients: Map<WebSocket, ClientInfo> = new Map();
+  // Track pending operations per document for OT
+  private documentVersions: Map<string, number> = new Map();
+  private pendingOps: Map<string, PendingOperation[]> = new Map();
+
+  constructor(server: http.Server, db: Database.Database) {
+    this.db = db;
+    this.wss = new WebSocketServer({ server });
+    this.setupHandlers();
+  }
+
+  private setupHandlers(): void {
+    this.wss.on('connection', (ws: WebSocket, req) => {
+      const docId = this.extractDocId(req.url);
+      
+      if (!docId) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid document ID' }));
+        ws.close();
+        return;
+      }
+
+      const doc = this.db.prepare('SELECT * FROM documents WHERE id = ?').get(docId) as Document | undefined;
+      
+      if (!doc) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+        ws.close();
+        return;
+      }
+
+      // Register connection in database
+      const connectionId = generateId();
+      const now = new Date().toISOString();
+      this.db.prepare('INSERT INTO active_connections (id, document_id, connected_at) VALUES (?, ?, ?)').run(connectionId, docId, now);
+
+      // Track client
+      const clientInfo: ClientInfo = { ws, docId, connectionId };
+      this.clients.set(ws, clientInfo);
+
+      // Add to room
+      if (!this.rooms.has(docId)) {
+        this.rooms.set(docId, new Set());
+      }
+      this.rooms.get(docId)!.add(ws);
+
+      // Initialize document version tracking
+      if (!this.documentVersions.has(docId)) {
+        const latestVersion = this.getLatestVersion(docId);
+        this.documentVersions.set(docId, latestVersion);
+      }
+      if (!this.pendingOps.has(docId)) {
+        this.pendingOps.set(docId, []);
+      }
+
+      // Send current state
+      const currentVersion = this.documentVersions.get(docId)!;
+      ws.send(JSON.stringify({
+        type: 'sync',
+        content: doc.content,
+        version: currentVersion
+      }));
+
+      ws.on('message', (data) => {
+        this.handleMessage(ws, data);
+      });
+
+      ws.on('close', () => {
+        this.handleClose(ws);
+      });
+
+      ws.on('error', () => {
+        this.handleClose(ws);
+      });
+    });
+  }
+
+  private extractDocId(url: string | undefined): string | null {
+    if (!url) return null;
+    // Remove query string if present
+    const path = url.split('?')[0];
+    // Remove leading slash
+    return path.substring(1) || null;
+  }
+
+  private getLatestVersion(docId: string): number {
+    const result = this.db.prepare(`
+      SELECT MAX(version) as version FROM versions WHERE document_id = ?
+    `).get(docId) as { version: number | null };
+    return result.version ?? 0;
+  }
+
+  private handleMessage(ws: WebSocket, data: unknown): void {
+    const clientInfo = this.clients.get(ws);
+    if (!clientInfo) return;
+
+    let message: Record<string, unknown>;
+    try {
+      message = JSON.parse(data as string);
+    } catch {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+      return;
+    }
+
+    if (message.type !== 'operation') {
+      ws.send(JSON.stringify({ type: 'error', message: 'Unknown message type' }));
+      return;
+    }
+
+    const operation = message.operation as Operation;
+    const baseVersion = (message.version as number) ?? this.documentVersions.get(clientInfo.docId)!;
+
+    // Validate operation type
+    if (operation.type !== 'insert' && operation.type !== 'delete') {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation type' }));
+      return;
+    }
+
+    // Get current document state
+    const doc = this.db.prepare('SELECT * FROM documents WHERE id = ?').get(clientInfo.docId) as Document;
+    const currentVersion = this.documentVersions.get(clientInfo.docId)!;
+    
+    // Transform operation if needed
+    let transformedOp = operation;
+    const pending = this.pendingOps.get(clientInfo.docId)!;
+    
+    // Transform against all operations that happened after baseVersion
+    if (baseVersion < currentVersion) {
+      for (const pendingOp of pending) {
+        if (pendingOp.baseVersion >= baseVersion) {
+          transformedOp = transformOperation(transformedOp, pendingOp.operation);
+        }
+      }
+    }
+
+    // Validate transformed operation
+    if (!validateOperation(transformedOp, doc.content.length)) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation bounds' }));
+      return;
+    }
+
+    // Apply operation
+    const newContent = applyOperation(doc.content, transformedOp);
+    const newVersion = currentVersion + 1;
+
+    // Update document
+    const now = new Date().toISOString();
+    this.db.prepare('UPDATE documents SET content = ?, updated_at = ? WHERE id = ?').run(newContent, now, clientInfo.docId);
+
+    // Store version
+    this.db.prepare(`
+      INSERT INTO versions (document_id, version, content, operation, created_at)
+      VALUES (?, ?, ?, ?, ?)
+    `).run(clientInfo.docId, newVersion, newContent, JSON.stringify(transformedOp), now);
+
+    // Track this operation
+    pending.push({ operation: transformedOp, baseVersion: currentVersion });
+    this.documentVersions.set(clientInfo.docId, newVersion);
+
+    // Send ack to sender
+    ws.send(JSON.stringify({
+      type: 'ack',
+      version: newVersion
+    }));
+
+    // Broadcast to others in room
+    this.broadcast(clientInfo.docId, {
+      type: 'operation',
+      operation: transformedOp,
+      version: newVersion
+    }, ws);
+  }
+
+  private broadcast(docId: string, message: Record<string, unknown>, exclude?: WebSocket): void {
+    const room = this.rooms.get(docId);
+    if (!room) return;
+
+    const data = JSON.stringify(message);
+    for (const client of room) {
+      if (client !== exclude && client.readyState === WebSocket.OPEN) {
+        client.send(data);
+      }
+    }
+  }
+
+  private handleClose(ws: WebSocket): void {
+    const clientInfo = this.clients.get(ws);
+    if (!clientInfo) return;
+
+    // Remove from room
+    const room = this.rooms.get(clientInfo.docId);
+    if (room) {
+      room.delete(ws);
+      if (room.size === 0) {
+        this.rooms.delete(clientInfo.docId);
+        this.documentVersions.delete(clientInfo.docId);
+        this.pendingOps.delete(clientInfo.docId);
+      }
+    }
+
+    // Remove from clients
+    this.clients.delete(ws);
+
+    // Remove from database
+    this.db.prepare('DELETE FROM active_connections WHERE id = ?').run(clientInfo.connectionId);
+  }
+
+  close(): void {
+    // Close all connections
+    for (const ws of this.clients.keys()) {
+      ws.close();
+    }
+    this.wss.close();
+  }
+}
