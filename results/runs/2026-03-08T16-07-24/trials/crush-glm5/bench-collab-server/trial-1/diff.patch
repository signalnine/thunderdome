+import express from 'express';
+import http from 'http';
+import type Database from 'better-sqlite3';
+import { createDatabase } from './db.js';
+import { createRoutes } from './routes.js';
+import { CollabWebSocketServer } from './ws.js';
+
+export interface AppInstance {
+  app: express.Application;
+  server: http.Server;
+  wss: CollabWebSocketServer;
+  db: Database.Database;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const app = express();
+  const server = http.createServer(app);
+  const wss = new CollabWebSocketServer(server, db);
+
+  app.use(express.json());
+  app.use('/', createRoutes(db));
+
+  const start = (port = 0): Promise<number> => {
+    return new Promise((resolve) => {
+      server.listen(port, () => {
+        const actualPort = (server.address() as { port: number }).port;
+        resolve(actualPort);
+      });
+    });
+  };
+
+  const stop = (): Promise<void> => {
+    return new Promise((resolve, reject) => {
+      wss.close();
+      server.close((err) => {
+        if (err) {
+          reject(err);
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    });
+  };
+
+  return { app, server, wss, db, start, stop };
+}
diff --git a/src/ws.ts b/src/ws.ts
