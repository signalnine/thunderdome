--- a/src/routes.ts
+++ b/src/routes.ts
@@ -1,6 +1,6 @@
 import { Router, Request, Response, NextFunction } from 'express';
 import Database from 'better-sqlite3';
-import { Note, NoteInput } from './models.js';
+import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';
 import { NotFoundError, ValidationError } from './errors.js';
 
 export function createRoutes(db: Database.Database): Router {
@@ -118,5 +118,79 @@ export function createRoutes(db: Database.Database): Router {
     }
   });
 
+  // GET /notes/search - Full-text search
+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const query = req.query.q as string | undefined;
+      const page = parseInt(req.query.page as string) || 1;
+      const perPage = 20;
+      const offset = (page - 1) * perPage;
+
+      if (!query || query.trim() === '') {
+        return res.status(400).json({ error: 'Search query "q" is required and cannot be empty.' });
+      }
+
+      // FTS5 search query with snippet highlighting and BM25 ranking
+      // Join with notes table to retrieve id and title correctly.
+      const searchStmt = db.prepare(`
+        SELECT T1.id, T1.title, snippet(T2, 0, '<mark>', '</mark>', '...', 64) AS snippet, bm25(T2) AS rank
+        FROM notes AS T1
+        INNER JOIN notes_fts AS T2 ON T1.id = T2.rowid
+        WHERE T2 MATCH ?
+        ORDER BY rank DESC
+        LIMIT ? OFFSET ?
+      `);
+      const searchResults = searchStmt.all(query, perPage, offset) as SearchResult[];
+
+      // Count total results for pagination
+      const countStmt = db.prepare(`
+        SELECT COUNT(*) AS total FROM notes_fts WHERE notes_fts MATCH ?
+      `);
+      const totalResult = countStmt.get(query) as { total: number };
+      const total = totalResult.total;
+
+      res.json({
+        results: searchResults,
+        total: total,
+        page: page,
+        perPage: perPage,
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /notes/search/suggest - Autocomplete suggestions
+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const prefix = req.query.q as string | undefined;
+
+      if (!prefix || prefix.trim() === '') {
+        return res.status(400).json({ error: 'Search prefix "q" is required and cannot be empty.' });
+      }
+
+      // FTS5 prefix search: 'prefix*' is a common way to do prefix matching in FTS.
+      // We construct the query to explicitly search for prefixes.
+      const formattedQuery = `${prefix}*`;
+
+      // Join with notes table to retrieve id and title correctly.
+      // Use explicit table names for clarity and to potentially avoid alias issues in MATCH clause.
+      const suggestStmt = db.prepare(`
+        SELECT notes.id, notes.title
+        FROM notes
+        INNER JOIN notes_fts ON notes.id = notes_fts.rowid
+        WHERE notes_fts MATCH ?
+        ORDER BY notes.title ASC
+        LIMIT 5
+      `);
+      const suggestions = suggestStmt.all(formattedQuery) as SuggestResult[];
+
+      res.json({ results: suggestions });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+
   return router;
 }
