 import { Router, Request, Response, NextFunction } from 'express';
 import Database from 'better-sqlite3';
-import { Note, NoteInput } from './models.js';
+import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';
 import { NotFoundError, ValidationError } from './errors.js';
 
 export function createRoutes(db: Database.Database): Router {
@@ -118,5 +118,117 @@ export function createRoutes(db: Database.Database): Router {
     }
   });
 
+  // GET /notes/search - Full-text search
+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const query = req.query.q as string | undefined;
+
+      if (!query || query.trim() === '') {
+        throw new ValidationError('Query parameter q is required');
+      }
+
+      const page = parseInt(req.query.page as string) || 1;
+      const perPage = 20;
+      const offset = (page - 1) * perPage;
+
+      // Escape special characters for FTS5
+      const escapedQuery = query.replace(/"/g, '""');
+
+      // Search using BM25 ranking
+      const searchStmt = db.prepare(`
+        SELECT
+          notes.id,
+          notes.title,
+          notes.body,
+          bm25(notes_fts) as rank
+        FROM notes_fts
+        JOIN notes ON notes_fts.rowid = notes.id
+        WHERE notes_fts MATCH ?
+        ORDER BY bm25(notes_fts)
+        LIMIT ? OFFSET ?
+      `);
+
+      // Get total count
+      const countStmt = db.prepare(`
+        SELECT COUNT(*) as total
+        FROM notes_fts
+        WHERE notes_fts MATCH ?
+      `);
+
+      const results = searchStmt.all(escapedQuery, perPage, offset) as Array<{
+        id: number;
+        title: string;
+        body: string;
+        rank: number;
+      }>;
+
+      const countResult = countStmt.get(escapedQuery) as { total: number };
+      const total = countResult.total;
+
+      // Generate snippets with highlighting
+      const snippetStmt = db.prepare(`
+        SELECT snippet(notes_fts, 0, '<mark>', '</mark>', '...', 32) as snippet
+        FROM notes_fts
+        WHERE rowid = ? AND notes_fts MATCH ?
+      `);
+
+      const searchResults: SearchResult[] = results.map((row) => {
+        // Try to get snippet from FTS, fallback to body excerpt
+        let snippet: string;
+        try {
+          const snippetResult = snippetStmt.get(row.id, escapedQuery) as { snippet: string } | undefined;
+          snippet = snippetResult?.snippet || row.body.substring(0, 150) + '...';
+        } catch {
+          snippet = row.body.substring(0, 150) + '...';
+        }
+
+        return {
+          id: row.id,
+          title: row.title,
+          snippet,
+          rank: row.rank,
+        };
+      });
+
+      res.json({
+        results: searchResults,
+        total,
+        page,
+        perPage,
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /notes/search/suggest - Autocomplete suggestions
+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const prefix = req.query.q as string | undefined;
+
+      if (!prefix || prefix.trim() === '') {
+        throw new ValidationError('Query parameter q is required');
+      }
+
+      // Use prefix query for autocomplete
+      const suggestStmt = db.prepare(`
+        SELECT DISTINCT notes.id, notes.title
+        FROM notes_fts
+        JOIN notes ON notes_fts.rowid = notes.id
+        WHERE notes_fts MATCH ?
+        LIMIT 5
+      `);
+
+      // Create prefix query (e.g., "learn*" matches "learning", "learns", etc.)
+      const prefixQuery = `${prefix}*`;
+
+      const results = suggestStmt.all(prefixQuery) as SuggestResult[];
+
+      res.json({ results });
+    } catch (err) {
+      next(err);
+    }
+  });
+
   return router;
 }
