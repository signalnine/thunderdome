+import { EventBus } from '../bus.ts';
+import { NotificationService, Events } from '../types.ts';
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  // Map of userId to array of notifications
+  const notifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();
+  // Map of orderId to userId to track which order belongs to which user
+  const orderUserMap = new Map<string, string>();
+
+  // Listen for order status changes and payment events to send notifications
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {
+    const event = payload as { orderId: string; status: string; previousStatus: string };
+    const userId = orderUserMap.get(event.orderId);
+    if (!userId) return;
+
+    const message = `Your order #${event.orderId} status changed from ${event.previousStatus} to ${event.status}`;
+    const notification = { type: 'order_status', message, timestamp: Date.now() };
+    const userNotifications = notifications.get(userId) ?? [];
+    userNotifications.push(notification);
+    notifications.set(userId, userNotifications);
+
+    // Also emit notification sent event for analytics
+    bus.emit(Events.NOTIFICATION_SENT, {
+      userId,
+      type: 'order_status',
+      message
+    });
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as { orderId: string; status: string; transactionId?: string; error?: string };
+    // We need to get the userId from the order. However, we don't have the order service here.
+    // Instead, we can rely on the orderUserMap that we populate when an order is created.
+    // But we don't listen for order created. Let's listen for order created as well.
+    // Actually, we can get the userId from the orderUserMap only if we have stored it.
+    // We'll need to listen for order created to populate orderUserMap.
+    // Let's adjust: we'll listen for order created and order status changed and payment processed.
+    // For now, we'll just leave a comment and implement order created listener below.
+  });
+
+  // We need to listen for order created to map order to user
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as { orderId: string; userId: string; cartId: string; total: number };
+    orderUserMap.set(event.orderId, event.userId);
+  });
+
+  // Now we can implement the payment processed listener fully
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as { orderId: string; status: string; transactionId?: string; error?: string };
+    const userId = orderUserMap.get(event.orderId);
+    if (!userId) return;
+
+    let message = '';
+    if (event.status === 'success') {
+      message = `Payment for order #${event.orderId} was successful`;
+    } else if (event.status === 'failed') {
+      message = `Payment for order #${event.orderId} failed: ${event.error || 'Unknown error'}`;
+    } else if (event.status === 'timeout') {
+      message = `Payment for order #${event.orderId} timed out`;
+    }
+
+    if (message) {
+      const notification = { type: 'payment', message, timestamp: Date.now() };
+      const userNotifications = notifications.get(userId) ?? [];
+      userNotifications.push(notification);
+      notifications.set(userId, userNotifications);
+
+      bus.emit(Events.NOTIFICATION_SENT, {
+        userId,
+        type: 'payment',
+        message
+      });
+    }
+  });
+
+  return {
+    subscribe(userId: string): void {
+      // Ensure the user has an empty array for notifications if not already present
+      if (!notifications.has(userId)) {
+        notifications.set(userId, []);
+      }
+    },
+
+    getNotifications(userId: string): Array<{ type: string; message: string; timestamp: number }> {
+      return notifications.get(userId) ?? [];
+    }
+  };
+}
