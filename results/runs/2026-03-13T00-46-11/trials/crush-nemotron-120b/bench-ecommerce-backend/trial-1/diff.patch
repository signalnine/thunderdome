@@ -0,0 +1,74 @@
+import { EventBus } from '../bus.ts';
+import { InventoryService, Events } from '../types.ts';
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  const inventory = new Map<string, { total: number; reserved: number; threshold: number }>();
+
+  // Initialize product when created
+  bus.on(Events.PRODUCT_CREATED, (payload: unknown) => {
+    const event = payload as { productId: string };
+    if (!inventory.has(event.productId)) {
+      inventory.set(event.productId, { total: 0, reserved: 0, threshold: 0 });
+    }
+  });
+
+  return {
+    setStock(productId: string, quantity: number): void {
+      let item = inventory.get(productId);
+      if (!item) {
+        item = { total: 0, reserved: 0, threshold: 0 };
+        inventory.set(productId, item);
+      }
+      item.total = quantity;
+      // Emit inventory updated event
+      bus.emit(Events.INVENTORY_UPDATED, { productId, quantity: item.total });
+      // Check for low stock
+      if (item.total < item.threshold) {
+        bus.emit(Events.LOW_STOCK_ALERT, {
+          productId,
+          currentQuantity: item.total,
+          threshold: item.threshold
+        });
+      }
+    },
+
+    getStock(productId: string): number {
+      const item = inventory.get(productId);
+      return item ? item.total : 0;
+    },
+
+    reserve(productId: string, quantity: number): boolean {
+      const item = inventory.get(productId);
+      if (!item) return false;
+      const available = item.total - item.reserved;
+      if (available >= quantity) {
+        item.reserved += quantity;
+        return true;
+      }
+      return false;
+    },
+
+    release(productId: string, quantity: number): void {
+      const item = inventory.get(productId);
+      if (!item) return;
+      item.reserved = Math.max(0, item.reserved - quantity);
+    },
+
+    setLowStockThreshold(productId: string, threshold: number): void {
+      let item = inventory.get(productId);
+      if (!item) {
+        item = { total: 0, reserved: 0, threshold: 0 };
+        inventory.set(productId, item);
+      }
+      item.threshold = threshold;
+      // Check if current stock is below new threshold
+      if (item.total < item.threshold) {
+        bus.emit(Events.LOW_STOCK_ALERT, {
+          productId,
+          currentQuantity: item.total,
+          threshold: item.threshold
+        });
+      }
+    }
+  };
+}
