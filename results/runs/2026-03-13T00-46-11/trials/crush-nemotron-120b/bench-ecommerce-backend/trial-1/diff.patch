+import { EventBus } from '../bus.ts';
+import { AnalyticsService, Events, OrderStatus, PaymentStatus } from '../types.ts';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  // State for analytics
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const cartItems = new Map<string, Map<string, number>>(); // cartId -> { productId => quantity }
+  const uniqueCarts = new Set<string>();
+  const orderCount = { value: 0 }; // using object to allow modification in inner functions
+  const orderTotals = new Map<string, number>(); // orderId => total
+  const productOrderQuantities = new Map<string, number>(); // productId => total quantity ordered
+
+  // Helper to increment event count
+  const incrementEventCount = (eventType: string) => {
+    const current = eventCounts.get(eventType) ?? 0;
+    eventCounts.set(eventType, current + 1);
+  };
+
+  // Listen to all events except ANALYTICS_EVENT to avoid self-loop
+  const eventNames = (Object.values(Events) as string[]).filter(
+    (e) => e !== Events.ANALYTICS_EVENT
+  );
+
+  for (const eventName of eventNames) {
+    bus.on(eventName, (payload: unknown) => {
+      // Increment count for this event type
+      incrementEventCount(eventName);
+
+      // Handle specific events for metrics
+      switch (eventName) {
+        case Events.CART_UPDATED: {
+          const event = payload as { cartId: string; userId: string; items: Array<{ productId: string; quantity: number }> };
+          // Update cart items for this cart (replace with current items)
+          const itemsMap = new Map<string, number>();
+          for (const item of event.items) {
+            itemsMap.set(item.productId, item.quantity);
+          }
+          cartItems.set(event.cartId, itemsMap);
+          uniqueCarts.add(event.cartId);
+          break;
+        }
+        case Events.ORDER_CREATED: {
+          const event = payload as { orderId: string; userId: string; cartId: string; total: number };
+          orderCount.value += 1;
+          orderTotals.set(event.orderId, event.total);
+          // Use cart items at the time of order to count product quantities
+          const cartItemMap = cartItems.get(event.cartId);
+          if (cartItemMap) {
+            for (const [productId, quantity] of cartItemMap.entries()) {
+              const current = productOrderQuantities.get(productId) ?? 0;
+              productOrderQuantities.set(productId, current + quantity);
+            }
+          }
+          break;
+        }
+        case Events.PAYMENT_PROCESSED: {
+          const event = payload as { orderId: string; status: PaymentStatus; transactionId?: string; error?: string };
+          if (event.status === PaymentStatus.SUCCESS) {
+            const total = orderTotals.get(event.orderId);
+            if (total !== undefined) {
+              revenue += total;
+            }
+          }
+          break;
+        }
+        // No specific handling needed for other events for our metrics
+        default:
+          break;
+      }
+    });
+  }
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+    getRevenue(): number {
+      return revenue;
+    },
+    getConversionRate(): number {
+      const cartsCreated = uniqueCarts.size;
+      return cartsCreated > 0 ? orderCount.value / cartsCreated : 0;
+    },
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> {
+      // Convert map to array, sort by count descending, take top limit
+      const productsArray = Array.from(productOrderQuantities.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count);
+      return productsArray.slice(0, limit);
+    }
+  };
+}
