+import { EventBus } from '../bus.ts';
+import { PaymentService, Events, PaymentStatus } from '../types.ts';
+
+interface PaymentServiceOptions {
+  mode?: 'success' | 'failure' | 'timeout' | 'random';
+  successRate?: number;
+  failureRate?: number;
+  timeoutRate?: number;
+  delayMs?: number;
+}
+
+export function createPaymentService(bus: EventBus, options: PaymentServiceOptions = {}): PaymentService {
+  const {
+    mode = 'success',
+    successRate = 1.0,
+    failureRate = 0.0,
+    timeoutRate = 0.0,
+    delayMs = 0
+  } = options;
+
+  // Ensure rates are valid
+  const total = successRate + failureRate + timeoutRate;
+  const normalizedSuccessRate = total > 0 ? successRate / total : 1.0;
+  const normalizedFailureRate = total > 0 ? failureRate / total : 0.0;
+  const normalizedTimeoutRate = total > 0 ? timeoutRate / total : 0.0;
+
+  const transactionMap = new Map<string, { orderId: string; amount: number }>();
+  let transactionIdCounter = 1;
+
+  function generateTransactionId(): string {
+    return `txn_${transactionIdCounter++}`;
+  }
+
+  function determineStatus(): PaymentStatus {
+    if (mode !== 'random') {
+      switch (mode) {
+        case 'success': return PaymentStatus.SUCCESS;
+        case 'failure': return PaymentStatus.FAILED;
+        case 'timeout': return PaymentStatus.TIMEOUT;
+        default: return PaymentStatus.SUCCESS;
+      }
+    }
+
+    const rand = Math.random();
+    if (rand < normalizedSuccessRate) {
+      return PaymentStatus.SUCCESS;
+    } else if (rand < normalizedSuccessRate + normalizedFailureRate) {
+      return PaymentStatus.FAILED;
+    } else {
+      return PaymentStatus.TIMEOUT;
+    }
+  }
+
+  async function processPayment(orderId: string, amount: number): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> {
+    // Simulate delay if specified
+    if (delayMs > 0) {
+      await new Promise(resolve => setTimeout(resolve, delayMs));
+    }
+
+    const status = determineStatus();
+    let transactionId: string | undefined;
+    let error: string | undefined;
+
+    if (status === PaymentStatus.SUCCESS) {
+      transactionId = generateTransactionId();
+      transactionMap.set(transactionId, { orderId, amount });
+    } else if (status === PaymentStatus.FAILED) {
+      error = 'Payment failed';
+    } else if (status === PaymentStatus.TIMEOUT) {
+      error = 'Payment timeout';
+    }
+
+    const result = { 
+      status, 
+      ...(transactionId ? { transactionId } : {}), 
+      ...(error ? { error } : {}) 
+    };
+
+    // Emit payment processed event
+    await bus.emit(Events.PAYMENT_PROCESSED, {
+      orderId,
+      ...result
+    });
+
+    return result;
+  }
+
+  async function refund(transactionId: string): Promise<boolean> {
+    const transaction = transactionMap.get(transactionId);
+    if (!transaction) {
+      return false;
+    }
+    transactionMap.delete(transactionId);
+    // In a real system, we would actually process the refund
+    // For simulation, we just remove the transaction and return true
+    return true;
+  }
+
+  return {
+    processPayment,
+    refund
+  };
+}
