+import { EventBus } from '../bus.ts';
+import { CartService, Events } from '../types.ts';
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, { userId: string; items: Map<string, number> }>();
+  let cartIdCounter = 1;
+
+  function generateCartId(): string {
+    return `cart_${cartIdCounter++}`;
+  }
+
+  function emitCartUpdated(cartId: string): void {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    const itemsArray = Array.from(cart.items.entries()).map(([productId, quantity]) => ({
+      productId,
+      quantity
+    }));
+    bus.emit(Events.CART_UPDATED, {
+      cartId,
+      userId: cart.userId,
+      items: itemsArray
+    });
+  }
+
+  return {
+    createCart(userId: string): string {
+      const id = generateCartId();
+      carts.set(id, { userId, items: new Map() });
+      emitCartUpdated(id);
+      return id;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number): void {
+      if (quantity <= 0) return;
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      const current = cart.items.get(productId) ?? 0;
+      cart.items.set(productId, current + quantity);
+      emitCartUpdated(cartId);
+    },
+
+    removeItem(cartId: string, productId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.delete(productId);
+      emitCartUpdated(cartId);
+    },
+
+    getCart(cartId: string): { id: string; userId: string; items: Array<{ productId: string; quantity: number }> } | null {
+      const cart = carts.get(cartId);
+      if (!cart) return null;
+      return {
+        id: cartId,
+        userId: cart.userId,
+        items: Array.from(cart.items.entries()).map(([productId, quantity]) => ({
+          productId,
+          quantity
+        }))
+      };
+    },
+
+    clearCart(cartId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.clear();
+      emitCartUpdated(cartId);
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      if (quantity <= 0) {
+        cart.items.delete(productId);
+      } else {
+        cart.items.set(productId, quantity);
+      }
+      emitCartUpdated(cartId);
+    }
+  };
+}
