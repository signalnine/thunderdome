+                const price = productPrices.get(item.productId) ?? item.price;
+                subtotal += price * item.quantity;
+            }
+            const discountPercentage = discountCodes.get(discountCode ?? '') ?? 0;
+            const discount = subtotal * (discountPercentage / 100);
