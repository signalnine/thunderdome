+import { Events } from '../types.ts';
+export function createCatalogService(bus) {
+    const products = new Map();
+    let idCounter = 1;
+    function generateId() {
+        return `prod_${idCounter++}`;
+    }
+    return {
+        createProduct(name, price, category) {
+            const id = generateId();
+            const product = { id, name, price, category };
+            products.set(id, product);
+            bus.emit(Events.PRODUCT_CREATED, { productId: id, name, price, category });
+            return id;
+        },
+        getProduct(productId) {
+            return products.get(productId) ?? null;
+        },
+        listProducts(category) {
+            if (category) {
+                return Array.from(products.values())
+                    .filter(p => p.category === category)
+                    .map(p => ({ id: p.id, name: p.name, price: p.price, category: p.category }));
+            }
+            return Array.from(products.values()).map(p => ({
+                id: p.id,
+                name: p.name,
+                price: p.price,
+                category: p.category
+            }));
+        },
+        searchProducts(query) {
+            const lowerQuery = query.toLowerCase();
+            return Array.from(products.values())
+                .filter(p => p.name.toLowerCase().includes(lowerQuery) ||
+                p.category.toLowerCase().includes(lowerQuery))
+                .map(p => ({ id: p.id, name: p.name, price: p.price, category: p.category }));
+        },
+        updateProduct(productId, updates) {
+            const product = products.get(productId);
+            if (!product) {
+                return;
+            }
+            const updated = { ...product, ...updates };
+            products.set(productId, updated);
+        },
+        removeProduct(productId) {
+            return products.delete(productId);
+        }
+    };
