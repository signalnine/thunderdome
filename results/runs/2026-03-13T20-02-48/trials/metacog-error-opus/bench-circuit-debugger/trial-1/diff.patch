   const key1 = `${g.op}:${g.in1}:${g.in2}`;\n      const key2 = `${g.op}:${g.in2}:${g.in1}`;\n      gateByInputsAndOp.set(key1, g);\n      gateByInputsAndOp.set(key2, g);\n    }\n  }\n\n  // We need to find gates that consume a given wire as input\n  function findConsumers(wire: string): Gate[] {\n    return gates.filter(g => g.in1 === wire || g.in2 === wire);\n  }\n\n  // Strategy: Walk bit by bit through the adder structure.\n  // For each bit, verify the expected structure and detect violations.\n\n  // Bit 0: XOR(x00, y00) -> z00; AND(x00, y00) -> carry\n  const pad = (n: number) => n.toString().padStart(2, '0');\n\n  let carry: string | undefined;\n\n  // Process bit 0\n  {\n    const x = `x${pad(0)}`;\n    const y = `y${pad(0)}`;\n\n    const xorGate = findGate('XOR', x, y);\n    const andGate = findGate('AND', x, y);\n\n    if (xorGate && xorGate.out !== 'z00') {\n      // z00 output is wrong - find what currently outputs z00 and swap\n      swapOutputs(xorGate.out, 'z00');\n      rebuildAllInputMaps();\n    }\n\n    if (andGate) {\n      carry = andGate.out;\n    }\n  }\n\n  // Process bits 1..maxBit\n  for (let i = 1; i <= maxBit; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const zWire = `z${pad(i)}`;\n\n    // Step 1: Find XOR(x_i, y_i) -> partial sum (t_i)\n    const xorXY = findGate('XOR', x, y);\n    if (!xorXY) continue;\n    let partialSum = xorXY.out;\n\n    // Step 2: Find XOR(partialSum, carry) -> z_i\n    let xorSumCarry = findGate('XOR', partialSum, carry!);\n\n    if (!xorSumCarry) {\n      // The partial sum or carry might be swapped\n      // Check if carry is being used somewhere unexpected\n      // Or if partialSum is wrong\n\n      // Check: is there a gate XOR(?, carry) that outputs z_i?\n      const zGate = gateByOutput.get(zWire);\n      if (zGate && zGate.op === 'XOR') {\n        // One of zGate's inputs should be carry, the other should be partialSum\n        const otherInput =\n          zGate.in1 === carry