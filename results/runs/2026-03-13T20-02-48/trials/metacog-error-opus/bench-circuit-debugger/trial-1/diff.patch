            result = a ^ b;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires involved in 4 output-wire swaps in a broken ripple-carry adder.\n *\n * Strategy (informed by structural analysis):\n * A correct N-bit ripple-carry adder for bit i (i >= 1) has this structure:\n *   XOR(x_i, y_i) -> t_i          (partial sum)\n *   XOR(t_i, c_{i-1}) -> z_i      (final sum = output bit)\n *   AND(x_i, y_i) -> a_i          (generate)\n *   AND(t_i, c_{i-1}) -> b_i      (propagate)\n *   OR(a_i, b_i) -> c_i           (carry out)\n *\n * For bit 0:\n *   XOR(x00, y00) -> z00\n *   AND(x00, y00) -> c00\n *\n * We walk the structure bit by bit, identifying gates by their structural role.\n * Any wire that doesn't fit its expected role indicates a swap.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Find max bit index from x-inputs\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const wire of [g.in1, g.in2]) {\n      if (wire.startsWith('x') || wire.startsWith('y')) {\n        const num = parseInt(wire.slice(1), 10);\n        if (num > maxBit) maxBit = num;\n      }\n    }\n  }\n\n  // Build a map: given two input wires and an operation, find the gate\n  const gateByInputsAndOp = new Map<string, Gate>();\n  for (const g of gates) {\n    const key1 = `${g.op}:${g.in1}:${g.in2}`;\n    const key2 = `${g.op}:${g.in2}:${g.in1}`;\n    gateByInputsAndOp.set(key1, g);\n    gateByInputsAndOp.set(key2, g);\n  }\n\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    const key = `${op}:${in1}:${in2}`;\n    return gateByInputsAndOp.get(key);\n  }\n\n  // Collect the swapped wires\n  const swapped = new Set<string>();\n\n  function swapOutputs(w1: string, w2: string): void {\n    swapped.add(w1);\n    swapped.add(w2);\n\n    const g1 = gateByOutput.get(w1)!;\n    const g2 = gateByOutput.get(w2)!;\n\n    // Perform the swap\n    g1.out = w2;\n    g2.out = w1;\n\n    // Update lookup maps\n    gateByOutput.set(w1, g2);\n    gateByOutput.set(w2, g1);\n\n    // Rebuild the inputs-op map for affected gates\n    rebuildInputMap(g1);\n    rebuildInputMap(g2);\n  }\n\n  function rebuildInputMap(g: Gate): void {\n    // Remove old entries and add new ones - just rebuild all for simplicity\n    // Since we only call this for swapped gates, full rebuild is fine\n  }\n\n  function rebuildAllInputMaps(): void {\n    gateByInputsAndOp.clear();\n    for (const g of gates) {\n      const key1 = `${g.op}:${g.in1}:${g.in2}`;\n      const key2 = `${g.op}:${g.in2}:${g.in1}`;\n      gateByInputsAndOp.set(key1, g);\n      gateByInputsAndOp.set(key2, g);\n    }\n  }\n\n  // We need to find gates that consume a given wire as input\n  function findConsumers(wire: string): Gate[] {\n    return gates.filter(g => g.in1 === wire || g.in2 === wire);\n  }\n\n  // Strategy: Walk bit by bit through the adder structure.\n  // For each bit, verify the expected structure and detect violations.\n\n  // Bit 0: XOR(x00, y00) -> z00; AND(x00, y00) -> carry\n  const pad = (n: number) => n.toString().padStart(2, '0');\n\n  let carry: string | undefined;\n\n  // Process bit 0\n  {\n    const x = `x${pad(0)}`;\n    const y = `y${pad(0)}`;\n\n    const xorGate = findGate('XOR', x, y);\n    const andGate = findGate('AND', x, y);\n\n    if (xorGate && xorGate.out !== 'z00') {\n      // z00 output is wrong - find what currently outputs z00 and swap\n      swapOutputs(xorGate.out, 'z00');\n      rebuildAllInputMaps();\n    }\n\n    if (andGate) {\n      carry = andGate.out;\n    }\n  }\n\n  // Process bits 1..maxBit\n  for (let i = 1; i <= maxBit; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const zWire = `z${pad(i)}`;\n\n    // Step 1: Find XOR(x_i, y_i) -> partial sum (t_i)\n    const xorXY = findGate('XOR', x, y);\n    if (!xorXY) continue;\n    let partialSum = xorXY.out;\n\n    // Step 2: Find XOR(partialSum, carry) -> z_i\n    let xorSumCarry = findGate('XOR', partialSum, carry!);\n\n    if (!xorSumCarry) {\n      // The partial sum or carry might be swapped\n      // Check if carry is being used somewhere unexpected\n      // Or if partialSum is wrong\n\n      // Check: is there a gate XOR(?, carry) that outputs z_i?\n      const zGate = gateByOutput.get(zWire);\n      if (zGate && zGate.op === 'XOR') {\n        // One of zGate's inputs should be carry, the other should be partialSum\n        const otherInput =\n          zGate.in1 === carry ? zGate.in2 : zGate.in2 === carry ? zGate.in1 : undefined;\n\n        if (otherInput !== undefined && otherInput !== partialSum) {\n          // partialSum was swapped with otherInput\n          swapOutputs(partialSum, otherInput);\n          rebuildAllInputMaps();\n          partialSum = otherInput;\n          xorSumCarry = zGate;\n        } else if (otherInput === undefined) {\n          // Neither input is carry - carry was swapped\n          // Try: which input of zGate is the partial sum?\n          if (zGate.in1 === partialSum) {\n            // zGate.in2 should be carry but isn't - swap carry with zGate.in2\n            swapOutputs(carry!, zGate.in2);\n            rebuildAllInputMaps();\n            carry = zGate.in2;\n            xorSumCarry = zGate;\n          } else if (zGate.in2 === partialSum) {\n            swapOutputs(carry!, zGate.in1);\n            rebuildAllInputMaps();\n            carry = zGate.in1;\n            xorSumCarry = zGate;\n          }\n        }\n      } else {\n        // z_i gate is not XOR or doesn't exist - the output to z_i was swapped\n        // Find the XOR gate that uses both partialSum and carry\n        // Check consumers of partialSum that are XOR\n        const partialSumConsumers = findConsumers(partialSum);\n        const xorConsumer = partialSumConsumers.find(\n          g => g.op === 'XOR' && (g.in1 === carry || g.in2 === carry)\n        );\n        if (xorConsumer) {\n          // This gate should output z_i but outputs something else\n          swapOutputs(xorConsumer.out, zWire);\n          rebuildAllInputMaps();\n          xorSumCarry = findGate('XOR', partialSum, carry!);\n        } else {\n          // Maybe carry is swapped - look for XOR consuming partialSum\n          const xorOfPartial = partialSumConsumers.find(g => g.op === 'XOR');\n          if (xorOfPartial) {\n            const otherIn =\n              xorOfPartial.in1 === partialSum ? xorOfPartial.in2 : xorOfPartial.in1;\n            // otherIn should be carry\n            swapOutputs(carry!, otherIn);\n            rebuildAllInputMaps();\n            carry = otherIn;\n            xorSumCarry = xorOfPartial;\n            // Also check if this gate's output is z_i\n            if (xorSumCarry && xorSumCarry.out !== zWire) {\n              swapOutputs(xorSumCarry.out, zWire);\n              rebuildAllInputMaps();\n              xorSumCarry = findGate('XOR', partialSum, carry!);\n            }\n          }\n        }\n      }\n    }\n\n    if (xorSumCarry && xorSumCarry.out !== zWire) {\n      // The output of the sum gate should be z_i\n      swapOutputs(xorSumCarry.out, zWire);\n      rebuildAllInputMaps();\n    }\n\n    // Step 3: Find AND(x_i, y_i) -> generate (a_i)\n    const andXY = findGate('AND', x, y);\n    if (!andXY) continue;\n    const generate = andXY.out;\n\n    // Step 4: Find AND(partialSum, carry) -> propagate (b_i)\n    const andSumCarry = findGate('AND', partialSum, carry!);\n    let propagate: string | undefined;\n    if (andSumCarry) {\n      propagate = andSumCarry.out;\n    }\n\n    // Step 5: Find OR(generate, propagate) -> carry out (c_i)\n    if (propagate !== undefined) {\n      const orGate = findGate('OR', generate, propagate);\n      if (orGate) {\n        carry = orGate.out;\n      } else {\n        // One of generate or propagate might be swapped, or the OR output\n        // Try to find an OR gate with one of them\n        const genConsumers = findConsumers(generate).filter(g => g.op === 'OR');\n        const propConsumers = findConsumers(propagate).filter(g => g.op === 'OR');\n\n        if (genConsumers.length > 0) {\n          const orG = genConsumers[0];\n          const otherIn = orG.in1 === generate ? orG.in2 : orG.in1;\n          // propagate was swapped with otherIn\n          swapOutputs(propagate, otherIn);\n          rebuildAllInputMaps();\n          carry = orG.out;\n        } else if (propConsumers.length > 0) {\n          const orG = propConsumers[0];\n          const otherIn = orG.in1 === propagate ? orG.in2 : orG.in1;\n          // generate was swapped with otherIn\n          swapOutputs(generate, otherIn);\n          rebuildAllInputMaps();\n          carry = orG.out;\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":113,"oldLines":17,"newStart":113,"newLines":8,"lines":["     // Update lookup maps","     gateByOutput.set(w1, g2);","     gateByOutput.set(w2, g1);","-","-    // Rebuild the inputs-op map for affected gates","-    rebuildInputMap(g1);","-    rebuildInputMap(g2);","   }"," ","-  function rebuildInputMap(g: Gate): void {","-    // Remove old entries and add new ones - just rebuild all for simplicity","-    // Since we only call this for swapped gates, full rebuild is fine","-  }","-","   function rebuildAllInputMaps(): void {","     gateByInputsAndOp.clear();","     for (const g of gates) {"]}],"userModified":false,"replaceAll":false}}
