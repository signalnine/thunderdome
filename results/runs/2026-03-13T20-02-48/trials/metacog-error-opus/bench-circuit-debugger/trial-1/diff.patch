+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index.js';
+
+describe('simulate', () => {
+  it('should compute a simple AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result.c).toBe(1);
+
+    const result2 = simulate(gates, { a: 1, b: 0 });
+    expect(result2.c).toBe(0);
+  });
+
+  it('should compute a simple OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);
+    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);
+  });
+
+  it('should compute a simple XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);
+    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);
+  });
+
+  it('should handle dependency chains', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'mid' },
+      { op: 'OR', in1: 'mid', in2: 'c', out: 'result' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, c: 0 }).result).toBe(1);
+    expect(simulate(gates, { a: 0, b: 1, c: 0 }).result).toBe(0);
+  });
+
+  it('should simulate a 4-bit adder correctly', () => {
+    const gates: Gate[] = [
+      // Bit 0
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      // Bit 2
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      // Bit 3
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },
+    ];
+
+    // Test 7 + 5 = 12 (0111 + 0101 = 01100)
+    const result = simulate(gates, {
+      x00: 1, x01: 1, x02: 1, x03: 0,
+      y00: 1, y01: 0, y02: 1, y03: 0,
+    });
+    // 12 = 01100 => z00=0, z01=0, z02=1, z03=1, c03=0
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(0);
+    expect(result.z02).toBe(1);
+    expect(result.z03).toBe(1);
+  });
+});
+
+describe('findSwappedWires', () => {
+  function swapGateOutputs(gates: Gate[], w1: string, w2: string): void {
+    const g1 = gates.find(g => g.out === w1)!;
+    const g2 = gates.find(g => g.out === w2)!;
+    g1.out = w2;
+    g2.out = w1;
+  }
+
+  it('should find swapped wires in a proper adder', () => {
+    // Proper 4-bit adder where last carry goes to z04
+    const gates: Gate[] = [
+      // Bit 0
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      // Bit 2
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      // Bit 3
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },  // last carry -> z04
+    ];
+
+    // Swap 1: z01 <-> a01
+    swapGateOutputs(gates, 'z01', 'a01');
+    // Swap 2: z02 <-> b02
+    swapGateOutputs(gates, 'z02', 'b02');
+    // Swap 3: t03 <-> a03
+    swapGateOutputs(gates, 't03', 'a03');
+    // Swap 4: z03 <-> z04
+    swapGateOutputs(gates, 'z03', 'z04');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a01', 'a03', 'b02', 't03', 'z01', 'z02', 'z03', 'z04'].sort()
+    );
+  });
+
+  function make8BitAdder(): Gate[] {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+    ];
+    for (let i = 1; i <= 7; i++) {
+      const p = i.toString().padStart(2, '0');
+      const pp = (i - 1).toString().padStart(2, '0');
+      const carry = i === 1 ? `c00` : `c${pp}`;
+      gates.push(
+        { op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: `t${p}` },
+        { op: 'XOR', in1: `t${p}`, in2: carry, out: `z${p}` },
+        { op: 'AND', in1: `x${p}`, in2: `y${p}`, out: `a${p}` },
+        { op: 'AND', in1: `t${p}`, in2: carry, out: `b${p}` },
+        { op: 'OR', in1: `a${p}`, in2: `b${p}`, out: `c${p}` },
+      );
+    }
+    // Last carry
+    const lastGate = gates.find(g => g.out === 'c07')!;
+    lastGate.out = 'z08';
+    return gates;
+  }
+
+  it('should find swapped carry and generate wires', () => {
+    const gates = make8BitAdder();
+    // Swap c01 (carry) with a02 (generate)
+    swapGateOutputs(gates, 'c01', 'a02');
+    // Swap c03 (carry) with b04 (propagate)
+    swapGateOutputs(gates, 'c03', 'b04');
+    // Swap z05 with t05 (sum output with partial sum)
+    swapGateOutputs(gates, 'z05', 't05');
+    // Swap z07 with z08 (sum with last carry)
+    swapGateOutputs(gates, 'z07', 'z08');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a02', 'b04', 'c01', 'c03', 't05', 'z05', 'z07', 'z08'].sort()
+    );
+  });
+});
