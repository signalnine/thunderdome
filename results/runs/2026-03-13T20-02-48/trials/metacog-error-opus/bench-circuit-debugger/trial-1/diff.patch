+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+function isXYInput(wire: string): boolean {
+  return /^[xy]\d+$/.test(wire);
+}
+
+function isZOutput(wire: string): boolean {
+  return /^z\d+$/.test(wire);
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a broken ripple-carry adder.
+ *
+ * Uses structural rules: in a correct ripple-carry adder, each gate type
+ * has constraints on what it can output to and what downstream gates consume it.
+ * Violations of these rules indicate swapped output wires.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Find the number of input bits from x-wires
+  let maxInputBit = 0;
+  for (const g of gates) {
+    for (const wire of [g.in1, g.in2]) {
+      if (wire.startsWith('x')) {
+        const num = parseInt(wire.slice(1), 10);
+        if (num > maxInputBit) maxInputBit = num;
+      }
+    }
+  }
+  // The last z output is z(maxInputBit + 1) - the carry out
+  const lastZ = `z${(maxInputBit + 1).toString().padStart(2, '0')}`;
+
+  // Build consumer map: wire -> gates that use it as input
+  const consumers = new Map<string, Gate[]>();
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      if (!consumers.has(w)) consumers.set(w, []);
+      consumers.get(w)!.push(g);
+    }
+  }
+
+  function isConsumedByOp(wire: string, op: string): boolean {
+    const cs = consumers.get(wire) || [];
+    return cs.some(g => g.op === op);
+  }
+
+  function hasXYInputs(g: Gate): boolean {
+    return isXYInput(g.in1) && isXYInput(g.in2);
+  }
+
+  function isBit0XY(g: Gate): boolean {
+    return hasXYInputs(g) &&
+      ((g.in1 === 'x00' && g.in2 === 'y00') || (g.in1 === 'y00' && g.in2 === 'x00'));
+  }
+
+  const swapped = new Set<string>();
+
+  for (const g of gates) {
+    const out = g.out;
+
+    if (g.op === 'XOR') {
+      if (hasXYInputs(g)) {
+        // XOR with x/y inputs: this is either z00 (for bit 0) or a partial sum
+        if (isBit0XY(g)) {
+          // Bit 0 XOR should output z00
+          if (out !== 'z00') {
+            swapped.add(out);
+          }
+        } else {
+          // Partial sum: must NOT output to z directly
+          // Must be consumed by exactly one XOR and one AND
+          if (isZOutput(out)) {
+            swapped.add(out);
+          } else if (!isConsumedByOp(out, 'XOR') || !isConsumedByOp(out, 'AND')) {
+            // This partial sum doesn't feed into the expected downstream gates
+            // This means its output was swapped
+            swapped.add(out);
+          }
+        }
+      } else {
+        // XOR with non-x/y inputs: this is a final sum gate, must output z_i
+        // But must NOT output lastZ (the final carry bit, which should come from OR)
+        if (!isZOutput(out) || out === lastZ) {
+          swapped.add(out);
+        }
+      }
+    } else if (g.op === 'AND') {
+      if (isBit0XY(g)) {
+        // Bit 0 AND: produces the initial carry
+        // For multi-bit adders: should feed into XOR and AND at bit 1
+        // For 1-bit adders: output IS lastZ (z01)
+        if (maxInputBit === 0) {
+          // 1-bit adder: bit0 AND should output lastZ
+          if (out !== lastZ) {
+            swapped.add(out);
+          }
+        } else {
+          if (isZOutput(out)) {
+            swapped.add(out);
+          } else if (!isConsumedByOp(out, 'XOR') || !isConsumedByOp(out, 'AND')) {
+            swapped.add(out);
+          }
+        }
+      } else {
+        // AND gate (not bit 0): produces either generate or propagate
+        // Both should feed into an OR gate
+        if (isZOutput(out)) {
+          swapped.add(out);
+        } else if (!isConsumedByOp(out, 'OR')) {
+          swapped.add(out);
+        }
+      }
+    } else if (g.op === 'OR') {
+      // OR gate: produces carry-out
+      // Should NOT output z (except the last z which is the final carry)
+      if (isZOutput(out) && out !== lastZ) {
+        swapped.add(out);
+      }
+      // Carry should feed into XOR and AND (for next bit's sum and propagate)
+      // Unless it's the last carry (which is lastZ)
+      if (out !== lastZ && (!isConsumedByOp(out, 'XOR') || !isConsumedByOp(out, 'AND'))) {
+        swapped.add(out);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
