@@ -0,0 +1,61 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const { config, files } = ctx;
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Sort files by date, newest first; files without dates go to the end
+        const sortedFiles = [...files].sort((a, b) => {
+          if (!a.date && !b.date) return 0;
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return new Date(b.date).getTime() - new Date(a.date).getTime();
+        });
+
+        const items = sortedFiles.map(file => {
+          const categories: string[] = [];
+          if (file.tags && tagMap) {
+            for (const tag of file.tags) {
+              const normalizedTag = tag.toLowerCase();
+              if (tagMap.has(normalizedTag)) {
+                categories.push(normalizedTag);
+              }
+            }
+          }
+
+          const categoryXml = categories
+            .map(cat => `        <category>${cat}</category>`)
+            .join('\n');
+
+          const pubDate = file.date
+            ? `        <pubDate>${new Date(file.date).toUTCString()}</pubDate>\n`
+            : '';
+
+          return `      <item>
+        <title>${file.title}</title>
+        <link>${config.baseUrl}/${file.slug}.html</link>
+        <description><![CDATA[${file.content}]]></description>
+${pubDate}${categoryXml ? categoryXml + '\n' : ''}      </item>`;
+        }).join('\n');
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${config.title}</title>
+    <link>${config.baseUrl}</link>
+    <description>${config.title} RSS Feed</description>
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
