+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ACPJ21Fh2D993nqq3fYRNB","type":"tool_result","content":"File created successfully at: /workspace/src/server.test.ts"}]},"parent_tool_use_id":null,"session_id":"8cc3cc01-e45e-4f12-8193-6b3e24b59e10","uuid":"0f1fcde7-143b-40c4-aa2e-52c396350312","tool_use_result":{"type":"create","filePath":"/workspace/src/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport { createApp, type AppInstance } from './server.js';\nimport WebSocket from 'ws';\n\nlet app: AppInstance;\nlet port: number;\nlet baseUrl: string;\n\nbeforeEach(async () => {\n  app = createApp(); // in-memory DB\n  port = await app.start(0);\n  baseUrl = `http://localhost:${port}`;\n});\n\nafterEach(async () => {\n  await app.stop();\n});\n\n// Helper to make HTTP requests\nasync function request(path: string, options?: RequestInit) {\n  const res = await fetch(`${baseUrl}${path}`, {\n    ...options,\n    headers: {\n      'Content-Type': 'application/json',\n      ...options?.headers,\n    },\n  });\n  return res;\n}\n\n// Helper to connect via WebSocket\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\n// Helper to wait for a specific message type\nfunction waitForMessage(ws: WebSocket, type: string, timeout = 5000): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error(`Timeout waiting for ${type}`)), timeout);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === type) {\n        clearTimeout(timer);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\n// Helper to collect all messages for a duration\nfunction collectMessages(ws: WebSocket, duration: number): Promise<Record<string, unknown>[]> {\n  return new Promise((resolve) => {\n    const msgs: Record<string, unknown>[] = [];\n    const handler = (data: WebSocket.Data) => {\n      msgs.push(JSON.parse(data.toString()));\n    };\n    ws.on('message', handler);\n    setTimeout(() => {\n      ws.off('message', handler);\n      resolve(msgs);\n    }, duration);\n  });\n}\n\ndescribe('REST API', () => {\n  it('should create a document', async () => {\n    const res = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('should reject document creation without title', async () => {\n    const res = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ content: 'Hello' }),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('should list documents', async () => {\n    await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Doc 1' }),\n    });\n    await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Doc 2' }),\n    });\n\n    const res = await request('/documents');\n    expect(res.status).toBe(200);\n    const docs = await res.json();\n    expect(docs).toHaveLength(2);\n  });\n\n  it('should get a single document', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'My Doc', content: 'Content here' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(`/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('My Doc');\n    expect(doc.content).toBe('Content here');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await request('/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Original', content: '' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(`/documents/${created.id}`, {\n      method: 'PUT',\n      body: JSON.stringify({ title: 'Updated', content: 'New content' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Updated');\n    expect(doc.content).toBe('New content');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'To Delete' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(`/documents/${created.id}`, { method: 'DELETE' });\n    expect(res.status).toBe(204);\n\n    const getRes = await request(`/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should get version history', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Versioned', content: 'v0' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(`/documents/${created.id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = await res.json();\n    expect(versions.length).toBeGreaterThanOrEqual(1);\n    expect(versions[0].version).toBe(0);\n    expect(versions[0].content).toBe('v0');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('should receive sync message on connect', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'WS Test', content: 'Initial' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const syncMsg = await waitForMessage(ws, 'sync');\n\n    expect(syncMsg.type).toBe('sync');\n    expect((syncMsg.document as Record<string, unknown>).content).toBe('Initial');\n    expect(syncMsg.version).toBe(0);\n\n    ws.close();\n  });\n\n  it('should reject connection for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent`);\n    const msg = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        resolve(JSON.parse(data.toString()));\n      });\n    });\n    expect(msg.type).toBe('error');\n    ws.close();\n  });\n\n  it('should apply an insert operation', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Edit Test', content: 'Hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      clientId: 'client1',\n      version: 0,\n      operation: { type: 'insert', position: 5, text: ' World' },\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const getRes = await request(`/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe('Hello World');\n\n    ws.close();\n  });\n\n  it('should apply a delete operation', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Delete Test', content: 'Hello World' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      clientId: 'client1',\n      version: 0,\n      operation: { type: 'delete', position: 5, length: 6 },\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe('Hello');\n\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Broadcast', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2, 'sync');\n\n    // ws2 listens for operation broadcast\n    const opPromise = waitForMessage(ws2, 'operation');\n\n    ws1.send(JSON.stringify({\n      clientId: 'client1',\n      version: 0,\n      operation: { type: 'insert', position: 0, text: 'Hello' },\n    }));\n\n    const opMsg = await opPromise;\n    expect(opMsg.type).toBe('operation');\n    expect(opMsg.clientId).toBe('client1');\n    expect((opMsg.operation as Record<string, unknown>).type).toBe('insert');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits from two clients', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Concurrent', content: 'Hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2, 'sync');\n\n    // Both clients send operations based on version 0\n    // Client 1: Insert \" World\" at position 5\n    // Client 2: Insert \"!\" at position 5\n    const ack1Promise = waitForMessage(ws1, 'ack');\n\n    ws1.send(JSON.stringify({\n      clientId: 'client1',\n      version: 0,\n      operation: { type: 'insert', position: 5, text: ' World' },\n    }));\n\n    await ack1Promise; // Wait for first op to be processed\n\n    const ack2Promise = waitForMessage(ws2, 'ack');\n    ws2.send(JSON.stringify({\n      clientId: 'client2',\n      version: 0,\n      operation: { type: 'insert', position: 5, text: '!' },\n    }));\n\n    await ack2Promise;\n\n    // Give a moment for all messages to propagate\n    await new Promise((r) => setTimeout(r, 100));\n\n    // Verify the final document contains both insertions\n    const getRes = await request(`/documents/${doc.id}`);\n    const final = await getRes.json();\n    expect(final.content).toContain('World');\n    expect(final.content).toContain('!');\n    expect(final.content).toContain('Hello');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Invalid', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws, 'sync');\n\n    // Send invalid JSON\n    ws.send('not json');\n    const err1 = await waitForMessage(ws, 'error');\n    expect(err1.type).toBe('error');\n\n    // Send invalid operation format\n    ws.send(JSON.stringify({ foo: 'bar' }));\n    const err2 = await waitForMessage(ws, 'error');\n    expect(err2.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Stress Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const clients: WebSocket[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(doc.id);\n      await waitForMessage(ws, 'sync');\n      clients.push(ws);\n    }\n\n    // Each client inserts its number sequentially\n    for (let i = 0; i < 10; i++) {\n      const ackPromise = waitForMessage(clients[i], 'ack');\n      clients[i].send(JSON.stringify({\n        clientId: `client${i}`,\n        version: i,\n        operation: { type: 'insert', position: i, text: String(i) },\n      }));\n      await ackPromise;\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    // Verify document has all digits\n    const getRes = await request(`/documents/${doc.id}`);\n    const final = await getRes.json();\n    for (let i = 0; i < 10; i++) {\n      expect(final.content).toContain(String(i));\n    }\n    expect(final.content).toHaveLength(10);\n\n    for (const c of clients) c.close();\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across restarts', async () => {\n    const tmpDb = `/tmp/test-collab-${Date.now()}.db`;\n\n    // Start first server instance\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n    const url1 = `http://localhost:${port1}`;\n\n    // Create a document\n    const createRes = await fetch(`${url1}/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persistent', content: 'Survives restart' }),\n    });\n    const doc = await createRes.json();\n\n    // Stop first server\n    await app1.stop();\n\n    // Start second server instance with same db\n    const app2 = createApp(tmpDb);\n    const port2 = await app2.start(0);\n    const url2 = `http://localhost:${port2}`;\n\n    // Document should still exist\n    const getRes = await fetch(`${url2}/documents/${doc.id}`);\n    expect(getRes.status).toBe(200);\n    const retrieved = await getRes.json();\n    expect(retrieved.title).toBe('Persistent');\n    expect(retrieved.content).toBe('Survives restart');\n\n    await app2.stop();\n\n    // Clean up\n    const fs = await import('fs');\n    try { fs.unlinkSync(tmpDb); } catch { /* ignore */ }\n  });\n});\n\ndescribe('OT correctness', () => {\n  it('should converge with simultaneous inserts at same position', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'OT Test', content: 'AB' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2, 'sync');\n\n    // Both insert at position 1, both based on version 0\n    const ack1 = waitForMessage(ws1, 'ack');\n    ws1.send(JSON.stringify({\n      clientId: 'c1',\n      version: 0,\n      operation: { type: 'insert', position: 1, text: 'X' },\n    }));\n    await ack1;\n\n    const ack2 = waitForMessage(ws2, 'ack');\n    ws2.send(JSON.stringify({\n      clientId: 'c2',\n      version: 0,\n      operation: { type: 'insert', position: 1, text: 'Y' },\n    }));\n    await ack2;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const final = await getRes.json();\n    // Both X and Y should be present\n    expect(final.content).toContain('A');\n    expect(final.content).toContain('B');\n    expect(final.content).toContain('X');\n    expect(final.content).toContain('Y');\n    expect(final.content).toHaveLength(4);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle insert and delete at overlapping positions', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'OT Overlap', content: 'ABCDE' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1: Insert 'X' at position 2 (between B and C)\n    const ack1 = waitForMessage(ws1, 'ack');\n    ws1.send(JSON.stringify({\n      clientId: 'c1',\n      version: 0,\n      operation: { type: 'insert', position: 2, text: 'X' },\n    }));\n    await ack1;\n\n    // Client 2: Delete 'C' (position 2, length 1) based on version 0\n    const ack2 = waitForMessage(ws2, 'ack');\n    ws2.send(JSON.stringify({\n      clientId: 'c2',\n      version: 0,\n      operation: { type: 'delete', position: 2, length: 1 },\n    }));\n    await ack2;\n\n    await new Promise((r) => setTimeout(r, 100));\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const final = await getRes.json();\n    // Should have: A, B, X (inserted), D, E (C was deleted)\n    expect(final.content).toContain('A');\n    expect(final.content).toContain('B');\n    expect(final.content).toContain('X');\n    expect(final.content).toContain('D');\n    expect(final.content).toContain('E');\n    expect(final.content).not.toContain('C');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle version history growing with edits via WebSocket', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Versions', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws, 'sync');\n\n    // Send 3 sequential operations\n    for (let i = 0; i < 3; i++) {\n      const ackPromise = waitForMessage(ws, 'ack');\n      ws.send(JSON.stringify({\n        clientId: 'c1',\n        version: i,\n        operation: { type: 'insert', position: i, text: String.fromCharCode(65 + i) },\n      }));\n      await ackPromise;\n    }\n\n    const versionsRes = await request(`/documents/${doc.id}/versions`);\n    const versions = await versionsRes.json();\n    // version 0 (initial) + 3 edits = 4 versions\n    expect(versions).toHaveLength(4);\n\n    ws.close();\n  });\n});\n\ndescribe('Edge cases', () => {\n  it('should handle empty document operations', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Empty', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      clientId: 'c1',\n      version: 0,\n      operation: { type: 'insert', position: 0, text: 'First' },\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    const getRes = await request(`/documents/${doc.id}`);\n    const final = await getRes.json();\n    expect(final.content).toBe('First');\n\n    ws.close();\n  });\n\n  it('should handle client disconnect gracefully', async () => {\n    const createRes = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Disconnect', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(doc.id);\n    await waitForMessage(ws2, 'sync');\n\n    // Disconnect ws1\n    ws1.close();\n    await new Promise((r) => setTimeout(r, 100));\n\n    // ws2 should still be able to send operations\n    ws2.send(JSON.stringify({\n      clientId: 'c2',\n      version: 0,\n      operation: { type: 'insert', position: 0, text: 'Still works' },\n    }));\n\n    const ack = await waitForMessage(ws2, 'ack');\n    expect(ack.version).toBe(1);\n\n    ws2.close();\n  });\n\n  it('should create document with default empty content', async () => {\n    const res = await request('/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'No Content' }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.content).toBe('');\n  });\n});\n","structuredPatch":[],"originalFile":null}}
