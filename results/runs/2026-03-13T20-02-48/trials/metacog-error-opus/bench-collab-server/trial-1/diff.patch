+++ b/src/websocket.ts
@@ -0,0 +1,201 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server } from 'http';
+import type { DatabaseLayer } from './database.js';
+import {
+  applyOperation,
+  transformAgainstOps,
+  validateClientOperation,
+  type Operation,
+  type ClientOperation,
+} from './ot.js';
+
+interface DocumentSession {
+  /** Current server version for this document */
+  version: number;
+  /** History of operations applied since document was loaded, indexed by version */
+  operations: Operation[];
+  /** Connected clients */
+  clients: Set<WebSocket>;
+}
+
+export interface WebSocketManager {
+  wss: WebSocketServer;
+  close(): void;
+}
+
+export function setupWebSocket(server: Server, db: DatabaseLayer): WebSocketManager {
+  const sessions = new Map<string, DocumentSession>();
+
+  const wss = new WebSocketServer({ server });
+
+  wss.on('connection', (ws: WebSocket, req) => {
+    const url = req.url || '';
+    // Expected URL pattern: /documents/:id or /ws/documents/:id
+    const match = url.match(/\/(?:ws\/)?documents\/([^/?]+)/);
+    if (!match) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid URL. Use /documents/:id' }));
+      ws.close();
+      return;
+    }
+
+    const docId = match[1];
+    const doc = db.getDocument(docId);
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    // Get or create session
+    let session = sessions.get(docId);
+    if (!session) {
+      const latestVersion = db.getLatestVersion(docId);
+      session = {
+        version: latestVersion,
+        operations: [],
+        clients: new Set(),
+      };
+      sessions.set(docId, session);
+    }
+
+    session.clients.add(ws);
+
+    // Send initial sync with current document state
+    ws.send(JSON.stringify({
+      type: 'sync',
+      document: {
+        id: doc.id,
+        title: doc.title,
+        content: doc.content,
+      },
+      version: session.version,
+    }));
+
+    ws.on('message', (data) => {
+      try {
+        const raw = data.toString();
+        let msg: unknown;
+        try {
+          msg = JSON.parse(raw);
+        } catch {
+          ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+          return;
+        }
+
+        if (!validateClientOperation(msg)) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation format' }));
+          return;
+        }
+
+        const clientOp = msg as ClientOperation;
+        const currentSession = sessions.get(docId);
+        if (!currentSession) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Session not found' }));
+          return;
+        }
+
+        // The client's operation is based on clientOp.version.
+        // We need to transform it against all operations that happened since then.
+        if (clientOp.version < 0 || clientOp.version > currentSession.version) {
+          ws.send(JSON.stringify({
+            type: 'error',
+            message: `Invalid version. Expected 0-${currentSession.version}, got ${clientOp.version}`,
+          }));
+          return;
+        }
+
+        // Get all operations that happened since the client's version
+        const opsToTransformAgainst = currentSession.operations.slice(clientOp.version);
+
+        // Transform the client's operation against the concurrent ops
+        const transformedOp = opsToTransformAgainst.length > 0
+          ? transformAgainstOps(clientOp.operation, opsToTransformAgainst)
+          : clientOp.operation;
+
+        // Apply to document
+        const currentDoc = db.getDocument(docId);
+        if (!currentDoc) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Document no longer exists' }));
+          return;
+        }
+
+        let newContent: string;
+        try {
+          newContent = applyOperation(currentDoc.content, transformedOp);
+        } catch (e) {
+          ws.send(JSON.stringify({
+            type: 'error',
+            message: `Failed to apply operation: ${e instanceof Error ? e.message : 'unknown error'}`,
+          }));
+          return;
+        }
+
+        // Update document and version
+        currentSession.version++;
+        currentSession.operations.push(transformedOp);
+        db.updateDocumentContent(docId, newContent);
+        db.addVersion(
+          docId,
+          currentSession.version,
+          newContent,
+          JSON.stringify(transformedOp)
+        );
+
+        // Acknowledge to the sender
+        ws.send(JSON.stringify({
+          type: 'ack',
+          version: currentSession.version,
+        }));
+
+        // Broadcast to other clients
+        const broadcast = JSON.stringify({
+          type: 'operation',
+          clientId: clientOp.clientId,
+          version: currentSession.version,
+          operation: transformedOp,
+        });
+
+        for (const client of currentSession.clients) {
+          if (client !== ws && client.readyState === WebSocket.OPEN) {
+            client.send(broadcast);
+          }
+        }
+      } catch (e) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          message: `Server error: ${e instanceof Error ? e.message : 'unknown'}`,
+        }));
+      }
+    });
+
+    ws.on('close', () => {
+      const s = sessions.get(docId);
+      if (s) {
+        s.clients.delete(ws);
+        if (s.clients.size === 0) {
+          sessions.delete(docId);
+        }
+      }
+    });
+
+    ws.on('error', () => {
+      const s = sessions.get(docId);
+      if (s) {
+        s.clients.delete(ws);
+      }
+    });
+  });
+
+  return {
+    wss,
+    close() {
+      for (const [, session] of sessions) {
+        for (const client of session.clients) {
+          client.close();
+        }
+      }
+      sessions.clear();
+      wss.close();
+    },
+  };
+}
