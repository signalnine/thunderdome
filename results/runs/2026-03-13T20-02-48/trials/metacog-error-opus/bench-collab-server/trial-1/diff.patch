+    });
+    const doc = await createRes.json();
+
+    const { ws: ws1 } = await connectWs(doc.id);
+    const { ws: ws2 } = await connectWs(doc.id);
+
+    // Client 1: Insert 'X' at position 2 (between B and C)
+    const ack1 = waitForMessage(ws1, 'ack');
+    ws1.send(JSON.stringify({
+      clientId: 'c1',
+      version: 0,
+      operation: { type: 'insert', position: 2, text: 'X' },
+    }));
+    await ack1;
+
+    // Client 2: Delete 'C' (position 2, length 1) based on version 0
+    const ack2 = waitForMessage(ws2, 'ack');
+    ws2.send(JSON.stringify({
+      clientId: 'c2',
+      version: 0,
+      operation: { type: 'delete', position: 2, length: 1 },
+    }));
+    await ack2;
+
+    await new Promise((r) => setTimeout(r, 100));
+
+    const getRes = await request(`/documents/${doc.id}`);
+    const final = await getRes.json();
+    expect(final.content).toContain('A');
+    expect(final.content).toContain('B');
+    expect(final.content).toContain('X');
+    expect(final.content).toContain('D');
+    expect(final.content).toContain('E');
+    expect(final.content).not.toContain('C');
+
+    ws1.close();
+    ws2.close();
+  });
+
+  it('should handle version history growing with edits via WebSocket', async () => {
+    const createRes = await request('/documents', {
+      method: 'POST',
+      body: JSON.stringify({ title: 'Versions', content: '' }),
+    });
+    const doc = await createRes.json();
+
+    const { ws } = await connectWs(doc.id);
+
+    // Send 3 sequential operations
+    for (let i = 0; i < 3; i++) {
+      const ackPromise = waitForMessage(ws, 'ack');
+      ws.send(JSON.stringify({
+        clientId: 'c1',
+        version: i,
+        operation: { type: 'insert', position: i, text: String.fromCharCode(65 + i) },
+      }));
+      await ackPromise;
+    }
+
+    const versionsRes = await request(`/documents/${doc.id}/versions`);
+    const versions = await versionsRes.json();
+    expect(versions).toHaveLength(4);
+
+    ws.close();
+  });
+});
+
+describe('Edge cases', () => {
+  it('should handle empty document operations', async () => {
+    const createRes = await request('/documents', {
+      method: 'POST',
+      body: JSON.stringify({ title: 'Empty', content: '' }),
