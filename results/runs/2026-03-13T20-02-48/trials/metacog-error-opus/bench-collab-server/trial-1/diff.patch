+import express from 'express';
+import { createServer, type Server } from 'http';
+import { createDatabase, type DatabaseLayer } from './database.js';
+import { createRouter } from './routes.js';
+import { setupWebSocket, type WebSocketManager } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const app = express();
+  const db: DatabaseLayer = createDatabase(dbPath);
+  const router = createRouter(db);
+
+  app.use('/api', router);
+  // Also mount at root for convenience
+  app.use(router);
+
+  let server: Server | null = null;
+  let wsManager: WebSocketManager | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve, reject) => {
+        server = createServer(app);
+        wsManager = setupWebSocket(server, db);
+
+        server.on('error', reject);
+        server.listen(port ?? 0, () => {
+          const addr = server!.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Failed to get server address'));
+          }
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      return new Promise((resolve) => {
+        if (wsManager) {
+          wsManager.close();
+          wsManager = null;
+        }
+        if (server) {
+          server.close(() => {
+            db.close();
+            resolve();
+          });
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    },
+  };
+}
