ts', async () => {\n   254→    const createRes = await request('/documents', {\n   255→      method: 'POST',\n   256→      body: JSON.stringify({ title: 'Broadcast', content: '' }),\n   257→    });\n   258→    const doc = await createRes.json();\n   259→\n   260→    const { ws: ws1 } = await connectWs(doc.id);\n   261→    const { ws: ws2 } = await connectWs(doc.id);\n   262→\n   263→    // ws2 listens for operation broadcast\n   264→    const opPromise = waitForMessage(ws2, 'operation');\n   265→\n   266→    ws1.send(JSON.stringify({\n   267→      clientId: 'client1',\n   268→      version: 0,\n   269→      operation: { type: 'insert', position: 0, text: 'Hello' },\n   270→    }));\n   271→\n   272→    const opMsg = await opPromise;\n   273→    expect(opMsg.type).toBe('operation');\n   274→    expect(opMsg.clientId).toBe('client1');\n   275→    expect((opMsg.operation as Record<string, unknown>).type).toBe('insert');\n   276→\n   277→    ws1.close();\n   278→    ws2.close();\n   279→  });\n   280→\n   281→  it('should handle concurrent edits from two clients', async () => {\n   282→    const createRes = await request('/documents', {\n   283→      method: 'POST',\n   284→      body: JSON.stringify({ title: 'Concurrent', content: 'Hello' }),\n   285→    });\n   286→    const doc = await createRes.json();\n   287→\n   288→    const { ws: ws1 } = await connectWs(doc.id);\n   289→    const { ws: ws2 } = await connectWs(doc.id);\n   290→\n   291→    // Both clients send operations based on version 0\n   292→    const ack1Promise = waitForMessage(ws1, 'ack');\n   293→\n   294→    ws1.send(JSON.stringify({\n   295→      clientId: 'client1',\n   296→      version: 0,\n   297→      operation: { type: 'insert', position: 5, text: ' World' },\n   298→    }));\n   299→\n   300→    await ack1Promise;\n   301→\n   302→    const ack2Promise = waitForMessage(ws2, 'ack');\n   303→    ws2.send(JSON.stringify({\n   304→      clientId: 'client2',\n   305→      version: 0,\n   306→      operation: { type: 'insert', position: 5, text: '!' },\n   307→    }));\n   308→\n   309→    await ack2Promise;\n   310→\n   311→    await new Promise((r) => setTimeout(r, 100));\n   312→\n   313→    const getRes = await request(`/documents/${doc.id}`);\n   314→    const final = await getRes.json();\n   315→    expect(final.content).toContain('World');\n   316→    expect(final.content).toContain('!');\n   317→    expect(final.content).toContain('Hello');\n   318→\n   319→    ws1.close();\n   320→    ws2.close();\n   321→  });\n   322→\n   323→  it('should reject invalid operations', async () => {\n   324→    const createRes = await request('/documents', {\n   325→      method: 'POST',\n   326→      body: JSON.stringify({ title: 'Invalid', content: '' }),\n   327→    });\n   328→    const doc = await createRes.json();\n   329→\n   330→    const { ws } = await connectWs(doc.id);\n   331→\n   332→    // Send invalid JSON\n   333→    ws.send('not json');\n   334→    const err1 = await waitForMessage(ws, 'error');\n   335→    expect(err1.type).toBe('error');\n   336→\n   337→    // Send invalid operation format\n   338→    ws.send(JSON.stringify({ foo: 'bar' }));\n   339→    const err2 = await waitForMessage(ws, 'error');\n   340→    expect(err2.type).toBe('error');\n   341→\n   342→    ws.close();\n   343→  });\n   344→\n   345→  it('should handle 10 concurrent clients', async () => {\n   346→    const createRes = await request('/documents', {\n   347→      method: 'POST',\n   348→      body: JSON.stringify({ title: 'Stress Test', content: '' }),\n   349→    });\n   350→    const doc = await createRes.json();\n   351→\n   352→    const clients: WebSocket[] = [];\n   353→    for (let i = 0; i < 10; i++) {\n   354→      const { ws } = await connectWs(doc.id);\n   355→      clients.push(ws);\n   356→    }\n   357→\n   358→    // Each client inserts its number sequentially\n   359→    for (let i = 0; i < 10; i++) {\n   360→      const ackPromise = waitForMessage(clients[i],