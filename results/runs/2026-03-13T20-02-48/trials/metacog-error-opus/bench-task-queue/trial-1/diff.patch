y check\n      this.detectCircularDependency(task.id, task.dependencies);\n    }\n\n    this.tasks.set(task.id, task as Task);\n\n    const queueName = task.queue;\n    if (!this.queues.has(queueName)) {\n      this.queues.set(queueName, []);\n    }\n    this.queues.get(queueName)!.push(task.id);\n\n    return task;\n  }\n\n  getNextTask(queueName = 'default'): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue || queue.length === 0) return null;\n\n    // Phase 8: Check concurrency limit\n    const limit = this.concurrencyLimits.get(queueName);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = new Date();\n\n    // Find best candidate considering priority, availability, dependencies\n    let bestIndex = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < queue.length; i++) {\n      const task = this.tasks.get(queue[i]);\n      if (!task || task.status !== 'pending') continue;\n\n      // Phase 4: Check availability time\n      if (task.availableAt > now) continue;\n\n      // Phase 7: Check dependencies\n      if (task.dependencies.length > 0 && !this.areDependenciesMet(task)) continue;\n\n      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {\n        bestIndex = i;\n        bestTask = task;\n      }\n    }\n\n    if (bestIndex === -1 || bestTask === null) return null;\n\n    // Remove from queue and transition to processing\n    queue.splice(bestIndex, 1);\n    bestTask.status = 'processing';\n    bestTask.attempt += 1;\n\n    return bestTask;\n  }\n\n  getPendingCount(queueName = 'default'): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    return queue.filter(id => {\n      const task = this.tasks.get(id);\n      return task && task.status === 'pending';\n    }).length;\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // --- Phase 2: Named Queues ---\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // --- Phase 5: Retry with Backoff ---\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n    task.status = 'completed';\n    task.progress = 100;\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n    task.failureCount += 1;\n\n    if (task.attempt <= task.maxRetries) {\n      // Re-add to queue with exponential backoff delay\n      const backoffDelay = task.baseDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + backoffDelay);\n      task.progress = 0;\n\n      const queue = this.queues.get(task.queue);\n      if (queue) {\n        queue.push(task.id);\n      }\n    } else {\n      // Phase 6: Move to DLQ\n      task.status = 'failed';\n      if (!this.dlqs.has(task.queue)) {\n        this.dlqs.set(task.queue, []);\n      }\n      this.dlqs.get(task.queue)!.push(task.id);\n    }\n  }\n\n  // --- Phase 6: Dead Letter Queue ---\n\n  getDeadLetterTasks(queueName = 'default'): Task[] {\n    const dlq = this.dlqs.get(queueName);\n    if (!dlq) return [];\n    return dlq.map(id => this.tasks.get(id)!).filter(Boolean);\n  }\n\n  retryDeadLetterTask(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'failed') {\n      throw new Error(`Task is not in dead letter queue: ${taskId}`);\n    }\n\n    // Remove from DLQ\n    const dlq = this.dlqs.get(task.queue);\n    if (dlq) {\n      const idx = dlq.indexOf(taskId);\n      if (idx !== -1) dlq.splice(idx, 1);\n    }\n\n    // Reset for fresh retries\n    task.status = 'pending';\n    task.attempt = 0;\n    task.failureCount = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n    task.progress = 0;\n\n    const queue = this.queues.get(task.queue);\n    if (queue) {\n      queue.push(task.id);\n    }\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName = 'default'): void {\n    const dlq = this.dlqs.get(queueName);\n    if (dlq) {\n      for (const id of dlq) {\n        this.tasks.delete(id);\n      }\n      this.dlqs.set(queueName, []);\n    }\n  }\n\n  // --- Phase 7: Task Dependencies ---\n\n  private detectCircularDependency(newTaskId: string, dependencies: string[]): void {\n    const visited = new Set<string>();\n    const stack = [...dependencies];\n\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === newTaskId) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n\n      const depTask = this.tasks.get(current);\n      if (depTask) {\n        for (const dep of depTask.dependencies) {\n          stack.push(dep);\n        }\n      }\n    }\n  }\n\n  private areDependenciesMet(task: Task): boolean {\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus; met: boolean }[] {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    return task.dependencies.map(depId => {\n      const dep = this.tasks.get(depId);\n      return {\n        taskId: depId,\n        status: dep ? dep.status : 'failed' as 