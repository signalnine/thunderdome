@@ -0,0 +1,76 @@
+export function parseCron(expression: string): { minute: number | null; hour: number | null; interval: number | null } {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: ${expression}`);
+  }
+
+  const [minutePart, hourPart, dayOfMonth, month, dayOfWeek] = parts;
+
+  if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {
+    throw new Error(`Unsupported cron expression: ${expression}. Only minute and hour fields are supported.`);
+  }
+
+  // */N * * * * - every N minutes
+  const intervalMatch = minutePart.match(/^\*\/(\d+)$/);
+  if (intervalMatch) {
+    if (hourPart !== '*') {
+      throw new Error(`Unsupported cron expression: ${expression}`);
+    }
+    return { minute: null, hour: null, interval: parseInt(intervalMatch[1], 10) };
+  }
+
+  // Specific minute
+  const minute = minutePart === '*' ? null : parseInt(minutePart, 10);
+  if (minute !== null && (isNaN(minute) || minute < 0 || minute > 59)) {
+    throw new Error(`Invalid minute in cron expression: ${expression}`);
+  }
+
+  // Specific hour
+  const hour = hourPart === '*' ? null : parseInt(hourPart, 10);
+  if (hour !== null && (isNaN(hour) || hour < 0 || hour > 23)) {
+    throw new Error(`Invalid hour in cron expression: ${expression}`);
+  }
+
+  return { minute, hour, interval: null };
+}
+
+export function shouldRun(expression: string, now: Date, lastRun?: Date): boolean {
+  const { minute, hour, interval } = parseCron(expression);
+
+  if (interval !== null) {
+    // */N * * * * - every N minutes
+    if (!lastRun) return true;
+    const diffMs = now.getTime() - lastRun.getTime();
+    const diffMinutes = diffMs / (1000 * 60);
+    return diffMinutes >= interval;
+  }
+
+  // For fixed time expressions: 0 * * * * or 0 0 * * *
+  const nowMinute = now.getMinutes();
+  const nowHour = now.getHours();
+
+  if (minute !== null && nowMinute !== minute) return false;
+  if (hour !== null && nowHour !== hour) return false;
+
+  // Check that we haven't already run in this matching window
+  if (lastRun) {
+    const lastMinute = lastRun.getMinutes();
+    const lastHour = lastRun.getHours();
+    const lastDate = lastRun.toDateString();
+    const nowDate = now.toDateString();
+
+    if (hour !== null && minute !== null) {
+      // 0 0 * * * - daily at midnight: same date means already ran
+      if (lastDate === nowDate && lastHour === hour && lastMinute === minute) return false;
+    } else if (minute !== null) {
+      // 0 * * * * - every hour at minute 0
+      if (lastDate === nowDate && lastHour === nowHour && lastMinute === minute) return false;
+      // Different day is fine
+      if (lastDate !== nowDate) return true;
+      // Same day but different hour
+      return lastHour !== nowHour;
+    }
+  }
+
+  return true;
+}
