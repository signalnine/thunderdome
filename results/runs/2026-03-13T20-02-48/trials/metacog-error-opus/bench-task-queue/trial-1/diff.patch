@@ -0,0 +1,82 @@
+import { randomUUID } from 'node:crypto';
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  maxRetries: number;
+  baseDelay: number;
+  attempt: number;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue'>;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void>;
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export function createTask<T>(payload: T, options: TaskOptions = {}): Task<T> {
+  const now = new Date();
+  const priority = options.priority ?? 5;
+
+  if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+    throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+  }
+
+  let availableAt = now;
+  if (options.availableAt) {
+    availableAt = options.availableAt;
+  } else if (options.delay !== undefined && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  }
+
+  return {
+    id: randomUUID(),
+    payload,
+    status: 'pending',
+    createdAt: now,
+    queue: options.queue ?? 'default',
+    priority,
+    availableAt,
+    maxRetries: options.maxRetries ?? 3,
+    baseDelay: options.baseDelay ?? 1000,
+    attempt: 0,
+    failureCount: 0,
+    dependencies: options.dependencies ? [...options.dependencies] : [],
+    progress: 0,
+  };
+}
