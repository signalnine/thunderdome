+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01EZ3H1qVCeCXxLAJzP3Jm8K","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KHnbZaDAvPHrWRNS16wxC7","name":"Write","input":{"file_path":"/workspace/tests/task-queue.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\nlet tq: TaskQueue;\n\nbeforeEach(() => {\n  tq = new TaskQueue();\n});\n\n// ============================================================\n// Phase 1: Basic FIFO Queue\n// ============================================================\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  it('should add a task and return a task object with required fields', () => {\n    const task = tq.addTask({ message: 'hello' });\n    expect(task.id).toBeDefined();\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n    expect(task.payload).toEqual({ message: 'hello' });\n  });\n\n  it('should assign unique IDs to each task', () => {\n    const t1 = tq.addTask('a');\n    const t2 = tq.addTask('b');\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  it('should retrieve tasks in FIFO order', () => {\n    tq.addTask('first');\n    tq.addTask('second');\n    tq.addTask('third');\n\n    expect(tq.getNextTask()?.payload).toBe('first');\n    expect(tq.getNextTask()?.payload).toBe('second');\n    expect(tq.getNextTask()?.payload).toBe('third');\n  });\n\n  it('should transition task to processing on retrieval', () => {\n    const added = tq.addTask('work');\n    const retrieved = tq.getNextTask();\n    expect(retrieved?.id).toBe(added.id);\n    expect(retrieved?.status).toBe('processing');\n  });\n\n  it('should return null when queue is empty', () => {\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should return null when all tasks are processing', () => {\n    tq.addTask('a');\n    tq.getNextTask();\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should count pending tasks', () => {\n    expect(tq.getPendingCount()).toBe(0);\n    tq.addTask('a');\n    tq.addTask('b');\n    expect(tq.getPendingCount()).toBe(2);\n    tq.getNextTask();\n    expect(tq.getPendingCount()).toBe(1);\n  });\n\n  it('should retrieve a task by ID', () => {\n    const added = tq.addTask('find me');\n    const found = tq.getTask(added.id);\n    expect(found).toBeDefined();\n    expect(found?.payload).toBe('find me');\n  });\n});\n\n// ============================================================\n// Phase 2: Named Queues\n// ============================================================\ndescribe('Phase 2: Named Queues', () => {\n  it('should use default queue when no name specified', () => {\n    tq.addTask('default task');\n    const task = tq.getNextTask();\n    expect(task?.queue).toBe('default');\n  });\n\n  it('should support named queues independently', () => {\n    tq.addTask('email', { queue: 'emails' });\n    tq.addTask('sms', { queue: 'sms' });\n\n    expect(tq.getNextTask('emails')?.payload).toBe('email');\n    expect(tq.getNextTask('sms')?.payload).toBe('sms');\n    expect(tq.getNextTask('emails')).toBeNull();\n  });\n\n  it('should list all queue names', () => {\n    tq.addTask('a', { queue: 'q1' });\n    tq.addTask('b', { queue: 'q2' });\n    const names = tq.getQueueNames();\n    expect(names).toContain('q1');\n    expect(names).toContain('q2');\n  });\n\n  it('should return null from non-existent queue', () => {\n    expect(tq.getNextTask('nonexistent')).toBeNull();\n  });\n\n  it('should be backward-compatible with Phase 1 API', () => {\n    tq.addTask('compat');\n    expect(tq.getNextTask()?.payload).toBe('compat');\n    expect(tq.getPendingCount()).toBe(0);\n  });\n});\n\n// ============================================================\n// Phase 3: Priority\n// ============================================================\ndescribe('Phase 3: Priority', () => {\n  it('should default priority to 5', () => {\n    const task = tq.addTask('normal');\n    expect(task.priority).toBe(5);\n  });\n\n  it('should return higher priority tasks first', () => {\n    tq.addTask('low', { priority: 10 });\n    tq.addTask('high', { priority: 1 });\n    tq.addTask('medium', { priority: 5 });\n\n    expect(tq.getNextTask()?.payload).toBe('high');\n    expect(tq.getNextTask()?.payload).toBe('medium');\n    expect(tq.getNextTask()?.payload).toBe('low');\n  });\n\n  it('should maintain FIFO within same priority', () => {\n    tq.addTask('first', { priority: 3 });\n    tq.addTask('second', { priority: 3 });\n    tq.addTask('third', { priority: 3 });\n\n    expect(tq.getNextTask()?.payload).toBe('first');\n    expect(tq.getNextTask()?.payload).toBe('second');\n    expect(tq.getNextTask()?.payload).toBe('third');\n  });\n\n  it('should reject invalid priority values', () => {\n    expect(() => tq.addTask('bad', { priority: 0 })).toThrow();\n    expect(() => tq.addTask('bad', { priority: 11 })).toThrow();\n    expect(() => tq.addTask('bad', { priority: 1.5 })).toThrow();\n  });\n\n  it('should apply priority per queue', () => {\n    tq.addTask('q1-low', { queue: 'q1', priority: 10 });\n    tq.addTask('q1-high', { queue: 'q1', priority: 1 });\n    tq.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n    expect(tq.getNextTask('q1')?.payload).toBe('q1-high');\n    expect(tq.getNextTask('q2')?.payload).toBe('q2-low');\n  });\n});\n\n// ============================================================\n// Phase 4: Delayed and Scheduled Tasks\n// ============================================================\ndescribe('Phase 4: Delayed and Scheduled Tasks', () => {\n  it('should not return delayed tasks before their availability time', () => {\n    tq.addTask('delayed', { delay: 60000 }); // 1 minute from now\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should return delayed tasks after availability time has passed', () => {\n    const task = tq.addTask('ready soon', { delay: 0 });\n    expect(task.availableAt.getTime()).toBeLessThanOrEqual(Date.now());\n    expect(tq.getNextTask()?.payload).toBe('ready soon');\n  });\n\n  it('should support availableAt as a specific date', () => {\n    const past = new Date(Date.now() - 1000);\n    tq.addTask('past task', { availableAt: past });\n    expect(tq.getNextTask()?.payload).toBe('past task');\n  });\n\n  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n    tq.addTask('delayed', { delay: 60000 });\n    tq.addTask('immediate');\n\n    expect(tq.getNextTask()?.payload).toBe('immediate');\n    expect(tq.getNextTask()).toBeNull(); // delayed still not available\n  });\n\n  it('should expose availableAt on the task object', () => {\n    const task = tq.addTask('check', { delay: 5000 });\n    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n  });\n\n  it('should order delayed tasks by availability time, then priority, then FIFO', () => {\n    const past1 = new Date(Date.now() - 3000);\n    const past2 = new Date(Date.now() - 2000);\n    const past3 = new Date(Date.now() - 1000);\n\n    tq.addTask('later-avail', { availableAt: past3, priority: 1 });\n    tq.addTask('earliest-avail', { availableAt: past1, priority: 5 });\n    tq.addTask('mid-avail', { availableAt: past2, priority: 5 });\n\n    // Priority takes precedence, so priority 1 task comes first\n    expect(tq.getNextTask()?.payload).toBe('later-avail');\n    // Then by availability time\n    expect(tq.getNextTask()?.payload).toBe('earliest-avail');\n    expect(tq.getNextTask()?.payload).toBe('mid-avail');\n  });\n});\n\n// ============================================================\n// Phase 5: Retry with Backoff\n// ============================================================\ndescribe('Phase 5: Retry with Backoff', () => {\n  it('should mark a task as completed', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n    tq.completeTask(task.id);\n    expect(tq.getTask(task.id)?.status).toBe('completed');\n  });\n\n  it('should mark a task as failed', () => {\n    const added = tq.addTask('work', { maxRetries: 0 });\n    const task = tq.getNextTask()!;\n    tq.failTask(task.id, 'something broke');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.status).toBe('failed');\n    expect(updated.error).toBe('something broke');\n  });\n\n  it('should retry failed tasks with exponential backoff', () => {\n    tq.addTask('retry me', { maxRetries: 3, baseDelay: 100 });\n    const task = tq.getNextTask()!;\n    expect(task.attempt).toBe(1);\n\n    tq.failTask(task.id, 'fail 1');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.status).toBe('pending');\n    expect(updated.attempt).toBe(1); // attempt stays, will increment on next getNextTask\n    // Task is delayed so it won't be immediately available\n    expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now() - 10);\n  });\n\n  it('should track attempt count', () => {\n    tq.addTask('track', { maxRetries: 2, baseDelay: 0 });\n    const t1 = tq.getNextTask()!;\n    expect(t1.attempt).toBe(1);\n\n    tq.failTask(t1.id, 'fail');\n    // Manually set availableAt to now for immediate retrieval\n    const task = tq.getTask(t1.id)!;\n    task.availableAt = new Date(Date.now() - 1);\n\n    const t2 = tq.getNextTask()!;\n    expect(t2.attempt).toBe(2);\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    tq.addTask('keep', { queue: 'special', priority: 2, maxRetries: 3, baseDelay: 0 });\n    const task = tq.getNextTask('special')!;\n    tq.failTask(task.id, 'fail');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.queue).toBe('special');\n    expect(updated.priority).toBe(2);\n  });\n\n  it('should fail permanently when retries exhausted', () => {\n    tq.addTask('exhaust', { maxRetries: 1, baseDelay: 0 });\n    const t1 = tq.getNextTask()!;\n    tq.failTask(t1.id, 'fail');\n\n    // Make available immediately\n    tq.getTask(t1.id)!.availableAt = new Date(Date.now() - 1);\n    const t2 = tq.getNextTask()!;\n    tq.failTask(t2.id, 'fail again');\n\n    expect(tq.getTask(t1.id)?.status).toBe('failed');\n  });\n\n  it('should default to 3 max retries', () => {\n    const task = tq.addTask('defaults');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default baseDelay to 1000ms', () => {\n    const task = tq.addTask('defaults');\n    expect(task.baseDelay).toBe(1000);\n  });\n});\n\n// ============================================================\n// Phase 6: Dead Letter Queue\n// ============================================================\ndescribe('Phase 6: Dead Letter Queue', () => {\n  it('should move permanently failed tasks to DLQ', () => {\n    tq.addTask('dlq me', { maxRetries: 1, baseDelay: 0 });\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'fail 1');\n    tq.getTask(t.id)!.availableAt = new Date(Date.now() - 1);\n    const t2 = tq.getNextTask()!;\n    tq.failTask(t2.id, 'fail 2');\n\n    const dlq = tq.getDeadLetterTasks();\n    expect(dlq.length).toBe(1);\n    expect(dlq[0].id).toBe(t.id);\n  });\n\n  it('should retain error info and failure count', () => {\n    tq.addTask('fail info', { maxRetries: 0 });\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'detailed error');\n\n    const dlq = tq.getDeadLetterTasks();\n    expect(dlq[0].error).toBe('detailed error');\n    expect(dlq[0].failureCount).toBe(1);\n  });\n\n  it('should retry dead-lettered tasks', () => {\n    tq.addTask('retry dlq', { maxRetries: 0 });\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'fail');\n\n    tq.retryDeadLetterTask(t.id);\n    const updated = tq.getTask(t.id)!;\n    expect(updated.status).toBe('pending');\n    expect(updated.attempt).toBe(0);\n    expect(updated.failureCount).toBe(0);\n    expect(tq.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('should clear DLQ for a queue', () => {\n    tq.addTask('clear me', { maxRetries: 0 });\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'fail');\n\n    expect(tq.getDeadLetterTasks().length).toBe(1);\n    tq.clearDeadLetterQueue();\n    expect(tq.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('should have independent DLQs per queue', () => {\n    tq.addTask('q1 fail', { queue: 'q1', maxRetries: 0 });\n    tq.addTask('q2 fail', { queue: 'q2', maxRetries: 0 });\n    const t1 = tq.getNextTask('q1')!;\n    const t2 = tq.getNextTask('q2')!;\n    tq.failTask(t1.id, 'fail');\n    tq.failTask(t2.id, 'fail');\n\n    expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n    expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    tq.clearDeadLetterQueue('q1');\n    expect(tq.getDeadLetterTasks('q1').length).toBe(0);\n    expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n  });\n});\n\n// ============================================================\n// Phase 7: Task Dependencies\n// ============================================================\ndescribe('Phase 7: Task Dependencies', () => {\n  it('should block tasks with unresolved dependencies', () => {\n    const dep = tq.addTask('dependency');\n    tq.addTask('dependent', { dependencies: [dep.id] });\n\n    // The dependent should not be available\n    const next = tq.getNextTask();\n    expect(next?.id).toBe(dep.id);\n    // Get next should skip the dependent since dep is not completed\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should unblock tasks when dependencies complete', () => {\n    const dep = tq.addTask('dependency');\n    tq.addTask('dependent', { dependencies: [dep.id] });\n\n    const depTask = tq.getNextTask()!;\n    tq.completeTask(depTask.id);\n\n    const dependentTask = tq.getNextTask();\n    expect(dependentTask?.payload).toBe('dependent');\n  });\n\n  it('should reject non-existent dependencies', () => {\n    expect(() => {\n      tq.addTask('bad dep', { dependencies: ['nonexistent-id'] });\n    }).toThrow();\n  });\n\n  it('should detect circular dependencies', () => {\n    // With the current implementation, since tasks reference existing IDs,\n    // true circular deps can't happen. But let's test the basic case.\n    const a = tq.addTask('a');\n    const b = tq.addTask('b', { dependencies: [a.id] });\n    // Can't create a task that depends on b and then make a depend on it\n    // because a already exists without that dependency.\n    // The system prevents this by design.\n    expect(b.dependencies).toContain(a.id);\n  });\n\n  it('should provide dependency status', () => {\n    const dep1 = tq.addTask('dep1');\n    const dep2 = tq.addTask('dep2');\n    const dependent = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });\n\n    const status = tq.getDependencyStatus(dependent.id);\n    expect(status.length).toBe(2);\n    expect(status[0].met).toBe(false);\n\n    const t = tq.getNextTask()!;\n    tq.completeTask(t.id);\n\n    const status2 = tq.getDependencyStatus(dependent.id);\n    const met = status2.filter(s => s.met);\n    expect(met.length).toBe(1);\n  });\n\n  it('should keep dependents blocked when dependency fails', () => {\n    const dep = tq.addTask('dep', { maxRetries: 0 });\n    tq.addTask('blocked', { dependencies: [dep.id] });\n\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'fail');\n\n    // Dependent remains blocked\n    expect(tq.getNextTask()).toBeNull();\n  });\n});\n\n// ============================================================\n// Phase 8: Concurrency Control\n// ============================================================\ndescribe('Phase 8: Concurrency Control', () => {\n  it('should limit concurrent processing tasks', () => {\n    tq.setConcurrency('default', 1);\n    tq.addTask('a');\n    tq.addTask('b');\n\n    const first = tq.getNextTask();\n    expect(first).not.toBeNull();\n    const second = tq.getNextTask();\n    expect(second).toBeNull();\n  });\n\n  it('should free slot when task completes', () => {\n    tq.setConcurrency('default', 1);\n    tq.addTask('a');\n    tq.addTask('b');\n\n    const first = tq.getNextTask()!;\n    tq.completeTask(first.id);\n    const second = tq.getNextTask();\n    expect(second).not.toBeNull();\n  });\n\n  it('should free slot when task fails', () => {\n    tq.setConcurrency('default', 1);\n    tq.addTask('a', { maxRetries: 0 });\n    tq.addTask('b');\n\n    const first = tq.getNextTask()!;\n    tq.failTask(first.id, 'fail');\n    const second = tq.getNextTask();\n    expect(second).not.toBeNull();\n  });\n\n  it('should have unlimited concurrency by default', () => {\n    expect(tq.getConcurrency('default')).toBeUndefined();\n  });\n\n  it('should report active count', () => {\n    tq.addTask('a');\n    tq.addTask('b');\n    expect(tq.getActiveCount('default')).toBe(0);\n\n    tq.getNextTask();\n    expect(tq.getActiveCount('default')).toBe(1);\n\n    tq.getNextTask();\n    expect(tq.getActiveCount('default')).toBe(2);\n  });\n\n  it('should still respect priority ordering with concurrency', () => {\n    tq.setConcurrency('default', 2);\n    tq.addTask('low', { priority: 10 });\n    tq.addTask('high', { priority: 1 });\n\n    expect(tq.getNextTask()?.payload).toBe('high');\n    expect(tq.getNextTask()?.payload).toBe('low');\n  });\n});\n\n// ============================================================\n// Phase 9: Progress Tracking and Cancellation\n// ============================================================\ndescribe('Phase 9: Progress Tracking and Cancellation', () => {\n  it('should report and query progress', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n    tq.reportProgress(task.id, 50, 'halfway');\n\n    const progress = tq.getProgress(task.id);\n    expect(progress.progress).toBe(50);\n    expect(progress.message).toBe('halfway');\n  });\n\n  it('should notify progress subscribers', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n\n    const updates: Array<{ progress: number; message?: string }> = [];\n    tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n    tq.reportProgress(task.id, 25, 'quarter');\n    tq.reportProgress(task.id, 75, 'three-quarters');\n\n    expect(updates.length).toBe(2);\n    expect(updates[0].progress).toBe(25);\n    expect(updates[1].progress).toBe(75);\n  });\n\n  it('should support unsubscribe', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n\n    const updates: number[] = [];\n    const subId = tq.onProgress(task.id, (p) => updates.push(p));\n\n    tq.reportProgress(task.id, 25);\n    tq.offProgress(task.id, subId);\n    tq.reportProgress(task.id, 50);\n\n    expect(updates.length).toBe(1);\n  });\n\n  it('should cancel a pending task', () => {\n    const task = tq.addTask('cancel me');\n    tq.cancelTask(task.id);\n\n    expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    expect(tq.getNextTask()).toBeNull();\n    expect(tq.getPendingCount()).toBe(0);\n  });\n\n  it('should cancel a processing task', () => {\n    tq.addTask('cancel processing');\n    const task = tq.getNextTask()!;\n    tq.cancelTask(task.id);\n    expect(tq.getTask(task.id)?.status).toBe('cancelled');\n  });\n\n  it('should not retry cancelled tasks', () => {\n    tq.addTask('no retry', { maxRetries: 3 });\n    const task = tq.getNextTask()!;\n    tq.cancelTask(task.id);\n\n    // The task should stay cancelled, not be retried\n    expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should reject invalid progress values', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n    expect(() => tq.reportProgress(task.id, -1)).toThrow();\n    expect(() => tq.reportProgress(task.id, 101)).toThrow();\n  });\n});\n\n// ============================================================\n// Phase 10: Recurring Tasks\n// ============================================================\ndescribe('Phase 10: Recurring Tasks', () => {\n  it('should create and list schedules', () => {\n    const id = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n    expect(id).toBeDefined();\n\n    const schedules = tq.getSchedules();\n    expect(schedules.length).toBe(1);\n    expect(schedules[0].cronExpression).toBe('*/5 * * * *');\n  });\n\n  it('should remove a schedule', () => {\n    const id = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n    tq.removeSchedule(id);\n    expect(tq.getSchedules().length).toBe(0);\n  });\n\n  it('should create tasks on tick for due schedules', () => {\n    tq.addSchedule('*/5 * * * *', 'jobs', { type: 'report' });\n\n    const tasks = tq.tick(new Date());\n    expect(tasks.length).toBe(1);\n    expect(tasks[0].queue).toBe('jobs');\n    expect(tasks[0].payload).toEqual({ type: 'report' });\n  });\n\n  it('should not double-fire on same tick', () => {\n    tq.addSchedule('*/5 * * * *', 'jobs', { type: 'report' });\n    const now = new Date();\n\n    tq.tick(now);\n    const second = tq.tick(now);\n    expect(second.length).toBe(0);\n  });\n\n  it('should respect cron timing - every hour', () => {\n    tq.addSchedule('0 * * * *', 'jobs', 'hourly');\n\n    // At minute 0\n    const onTheHour = new Date('2025-01-01T10:00:00');\n    const tasks1 = tq.tick(onTheHour);\n    expect(tasks1.length).toBe(1);\n\n    // At minute 30 - should not fire\n    const halfHour = new Date('2025-01-01T10:30:00');\n    const tasks2 = tq.tick(halfHour);\n    expect(tasks2.length).toBe(0);\n\n    // Next hour\n    const nextHour = new Date('2025-01-01T11:00:00');\n    const tasks3 = tq.tick(nextHour);\n    expect(tasks3.length).toBe(1);\n  });\n\n  it('should respect cron timing - daily at midnight', () => {\n    tq.addSchedule('0 0 * * *', 'jobs', 'daily');\n\n    const midnight = new Date('2025-01-01T00:00:00');\n    const tasks1 = tq.tick(midnight);\n    expect(tasks1.length).toBe(1);\n\n    const noon = new Date('2025-01-01T12:00:00');\n    const tasks2 = tq.tick(noon);\n    expect(tasks2.length).toBe(0);\n\n    const nextMidnight = new Date('2025-01-02T00:00:00');\n    const tasks3 = tq.tick(nextMidnight);\n    expect(tasks3.length).toBe(1);\n  });\n\n  it('should make recurring tasks subject to all queue rules', () => {\n    tq.addSchedule('*/1 * * * *', 'default', 'recurring', { priority: 2 });\n    const tasks = tq.tick();\n    expect(tasks[0].priority).toBe(2);\n  });\n});\n\n// ============================================================\n// Phase 11: Middleware Pipeline\n// ============================================================\ndescribe('Phase 11: Middleware Pipeline', () => {\n  it('should execute middleware in order', async () => {\n    const order: string[] = [];\n\n    tq.use('default', async (_task, next) => {\n      order.push('first');\n      await next();\n    });\n    tq.use('default', async (_task, next) => {\n      order.push('second');\n      await next();\n    });\n    tq.setHandler('default', async () => {\n      order.push('handler');\n    });\n\n    tq.addTask('test');\n    const task = tq.getNextTask()!;\n    await tq.processTask(task.id);\n\n    expect(order).toEqual(['first', 'second', 'handler']);\n  });\n\n  it('should allow middleware to skip processing by not calling next', async () => {\n    const order: string[] = [];\n\n    tq.use('default', async () => {\n      order.push('blocker');\n      // Don't call next\n    });\n    tq.setHandler('default', async () => {\n      order.push('handler');\n    });\n\n    tq.addTask('test');\n    const task = tq.getNextTask()!;\n    await tq.processTask(task.id);\n\n    expect(order).toEqual(['blocker']);\n  });\n\n  it('should allow middleware to modify the task', async () => {\n    tq.use('default', async (task, next) => {\n      (task as Record<string, unknown>).customField = 'added';\n      await next();\n    });\n\n    let receivedTask: Record<string, unknown> | null = null;\n    tq.setHandler('default', async (task) => {\n      receivedTask = task as Record<string, unknown>;\n    });\n\n    tq.addTask('test');\n    const task = tq.getNextTask()!;\n    await tq.processTask(task.id);\n\n    expect(receivedTask?.customField).toBe('added');\n  });\n\n  it('should fail task when middleware throws', async () => {\n    tq.use('default', async () => {\n      throw new Error('middleware error');\n    });\n\n    tq.addTask('test', { maxRetries: 0 });\n    const task = tq.getNextTask()!;\n\n    await expect(tq.processTask(task.id)).rejects.toThrow('middleware error');\n    expect(tq.getTask(task.id)?.status).toBe('failed');\n  });\n\n  it('should have independent middleware per queue', async () => {\n    const q1Order: string[] = [];\n    const q2Order: string[] = [];\n\n    tq.use('q1', async (_task, next) => {\n      q1Order.push('q1-mw');\n      await next();\n    });\n    tq.use('q2', async (_task, next) => {\n      q2Order.push('q2-mw');\n      await next();\n    });\n\n    tq.setHandler('q1', async () => { q1Order.push('q1-handler'); });\n    tq.setHandler('q2', async () => { q2Order.push('q2-handler'); });\n\n    tq.addTask('a', { queue: 'q1' });\n    tq.addTask('b', { queue: 'q2' });\n    const t1 = tq.getNextTask('q1')!;\n    const t2 = tq.getNextTask('q2')!;\n\n    await tq.processTask(t1.id);\n    await tq.processTask(t2.id);\n\n    expect(q1Order).toEqual(['q1-mw', 'q1-handler']);\n    expect(q2Order).toEqual(['q2-mw', 'q2-handler']);\n  });\n});\n\n// ============================================================\n// Phase 12: Graceful Shutdown\n// ============================================================\ndescribe('Phase 12: Graceful Shutdown', () => {\n  it('should prevent adding tasks after shutdown', async () => {\n    await tq.shutdown();\n    expect(() => tq.addTask('nope')).toThrow(/shutting down/);\n  });\n\n  it('should complete immediately with no processing tasks', async () => {\n    const summary = await tq.shutdown();\n    expect(summary.completed).toBe(0);\n    expect(summary.forceCancelled).toBe(0);\n    expect(summary.duration).toBeDefined();\n  });\n\n  it('should wait for processing tasks to finish', async () => {\n    tq.addTask('will complete');\n    const task = tq.getNextTask()!;\n\n    // Complete the task shortly after shutdown starts\n    setTimeout(() => tq.completeTask(task.id), 50);\n\n    const summary = await tq.shutdown(5000);\n    expect(summary.completed).toBe(1);\n    expect(summary.forceCancelled).toBe(0);\n  });\n\n  it('should force-cancel tasks exceeding timeout', async () => {\n    tq.addTask('will timeout');\n    tq.getNextTask();\n\n    const summary = await tq.shutdown(50);\n    expect(summary.forceCancelled).toBe(1);\n  });\n\n  it('should run shutdown callbacks', async () => {\n    let callbackRan = false;\n    tq.onShutdown(() => { callbackRan = true; });\n\n    await tq.shutdown();\n    expect(callbackRan).toBe(true);\n  });\n\n  it('should return same result for multiple shutdown calls', async () => {\n    const s1 = tq.shutdown();\n    const s2 = tq.shutdown();\n    const [r1, r2] = await Promise.all([s1, s2]);\n    expect(r1).toBe(r2);\n  });\n\n  it('should expose isShuttingDown state', async () => {\n    expect(tq.isShuttingDown).toBe(false);\n    const p = tq.shutdown();\n    expect(tq.isShuttingDown).toBe(true);\n    await p;\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":220,"cache_read_input_tokens":36998,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":220},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1c0273b1-8aed-41b3-ac25-4872ce9bf042","uuid":"f9a1aa54-93ba-4269-9989-d6b9c703bedc"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KHnbZaDAvPHrWRNS16wxC7","type":"tool_result","content":"File created successfully at: /workspace/tests/task-queue.test.ts"}]},"parent_tool_use_id":null,"session_id":"1c0273b1-8aed-41b3-ac25-4872ce9bf042","uuid":"7c61bd35-25e6-4dda-9121-ea8d65228f96","tool_use_result":{"type":"create","filePath":"/workspace/tests/task-queue.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\nlet tq: TaskQueue;\n\nbeforeEach(() => {\n  tq = new TaskQueue();\n});\n\n// ============================================================\n// Phase 1: Basic FIFO Queue\n// ============================================================\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  it('should add a task and return a task object with required fields', () => {\n    const task = tq.addTask({ message: 'hello' });\n    expect(task.id).toBeDefined();\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n    expect(task.payload).toEqual({ message: 'hello' });\n  });\n\n  it('should assign unique IDs to each task', () => {\n    const t1 = tq.addTask('a');\n    const t2 = tq.addTask('b');\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  it('should retrieve tasks in FIFO order', () => {\n    tq.addTask('first');\n    tq.addTask('second');\n    tq.addTask('third');\n\n    expect(tq.getNextTask()?.payload).toBe('first');\n    expect(tq.getNextTask()?.payload).toBe('second');\n    expect(tq.getNextTask()?.payload).toBe('third');\n  });\n\n  it('should transition task to processing on retrieval', () => {\n    const added = tq.addTask('work');\n    const retrieved = tq.getNextTask();\n    expect(retrieved?.id).toBe(added.id);\n    expect(retrieved?.status).toBe('processing');\n  });\n\n  it('should return null when queue is empty', () => {\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should return null when all tasks are processing', () => {\n    tq.addTask('a');\n    tq.getNextTask();\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should count pending tasks', () => {\n    expect(tq.getPendingCount()).toBe(0);\n    tq.addTask('a');\n    tq.addTask('b');\n    expect(tq.getPendingCount()).toBe(2);\n    tq.getNextTask();\n    expect(tq.getPendingCount()).toBe(1);\n  });\n\n  it('should retrieve a task by ID', () => {\n    const added = tq.addTask('find me');\n    const found = tq.getTask(added.id);\n    expect(found).toBeDefined();\n    expect(found?.payload).toBe('find me');\n  });\n});\n\n// ============================================================\n// Phase 2: Named Queues\n// ============================================================\ndescribe('Phase 2: Named Queues', () => {\n  it('should use default queue when no name specified', () => {\n    tq.addTask('default task');\n    const task = tq.getNextTask();\n    expect(task?.queue).toBe('default');\n  });\n\n  it('should support named queues independently', () => {\n    tq.addTask('email', { queue: 'emails' });\n    tq.addTask('sms', { queue: 'sms' });\n\n    expect(tq.getNextTask('emails')?.payload).toBe('email');\n    expect(tq.getNextTask('sms')?.payload).toBe('sms');\n    expect(tq.getNextTask('emails')).toBeNull();\n  });\n\n  it('should list all queue names', () => {\n    tq.addTask('a', { queue: 'q1' });\n    tq.addTask('b', { queue: 'q2' });\n    const names = tq.getQueueNames();\n    expect(names).toContain('q1');\n    expect(names).toContain('q2');\n  });\n\n  it('should return null from non-existent queue', () => {\n    expect(tq.getNextTask('nonexistent')).toBeNull();\n  });\n\n  it('should be backward-compatible with Phase 1 API', () => {\n    tq.addTask('compat');\n    expect(tq.getNextTask()?.payload).toBe('compat');\n    expect(tq.getPendingCount()).toBe(0);\n  });\n});\n\n// ============================================================\n// Phase 3: Priority\n// ============================================================\ndescribe('Phase 3: Priority', () => {\n  it('should default priority to 5', () => {\n    const task = tq.addTask('normal');\n    expect(task.priority).toBe(5);\n  });\n\n  it('should return higher priority tasks first', () => {\n    tq.addTask('low', { priority: 10 });\n    tq.addTask('high', { priority: 1 });\n    tq.addTask('medium', { priority: 5 });\n\n    expect(tq.getNextTask()?.payload).toBe('high');\n    expect(tq.getNextTask()?.payload).toBe('medium');\n    expect(tq.getNextTask()?.payload).toBe('low');\n  });\n\n  it('should maintain FIFO within same priority', () => {\n    tq.addTask('first', { priority: 3 });\n    tq.addTask('second', { priority: 3 });\n    tq.addTask('third', { priority: 3 });\n\n    expect(tq.getNextTask()?.payload).toBe('first');\n    expect(tq.getNextTask()?.payload).toBe('second');\n    expect(tq.getNextTask()?.payload).toBe('third');\n  });\n\n  it('should reject invalid priority values', () => {\n    expect(() => tq.addTask('bad', { priority: 0 })).toThrow();\n    expect(() => tq.addTask('bad', { priority: 11 })).toThrow();\n    expect(() => tq.addTask('bad', { priority: 1.5 })).toThrow();\n  });\n\n  it('should apply priority per queue', () => {\n    tq.addTask('q1-low', { queue: 'q1', priority: 10 });\n    tq.addTask('q1-high', { queue: 'q1', priority: 1 });\n    tq.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n    expect(tq.getNextTask('q1')?.payload).toBe('q1-high');\n    expect(tq.getNextTask('q2')?.payload).toBe('q2-low');\n  });\n});\n\n// ============================================================\n// Phase 4: Delayed and Scheduled Tasks\n// ============================================================\ndescribe('Phase 4: Delayed and Scheduled Tasks', () => {\n  it('should not return delayed tasks before their availability time', () => {\n    tq.addTask('delayed', { delay: 60000 }); // 1 minute from now\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should return delayed tasks after availability time has passed', () => {\n    const task = tq.addTask('ready soon', { delay: 0 });\n    expect(task.availableAt.getTime()).toBeLessThanOrEqual(Date.now());\n    expect(tq.getNextTask()?.payload).toBe('ready soon');\n  });\n\n  it('should support availableAt as a specific date', () => {\n    const past = new Date(Date.now() - 1000);\n    tq.addTask('past task', { availableAt: past });\n    expect(tq.getNextTask()?.payload).toBe('past task');\n  });\n\n  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n    tq.addTask('delayed', { delay: 60000 });\n    tq.addTask('immediate');\n\n    expect(tq.getNextTask()?.payload).toBe('immediate');\n    expect(tq.getNextTask()).toBeNull(); // delayed still not available\n  });\n\n  it('should expose availableAt on the task object', () => {\n    const task = tq.addTask('check', { delay: 5000 });\n    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n  });\n\n  it('should order delayed tasks by availability time, then priority, then FIFO', () => {\n    const past1 = new Date(Date.now() - 3000);\n    const past2 = new Date(Date.now() - 2000);\n    const past3 = new Date(Date.now() - 1000);\n\n    tq.addTask('later-avail', { availableAt: past3, priority: 1 });\n    tq.addTask('earliest-avail', { availableAt: past1, priority: 5 });\n    tq.addTask('mid-avail', { availableAt: past2, priority: 5 });\n\n    // Priority takes precedence, so priority 1 task comes first\n    expect(tq.getNextTask()?.payload).toBe('later-avail');\n    // Then by availability time\n    expect(tq.getNextTask()?.payload).toBe('earliest-avail');\n    expect(tq.getNextTask()?.payload).toBe('mid-avail');\n  });\n});\n\n// ============================================================\n// Phase 5: Retry with Backoff\n// ============================================================\ndescribe('Phase 5: Retry with Backoff', () => {\n  it('should mark a task as completed', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n    tq.completeTask(task.id);\n    expect(tq.getTask(task.id)?.status).toBe('completed');\n  });\n\n  it('should mark a task as failed', () => {\n    const added = tq.addTask('work', { maxRetries: 0 });\n    const task = tq.getNextTask()!;\n    tq.failTask(task.id, 'something broke');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.status).toBe('failed');\n    expect(updated.error).toBe('something broke');\n  });\n\n  it('should retry failed tasks with exponential backoff', () => {\n    tq.addTask('retry me', { maxRetries: 3, baseDelay: 100 });\n    const task = tq.getNextTask()!;\n    expect(task.attempt).toBe(1);\n\n    tq.failTask(task.id, 'fail 1');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.status).toBe('pending');\n    expect(updated.attempt).toBe(1); // attempt stays, will increment on next getNextTask\n    // Task is delayed so it won't be immediately available\n    expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now() - 10);\n  });\n\n  it('should track attempt count', () => {\n    tq.addTask('track', { maxRetries: 2, baseDelay: 0 });\n    const t1 = tq.getNextTask()!;\n    expect(t1.attempt).toBe(1);\n\n    tq.failTask(t1.id, 'fail');\n    // Manually set availableAt to now for immediate retrieval\n    const task = tq.getTask(t1.id)!;\n    task.availableAt = new Date(Date.now() - 1);\n\n    const t2 = tq.getNextTask()!;\n    expect(t2.attempt).toBe(2);\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    tq.addTask('keep', { queue: 'special', priority: 2, maxRetries: 3, baseDelay: 0 });\n    const task = tq.getNextTask('special')!;\n    tq.failTask(task.id, 'fail');\n    const updated = tq.getTask(task.id)!;\n    expect(updated.queue).toBe('special');\n    expect(updated.priority).toBe(2);\n  });\n\n  it('should fail permanently when retries exhausted', () => {\n    tq.addTask('exhaust', { maxRetries: 1, baseDelay: 0 });\n    const t1 = tq.getNextTask()!;\n    tq.failTask(t1.id, 'fail');\n\n    // Make available immediately\n    tq.getTask(t1.id)!.availableAt = new Date(Date.now() - 1);\n    const t2 = tq.getNextTask()!;\n    tq.failTask(t2.id, 'fail again');\n\n    expect(tq.getTask(t1.id)?.status).toBe('failed');\n  });\n\n  it('should default to 3 max retries', () => {\n    const task = tq.addTask('defaults');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default baseDelay to 1000ms', () => {\n    const task = tq.addTask('defaults');\n    expect(task.baseDelay).toBe(1000);\n  });\n});\n\n// ============================================================\n// Phase 6: Dead Letter Queue\n// ============================================================\ndescribe('Phase 6: Dead Letter Queue', () => {\n  it('should move permanently failed tasks to DLQ', () => {\n    tq.addTask('dlq me', { maxRetries: 1, baseDelay: 0 });\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'fail 1');\n    tq.getTask(t.id)!.availableAt = new Date(Date.now() - 1);\n    const t2 = tq.getNextTask()!;\n    tq.failTask(t2.id, 'fail 2');\n\n    const dlq = tq.getDeadLetterTasks();\n    expect(dlq.length).toBe(1);\n    expect(dlq[0].id).toBe(t.id);\n  });\n\n  it('should retain error info and failure count', () => {\n    tq.addTask('fail info', { maxRetries: 0 });\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'detailed error');\n\n    const dlq = tq.getDeadLetterTasks();\n    expect(dlq[0].error).toBe('detailed error');\n    expect(dlq[0].failureCount).toBe(1);\n  });\n\n  it('should retry dead-lettered tasks', () => {\n    tq.addTask('retry dlq', { maxRetries: 0 });\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'fail');\n\n    tq.retryDeadLetterTask(t.id);\n    const updated = tq.getTask(t.id)!;\n    expect(updated.status).toBe('pending');\n    expect(updated.attempt).toBe(0);\n    expect(updated.failureCount).toBe(0);\n    expect(tq.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('should clear DLQ for a queue', () => {\n    tq.addTask('clear me', { maxRetries: 0 });\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'fail');\n\n    expect(tq.getDeadLetterTasks().length).toBe(1);\n    tq.clearDeadLetterQueue();\n    expect(tq.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('should have independent DLQs per queue', () => {\n    tq.addTask('q1 fail', { queue: 'q1', maxRetries: 0 });\n    tq.addTask('q2 fail', { queue: 'q2', maxRetries: 0 });\n    const t1 = tq.getNextTask('q1')!;\n    const t2 = tq.getNextTask('q2')!;\n    tq.failTask(t1.id, 'fail');\n    tq.failTask(t2.id, 'fail');\n\n    expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n    expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    tq.clearDeadLetterQueue('q1');\n    expect(tq.getDeadLetterTasks('q1').length).toBe(0);\n    expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n  });\n});\n\n// ============================================================\n// Phase 7: Task Dependencies\n// ============================================================\ndescribe('Phase 7: Task Dependencies', () => {\n  it('should block tasks with unresolved dependencies', () => {\n    const dep = tq.addTask('dependency');\n    tq.addTask('dependent', { dependencies: [dep.id] });\n\n    // The dependent should not be available\n    const next = tq.getNextTask();\n    expect(next?.id).toBe(dep.id);\n    // Get next should skip the dependent since dep is not completed\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should unblock tasks when dependencies complete', () => {\n    const dep = tq.addTask('dependency');\n    tq.addTask('dependent', { dependencies: [dep.id] });\n\n    const depTask = tq.getNextTask()!;\n    tq.completeTask(depTask.id);\n\n    const dependentTask = tq.getNextTask();\n    expect(dependentTask?.payload).toBe('dependent');\n  });\n\n  it('should reject non-existent dependencies', () => {\n    expect(() => {\n      tq.addTask('bad dep', { dependencies: ['nonexistent-id'] });\n    }).toThrow();\n  });\n\n  it('should detect circular dependencies', () => {\n    // With the current implementation, since tasks reference existing IDs,\n    // true circular deps can't happen. But let's test the basic case.\n    const a = tq.addTask('a');\n    const b = tq.addTask('b', { dependencies: [a.id] });\n    // Can't create a task that depends on b and then make a depend on it\n    // because a already exists without that dependency.\n    // The system prevents this by design.\n    expect(b.dependencies).toContain(a.id);\n  });\n\n  it('should provide dependency status', () => {\n    const dep1 = tq.addTask('dep1');\n    const dep2 = tq.addTask('dep2');\n    const dependent = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });\n\n    const status = tq.getDependencyStatus(dependent.id);\n    expect(status.length).toBe(2);\n    expect(status[0].met).toBe(false);\n\n    const t = tq.getNextTask()!;\n    tq.completeTask(t.id);\n\n    const status2 = tq.getDependencyStatus(dependent.id);\n    const met = status2.filter(s => s.met);\n    expect(met.length).toBe(1);\n  });\n\n  it('should keep dependents blocked when dependency fails', () => {\n    const dep = tq.addTask('dep', { maxRetries: 0 });\n    tq.addTask('blocked', { dependencies: [dep.id] });\n\n    const t = tq.getNextTask()!;\n    tq.failTask(t.id, 'fail');\n\n    // Dependent remains blocked\n    expect(tq.getNextTask()).toBeNull();\n  });\n});\n\n// ============================================================\n// Phase 8: Concurrency Control\n// ============================================================\ndescribe('Phase 8: Concurrency Control', () => {\n  it('should limit concurrent processing tasks', () => {\n    tq.setConcurrency('default', 1);\n    tq.addTask('a');\n    tq.addTask('b');\n\n    const first = tq.getNextTask();\n    expect(first).not.toBeNull();\n    const second = tq.getNextTask();\n    expect(second).toBeNull();\n  });\n\n  it('should free slot when task completes', () => {\n    tq.setConcurrency('default', 1);\n    tq.addTask('a');\n    tq.addTask('b');\n\n    const first = tq.getNextTask()!;\n    tq.completeTask(first.id);\n    const second = tq.getNextTask();\n    expect(second).not.toBeNull();\n  });\n\n  it('should free slot when task fails', () => {\n    tq.setConcurrency('default', 1);\n    tq.addTask('a', { maxRetries: 0 });\n    tq.addTask('b');\n\n    const first = tq.getNextTask()!;\n    tq.failTask(first.id, 'fail');\n    const second = tq.getNextTask();\n    expect(second).not.toBeNull();\n  });\n\n  it('should have unlimited concurrency by default', () => {\n    expect(tq.getConcurrency('default')).toBeUndefined();\n  });\n\n  it('should report active count', () => {\n    tq.addTask('a');\n    tq.addTask('b');\n    expect(tq.getActiveCount('default')).toBe(0);\n\n    tq.getNextTask();\n    expect(tq.getActiveCount('default')).toBe(1);\n\n    tq.getNextTask();\n    expect(tq.getActiveCount('default')).toBe(2);\n  });\n\n  it('should still respect priority ordering with concurrency', () => {\n    tq.setConcurrency('default', 2);\n    tq.addTask('low', { priority: 10 });\n    tq.addTask('high', { priority: 1 });\n\n    expect(tq.getNextTask()?.payload).toBe('high');\n    expect(tq.getNextTask()?.payload).toBe('low');\n  });\n});\n\n// ============================================================\n// Phase 9: Progress Tracking and Cancellation\n// ============================================================\ndescribe('Phase 9: Progress Tracking and Cancellation', () => {\n  it('should report and query progress', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n    tq.reportProgress(task.id, 50, 'halfway');\n\n    const progress = tq.getProgress(task.id);\n    expect(progress.progress).toBe(50);\n    expect(progress.message).toBe('halfway');\n  });\n\n  it('should notify progress subscribers', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n\n    const updates: Array<{ progress: number; message?: string }> = [];\n    tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n    tq.reportProgress(task.id, 25, 'quarter');\n    tq.reportProgress(task.id, 75, 'three-quarters');\n\n    expect(updates.length).toBe(2);\n    expect(updates[0].progress).toBe(25);\n    expect(updates[1].progress).toBe(75);\n  });\n\n  it('should support unsubscribe', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n\n    const updates: number[] = [];\n    const subId = tq.onProgress(task.id, (p) => updates.push(p));\n\n    tq.reportProgress(task.id, 25);\n    tq.offProgress(task.id, subId);\n    tq.reportProgress(task.id, 50);\n\n    expect(updates.length).toBe(1);\n  });\n\n  it('should cancel a pending task', () => {\n    const task = tq.addTask('cancel me');\n    tq.cancelTask(task.id);\n\n    expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    expect(tq.getNextTask()).toBeNull();\n    expect(tq.getPendingCount()).toBe(0);\n  });\n\n  it('should cancel a processing task', () => {\n    tq.addTask('cancel processing');\n    const task = tq.getNextTask()!;\n    tq.cancelTask(task.id);\n    expect(tq.getTask(task.id)?.status).toBe('cancelled');\n  });\n\n  it('should not retry cancelled tasks', () => {\n    tq.addTask('no retry', { maxRetries: 3 });\n    const task = tq.getNextTask()!;\n    tq.cancelTask(task.id);\n\n    // The task should stay cancelled, not be retried\n    expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    expect(tq.getNextTask()).toBeNull();\n  });\n\n  it('should reject invalid progress values', () => {\n    tq.addTask('work');\n    const task = tq.getNextTask()!;\n    expect(() => tq.reportProgress(task.id, -1)).toThrow();\n    expect(() => tq.reportProgress(task.id, 101)).toThrow();\n  });\n});\n\n// ============================================================\n// Phase 10: Recurring Tasks\n// ============================================================\ndescribe('Phase 10: Recurring Tasks', () => {\n  it('should create and list schedules', () => {\n    const id = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n    expect(id).toBeDefined();\n\n    const schedules = tq.getSchedules();\n    expect(schedules.length).toBe(1);\n    expect(schedules[0].cronExpression).toBe('*/5 * * * *');\n  });\n\n  it('should remove a schedule', () => {\n    const id = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n    tq.removeSchedule(id);\n    expect(tq.getSchedules().length).toBe(0);\n  });\n\n  it('should create tasks on tick for due schedules', () => {\n    tq.addSchedule('*/5 * * * *', 'jobs', { type: 'report' });\n\n    const tasks = tq.tick(new Date());\n    expect(tasks.length).toBe(1);\n    expect(tasks[0].queue).toBe('jobs');\n    expect(tasks[0].payload).toEqual({ type: 'report' });\n  });\n\n  it('should not double-fire on same tick', () => {\n    tq.addSchedule('*/5 * * * *', 'jobs', { type: 'report' });\n    const now = new Date();\n\n    tq.tick(now);\n    const second = tq.tick(now);\n    expect(second.length).toBe(0);\n  });\n\n  it('should respect cron timing - every hour', () => {\n    tq.addSchedule('0 * * * *', 'jobs', 'hourly');\n\n    // At minute 0\n    const onTheHour = new Date('2025-01-01T10:00:00');\n    const tasks1 = tq.tick(onTheHour);\n    expect(tasks1.length).toBe(1);\n\n    // At minute 30 - should not fire\n    const halfHour = new Date('2025-01-01T10:30:00');\n    const tasks2 = tq.tick(halfHour);\n    expect(tasks2.length).toBe(0);\n\n    // Next hour\n    const nextHour = new Date('2025-01-01T11:00:00');\n    const tasks3 = tq.tick(nextHour);\n    expect(tasks3.length).toBe(1);\n  });\n\n  it('should respect cron timing - daily at midnight', () => {\n    tq.addSchedule('0 0 * * *', 'jobs', 'daily');\n\n    const midnight = new Date('2025-01-01T00:00:00');\n    const tasks1 = tq.tick(midnight);\n    expect(tasks1.length).toBe(1);\n\n    const noon = new Date('2025-01-01T1