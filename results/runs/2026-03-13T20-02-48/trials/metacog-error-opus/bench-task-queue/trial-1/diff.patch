`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName: string): number | undefined {\n    return this.concurrencyLimits.get(queueName);\n  }\n\n  getActiveCount(queueName: string): number {\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queueName && task.status === 'processing') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // --- Phase 9: Progress Tracking and Cancellation ---\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify subscribers\n    const subs = this.progressSubscribers.get(taskId);\n    if (subs) {\n      for (const cb of subs.values()) {\n        cb(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): string {\n    if (!this.progressSubscribers.has(taskId)) {\n      this.progressSubscribers.set(taskId, new Map());\n    }\n    const subId = randomUUID();\n    this.progressSubscribers.get(taskId)!.set(subId, callback);\n    return subId;\n  }\n\n  offProgress(taskId: string, subscriptionId: string): void {\n    const subs = this.progressSubscribers.get(taskId);\n    if (subs) {\n      subs.delete(subscriptionId);\n    }\n  }\n\n 