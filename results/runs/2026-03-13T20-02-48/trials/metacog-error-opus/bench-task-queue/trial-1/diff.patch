diff --git a/src/TaskQueue.ts b/src/TaskQueue.ts
new file mode 100644
index 0000000..fb0dae3
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,562 @@
+import { randomUUID } from 'node:crypto';
+import {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressCallback,
+  ShutdownSummary,
+  createTask,
+} from './types.js';
+import { shouldRun } from './cron.js';
+
+export class TaskQueue {
+  // All tasks by ID
+  private tasks = new Map<string, Task>();
+
+  // Per-queue pending task lists (task IDs)
+  private queues = new Map<string, string[]>();
+
+  // Dead letter queues per queue name
+  private dlqs = new Map<string, string[]>();
+
+  // Concurrency limits per queue
+  private concurrencyLimits = new Map<string, number>();
+
+  // Progress subscribers per task ID
+  private progressSubscribers = new Map<string, Map<string, ProgressCallback>>();
+
+  // Schedules
+  private schedules = new Map<string, Schedule>();
+
+  // Middleware per queue
+  private middleware = new Map<string, MiddlewareFn[]>();
+
+  // Handlers per queue
+  private handlers = new Map<string, HandlerFn>();
+
+  // Shutdown state
+  private _isShuttingDown = false;
+  private _shutdownPromise: Promise<ShutdownSummary> | null = null;
+
+  // --- Phase 1: Basic FIFO Queue ---
+
+  addTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this._isShuttingDown) {
+      throw new Error('Cannot add tasks: system is shutting down.');
+    }
+
+    const task = createTask(payload, options);
+
+    // Phase 7: Validate dependencies
+    if (task.dependencies.length > 0) {
+      for (const depId of task.dependencies) {
+        if (!this.tasks.has(depId)) {
+          throw new Error(`Dependency task not found: ${depId}`);
+        }
+      }
+      // Circular dependency check
+      this.detectCircularDependency(task.id, task.dependencies);
+    }
+
+    this.tasks.set(task.id, task as Task);
+
+    const queueName = task.queue;
+    if (!this.queues.has(queueName)) {
+      this.queues.set(queueName, []);
+    }
+    this.queues.get(queueName)!.push(task.id);
+
+    return task;
+  }
+
+  getNextTask(queueName = 'default'): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue || queue.length === 0) return null;
+
+    // Phase 8: Check concurrency limit
+    const limit = this.concurrencyLimits.get(queueName);
+    if (limit !== undefined) {
+      const activeCount = this.getActiveCount(queueName);
+      if (activeCount >= limit) return null;
+    }
+
+    const now = new Date();
+
+    // Find best candidate considering priority, availability, dependencies
+    let bestIndex = -1;
+    let bestTask: Task | null = null;
+
+    for (let i = 0; i < queue.length; i++) {
+      const task = this.tasks.get(queue[i]);
+      if (!task || task.status !== 'pending') continue;
+
+      // Phase 4: Check availability time
+      if (task.availableAt > now) continue;
+
+      // Phase 7: Check dependencies
+      if (task.dependencies.length > 0 && !this.areDependenciesMet(task)) continue;
+
+      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {
+        bestIndex = i;
+        bestTask = task;
+      }
+    }
+
+    if (bestIndex === -1 || bestTask === null) return null;
+
+    // Remove from queue and transition to processing
+    queue.splice(bestIndex, 1);
+    bestTask.status = 'processing';
+    bestTask.attempt += 1;
+
+    return bestTask;
+  }
+
+  getPendingCount(queueName = 'default'): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+    return queue.filter(id => {
+      const task = this.tasks.get(id);
+      return task && task.status === 'pending';
+    }).length;
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  // --- Phase 2: Named Queues ---
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // --- Phase 5: Retry with Backoff ---
+
+  completeTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in status: ${task.status}`);
+    }
+    task.status = 'completed';
+    task.progress = 100;
+  }
+
+  failTask(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in status: ${task.status}`);
+    }
+
+    task.error = error;
+    task.failureCount += 1;
+
+    if (task.attempt <= task.maxRetries) {
+      // Re-add to queue with exponential backoff delay
+      const backoffDelay = task.baseDelay * Math.pow(2, task.attempt - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + backoffDelay);
+      task.progress = 0;
+
+      const queue = this.queues.get(task.queue);
+      if (queue) {
+        queue.push(task.id);
+      }
+    } else {
+      // Phase 6: Move to DLQ
+      task.status = 'failed';
+      if (!this.dlqs.has(task.queue)) {
+        this.dlqs.set(task.queue, []);
+      }
+      this.dlqs.get(task.queue)!.push(task.id);
+    }
+  }
+
+  // --- Phase 6: Dead Letter Queue ---
+
+  getDeadLetterTasks(queueName = 'default'): Task[] {
+    const dlq = this.dlqs.get(queueName);
+    if (!dlq) return [];
+    return dlq.map(id => this.tasks.get(id)!).filter(Boolean);
+  }
+
+  retryDeadLetterTask(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'failed') {
+      throw new Error(`Task is not in dead letter queue: ${taskId}`);
+    }
+
+    // Remove from DLQ
+    const dlq = this.dlqs.get(task.queue);
+    if (dlq) {
+      const idx = dlq.indexOf(taskId);
+      if (idx !== -1) dlq.splice(idx, 1);
+    }
+
+    // Reset for fresh retries
+    task.status = 'pending';
+    task.attempt = 0;
+    task.failureCount = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.progress = 0;
+
+    const queue = this.queues.get(task.queue);
+    if (queue) {
+      queue.push(task.id);
+    }
+
+    return task;
+  }
+
+  clearDeadLetterQueue(queueName = 'default'): void {
+    const dlq = this.dlqs.get(queueName);
+    if (dlq) {
+      for (const id of dlq) {
+        this.tasks.delete(id);
+      }
+      this.dlqs.set(queueName, []);
+    }
+  }
+
+  // --- Phase 7: Task Dependencies ---
+
+  private detectCircularDependency(newTaskId: string, dependencies: string[]): void {
+    const visited = new Set<string>();
+    const stack = [...dependencies];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === newTaskId) {
+        throw new Error('Circular dependency detected');
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const depTask = this.tasks.get(current);
+      if (depTask) {
+        for (const dep of depTask.dependencies) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private areDependenciesMet(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (!dep || dep.status !== 'completed') {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus; met: boolean }[] {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    return task.dependencies.map(depId => {
+      const dep = this.tasks.get(depId);
+      return {
+        taskId: depId,
+        status: dep ? dep.status : 'failed' as TaskStatus,
+        met: dep ? dep.status === 'completed' : false,
+      };
+    });
+  }
+
+  // --- Phase 8: Concurrency Control ---
+
+  setConcurrency(queueName: string, limit: number): void {
+    if (limit < 1 || !Number.isInteger(limit)) {
+      throw new Error(`Invalid concurrency limit: ${limit}`);
+    }
+    this.concurrencyLimits.set(queueName, limit);
+  }
+
+  getConcurrency(queueName: string): number | undefined {
+    return this.concurrencyLimits.get(queueName);
+  }
+
+  getActiveCount(queueName: string): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queueName && task.status === 'processing') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // --- Phase 9: Progress Tracking and Cancellation ---
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot report progress for task in status: ${task.status}`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify subscribers
+    const subs = this.progressSubscribers.get(taskId);
+    if (subs) {
+      for (const cb of subs.values()) {
+        cb(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, callback: ProgressCallback): string {
+    if (!this.progressSubscribers.has(taskId)) {
+      this.progressSubscribers.set(taskId, new Map());
+    }
+    const subId = randomUUID();
+    this.progressSubscribers.get(taskId)!.set(subId, callback);
+    return subId;
+  }
+
+  offProgress(taskId: string, subscriptionId: string): void {
+    const subs = this.progressSubscribers.get(taskId);
+    if (subs) {
+      subs.delete(subscriptionId);
+    }
+  }
+
+  cancelTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    if (task.status === 'pending') {
+      // Remove from queue
+      const queue = this.queues.get(task.queue);
+      if (queue) {
+        const idx = queue.indexOf(taskId);
+        if (idx !== -1) queue.splice(idx, 1);
+      }
+    }
+
+    task.status = 'cancelled';
+  }
+
+  // --- Phase 10: Recurring Tasks ---
+
+  addSchedule(cronExpression: string, queue: string, payload: unknown, taskOptions?: Omit<TaskOptions, 'queue'>): string {
+    if (this._isShuttingDown) {
+      throw new Error('Cannot add schedules: system is shutting down.');
+    }
+
+    const id = randomUUID();
+    const schedule: Schedule = {
+      id,
+      cronExpression,
+      queue,
+      payload,
+      taskOptions,
+    };
+
+    // Validate the cron expression
+    this.validateCron(cronExpression);
+
+    this.schedules.set(id, schedule);
+    return id;
+  }
+
+  private validateCron(expression: string): void {
+    // Simple validation inline
+    const parts = expression.trim().split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expression}`);
+    }
+  }
+
+  removeSchedule(scheduleId: string): void {
+    this.schedules.delete(scheduleId);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (shouldRun(schedule.cronExpression, currentTime, schedule.lastRun)) {
+        const task = this.addTask(schedule.payload, {
+          ...schedule.taskOptions,
+          queue: schedule.queue,
+        });
+        schedule.lastRun = currentTime;
+        created.push(task);
+      }
+    }
+
+    return created;
+  }
+
+  // --- Phase 11: Middleware Pipeline ---
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    if (!this.middleware.has(queueName)) {
+      this.middleware.set(queueName, []);
+    }
+    this.middleware.get(queueName)!.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    this.handlers.set(queueName, handler);
+  }
+
+  async processTask(taskId: string): Promise<void> {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot process task in status: ${task.status}`);
+    }
+
+    const middlewareStack = this.middleware.get(task.queue) ?? [];
+    const handler = this.handlers.get(task.queue);
+
+    let index = 0;
+
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewareStack.length) {
+        const mw = middlewareStack[index++];
+        await mw(task, executeNext);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+    } catch (err) {
+      const errorMessage = err instanceof Error ? err.message : String(err);
+      this.failTask(taskId, errorMessage);
+      throw err;
+    }
+  }
+
+  // --- Phase 12: Graceful Shutdown ---
+
+  get isShuttingDown(): boolean {
+    return this._isShuttingDown;
+  }
+
+  private shutdownCallbacks: (() => void | Promise<void>)[] = [];
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout = 30000): Promise<ShutdownSummary> {
+    if (this._shutdownPromise) {
+      return this._shutdownPromise;
+    }
+
+    this._isShuttingDown = true;
+    this._shutdownPromise = this._doShutdown(timeout);
+    return this._shutdownPromise;
+  }
+
+  private async _doShutdown(timeout: number): Promise<ShutdownSummary> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Get all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    // Wait for processing tasks to complete, with timeout
+    const waitStart = Date.now();
+
+    await new Promise<void>((resolve) => {
+      const checkInterval = setInterval(() => {
+        let allDone = true;
+        for (const task of processingTasks) {
+          if (task.status === 'processing') {
+            allDone = false;
+            break;
+          }
+        }
+
+        if (allDone || (Date.now() - waitStart) >= timeout) {
+          clearInterval(checkInterval);
+          resolve();
+        }
+      }, 10);
+    });
+
+    // Count results and force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        forceCancelled++;
+      } else if (task.status === 'completed') {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  // --- Utility: Task comparison for priority ordering ---
+
+  private compareTasks(a: Task, b: Task): number {
+    // Lower priority number = higher priority
+    if (a.priority !== b.priority) return a.priority - b.priority;
+    // Earlier availability time first
+    if (a.availableAt.getTime() !== b.availableAt.getTime()) {
+      return a.availableAt.getTime() - b.availableAt.getTime();
+    }
+    // FIFO: earlier creation time first
+    return a.createdAt.getTime() - b.createdAt.getTime();
+  }
+}
