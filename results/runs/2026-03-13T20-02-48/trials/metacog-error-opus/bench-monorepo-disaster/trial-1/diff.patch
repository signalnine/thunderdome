+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B2BHZXJyGptrMewt3Hoziy","type":"tool_result","content":"     1→/**\n     2→ * Cleanup job.\n     3→ * Removes stale data and performs maintenance tasks.\n     4→ */\n     5→\n     6→import { getAllUsers } from '@monorepo/core';\n     7→\n     8→export interface CleanupResult {\n     9→  staleRecords: number;\n    10→  cleanedUp: number;\n    11→  duration: number;\n    12→}\n    13→\n    14→export async function cleanupJob(): Promise<CleanupResult> {\n    15→  const startTime = Date.now();\n    16→\n    17→  // Get all users to check for stale records\n    18→  const users = getAllUsers();\n    19→\n    20→  let staleRecords = 0;\n    21→  let cleanedUp = 0;\n    22→\n    23→  for (const user of users) {\n    24→    const createdDate = new Date(user.createdAt);\n    25→    const now = new Date();\n    26→    const daysSinceCreation =\n    27→      (now.getTime() - createdDate.getTime()) / (1000 * 60 * 60 * 24);\n    28→\n    29→    // Mark records older than 365 days as stale (simulation)\n    30→    if (daysSinceCreation > 365) {\n    31→      staleRecords++;\n    32→      // In a real app, we'd archive or delete\n    33→      cleanedUp++;\n    34→    }\n    35→  }\n    36→\n    37→  const duration = Date.now() - startTime;\n    38→\n    39→  console.log(\n    40→    `Cleanup complete: ${staleRecords} stale, ${cleanedUp} cleaned in ${duration}ms`\n    41→  );\n    42→\n    43→  return { staleRecords, cleanedUp, duration };\n    44→}\n    45→\n    46→export function getCleanupThresholdDays(): number {\n    47→  return 365;\n    48→}\n    49→"}]},"parent_tool_use_id":"toolu_01NZgnBkugQVEYoC9wmtUgGE","session_id":"db3f48a0-46d6-440b-8c6e-8358c53cd4ad","uuid":"0810ed51-29cf-4176-af86-b2775f2641ea"}
