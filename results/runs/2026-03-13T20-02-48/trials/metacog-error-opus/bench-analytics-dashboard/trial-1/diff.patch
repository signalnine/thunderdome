+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { AuthRequest, authMiddleware } from '../auth.js';
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // All dashboard routes require auth
+  router.use(authMiddleware);
+
+  // Create dashboard
+  router.post('/', (req: AuthRequest, res: Response) => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Dashboard name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenant_id;
+    const ownerId = req.user!.id;
+    const dashConfig = config ? JSON.stringify(config) : '{}';
+    const now = new Date().toISOString();
+
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, ownerId, dashConfig, now, now);
+
+    res.status(201).json({
+      dashboard: { id, tenant_id: tenantId, name, owner_id: ownerId, config: config || {}, created_at: now, updated_at: now }
+    });
+  });
+
+  // List dashboards for tenant
+  router.get('/', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(tenantId) as Array<{
+      id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string;
+    }>;
+
+    res.json({
+      dashboards: dashboards.map(d => ({
+        ...d,
+        config: JSON.parse(d.config)
+      }))
+    });
+  });
+
+  // Get single dashboard
+  router.get('/:id', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as {
+      id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string;
+    } | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    // Also get widgets
+    const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboard.id) as Array<{
+      id: string; dashboard_id: string; type: string; config: string; position_x: number; position_y: number; width: number; height: number;
+    }>;
+
+    res.json({
+      dashboard: {
+        ...dashboard,
+        config: JSON.parse(dashboard.config),
+        widgets: widgets.map(w => ({ ...w, config: JSON.parse(w.config) }))
+      }
+    });
+  });
+
+  // Update dashboard
+  router.put('/:id', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as {
+      id: string; tenant_id: string; name: string; owner_id: string; config: string;
+    } | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const { name, config } = req.body;
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?').run(
+      updatedName, updatedConfig, now, req.params.id
+    );
+
+    res.json({
+      dashboard: {
+        id: existing.id,
+        tenant_id: tenantId,
+        name: updatedName,
+        owner_id: existing.owner_id,
+        config: config !== undefined ? config : JSON.parse(existing.config),
+        updated_at: now
+      }
+    });
+  });
+
+  // Delete dashboard
+  router.delete('/:id', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const existing = db.prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId);
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);
+
+    res.json({ message: 'Dashboard deleted' });
+  });
+
+  // Add widget to dashboard
+  router.post('/:id/widgets', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const dashboard = db.prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId);
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const { type, config, position_x, position_y, width, height } = req.body;
+
+    if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+      res.status(400).json({ error: 'Valid widget type required (counter, timeseries, breakdown, funnel)' });
+      return;
+    }
+
+    const id = uuidv4();
+    const widgetConfig = config ? JSON.stringify(config) : '{}';
+
+    db.prepare(
+      'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, req.params.id, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);
+
+    res.status(201).json({
+      widget: { id, dashboard_id: req.params.id, type, config: config || {}, position_x: position_x || 0, position_y: position_y || 0, width: width || 1, height: height || 1 }
+    });
+  });
+
+  return router;
+}
diff --git a/src/routes/events.ts b/src/routes/events.ts
new file mode 100644
index 0000000..a078941
--- /dev/null
+++ b/src/routes/events.ts
@@ -0,0 +1,196 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { AuthRequest, authMiddleware } from '../auth.js';
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // All event routes require auth
+  router.use(authMiddleware);
+
+  // Ingest single event
+  router.post('/', (req: AuthRequest, res: Response) => {
+    const { name, properties, timestamp, session_id } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Event name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenant_id;
+    const userId = req.user!.id;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : '{}';
+
+    db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, session_id || null);
+
+    res.status(201).json({ event: { id, tenant_id: tenantId, name, properties: properties || {}, timestamp: eventTimestamp, user_id: userId, session_id: session_id || null } });
+  });
+
+  // Ingest batch of events
+  router.post('/batch', (req: AuthRequest, res: Response) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: 'events array is required and must not be empty' });
+      return;
+    }
+
+    const tenantId = req.user!.tenant_id;
+    const userId = req.user!.id;
+
+    const insert = db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    );
+
+    const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string; session_id?: string }>) => {
+      const results: Array<{ id: string; name: string }> = [];
+      for (const evt of evts) {
+        if (!evt.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = evt.timestamp || new Date().toISOString();
+        const eventProperties = evt.properties ? JSON.stringify(evt.properties) : '{}';
+        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId, evt.session_id || null);
+        results.push({ id, name: evt.name });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  // Query: count
+  router.post('/query/count', (req: AuthRequest, res: Response) => {
+    const { event_name, start_date, end_date, filters } = req.body;
+    const tenantId = req.user!.tenant_id;
+
+    let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ' AND json_extract(properties, ?) = ?';
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Query: timeseries
+  router.post('/query/timeseries', (req: AuthRequest, res: Response) => {
+    const { event_name, start_date, end_date, interval, filters } = req.body;
+    const tenantId = req.user!.tenant_id;
+
+    // Default interval is 'day'
+    const bucket = interval || 'day';
+    let dateFormat: string;
+
+    switch (bucket) {
+      case 'hour':
+        dateFormat = '%Y-%m-%dT%H:00:00';
+        break;
+      case 'month':
+        dateFormat = '%Y-%m-01';
+        break;
+      case 'day':
+      default:
+        dateFormat = '%Y-%m-%d';
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ' AND json_extract(properties, ?) = ?';
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += ' GROUP BY period ORDER BY period ASC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ period: string; count: number }>;
+    res.json({ timeseries: results });
+  });
+
+  // Query: breakdown
+  router.post('/query/breakdown', (req: AuthRequest, res: Response) => {
+    const { event_name, property, start_date, end_date, filters } = req.body;
+    const tenantId = req.user!.tenant_id;
+
+    if (!property) {
+      res.status(400).json({ error: 'property is required for breakdown queries' });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ' AND json_extract(properties, ?) = ?';
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += ' GROUP BY value ORDER BY count DESC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;
+    res.json({ breakdown: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
new file mode 100644
index 0000000..96ff825
--- /dev/null
+++ b/src/routes/export.ts
@@ -0,0 +1,132 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { AuthRequest, authMiddleware } from '../auth.js';
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = 'id,tenant_id,name,properties,timestamp,user_id,session_id';
+  const rows = events.map(e => {
+    const props = e.properties.replace(/"/g, '""');
+    return `${e.id},${e.tenant_id},${e.name},"${props}",${e.timestamp},${e.user_id || ''},${e.session_id || ''}`;
+  });
+  return [header, ...rows].join('\n');
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const header = 'id,tenant_id,name,owner_id,config,created_at,updated_at';
+  const rows = dashboards.map(d => {
+    const config = d.config.replace(/"/g, '""');
+    return `${d.id},${d.tenant_id},${d.name},${d.owner_id},"${config}",${d.created_at},${d.updated_at}`;
+  });
+  return [header, ...rows].join('\n');
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // All export routes require auth
+  router.use(authMiddleware);
+
+  // Export events as JSON
+  router.get('/events/json', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    sql += ' ORDER BY timestamp DESC';
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const parsed = events.map(e => ({ ...e, properties: JSON.parse(e.properties) }));
+
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get('/events/csv', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    sql += ' ORDER BY timestamp DESC';
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboards as JSON
+  router.get('/dashboards/json', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(tenantId) as DashboardRow[];
+    const parsed = dashboards.map(d => ({ ...d, config: JSON.parse(d.config) }));
+
+    res.json({ dashboards: parsed });
+  });
+
+  // Export dashboards as CSV
+  router.get('/dashboards/csv', (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenant_id;
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(tenantId) as DashboardRow[];
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="dashboards.csv"');
+    res.send(dashboardsToCsv(dashboards));
+  });
+
+  return router;
+}
