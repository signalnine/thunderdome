+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Returns the topological order if no cycle exists, throws on cycle.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Validate that prerequisites reference existing events
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        if (prereq === e.id) {
+          throw new Error(`Cycle detected: event "${e.id}" has a self-reference in prerequisites`);
+        }
+      }
+    }
+  }
+
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) {
+    color.set(e.id, WHITE);
+  }
+
+  const order: string[] = [];
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        const c = color.get(prereq);
+        if (c === GRAY) {
+          throw new Error(`Cycle detected in prerequisites involving event "${prereq}"`);
+        }
+        if (c === WHITE) {
+          dfs(prereq);
+        }
+      }
+    }
+    color.set(id, BLACK);
+    order.push(id);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) {
+      dfs(e.id);
+    }
+  }
+
+  return order;
+}
+
+/**
+ * Find the earliest start time for an event in a given room, considering:
+ * - Room's existing schedule (gaps between events)
+ * - Prerequisite completion times
+ * - Schedule window boundaries
+ */
+function findEarliestStart(
+  eventDuration: number,
+  roomId: string,
+  roomSchedule: Assignment[],
+  prerequisiteEndTimes: number[],
+  options: ScheduleOptions,
+  gap: number
+): number | null {
+  // Earliest possible start based on prerequisites
+  let earliest = options.startTime;
+  for (const prereqEnd of prerequisiteEndTimes) {
+    const afterPrereq = prereqEnd + gap;
+    if (afterPrereq > earliest) {
+      earliest = afterPrereq;
+    }
+  }
+
+  // Check if the event can even fit in the window
+  if (earliest + eventDuration > options.endTime) {
+    return null;
+  }
+
+  // Sort existing assignments in this room by start time
+  const sorted = [...roomSchedule].sort((a, b) => a.startTime - b.startTime);
+
+  // Try to fit before the first event, between events, or after the last event
+  let candidateStart = earliest;
+
+  for (const existing of sorted) {
+    // If we can fit before this existing event
+    if (candidateStart + eventDuration <= existing.startTime - gap) {
+      // We found a slot, but also verify it ends within the window
+      if (candidateStart + eventDuration <= options.endTime) {
+        return candidateStart;
+      }
+      return null;
+    }
+    // Otherwise, move candidate past this existing event
+    const afterExisting = existing.endTime + gap;
+    if (afterExisting > candidateStart) {
+      candidateStart = afterExisting;
+    }
+  }
+
+  // Try to fit after all existing events
+  if (candidateStart + eventDuration <= options.endTime) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+/**
+ * Schedule events into rooms respecting all constraints.
+ * Uses a most-constrained-first heuristic after topological sorting.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? 15;
+
+  // Step 1: Topological sort (also detects cycles)
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Step 2: Compute topological levels for ordering heuristic
+  const topoLevel = new Map<string, number>();
+  for (const id of topoOrder) {
+    const event = eventMap.get(id)!;
+    let level = 0;
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        const prereqLevel = topoLevel.get(prereq);
+        if (prereqLevel !== undefined && prereqLevel + 1 > level) {
+          level = prereqLevel + 1;
+        }
+      }
+    }
+    topoLevel.set(id, level);
+  }
+
+  // Step 3: Count how many rooms can fit each event (for constraint difficulty)
+  const fittingRoomCount = new Map<string, number>();
+  for (const e of events) {
+    const attendees = e.attendees ?? 1;
+    let count = 0;
+    for (const r of rooms) {
+      if (r.capacity >= attendees) {
+        count++;
+      }
+    }
+    fittingRoomCount.set(e.id, count);
+  }
+
+  // Step 4: Sort events — topological level first, then most-constrained-first
+  // Most constrained = fewer fitting rooms, longer duration
+  const sortedEvents = [...topoOrder];
+  sortedEvents.sort((a, b) => {
+    const levelA = topoLevel.get(a)!;
+    const levelB = topoLevel.get(b)!;
+    if (levelA !== levelB) return levelA - levelB;
+
+    // Fewer fitting rooms = more constrained
+    const fittingA = fittingRoomCount.get(a)!;
+    const fittingB = fittingRoomCount.get(b)!;
+    if (fittingA !== fittingB) return fittingA - fittingB;
+
+    // Longer duration = harder to fit
+    const eventA = eventMap.get(a)!;
+    const eventB = eventMap.get(b)!;
+    return eventB.duration - eventA.duration;
+  });
+
+  // Step 5: Greedy assignment with backtracking capability
+  const roomSchedules = new Map<string, Assignment[]>();
+  for (const r of rooms) {
+    roomSchedules.set(r.id, []);
+  }
+
+  const assignments: Assignment[] = [];
+  const assignedEvents = new Map<string, Assignment>();
+  const unscheduled: string[] = [];
+
+  // Sort rooms by capacity (ascending) for best-fit assignment
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  for (const eventId of sortedEvents) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+
+    // Get prerequisite end times
+    const prereqEndTimes: number[] = [];
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        const prereqAssignment = assignedEvents.get(prereqId);
+        if (prereqAssignment) {
+          prereqEndTimes.push(prereqAssignment.endTime);
+        }
+        // If a prerequisite wasn't scheduled, this event can't be scheduled either
+        // (unless the prerequisite ID doesn't exist in events — external dependency)
+        else if (eventMap.has(prereqId)) {
+          // Prerequisite exists but wasn't scheduled — skip this event
+          prereqEndTimes.push(Infinity);
+        }
+      }
+    }
+
+    // If any prerequisite wasn't scheduled, skip
+    if (prereqEndTimes.some(t => t === Infinity)) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    // Try preferred room first, then all rooms sorted by smallest sufficient capacity
+    let bestAssignment: Assignment | null = null;
+    let bestStart = Infinity;
+
+    const roomOrder: Room[] = [];
+    if (event.preferredRoom) {
+      const preferred = sortedRooms.find(r => r.id === event.preferredRoom);
+      if (preferred && preferred.capacity >= attendees) {
+        roomOrder.push(preferred);
+      }
+    }
+    for (const r of sortedRooms) {
+      if (r.capacity >= attendees && (!event.preferredRoom || r.id !== event.preferredRoom)) {
+        roomOrder.push(r);
+      }
+    }
+
+    for (const room of roomOrder) {
+      const start = findEarliestStart(
+        event.duration,
+        room.id,
+        roomSchedules.get(room.id)!,
+        prereqEndTimes,
+        options,
+        gap
+      );
+
+      if (start !== null) {
+        // Prefer preferred room if it can fit at the earliest possible time
+        if (event.preferredRoom && room.id === event.preferredRoom) {
+          bestAssignment = {
+            eventId: event.id,
+            roomId: room.id,
+            startTime: start,
+            endTime: start + event.duration,
+          };
+          break; // Preferred room works, use it
+        }
+
+        // Otherwise pick the room that gives the earliest start time
+        if (start < bestStart) {
+          bestStart = start;
+          bestAssignment = {
+            eventId: event.id,
+            roomId: room.id,
+            startTime: start,
+            endTime: start + event.duration,
+          };
+        }
+      }
+    }
+
+    if (bestAssignment) {
+      assignments.push(bestAssignment);
+      assignedEvents.set(eventId, bestAssignment);
+      roomSchedules.get(bestAssignment.roomId)!.push(bestAssignment);
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
