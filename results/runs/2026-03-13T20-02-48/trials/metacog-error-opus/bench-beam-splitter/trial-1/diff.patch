+
+  // To avoid infinite loops with deduplication, track (row, col, dir) seen states
+  const seen = new Set<string>();
+  seen.add(`${source[0]},${source[1]},down`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+
+    // Move the beam one step in its current direction
+    const [nr, nc] = nextPos(row, col, dir);
+
+    if (!inBounds(nr, nc, rows, cols)) {
+      // Beam exits grid - absorbed
+      continue;
+    }
+
+    visited.add(`${nr},${nc}`);
+
+    const cell = grid[nr][nc];
+    if (cell === '^') {
+      // Splitter: beam splits into down-left and down-right
+      const key1 = `${nr},${nc},down-left`;
+      const key2 = `${nr},${nc},down-right`;
+      if (!seen.has(key1)) {
+        seen.add(key1);
+        beams.push({ row: nr, col: nc, dir: 'down-left' });
+      }
+      if (!seen.has(key2)) {
+        seen.add(key2);
+        beams.push({ row: nr, col: nc, dir: 'down-right' });
+      }
+    } else {
+      // Continue in same direction
+      const key = `${nr},${nc},${dir}`;
+      if (!seen.has(key)) {
+        seen.add(key);
+        beams.push({ row: nr, col: nc, dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // Aggregate path counts by (row, col, dir) to avoid exponential blowup.
+  // Since beams only move downward, we can process row by row.
+  // Map from "row,col,dir" -> bigint count of paths at that state
+  let currentBeams = new Map<string, bigint>();
+  const startKey = `${source[0]},${source[1]},down`;
+  currentBeams.set(startKey, 1n);
+
+  let totalPaths = 0n;
+
+  while (currentBeams.size > 0) {
+    const nextBeams = new Map<string, bigint>();
+
+    for (const [key, count] of currentBeams) {
+      const parts = key.split(',');
+      const row = parseInt(parts[0]);
+      const col = parseInt(parts[1]);
+      const dir = parts[2] as Direction;
+
+      const [nr, nc] = nextPos(row, col, dir);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        // Beam exits - these are complete paths
+        totalPaths += count;
+        continue;
+      }
+
+      const cell = grid[nr][nc];
+      if (cell === '^') {
+        // Splitter: split into two directions
+        const key1 = `${nr},${nc},down-left`;
+        const key2 = `${nr},${nc},down-right`;
+        nextBeams.set(key1, (nextBeams.get(key1) ?? 0n) + count);
+        nextBeams.set(key2, (nextBeams.get(key2) ?? 0n) + count);
+      } else {
+        // Continue in same direction
+        const nk = `${nr},${nc},${dir}`;
+        nextBeams.set(nk, (nextBeams.get(nk) ?? 0n) + count);
+      }
+    }
+
+    currentBeams = nextBeams;
+  }
+
+  return totalPaths;
+}
