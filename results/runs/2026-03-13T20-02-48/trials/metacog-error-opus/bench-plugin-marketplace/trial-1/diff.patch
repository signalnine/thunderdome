--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,127 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      const visited = new Set<string>();
+
+      function build(pluginName: string): DependencyNode {
+        const manifest = registry.get(pluginName);
+        if (!manifest) {
+          return { name: pluginName, version: 'unknown', dependencies: [] };
+        }
+
+        const key = `${manifest.name}@${manifest.version}`;
+        if (visited.has(key)) {
+          // Circular reference — return node without further recursion
+          return { name: manifest.name, version: manifest.version, dependencies: [] };
+        }
+
+        visited.add(key);
+        const deps: DependencyNode[] = [];
+        for (const depName of Object.keys(manifest.dependencies)) {
+          deps.push(build(depName));
+        }
+
+        return {
+          name: manifest.name,
+          version: manifest.version,
+          dependencies: deps,
+        };
+      }
+
+      return build(name);
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles: string[][] = [];
+      const visited = new Set<string>();
+      const stack: string[] = [];
+      const inStack = new Set<string>();
+
+      function dfs(pluginName: string): void {
+        if (inStack.has(pluginName)) {
+          // Found a cycle
+          const cycleStart = stack.indexOf(pluginName);
+          const cycle = [...stack.slice(cycleStart), pluginName];
+          cycles.push(cycle);
+          return;
+        }
+
+        if (visited.has(pluginName)) {
+          return;
+        }
+
+        visited.add(pluginName);
+        inStack.add(pluginName);
+        stack.push(pluginName);
+
+        const manifest = registry.get(pluginName);
+        if (manifest) {
+          for (const depName of Object.keys(manifest.dependencies)) {
+            dfs(depName);
+          }
+        }
+
+        stack.pop();
+        inStack.delete(pluginName);
+      }
+
+      dfs(name);
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const result: string[] = [];
+      const visited = new Set<string>();
+      const visiting = new Set<string>();
+
+      function visit(pluginName: string): void {
+        if (visited.has(pluginName)) return;
+        if (visiting.has(pluginName)) {
+          throw new Error(`Circular dependency detected involving ${pluginName}`);
+        }
+
+        visiting.add(pluginName);
+        const manifest = registry.get(pluginName);
+        if (manifest) {
+          for (const depName of Object.keys(manifest.dependencies)) {
+            visit(depName);
+          }
+        }
+        visiting.delete(pluginName);
+        visited.add(pluginName);
+        result.push(pluginName);
+      }
+
+      visit(name);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const deps = new Set<string>();
+      const visited = new Set<string>();
+
+      function collect(pluginName: string): void {
+        if (visited.has(pluginName)) return;
+        visited.add(pluginName);
+
+        const manifest = registry.get(pluginName);
+        if (manifest) {
+          for (const depName of Object.keys(manifest.dependencies)) {
+            deps.add(depName);
+            collect(depName);
+          }
+        }
+      }
+
+      collect(name);
+      return Array.from(deps);
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const cycles = this.detectCycles(name, registry);
+      return cycles !== null;
+    },
+  };
+}
