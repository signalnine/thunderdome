ect(tree.dependencies[0].dependencies).toHaveLength(1);\n      expect(tree.dependencies[0].dependencies[0].name).toBe('dep-b');\n    });\n\n    it('should handle missing plugins gracefully', () => {\n      registry.register(makeManifest('root', { 'missing': '^1.0.0' }));\n      const tree = depsService.buildTree('root', registry);\n      expect(tree.dependencies).toHaveLength(1);\n      expect(tree.dependencies[0].name).toBe('missing');\n      expect(tree.dependencies[0].version).toBe('unknown');\n    });\n  });\n\n  describe('detectCycles', () => {\n    it('should return null for no cycles', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0' }));\n      registry.register(makeManifest('b'));\n\n      const cycles = depsService.detectCycles('a', registry);\n      expect(cycles).toBeNull();\n    });\n\n    it('should detect a direct cycle', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0' }));\n      registry.register(makeManifest('b', { 'a': '^1.0.0' }));\n\n      const cycles = depsService.detectCycles('a', registry);\n      expect(cycles).not.toBeNull();\n      expect(cycles!.length).toBeGreaterThan(0);\n    });\n\n    it('should detect an indirect cycle', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0' }));\n      registry.register(makeManifest('b', { 'c': '^1.0.0' }));\n      registry.register(makeManifest('c', { 'a': '^1.0.0' }));\n\n      const cycles = depsService.detectCycles('a', registry);\n      expect(cycles).not.toBeNull();\n      expect(cycles!.length).toBeGreaterThan(0);\n    });\n  });\n\n  describe('hasCircularDependency', () => {\n    it('should return false for acyclic graph', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0' }));\n      registry.register(makeManifest('b'));\n\n      expect(depsService.hasCircularDependency('a', registry)).toBe(false);\n    });\n\n    it('should return true for cyclic graph', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0' }));\n      registry.register(makeManifest('b', { 'a': '^1.0.0' }));\n\n      expect(depsService.hasCircularDependency('a', registry)).toBe(true);\n    });\n  });\n\n  describe('topologicalSort', () => {\n    it('should return correct order for linear chain', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0' }));\n      registry.register(makeManifest('b', { 'c': '^1.0.0' }));\n      registry.register(makeManifest('c'));\n\n      const sorted = depsService.topologicalSort('a', registry);\n      expect(sorted).toEqual(['c', 'b', 'a']);\n    });\n\n    it('should handle single plugin', () => {\n      registry.register(makeManifest('solo'));\n      const sorted = depsService.topologicalSort('solo', registry);\n      expect(sorted).toEqual(['solo']);\n    });\n\n    it('should throw on circular dependency', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0' }));\n      registry.register(makeManifest('b', { 'a': '^1.0.0' }));\n\n      expect(() => depsService.topologicalSort('a', registry)).toThrow('Circular dependency');\n    });\n\n    it('should handle diamond dependencies', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0', 'c': '^1.0.0' }));\n      registry.register(makeManifest('b', { 'd': '^1.0.0' }));\n      registry.register(makeManifest('c', { 'd': '^1.0.0' }));\n      registry.register(makeManifest('d'));\n\n      const sorted = depsService.topologicalSort('a', registry);\n      // d should come before b and c, and all before a\n      expect(sorted.indexOf('d')).toBeLessThan(sorted.indexOf('b'));\n      expect(sorted.indexOf('d')).toBeLessThan(sorted.indexOf('c'));\n      expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));\n      expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('a'));\n    });\n  });\n\n  describe('flattenDependencies', () => {\n    it('should return empty array for plugin with no deps', () => {\n      registry.register(makeManifest('solo'));\n      const flat = depsService.flattenDependencies('solo', registry);\n      expect(flat).toHaveLength(0);\n    });\n\n    it('should return all transitive dependencies', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0' }));\n      registry.register(makeManifest('b', { 'c': '^1.0.0' }));\n      registry.register(makeManifest('c'));\n\n      const flat = depsService.flattenDependencies('a', registry);\n      expect(flat).toContain('b');\n      expect(flat).toContain('c');\n      expect(flat).not.toContain('a');\n    });\n\n    it('should handle diamond deps without duplicates', () => {\n      registry.register(makeManifest('a', { 'b': '^1.0.0', 'c': '^1.0.0' }));\n      registry.register(makeManifest('b', { 'd': '^1.0.0' }));\n      registry.register(makeManifest('c', { 'd': '^1.0.0' }));\n      registry.register(makeManifest('d'));\n\n      const flat = depsService.flattenDependencies('a', registry);\n      expect(flat).toContain('b');\n      expect(flat).toContain('c');\n      expect(flat).toContain('d');\n      // No duplicates\n      expect(new Set(flat).size).toBe(flat.length);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01GxvgabGawT7MDCPCi91f9C","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BZkKTmTutGpk4JaQThPKd9","name":"Write","input":{"file_path":"/workspace/tests/marketplace.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { createMarketplace } from '../src/index.js';\nimport type { Marketplace } from '../src/index.js';\nimport type { PluginManifest } from '../src/types.js';\n\nfunction makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {\n  return {\n    name: 'test-plugin',\n    version: '1.0.0',\n    description: 'A test plugin',\n    author: 'tester',\n    dependencies: {},\n    entryPoint: '2 + 2',\n    permissions: [],\n    ...overrides,\n  };\n}\n\ndescribe('Marketplace Integration', () => {\n  let marketplace: Marketplace;\n\n  beforeEach(() => {\n    marketplace = createMarketplace();\n  });\n\n  describe('installPlugin', () => {\n    it('should install a simple plugin with no dependencies', async () => {\n      const manifest = makeManifest();\n      const result = await marketplace.installPlugin(manifest);\n\n      expect(result.resolvedDependencies).toEqual([]);\n      expect(result.executionResult.success).toBe(true);\n      expect(result.executionResult.output).toBe(4);\n    });\n\n    it('should register the plugin in the registry after install', async () => {\n      const manifest = makeManifest();\n      await marketplace.installPlugin(manifest);\n\n      const registered = marketplace.registry.get('test-plugin');\n      expect(registered).not.toBeNull();\n      expect(registered!.name).toBe('test-plugin');\n    });\n\n    it('should resolve dependencies during install', async () => {\n      // Register dependency first\n      marketplace.registry.register(makeManifest({\n        name: 'dep-plugin',\n        version: '1.0.0',\n        entryPoint: '\"dep loaded\"',\n      }));\n      marketplace.registry.register(makeManifest({\n        name: 'dep-plugin',\n        version: '1.1.0',\n        entryPoint: '\"dep loaded\"',\n      }));\n\n      const manifest = makeManifest({\n        name: 'main-plugin',\n        dependencies: { 'dep-plugin': '^1.0.0' },\n      });\n\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.resolvedDependencies).toHaveLength(1);\n      expect(result.resolvedDependencies[0].name).toBe('dep-plugin');\n      expect(result.resolvedDependencies[0].version).toBe('1.1.0');\n    });\n\n    it('should reject plugin with missing name', async () => {\n      const manifest = makeManifest({ name: '' });\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');\n    });\n\n    it('should reject plugin with missing version', async () => {\n      const manifest = makeManifest({ version: '' });\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');\n    });\n\n    it('should reject plugin with missing entryPoint', async () => {\n      const manifest = makeManifest({ entryPoint: '' });\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('entryPoint');\n    });\n\n    it('should detect and reject circular dependencies', async () => {\n      // Pre-register plugin-b which depends on plugin-a\n      marketplace.registry.register(makeManifest({\n        name: 'plugin-b',\n        version: '1.0.0',\n        dependencies: { 'plugin-a': '^1.0.0' },\n      }));\n\n      // Now install plugin-a which depends on plugin-b — cycle!\n      const manifest = makeManifest({\n        name: 'plugin-a',\n        version: '1.0.0',\n        dependencies: { 'plugin-b': '^1.0.0' },\n      });\n\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency');\n\n      // Plugin should be removed from registry after cycle detection\n      expect(marketplace.registry.get('plugin-a')).toBeNull();\n    });\n\n    it('should handle plugin execution errors', async () => {\n      const manifest = makeManifest({\n        entryPoint: 'throw new Error(\"plugin init failed\")',\n      });\n\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.executionResult.success).toBe(false);\n      expect(result.executionResult.error).toBe('plugin init failed');\n    });\n\n    it('should execute entry point code in sandbox', async () => {\n      const manifest = makeManifest({\n        entryPoint: '({ status: \"initialized\", value: 42 })',\n      });\n\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.executionResult.success).toBe(true);\n      expect(result.executionResult.output).toEqual({ status: 'initialized', value: 42 });\n    });\n  });\n\n  describe('full workflow', () => {\n    it('should support installing, reviewing, and querying plugins', async () => {\n      // Install a plugin\n      const manifest = makeManifest({\n        name: 'awesome-plugin',\n        version: '1.0.0',\n        entryPoint: '\"awesome\"',\n      });\n      const installResult = await marketplace.installPlugin(manifest);\n      expect(installResult.executionResult.success).toBe(true);\n\n      // Add reviews\n      marketplace.reviews.addReview({\n        pluginName: 'awesome-plugin',\n        pluginVersion: '1.0.0',\n        userId: 'user1',\n        rating: 5,\n        comment: 'Love it!',\n      });\n      marketplace.reviews.addReview({\n        pluginName: 'awesome-plugin',\n        pluginVersion: '1.0.0',\n        userId: 'user2',\n        rating: 4,\n        comment: 'Pretty good',\n      });\n\n      // Check average rating\n      const avg = marketplace.reviews.getAverageRating('awesome-plugin');\n      expect(avg).toBe(4.5);\n\n      // Search for the plugin\n      const searchResults = marketplace.registry.search('awesome');\n      expect(searchResults).toHaveLength(1);\n\n      // Check dependency graph\n      const tree = marketplace.deps.buildTree('awesome-plugin', marketplace.registry);\n      expect(tree.name).toBe('awesome-plugin');\n      expect(tree.dependencies).toHaveLength(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2295,"cache_read_input_tokens":38499,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2295},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c05f9106-1d24-4163-b1d4-c4d5231386ae","uuid":"427bbbfe-e869-4ed2-87b8-6ae98a856972"}
