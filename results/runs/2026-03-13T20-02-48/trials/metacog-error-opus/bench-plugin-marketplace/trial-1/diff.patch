Version: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Great!',\n    });\n\n    const removed = reviews.removeReview(review.id);\n    expect(removed).toBe(true);\n    expect(reviews.getReviews('test-plugin')).toHaveLength(0);\n  });\n\n  it('should return false when removing nonexistent review', () => {\n    expect(reviews.removeReview(9999)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Great!',\n    });\n    reviews.addReview({\n      pluginName: 'plugin-b',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 3,\n      comment: 'OK',\n    });\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 4,\n      comment: 'Good',\n    });\n\n    const user1Reviews = reviews.getReviewsByUser('user1');\n    expect(user1Reviews).toHaveLength(2);\n    expect(user1Reviews.every(r => r.userId === 'user1')).toBe(true);\n  });\n\n  it('should get review count for a plugin', () => {\n    reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Great!',\n    });\n    reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 3,\n      comment: 'OK',\n    });\n\n    expect(reviews.getReviewCount('test-plugin')).toBe(2);\n    expect(reviews.getReviewCount('nonexistent')).toBe(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":846,"cache_read_input_tokens":35695,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":846},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,