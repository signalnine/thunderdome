@@ -0,0 +1,76 @@
+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import {
+  PaymentService,
+  PaymentStatus,
+  Events,
+  PaymentProcessedEvent,
+} from '../types.js';
+
+export interface PaymentOptions {
+  simulateFailure?: boolean;
+  simulateTimeout?: boolean;
+  delayMs?: number;
+}
+
+interface Transaction {
+  transactionId: string;
+  orderId: string;
+  amount: number;
+  status: PaymentStatus;
+}
+
+export function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {
+  const transactions = new Map<string, Transaction>();
+
+  return {
+    async processPayment(orderId: string, amount: number) {
+      if (options.delayMs) {
+        await new Promise(resolve => setTimeout(resolve, options.delayMs));
+      }
+
+      if (options.simulateTimeout) {
+        const event: PaymentProcessedEvent = { orderId, status: PaymentStatus.TIMEOUT, error: 'Payment timed out' };
+        await bus.emit(Events.PAYMENT_PROCESSED, event);
+        return { status: PaymentStatus.TIMEOUT, error: 'Payment timed out' };
+      }
+
+      if (options.simulateFailure) {
+        const event: PaymentProcessedEvent = { orderId, status: PaymentStatus.FAILED, error: 'Payment failed' };
+        await bus.emit(Events.PAYMENT_PROCESSED, event);
+        return { status: PaymentStatus.FAILED, error: 'Payment failed' };
+      }
+
+      const transactionId = uuidv4();
+      const transaction: Transaction = {
+        transactionId,
+        orderId,
+        amount,
+        status: PaymentStatus.SUCCESS,
+      };
+      transactions.set(transactionId, transaction);
+
+      const event: PaymentProcessedEvent = { orderId, status: PaymentStatus.SUCCESS, transactionId };
+      await bus.emit(Events.PAYMENT_PROCESSED, event);
+
+      return { status: PaymentStatus.SUCCESS, transactionId };
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      const transaction = transactions.get(transactionId);
+      if (!transaction || transaction.status !== PaymentStatus.SUCCESS) {
+        return false;
+      }
+      transaction.status = PaymentStatus.FAILED;
+
+      const event: PaymentProcessedEvent = {
+        orderId: transaction.orderId,
+        status: PaymentStatus.FAILED,
+        transactionId,
+      };
+      await bus.emit(Events.PAYMENT_PROCESSED, event);
+
+      return true;
+    },
+  };
+}
