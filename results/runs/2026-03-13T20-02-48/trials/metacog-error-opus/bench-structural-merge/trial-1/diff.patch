 const keys = Object.keys(obj);\n  if (keys.length === 0) {\n    // empty object is a leaf\n    out.set(prefix, obj);\n    return;\n  }\n  for (const key of keys) {\n    const path = prefix ? `${prefix}.${key}` : key;\n    collectPaths(obj[key], path, out);\n  }\n}\n\nfunction getByPath(obj: any, path: string): any {\n  const parts = path.split('.');\n  let cur = obj;\n  for (const p of parts) {\n    if (cur === null || cur === undefined || typeof cur !== 'object' || Array.isArray(cur)) {\n      return undefined;\n    }\n    cur = cur[p];\n  }\n  return cur;\n}\n\nfunction setByPath(obj: any, path: string, value: any): void {\n  const parts = path.split('.');\n  let cur = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const p = parts[i];\n    if (cur[p] === undefined || cur[p] === null || typeof cur[p] !== 'object' || Array.isArray(cur[p])) {\n      cur[p] = {};\n    }\n    cur = cur[p];\n  }\n  cur[parts[parts.length - 1]] = value;\n}\n\nfunction deleteByPath(obj: any, path: string): void {\n  const parts = path.split('.');\n  let cur = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const p = parts[i];\n    if (cur[p] === undefined || cur[p] === null || typeof cur[p] !== 'object') {\n      return;\n    }\n    cur = cur[p];\n  }\n  delete cur[parts[parts.length - 1]];\n}\n\nfunction valuesEqual(a: any, b: any): boolean {\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n/**\n * Three-way merge of two objects against a common base.\n * Returns merged object and list of conflict paths.\n */\nfunction threeWayMerge(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string,\n): { merged: object; conflicts: Conflict[] } {\n  const basePaths = new Map<string, any>();\n  const ourPaths = new Map<string, any>();\n  const theirPaths = new Map<string, any>();\n\n  if (base) collectPaths(base, '', basePaths);\n  if (ours) collectPaths(ours, '', ourPaths);\n  if (theirs) collectPaths(theirs, '', theirPaths);\n\n  // Collect all paths from all three\n  const allPaths = new Set<string>();\n  for (const p of basePaths.keys()) allPaths.add(p);\n  for (const p of ourPaths.keys()) allPaths.add(p);\n  for (const p of theirPaths.keys()) allPaths.add(p);\n\n  const merged: any = ours ? deepClone(ours) : {};\n  const conflicts: Conflict[] = [];\n\n  for (const path of allPaths) {\n    const baseVal = basePaths.has(path) ? basePaths.get(path) : undefined;\n    const ourVal = ourPaths.has(path) ? ourPaths.get(path) : undefined;\n    const theirVal = theirPaths.has(path) ? theirPaths.get(path) : undefined;\n\n    const baseHas = basePaths.has(path);\n    const ourHas = ourPaths.has(path);\n    const theirHas = theirPaths.has(path);\n\n    const ourChanged = !valuesEqual(baseVal, ourVal) || (baseHas !== ourHas);\n    const theirChanged = !valuesEqual(baseVal, theirVal) || (baseHas !== theirHas);\n\n    if (!ourChanged && !theirChanged) {\n      // No changes — keep as-is (already in merged from ours clone)\n      continue;\n    }\n\n    if (ourChanged && !theirChanged) {\n      // Only ours changed — already in merged\n      continue;\n    }\n\n    if (!ourChanged && theirChanged) {\n      // Only theirs changed — apply theirs\n      if (theirHas) {\n        setByPath(merged, path, deepClone(theirVal));\n      } else {\n        deleteByPath(merged, path);\n      }\n      continue;\n    }\n\n    // Both changed\n    if (valuesEqual(ourVal, theirVal) && ourHas === theirHas) {\n      // Both changed to the same value — no conflict\n      continue;\n    }\n\n    // Conflict! merged keeps \"ours\" value (already there)\n    conflicts.push({\n      documentId,\n      path,\n      base: baseVal !== undefined ? deepClone(baseVal) : undefined,\n      ours: ourVal !== undefined ? deepClone(ourVal) : undefined,\n      theirs: theirVal !== undefined ? deepClone(theirVal) : undefined,\n    });\n  }\n\n  // Sort conflicts by path for deterministic output\n  conflicts.sort((a, b) => a.path.localeComp