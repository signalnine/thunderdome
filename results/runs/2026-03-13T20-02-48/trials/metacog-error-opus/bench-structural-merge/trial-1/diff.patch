Content!);\n        allConflicts.push({\n          documentId: docId,\n          path: '',\n          base: baseContent ? deepClone(baseContent) : undefined,\n          ours: targetContent ? deepClone(targetContent) : undefined,\n          theirs: undefined,\n        });\n        continue;\n      }\n\n      // Both modified (neither deleted) — do three-way structural merge\n      const result = threeWayMerge(baseContent, targetContent, sourceContent, docId);\n      merged[docId] = result.merged;\n      allConflicts.push(...result.conflicts);\n    }\n\n    const hasConflicts = allConflicts.length > 0;\n\n    if (!hasConflicts) {\n      // Apply merge to target branch\n      for (const docId of allDocIds) {\n        if (docId in merged) {\n          const targetDoc = target.docs.get(docId);\n          if (targetDoc) {\n            // Check if content actually changed\n            if (!valuesEqual(targetDoc.content, merged[docId]) || targetDoc.deleted) {\n              const clonedContent = deepClone(merged[docId]);\n              const version: Version = {\n                id: makeVersionId(),\n                timestamp: Date.now(),\n                content: deepClone(clonedContent),\n              };\n              targetDoc.content = clonedContent;\n              targetDoc.deleted = false;\n              targetDoc.versions.push(version);\n            }\n          } else {\n            // New document from source\n            const clonedContent = deepClone(merged[docId]);\n            const version: Version = {\n              id: makeVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(clonedContent),\n            };\n            // Also bring over version history from source\n            const sourceDoc = source.docs.get(docId);\n            const existingVersions = sourceDoc ? sourceDoc.versions.map(v => ({\n              id: v.id,\n              timestamp: v.timestamp,\n              content: deepClone(v.content),\n            })) 