@@ -0,0 +1,480 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocState {
+  content: object;
+  deleted: boolean;
+  versions: Version[];
+}
+
+interface BranchState {
+  docs: Map<string, DocState>;
+  parent: string | null;
+  base: Map<string, DocState>;
+}
+
+type JsonValue = string | number | boolean | null | JsonValue[] | { [key: string]: JsonValue };
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function cloneDocState(ds: DocState): DocState {
+  return {
+    content: deepClone(ds.content),
+    deleted: ds.deleted,
+    versions: ds.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+  };
+}
+
+function cloneDocsMap(docs: Map<string, DocState>): Map<string, DocState> {
+  const cloned = new Map<string, DocState>();
+  for (const [id, ds] of docs) {
+    cloned.set(id, cloneDocState(ds));
+  }
+  return cloned;
+}
+
+let versionCounter = 0;
+
+function makeVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function collectPaths(obj: JsonValue, prefix: string, out: Map<string, JsonValue>): void {
+  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {
+    out.set(prefix, obj);
+    return;
+  }
+  const keys = Object.keys(obj);
+  if (keys.length === 0) {
+    out.set(prefix, obj);
+    return;
+  }
+  for (const key of keys) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    collectPaths(obj[key], path, out);
+  }
+}
+
+function setByPath(obj: Record<string, JsonValue>, path: string, value: JsonValue): void {
+  const parts = path.split('.');
+  let cur: Record<string, JsonValue> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const p = parts[i];
+    const next = cur[p];
+    if (next === undefined || next === null || typeof next !== 'object' || Array.isArray(next)) {
+      cur[p] = {};
+    }
+    cur = cur[p] as Record<string, JsonValue>;
+  }
+  cur[parts[parts.length - 1]] = value;
+}
+
+function deleteByPath(obj: Record<string, JsonValue>, path: string): void {
+  const parts = path.split('.');
+  let cur: Record<string, JsonValue> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const p = parts[i];
+    const next = cur[p];
+    if (next === undefined || next === null || typeof next !== 'object') {
+      return;
+    }
+    cur = next as Record<string, JsonValue>;
+  }
+  delete cur[parts[parts.length - 1]];
+}
+
+function valuesEqual(a: JsonValue | undefined, b: JsonValue | undefined): boolean {
+  return JSON.stringify(a) === JSON.stringify(b);
+}
+
+function threeWayMerge(
+  base: object | null,
+  ours: object | null,
+  theirs: object | null,
+  documentId: string,
+): { merged: object; conflicts: Conflict[] } {
+  const basePaths = new Map<string, JsonValue>();
+  const ourPaths = new Map<string, JsonValue>();
+  const theirPaths = new Map<string, JsonValue>();
+
+  if (base) collectPaths(base as JsonValue, '', basePaths);
+  if (ours) collectPaths(ours as JsonValue, '', ourPaths);
+  if (theirs) collectPaths(theirs as JsonValue, '', theirPaths);
+
+  const allPaths = new Set<string>();
+  for (const p of basePaths.keys()) allPaths.add(p);
+  for (const p of ourPaths.keys()) allPaths.add(p);
+  for (const p of theirPaths.keys()) allPaths.add(p);
+
+  const merged: Record<string, JsonValue> = ours ? deepClone(ours) as Record<string, JsonValue> : {};
+  const conflicts: Conflict[] = [];
+
+  for (const path of allPaths) {
+    const baseVal = basePaths.has(path) ? basePaths.get(path) : undefined;
+    const ourVal = ourPaths.has(path) ? ourPaths.get(path) : undefined;
+    const theirVal = theirPaths.has(path) ? theirPaths.get(path) : undefined;
+
+    const baseHas = basePaths.has(path);
+    const ourHas = ourPaths.has(path);
+    const theirHas = theirPaths.has(path);
+
+    const ourChanged = !valuesEqual(baseVal, ourVal) || (baseHas !== ourHas);
+    const theirChanged = !valuesEqual(baseVal, theirVal) || (baseHas !== theirHas);
+
+    if (!ourChanged && !theirChanged) {
+      continue;
+    }
+
+    if (ourChanged && !theirChanged) {
+      continue;
+    }
+
+    if (!ourChanged && theirChanged) {
+      if (theirHas && theirVal !== undefined) {
+        setByPath(merged, path, deepClone(theirVal));
+      } else {
+        deleteByPath(merged, path);
+      }
+      continue;
+    }
+
+    if (valuesEqual(ourVal, theirVal) && ourHas === theirHas) {
+      continue;
+    }
+
+    conflicts.push({
+      documentId,
+      path,
+      base: baseVal !== undefined ? deepClone(baseVal) : undefined,
+      ours: ourVal !== undefined ? deepClone(ourVal) : undefined,
+      theirs: theirVal !== undefined ? deepClone(theirVal) : undefined,
+    });
+  }
+
+  conflicts.sort((a, b) => a.path.localeCompare(b.path));
+
+  return { merged, conflicts };
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      docs: new Map(),
+      parent: null,
+      base: new Map(),
+    });
+  }
+
+  private getBranchState(name?: string): BranchState {
+    const branch = this.branches.get(name ?? this.currentBranch);
+    if (!branch) {
+      throw new Error(`Branch "${name ?? this.currentBranch}" does not exist`);
+    }
+    return branch;
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchState();
+    const existing = branch.docs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: makeVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+    branch.docs.set(id, {
+      content: cloned,
+      deleted: false,
+      versions: existing ? [...existing.versions, version] : [version],
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchState();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchState();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: makeVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+    doc.content = cloned;
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchState();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchState();
+    const doc = branch.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchState();
+    const doc = branch.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.getBranchState(sourceName);
+    this.branches.set(name, {
+      docs: cloneDocsMap(source.docs),
+      parent: sourceName,
+      base: cloneDocsMap(source.docs),
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys()).sort();
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const targetName = this.currentBranch;
+    const target = this.getBranchState(targetName);
+    const source = this.getBranchState(sourceBranch);
+
+    let base: Map<string, DocState>;
+    if (source.parent === targetName) {
+      base = source.base;
+    } else if (target.parent === sourceBranch) {
+      base = target.base;
+    } else {
+      base = this.findCommonBase(targetName, sourceBranch);
+    }
+
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const id of target.docs.keys()) allDocIds.add(id);
+    for (const id of source.docs.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseDoc = base.get(docId);
+      const targetDoc = target.docs.get(docId);
+      const sourceDoc = source.docs.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : null;
+      const targetContent = targetDoc && !targetDoc.deleted ? targetDoc.content : null;
+      const sourceContent = sourceDoc && !sourceDoc.deleted ? sourceDoc.content : null;
+
+      const baseDeleted = !baseDoc || baseDoc.deleted;
+      const targetDeleted = !targetDoc || targetDoc.deleted;
+      const sourceDeleted = !sourceDoc || sourceDoc.deleted;
+
+      const targetChanged = !valuesEqual(baseContent as JsonValue, targetContent as JsonValue) || baseDeleted !== targetDeleted;
+      const sourceChanged = !valuesEqual(baseContent as JsonValue, sourceContent as JsonValue) || baseDeleted !== sourceDeleted;
+
+      if (!targetChanged && !sourceChanged) {
+        if (targetContent !== null) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      if (targetChanged && !sourceChanged) {
+        if (targetContent !== null) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      if (!targetChanged && sourceChanged) {
+        if (sourceContent !== null) {
+          merged[docId] = deepClone(sourceContent);
+        }
+        continue;
+      }
+
+      // Both changed
+      if (targetDeleted && sourceDeleted) {
+        continue;
+      }
+
+      if (targetDeleted && !sourceDeleted) {
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent ? deepClone(baseContent) : undefined,
+          ours: undefined,
+          theirs: sourceContent ? deepClone(sourceContent) : undefined,
+        });
+        continue;
+      }
+
+      if (!targetDeleted && sourceDeleted) {
+        merged[docId] = deepClone(targetContent!);
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent ? deepClone(baseContent) : undefined,
+          ours: targetContent ? deepClone(targetContent) : undefined,
+          theirs: undefined,
+        });
+        continue;
+      }
+
+      const result = threeWayMerge(baseContent, targetContent, sourceContent, docId);
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+    }
+
+    const hasConflicts = allConflicts.length > 0;
+
+    if (!hasConflicts) {
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const targetDoc = target.docs.get(docId);
+          if (targetDoc) {
+            if (!valuesEqual(targetDoc.content as JsonValue, merged[docId] as JsonValue) || targetDoc.deleted) {
+              const clonedContent = deepClone(merged[docId]);
+              const version: Version = {
+                id: makeVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(clonedContent),
+              };
+              targetDoc.content = clonedContent;
+              targetDoc.deleted = false;
+              targetDoc.versions.push(version);
+            }
+          } else {
+            const clonedContent = deepClone(merged[docId]);
+            const sourceDoc = source.docs.get(docId);
+            const versions = sourceDoc ? sourceDoc.versions.map(v => ({
+              id: v.id,
+              timestamp: v.timestamp,
+              content: deepClone(v.content),
+            })) : [];
+            target.docs.set(docId, {
+              content: clonedContent,
+              deleted: false,
+              versions,
+            });
+          }
+        } else {
+          const targetDoc = target.docs.get(docId);
+          if (targetDoc && !targetDoc.deleted) {
+            targetDoc.deleted = true;
+          }
+        }
+      }
+
+      source.base = cloneDocsMap(target.docs);
+    }
+
+    return {
+      merged,
+      conflicts: allConflicts,
+      applied: !hasConflicts,
+    };
+  }
+
+  private findCommonBase(branch1: string, branch2: string): Map<string, DocState> {
+    const ancestors1 = new Set<string>();
+    let cur: string | null = branch1;
+    while (cur) {
+      ancestors1.add(cur);
+      const b = this.branches.get(cur);
+      cur = b?.parent ?? null;
+    }
+
+    cur = branch2;
+    while (cur) {
+      if (ancestors1.has(cur)) {
+        const b2 = this.branches.get(branch2);
+        if (b2 && b2.parent === cur) {
+          return b2.base;
+        }
+        const b1 = this.branches.get(branch1);
+        if (b1 && b1.parent === cur) {
+          return b1.base;
+        }
+        const ancestor = this.branches.get(cur);
+        return ancestor ? cloneDocsMap(ancestor.docs) : new Map();
+      }
+      const b = this.branches.get(cur);
+      cur = b?.parent ?? null;
+    }
+
+    return new Map();
+  }
+}
