+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function modInverse(a: number, mod: number): number {
+  a = ((a % mod) + mod) % mod;
+  if (a === 0) return 0;
+  let result = 1;
+  let base = a;
+  let exp = mod - 2;
+  while (exp > 0) {
+    if (exp % 2 === 1) {
+      result = (result * base) % mod;
+    }
+    base = (base * base) % mod;
+    exp = Math.floor(exp / 2);
+  }
+  return result;
+}
+
+function toggleBetter(candidate: number[], current: number[]): boolean {
+  for (let i = 0; i < candidate.length; i++) {
+    if (candidate[i] > current[i]) return true;
+    if (candidate[i] < current[i]) return false;
+  }
+  return false;
+}
+
+function counterBetter(candidate: number[], current: number[]): boolean {
+  for (let i = 0; i < candidate.length; i++) {
+    if (candidate[i] < current[i]) return true;
+    if (candidate[i] > current[i]) return false;
+  }
+  return false;
+}
+
+type Comparator = (candidate: number[], current: number[]) => boolean;
+
+function solveLinearSystem(
+  nLights: number,
+  nButtons: number,
+  getCoeff: (light: number, button: number) => number,
+  target: number[],
+  mod: number,
+  isBetter: Comparator
+): number[] | null {
+  const matrix: number[][] = [];
+  for (let i = 0; i < nLights; i++) {
+    const row: number[] = [];
+    for (let j = 0; j < nButtons; j++) {
+      row.push(getCoeff(i, j) % mod);
+    }
+    row.push(target[i] % mod);
+    matrix.push(row);
+  }
+
+  const cols = nButtons;
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(cols).fill(-1);
+  let row = 0;
+
+  for (let col = 0; col < cols && row < nLights; col++) {
+    let pivotR = -1;
+    for (let r = row; r < nLights; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotR = r;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];
+
+    const inv = modInverse(matrix[row][col], mod);
+    for (let j = col; j <= cols; j++) {
+      matrix[row][j] = (matrix[row][j] * inv) % mod;
+    }
+
+    for (let r = 0; r < nLights; r++) {
+      if (r === row || matrix[r][col] === 0) continue;
+      const factor = matrix[r][col];
+      for (let j = col; j <= cols; j++) {
+        matrix[r][j] = (((matrix[r][j] - factor * matrix[row][j]) % mod) + mod) % mod;
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow[col] = row;
+    row++;
+  }
+
+  for (let r = row; r < nLights; r++) {
+    if (matrix[r][cols] !== 0) {
+      return null;
+    }
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < cols; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  if (freeVars.length === 0) {
+    const solution: number[] = new Array(nButtons).fill(0);
+    for (let i = 0; i < pivotCol.length; i++) {
+      solution[pivotCol[i]] = matrix[i][cols];
+    }
+    return solution;
+  }
+
+  const nFree = freeVars.length;
+  const totalCombinations = Math.pow(mod, nFree);
+
+  if (totalCombinations <= 10_000_000) {
+    return enumerateFreeVars(matrix, pivotCol, freeVars, nButtons, cols, mod, nFree, totalCombinations, isBetter);
+  }
+
+  if (mod === 2) {
+    return solveWithMITM(matrix, pivotCol, freeVars, nButtons, isBetter);
+  }
+
+  // Fallback for non-binary with huge free space
+  const solution: number[] = new Array(nButtons).fill(0);
+  for (let i = 0; i < pivotCol.length; i++) {
+    solution[pivotCol[i]] = matrix[i][cols];
+  }
+  return solution;
+}
+
+function enumerateFreeVars(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  nButtons: number,
+  cols: number,
+  mod: number,
+  nFree: number,
+  totalCombinations: number,
+  isBetter: Comparator
+): number[] | null {
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  const freeAssignment = new Array(nFree).fill(0);
+
+  for (let iter = 0; iter < totalCombinations; iter++) {
+    const solution: number[] = new Array(nButtons).fill(0);
+    for (let f = 0; f < nFree; f++) {
+      solution[freeVars[f]] = freeAssignment[f];
+    }
+
+    for (let i = 0; i < pivotCol.length; i++) {
+      let val = matrix[i][cols];
+      for (let f = 0; f < nFree; f++) {
+        val = (((val - matrix[i][freeVars[f]] * freeAssignment[f]) % mod) + mod) % mod;
+      }
+      solution[pivotCol[i]] = val % mod;
+    }
+
+    const sum = solution.reduce((a, b) => a + b, 0);
+    if (sum < bestSum || (sum === bestSum && bestSolution !== null && isBetter(solution, bestSolution))) {
+      bestSum = sum;
+      bestSolution = [...solution];
+    }
+
+    let carry = true;
+    for (let f = nFree - 1; f >= 0 && carry; f--) {
+      freeAssignment[f]++;
+      if (freeAssignment[f] >= mod) {
+        freeAssignment[f] = 0;
+      } else {
+        carry = false;
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+function popcount(n: bigint): number {
+  let count = 0;
+  while (n > 0n) {
+    n &= n - 1n;
+    count++;
+  }
+  return count;
+}
+
+function solveWithMITM(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  nButtons: number,
+  isBetter: Comparator
+): number[] | null {
+  const nFree = freeVars.length;
+  const nPivots = pivotCol.length;
+
+  // Build bitmasks for how each free variable affects pivot variables
+  const freeMasks: bigint[] = [];
+  for (let f = 0; f < nFree; f++) {
+    let mask = 0n;
+    for (let i = 0; i < nPivots; i++) {
+      if (matrix[i][freeVars[f]] !== 0) {
+        mask |= 1n << BigInt(i);
+      }
+    }
+    freeMasks.push(mask);
+  }
+
+  let basePivotMask = 0n;
+  for (let i = 0; i < nPivots; i++) {
+    if (matrix[i][nButtons] !== 0) {
+      basePivotMask |= 1n << BigInt(i);
+    }
+  }
+
+  // Split free variables into two halves
+  const halfA = Math.floor(nFree / 2);
+  const halfB = nFree - halfA;
+  const sizeA = 1 << halfA;
+  const sizeB = 1 << halfB;
+
+  // Build second-half entries grouped by pivotXor
+  // For each pivotXor, keep a list of (sumB, bits) sorted by sumB then bits
+  const secondHalfByXor = new Map<bigint, Array<{ sumB: number; bits: number }>>();
+
+  for (let bits = 0; bits < sizeB; bits++) {
+    let pivotXor = 0n;
+    let freeCount = 0;
+    for (let f = 0; f < halfB; f++) {
+      if (bits & (1 << f)) {
+        pivotXor ^= freeMasks[halfA + f];
+        freeCount++;
+      }
+    }
+    let group = secondHalfByXor.get(pivotXor);
+    if (!group) {
+      group = [];
+      secondHalfByXor.set(pivotXor, group);
+    }
+    group.push({ sumB: freeCount, bits });
+  }
+
+  // For each group, keep only the entry with minimum sumB.
+  // For ties, we need to reconstruct and compare, but for the first pass
+  // we can just keep the minimum sumB entry (we'll refine later for ties).
+  // Actually, for finding the globally optimal solution, we need:
+  // For each first-half entry, for each pivotXor group:
+  //   total = sumA + best_sumB + pivotPopcount
+  // We only need the best sumB per group for the initial min-sum search.
+  // For lex tiebreaking, we may need multiple entries per group.
+
+  // Keep best (min sumB) per group, and separately track all entries for tiebreaking
+  const bestPerGroup = new Map<bigint, { sumB: number; bits: number }>();
+  for (const [xor, group] of secondHalfByXor) {
+    let best = group[0];
+    for (let i = 1; i < group.length; i++) {
+      if (group[i].sumB < best.sumB) {
+        best = group[i];
+      }
+    }
+    bestPerGroup.set(xor, best);
+  }
+
+  // Phase 1: Find the minimum possible total sum
+  let globalBestSum = Infinity;
+
+  for (let bitsA = 0; bitsA < sizeA; bitsA++) {
+    let pivotXorA = 0n;
+    let sumA = 0;
+    for (let f = 0; f < halfA; f++) {
+      if (bitsA & (1 << f)) {
+        pivotXorA ^= freeMasks[f];
+        sumA++;
+      }
+    }
+
+    if (sumA >= globalBestSum) continue;
+
+    for (const [pivotXorB, { sumB }] of bestPerGroup) {
+      const pivotSum = popcount(basePivotMask ^ pivotXorA ^ pivotXorB);
+      const totalSum = sumA + sumB + pivotSum;
+      if (totalSum < globalBestSum) {
+        globalBestSum = totalSum;
+      }
+    }
+  }
+
+  if (globalBestSum === Infinity) return null;
+
+  // Phase 2: Collect all solutions achieving the minimum sum, find lex-best
+  // For efficiency, build per-group maps: sumB -> list of bits
+  const groupBySumB = new Map<bigint, Map<number, number[]>>();
+  for (const [xor, group] of secondHalfByXor) {
+    const bySumB = new Map<number, number[]>();
+    for (const { sumB, bits } of group) {
+      let list = bySumB.get(sumB);
+      if (!list) {
+        list = [];
+        bySumB.set(sumB, list);
+      }
+      list.push(bits);
+    }
+    groupBySumB.set(xor, bySumB);
+  }
+
+  let bestSolution: number[] | null = null;
+
+  for (let bitsA = 0; bitsA < sizeA; bitsA++) {
+    let pivotXorA = 0n;
+    let sumA = 0;
+    for (let f = 0; f < halfA; f++) {
+      if (bitsA & (1 << f)) {
+        pivotXorA ^= freeMasks[f];
+        sumA++;
+      }
+    }
+
+    if (sumA > globalBestSum) continue;
+
+    for (const [pivotXorB, bySumB] of groupBySumB) {
+      const pivotSum = popcount(basePivotMask ^ pivotXorA ^ pivotXorB);
+      const neededSumB = globalBestSum - sumA - pivotSum;
+
+      if (neededSumB < 0) continue;
+
+      const candidates = bySumB.get(neededSumB);
+      if (!candidates) continue;
+
+      const freeXor = pivotXorA ^ pivotXorB;
+
+      for (const bitsB of candidates) {
+        const candidate = buildSolution(
+          bitsA, bitsB, freeXor,
+          pivotCol, freeVars, halfA, nButtons, basePivotMask
+        );
+        if (bestSolution === null || isBetter(candidate, bestSolution)) {
+          bestSolution = candidate;
+        }
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+function buildSolution(
+  bitsA: number,
+  bitsB: number,
+  freeXor: bigint,
+  pivotCol: number[],
+  freeVars: number[],
+  halfA: number,
+  nButtons: number,
+  basePivotMask: bigint
+): number[] {
+  const solution: number[] = new Array(nButtons).fill(0);
+  const nFree = freeVars.length;
+  const halfB = nFree - halfA;
+
+  for (let f = 0; f < halfA; f++) {
+    if (bitsA & (1 << f)) {
+      solution[freeVars[f]] = 1;
+    }
+  }
+  for (let f = 0; f < halfB; f++) {
+    if (bitsB & (1 << f)) {
+      solution[freeVars[halfA + f]] = 1;
+    }
+  }
+
+  const nPivots = pivotCol.length;
+  const resultPivot = basePivotMask ^ freeXor;
+  for (let i = 0; i < nPivots; i++) {
+    solution[pivotCol[i]] = Number((resultPivot >> BigInt(i)) & 1n);
+  }
+
+  return solution;
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const nLights = target.length;
+  const nButtons = buttons.length;
+
+  const targetNums = target.map(t => t ? 1 : 0);
+
+  const buttonSets: Set<number>[] = buttons.map(b => new Set(b));
+  const getCoeff = (light: number, button: number): number => {
+    return buttonSets[button].has(light) ? 1 : 0;
+  };
+
+  const result = solveLinearSystem(nLights, nButtons, getCoeff, targetNums, 2, toggleBetter);
+
+  if (result === null) return null;
+
+  const pressed: number[] = [];
+  for (let i = 0; i < nButtons; i++) {
+    if (result[i] !== 0) {
+      pressed.push(i);
+    }
+  }
+
+  return pressed;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const nLights = lights.length;
+  const nButtons = buttons.length;
+
+  const target = lights.map(v => ((v % modulus) + modulus) % modulus);
+
+  const buttonSets: Set<number>[] = buttons.map(b => new Set(b));
+  const getCoeff = (light: number, button: number): number => {
+    return buttonSets[button].has(light) ? 1 : 0;
+  };
+
+  return solveLinearSystem(nLights, nButtons, getCoeff, target, modulus, counterBetter);
+}
