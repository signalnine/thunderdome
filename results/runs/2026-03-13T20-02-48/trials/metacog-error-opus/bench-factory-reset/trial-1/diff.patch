;\n}\n\n/**\n * Compute modular multiplicative inverse using extended Euclidean algorithm.\n * Only valid when mod is prime.\n */\nfunction modInverse(a: number, mod: number): number {\n  a = ((a % mod) + mod) % mod;\n  if (a === 0) return 0;\n  // Fermat's little theorem: a^(p-1) ≡ 1 (mod p) => a^(-1) ≡ a^(p-2)\n  let result = 1;\n  let base = a;\n  let exp = mod - 2;\n  while (exp > 0) {\n    if (exp % 2 === 1) {\n      result = (result * base) % mod;\n    }\n    base = (base * base) % mod;\n    exp = Math.floor(exp / 2);\n  }\n  return result;\n}\n\n/**\n * Solve a system of linear equations over GF(mod) using Gaussian elimination.\n *\n * Given matrix A (nLights x nButtons) and target vector b (nLights),\n * find x (nButtons) such that A * x ≡ b (mod mod).\n *\n * Returns the optimal solution (minimum sum, then lexicographically smallest)\n * or null if no solution exists.\n */\nfunction solveLinearSystem(\n  nLights: number,\n  nButtons: number,\n  // buildRow: for light i, returns coefficient of button j\n  getCoeff: (light: number, button: number) => number,\n  target: number[],\n  mod: number\n): number[] | null {\n  // Build augmented matrix [A | b] over GF(mod)\n  // Each row: nButtons coefficients + 1 target value\n  const matrix: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row: number[] = [];\n    for (let j = 0; j < nButtons; j++) {\n      row.push(getCoeff(i, j) % mod);\n    }\n    row.push(target[i] % mod);\n    matrix.push(row);\n  }\n\n  const cols = nButtons;\n  const pivotCol: number[] = []; // pivotCol[pivotRow] = column index of pivot\n  const pivotRow: number[] = new Array(cols).fill(-1); // pivotRow[col] = row index, -1 if free\n  let row = 0;\n\n  // Forward elimination\n  for (let col = 0; col < cols && row < nLights; col++) {\n    // Find pivot\n    let pivotR = -1;\n    for (let r = row; r < nLights; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue; // Free variable\n\n    // Swap rows\n    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(matrix[row][col], mod);\n    for (let j = col; j <= cols; j++) {\n      matrix[row][j] = (matrix[row][j] * inv) % mod;\n    }\n\n    // Eliminate column in all other rows\n    for (let r = 0; r < nLights; r++) {\n      if (r === row || matrix[r][col] === 0) continue;\n      const factor = matrix[r][col];\n      for (let j = col; j <= cols; j++) {\n        matrix[r][j] = (((matrix[r][j] - factor * matrix[row][j]) % mod) + mod) % mod;\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = row;\n    row++;\n  }\n\n  // Check consistency: any row with all-zero coefficients but nonzero target\n  for (let r = row; r < nLights; r++) {\n    if (matrix[r][cols] !== 0) {\n      return null; // No solution\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < cols; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // If no free variables, unique solution\n  if (freeVars.length === 0) {\n    const solution: number[] = new Array(nButtons).fill(0);\n    for (let i = 0; i < pivotCol.length; i++) {\n      solution[pivotCol[i]] = matrix[i][cols];\n    }\n    return solution;\n  }\n\n  // With free variables, we need to find the assignment that minimizes total presses,\n  // then lexicographically smallest.\n  // For GF(2), free vars are 0 or 1 -> enumerate 2^freeVars possibilities.\n  // For GF(p), free vars have p choices each -> could be p^freeVars.\n  // With up to 40 variables, we need to be smart.\n\n  // For mod=2: up to 2^40 is too many, but in practice the number of free variables\n  // after GE on a 40x40 system should be manageable. If it's large we need heuristics.\n  // But realistically, for well-formed puzzles, free vars should be modest.\n\n  // Strategy: enumerate all assignments of free variables.\n  // For each, compute the determined variables and evaluate the solution.\n  const nFree = freeVars.length;\n  const totalCombinations = Math.pow(mod, nFree);\n\n  // If the enumeration space is too large, use a smarter approach.\n  // For mod=2 and nFree <= 25ish, brute force is fine (2^25 = ~33M).\n  // For larger, we'd need meet-in-the-middle or other approaches.\n  // Given the constraint of 40 buttons, 40 lights, the rank can be at most 40,\n  // so nFree can be at most 40 - but with the full 40x40 system the rank\n  // is typically high. Let's handle the general case with MITM for mod=2 when needed.\n\n  if (totalCombinations <= 10_000_000) {\n    // Direct enumeration\n    let bestSolution: number[] | null = null;\n    let bestSum = Infinity;\n\n    const freeAssignment = new Array(nFree).fill(0);\n\n    for (let iter = 0; iter < totalCombinations; iter++) {\n      // Compute solution from free variable assignment\n      const solution: number[] = new Array(nButtons).fill(0);\n      for (let f = 0; f < nFree; f++) {\n        solution[freeVars[f]] = freeAssignment[f];\n      }\n\n      // Compute pivot variables: x_pivot = b' - sum(a'_j * x_j for free j)\n      for (let i = 0; i < pivotCol.length; i++) {\n        let val = matrix[i][cols];\n        for (let f = 0; f < nFree; f++) {\n          val = (((val - matrix[i][freeVars[f]] * freeAssignment[f]) % mod) + mod) % mod;\n        }\n        solution[pivotCol[i]] = val % mod;\n      }\n\n      const sum = solution.reduce((a, b) => a + b, 0);\n      if (sum < bestSum || (sum === bestSum && lexLess(solution, bestSolution!))) {\n        bestSum = sum;\n        bestSolution = [...solution];\n      }\n\n      // Increment free assignment (odometer style)\n      let carry = true;\n      for (let f = nFree - 1; f >= 0 && carry; f--) {\n        freeAssignment[f]++;\n        if (freeAssignment[f] >= mod) {\n          freeAssignment[f] = 0;\n        } else {\n          carry = false;\n        }\n      }\n    }\n\n    return bestSolution;\n  }\n\n  // For large enumeration spaces, use meet-in-the-middle (primarily for mod=2).\n  return solveWithMITM(matrix, pivotCol, pivotRow, freeVars, nButtons, mod);\n}\n\nfunction lexLess(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * Meet-in-the-middle approach for large free variable spaces.\n * Split free variables into two halves, enumerate each half,\n * and combine to find optimal solution.\n */\nfunction solveWithMITM(\n  matrix: number[][],\n  pivotCol: number[],\n  pivotRow: number[],\n  freeVars: number[],\n  nButtons: number,\n  mod: number\n): number[] | null {\n  const nFree = freeVars.length;\n  const halfA = Math.floor(nFree / 2);\n  const halfB = nFree - halfA;\n\n  // For each half, compute: for each assignment of free vars in that half,\n  // what's the partial contribution to each pivot variable.\n  // We also track the free variable values themselves and their partial sum.\n\n  // For the first half (freeVars[0..halfA-1]):\n  // partial_pivot[i] = sum of matrix[pivotRow][freeVars[f]] * assignment[f] for f in first half\n  // For the second half, similarly.\n  // Full pivot value: matrix[row][cols] - partial_A - partial_B\n\n  // The sum of the solution = sum(freeAssignment values) + sum(pivot variable values)\n  // pivot variable values depend on both halves.\n\n  // This is complex for general mod. For mod=2, it's XOR-based.\n  // Let's implement for mod=2.\n\n  if (mod !== 2) {\n    // Fallback: if we somehow get here with mod != 2 and huge space,\n    // try a greedy approach: set free variables to 0.\n    // This won't be optimal but handles edge cases.\n    const solution: number[] = new Array(nButtons).fill(0);\n    for (let i = 0; i < pivotCol.length; i++) {\n      solution[pivotCol[i]] = matrix[i][nButtons]; // The augmented column\n    }\n    return solution;\n  }\n\n  // For mod=2, represent contributions as bit vectors.\n  // For each pivot variable i, the contribution from free var f is matrix[i][freeVars[f]] (0 or 1).\n  // When we XOR in free var f, it flips certain pivot variables.\n\n  // Key: we need to minimize total presses = popcount(free bits set) + sum(pivot values).\n  // Pivot values: for pivot i, value = matrix[i][cols] XOR (XOR of free contributions).\n\n  // Encode: for each free var f, create a bitmask of which pivots it affects.\n  const nPivots = pivotCol.length;\n  // Use BigInt for bitmask if nPivots > 30.\n  // Actually, nPivots + nFree can be at most 40, so nPivots can be up to 40.\n  // Let's use BigInt.\n\n  const freeMasksA: bigint[] = []; // For first half free vars: which pivots they flip\n  const freeMasksB: bigint[] = [];\n\n  for (let f = 0; f < halfA; f++) {\n    let mask = 0n;\n    for (let i = 0; i < nPivots; i++) {\n      if (matrix[i][freeVars[f]] !== 0) {\n        mask |= 1n << BigInt(i);\n      }\n    }\n    freeMasksA.push(mask);\n  }\n  for (let f = halfA; f < nFree; f++) {\n    let mask = 0n;\n    for (let i = 0; i < nPivots; i++) {\n      if (matrix[i][freeVars[f]] !== 0) {\n        mask |= 1n << BigInt(i);\n      }\n    }\n    freeMasksB.push(mask);\n  }\n\n  // Base pivot values (with all free = 0)\n  let basePivotMask = 0n;\n  for (let i = 0; i < nPivots; i++) {\n    if (matrix[i][nButtons] !== 0) {\n      basePivotMask |= 1n << BigInt(i);\n    }\n  }\n\n  // Popcount for BigInt\n  function popcount(n: bigint): number {\n    let count = 0;\n    while (n > 0n) {\n      n &= n - 1n;\n      count++;\n    }\n    return count;\n  }\n\n  // Enumerate first half: for each assignment, compute (xored pivot mask, number of free vars set, assignment bits)\n  const sizeA = 1 << halfA;\n  const sizeB = 1 << halfB;\n\n  // For the second half, we build a map: pivotXor -> best (freeCount, freeBits)\n  // Then for each first-half entry, we look up the needed pivotXor to cancel.\n\n  // After combining: total free pressed = freeCountA + freeCountB\n  // Pivot values after XOR: basePivotMask XOR pivotXorA XOR pivotXorB\n  // We want basePivotMask XOR pivotXorA XOR pivotXorB to have minimum popcount,\n  // plus freeCountA + freeCountB.\n  // Actually, the pivot values are determined: for pivot i, value = (basePivotMask >> i & 1) XOR contributions.\n  // We want each pivot value to be 0 or 1 (it will be, in GF(2)).\n  // The total sum = freeCountA + freeCountB + popcount(basePivotMask XOR pivotXorA XOR pivotXorB).\n  // We want to minimize this.\n\n  // This is still a search over all combinations. Let's use MITM properly:\n  // For each first-half assignment: compute pivotXorA, sumA = freeCountA\n  // For each second-half assignment: compute pivotXorB, sumB = freeCountB\n  // Target: minimize sumA + sumB + popcount(basePivotMask XOR pivotXorA XOR pivotXorB)\n  //\n  // Group second-half by pivotXorB. For each first-half entry:\n  //   needed = we want to minimize over all pivotXorB of:\n  //     sumB + popcount(basePivotMask XOR pivotXorA XOR pivotXorB)\n  //   This is still iterating over all second-half entries for each first-half entry.\n  //\n  // Alternative: enumerate all, tracking the global best.\n  // With halfA ~ 20, we have 2^20 ~ 1M entries per half, and combination would be 2^40.\n  // But we can store second half in a map keyed by pivotXorB, keeping only the best entry per key.\n  // Then iterate first half and for each, check if there's a matching second half that gives good result.\n  // Problem: the popcount(basePivotMask XOR pivotXorA XOR pivotXorB) means the optimal pivotXorB\n  // depends on pivotXorA.\n  //\n  // True MITM: for each first-half entry, we want pivotXorB such that\n  // basePivotMask XOR pivotXorA XOR pivotXorB has minimum popcount - but also sumB is minimized.\n  // These are competing objectives.\n  //\n  // Pragmatic approach: since nFree <= 40 and each half <= 20,\n  // enumerate both halves (~1M each) and then for each first-half entry,\n  // we need to search the second-half entries. This is 2^40 in the worst case.\n  //\n  // Better: observe that for the pivot sum, let targetPivot = basePivotMask XOR pivotXorA.\n  // We want pivotXorB close to targetPivot (in XOR distance = small popcount of difference).\n  // pivotPopcount = popcount(targetPivot XOR pivotXorB).\n  // total = sumA + sumB + popcount(targetPivot XOR pivotXorB).\n  //\n  // If we precompute for the second half: for each possible pivotXorB, store min sumB,\n  // then for each first-half, iterate all second-half keys. But that's still potentially large.\n  //\n  // Given constraints (up to 40 buttons, 40 lights), nPivots can be up to 40 and nFree up to 40.\n  // In practice with 40 lights and 40 buttons, if all buttons are independent, nFree=0.\n  // nFree is large only when many buttons are redundant. In a well-designed puzzle this shouldn't\n  // exceed ~20-25, making direct enumeration feasible.\n  //\n  // Let's just enumerate both halves and combine carefully.\n\n  // Build second-half entries, grouped by pivotXorB\n  const secondHalf = new Map<bigint, { sumB: number; bits: number }>();\n\n  for (let bits = 0; bits < sizeB; bits++) {\n    let pivotXor = 0n;\n    let freeCount = 0;\n    for (let f = 0; f < halfB; f++) {\n      if (bits & (1 << f)) {\n        pivotXor ^= freeMasksB[f];\n        freeCount++;\n      }\n    }\n    const existing = secondHalf.get(pivotXor);\n    if (!existing || freeCount < existing.sumB ||\n        (freeCount === existing.sumB && bits < existing.bits)) {\n      secondHalf.set(pivotXor, { sumB: freeCount, bits });\n    }\n  }\n\n  // For each first-half entry, find optimal combination\n  let bestSum = Infinity;\n  let bestSolution: number[] | null = null;\n\n  for (let bitsA = 0; bitsA < sizeA; bitsA++) {\n    let pivotXorA = 0n;\n    let sumA = 0;\n    for (let f = 0; f < halfA; f++) {\n      if (bitsA & (1 << f)) {\n        pivotXorA ^= freeMasksA[f];\n        sumA++;\n      }\n    }\n\n    // For each second-half entry\n    for (const [pivotXorB, { sumB, bits: bitsB }] of secondHalf) {\n      const resultPivot = basePivotMask ^ pivotXorA ^ pivotXorB;\n      const pivotSum = popcount(resultPivot);\n      const totalSum = sumA + sumB + pivotSum;\n\n      if (totalSum < bestSum) {\n        bestSum = totalSum;\n        // Reconstruct solution\n        bestSolution = reconstructSolution(\n          bitsA, bitsB, pivotXorA ^ pivotXorB,\n          matrix, pivotCol, freeVars, halfA, nButtons, basePivotMask, mod\n        );\n      } else if (totalSum === bestSum) {\n        const candidate = reconstructSolution(\n          bitsA, bitsB, pivotXorA ^ pivotXorB,\n          matrix, pivotCol, freeVars, halfA, nButtons, basePivotMask, mod\n        );\n        if (lexLess(candidate, bestSolution!)) {\n          bestSolution = candidate;\n        }\n      }\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction reconstructSolution(\n  bitsA: number,\n  bitsB: number,\n  freeXor: bigint,\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  halfA: number,\n  nButtons: number,\n  basePivotMask: bigint,\n  _mod: number\n): number[] {\n  const solution: number[] = new Array(nButtons).fill(0);\n  const nFree = freeVars.length;\n  const halfB = nFree - halfA;\n\n  // Set free variables\n  for (let f = 0; f < halfA; f++) {\n    if (bitsA & (1 << f)) {\n      solution[freeVars[f]] = 1;\n    }\n  }\n  for (let f = 0; f < halfB; f++) {\n    if (bitsB & (1 << f)) {\n      solution[freeVars[halfA + f]] = 1;\n    }\n  }\n\n  // Compute pivot variables\n  const nPivots = pivotCol.length;\n  const resultPivot = basePivotMask ^ freeXor;\n  for (let i = 0; i < nPivots; i++) {\n    solution[pivotCol[i]] = Number((resultPivot >> BigInt(i)) & 1n);\n  }\n\n  return solution;\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  // Convert target to numbers (0 or 1)\n  const targetNums = target.map(t => t ? 1 : 0);\n\n  // Build coefficient accessor: light i has coefficient 1 for button j if j toggles light i\n  // Build a set for each button for O(1) lookup\n  const buttonSets: Set<number>[] = buttons.map(b => new Set(b));\n\n  const getCoeff = (light: number, button: number): number => {\n    return buttonSets[button].has(light) ? 1 : 0;\n  };\n\n  const result = solveLinearSystem(nLights, nButtons, getCoeff, targetNums, 2);\n\n  if (result === null) return null;\n\n  // Convert to list of pressed button indices\n  const pressed: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (result[i] !== 0) {\n      pressed.push(i);\n    }\n  }\n\n  return pressed;\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const nLights = lights.length;\n  const nButtons = buttons.length;\n\n  const target = lights.map(v => ((v % modulus) + modulus) % modulus);\n\n  const buttonSets: Set<number>[] = buttons.map(b => new Set(b));\n\n  const getCoeff = (light: number, button: number): number => {\n    return buttonSets[button].has(light) ? 1 : 0;\n  };\n\n  return solveLinearSystem(nLights, nButtons, getCoeff, target, modulus);\n}\n"}}
