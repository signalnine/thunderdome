;\n  if (r !== \"CORRECT\" && !r.startsWith(\"null\")) {\n    console.log(\"FAIL:\", r);\n  }\n}\nconsole.log(\"All random toggle tests passed or returned null (no solution)\");\n\n// Random counter tests\nfunction randomCounterTest(nLights, nButtons, modulus) {\n  const buttons = [];\n  for (let i = 0; i < nButtons; i++) {\n    const btn = [];\n    for (let j = 0; j < nLights; j++) {\n      if (Math.random() < 0.3) btn.push(j);\n    }\n    buttons.push(btn);\n  }\n  const lights = Array.from({length: nLights}, () => Math.floor(Math.random() * modulus));\n  const result = solveCounter(lights, buttons, modulus);\n  const check = verifyCounter(lights, buttons, modulus, result);\n  return check;\n}\n\nconsole.log(\"=== Random counter tests ===\");\nfor (let i = 0; i < 20; i++) {\n  const r = randomCounterTest(8, 8, 5);\n  if (r !== \"CORRECT\" && !r.startsWith(\"null\")) {\n    console.log(\"FAIL:\", r);\n  }\n}\nconsole.log(\"All random counter tests passed or returned null\");\n\n// Performance test: 40x40 toggle\nconst n = 40;\nconst target40 = Array.from({length: n}, () => true);\nconst buttons40 = Array.from({length: n}, (_, i) => [i]);\nconst start = Date.now();\nconst r40 = solveToggle({ target: target40, buttons: buttons40 });\nconsole.log(\"40x40 toggle:\", Date.now() - start, \"ms, buttons pressed:\", r40?.length);\n\n// Performance test: 40x40 counter mod 97\nconst target40c = Array.from({length: 40}, (_, i) => (i * 13 + 7) % 97);\nconst buttons40c = Array.from({length: 40}, (_, i) => [i]);\nconst start2 = Date.now();\nconst r40c = solveCounter(target40c, buttons40c, 97);\nconst check40 = verifyCounter(target40c, buttons40c, 97, r40c);\nconsole.log(\"40x40 counter mod 97:\", Date.now() - start2, \"ms,\", check40);\n\n// Performance test: Dense 40x40\nconst targetDense = Array.from({length: 20}, () => true).concat(Array.from({length: 20}, () => false));\nconst buttonsDense = Array.from({length: 40}, (_, i) => {\n  const btn = [];\n  for (let j = 0; j < 40; j+