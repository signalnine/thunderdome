rue], buttons:[]}), null);\n\n// Toggle lex: {0} < {1} when both possible with same count\nassert(\"toggle: lex min\", solveToggle({target:[true,false,false], buttons:[[0],[0],[0,1,2]]}), [0]);\nassert(\"toggle: lex 3 redundant\", solveToggle({target:[true], buttons:[[0],[0],[0]]}), [0]);\n\n// Toggle: impossible\nassert(\"toggle: impossible pair\", solveToggle({target:[true,false], buttons:[[0,1]]}), null);\n\n// Counter tests\nassert(\"counter: empty\", solveCounter([], [], 2), []);\nassert(\"counter: [1,2] mod 3\", solveCounter([1,2], [[0],[1]], 3), [1,2]);\nassert(\"counter: [0] mod 3\", solveCounter([0], [[0]], 3), [0]);\nassert(\"counter: [2,1] mod 3\", solveCounter([2,1], [[0,1],[0]], 3), [1,1]);\nassert(\"counter: zero target\", solveCounter([0,0], [], 3), []);\nassert(\"counter: impossible\", solveCounter([1], [], 3), null);\nassert(\"counter: mod 5\", solveCounter([4], [[0]], 5), [4]);\nassert(\"counter: lex smallest\", solveCounter([1], [[0],[0]], 3), [0,1]);\n\n// Verify correctness of random tests\nfor (let t = 0; t < 100; t++) {\n  const nB = 15, nL = 10;\n  const btns = [];\n  for (let i = 0; i < nB; i++) {\n    const b = [];\n    for (let j = 0; j < nL; j++) if (Math.random() < 0.3) b.push(j);\n    btns.push(b);\n  }\n  const target = Array.from({length: nL}, () => Math.random() < 0.5);\n  const machine = {target, buttons: btns};\n  const r = solveToggle(machine);\n  if (!verifyToggle(machine, r)) {\n    fail++;\n    console.log(\"FAIL: random toggle test\", t);\n  } else { pass++; }\n}\n\nfor (let t = 0; t < 50; t++) {\n  const nB = 10, nL = 8;\n  const mod = [2,3,5,7,11][t % 5];\n  const btns = [];\n  for (let i = 0; i < nB; i++) {\n    const b = [];\n    for (let j = 0; j < nL; j++) if (Math.random() < 0.3) b.push(j);\n    btns.push(b);\n  }\n  const lights = Array.from({length: nL}, () => Math.floor(Math.random() * mod));\n  const r = solveCounter(lights, btns, mod);\n  if (!verifyCounter(lights, btns, mod, r)) {\n    fail++;\n    console.log(\"F