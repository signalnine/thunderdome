  row.push(target[i] % mod);\n    53→    matrix.push(row);\n    54→  }\n    55→\n    56→  const cols = nButtons;\n    57→  const pivotCol: number[] = []; // pivotCol[pivotRow] = column index of pivot\n    58→  const pivotRow: number[] = new Array(cols).fill(-1); // pivotRow[col] = row index, -1 if free\n    59→  let row = 0;\n    60→\n    61→  // Forward elimination\n    62→  for (let col = 0; col < cols && row < nLights; col++) {\n    63→    // Find pivot\n    64→    let pivotR = -1;\n    65→    for (let r = row; r < nLights; r++) {\n    66→      if (matrix[r][col] !== 0) {\n    67→        pivotR = r;\n    68→        break;\n    69→      }\n    70→    }\n    71→    if (pivotR === -1) continue; // Free variable\n    72→\n    73→    // Swap rows\n    74→    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n    75→\n    76→    // Scale pivot row so pivot element = 1\n    77→    const inv = modInverse(matrix[row][col], mod);\n    78→    for (let j = col; j <= cols; j++) {\n    79→      matrix[row][j] = (matrix[row][j] * inv) % mod;\n    80→    }\n    81→\n    82→    // Eliminate column in all other rows\n    83→    for (let r = 0; r < nLights; r++) {\n    84→      if (r === row || matrix[r][col] === 0) continue;\n    85→      const factor = matrix[r][col];\n    86→      for (let j = col; j <= cols; j++) {\n    87→        matrix[r][j] = (((matrix[r][j] - factor * matrix[row][j]) % mod) + mod) % mod;\n    88→      }\n    89→    }\n    90→\n    91→    pivotCol.push(col);\n    92→    pivotRow[col] = row;\n    93→    row++;\n    94→  }\n    95→\n    96→  // Check consistency: any row with all-zero coefficients but nonzero target\n    97→  for (let r = row; r < nLights; r++) {\n    98→    if (matrix[r][cols] !== 0) {\n    99→      return null; // No solution\n   100→    }\n   101→  }\n   102→\n   103→  // Identify free variables\n   104→  const freeVars: number[] = [];\n   105→  for (let col = 0; col < cols; col++) {\n   106→    if (pivotRow[col] === -1) {\n   107→      freeVars.push(col);\n   108→    }\n   109→  }\n   110→\n   111→  // If no free variables, unique solution\n   112→  if (freeVars.length === 0) {\n   113→    const solution: number[] = new Array(nButtons).fill(0);\n   114→    for (let i = 0; i < pivotCol.length; i++) {\n   115→      solution[pivotCol[i]] = matrix[i][cols];\n   116→    }\n   117→    return solution;\n   118→  }\n   119→\n   120→  // With free variables, we need to find the assignment that minimizes total presses,\n   121→  // then lexicographically smallest.\n   122→  // For GF(2), free vars are 0 or 1 -> enumerate 2^freeVars possibilities.\n   123→  // For GF(p), free vars have p choices each -> could be p^freeVars.\n   124→  // With up to 40 variables, we need to be smart.\n   125→\n   126→  // For mod=2: up to 2^40 is too many, but in practice the number of free variables\n   127→  // after GE on a 40x40 system should be manageable. If it's large we need heuristics.\n   128→  // But realistically, for well-formed puzzles, free vars should be modest.\n   129→\n   130→  // Strategy: enumerate all assignments of free variables.\n   131→  // For each, compute the determined variables and evaluate the solution.\n   132→  const nFree = freeVars.length;\n   133→  const totalCombinations = Math.pow(mod, nFree);\n   134→\n   135→  // If the enumeration space is too large, use a smarter approach.\n   136→  // For mod=2 and nFree <= 25ish, brute force is fine (2^25 = ~33M).\n   137→  // For larger, we'd need meet-in-the-middle or other approaches.\n   138→  // Given the constraint of 40 buttons, 40 lights, the rank can be at most 40,\n   139→  // so nFree can be at most 40 - but with the full 40x40 system the rank\n   140→  // is typically high. Let's handle the general case with MITM for mod=2 when needed.\n   141→\n   142→  if (totalCombinations <= 10_000_000) {\n   143→    // Direct enumeration\n   144→    let bestSolution: number[] | null = null;\n   145→    let bestSum = Infinity;\n   146→\n   