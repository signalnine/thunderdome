(matrix[i][nButtons] !== 0) {\n      basePivotMask |= 1n << BigInt(i);\n    }\n  }\n\n  // Popcount for BigInt\n  function popcount(n: bigint): number {\n    let count = 0;\n    while (n > 0n) {\n      n &= n - 1n;\n      count++;\n    }\n    return count;\n  }\n\n  // Enumerate first half: for each assignment, compute (xored pivot mask, number of free vars set, assignment bits)\n  type HalfEntry = { pivotXor: bigint; freeCount: number; freeBits: number; };\n  const sizeA = 1 << halfA;\n  const sizeB = 1 << halfB;\n\n  // For the second half, we build a map: pivotXor -> best (freeCount, freeBits)\n  // Then for each first-half entry, we look up the needed pivotXor to cancel.\n\n  // After combining: total free pressed = freeCountA + freeCountB\n  // Pivot values after XOR: basePivotMask XOR pivotXorA XOR pivotXorB\n  // We want basePivotMask XOR pivotXorA XOR pivotXorB to have minimum popcount,\n  // plus freeCountA + freeCountB.\n  // Actually, the pivot values are determined: for pivot i, value = (basePivotMask >> i & 1) XOR contributions.\n  // We want each pivot value to be 0 or 1 (it will be, in GF(2)).\n  // The total sum = freeCountA + freeCountB + popcount(basePivotMask XOR pivotXorA XOR pivotXorB).\n  // We want to minimize this.\n\n  // This is still a search over all combinations. Let's use MITM properly:\n  // For each first-half assignment: compute pivotXorA, sumA = freeCountA\n  // For each second-half assignment: compute pivotXorB, sumB = freeCountB\n  // Target: minimize sumA + sumB + popcount(basePivotMask XOR pivotXorA XOR pivotXorB)\n  //\n  // Group second-half by pivotXorB. For each first-half entry:\n  //   needed = we want to minimize over all pivotXorB of:\n  //     sumB + popcount(basePivotMask XOR pivotXorA XOR pivotXorB)\n  //   This is still iterating over all second-half entries for each first-half entry.\n  //\n  // Alternative: enumerate all, tracking the global best.\n  // With halfA ~ 20, we have 2^20 ~ 1M entries per half, and combi