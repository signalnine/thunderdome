.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n    const r3 = reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'spam' });\n\n    expect(reviews.getAverageRating('a')).toBe(3); // (5+3+1)/3\n\n    reviews.flagReview(r3.id);\n    expect(reviews.getAverageRating('a')).toBe(4); // (5+3)/2\n  });\n\n  it('should return 0 for average when no reviews', () => {\n    expect(reviews.getAverageRating('nonexistent')).toBe(0);\n  });\n\n  it('should flag a review', () => {\n    const review = reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam' });\n    reviews.flagReview(review.id);\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged).toHaveLength(1);\n    expect(flagged[0].id).toBe(review.id);\n  });\n\n  it('should throw when flagging non-existent review', () => {\n    expect(() => reviews.flagReview(999)).toThrow();\n  });\n\n  it('should remove a review', () => {\n    const r = reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    expect(reviews.removeReview(r.id)).toBe(true);\n    expect(reviews.getReviews('a')).toHaveLength(0);\n  });\n\n  it('should return false when removing non-existent review', () => {\n    expect(reviews.removeReview(999)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: '' });\n    reviews.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: '' });\n    reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: '' });\n\n    expect(reviews.getReviewsByUser('user1')).toHaveLength(2);\n    expect(reviews.getReviewsByUser('user2')).toHaveLength(1);\n  });\n\n  it('should get review count', () => {\n    reviews.addReview({ pluginName: 'a', pluginVers