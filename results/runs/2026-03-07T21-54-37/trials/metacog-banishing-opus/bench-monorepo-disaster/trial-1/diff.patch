+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XgaK4Zx1qsWnKhVijLdNkj","type":"tool_result","content":"     1→/**\n     2→ * Shared types for the monorepo.\n     3→ */\n     4→\n     5→import { getUserById } from './user.js';\n     6→\n     7→export type Role = 'admin' | 'user' | 'viewer';\n     8→\n     9→export type Permission =\n    10→  | 'read'\n    11→  | 'write'\n    12→  | 'delete'\n    13→  | 'manage_users'\n    14→  | 'view_reports';\n    15→\n    16→export interface User {\n    17→  id: number;\n    18→  name: string;\n    19→  email: string;\n    20→  role: Role;\n    21→  createdAt: string;\n    22→  updatedAt: string;\n    23→}\n    24→\n    25→export interface CreateUserInput {\n    26→  name: string;\n    27→  email: string;\n    28→  role: Role;\n    29→}\n    30→\n    31→export interface UserFilters {\n    32→  role?: Role;\n    33→  search?: string;\n    34→  limit?: number;\n    35→  offset?: number;\n    36→}\n    37→\n    38→/** Utility to check if a user exists by ID */\n    39→export function userExists(id: number): boolean {\n    40→  return getUserById(id) !== null;\n    41→}\n    42→"}]},"parent_tool_use_id":"toolu_017XkQtHKF1h5bgh6pB2MHZc","session_id":"585e24ca-c84c-448c-ad45-7bbc97b45dd0","uuid":"515854d0-5775-4faa-bdc5-99ca3fbcd5cd"}
