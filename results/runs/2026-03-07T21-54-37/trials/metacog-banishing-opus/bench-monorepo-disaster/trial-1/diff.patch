eCreation =\n      (now.getTime() - createdDate.getTime()) / (1000 * 60 * 60 * 24);\n\n    // Mark records older than 365 days as stale (simulation)\n    if (daysSinceCreation > 365) {\n      staleRecords++;\n      // In a real app, we'd archive or delete\n      cleanedUp++;\n    }\n  }\n\n  const duration = Date.now() - startTime;\n\n  console.log(\n    `Cleanup complete: ${staleRecords} stale, ${cleanedUp} cleaned in ${duration}ms`\n  );\n\n  return { staleRecords, cleanedUp, duration };\n}\n\nexport function getCleanupThresholdDays(): number {\n  return 365;\n}\n```\n\n---\n\n### 10. PACKAGES/WORKER TEST FILES\n\n#### `/workspace/packages/worker/tests/scheduler.test.ts`\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { Scheduler } from '../src/scheduler.js';\n\ndescribe('Scheduler', () => {\n  let scheduler: Scheduler;\n\n  beforeEach(() => {\n    scheduler = new Scheduler();\n  });\n\n  it('registers a job', () => {\n    scheduler.register('test', () => {}, 1000);\n    const status = scheduler.getStatus();\n    expect(status).toHaveLength(1);\n    expect(status[0].name).toBe('test');\n  });\n\n  it('runs a job once', async () => {\n    let ran = false;\n    scheduler.register('test', () => { ran = true; }, 1000);\n    await scheduler.runOnce('test');\n    expect(ran).toBe(true);\n  });\n\n  it('tracks run count', async () => {\n    scheduler.register('test', () => {}, 1000);\n    await scheduler.runOnce('test');\n    await scheduler.runOnce('test');\n    const status = scheduler.getStatus();\n    expect(status[0].runCount).toBe(2);\n  });\n\n  it('throws for unknown job', async () => {\n    await expect(scheduler.runOnce('nonexistent')).rejects.toThrow(\n      \"Job 'nonexistent' not found\"\n    );\n  });\n\n  it('starts and stops', () => {\n    scheduler.register('test', () => {}, 60000);\n    scheduler.start();\n    expect(scheduler.isRunning()).toBe(true);\n    scheduler.stop();\n    expect(scheduler.isRunning()).toBe(false