+export interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: 'static' | 'asset' | 'api' }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin() {
+  const defaultPort = 3000;
+
+  function buildDevServerConfig(output, data) {
+    const config: DevServerConfig = {
+      port: defaultPort,
+      routes: [],
+      assetPaths: [],
+      searchIndexPath: '/search-index.json',
+    };
+
+    const outputPaths = new Set(output.keys());
+    
+    outputPaths.forEach((path) => {
+      if (path.endsWith('.html') || path.endsWith('/')) {
+        config.routes.push({
+          path: '/' + path,
+          handler: 'static',
+        });
+      }
+    });
+
+    const assetManifest = data.get('asset-manifest') as Map<string, string[]>;
+    if (assetManifest) {
+      assetManifest.forEach((assets, assetPath) => {
+        assets.forEach((asset) => {
+          config.routes.push({
+            path: '/' + assetPath + '/' + asset,
+            handler: 'asset',
+          });
+          config.assetPaths.push(asset);
+        });
+      });
+    }
+
+    const searchIndex = output.get('search-index.json');
+    if (searchIndex) {
+      config.searchIndexPath = '/search-index.json';
+    }
+
+    return config;
+  }
+
+  const plugin = {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: async (ctx) => {
+        const devServerConfig = buildDevServerConfig(ctx.output, ctx.data);
+        ctx.data.set('dev-server-config', devServerConfig);
+      },
+    },
+  };
+
+  return plugin;
+}
