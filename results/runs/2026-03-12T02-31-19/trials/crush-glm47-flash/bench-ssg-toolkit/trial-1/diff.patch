+export function createSyntaxHighlightPlugin() {
+  function addLanguageClasses(content: string) {
+    const highlightedBlocks: number[] = [];
+    let markdownified = content.replace(
+      /<pre>\s*<code\s+class=["']language-([^"']+)["']>([\s\S]*?)<\/code>\s*<\/pre>/gi,
+      (match, lang, code) => {
+        highlightedBlocks.push(parseInt(lang.replace(/\D/g, '')));
+        return `<pre><code class="language-${lang} highlighted" data-language="${lang}">${code}</code></pre>`;
+      }
+    );
+
+    const matchingRegex = /<pre>\s*<code\s+class=["']language-([^"']+)["']>\s*<\/code>\s*<\/pre>/gi;
+    if (matchingRegex.test(markdownified)) {
+      markdownified = markdownified.replace(matchingRegex, (match, lang) => {
+        highlightedBlocks.push(parseInt(lang.replace(/\D/g, '')));
+        return `<pre><code class="language-${lang} highlighted" data-language="${lang}"></code></pre>`;
+      });
+    }
+
+    return { content: markdownified, highlightedBlocks };
+  }
+
+  const plugin = {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file, ctx) => {
+        const { content } = addLanguageClasses(file.content);
+        return { ...file, content };
+      },
+    },
+  };
+
+  return plugin;
+}
