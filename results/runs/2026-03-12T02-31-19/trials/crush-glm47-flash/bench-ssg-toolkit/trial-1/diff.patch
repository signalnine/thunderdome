+import { BuildContext, ContentFile, SiteConfig } from '../core/types.js';
+
+export function createRssFeedPlugin() {
+  function generateRssXml(config: SiteConfig, files: ContentFile[], data: Map<string, unknown>) {
+    const title = config.title;
+    const baseUrl = config.baseUrl;
+    const tagMap = data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+
+    const sortedFiles = [...files].sort((a, b) => {
+      const dateA = a.date || Date.now().toString();
+      const dateB = b.date || Date.now().toString();
+      return new Date(dateB).getTime() - new Date(dateA).getTime();
+    });
+
+    const itemEntries = sortedFiles
+      .filter((f) => f.date)
+        .map((file) => {
+          const pubDate = new Date(file.date!).toUTCString();
+          let categories = '';
+          if (tagMap && file.tags) {
+            file.tags.forEach((tag) => {
+              const normalizedTag = tag.toLowerCase();
+              const taggedFile = tagMap.get(normalizedTag);
+              if (taggedFile && taggedFile[0] === file) {
+                categories += `<category>${tag}</category>`;
+              }
+            });
+          }
+          return `<item>\n    <title>${escapeXml(file.title)}</title>\n    <link>${baseUrl}/${file.slug}.html</link>\n    <description><![CDATA[${file.content}]]></description>\n    <pubDate>${pubDate}</pubDate>\n${categories}</item>`;
+        }
+      )
+      .join('\n');
+
+    return `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(title)}</title>
+    <link>${baseUrl}</link>
+    <description>Site feed</description>
+    ${itemEntries}
+  </channel>
+</rss>`;
+  }
+
+  function escapeXml(unsafe: string) {
+    return unsafe
+      .replace(/&/g, '&amp;')
+      .replace(/</g, '&lt;')
+      .replace(/>/g, '&gt;')
+      .replace(/"/g, '&quot;')
+      .replace(/'/g, '&apos;');
+  }
+
+  const plugin = {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: async (ctx) => {
+        const feedXml = generateRssXml(ctx.config, ctx.files, ctx.data);
+        ctx.output.set('feed.xml', feedXml);
+      },
+    },
+  };
+
+  return plugin;
+}
