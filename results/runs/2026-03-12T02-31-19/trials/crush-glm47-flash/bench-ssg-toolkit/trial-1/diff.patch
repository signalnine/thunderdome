+export function createSitemapPlugin() {
+  const BASE_URL_REGEX = /https?:\/\/[^\s]+/g;
+
+  function extractBaseUrl(content: string): string {
+    const match = content.match(BASE_URL_REGEX);
+    return match ? match[0] : '';
+  }
+
+  function generateSitemap(output, data, config) {
+    const baseUrl = config.baseUrl;
+    const tagMap = data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+    const outputUrls = new Set<string>();
+    const emptyTags = [];
+
+    output.forEach((content, path) => {
+      const url = `${baseUrl}/${path}`;
+      outputUrls.add(url);
+    });
+
+    if (tagMap) {
+      tagMap.forEach((_, tag) => {
+        const tagPath = `${baseUrl}/tags/${tag}.html`;
+        outputUrls.add(tagPath);
+      });
+    }
+
+    const missingFeedXml = output.get('feed.xml');
+    if (missingFeedXml) {
+      outputUrls.add(`${baseUrl}/feed.xml`);
+    }
+
+    const urls = Array.from(outputUrls).map(
+      (url) => `<url>
+    <loc>${escapeXml(url)}</loc>
+  </url>`
+    ).join('\n');
+
+    return `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+${urls}
+</urlset>`;
+  }
+
+  function escapeXml(unsafe: string) {
+    return unsafe
+      .replace(/&/g, '&amp;')
+      .replace(/</g, '&lt;')
+      .replace(/>/g, '&gt;')
+      .replace(/"/g, '&quot;');
+  }
+
+  const plugin = {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: async (ctx) => {
+        const sitemapXml = generateSitemap(ctx.output, ctx.data, ctx.config);
+        ctx.output.set('sitemap.xml', sitemapXml);
+      },
+    },
+  };
+
+  return plugin;
+}
