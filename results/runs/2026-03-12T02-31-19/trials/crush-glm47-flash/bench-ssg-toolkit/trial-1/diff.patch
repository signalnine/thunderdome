+export function createTaxonomyPlugin() {
+  const TAG_PATH = '/tags';
+
+  function buildTagMap(files: ContentFile[]) {
+    const tagMap = new Map<string, ContentFile[]>();
+    
+    files.forEach((file) => {
+      const tags = file.tags || [];
+      tags.forEach((tag) => {
+        const normalizedTag = tag.toLowerCase();
+        if (!tagMap.has(normalizedTag)) {
+          tagMap.set(normalizedTag, []);
+        }
+        tagMap.get(normalizedTag)!.push(file);
+      });
+    });
+    
+    return tagMap;
+  }
+
+  function generateTagPageContent(tag: string, taggedFiles: ContentFile[], config, baseUrl) {
+    const entries = taggedFiles
+      .map(
+        (f) =>
+          `<li>
+            <a href="${baseUrl}/${f.slug}.html">${f.title || f.slug}</a>
+          </li>`
+      )
+      .join('\n');
+
+    return `<!DOCTYPE html>
+<html>
+<head>
+  <title>${config.title} - Tag: ${tag}</title>
+</head>
+<body>
+  <h1>${config.title} - ${tag}</h1>
+  <ul>
+${entries}
+  </ul>
+</body>
+</html>`;
+  }
+
+  const plugin = {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: async (ctx, file) => {
+        const tagMap = buildTagMap(ctx.files);
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: async (ctx) => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+        if (!tagMap) return;
+
+        const config = ctx.config;
+        const baseUrl = config.baseUrl;
+
+        tagMap.forEach((taggedFiles, tag) => {
+          const content = generateTagPageContent(tag, taggedFiles, config, baseUrl);
+          ctx.output.set(`${TAG_PATH}/${tag}.html`, content);
+        });
+      },
+    },
+  };
+
+  return plugin;
+}
