+export function createAssetPipelinePlugin() {
+  function packManifest(manifest: Map<string, string[]>) {
+    const assets: string[] = [];
+    const assetSet = new Set<string>();
+    
+    manifest.forEach((entries, path) => {
+      entries.forEach((entry) => {
+        assetSet.add(`${path}/${entry}`);
+      });
+    });
+    
+    return Array.from(assetSet).sort();
+  }
+
+  function rewriteAssetUrls(content: string, baseUrl: string) {
+    return content.replace(
+      /<(img|link)[^>]+src=["'](?!(?:https:)?\/\/)[.]?([^"']+)["']/gi,
+      (match, tag, path) => {
+        const assetPath = path.startsWith('/') ? path : `/${path}`;
+        return `${tag} src="${baseUrl}${assetPath}"`;
+      }
+    );
+  }
+
+  const plugin = {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file, ctx) => {
+        const config = ctx.config;
+        const rewritten = rewriteAssetUrls(file.content, config.baseUrl);
+        const path = `/${config.outputDir}/assets`;
+        const manifest = ctx.data.get('asset-manifest') as Map<string, string[]>;
+        if (!manifest) {
+          ctx.data.set('asset-manifest', new Map());
+        }
+        const currentManifest = ctx.data.get('asset-manifest') as Map<string, string[]>;
+        const assets = currentManifest.get(path) || [];
+        assets.push(file.slug);
+        currentManifest.set(path, assets);
+        return { ...file, content: rewritten };
+      },
+    },
+  };
+
+  return plugin;
+}
