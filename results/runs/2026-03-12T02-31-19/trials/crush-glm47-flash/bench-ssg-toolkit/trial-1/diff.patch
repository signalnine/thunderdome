+export function createSearchIndexPlugin() {
+  function stripHtml(html: string) {
+    return html.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
+  }
+
+  function generateSearchIndex(files, ctx) {
+    const index: Record<string, { title: string; slug: string; content: string; tags?: string[] }> = [];
+    
+    files.forEach((file) => {
+      const content = stripHtml(file.content);
+      const indexEntry: Record<string, { title: string; slug: string; content: string; tags?: string[] }> = {
+        title: file.title || '',
+        slug: file.slug,
+        content,
+      };
+      if (file.tags) {
+        indexEntry.tags = file.tags;
+      }
+      index.push(indexEntry);
+    });
+
+    return JSON.stringify(index);
+  }
+
+  const plugin = {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: async (ctx) => {
+        const searchIndex = generateSearchIndex(ctx.files, ctx);
+        ctx.output.set('search-index.json', searchIndex);
+      },
+    },
+  };
+
+  return plugin;
+}
