+import { Plugin as PluginInterface } from '../core/types.js';
+
+export interface Plugin extends PluginInterface {}
+
+export function createAssetPipelinePlugin(): Plugin {
+    let manifest: string[] = [];
+
+    return {
+        name: 'asset-pipeline',
+        version: '1.0.0',
+        dependencies: [],
+        hooks: {
+            async beforeBuild(ctx) {
+                ctx.data.set('asset-manifest', { assets: manifest });
+            },
+            async transformContent(file: any, ctx: any) {
+                const content = file.content as string;
+
+                let result = content.replace(
+                    /(src|href)="([^"]+)"/g,
+                    (full: string, attr: string, path: string) => {
+                        if (path.startsWith('./') || path.startsWith('../')) {
+                            const assetName = path.split('/').pop() || path;
+                            manifest.push(assetName);
+                            return `${attr}="/assets/${assetName}"`;
+                        }
+                        return full;
+                    }
+                );
+
+                return { ...file, content: result };
+            }
+        }
+    };
+}
