+import { marked } from 'marked';
+import { Plugin as PluginInterface } from '../core/types.js';
+
+export interface Plugin extends PluginInterface {}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: any, ctx: any) {
+        let content = (await marked.parse(file.content as string)) as string;
+
+        const footnotes: Record<string, string> = {};
+
+        content = content.replace(/(?:^\n)?\^?\[(\d+)\]:([^\n]+)/g, (match: string, ref: string, text: string) => {
+          footnotes[ref] = text.trim();
+          return match;
+        });
+
+        content = content.replace(/\[\^(\d+)\]/g, (_: string, ref: string) => {
+          const id = `fn-${ref}`;
+          const a = `<a href="#${id}">${ref}</a>`;
+          return `<sup>${a}</sup>`;
+        });
+
+        let footnoteSection = '';
+        if (Object.keys(footnotes).length > 0) {
+          const items = Object.entries(footnotes).map(([ref, text]) =>
+            `<li id="${ref}">${text}</li>`
+          ).join('\n  ');
+
+          footnoteSection = `
+<section class="footnotes">
+<hr>
+<ol>
+${items}
+</ol>
+</section>`;
+        }
+
+        content = content.replace(/:::(\s*)(\w+)/gm, (_: string, spaces: string, type: string) => {
+          const className = `admonition-${type}`;
+          return `<div class="admonition ${className}" data-type="${type}">${spaces}`;
+        });
+
+        const admonitionContent = content.match(/<div class="admonition (\w+) admonition-(\w+)" data-type="(\w+)">([\s\S]*?)<\/div>/g);
+        if (admonitionContent) {
+          for (const match of admonitionContent) {
+            const firstMatch = match.match(/<div class="admonition (\w+) admonition-(\w+)" data-type="(\w+)">([\s\S]*?)<\/div>/);
+            if (firstMatch) {
+              const [fullMatch, classes, admonitionClass, admonitionType, innerContent] = firstMatch;
+              const newContent = `<div class="admonition admonition-${admonitionType}" data-type="${admonitionType}">${innerContent.trim()}</div>`;
+              content = content.replace(fullMatch, newContent);
+            }
+          }
+        }
+
+        if (footnoteSection) {
+          content += '\n' + footnoteSection;
+        }
+
+        return { ...file, content };
+      }
+    }
+  };
+}
