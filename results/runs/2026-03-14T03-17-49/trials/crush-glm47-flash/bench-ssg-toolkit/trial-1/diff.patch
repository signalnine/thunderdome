+import { Plugin as PluginInterface } from '../core/types.js';
+
+export interface Plugin extends PluginInterface {}
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: any, ctx: any) {
+        const content = file.content as string;
+
+        const transformed = content.replace(
+          /<pre>[\s\S]*?<code class="language-(\w+)"?>([\s\S]*?)<\/code>[\s\S]*?<\/pre>/gi,
+          (_: any, lang: string, code: string) => {
+            const dataAttr = `data-language="${lang}"`;
+            return `<pre><code class="language-${lang} highlighted" ${dataAttr}>${code}</code></pre>`;
+          }
+        );
+
+        return { ...file, content: transformed };
+      }
+    }
+  };
+}
