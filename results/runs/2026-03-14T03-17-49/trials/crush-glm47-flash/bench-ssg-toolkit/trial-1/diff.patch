+import { Plugin as PluginInterface } from '../core/types.js';
+
+export interface Plugin extends PluginInterface {}
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      async afterBuild(ctx: any) {
+        const index = ctx.files.map((file: any) => {
+          const title = (file.title || '').trim();
+          const content = (file.content || '').trim()
+            .replace(/<[^>]+>/g, ' ')
+            .replace(/\s+/g, ' ')
+            .substring(0, 500);
+
+          return {
+            id: file.slug || file.slug?.toString() || '',
+            title,
+            content,
+            url: `${ctx.config.baseUrl}/${file.slug}.html`,
+            date: file.date || '',
+            tags: file.tags || [],
+          };
+        });
+
+        ctx.output.set('search-index.json', JSON.stringify(index, null, 2));
+      }
+    }
+  };
+}
