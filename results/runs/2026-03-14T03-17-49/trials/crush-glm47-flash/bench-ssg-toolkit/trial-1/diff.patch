+import { Plugin as PluginInterface } from '../core/types.js';
+
+export interface Plugin extends PluginInterface {}
+
+export interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      async afterBuild(ctx: any) {
+        const config: DevServerConfig = {
+          port: 3000,
+          routes: [],
+          assetPaths: [],
+          searchIndexPath: '/search-index.json',
+        };
+
+        const assetManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (assetManifest && assetManifest.assets) {
+          config.assetPaths = assetManifest.assets;
+          config.routes.push(...config.assetPaths.map(path => ({
+            path: `/assets/${path}`,
+            handler: 'asset',
+          })));
+        }
+
+        const searchIndexPath = config.searchIndexPath;
+        config.routes.push({ path: searchIndexPath, handler: 'static' });
+
+        const contentRoutes: { path: string; handler: string }[] = [];
+
+        const outputEntries = ctx.output.entries();
+        for (const [path] of outputEntries) {
+            if (!path.startsWith('tags/')) {
+                contentRoutes.push({ path: `/${path}`, handler: 'static' });
+            }
+        }
+        config.routes.push(...contentRoutes);
+
+        ctx.data.set('dev-server-config', config);
+      }
+    }
+  };
+}
