+import { Plugin as PluginInterface } from '../core/types.js';
+
+export interface Plugin extends PluginInterface {}
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async beforeBuild(ctx: any) {
+        const allFiles = ctx.files.filter((f: any) => f.tags);
+        const tagMap = new Map<string, any[]>();
+
+        if (!allFiles.length) {
+          ctx.data.set('taxonomy-tags', new Map());
+          return;
+        }
+
+        for (const file of allFiles) {
+          for (const tag of file.tags) {
+            const lowerTag = tag.toLowerCase();
+            if (!tagMap.has(lowerTag)) {
+              tagMap.set(lowerTag, []);
+            }
+            tagMap.get(lowerTag)!.push(file);
+          }
+        }
+
+        const normalizedTagMap = new Map<string, any[]>();
+        for (const [tag, files] of tagMap) {
+          normalizedTagMap.set(tag, [...files].sort((a: any, b: any) => {
+            const aDate = a.date || '';
+            const bDate = b.date || '';
+            return bDate.localeCompare(aDate);
+          }));
+        }
+
+        ctx.data.set('taxonomy-tags', normalizedTagMap);
+      },
+      async afterBuild(ctx: any) {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, any[]>;
+        if (!tagMap || tagMap.size === 0) return;
+
+        const baseUrl = ctx.config.baseUrl;
+
+        for (const [tag, files] of tagMap) {
+          if (!files || files.length === 0) continue;
+
+          const items = files
+            .map((f: any) => `<li><a href="${f.slug}.html">${f.title}</a></li>`)
+            .join('\n      ');
+
+          const content = `<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <title>${tag} posts | ${ctx.config.title}</title>
+</head>
+<body>
+  <h1>${tag} posts</h1>
+  <div class="list">
+    <ul>
+${items}
+    </ul>
+  </div>
+</body>
+</html>`;
+
+          ctx.output.set(`tags/${tag}.html`, content);
+        }
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      }
+    }
+  };
+}
