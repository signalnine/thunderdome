+import { Plugin as PluginInterface } from '../core/types.js';
+
+export interface Plugin extends PluginInterface {}
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      async afterBuild(ctx: any) {
+        const files = ctx.files.filter((f: any) => f.date).sort((a: any, b: any) => {
+          return b.date.localeCompare(a.date);
+        }).slice(0, 20);
+
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, any[]> || new Map();
+        const categories = new Set<string>();
+
+        files.forEach((file: any) => {
+          if (file.tags) {
+            file.tags.forEach((tag: string) => categories.add(tag.toLowerCase()));
+          }
+        });
+
+        const items = files.map((file: any) => {
+          let content: string = file.content as string;
+          if (content.length > 1024) {
+            content = content.substring(0, 1024) + '...';
+          }
+          const htmlEncoded = content.replace(/</g, '&lt;').replace(/>/g, '&gt;');
+          return `    <item>
+      <title>${file.title}</title>
+      <link>${ctx.config.baseUrl}/${file.slug}.html</link>
+      ${file.date ? `      <pubDate>${file.date}</pubDate>` : ''}
+      <guid isPermaLink="true">${ctx.config.baseUrl}/${file.slug}.html</guid>
+      <description><![CDATA[${htmlEncoded}]]></description>
+    </item>`;
+        }).join('\n');
+
+        const categoryTags = Array.from(categories).map(c => `    <category>${c}</category>`).join('\n');
+
+        const xml = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${ctx.config.title}</title>
+    <link>${ctx.config.baseUrl}</link>
+${categoryTags}
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', xml);
+      }
+    }
+  };
+}
