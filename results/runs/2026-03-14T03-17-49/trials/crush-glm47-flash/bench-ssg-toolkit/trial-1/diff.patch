+import { Plugin as PluginInterface } from '../core/types.js';
+
+export interface Plugin extends PluginInterface {}
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      async afterBuild(ctx: any) {
+        const baseUrl = ctx.config.baseUrl;
+        const urls: string[] = [`${baseUrl}/`];
+
+        for (const [path, content] of ctx.output) {
+          if (!content.startsWith('<html')) continue;
+          const filename = path.split('/').pop() || '';
+          if (filename !== 'sitemap.xml') {
+            urls.push(`${baseUrl}/${path}`);
+          }
+        }
+
+        if (ctx.output.has('feed.xml')) {
+          urls.push(`${baseUrl}/feed.xml`);
+        }
+
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, any[]>;
+        if (tagMap) {
+          for (const tag of tagMap.keys()) {
+            urls.push(`${baseUrl}/tags/${tag}.html`);
+          }
+        }
+
+        const sitemap = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+${urls.map(url => `  <url>
+    <loc>${url}</loc>
+  </url>`).join('\n')}
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemap);
+      }
+    }
+  };
+}
