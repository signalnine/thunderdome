@@ -0,0 +1,80 @@
+import type { Operation, InsertOperation, DeleteOperation } from './models.js';
+
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    return content.slice(0, op.position) + op.text + content.slice(op.position);
+  } else {
+    return content.slice(0, op.position) + content.slice(op.position + op.count);
+  }
+}
+
+export function transformOperation(op: Operation, against: Operation): Operation {
+  if (op.type === 'insert') {
+    return transformInsert(op, against);
+  } else {
+    return transformDelete(op, against);
+  }
+}
+
+function transformInsert(op: InsertOperation, against: Operation): InsertOperation {
+  if (against.type === 'insert') {
+    if (against.position <= op.position) {
+      return { ...op, position: op.position + against.text.length };
+    }
+    return op;
+  } else {
+    if (against.position + against.count <= op.position) {
+      return { ...op, position: op.position - against.count };
+    } else if (against.position <= op.position) {
+      return { ...op, position: against.position };
+    }
+    return op;
+  }
+}
+
+function transformDelete(op: DeleteOperation, against: Operation): DeleteOperation {
+  if (against.type === 'insert') {
+    if (against.position <= op.position) {
+      return { ...op, position: op.position + against.text.length };
+    } else if (against.position < op.position + op.count) {
+      return { ...op, count: op.count + against.text.length };
+    }
+    return op;
+  } else {
+    const againstEnd = against.position + against.count;
+    const opEnd = op.position + op.count;
+    
+    if (againstEnd <= op.position) {
+      return { ...op, position: op.position - against.count };
+    } else if (opEnd <= against.position) {
+      return op;
+    } else if (against.position <= op.position && againstEnd >= opEnd) {
+      return { ...op, count: 0 };
+    } else if (against.position <= op.position && againstEnd < opEnd) {
+      const newPos = against.position;
+      const newCount = opEnd - againstEnd;
+      return { ...op, position: newPos, count: newCount };
+    } else if (op.position < against.position && opEnd > againstEnd) {
+      const newCount = op.count - against.count;
+      return { ...op, count: newCount };
+    } else {
+      const overlapStart = Math.max(op.position, against.position);
+      const overlapEnd = Math.min(opEnd, againstEnd);
+      const overlap = overlapEnd - overlapStart;
+      const newCount = op.count - overlap;
+      return { ...op, count: Math.max(0, newCount) };
+    }
+  }
+}
+
+export function validateOperation(op: Operation, contentLength: number): boolean {
+  if (op.type === 'insert') {
+    return op.position >= 0 && op.position <= contentLength && typeof op.text === 'string';
+  } else {
+    return (
+      op.position >= 0 &&
+      op.count >= 0 &&
+      op.position + op.count <= contentLength
+    );
+  }
+}
