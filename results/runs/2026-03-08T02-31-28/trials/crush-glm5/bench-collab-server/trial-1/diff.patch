@@ -0,0 +1,66 @@
+import express from 'express';
+import { createServer } from 'http';
+import type { Server as HttpServer } from 'http';
+import type { WebSocketServer } from 'ws';
+import type Database from 'better-sqlite3';
+import { createDatabase } from './db.js';
+import { createRoutes } from './routes.js';
+import { createWebSocketServer, handleUpgrade } from './ws.js';
+
+export interface AppInstance {
+  app: express.Application;
+  server: HttpServer;
+  wss: WebSocketServer;
+  db: Database.Database;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const app = express();
+  const server = createServer(app);
+  const wss = createWebSocketServer(db);
+
+  app.use(express.json());
+  app.use('/', createRoutes(db));
+
+  server.on('upgrade', (request, socket, head) => {
+    handleUpgrade(wss, db, request, socket, head);
+  });
+
+  const start = (port = 0): Promise<number> => {
+    return new Promise((resolve, reject) => {
+      server.listen(port, () => {
+        const address = server.address();
+        if (address && typeof address === 'object') {
+          resolve(address.port);
+        } else {
+          reject(new Error('Failed to get server port'));
+        }
+      });
+    });
+  };
+
+  const stop = (): Promise<void> => {
+    return new Promise((resolve) => {
+      for (const ws of wss.clients) {
+        ws.close();
+      }
+      wss.close(() => {
+        server.close(() => {
+          db.prepare('DELETE FROM active_connections').run();
+          if (!db.memory) {
+            db.close();
+          }
+          resolve();
+        });
+      });
+    });
+  };
+
+  return { app, server, wss, db, start, stop };
+}
+
+export { createDatabase } from './db.js';
+export type { Document, Version, Operation, InsertOperation, DeleteOperation } from './models.js';
diff --git a/src/ws.ts b/src/ws.ts
new file mode 100644
index 0000000..02f9fce
--- /dev/null
+++ b/src/ws.ts
@@ -0,0 +1,199 @@
+import { WebSocketServer, WebSocket, type RawData } from 'ws';
+import type { IncomingMessage } from 'http';
+import type Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import { applyOperation, validateOperation, transformOperation } from './ot.js';
+import type { Document, Operation } from './models.js';
+
+interface ClientInfo {
+  docId: string;
+  ws: WebSocket;
+}
+
+interface DocumentState {
+  content: string;
+  version: number;
+  operations: Operation[];
+}
+
+export function createWebSocketServer(db: Database.Database): WebSocketServer {
+  const wss = new WebSocketServer({ noServer: true });
+  
+  const rooms = new Map<string, Set<WebSocket>>();
+  const docStates = new Map<string, DocumentState>();
+  const clients = new Map<WebSocket, ClientInfo>();
+
+  function getDocumentState(docId: string): DocumentState | null {
+    if (docStates.has(docId)) {
+      return docStates.get(docId)!;
+    }
+
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(docId) as Document | undefined;
+    if (!doc) {
+      return null;
+    }
+
+    const versions = db
+      .prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1')
+      .all(docId) as { version: number }[];
+
+    const version = versions.length > 0 ? versions[0].version : 0;
+    const operations: Operation[] = [];
+
+    const state: DocumentState = { content: doc.content, version, operations };
+    docStates.set(docId, state);
+    return state;
+  }
+
+  function sendError(ws: WebSocket, message: string): void {
+    ws.send(JSON.stringify({ type: 'error', message }));
+  }
+
+  function sendSync(ws: WebSocket, content: string, version: number): void {
+    ws.send(JSON.stringify({ type: 'sync', content, version }));
+  }
+
+  function sendAck(ws: WebSocket, version: number): void {
+    ws.send(JSON.stringify({ type: 'ack', version }));
+  }
+
+  function broadcast(docId: string, message: unknown, exclude?: WebSocket): void {
+    const room = rooms.get(docId);
+    if (!room) return;
+
+    const data = JSON.stringify(message);
+    for (const client of room) {
+      if (client !== exclude && client.readyState === WebSocket.OPEN) {
+        client.send(data);
+      }
+    }
+  }
+
+  wss.on('connection', (ws: WebSocket, req: IncomingMessage, docId: string) => {
+    const state = getDocumentState(docId);
+    if (!state) {
+      sendError(ws, `Document ${docId} not found`);
+      ws.close();
+      return;
+    }
+
+    if (!rooms.has(docId)) {
+      rooms.set(docId, new Set());
+    }
+    rooms.get(docId)!.add(ws);
+
+    const connId = randomUUID();
+    db.prepare('INSERT INTO active_connections (id, document_id) VALUES (?, ?)').run(connId, docId);
+
+    clients.set(ws, { docId, ws });
+
+    sendSync(ws, state.content, state.version);
+
+    ws.on('message', (data: RawData) => {
+      const message = data.toString();
+      let parsed: { type: string; operation?: unknown; version?: number };
+
+      try {
+        parsed = JSON.parse(message);
+      } catch {
+        sendError(ws, 'Invalid JSON');
+        return;
+      }
+
+      if (parsed.type !== 'operation') {
+        sendError(ws, 'Unknown message type');
+        return;
+      }
+
+      const op = parsed.operation as Operation;
+      if (!op || (op.type !== 'insert' && op.type !== 'delete')) {
+        sendError(ws, 'Invalid operation type');
+        return;
+      }
+
+      const currentState = getDocumentState(docId);
+      if (!currentState) {
+        sendError(ws, 'Document not found');
+        return;
+      }
+
+      let transformedOp = op;
+      const clientVersion = parsed.version ?? currentState.version;
+
+      if (clientVersion < currentState.version) {
+        for (let i = clientVersion; i < currentState.operations.length; i++) {
+          transformedOp = transformOperation(transformedOp, currentState.operations[i]);
+        }
+      }
+
+      if (!validateOperation(transformedOp, currentState.content.length)) {
+        sendError(ws, 'Invalid operation bounds');
+        return;
+      }
+
+      const newContent = applyOperation(currentState.content, transformedOp);
+      const newVersion = currentState.version + 1;
+      const now = new Date().toISOString();
+
+      currentState.content = newContent;
+      currentState.version = newVersion;
+      currentState.operations.push(transformedOp);
+
+      db.prepare('UPDATE documents SET content = ?, updated_at = ? WHERE id = ?').run(newContent, now, docId);
+      db.prepare(
+        'INSERT INTO versions (document_id, version, content, operation, created_at) VALUES (?, ?, ?, ?, ?)'
+      ).run(docId, newVersion, newContent, JSON.stringify(transformedOp), now);
+
+      sendAck(ws, newVersion);
+
+      broadcast(docId, { type: 'operation', operation: transformedOp }, ws);
+    });
+
+    ws.on('close', () => {
+      const clientInfo = clients.get(ws);
+      if (clientInfo) {
+        const room = rooms.get(clientInfo.docId);
+        if (room) {
+          room.delete(ws);
+          if (room.size === 0) {
+            rooms.delete(clientInfo.docId);
+          }
+        }
+        db.prepare('DELETE FROM active_connections WHERE id = ?').run(connId);
+        clients.delete(ws);
+      }
+    });
+  });
+
+  return wss;
+}
+
+export function handleUpgrade(
+  wss: WebSocketServer,
+  db: Database.Database,
+  request: IncomingMessage,
+  socket: import('stream').Duplex,
+  head: Buffer
+): void {
+  const url = new URL(request.url || '', `http://${request.headers.host}`);
+  const pathParts = url.pathname.split('/').filter(Boolean);
+  const docId = pathParts[0] || '';
+
+  if (!docId) {
+    socket.destroy();
+    return;
+  }
+
+  const doc = db.prepare('SELECT id FROM documents WHERE id = ?').get(docId);
+  if (!doc) {
+    wss.handleUpgrade(request, socket, head, (ws) => {
+      ws.send(JSON.stringify({ type: 'error', message: `Document ${docId} not found` }));
+      ws.close();
+    });
+    return;
+  }
+
+  wss.handleUpgrade(request, socket, head, (ws) => {
+    wss.emit('connection', ws, request, docId);
+  });
+}
