n this.entries.map((e) => ({ ...e }));\n  }\n\n  getEntriesByDateRange(from: Date, to: Date): TimeEntry[] {\n    const fromMs = from.getTime();\n    const toMs = to.getTime();\n\n    return this.entries\n      .filter((e) => e.start >= fromMs && e.start <= toMs)\n      .map((e) => ({ ...e }));\n  }\n\n  getSummary(): TimeSummary {\n    const summary: TimeSummary = {};\n    const now = Date.now();\n\n    for (const entry of this.entries) {\n      const end = entry.stop ?? now;\n      const duration = end - entry.start;\n      summary[entry.task] = (summary[entry.task] ?? 0) + duration;\n    }\n\n    return summary;\n  }\n\n  isRunning(): boolean {\n    return this.entries.some((e) => e.stop === null);\n  }\n\n  currentTask(): string | null {\n    const running = this.entries.find((e) => e.stop === null);\n    return running ? running.task : null;\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":261,"cache_read_input_tokens":19846,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":261},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8279d7c7-9570-4449-ac04-71552d93d46a","uuid":"fa923ad5-37a7-4d10-8e8b-b6ddfa9b0ab3"}
