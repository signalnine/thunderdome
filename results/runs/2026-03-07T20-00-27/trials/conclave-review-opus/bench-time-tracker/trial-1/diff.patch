--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,106 @@
+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: number;
+  stop: number | null;
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.load();
+  }
+
+  private load(): void {
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (Array.isArray(parsed)) {
+        this.entries = parsed as TimeEntry[];
+      }
+    } catch {
+      // File doesn't exist or is invalid — start with empty entries
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Stop currently running timer if any
+    const running = this.entries.find((e) => e.stop === null);
+    if (running) {
+      running.stop = Date.now();
+    }
+
+    this.entries.push({
+      task,
+      start: Date.now(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.entries.find((e) => e.stop === null);
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = Date.now();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(): TimeEntry[] {
+    return this.entries.map((e) => ({ ...e }));
+  }
+
+  getEntriesByDateRange(from: Date, to: Date): TimeEntry[] {
+    const fromMs = from.getTime();
+    const toMs = to.getTime();
+
+    return this.entries
+      .filter((e) => e.start >= fromMs && e.start <= toMs)
+      .map((e) => ({ ...e }));
+  }
+
+  getSummary(): TimeSummary {
+    const summary: TimeSummary = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const end = entry.stop ?? now;
+      const duration = end - entry.start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.entries.some((e) => e.stop === null);
+  }
+
+  currentTask(): string | null {
+    const running = this.entries.find((e) => e.stop === null);
+    return running ? running.task : null;
+  }
+}
