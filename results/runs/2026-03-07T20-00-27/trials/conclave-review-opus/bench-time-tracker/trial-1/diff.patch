+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker, TimeEntry } from "../src/index.js";
+import { mkdirSync, rmSync, existsSync, readFileSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+function tmpFile(): string {
+  return join(
+    tmpdir(),
+    `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}`,
+    "data.json"
+  );
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+    tracker = new TimeTracker(filePath);
+  });
+
+  afterEach(() => {
+    try {
+      const dir = join(filePath, "..");
+      rmSync(dir, { recursive: true, force: true });
+    } catch {
+      // ignore
+    }
+  });
+
+  describe("start and stop", () => {
+    it("should start and stop a timer", () => {
+      tracker.start("coding");
+      expect(tracker.isRunning()).toBe(true);
+      expect(tracker.currentTask()).toBe("coding");
+
+      const entry = tracker.stop();
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeLessThanOrEqual(entry.stop!);
+      expect(tracker.isRunning()).toBe(false);
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].stop).toBeNull();
+    });
+
+    it("should throw when starting with empty name", () => {
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should create file and directories automatically", () => {
+      tracker.start("test");
+      expect(existsSync(filePath)).toBe(true);
+    });
+
+    it("should persist entries between instances", () => {
+      tracker.start("persistent-task");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("persistent-task");
+    });
+
+    it("should create deeply nested directories", () => {
+      const deepPath = join(
+        tmpdir(),
+        `deep-${Date.now()}`,
+        "a",
+        "b",
+        "c",
+        "data.json"
+      );
+      const t = new TimeTracker(deepPath);
+      t.start("deep");
+      expect(existsSync(deepPath)).toBe(true);
+      rmSync(join(tmpdir(), `deep-${Date.now()}`), {
+        recursive: true,
+        force: true,
+      });
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries", () => {
+      tracker.start("a");
+      tracker.start("b");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+    });
+
+    it("should return copies (not references)", () => {
+      tracker.start("test");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      entries[0].task = "modified";
+
+      const entriesAgain = tracker.getEntries();
+      expect(entriesAgain[0].task).toBe("test");
+    });
+  });
+
+  describe("getEntriesByDateRange", () => {
+    it("should filter entries by date range", () => {
+      tracker.start("in-range");
+      tracker.stop();
+
+      const now = Date.now();
+      const entries = tracker.getEntriesByDateRange(
+        new Date(now - 60000),
+        new Date(now + 60000)
+      );
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("in-range");
+    });
+
+    it("should exclude entries outside range", () => {
+      tracker.start("task");
+      tracker.stop();
+
+      const future = new Date(Date.now() + 100000);
+      const farFuture = new Date(Date.now() + 200000);
+      const entries = tracker.getEntriesByDateRange(future, farFuture);
+      expect(entries).toHaveLength(0);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task name", () => {
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("meeting");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary).toHaveProperty("coding");
+      expect(summary).toHaveProperty("meeting");
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["meeting"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should use current time for running tasks", () => {
+      tracker.start("running-task");
+
+      const summary = tracker.getSummary();
+      expect(summary["running-task"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      tracker.start("日本語タスク");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("日本語タスク");
+    });
+
+    it("should handle emoji task names", () => {
+      tracker.start("🚀 Launch prep");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 Launch prep");
+    });
+
+    it("should persist unicode names", () => {
+      tracker.start("café ☕ работа");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("café ☕ работа");
+    });
   });
 });
