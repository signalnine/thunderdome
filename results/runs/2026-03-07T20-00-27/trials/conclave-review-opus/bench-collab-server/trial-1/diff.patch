@@ -0,0 +1,265 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage, Server as HttpServer } from 'http';
+import { DocumentRepo } from './db.js';
+import { Operation, apply, transform, validate } from './ot.js';
+
+interface ClientMessage {
+  type: 'operation';
+  version: number;
+  operation: Operation;
+}
+
+interface SyncMessage {
+  type: 'sync';
+  content: string;
+  version: number;
+}
+
+interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+interface OpBroadcast {
+  type: 'operation';
+  operation: Operation;
+  version: number;
+}
+
+interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+type ServerMessage = SyncMessage | AckMessage | OpBroadcast | ErrorMessage;
+
+interface ConnectedClient {
+  ws: WebSocket;
+  documentId: string;
+}
+
+interface DocumentState {
+  content: string;
+  version: number;
+  /** Operations log: index i = operation that produced version (i + baseVersion + 1) */
+  ops: Operation[];
+  baseVersion: number;
+}
+
+export function setupWebSocket(
+  server: HttpServer,
+  repo: DocumentRepo
+) {
+  const wss = new WebSocketServer({ server });
+
+  // documentId -> state
+  const documents = new Map<string, DocumentState>();
+  // ws -> client info
+  const clients = new Map<WebSocket, ConnectedClient>();
+
+  function getDocumentState(docId: string): DocumentState | null {
+    let state = documents.get(docId);
+    if (state) return state;
+
+    const doc = repo.get(docId);
+    if (!doc) return null;
+
+    const version = repo.getLatestVersion(docId);
+    state = {
+      content: doc.content,
+      version,
+      ops: [],
+      baseVersion: version,
+    };
+    documents.set(docId, state);
+    return state;
+  }
+
+  function getClientsForDocument(docId: string): WebSocket[] {
+    const result: WebSocket[] = [];
+    for (const [ws, client] of clients) {
+      if (client.documentId === docId && ws.readyState === WebSocket.OPEN) {
+        result.push(ws);
+      }
+    }
+    return result;
+  }
+
+  function send(ws: WebSocket, msg: ServerMessage) {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(msg));
+    }
+  }
+
+  wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+    const url = req.url ?? '';
+    // Expect path like /ws/{documentId}  or /doc/{documentId}/ws
+    const match = url.match(/\/(?:ws\/|doc\/)([^/]+)(?:\/ws)?$/);
+    if (!match) {
+      send(ws, { type: 'error', message: 'Invalid WebSocket path. Use /ws/{documentId}' });
+      ws.close();
+      return;
+    }
+
+    const documentId = match[1];
+    const state = getDocumentState(documentId);
+    if (!state) {
+      send(ws, { type: 'error', message: `Document ${documentId} not found` });
+      ws.close();
+      return;
+    }
+
+    clients.set(ws, { ws, documentId });
+
+    // Send current document state
+    send(ws, {
+      type: 'sync',
+      content: state.content,
+      version: state.version,
+    });
+
+    ws.on('message', (data) => {
+      let msg: ClientMessage;
+      try {
+        msg = JSON.parse(data.toString());
+      } catch {
+        send(ws, { type: 'error', message: 'Invalid JSON' });
+        return;
+      }
+
+      if (msg.type !== 'operation') {
+        send(ws, { type: 'error', message: `Unknown message type: ${msg.type}` });
+        return;
+      }
+
+      const docState = getDocumentState(documentId);
+      if (!docState) {
+        send(ws, { type: 'error', message: 'Document no longer exists' });
+        return;
+      }
+
+      // Validate version
+      if (typeof msg.version !== 'number' || msg.version < docState.baseVersion || msg.version > docState.version) {
+        send(ws, {
+          type: 'error',
+          message: `Invalid version ${msg.version}. Current version is ${docState.version}`,
+        });
+        return;
+      }
+
+      // Validate operation against the document at the given version
+      let op = msg.operation;
+      const validationError = validate(op, getDocLengthAtVersion(docState, msg.version));
+      if (validationError) {
+        send(ws, { type: 'error', message: validationError });
+        return;
+      }
+
+      // Transform against all operations that happened after the client's version
+      const startIdx = msg.version - docState.baseVersion;
+      for (let i = startIdx; i < docState.ops.length; i++) {
+        const [transformedOp] = transform(op, docState.ops[i]);
+        op = transformedOp;
+      }
+
+      // Apply the transformed operation
+      try {
+        docState.content = apply(docState.content, op);
+      } catch (e) {
+        send(ws, {
+          type: 'error',
+          message: `Failed to apply operation: ${e instanceof Error ? e.message : String(e)}`,
+        });
+        return;
+      }
+
+      docState.version++;
+      docState.ops.push(op);
+
+      // Persist
+      try {
+        repo.updateContent(documentId, docState.content, op);
+      } catch {
+        // Log but don't fail the operation
+      }
+
+      // Acknowledge to sender
+      send(ws, { type: 'ack', version: docState.version });
+
+      // Broadcast to other clients
+      const otherClients = getClientsForDocument(documentId);
+      for (const clientWs of otherClients) {
+        if (clientWs !== ws) {
+          send(clientWs, {
+            type: 'operation',
+            operation: op,
+            version: docState.version,
+          });
+        }
+      }
+    });
+
+    ws.on('close', () => {
+      clients.delete(ws);
+    });
+
+    ws.on('error', () => {
+      clients.delete(ws);
+    });
+  });
+
+  function getDocLengthAtVersion(state: DocumentState, version: number): number {
+    // Replay from current content backwards or forwards.
+    // Easier: start from original content and apply ops up to version.
+    // But we don't store original content.
+    // Instead, compute from current doc by reverse calculation.
+    // Actually, let's just replay from content at baseVersion.
+
+    // We need the content at the base version. Let's store it.
+    // Alternative: use the ops array to compute lengths.
+    // The document at baseVersion has some length. Each op changes the length.
+    // We can figure out document length at any version from the ops.
+
+    // Get content at version by looking at the database
+    if (version === state.version) {
+      return state.content.length;
+    }
+
+    // Compute the length at the requested version by working backwards from current
+    let len = state.content.length;
+    for (let i = state.ops.length - 1; i >= version - state.baseVersion; i--) {
+      const op = state.ops[i];
+      // This op transforms docAtVersion_i into docAtVersion_(i+1)
+      // outputLength of op = len at i+1, inputLength = len at i
+      let inLen = 0;
+      let outLen = 0;
+      for (const c of op) {
+        if ('retain' in c) { inLen += c.retain; outLen += c.retain; }
+        else if ('insert' in c) { outLen += c.insert.length; }
+        else if ('delete' in c) { inLen += c.delete; }
+      }
+      // outLen should equal the length at the next version
+      // inLen is the length at this version
+      len = inLen;
+    }
+    return len;
+  }
+
+  return {
+    wss,
+    close() {
+      for (const [ws] of clients) {
+        ws.close();
+      }
+      clients.clear();
+      documents.clear();
+      wss.close();
+    },
+    /** Invalidate cached document state — used when REST API modifies a document */
+    invalidateDocument(docId: string) {
+      documents.delete(docId);
+    },
+  };
+}
+
+export type WsManager = ReturnType<typeof setupWebSocket>;
