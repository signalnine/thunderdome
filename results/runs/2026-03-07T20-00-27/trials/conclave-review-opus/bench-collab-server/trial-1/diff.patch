leted = repo.delete(req.params.id);\n    if (!deleted) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    wsManager.invalidateDocument(req.params.id);\n    res.status(204).send();\n  });\n\n  // Get document version history\n  router.get('/documents/:id/versions', (req, res) => {\n    const doc = repo.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = repo.getVersions(req.params.id);\n    res.json(versions);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":308,"cache_read_input_tokens":29177,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":308},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1b30b82e-650e-4203-83a3-f2027dbd8c28","uuid":"a2782128-1428-436a-8219-f016ba411272"}
