+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, validate, inputLength, outputLength, Operation } from './ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('applies a simple insert', () => {
+      const doc = 'hello';
+      const op: Operation = [{ retain: 5 }, { insert: ' world' }];
+      expect(apply(doc, op)).toBe('hello world');
+    });
+
+    it('applies a simple delete', () => {
+      const doc = 'hello world';
+      const op: Operation = [{ retain: 5 }, { delete: 6 }];
+      expect(apply(doc, op)).toBe('hello');
+    });
+
+    it('applies insert at beginning', () => {
+      const doc = 'world';
+      const op: Operation = [{ insert: 'hello ' }, { retain: 5 }];
+      expect(apply(doc, op)).toBe('hello world');
+    });
+
+    it('applies combined operations', () => {
+      const doc = 'hello world';
+      const op: Operation = [{ retain: 5 }, { delete: 1 }, { insert: ', ' }, { retain: 5 }];
+      expect(apply(doc, op)).toBe('hello, world');
+    });
+
+    it('applies to empty document', () => {
+      const op: Operation = [{ insert: 'hello' }];
+      expect(apply('', op)).toBe('hello');
+    });
+
+    it('throws on length mismatch', () => {
+      expect(() => apply('hello', [{ retain: 3 }])).toThrow();
+    });
+  });
+
+  describe('transform', () => {
+    it('transforms two inserts at different positions', () => {
+      // Doc: "abc" (length 3)
+      // A inserts "X" at position 1: [retain 1, insert "X", retain 2]
+      // B inserts "Y" at position 2: [retain 2, insert "Y", retain 1]
+      const opA: Operation = [{ retain: 1 }, { insert: 'X' }, { retain: 2 }];
+      const opB: Operation = [{ retain: 2 }, { insert: 'Y' }, { retain: 1 }];
+
+      const [aPrime, bPrime] = transform(opA, opB);
+
+      const doc = 'abc';
+      const afterA = apply(doc, opA);    // "aXbc"
+      const afterB = apply(doc, opB);    // "abYc"
+
+      const afterAB = apply(afterA, bPrime); // should be "aXbYc"
+      const afterBA = apply(afterB, aPrime); // should be "aXbYc"
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toBe('aXbYc');
+    });
+
+    it('transforms two inserts at the same position', () => {
+      // Doc: "ab" (length 2)
+      // A inserts "X" at position 1
+      // B inserts "Y" at position 1
+      const opA: Operation = [{ retain: 1 }, { insert: 'X' }, { retain: 1 }];
+      const opB: Operation = [{ retain: 1 }, { insert: 'Y' }, { retain: 1 }];
+
+      const [aPrime, bPrime] = transform(opA, opB);
+
+      const doc = 'ab';
+      const afterA = apply(doc, opA);
+      const afterB = apply(doc, opB);
+
+      const afterAB = apply(afterA, bPrime);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      // Both inserts should be preserved
+      expect(afterAB).toContain('X');
+      expect(afterAB).toContain('Y');
+    });
+
+    it('transforms insert vs delete', () => {
+      // Doc: "abcd" (length 4)
+      // A inserts "X" at position 2: [retain 2, insert "X", retain 2]
+      // B deletes char at position 1: [retain 1, delete 1, retain 2]
+      const opA: Operation = [{ retain: 2 }, { insert: 'X' }, { retain: 2 }];
+      const opB: Operation = [{ retain: 1 }, { delete: 1 }, { retain: 2 }];
+
+      const [aPrime, bPrime] = transform(opA, opB);
+
+      const doc = 'abcd';
+      const afterA = apply(doc, opA);    // "abXcd"
+      const afterB = apply(doc, opB);    // "acd"
+
+      const afterAB = apply(afterA, bPrime);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toBe('aXcd');
+    });
+
+    it('transforms two deletes at different positions', () => {
+      // Doc: "abcd" (length 4)
+      // A deletes at position 0: [delete 1, retain 3]
+      // B deletes at position 3: [retain 3, delete 1]
+      const opA: Operation = [{ delete: 1 }, { retain: 3 }];
+      const opB: Operation = [{ retain: 3 }, { delete: 1 }];
+
+      const [aPrime, bPrime] = transform(opA, opB);
+
+      const doc = 'abcd';
+      const afterA = apply(doc, opA);
+      const afterB = apply(doc, opB);
+
+      const afterAB = apply(afterA, bPrime);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toBe('bc');
+    });
+
+    it('transforms two deletes at the same position', () => {
+      // Doc: "abc" (length 3)
+      // Both delete the first char
+      const opA: Operation = [{ delete: 1 }, { retain: 2 }];
+      const opB: Operation = [{ delete: 1 }, { retain: 2 }];
+
+      const [aPrime, bPrime] = transform(opA, opB);
+
+      const doc = 'abc';
+      const afterA = apply(doc, opA);
+      const afterB = apply(doc, opB);
+
+      const afterAB = apply(afterA, bPrime);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toBe('bc');
+    });
+
+    it('throws on different input lengths', () => {
+      const opA: Operation = [{ retain: 3 }];
+      const opB: Operation = [{ retain: 5 }];
+      expect(() => transform(opA, opB)).toThrow();
+    });
+  });
+
+  describe('compose', () => {
+    it('composes two sequential operations', () => {
+      const doc = 'abc';
+      const op1: Operation = [{ retain: 3 }, { insert: 'd' }]; // "abcd"
+      const op2: Operation = [{ retain: 1 }, { insert: 'X' }, { retain: 3 }]; // "aXbcd"
+
+      const composed = compose(op1, op2);
+      const result = apply(doc, composed);
+
+      expect(result).toBe(apply(apply(doc, op1), op2));
+      expect(result).toBe('aXbcd');
+    });
+
+    it('composes insert then delete', () => {
+      const doc = 'ab';
+      const op1: Operation = [{ insert: 'X' }, { retain: 2 }]; // "Xab"
+      const op2: Operation = [{ retain: 1 }, { delete: 1 }, { retain: 1 }]; // "Xb"
+
+      const composed = compose(op1, op2);
+      const result = apply(doc, composed);
+
+      expect(result).toBe(apply(apply(doc, op1), op2));
+      expect(result).toBe('Xb');
+    });
+  });
+
+  describe('validate', () => {
+    it('returns null for valid operation', () => {
+      expect(validate([{ retain: 5 }, { insert: 'x' }], 5)).toBeNull();
+    });
+
+    it('rejects non-array', () => {
+      expect(validate('not an array' as unknown as Operation, 0)).toBe('Operation must be an array');
+    });
+
+    it('rejects length mismatch', () => {
+      expect(validate([{ retain: 3 }], 5)).toContain('does not match');
+    });
+
+    it('rejects unknown component type', () => {
+      expect(validate([{ foo: 1 } as unknown as Operation[0]], 0)).toContain('Unknown component type');
+    });
+
+    it('rejects negative retain', () => {
+      expect(validate([{ retain: -1 }], 0)).toContain('positive number');
+    });
+
+    it('rejects empty insert string', () => {
+      expect(validate([{ insert: '' }], 0)).toContain('non-empty string');
+    });
+  });
+
+  describe('inputLength / outputLength', () => {
+    it('computes input length', () => {
+      const op: Operation = [{ retain: 3 }, { insert: 'ab' }, { delete: 2 }];
+      expect(inputLength(op)).toBe(5);
+    });
+
+    it('computes output length', () => {
+      const op: Operation = [{ retain: 3 }, { insert: 'ab' }, { delete: 2 }];
+      expect(outputLength(op)).toBe(5);
+    });
+  });
+});
