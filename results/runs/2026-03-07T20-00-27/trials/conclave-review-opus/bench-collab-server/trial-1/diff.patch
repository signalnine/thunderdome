@@ -0,0 +1,378 @@
+/**
+ * Operational Transformation engine.
+ *
+ * Operations are arrays of components. Each component is one of:
+ *   - { retain: n }    — keep n characters unchanged
+ *   - { insert: str }  — insert str at the current position
+ *   - { delete: n }    — delete n characters at the current position
+ *
+ * An operation's "input length" is the sum of retain + delete lengths.
+ * An operation's "output length" is the sum of retain + insert lengths.
+ * An operation must span the entire document (input length === doc length).
+ */
+
+export interface RetainOp {
+  retain: number;
+}
+
+export interface InsertOp {
+  insert: string;
+}
+
+export interface DeleteOp {
+  delete: number;
+}
+
+export type OpComponent = RetainOp | InsertOp | DeleteOp;
+
+export type Operation = OpComponent[];
+
+function isRetain(c: OpComponent): c is RetainOp {
+  return 'retain' in c;
+}
+
+function isInsert(c: OpComponent): c is InsertOp {
+  return 'insert' in c;
+}
+
+function isDelete(c: OpComponent): c is DeleteOp {
+  return 'delete' in c;
+}
+
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (isRetain(c)) len += c.retain;
+    else if (isDelete(c)) len += c.delete;
+  }
+  return len;
+}
+
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (isRetain(c)) len += c.retain;
+    else if (isInsert(c)) len += c.insert.length;
+  }
+  return len;
+}
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, op: Operation): string {
+  const inLen = inputLength(op);
+  if (inLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${inLen}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (isRetain(c)) {
+      result += doc.slice(pos, pos + c.retain);
+      pos += c.retain;
+    } else if (isInsert(c)) {
+      result += c.insert;
+    } else if (isDelete(c)) {
+      pos += c.delete;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ *
+ * Given operations A and B that were both created against the same document,
+ * returns [A', B'] such that:
+ *   apply(apply(doc, A), B') === apply(apply(doc, B), A')
+ *
+ * Convention: A has priority (its inserts go first at the same position).
+ */
+export function transform(
+  opA: Operation,
+  opB: Operation
+): [Operation, Operation] {
+  const inLenA = inputLength(opA);
+  const inLenB = inputLength(opB);
+  if (inLenA !== inLenB) {
+    throw new Error(
+      `Transform: operations have different input lengths (${inLenA} vs ${inLenB})`
+    );
+  }
+
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  let ia = 0;
+  let ib = 0;
+
+  // Mutable copies of current components being consumed
+  let ca: OpComponent | null = ia < opA.length ? { ...opA[ia] } : null;
+  let cb: OpComponent | null = ib < opB.length ? { ...opB[ib] } : null;
+
+  function nextA() {
+    ia++;
+    ca = ia < opA.length ? { ...opA[ia] } : null;
+  }
+
+  function nextB() {
+    ib++;
+    cb = ib < opB.length ? { ...opB[ib] } : null;
+  }
+
+  function pushA(c: OpComponent) {
+    // Merge with previous if compatible
+    if (aPrime.length > 0) {
+      const last = aPrime[aPrime.length - 1];
+      if (isRetain(c) && isRetain(last)) {
+        last.retain += c.retain;
+        return;
+      }
+      if (isInsert(c) && isInsert(last)) {
+        last.insert += c.insert;
+        return;
+      }
+      if (isDelete(c) && isDelete(last)) {
+        last.delete += c.delete;
+        return;
+      }
+    }
+    aPrime.push(c);
+  }
+
+  function pushB(c: OpComponent) {
+    if (bPrime.length > 0) {
+      const last = bPrime[bPrime.length - 1];
+      if (isRetain(c) && isRetain(last)) {
+        last.retain += c.retain;
+        return;
+      }
+      if (isInsert(c) && isInsert(last)) {
+        last.insert += c.insert;
+        return;
+      }
+      if (isDelete(c) && isDelete(last)) {
+        last.delete += c.delete;
+        return;
+      }
+    }
+    bPrime.push(c);
+  }
+
+  while (ca !== null || cb !== null) {
+    // Insert in A: A' keeps the insert, B' retains over it
+    if (ca !== null && isInsert(ca)) {
+      pushA({ insert: ca.insert });
+      pushB({ retain: ca.insert.length });
+      nextA();
+      continue;
+    }
+
+    // Insert in B: B' keeps the insert, A' retains over it
+    if (cb !== null && isInsert(cb)) {
+      pushB({ insert: cb.insert });
+      pushA({ retain: cb.insert.length });
+      nextB();
+      continue;
+    }
+
+    if (ca === null || cb === null) {
+      throw new Error('Transform: operations do not span the same document');
+    }
+
+    // Both retain
+    if (isRetain(ca) && isRetain(cb)) {
+      const min = Math.min(ca.retain, cb.retain);
+      pushA({ retain: min });
+      pushB({ retain: min });
+      ca.retain -= min;
+      cb.retain -= min;
+      if (ca.retain === 0) nextA();
+      if (cb.retain === 0) nextB();
+    }
+    // A deletes, B retains
+    else if (isDelete(ca) && isRetain(cb)) {
+      const min = Math.min(ca.delete, cb.retain);
+      pushA({ delete: min });
+      // B' skips over deleted text (nothing added)
+      ca.delete -= min;
+      cb.retain -= min;
+      if (ca.delete === 0) nextA();
+      if (cb.retain === 0) nextB();
+    }
+    // A retains, B deletes
+    else if (isRetain(ca) && isDelete(cb)) {
+      const min = Math.min(ca.retain, cb.delete);
+      pushB({ delete: min });
+      // A' skips over deleted text (nothing added)
+      ca.retain -= min;
+      cb.delete -= min;
+      if (ca.retain === 0) nextA();
+      if (cb.delete === 0) nextB();
+    }
+    // Both delete same region
+    else if (isDelete(ca) && isDelete(cb)) {
+      const min = Math.min(ca.delete, cb.delete);
+      ca.delete -= min;
+      cb.delete -= min;
+      if (ca.delete === 0) nextA();
+      if (cb.delete === 0) nextB();
+    }
+  }
+
+  return [aPrime, bPrime];
+}
+
+/**
+ * Compose two sequential operations into one.
+ * compose(A, B) produces C such that apply(doc, C) === apply(apply(doc, A), B)
+ */
+export function compose(opA: Operation, opB: Operation): Operation {
+  const outA = outputLength(opA);
+  const inB = inputLength(opB);
+  if (outA !== inB) {
+    throw new Error(
+      `Compose: output length of A (${outA}) !== input length of B (${inB})`
+    );
+  }
+
+  const result: Operation = [];
+  let ia = 0;
+  let ib = 0;
+  let ca: OpComponent | null = ia < opA.length ? { ...opA[ia] } : null;
+  let cb: OpComponent | null = ib < opB.length ? { ...opB[ib] } : null;
+
+  function nextA() {
+    ia++;
+    ca = ia < opA.length ? { ...opA[ia] } : null;
+  }
+
+  function nextB() {
+    ib++;
+    cb = ib < opB.length ? { ...opB[ib] } : null;
+  }
+
+  function push(c: OpComponent) {
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (isRetain(c) && isRetain(last)) {
+        last.retain += c.retain;
+        return;
+      }
+      if (isInsert(c) && isInsert(last)) {
+        last.insert += c.insert;
+        return;
+      }
+      if (isDelete(c) && isDelete(last)) {
+        last.delete += c.delete;
+        return;
+      }
+    }
+    result.push(c);
+  }
+
+  while (ca !== null || cb !== null) {
+    // Delete in A: pass through
+    if (ca !== null && isDelete(ca)) {
+      push({ delete: ca.delete });
+      nextA();
+      continue;
+    }
+
+    // Insert in B: pass through
+    if (cb !== null && isInsert(cb)) {
+      push({ insert: cb.insert });
+      nextB();
+      continue;
+    }
+
+    if (ca === null || cb === null) {
+      throw new Error('Compose: operations do not match');
+    }
+
+    // Both retain
+    if (isRetain(ca) && isRetain(cb)) {
+      const min = Math.min(ca.retain, cb.retain);
+      push({ retain: min });
+      ca.retain -= min;
+      cb.retain -= min;
+      if (ca.retain === 0) nextA();
+      if (cb.retain === 0) nextB();
+    }
+    // A inserts, B retains → insert
+    else if (isInsert(ca) && isRetain(cb)) {
+      const min = Math.min(ca.insert.length, cb.retain);
+      push({ insert: ca.insert.slice(0, min) });
+      ca = { insert: ca.insert.slice(min) };
+      if (ca.insert.length === 0) nextA();
+      cb.retain -= min;
+      if (cb.retain === 0) nextB();
+    }
+    // A inserts, B deletes → cancel out
+    else if (isInsert(ca) && isDelete(cb)) {
+      const min = Math.min(ca.insert.length, cb.delete);
+      ca = { insert: ca.insert.slice(min) };
+      if (ca.insert.length === 0) nextA();
+      cb.delete -= min;
+      if (cb.delete === 0) nextB();
+    }
+    // A retains, B deletes
+    else if (isRetain(ca) && isDelete(cb)) {
+      const min = Math.min(ca.retain, cb.delete);
+      push({ delete: min });
+      ca.retain -= min;
+      cb.delete -= min;
+      if (ca.retain === 0) nextA();
+      if (cb.delete === 0) nextB();
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Validate an operation against a document length.
+ * Returns null if valid, or an error message string if invalid.
+ */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) {
+    return 'Operation must be an array';
+  }
+
+  for (const c of op) {
+    if (typeof c !== 'object' || c === null) {
+      return 'Each component must be an object';
+    }
+    const keys = Object.keys(c);
+    if (keys.length !== 1) {
+      return 'Each component must have exactly one key (retain, insert, or delete)';
+    }
+    const key = keys[0];
+    if (key === 'retain') {
+      if (typeof (c as RetainOp).retain !== 'number' || (c as RetainOp).retain <= 0) {
+        return 'Retain must be a positive number';
+      }
+    } else if (key === 'insert') {
+      if (typeof (c as InsertOp).insert !== 'string' || (c as InsertOp).insert.length === 0) {
+        return 'Insert must be a non-empty string';
+      }
+    } else if (key === 'delete') {
+      if (typeof (c as DeleteOp).delete !== 'number' || (c as DeleteOp).delete <= 0) {
+        return 'Delete must be a positive number';
+      }
+    } else {
+      return `Unknown component type: ${key}`;
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
