@@ -0,0 +1,79 @@
+import { Router, json } from 'express';
+import { DocumentRepo } from './db.js';
+import { WsManager } from './ws.js';
+
+export function createRouter(repo: DocumentRepo, wsManager: WsManager): Router {
+  const router = Router();
+  router.use(json());
+
+  // List documents
+  router.get('/documents', (_req, res) => {
+    const docs = repo.list();
+    res.json(docs);
+  });
+
+  // Create document
+  router.post('/documents', (req, res) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Title is required and must be a string' });
+      return;
+    }
+    const doc = repo.create(title, content ?? '');
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/documents/:id', (req, res) => {
+    const doc = repo.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/documents/:id', (req, res) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Title is required and must be a string' });
+      return;
+    }
+    if (content !== undefined && typeof content !== 'string') {
+      res.status(400).json({ error: 'Content must be a string' });
+      return;
+    }
+    const doc = repo.update(req.params.id, title, content ?? '');
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    wsManager.invalidateDocument(req.params.id);
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/documents/:id', (req, res) => {
+    const deleted = repo.delete(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    wsManager.invalidateDocument(req.params.id);
+    res.status(204).send();
+  });
+
+  // Get document version history
+  router.get('/documents/:id/versions', (req, res) => {
+    const doc = repo.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = repo.getVersions(req.params.id);
+    res.json(versions);
+  });
+
+  return router;
+}
