@@ -1,6 +1,6 @@
 import { Router, Request, Response, NextFunction } from 'express';
 import Database from 'better-sqlite3';
-import { Note, NoteInput } from './models.js';
+import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';
 import { NotFoundError, ValidationError } from './errors.js';
 
 export function createRoutes(db: Database.Database): Router {
@@ -118,5 +118,79 @@ export function createRoutes(db: Database.Database): Router {
     }
   });
 
+  // GET /notes/search - Full-text search across notes
+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const q = req.query.q as string | undefined;
+      const page = parseInt(req.query.page as string) || 1;
+      const perPage = 20;
+
+      if (!q || q.trim() === '') {
+        throw new ValidationError('Search query is required');
+      }
+
+      const offset = (page - 1) * perPage;
+
+      // First, get the total count of matching rows
+      const countStmt = db.prepare(`
+        SELECT COUNT(*) as total
+        FROM notes_fts
+        WHERE notes_fts MATCH ?
+      `);
+      const countResult = countStmt.get(q.trim());
+      const total = countResult.total as number;
+
+      // Then, get the paginated results with snippet and rank
+      const searchStmt = db.prepare(`
+        SELECT 
+          notes.id,
+          notes.title,
+          snippet(notes_fts, 2, '<mark>', '</mark>', '...', 15) as snippet,
+          bm25(notes_fts) as rank
+        FROM notes_fts
+        JOIN notes ON notes.id = notes_fts.rowid
+        WHERE notes_fts MATCH ?
+        ORDER BY rank
+        LIMIT ? OFFSET ?
+      `);
+      const searchResults = searchStmt.all(q.trim(), perPage, offset) as SearchResult[];
+
+      res.json({
+        results: searchResults,
+        total,
+        page,
+        perPage
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /notes/search/suggest - Autocomplete for note titles
+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const q = req.query.q as string | undefined;
+
+      if (!q || q.trim() === '') {
+        throw new ValidationError('Search query is required');
+      }
+
+      const suggestStmt = db.prepare(`
+        SELECT 
+          notes.id,
+          notes.title
+        FROM notes_fts
+        JOIN notes ON notes.id = notes_fts.rowid
+        WHERE notes_fts MATCH ?
+        LIMIT 5
+      `);
+      const suggestResults = suggestStmt.all(q.trim() + '*') as SuggestResult[];
+
+      res.json({ results: suggestResults });
+    } catch (err) {
+      next(err);
+    }
+  });
+
   return router;
 }
