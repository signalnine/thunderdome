+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import { marked } from 'marked';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Process admonition containers first (before markdown parsing)
+        // :::note, :::warning, :::tip
+        content = content.replace(
+          /:::([a-z]+)\n([\s\S]*?):::/g,
+          (_match, type: string, inner: string) => {
+            return `<div class="admonition admonition-${type}">\n${inner.trim()}\n</div>`;
+          }
+        );
+
+        // Process footnotes
+        const footnotes = new Map<string, string>();
+        const footnoteDefRegex = /\[\^([\w-]+)\]:\s*(.+)$/gm;
+        let match;
+        while ((match = footnoteDefRegex.exec(content)) !== null) {
+          footnotes.set(match[1], match[2]);
+        }
+        // Remove footnote definitions from content
+        content = content.replace(footnoteDefRegex, '');
+
+        // Replace footnote references with links
+        content = content.replace(
+          /\[\^([\w-]+)\]/g,
+          (_match, id: string) => {
+            return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+          }
+        );
+
+        // Convert markdown to HTML using marked
+        let htmlContent: string;
+        if (content.trim().startsWith('<')) {
+          // Content already looks like HTML, preserve it
+          htmlContent = content;
+        } else {
+          htmlContent = marked.parse(content) as string;
+        }
+
+        // Add footnotes section if there are footnotes
+        if (footnotes.size > 0) {
+          const footnoteList: string[] = [];
+          footnotes.forEach((text, id) => {
+            footnoteList.push(`<li id="fn-${id}">${text}</li>`);
+          });
+          htmlContent += `\n<section class="footnotes">\n<ol>\n${footnoteList.join('\n')}\n</ol>\n</section>`;
+        }
+
+        return {
+          ...file,
+          content: htmlContent,
+        };
+      },
+    },
+  };
+}
