+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const baseUrl = ctx.config.baseUrl;
+        const siteTitle = ctx.config.title;
+
+        // Get tag map for categories (dependency ensures taxonomy runs first)
+        const _tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Sort files by date (newest first), files without dates go last
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          if (a.date && b.date) {
+            return new Date(b.date).getTime() - new Date(a.date).getTime();
+          }
+          if (a.date) return -1;
+          if (b.date) return 1;
+          return 0;
+        });
+
+        // Generate RSS items
+        const items: string[] = [];
+        for (const file of sortedFiles) {
+          const link = `${baseUrl}/${file.slug}.html`;
+          const date = file.date ? new Date(file.date) : new Date();
+          const pubDate = file.date ? `<pubDate>${date.toUTCString()}</pubDate>` : '';
+
+          // Build categories from tags
+          let categories = '';
+          if (file.tags && file.tags.length > 0) {
+            categories = file.tags.map(tag => `<category>${tag}</category>`).join('\n      ');
+          }
+
+          // Get content - wrap in CDATA
+          const content = `<![CDATA[${file.content}]]>`;
+
+          const item = `    <item>
+      <title>${escapeXml(file.title)}</title>
+      <link>${link}</link>
+      <guid>${link}</guid>
+      ${pubDate}
+      <description>${content}</description>
+      ${categories}
+    </item>`;
+          items.push(item);
+        }
+
+        // Generate RSS feed
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(siteTitle)}</title>
+    <link>${baseUrl}</link>
+    <description>RSS feed for ${escapeXml(siteTitle)}</description>
+    <lastBuildDate>${new Date().toUTCString()}</lastBuildDate>
+${items.join('\n')}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
diff --git a/src/plugins/search-index.ts b/src/plugins/search-index.ts
