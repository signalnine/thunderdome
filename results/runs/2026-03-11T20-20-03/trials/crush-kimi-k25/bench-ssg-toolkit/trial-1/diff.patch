+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const baseUrl = ctx.config.baseUrl;
+        const urls: string[] = [];
+
+        // Add all content pages from output
+        for (const [path, _content] of ctx.output.entries()) {
+          // Skip non-HTML files and special files
+          if (path.endsWith('.html')) {
+            const fullUrl = `${baseUrl}/${path}`;
+            urls.push(`    <url>\n      <loc>${escapeXml(fullUrl)}</loc>\n    </url>`);
+          }
+        }
+
+        // Add tag pages from taxonomy data
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (tagMap) {
+          for (const tag of tagMap.keys()) {
+            const tagUrl = `${baseUrl}/tags/${tag}.html`;
+            // Only add if not already in output
+            const tagPath = `tags/${tag}.html`;
+            if (!ctx.output.has(tagPath)) {
+              urls.push(`    <url>\n      <loc>${escapeXml(tagUrl)}</loc>\n    </url>`);
+            }
+          }
+        }
+
+        // Add feed.xml if it exists
+        if (ctx.output.has('feed.xml')) {
+          const feedUrl = `${baseUrl}/feed.xml`;
+          urls.push(`    <url>\n      <loc>${escapeXml(feedUrl)}</loc>\n    </url>`);
+        }
+
+        // Generate sitemap XML
+        const sitemap = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+${urls.join('\n')}
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemap);
+      },
+    },
+  };
+}
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
