--- /dev/null
+++ b/src/plugins/search-index.ts
@@ -0,0 +1,61 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+interface SearchIndexEntry {
+  slug: string;
+  title: string;
+  content: string;
+  tags?: string[];
+}
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: async (ctx: BuildContext): Promise<void> => {
+        const index: SearchIndexEntry[] = [];
+
+        for (const file of ctx.files) {
+          // Strip HTML tags from content to get plain text
+          const plainContent = stripHtml(file.content);
+
+          const entry: SearchIndexEntry = {
+            slug: file.slug,
+            title: file.title,
+            content: plainContent,
+          };
+
+          if (file.tags && file.tags.length > 0) {
+            entry.tags = [...file.tags];
+          }
+
+          index.push(entry);
+        }
+
+        // Output as JSON
+        ctx.output.set('search-index.json', JSON.stringify(index, null, 2));
+      },
+    },
+  };
+}
+
+function stripHtml(html: string): string {
+  // Replace common HTML tags with spaces to preserve word boundaries
+  let text = html
+    .replace(/<pre[^>]*><code[^>]*>([\s\S]*?)<\/code><\/pre>/g, '$1') // Keep code content
+    .replace(/<[^>]+>/g, ' ') // Replace other tags with space
+    .replace(/\s+/g, ' ') // Normalize whitespace
+    .trim();
+
+  // Decode common HTML entities
+  text = text
+    .replace(/&amp;/g, '&')
+    .replace(/&lt;/g, '<')
+    .replace(/&gt;/g, '>')
+    .replace(/&quot;/g, '"')
+    .replace(/&apos;/g, "'")
+    .replace(/&#(\d+);/g, (_match, code) => String.fromCharCode(code));
+
+  return text;
+}
