+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: async (ctx: BuildContext): Promise<void> => {
+        // Initialize asset manifest
+        ctx.data.set('asset-manifest', { assets: [] as string[] });
+      },
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assets = manifest?.assets || [];
+
+        // Find and rewrite relative URLs in img src and link href
+        // Match src="./filename" or href="./filename"
+        content = content.replace(
+          /(src|href)="\.\/([^"]+)"/g,
+          (match, attr: string, path: string) => {
+            // Skip if already an absolute path or already /assets/
+            if (path.startsWith('/')) {
+              return match;
+            }
+            // Add to manifest if not already there
+            if (!assets.includes(path)) {
+              assets.push(path);
+            }
+            return `${attr}="/assets/${path}"`;
+          }
+        );
+
+        // Update manifest
+        ctx.data.set('asset-manifest', { assets });
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
