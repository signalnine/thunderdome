+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from '../src/index.js';
+
+describe('simulate', () => {
+  it('should handle a simple AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 1, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result).toEqual({ a: 1, b: 1, c: 1 });
+  });
+
+  it('should handle AND with one zero', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 1, b: 0 };
+    const result = simulate(gates, inputs);
+    expect(result).toEqual({ a: 1, b: 0, c: 0 });
+  });
+
+  it('should handle OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 0, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result).toEqual({ a: 0, b: 1, c: 1 });
+  });
+
+  it('should handle XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 1, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result).toEqual({ a: 1, b: 1, c: 0 });
+  });
+
+  it('should handle dependency chains', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    const inputs = { a: 1, b: 1, d: 0 };
+    const result = simulate(gates, inputs);
+    expect(result).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });
+  });
+
+  it('should handle gates in any order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const inputs = { a: 1, b: 1, d: 0 };
+    const result = simulate(gates, inputs);
+    expect(result).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });
+  });
+
+  it('should simulate a 2-bit adder', () => {
+    // x=01 (1), y=01 (1), expected z=10 (2)
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+    // x=01, y=01 => 1+1=2 => z=010
+    const inputs = { x00: 1, x01: 0, y00: 1, y01: 0 };
+    const result = simulate(gates, inputs);
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(0);
+  });
+
+  it('should simulate a 2-bit adder with carry', () => {
+    // x=11 (3), y=11 (3), expected z=110 (6)
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+    const inputs = { x00: 1, x01: 1, y00: 1, y01: 1 };
+    const result = simulate(gates, inputs);
+    expect(result.z00).toBe(0); // 3+3=6 => 110
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(1);
+  });
+});
+
+describe('findSwappedWires', () => {
+  it('should find swapped wires in a simple 4-bit adder', () => {
+    // Build a correct 4-bit adder, then swap 4 pairs of outputs
+    const correctGates: Gate[] = [
+      // Bit 0 - half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1 - full adder
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      // Bit 2 - full adder
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      // Bit 3 - full adder
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },
+      // Bit 4 - full adder
+      { op: 'XOR', in1: 'x04', in2: 'y04', out: 't04' },
+      { op: 'XOR', in1: 't04', in2: 'c03', out: 'z04' },
+      { op: 'AND', in1: 'x04', in2: 'y04', out: 'a04' },
+      { op: 'AND', in1: 't04', in2: 'c03', out: 'b04' },
+      { op: 'OR', in1: 'a04', in2: 'b04', out: 'c04' },
+      // Bit 5 - full adder
+      { op: 'XOR', in1: 'x05', in2: 'y05', out: 't05' },
+      { op: 'XOR', in1: 't05', in2: 'c04', out: 'z05' },
+      { op: 'AND', in1: 'x05', in2: 'y05', out: 'a05' },
+      { op: 'AND', in1: 't05', in2: 'c04', out: 'b05' },
+      { op: 'OR', in1: 'a05', in2: 'b05', out: 'c05' },
+      // Bit 6 - full adder
+      { op: 'XOR', in1: 'x06', in2: 'y06', out: 't06' },
+      { op: 'XOR', in1: 't06', in2: 'c05', out: 'z06' },
+      { op: 'AND', in1: 'x06', in2: 'y06', out: 'a06' },
+      { op: 'AND', in1: 't06', in2: 'c05', out: 'b06' },
+      { op: 'OR', in1: 'a06', in2: 'b06', out: 'c06' },
+      // Bit 7 - full adder
+      { op: 'XOR', in1: 'x07', in2: 'y07', out: 't07' },
+      { op: 'XOR', in1: 't07', in2: 'c06', out: 'z07' },
+      { op: 'AND', in1: 'x07', in2: 'y07', out: 'a07' },
+      { op: 'AND', in1: 't07', in2: 'c06', out: 'b07' },
+      { op: 'OR', in1: 'a07', in2: 'b07', out: 'z08' }, // last carry = z08
+    ];
+
+    // Now swap 4 pairs:
+    // Swap 1: z01 <-> a01
+    // Swap 2: t02 <-> z02
+    // Swap 3: b03 <-> c03
+    // Swap 4: z06 <-> a06
+    const swappedGates = correctGates.map((g) => {
+      const swapMap: Record<string, string> = {
+        z01: 'a01',
+        a01: 'z01',
+        t02: 'z02',
+        z02: 't02',
+        b03: 'c03',
+        c03: 'b03',
+        z06: 'a06',
+        a06: 'z06',
+      };
+      return { ...g, out: swapMap[g.out] ?? g.out };
+    });
+
+    const result = findSwappedWires(swappedGates);
+    expect(result).toEqual([
+      'a01', 'a06', 'b03', 'c03', 't02', 'z01', 'z02', 'z06',
+    ]);
+  });
+
+  it('should find swapped wires with different swap patterns', () => {
+    // 10-bit adder with different swaps
+    function makeAdder(bits: number): Gate[] {
+      const gates: Gate[] = [];
+      const pad = (n: number) => String(n).padStart(2, '0');
+      // Bit 0 - half adder
+      gates.push({ op: 'XOR', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `z${pad(0)}` });
+      gates.push({ op: 'AND', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `c${pad(0)}` });
+      for (let i = 1; i < bits; i++) {
+        const xi = `x${pad(i)}`, yi = `y${pad(i)}`;
+        const ti = `t${pad(i)}`, zi = `z${pad(i)}`;
+        const ai = `a${pad(i)}`, bi = `b${pad(i)}`, ci = `c${pad(i)}`;
