+    // Swap 4: z09 <-> a09 (z-wire with AND output)
+    const swapMap: Record<string, string> = {
+      z03: 'b05', b05: 'z03',
+      t07: 'z07', z07: 't07',
+      a02: 'c02', c02: 'a02',
+      z09: 'a09', a09: 'z09',
