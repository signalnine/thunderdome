+      gates.push({ op: 'AND', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `c${pad(0)}` });
+      for (let i = 1; i < bits; i++) {
+        const xi = `x${pad(i)}`, yi = `y${pad(i)}`;
+        const ti = `t${pad(i)}`, zi = `z${pad(i)}`;
+        const ai = `a${pad(i)}`, bi = `b${pad(i)}`, ci = `c${pad(i)}`;
