+    const result = findSwappedWires(swappedGates);
+    expect(result).toEqual([
+      'a02', 'a09', 'b05', 'c02', 't07', 'z03', 'z07', 'z09',
+    ]);
+  });
+
+  it('should handle a 45-bit adder within 5 seconds', () => {
+    function makeAdder(bits: number): Gate[] {
