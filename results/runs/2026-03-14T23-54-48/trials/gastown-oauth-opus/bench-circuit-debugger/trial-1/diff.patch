+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set<number>(gates.map((_, i) => i));
+
+  let progress = true;
+  while (remaining.size > 0 && progress) {
+    progress = false;
+    for (const idx of remaining) {
+      const gate = gates[idx];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 === undefined || v2 === undefined) continue;
+
+      let result: number;
+      switch (gate.op) {
+        case 'AND':
+          result = v1 & v2;
+          break;
+        case 'OR':
+          result = v1 | v2;
+          break;
+        case 'XOR':
+          result = v1 ^ v2;
+          break;
+      }
+
+      wires[gate.out] = result;
+      remaining.delete(idx);
+      progress = true;
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped: Set<string> = new Set();
+
+  // Find the highest z-wire number to determine the bit width
+  let maxZ = 0;
+  for (const gate of gates) {
+    if (gate.out.startsWith('z')) {
+      const num = parseInt(gate.out.slice(1), 10);
+      if (num > maxZ) maxZ = num;
+    }
+  }
+
+  // The last z-wire (maxZ) is the final carry bit - it comes from an OR gate (or the carry of the last full adder)
+  const lastZ = `z${String(maxZ).padStart(2, '0')}`;
+
+  // Helper: check if both inputs of a gate are x_i/y_i for same bit
+  function isXYPair(gate: Gate): boolean {
+    const ins = [gate.in1, gate.in2].sort();
+    return (
+      (ins[0].startsWith('x') && ins[1].startsWith('y')) &&
+      ins[0].slice(1) === ins[1].slice(1)
+    );
+  }
+
+  // Helper: find gates that use a given wire as input
+  function findConsumers(wire: string): Gate[] {
+    return gates.filter((g) => g.in1 === wire || g.in2 === wire);
+  }
+
+  // Structural rules checking - iterate through all gates and check invariants
+  for (const gate of gates) {
+    const out = gate.out;
+
+    // Rule 1: z-wires (except the last one) must be outputs of XOR gates
+    if (out.startsWith('z') && out !== lastZ) {
+      if (gate.op !== 'XOR') {
+        swapped.add(out);
+      }
+    }
+
+    // Rule 2: XOR gates whose inputs are both x_i/y_i must NOT output to z (except z00)
+    if (gate.op === 'XOR' && isXYPair(gate)) {
+      if (out.startsWith('z') && out !== 'z00') {
+        swapped.add(out);
+      }
+    }
+
+    // Rule 3: XOR gates whose inputs are NOT both x/y must output to a z-wire
+    if (gate.op === 'XOR' && !isXYPair(gate)) {
+      if (!out.startsWith('z')) {
+        swapped.add(out);
+      }
+    }
+
+    // Rule 4: AND gates must NOT output to z-wires (except potentially the final bit)
+    if (gate.op === 'AND' && out.startsWith('z') && out !== lastZ) {
+      swapped.add(out);
+    }
+
+    // Rule 5: OR gates must NOT output to z-wires (except the final z bit)
+    if (gate.op === 'OR' && out.startsWith('z') && out !== lastZ) {
+      swapped.add(out);
+    }
+
+    // Rule 6: AND gates (except x00 AND y00) must feed into an OR gate
+    if (gate.op === 'AND') {
+      // Check if this is the x00 AND y00 gate
+      const ins = [gate.in1, gate.in2].sort();
+      const isBit0And = ins[0] === 'x00' && ins[1] === 'y00';
+      if (!isBit0And && !out.startsWith('z')) {
+        const consumers = findConsumers(out);
+        const feedsOR = consumers.some((c) => c.op === 'OR');
+        if (!feedsOR && out !== lastZ) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    // Rule 7: XOR of x_i/y_i (for i > 0) must feed into another XOR and another AND
+    if (gate.op === 'XOR' && isXYPair(gate) && !out.startsWith('z')) {
+      const consumers = findConsumers(out);
+      const feedsXOR = consumers.some((c) => c.op === 'XOR');
+      const feedsAND = consumers.some((c) => c.op === 'AND');
+      if (!feedsXOR || !feedsAND) {
+        if (!swapped.has(out)) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    // Rule 8: OR gate outputs (carry wires) must feed into XOR and AND gates (except last z)
+    if (gate.op === 'OR' && !out.startsWith('z')) {
+      const consumers = findConsumers(out);
+      const feedsXOR = consumers.some((c) => c.op === 'XOR');
+      const feedsAND = consumers.some((c) => c.op === 'AND');
+      if (!feedsXOR || !feedsAND) {
+        swapped.add(out);
+      }
+    }
+  }
+
+  return Array.from(swapped).sort();
+}
