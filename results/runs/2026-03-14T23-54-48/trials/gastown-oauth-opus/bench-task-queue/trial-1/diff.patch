+      const failed = queue.failTask(next.id, new Error('oops'));
+      expect(failed.status).toBe('pending');
+      expect(failed.attempt).toBe(1);
+    });
+
+    it('should move to failed after max retries', () => {
+      const task = queue.addTask('fail-me', { maxRetries: 1, backoffDelay: 0 });
+      let next = queue.getNextTask()!;
+      queue.failTask(next.id, new Error('fail 1'));
+
+      // After delay passes, get and fail again
+      next = queue.getNextTask()!;
+      const failed = queue.failTask(next.id, new Error('fail 2'));
+      expect(failed.status).toBe('failed');
+    });
+
+    it('should complete a task', () => {
+      queue.addTask('complete-me');
+      const next = queue.getNextTask()!;
+      const completed = queue.completeTask(next.id);
+      expect(completed.status).toBe('completed');
+    });
+  });
+
+  // Phase 6: Dead Letter Queue
+  describe('Phase 6: Dead Letter Queue', () => {
+    it('should move permanently failed tasks to DLQ', () => {
+      queue.addTask('dlq-me', { maxRetries: 1, backoffDelay: 0 });
+      let next = queue.getNextTask()!;
+      queue.failTask(next.id, new Error('fail 1'));
+      next = queue.getNextTask()!;
+      queue.failTask(next.id, new Error('fail 2'));
+
+      const dlq = queue.getDeadLetterQueue();
+      expect(dlq.length).toBe(1);
+      expect(dlq[0].payload).toBe('dlq-me');
+    });
+
+    it('should requeue from DLQ', () => {
+      queue.addTask('dlq-requeue', { maxRetries: 1, backoffDelay: 0 });
+      let next = queue.getNextTask()!;
+      queue.failTask(next.id, new Error('fail 1'));
+      next = queue.getNextTask()!;
+      queue.failTask(next.id, new Error('fail 2'));
+
+      const dlq = queue.getDeadLetterQueue();
+      const requeued = queue.requeueDeadLetter(dlq[0].id);
+      expect(requeued.status).toBe('pending');
+      expect(requeued.attempt).toBe(0);
+    });
+
+    it('should clear DLQ', () => {
+      queue.addTask('dlq-clear', { maxRetries: 1, backoffDelay: 0 });
+      let next = queue.getNextTask()!;
+      queue.failTask(next.id, new Error('fail 1'));
+      next = queue.getNextTask()!;
+      queue.failTask(next.id, new Error('fail 2'));
+
+      queue.clearDeadLetterQueue();
+      expect(queue.getDeadLetterQueue().length).toBe(0);
+    });
+  });
+
+  // Phase 7: Task Dependencies
+  describe('Phase 7: Task Dependencies', () => {
+    it('should block tasks with unresolved dependencies', () => {
+      const dep = queue.addTask('dependency');
+      queue.addTask('dependent', { dependsOn: [dep.id] });
+
+      // Should only get the dependency task
+      const next = queue.getNextTask()!;
+      expect(next.id).toBe(dep.id);
+      // Dependent should not be returned
+      expect(queue.getNextTask()).toBeNull();
+    });
+
+    it('should unblock when dependencies complete', () => {
+      const dep = queue.addTask('dependency');
+      const dependent = queue.addTask('dependent', { dependsOn: [dep.id] });
+
+      const next = queue.getNextTask()!;
+      queue.completeTask(next.id);
+
+      const unblocked = queue.getNextTask();
+      expect(unblocked).not.toBeNull();
+      expect(unblocked!.id).toBe(dependent.id);
+    });
+
+    it('should reject non-existent dependency', () => {
+      expect(() => queue.addTask('x', { dependsOn: ['nonexistent'] })).toThrow();
+    });
+
+    it('should get dependency status', () => {
+      const dep = queue.addTask('dep');
+      const task = queue.addTask('task', { dependsOn: [dep.id] });
+      const status = queue.getDependencyStatus(task.id);
+      expect(status.dependsOn).toContain(dep.id);
+      expect(status.pending).toContain(dep.id);
+      expect(status.resolved.length).toBe(0);
+    });
+  });
+
+  // Phase 8: Concurrency Control
+  describe('Phase 8: Concurrency Control', () => {
+    it('should respect concurrency limits', () => {
+      queue.setConcurrency('default', 1);
+      queue.addTask('a');
+      queue.addTask('b');
+
+      expect(queue.getNextTask()).not.toBeNull();
+      expect(queue.getNextTask()).toBeNull(); // limited
+    });
+
+    it('should free concurrency slots on completion', () => {
+      queue.setConcurrency('default', 1);
+      queue.addTask('a');
+      queue.addTask('b');
+
+      const task = queue.getNextTask()!;
+      queue.completeTask(task.id);
+
+      expect(queue.getNextTask()).not.toBeNull();
+    });
+
+    it('should report concurrency info', () => {
+      queue.setConcurrency('default', 5);
+      const info = queue.getConcurrency('default');
+      expect(info.limit).toBe(5);
+      expect(info.active).toBe(0);
+    });
+  });
+
+  // Phase 9: Progress and Cancellation
+  describe('Phase 9: Progress and Cancellation', () => {
+    it('should report and query progress', () => {
+      queue.addTask('progress-task');
+      const task = queue.getNextTask()!;
+      queue.reportProgress(task.id, 50, 'halfway');
+      const updated = queue.getTask(task.id)!;
+      expect(updated.progress).toBe(50);
+      expect(updated.progressMessage).toBe('halfway');
+    });
+
+    it('should subscribe to progress updates', () => {
+      queue.addTask('progress-sub');
+      const task = queue.getNextTask()!;
+      let received = 0;
+      const subId = queue.onProgress(task.id, (p) => { received = p; });
+      queue.reportProgress(task.id, 75);
+      expect(received).toBe(75);
+      queue.offProgress(task.id, subId);
+    });
+
+    it('should cancel pending tasks', () => {
+      const task = queue.addTask('cancel-me');
+      const cancelled = queue.cancelTask(task.id);
+      expect(cancelled.status).toBe('cancelled');
+      expect(queue.getNextTask()).toBeNull();
+    });
+
+    it('should cancel processing tasks', () => {
+      queue.addTask('cancel-processing');
+      const task = queue.getNextTask()!;
+      const cancelled = queue.cancelTask(task.id);
+      expect(cancelled.status).toBe('cancelled');
+    });
+  });
+});
