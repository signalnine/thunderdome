--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,59 @@
+import { TaskQueue } from './TaskQueue.js';
+import { Task } from './Task.js';
+
+export { TaskQueue } from './TaskQueue.js';
+export { Task } from './Task.js';
+export type {
+  TaskStatus,
+  TaskOptions,
+  TaskData,
+  ProgressListener,
+  MiddlewareFn,
+  RecurringSchedule,
+  ShutdownOptions,
+  ShutdownResult,
+  ShutdownCallback,
+  TaskHandler,
+  TaskContext,
+  ProcessingHandler,
+  ProcessingOptions,
+} from './types.js';
+
+const queues: Map<string, TaskQueue> = new Map();
+
+export function createQueue(name: string): TaskQueue {
+  let queue = queues.get(name);
+  if (!queue) {
+    queue = new TaskQueue(name);
+    queues.set(name, queue);
+  }
+  return queue;
+}
+
+export function getQueue(name: string): TaskQueue | undefined {
+  return queues.get(name);
+}
+
+export function listQueues(): string[] {
+  return Array.from(queues.keys());
+}
+
+function getDefaultQueue(): TaskQueue {
+  return createQueue('default');
+}
+
+export function addTask(data: unknown, options?: import('./types.js').TaskOptions): Task {
+  return getDefaultQueue().addTask(data, options);
+}
+
+export async function process<T = unknown>(handler: (data: T) => unknown | Promise<unknown>): Promise<Task | null> {
+  return getDefaultQueue().process(handler);
+}
+
+export function getTask(id: string): Task | undefined {
+  return getDefaultQueue().getTask(id);
+}
+
+export function resetAll(): void {
+  queues.clear();
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..378fd72
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,70 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'delayed' | 'waiting';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependsOn?: string[];
+  dependencies?: string[];
+}
+
+export interface TaskData {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  progress: number;
+  progressMessage?: string;
+  error?: Error;
+  dependsOn: string[];
+  metadata: Record<string, unknown>;
+}
+
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export type MiddlewareFn = (task: TaskData, next: () => Promise<void>) => Promise<void>;
+
+export interface RecurringSchedule {
+  name: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue'>;
+  lastRun?: Date;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export type ShutdownCallback = () => void | Promise<void>;
+
+export type TaskHandler = (task: TaskData) => Promise<void> | void;
+
+export interface TaskContext {
+  signal: AbortSignal;
+  reportProgress: (value: number, message?: string) => void;
+}
+
+export type ProcessingHandler = (payload: unknown, ctx: TaskContext) => Promise<void> | void;
+
+export interface ProcessingOptions {
+  concurrency?: number;
+  queue?: string;
+}
