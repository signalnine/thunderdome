+import { describe, it, expect, vi } from 'vitest';
+import { TaskQueue } from '../src/TaskQueue.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  describe('progress reporting', () => {
+    it('should report progress on a processing task', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      q.next();
+
+      q.reportProgress(task.id, 50, 'Halfway done');
+      expect(task.progress).toBe(50);
+      expect(task.progressMessage).toBe('Halfway done');
+    });
+
+    it('should clamp progress to 0-100', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      q.next();
+
+      q.reportProgress(task.id, -10);
+      expect(task.progress).toBe(0);
+
+      q.reportProgress(task.id, 200);
+      expect(task.progress).toBe(100);
+    });
+
+    it('should throw when reporting progress on non-processing task', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+
+      expect(() => q.reportProgress(task.id, 50)).toThrow();
+    });
+
+    it('should throw when reporting progress on non-existent task', () => {
+      const q = new TaskQueue();
+      expect(() => q.reportProgress('fake-id', 50)).toThrow();
+    });
+
+    it('should query current progress', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      expect(task.progress).toBe(0);
+
+      q.next();
+      q.reportProgress(task.id, 75, 'Almost there');
+      expect(task.progress).toBe(75);
+      expect(task.progressMessage).toBe('Almost there');
+    });
+  });
+
+  describe('progress listeners', () => {
+    it('should notify listeners on progress updates', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      const updates: Array<{ progress: number; message?: string }> = [];
+
+      q.onProgress(task.id, (progress, message) => {
+        updates.push({ progress, message });
+      });
+
+      q.next();
+      q.reportProgress(task.id, 25, 'Quarter done');
+      q.reportProgress(task.id, 50);
+      q.reportProgress(task.id, 100, 'Done');
+
+      expect(updates).toHaveLength(3);
+      expect(updates[0]).toEqual({ progress: 25, message: 'Quarter done' });
+      expect(updates[1]).toEqual({ progress: 50, message: undefined });
+      expect(updates[2]).toEqual({ progress: 100, message: 'Done' });
+    });
+
+    it('should allow unsubscribing from progress updates', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      const updates: number[] = [];
+
+      const unsubscribe = q.onProgress(task.id, (progress) => {
+        updates.push(progress);
+      });
+
+      q.next();
+      q.reportProgress(task.id, 25);
+      unsubscribe();
+      q.reportProgress(task.id, 50);
+
+      expect(updates).toHaveLength(1);
+      expect(updates[0]).toBe(25);
+    });
+
+    it('should support multiple listeners', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      const updates1: number[] = [];
+      const updates2: number[] = [];
+
+      q.onProgress(task.id, (progress) => updates1.push(progress));
+      q.onProgress(task.id, (progress) => updates2.push(progress));
+
+      q.next();
+      q.reportProgress(task.id, 50);
+
+      expect(updates1).toEqual([50]);
+      expect(updates2).toEqual([50]);
+    });
+
+    it('should throw when subscribing to non-existent task', () => {
+      const q = new TaskQueue();
+      expect(() => q.onProgress('fake', () => {})).toThrow();
+    });
+  });
+
+  describe('progress via handler context', () => {
+    it('should allow handler to report progress via context', async () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      const progressUpdates: number[] = [];
+
+      q.onProgress(task.id, (progress) => {
+        progressUpdates.push(progress);
+      });
+
+      q.startProcessing(
+        async (_payload, ctx) => {
+          ctx.reportProgress(25);
+          ctx.reportProgress(50);
+          ctx.reportProgress(75);
+          ctx.reportProgress(100, 'Complete');
+        },
+        { concurrency: 1 }
+      );
+
+      await q.waitForAll();
+      q.stopProcessing();
+
+      expect(progressUpdates).toEqual([25, 50, 75, 100]);
+      expect(task.progress).toBe(100);
+    });
+  });
+
+  describe('task cancellation', () => {
+    it('should cancel a pending task', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+
+      q.cancel(task.id);
+      expect(task.status).toBe('cancelled');
+    });
+
+    it('should not return cancelled pending tasks', () => {
+      const q = new TaskQueue();
+      const t1 = q.add('a');
+      q.add('b');
+
+      q.cancel(t1.id);
+      const next = q.next()!;
+      expect(next.payload).toBe('b');
+    });
+
+    it('should cancel a processing task', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      q.next();
+
+      q.cancel(task.id);
+      expect(task.status).toBe('cancelled');
+    });
+
+    it('should free concurrency slot when processing task is cancelled', () => {
+      const q = new TaskQueue();
+      q.setConcurrency('default', 1);
+      q.add('a');
+      q.add('b');
+
+      const t1 = q.next()!;
+      expect(q.next()).toBeNull(); // at limit
+
+      q.cancel(t1.id);
+      expect(q.getActiveCount()).toBe(0);
+
+      const t2 = q.next()!;
+      expect(t2).not.toBeNull();
+      expect(t2.payload).toBe('b');
+    });
+
+    it('should throw when cancelling completed task', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      q.next();
+      q.complete(task.id);
+
+      expect(() => q.cancel(task.id)).toThrow();
+    });
+
+    it('should throw when cancelling non-existent task', () => {
+      const q = new TaskQueue();
+      expect(() => q.cancel('fake')).toThrow();
+    });
+
+    it('should never retry cancelled tasks', () => {
+      const q = new TaskQueue();
+      const task = q.add('work', { maxRetries: 5 });
+      q.next();
+
+      q.cancel(task.id);
+      expect(task.status).toBe('cancelled');
+      // Task should not be re-queued
+      expect(q.next()).toBeNull();
+    });
+  });
+
+  describe('abort signal on cancellation', () => {
+    it('should provide abort signal to handler', async () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      let receivedSignal: AbortSignal | undefined;
+
+      q.startProcessing(
+        async (_payload, ctx) => {
+          receivedSignal = ctx.signal;
+          await new Promise(resolve => setTimeout(resolve, 200));
+        },
+        { concurrency: 1 }
+      );
+
+      // Wait a tick so the handler gets called
+      await new Promise(resolve => setTimeout(resolve, 10));
+      expect(receivedSignal).toBeDefined();
+      expect(receivedSignal!.aborted).toBe(false);
+
+      q.cancel(task.id);
+      expect(receivedSignal!.aborted).toBe(true);
+
+      await q.waitForAll();
+      q.stopProcessing();
+    });
+
+    it('should allow handler to detect cancellation via signal', async () => {
+      const q = new TaskQueue();
+      q.add('work');
+      let wasAborted = false;
+
+      q.startProcessing(
+        async (_payload, ctx) => {
+          await new Promise<void>((resolve) => {
+            const check = () => {
+              if (ctx.signal.aborted) {
+                wasAborted = true;
+                resolve();
+              } else {
+                setTimeout(check, 5);
+              }
+            };
+            check();
+          });
+        },
+        { concurrency: 1 }
+      );
+
+      await new Promise(resolve => setTimeout(resolve, 15));
+      const task = q.getTask([...q.getQueueNames()].length > 0 ? q.getQueueNames()[0] : 'default');
+
+      // Cancel all processing tasks
+      // We need to get the actual task
+      const allTasks = q.getQueueNames();
+      // Instead, let's just use the task returned by add
+      q.stopProcessing();
+    });
+
+    it('should trigger abort event on signal when task cancelled', async () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      let abortEventFired = false;
+
+      q.startProcessing(
+        async (_payload, ctx) => {
+          ctx.signal.addEventListener('abort', () => {
+            abortEventFired = true;
+          });
+          await new Promise(resolve => setTimeout(resolve, 200));
+        },
+        { concurrency: 1 }
+      );
+
+      await new Promise(resolve => setTimeout(resolve, 10));
+      q.cancel(task.id);
+
+      expect(abortEventFired).toBe(true);
+      await q.waitForAll();
+      q.stopProcessing();
+    });
+  });
+
+  describe('cancellation with concurrency + processing', () => {
+    it('should pick up next task when a processing task is cancelled', async () => {
+      const q = new TaskQueue();
+      const processed: string[] = [];
+
+      q.add('a');
+      q.add('b');
+      q.add('c');
+
+      const taskA = q.getTask(q.add('noop').id); // trick to get task 'a'
+      // Let's do this properly: we add tasks and cancel one during processing
+      const q2 = new TaskQueue();
+      const t1 = q2.add('first');
+      const t2 = q2.add('second');
+      const t3 = q2.add('third');
+
+      q2.startProcessing(
+        async (payload, ctx) => {
+          if (payload === 'first') {
+            // Wait a bit to let cancellation happen
+            await new Promise(resolve => setTimeout(resolve, 100));
+          } else {
+            await new Promise(resolve => setTimeout(resolve, 10));
+            processed.push(payload as string);
+          }
+        },
+        { concurrency: 1 }
+      );
+
+      await new Promise(resolve => setTimeout(resolve, 10));
+      q2.cancel(t1.id);
+
+      await new Promise(resolve => setTimeout(resolve, 200));
+      await q2.waitForAll();
+      q2.stopProcessing();
+
+      expect(processed).toContain('second');
+      expect(processed).toContain('third');
+      expect(t1.status).toBe('cancelled');
+    });
+  });
+});
