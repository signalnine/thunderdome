@@ -0,0 +1,178 @@
+import { randomUUID } from 'node:crypto';
+import type { TaskData, TaskOptions, TaskStatus, ProgressListener } from './types.js';
+
+export class Task implements TaskData {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  progress: number;
+  progressMessage?: string;
+  error?: Error;
+  dependsOn: string[];
+  metadata: Record<string, unknown>;
+  result?: unknown;
+
+  readonly originalDependencies: readonly string[];
+  pendingDependencies: Set<string>;
+
+  private _abortController: AbortController | null = null;
+  private progressListeners: Map<string, ProgressListener> = new Map();
+
+  constructor(payload: unknown, options: TaskOptions = {}) {
+    this.id = randomUUID();
+    this.payload = payload;
+    this.status = 'pending';
+    this.queue = options.queue ?? 'default';
+    this.createdAt = new Date();
+    this.attempt = 0;
+    this.maxRetries = options.maxRetries ?? 3;
+    this.backoffDelay = options.backoffDelay ?? 1000;
+    this.progress = 0;
+    this.metadata = {};
+
+    // Support both dependsOn and dependencies
+    const deps = options.dependsOn ?? options.dependencies ?? [];
+    this.dependsOn = [...deps];
+    this.originalDependencies = Object.freeze([...deps]);
+    this.pendingDependencies = new Set(deps);
+
+    // Priority validation
+    if (options.priority !== undefined) {
+      if (options.priority < 1 || options.priority > 10 || !Number.isInteger(options.priority)) {
+        throw new Error(`Invalid priority ${options.priority}: must be an integer between 1 and 10`);
+      }
+      this.priority = options.priority;
+    } else {
+      this.priority = 5;
+    }
+
+    // Determine availability time
+    if (options.availableAt) {
+      this.availableAt = options.availableAt;
+    } else if (options.delay !== undefined && options.delay > 0) {
+      this.availableAt = new Date(Date.now() + options.delay);
+    } else {
+      this.availableAt = this.createdAt;
+    }
+
+    // Determine initial status
+    if (this.pendingDependencies.size > 0) {
+      this.status = 'waiting';
+    } else if (this.availableAt > this.createdAt) {
+      this.status = 'delayed';
+    } else {
+      this.status = 'pending';
+    }
+  }
+
+  /** Alias for payload, used by some tests */
+  get data(): unknown {
+    return this.payload;
+  }
+
+  /** Alias for attempt */
+  get attempts(): number {
+    return this.attempt;
+  }
+
+  set attempts(value: number) {
+    this.attempt = value;
+  }
+
+  get abortSignal(): AbortSignal | null {
+    return this._abortController?.signal ?? null;
+  }
+
+  isAvailable(): boolean {
+    return this.availableAt.getTime() <= Date.now();
+  }
+
+  markProcessing(): void {
+    this.status = 'processing';
+    this.attempt++;
+    this._abortController = new AbortController();
+  }
+
+  markCompleted(): void {
+    this.status = 'completed';
+    this.progress = 100;
+    this._abortController = null;
+  }
+
+  markFailed(error?: Error | string): void {
+    if (error !== undefined) {
+      this.error = error instanceof Error ? error : new Error(error);
+    }
+    this.status = 'failed';
+    this._abortController = null;
+  }
+
+  markCancelled(): void {
+    const wasProcessing = this.status === 'processing';
+    this.status = 'cancelled';
+    if (wasProcessing && this._abortController) {
+      this._abortController.abort();
+      this._abortController = null;
+    }
+  }
+
+  scheduleRetry(): void {
+    const delay = this.backoffDelay * Math.pow(2, this.attempt - 1);
+    this.status = 'pending';
+    this.availableAt = new Date(Date.now() + delay);
+    this.progress = 0;
+    this.progressMessage = undefined;
+  }
+
+  get retriesRemaining(): number {
+    return Math.max(0, this.maxRetries - this.attempt);
+  }
+
+  reportProgress(percent: number, message?: string): void {
+    this.progress = Math.max(0, Math.min(100, percent));
+    this.progressMessage = message;
+    for (const listener of this.progressListeners.values()) {
+      listener(this.progress, this.progressMessage);
+    }
+  }
+
+  onProgress(listener: ProgressListener): () => void {
+    const id = randomUUID();
+    this.progressListeners.set(id, listener);
+    return () => {
+      this.progressListeners.delete(id);
+    };
+  }
+
+  offProgress(subscriptionId: string): void {
+    this.progressListeners.delete(subscriptionId);
+  }
+
+  toData(): TaskData {
+    return {
+      id: this.id,
+      payload: this.payload,
+      status: this.status,
+      queue: this.queue,
+      priority: this.priority,
+      createdAt: this.createdAt,
+      availableAt: this.availableAt,
+      attempt: this.attempt,
+      attempts: this.attempt,
+      maxRetries: this.maxRetries,
+      backoffDelay: this.backoffDelay,
+      progress: this.progress,
+      progressMessage: this.progressMessage,
+      error: this.error,
+      dependsOn: [...this.dependsOn],
+      metadata: { ...this.metadata },
+    };
+  }
+}
