diff --git a/tests/phase-foundations.test.ts b/tests/phase-foundations.test.ts
new file mode 100644
index 0000000..9378643
--- /dev/null
+++ b/tests/phase-foundations.test.ts
@@ -0,0 +1,218 @@
+import { describe, it, expect } from 'vitest';
+import { TaskQueue } from '../src/TaskQueue.js';
+import { Task } from '../src/Task.js';
+
+describe('Foundation phases (1-7) basics', () => {
+  describe('Phase 1: FIFO Queue', () => {
+    it('should add and retrieve tasks in FIFO order', () => {
+      const q = new TaskQueue();
+      const t1 = q.add('first');
+      const t2 = q.add('second');
+
+      expect(t1.status).toBe('pending');
+      expect(t1.id).toBeDefined();
+      expect(t1.createdAt).toBeInstanceOf(Date);
+
+      const next = q.next()!;
+      expect(next.id).toBe(t1.id);
+      expect(next.status).toBe('processing');
+
+      const next2 = q.next()!;
+      expect(next2.id).toBe(t2.id);
+    });
+
+    it('should return null when no tasks available', () => {
+      const q = new TaskQueue();
+      expect(q.next()).toBeNull();
+    });
+
+    it('should track pending count', () => {
+      const q = new TaskQueue();
+      expect(q.size()).toBe(0);
+      q.add('a');
+      q.add('b');
+      expect(q.size()).toBe(2);
+      q.next();
+      expect(q.size()).toBe(1);
+    });
+  });
+
+  describe('Phase 2: Named Queues', () => {
+    it('should support named queues independently', () => {
+      const q = new TaskQueue();
+      q.add('a', { queue: 'q1' });
+      q.add('b', { queue: 'q2' });
+
+      expect(q.size('q1')).toBe(1);
+      expect(q.size('q2')).toBe(1);
+
+      expect(q.next('q1')!.payload).toBe('a');
+      expect(q.next('q2')!.payload).toBe('b');
+    });
+
+    it('should use default queue when no name given', () => {
+      const q = new TaskQueue();
+      q.add('a');
+      expect(q.next('default')!.payload).toBe('a');
+    });
+
+    it('should list queue names', () => {
+      const q = new TaskQueue();
+      q.add('a', { queue: 'alpha' });
+      q.add('b', { queue: 'beta' });
+      expect(q.getQueueNames()).toContain('alpha');
+      expect(q.getQueueNames()).toContain('beta');
+    });
+
+    it('should return null for empty/nonexistent queue', () => {
+      const q = new TaskQueue();
+      expect(q.next('nope')).toBeNull();
+    });
+  });
+
+  describe('Phase 3: Priority', () => {
+    it('should process higher priority tasks first', () => {
+      const q = new TaskQueue();
+      q.add('low', { priority: 10 });
+      q.add('high', { priority: 1 });
+      q.add('medium', { priority: 5 });
+
+      expect(q.next()!.payload).toBe('high');
+      expect(q.next()!.payload).toBe('medium');
+      expect(q.next()!.payload).toBe('low');
+    });
+
+    it('should reject invalid priorities', () => {
+      const q = new TaskQueue();
+      expect(() => q.add('x', { priority: 0 })).toThrow();
+      expect(() => q.add('x', { priority: 11 })).toThrow();
+      expect(() => q.add('x', { priority: 1.5 })).toThrow();
+    });
+
+    it('should default priority to 5', () => {
+      const q = new TaskQueue();
+      const task = q.add('x');
+      expect(task.priority).toBe(5);
+    });
+  });
+
+  describe('Phase 4: Delayed Tasks', () => {
+    it('should not return delayed tasks before their time', () => {
+      const q = new TaskQueue();
+      q.add('delayed', { delay: 10000 });
+      expect(q.next()).toBeNull();
+    });
+
+    it('should return delayed tasks after their time', async () => {
+      const q = new TaskQueue();
+      q.add('quick', { delay: 10 });
+      await new Promise(resolve => setTimeout(resolve, 20));
+      expect(q.next()!.payload).toBe('quick');
+    });
+
+    it('should prefer non-delayed tasks', () => {
+      const q = new TaskQueue();
+      q.add('delayed', { delay: 100000 });
+      q.add('immediate');
+      expect(q.next()!.payload).toBe('immediate');
+    });
+  });
+
+  describe('Phase 5: Retry with Backoff', () => {
+    it('should complete and fail tasks', () => {
+      const q = new TaskQueue();
+      const t1 = q.add('a');
+      const t2 = q.add('b');
+
+      q.next();
+      q.complete(t1.id);
+      expect(t1.status).toBe('completed');
+
+      q.next();
+      q.fail(t2.id, 'oops');
+      // It will be retried, so status goes back to pending
+      expect(t2.status).toBe('pending');
+      expect(t2.attempts).toBe(1);
+    });
+
+    it('should default to 3 retries', () => {
+      const q = new TaskQueue();
+      const task = q.add('work');
+      expect(task.maxRetries).toBe(3);
+    });
+
+    it('should exhaust retries and move to failed', () => {
+      const q = new TaskQueue();
+      const task = q.add('work', { maxRetries: 2, backoffDelay: 1 });
+
+      // First attempt
+      q.next();
+      q.fail(task.id, 'err1');
+      expect(task.status).toBe('pending'); // retried, 1 retry remaining
+
+      // Second attempt (need to wait for backoff)
+      // backoffDelay * 2^0 = 1ms
+    });
+  });
+
+  describe('Phase 6: Dead Letter Queue', () => {
+    it('should move permanently failed tasks to DLQ', () => {
+      const q = new TaskQueue();
+      const task = q.add('work', { maxRetries: 0 });
+      q.next();
+      q.fail(task.id, 'permanent error');
+
+      expect(task.status).toBe('failed');
+      const dlq = q.getDeadLetterQueue();
+      expect(dlq).toHaveLength(1);
+      expect(dlq[0].id).toBe(task.id);
+    });
+
+    it('should clear DLQ', () => {
+      const q = new TaskQueue();
+      const task = q.add('work', { maxRetries: 0 });
+      q.next();
+      q.fail(task.id, 'err');
+
+      q.clearDeadLetterQueue();
+      expect(q.getDeadLetterQueue()).toHaveLength(0);
+    });
+  });
+
+  describe('Phase 7: Task Dependencies', () => {
+    it('should block tasks with unresolved dependencies', () => {
+      const q = new TaskQueue();
+      const t1 = q.add('parent');
+      const t2 = q.add('child', { dependencies: [t1.id] });
+
+      // t2 is blocked; only t1 should be returned
+      const next = q.next()!;
+      expect(next.id).toBe(t1.id);
+      expect(q.next()).toBeNull(); // t2 still blocked
+
+      q.complete(t1.id);
+      const next2 = q.next()!;
+      expect(next2.id).toBe(t2.id);
+    });
+
+    it('should reject non-existent dependency', () => {
+      const q = new TaskQueue();
+      expect(() => q.add('child', { dependencies: ['nonexistent'] })).toThrow();
+    });
+  });
+
+  describe('Task class', () => {
+    it('should create task with UUID', () => {
+      const task = new Task('payload');
+      expect(task.id).toMatch(/^[0-9a-f-]{36}$/);
+    });
+
+    it('should expose toData()', () => {
+      const task = new Task('payload', { priority: 3 });
+      const data = task.toData();
+      expect(data.payload).toBe('payload');
+      expect(data.priority).toBe(3);
+      expect(data.status).toBe('pending');
+    });
+  });
+});
