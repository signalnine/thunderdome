+
+describe('Phases 1-9: Foundation', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  // Phase 1: Basic FIFO Queue
+  describe('Phase 1: Basic FIFO', () => {
+    it('should add a task and retrieve it', () => {
+      const task = queue.addTask({ action: 'test' });
+      expect(task.id).toBeDefined();
+      expect(task.status).toBe('pending');
+      expect(task.payload).toEqual({ action: 'test' });
+
+      const next = queue.getNextTask();
+      expect(next).not.toBeNull();
+      expect(next!.id).toBe(task.id);
+      expect(next!.status).toBe('processing');
+    });
+
+    it('should return null for empty queue', () => {
+      expect(queue.getNextTask()).toBeNull();
+    });
+
+    it('should process in FIFO order', () => {
+      const t1 = queue.addTask('first');
+      const t2 = queue.addTask('second');
+      const t3 = queue.addTask('third');
+
+      expect(queue.getNextTask()!.id).toBe(t1.id);
+      expect(queue.getNextTask()!.id).toBe(t2.id);
+      expect(queue.getNextTask()!.id).toBe(t3.id);
+    });
+
+    it('should track pending count', () => {
+      queue.addTask('a');
+      queue.addTask('b');
+      expect(queue.pendingCount()).toBe(2);
+      queue.getNextTask();
+      expect(queue.pendingCount()).toBe(1);
+    });
+  });
+
+  // Phase 2: Named Queues
+  describe('Phase 2: Named Queues', () => {
+    it('should support named queues', () => {
+      queue.addTask('a', { queue: 'emails' });
+      queue.addTask('b', { queue: 'reports' });
+
+      expect(queue.getNextTask('emails')!.payload).toBe('a');
+      expect(queue.getNextTask('reports')!.payload).toBe('b');
+    });
+
+    it('should default to "default" queue', () => {
+      queue.addTask('a');
+      expect(queue.getNextTask('default')!.payload).toBe('a');
+    });
+
+    it('should list queue names', () => {
+      queue.addTask('a', { queue: 'q1' });
+      queue.addTask('b', { queue: 'q2' });
+      expect(queue.getQueueNames()).toContain('q1');
+      expect(queue.getQueueNames()).toContain('q2');
+    });
+
+    it('should return null for non-existent queue', () => {
+      expect(queue.getNextTask('nonexistent')).toBeNull();
+    });
+  });
+
+  // Phase 3: Priority
+  describe('Phase 3: Priority', () => {
+    it('should return higher priority tasks first', () => {
+      queue.addTask('low', { priority: 10 });
+      queue.addTask('high', { priority: 1 });
+      queue.addTask('medium', { priority: 5 });
+
+      expect(queue.getNextTask()!.payload).toBe('high');
+      expect(queue.getNextTask()!.payload).toBe('medium');
+      expect(queue.getNextTask()!.payload).toBe('low');
+    });
+
+    it('should reject invalid priority', () => {
+      expect(() => queue.addTask('x', { priority: 0 })).toThrow();
+      expect(() => queue.addTask('x', { priority: 11 })).toThrow();
+    });
+
+    it('should default to priority 5', () => {
+      const task = queue.addTask('x');
+      expect(task.priority).toBe(5);
+    });
+  });
+
+  // Phase 4: Delayed Tasks
+  describe('Phase 4: Delayed Tasks', () => {
+    it('should not return delayed tasks before their time', () => {
+      queue.addTask('delayed', { delay: 100000 });
+      expect(queue.getNextTask()).toBeNull();
+    });
+
+    it('should return tasks that are now available', () => {
+      queue.addTask('available', { availableAt: new Date(Date.now() - 1000) });
+      expect(queue.getNextTask()).not.toBeNull();
+    });
+  });
+
+  // Phase 5: Retry
+  describe('Phase 5: Retry', () => {
+    it('should retry failed tasks with backoff', () => {
