--- /dev/null
+++ b/tests/phase08-concurrency.test.ts
@@ -0,0 +1,247 @@
+import { describe, it, expect, vi } from 'vitest';
+import { TaskQueue } from '../src/TaskQueue.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  describe('concurrency limit basics', () => {
+    it('should default to no concurrency limit', () => {
+      const q = new TaskQueue();
+      q.add('a');
+      expect(q.getConcurrency('default')).toBe(null);
+    });
+
+    it('should set and get concurrency limit', () => {
+      const q = new TaskQueue();
+      q.setConcurrency('default', 2);
+      expect(q.getConcurrency('default')).toBe(2);
+    });
+
+    it('should return null for nonexistent queue concurrency', () => {
+      const q = new TaskQueue();
+      expect(q.getConcurrency('nonexistent')).toBe(null);
+    });
+
+    it('should track active count', () => {
+      const q = new TaskQueue();
+      q.add('a');
+      q.add('b');
+      expect(q.getActiveCount('default')).toBe(0);
+
+      const t1 = q.next()!;
+      expect(q.getActiveCount('default')).toBe(1);
+
+      const t2 = q.next()!;
+      expect(q.getActiveCount('default')).toBe(2);
+
+      q.complete(t1.id);
+      expect(q.getActiveCount('default')).toBe(1);
+
+      q.complete(t2.id);
+      expect(q.getActiveCount('default')).toBe(0);
+    });
+
+    it('should return 0 active count for nonexistent queue', () => {
+      const q = new TaskQueue();
+      expect(q.getActiveCount('nonexistent')).toBe(0);
+    });
+  });
+
+  describe('concurrency enforcement', () => {
+    it('should return null when concurrency limit is reached', () => {
+      const q = new TaskQueue();
+      q.setConcurrency('default', 2);
+      q.add('a');
+      q.add('b');
+      q.add('c');
+
+      const t1 = q.next();
+      expect(t1).not.toBeNull();
+
+      const t2 = q.next();
+      expect(t2).not.toBeNull();
+
+      // Concurrency limit reached
+      const t3 = q.next();
+      expect(t3).toBeNull();
+
+      // Complete one, slot opens
+      q.complete(t1!.id);
+      const t4 = q.next();
+      expect(t4).not.toBeNull();
+    });
+
+    it('should free slot on task failure', () => {
+      const q = new TaskQueue();
+      q.setConcurrency('default', 1);
+      q.add('a', { maxRetries: 0 });
+      q.add('b');
+
+      const t1 = q.next()!;
+      expect(q.next()).toBeNull(); // limit reached
+
+      q.fail(t1.id, 'error');
+      const t2 = q.next();
+      expect(t2).not.toBeNull();
+    });
+
+    it('should work with concurrency limit of 1 (serial)', () => {
+      const q = new TaskQueue();
+      q.setConcurrency('default', 1);
+      q.add('a');
+      q.add('b');
+      q.add('c');
+
+      const t1 = q.next()!;
+      expect(q.next()).toBeNull();
+
+      q.complete(t1.id);
+      const t2 = q.next()!;
+      expect(q.next()).toBeNull();
+
+      q.complete(t2.id);
+      const t3 = q.next()!;
+      expect(t3).not.toBeNull();
+      q.complete(t3.id);
+    });
+
+    it('should allow unlimited tasks without concurrency limit', () => {
+      const q = new TaskQueue();
+      q.add('a');
+      q.add('b');
+      q.add('c');
+
+      const t1 = q.next()!;
+      const t2 = q.next()!;
+      const t3 = q.next()!;
+      expect(t1).not.toBeNull();
+      expect(t2).not.toBeNull();
+      expect(t3).not.toBeNull();
+    });
+  });
+
+  describe('concurrency with priorities', () => {
+    it('should respect priority ordering with concurrency limit', () => {
+      const q = new TaskQueue();
+      q.setConcurrency('default', 1);
+
+      q.add('low', { priority: 10 });
+      q.add('high', { priority: 1 });
+      q.add('medium', { priority: 5 });
+
+      const t1 = q.next()!;
+      expect(t1.payload).toBe('high');
+      expect(q.next()).toBeNull(); // concurrency limit
+
+      q.complete(t1.id);
+      const t2 = q.next()!;
+      expect(t2.payload).toBe('medium');
+    });
+  });
+
+  describe('concurrency per queue independence', () => {
+    it('should enforce concurrency independently per named queue', () => {
+      const q = new TaskQueue();
+      q.setConcurrency('queue-a', 1);
+      q.setConcurrency('queue-b', 1);
+
+      q.add('a1', { queue: 'queue-a' });
+      q.add('a2', { queue: 'queue-a' });
+      q.add('b1', { queue: 'queue-b' });
+
+      const ta1 = q.next('queue-a')!;
+      expect(ta1).not.toBeNull();
+      expect(q.next('queue-a')).toBeNull(); // queue-a at limit
+
+      const tb1 = q.next('queue-b')!;
+      expect(tb1).not.toBeNull(); // queue-b is independent
+
+      q.complete(ta1.id);
+      const ta2 = q.next('queue-a')!;
+      expect(ta2).not.toBeNull();
+    });
+  });
+
+  describe('startProcessing with concurrency', () => {
+    it('should process tasks with concurrency limit', async () => {
+      const q = new TaskQueue();
+      const processed: string[] = [];
+      let maxConcurrent = 0;
+      let currentConcurrent = 0;
+
+      q.add('a');
+      q.add('b');
+      q.add('c');
+      q.add('d');
+
+      q.startProcessing(
+        async (payload) => {
+          currentConcurrent++;
+          maxConcurrent = Math.max(maxConcurrent, currentConcurrent);
+          await new Promise(resolve => setTimeout(resolve, 50));
+          processed.push(payload as string);
+          currentConcurrent--;
+        },
+        { concurrency: 2 }
+      );
+
+      await q.waitForAll();
+      q.stopProcessing();
+
+      expect(processed).toHaveLength(4);
+      expect(maxConcurrent).toBeLessThanOrEqual(2);
+    });
+
+    it('should process tasks serially with concurrency=1', async () => {
+      const q = new TaskQueue();
+      const order: string[] = [];
+
+      q.add('a');
+      q.add('b');
+      q.add('c');
+
+      q.startProcessing(
+        async (payload) => {
+          order.push(`start-${payload}`);
+          await new Promise(resolve => setTimeout(resolve, 20));
+          order.push(`end-${payload}`);
+        },
+        { concurrency: 1 }
+      );
+
+      await q.waitForAll();
+      q.stopProcessing();
+
+      // With concurrency 1, tasks should not overlap
+      expect(order[0]).toBe('start-a');
+      expect(order[1]).toBe('end-a');
+      expect(order[2]).toBe('start-b');
+      expect(order[3]).toBe('end-b');
+    });
+
+    it('should pick up newly added tasks while processing', async () => {
+      const q = new TaskQueue();
+      const processed: string[] = [];
+
+      q.add('a');
+
+      q.startProcessing(
+        async (payload) => {
+          processed.push(payload as string);
+          await new Promise(resolve => setTimeout(resolve, 10));
+        },
+        { concurrency: 2 }
+      );
+
+      // Wait a tick for first task to start, then add more
+      await new Promise(resolve => setTimeout(resolve, 5));
+      q.add('b');
+      q.add('c');
+
+      await q.waitForAll();
+      q.stopProcessing();
+
+      expect(processed).toContain('a');
+      expect(processed).toContain('b');
+      expect(processed).toContain('c');
+    });
+  });
+});
