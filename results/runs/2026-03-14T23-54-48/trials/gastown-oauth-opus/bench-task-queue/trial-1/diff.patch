+import { describe, it, expect, beforeEach } from 'vitest';
+import { createQueue, getQueue, listQueues, addTask, process, getTask, resetAll } from '../src/index.js';
+
+describe('Phase 2: Named Queues', () => {
+  beforeEach(() => {
+    resetAll();
+  });
+
+  it('should create independent named queues', () => {
+    const emailQueue = createQueue('email');
+    const smsQueue = createQueue('sms');
+
+    expect(emailQueue.name).toBe('email');
+    expect(smsQueue.name).toBe('sms');
+    expect(emailQueue).not.toBe(smsQueue);
+  });
+
+  it('should return the same queue instance for the same name', () => {
+    const q1 = createQueue('jobs');
+    const q2 = createQueue('jobs');
+    expect(q1).toBe(q2);
+  });
+
+  it('should operate queues independently', async () => {
+    const q1 = createQueue('q1');
+    const q2 = createQueue('q2');
+
+    q1.addTask('q1-task');
+    q2.addTask('q2-task');
+
+    const results: string[] = [];
+    await q1.process((data: string) => { results.push(`q1:${data}`); });
+    await q2.process((data: string) => { results.push(`q2:${data}`); });
+
+    expect(results).toEqual(['q1:q1-task', 'q2:q2-task']);
+  });
+
+  it('should list all queue names', () => {
+    createQueue('alpha');
+    createQueue('beta');
+    createQueue('gamma');
+
+    const names = listQueues();
+    expect(names).toContain('alpha');
+    expect(names).toContain('beta');
+    expect(names).toContain('gamma');
+  });
+
+  it('should return undefined for non-existent queue', () => {
+    expect(getQueue('nonexistent')).toBeUndefined();
+  });
+
+  it('should use default queue when no name specified', () => {
+    const task = addTask('default-task');
+    expect(task.status).toBe('pending');
+
+    const defaultQueue = getQueue('default');
+    expect(defaultQueue).toBeDefined();
+    expect(defaultQueue!.getTask(task.id)).toBe(task);
+  });
+
+  it('should retrieve tasks from default queue via getTask', () => {
+    const task = addTask('find-me');
+    const found = getTask(task.id);
+    expect(found).toBe(task);
+  });
+
+  it('should process from default queue via process', async () => {
+    addTask('process-me');
+    const result = await process((data: string) => `processed:${data}`);
+    expect(result!.status).toBe('completed');
+    expect(result!.result).toBe('processed:process-me');
+  });
+
+  it('should return null when processing empty/non-existent queue', async () => {
+    const q = createQueue('empty');
+    const result = await q.process(() => {});
+    expect(result).toBeNull();
+  });
+});
