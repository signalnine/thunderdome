+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/TaskQueue.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should create a task with unique ID and pending status', () => {
+    const task = queue.addTask({ message: 'hello' });
+    expect(task.id).toBeDefined();
+    expect(typeof task.id).toBe('string');
+    expect(task.status).toBe('pending');
+    expect(task.data).toEqual({ message: 'hello' });
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should assign unique IDs to each task', () => {
+    const t1 = queue.addTask('a');
+    const t2 = queue.addTask('b');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should process tasks in FIFO order', async () => {
+    queue.addTask('first');
+    queue.addTask('second');
+    queue.addTask('third');
+
+    const results: string[] = [];
+    const handler = (data: string) => { results.push(data); };
+
+    await queue.process(handler);
+    await queue.process(handler);
+    await queue.process(handler);
+
+    expect(results).toEqual(['first', 'second', 'third']);
+  });
+
+  it('should transition task status through lifecycle', async () => {
+    const task = queue.addTask('test');
+    expect(task.status).toBe('pending');
+
+    const processed = await queue.process((data: string) => `done: ${data}`);
+    expect(processed).toBe(task);
+    expect(task.status).toBe('completed');
+    expect(task.result).toBe('done: test');
+  });
+
+  it('should set status to failed when handler throws', async () => {
+    const task = queue.addTask('fail-me');
+
+    const processed = await queue.process(() => {
+      throw new Error('oops');
+    });
+
+    expect(processed).toBe(task);
+    expect(task.status).toBe('failed');
+    expect(task.error).toBeInstanceOf(Error);
+    expect(task.error!.message).toBe('oops');
+  });
+
+  it('should return null when no tasks are available', async () => {
+    const result = await queue.process(() => {});
+    expect(result).toBeNull();
+  });
+
+  it('should retrieve a task by ID', () => {
+    const task = queue.addTask('find me');
+    const found = queue.getTask(task.id);
+    expect(found).toBe(task);
+  });
+
+  it('should return undefined for unknown task ID', () => {
+    expect(queue.getTask('nonexistent')).toBeUndefined();
+  });
+
+  it('should report pending count correctly', async () => {
+    expect(queue.size).toBe(0);
+    queue.addTask('a');
+    queue.addTask('b');
+    expect(queue.size).toBe(2);
+    await queue.process(() => {});
+    expect(queue.size).toBe(1);
+  });
+
+  it('should handle async handlers', async () => {
+    queue.addTask(42);
+    const task = await queue.process(async (data: number) => {
+      return data * 2;
+    });
+    expect(task!.status).toBe('completed');
+    expect(task!.result).toBe(84);
+  });
+
+  it('should handle async handler rejection', async () => {
+    queue.addTask('fail');
+    const task = await queue.process(async () => {
+      throw new Error('async oops');
+    });
+    expect(task!.status).toBe('failed');
+    expect(task!.error!.message).toBe('async oops');
+  });
+});
