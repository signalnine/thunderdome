+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/TaskQueue.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+    vi.useRealTimers();
+  });
+
+  it('should create delayed tasks with "delayed" status', () => {
+    const task = queue.addTask('later', { delay: 10000 });
+    expect(task.status).toBe('delayed');
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should create immediate tasks with "pending" status', () => {
+    const task = queue.addTask('now');
+    expect(task.status).toBe('pending');
+    expect(task.availableAt.getTime()).toBeLessThanOrEqual(Date.now());
+  });
+
+  it('should not process delayed tasks before their availability time', async () => {
+    queue.addTask('delayed', { delay: 60000 });
+    const result = await queue.process(() => {});
+    expect(result).toBeNull();
+  });
+
+  it('should prefer non-delayed tasks over not-yet-available delayed tasks', async () => {
+    queue.addTask('delayed', { delay: 60000 });
+    queue.addTask('immediate');
+
+    const results: string[] = [];
+    const task = await queue.process((d: string) => { results.push(d); });
+
+    expect(task).not.toBeNull();
+    expect(results).toEqual(['immediate']);
+  });
+
+  it('should process delayed tasks once they become available', async () => {
+    vi.useFakeTimers();
+    const now = Date.now();
+    vi.setSystemTime(now);
+
+    queue.addTask('delayed-100ms', { delay: 100 });
+
+    // Not yet available
+    let result = await queue.process(() => {});
+    expect(result).toBeNull();
+
+    // Advance time past the delay
+    vi.setSystemTime(now + 150);
+
+    result = await queue.process((d: string) => d);
+    expect(result).not.toBeNull();
+    expect(result!.data).toBe('delayed-100ms');
+    expect(result!.status).toBe('completed');
+
+    vi.useRealTimers();
+  });
+
+  it('should support availableAt option for scheduling', async () => {
+    vi.useFakeTimers();
+    const now = Date.now();
+    vi.setSystemTime(now);
+
+    const futureTime = new Date(now + 5000);
+    const task = queue.addTask('scheduled', { availableAt: futureTime });
+    expect(task.status).toBe('delayed');
+    expect(task.availableAt).toEqual(futureTime);
+
+    // Not available yet
+    let result = await queue.process(() => {});
+    expect(result).toBeNull();
+
+    // Advance past scheduled time
+    vi.setSystemTime(now + 6000);
+
+    result = await queue.process((d: string) => d);
+    expect(result).not.toBeNull();
+    expect(result!.data).toBe('scheduled');
+
+    vi.useRealTimers();
+  });
+
+  it('should order by availability time, then priority, then FIFO when delayed tasks become available simultaneously', async () => {
+    vi.useFakeTimers();
+    const now = Date.now();
+    vi.setSystemTime(now);
+
+    // Add tasks with different delays, same priority
+    queue.addTask('later', { delay: 200 });
+    queue.addTask('sooner', { delay: 100 });
+
+    // Advance past both delays
+    vi.setSystemTime(now + 300);
+
+    const results: string[] = [];
+    const handler = (data: string) => { results.push(data); };
+
+    await queue.process(handler);
+    await queue.process(handler);
+
+    // sooner became available first, so it should process first (both same priority)
+    expect(results).toEqual(['sooner', 'later']);
+
+    vi.useRealTimers();
+  });
+
+  it('should respect priority among available delayed tasks', async () => {
+    vi.useFakeTimers();
+    const now = Date.now();
+    vi.setSystemTime(now);
+
+    queue.addTask('low-prio', { delay: 100, priority: 10 });
+    queue.addTask('high-prio', { delay: 100, priority: 1 });
+
+    // Advance past delay
+    vi.setSystemTime(now + 200);
+
+    const results: string[] = [];
+    const handler = (data: string) => { results.push(data); };
+
+    await queue.process(handler);
+    await queue.process(handler);
+
+    expect(results).toEqual(['high-prio', 'low-prio']);
+
+    vi.useRealTimers();
+  });
+
+  it('should work with delayed tasks in named queues', async () => {
+    vi.useFakeTimers();
+    const now = Date.now();
+    vi.setSystemTime(now);
+
+    const q1 = new TaskQueue('q1');
+    const q2 = new TaskQueue('q2');
+
+    q1.addTask('q1-delayed', { delay: 100 });
+    q2.addTask('q2-immediate');
+
+    // q1's task isn't available yet
+    let result = await q1.process(() => {});
+    expect(result).toBeNull();
+
+    // q2's task is immediate
+    result = await q2.process((d: string) => d);
+    expect(result).not.toBeNull();
+    expect(result!.data).toBe('q2-immediate');
+
+    // Advance time
+    vi.setSystemTime(now + 200);
+
+    result = await q1.process((d: string) => d);
+    expect(result).not.toBeNull();
+    expect(result!.data).toBe('q1-delayed');
+
+    vi.useRealTimers();
+  });
+
+  it('should expose availableAt on task object', () => {
+    const task = queue.addTask('test', { delay: 5000 });
+    expect(task.availableAt).toBeInstanceOf(Date);
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should track lifecycle states correctly for delayed tasks', async () => {
+    vi.useFakeTimers();
+    const now = Date.now();
+    vi.setSystemTime(now);
+
+    const task = queue.addTask('lifecycle', { delay: 100 });
+    expect(task.status).toBe('delayed');
+
+    // Advance time and process
+    vi.setSystemTime(now + 200);
+    await queue.process((d: string) => d);
+
+    expect(task.status).toBe('completed');
+
+    vi.useRealTimers();
+  });
+});
