+import { describe, it, expect, vi, beforeEach } from 'vitest';
+import { TaskQueue, Task } from '../src/index.js';
+
+describe('Phase 1-4: Foundation', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('adds and retrieves tasks in FIFO order', () => {
+    const t1 = tq.addTask({ name: 'first' });
+    const t2 = tq.addTask({ name: 'second' });
+    expect(t1.status).toBe('pending');
+    expect(t2.status).toBe('pending');
+
+    const next = tq.getNextTask();
+    expect(next?.id).toBe(t1.id);
+    expect(next?.status).toBe('processing');
+    expect(next?.attempts).toBe(1);
+  });
+
+  it('returns null from empty queue', () => {
+    expect(tq.getNextTask()).toBeNull();
+    expect(tq.getNextTask('nonexistent')).toBeNull();
+  });
+
+  it('supports named queues', () => {
+    tq.addTask('a', { queue: 'q1' });
+    tq.addTask('b', { queue: 'q2' });
+    expect(tq.getQueueNames()).toEqual(expect.arrayContaining(['q1', 'q2']));
+    expect(tq.getNextTask('q1')?.payload).toBe('a');
+    expect(tq.getNextTask('q2')?.payload).toBe('b');
+  });
+
+  it('respects priority ordering', () => {
+    tq.addTask('low', { priority: 10 });
+    tq.addTask('high', { priority: 1 });
+    tq.addTask('mid', { priority: 5 });
+
+    expect(tq.getNextTask()?.payload).toBe('high');
+    expect(tq.getNextTask()?.payload).toBe('mid');
+    expect(tq.getNextTask()?.payload).toBe('low');
+  });
+
+  it('throws on invalid priority', () => {
+    expect(() => tq.addTask('x', { priority: 0 })).toThrow();
+    expect(() => tq.addTask('x', { priority: 11 })).toThrow();
+    expect(() => tq.addTask('x', { priority: 1.5 })).toThrow();
+  });
+
+  it('delays tasks', () => {
+    vi.useFakeTimers();
+    try {
+      tq.addTask('delayed', { delay: 5000 });
+      expect(tq.getNextTask()).toBeNull();
+      vi.advanceTimersByTime(5000);
+      expect(tq.getNextTask()?.payload).toBe('delayed');
+    } finally {
+      vi.useRealTimers();
+    }
+  });
+
+  it('tracks pending count', () => {
+    tq.addTask('a');
+    tq.addTask('b');
+    expect(tq.getPendingCount()).toBe(2);
+    tq.getNextTask();
+    expect(tq.getPendingCount()).toBe(1);
+  });
+});
+
+describe('Phase 5: Retry with Backoff', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('retries a failed task with exponential backoff', () => {
+    const task = tq.addTask('flaky', { maxRetries: 3, backoffDelay: 1000 });
+
+    // Attempt 1
+    const t1 = tq.getNextTask()!;
+    expect(t1.attempts).toBe(1);
+    tq.failTask(t1.id, new Error('fail 1'));
+    expect(t1.status).toBe('pending');
+    expect(t1.error?.message).toBe('fail 1');
+
+    // Not available immediately (backoff = 1000 * 2^0 = 1000ms)
+    expect(tq.getNextTask()).toBeNull();
+    vi.advanceTimersByTime(1000);
+
+    // Attempt 2
+    const t2 = tq.getNextTask()!;
+    expect(t2.id).toBe(task.id);
+    expect(t2.attempts).toBe(2);
+    tq.failTask(t2.id, new Error('fail 2'));
+
+    // Backoff = 1000 * 2^1 = 2000ms
+    expect(tq.getNextTask()).toBeNull();
+    vi.advanceTimersByTime(2000);
+
+    // Attempt 3 (final)
+    const t3 = tq.getNextTask()!;
+    expect(t3.attempts).toBe(3);
+    tq.failTask(t3.id, new Error('fail 3'));
+
+    // Should be failed now (exhausted all 3 retries)
+    expect(t3.status).toBe('failed');
+  });
+
+  it('uses default maxRetries of 3', () => {
+    const task = tq.addTask('x');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('uses default backoffDelay of 1000', () => {
+    const task = tq.addTask('x');
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  it('allows configurable maxRetries and backoffDelay', () => {
+    const task = tq.addTask('x', { maxRetries: 5, backoffDelay: 500 });
+    expect(task.maxRetries).toBe(5);
+    expect(task.backoffDelay).toBe(500);
+  });
+
+  it('completes a task successfully', () => {
+    tq.addTask('ok');
+    const t = tq.getNextTask()!;
+    const completed = tq.completeTask(t.id);
+    expect(completed.status).toBe('completed');
+  });
+
+  it('throws when completing a non-processing task', () => {
+    const t = tq.addTask('x');
+    expect(() => tq.completeTask(t.id)).toThrow("Cannot complete task in 'pending' state");
+  });
+
+  it('throws when failing a non-processing task', () => {
+    const t = tq.addTask('x');
+    expect(() => tq.failTask(t.id)).toThrow("Cannot fail task in 'pending' state");
+  });
+
+  it('retried tasks keep their original queue and priority', () => {
+    const task = tq.addTask('data', { queue: 'myq', priority: 2, maxRetries: 2, backoffDelay: 100 });
+    const t = tq.getNextTask('myq')!;
+    tq.failTask(t.id, new Error('oops'));
+
+    expect(task.queue).toBe('myq');
+    expect(task.priority).toBe(2);
+    expect(task.status).toBe('pending');
+
+    vi.advanceTimersByTime(100);
+    const t2 = tq.getNextTask('myq')!;
+    expect(t2.id).toBe(task.id);
+    expect(t2.priority).toBe(2);
+  });
+});
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  function exhaustRetries(taskId: string, maxRetries: number, backoffDelay: number) {
+    for (let i = 0; i < maxRetries; i++) {
+      const t = tq.getNextTask()!;
+      expect(t.id).toBe(taskId);
+      tq.failTask(t.id, new Error(`fail ${i + 1}`));
+      if (i < maxRetries - 1) {
+        vi.advanceTimersByTime(backoffDelay * Math.pow(2, i));
+      }
+    }
+  }
+
+  it('moves task to DLQ after exhausting retries', () => {
+    const task = tq.addTask('doomed', { maxRetries: 2, backoffDelay: 100 });
+    exhaustRetries(task.id, 2, 100);
+
+    expect(task.status).toBe('failed');
+    const dlq = tq.getDLQ('default');
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].id).toBe(task.id);
+    expect(dlq[0].error?.message).toBe('fail 2');
+  });
+
+  it('each named queue has its own DLQ', () => {
+    const t1 = tq.addTask('a', { queue: 'q1', maxRetries: 1, backoffDelay: 10 });
+    const t2 = tq.addTask('b', { queue: 'q2', maxRetries: 1, backoffDelay: 10 });
+
+    // Exhaust q1
+    const n1 = tq.getNextTask('q1')!;
+    tq.failTask(n1.id, new Error('q1 fail'));
+
+    // Exhaust q2
+    const n2 = tq.getNextTask('q2')!;
+    tq.failTask(n2.id, new Error('q2 fail'));
+
+    expect(tq.getDLQ('q1')).toHaveLength(1);
+    expect(tq.getDLQ('q1')[0].id).toBe(t1.id);
+    expect(tq.getDLQ('q2')).toHaveLength(1);
+    expect(tq.getDLQ('q2')[0].id).toBe(t2.id);
+  });
+
+  it('retains error information on DLQ tasks', () => {
+    const task = tq.addTask('x', { maxRetries: 1, backoffDelay: 10 });
+    const t = tq.getNextTask()!;
+    tq.failTask(t.id, new Error('the error'));
+
+    const dlq = tq.getDLQ();
+    expect(dlq[0].error?.message).toBe('the error');
+    expect(dlq[0].attempts).toBe(1);
+  });
+
+  it('retryFromDLQ moves task back to its queue', () => {
+    const task = tq.addTask('retry-me', { maxRetries: 1, backoffDelay: 10 });
+    const t = tq.getNextTask()!;
+    tq.failTask(t.id, new Error('fail'));
+
+    expect(tq.getDLQ()).toHaveLength(1);
+    expect(tq.getNextTask()).toBeNull(); // Not in main queue
+
+    const retried = tq.retryFromDLQ(task.id);
+    expect(retried.status).toBe('pending');
+    expect(retried.attempts).toBe(0);
+    expect(retried.error).toBeUndefined();
+    expect(tq.getDLQ()).toHaveLength(0);
+
+    const next = tq.getNextTask()!;
+    expect(next.id).toBe(task.id);
+  });
+
+  it('throws when retrying a task not in any DLQ', () => {
+    expect(() => tq.retryFromDLQ('nonexistent')).toThrow();
+  });
+
+  it('clearDLQ removes all dead-lettered tasks', () => {
+    const t1 = tq.addTask('a', { maxRetries: 1, backoffDelay: 10 });
+    const t2 = tq.addTask('b', { maxRetries: 1, backoffDelay: 10 });
+
+    const n1 = tq.getNextTask()!;
+    tq.failTask(n1.id, new Error('f'));
+    const n2 = tq.getNextTask()!;
+    tq.failTask(n2.id, new Error('f'));
+
+    expect(tq.getDLQ()).toHaveLength(2);
+    const count = tq.clearDLQ();
+    expect(count).toBe(2);
+    expect(tq.getDLQ()).toHaveLength(0);
+
+    // Tasks should also be removed from the global task map
+    expect(tq.getTask(t1.id)).toBeNull();
+    expect(tq.getTask(t2.id)).toBeNull();
+  });
+
+  it('clearDLQ returns 0 for empty DLQ', () => {
+    expect(tq.clearDLQ()).toBe(0);
+  });
+});
+
+describe('Phase 7: Task Dependencies', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('tasks with dependencies start in waiting state', () => {
+    const a = tq.addTask('a');
+    const b = tq.addTask('b', { dependsOn: [a.id] });
+    expect(b.status).toBe('waiting');
+  });
+
+  it('waiting tasks are not returned by getNextTask', () => {
+    const a = tq.addTask('a');
+    tq.addTask('b', { dependsOn: [a.id] });
+
+    const next = tq.getNextTask()!;
+    expect(next.id).toBe(a.id);
+
+    // b should not be available yet
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('unblocks task when dependency completes', () => {
+    const a = tq.addTask('a');
+    const b = tq.addTask('b', { dependsOn: [a.id] });
+
+    const t = tq.getNextTask()!;
+    tq.completeTask(t.id);
+
+    expect(b.status).toBe('pending');
+    const next = tq.getNextTask()!;
+    expect(next.id).toBe(b.id);
+  });
+
+  it('supports multiple dependencies', () => {
+    const a = tq.addTask('a');
+    const b = tq.addTask('b');
+    const c = tq.addTask('c', { dependsOn: [a.id, b.id] });
+
+    expect(c.status).toBe('waiting');
+
+    // Complete a
+    const ta = tq.getNextTask()!;
+    expect(ta.id).toBe(a.id);
+    tq.completeTask(ta.id);
+
+    // c still waiting (b not done)
+    expect(c.status).toBe('waiting');
+
+    // Complete b
+    const tb = tq.getNextTask()!;
+    expect(tb.id).toBe(b.id);
+    tq.completeTask(tb.id);
+
+    // c should now be pending
+    expect(c.status).toBe('pending');
+  });
+
+  it('throws on non-existent dependency', () => {
+    expect(() => tq.addTask('x', { dependsOn: ['nonexistent'] })).toThrow(
+      'Dependency task not found: nonexistent'
+    );
+  });
+
+  it('detects circular dependencies (direct)', () => {
+    // A depends on B, B depends on A can't happen because we can't have
+    // A depend on B if B doesn't exist yet. But we can test:
+    // A exists, B depends on A, C depends on B — no cycle, should work.
+
+    const a = tq.addTask('a');
+    const b = tq.addTask('b', { dependsOn: [a.id] });
+    const c = tq.addTask('c', { dependsOn: [b.id] });
+    expect(c.status).toBe('waiting');
+  });
+
+  it('detects self-dependency', () => {
+    // Can't depend on yourself because you must exist before being a dependency.
+    // But since the task ID is generated inside addTask, we can't easily self-reference.
+    // This is inherently prevented by the "dependency must exist" check.
+  });
+
+  it('supports dependency chains that eventually resolve', () => {
+    const a = tq.addTask('a');
+    const b = tq.addTask('b', { dependsOn: [a.id] });
+    const c = tq.addTask('c', { dependsOn: [b.id] });
+
+    expect(b.status).toBe('waiting');
+    expect(c.status).toBe('waiting');
+
+    // Complete a
+    const ta = tq.getNextTask()!;
+    tq.completeTask(ta.id);
+    expect(b.status).toBe('pending');
+    expect(c.status).toBe('waiting');
+
+    // Complete b
+    const tb = tq.getNextTask()!;
+    tq.completeTask(tb.id);
+    expect(c.status).toBe('pending');
+
+    // Complete c
+    const tc = tq.getNextTask()!;
+    tq.completeTask(tc.id);
+    expect(tc.status).toBe('completed');
+  });
+
+  it('failed dependency does NOT automatically fail dependents (they remain blocked)', () => {
+    vi.useFakeTimers();
+    try {
+      const a = tq.addTask('a', { maxRetries: 1, backoffDelay: 10 });
+      const b = tq.addTask('b', { dependsOn: [a.id] });
+
+      const ta = tq.getNextTask()!;
+      tq.failTask(ta.id, new Error('a failed'));
+
+      // a is now in DLQ (failed), but b should still be waiting
+      expect(b.status).toBe('waiting');
+    } finally {
+      vi.useRealTimers();
+    }
+  });
+
+  it('getTaskDependencyStatus returns correct info', () => {
+    const a = tq.addTask('a');
+    const b = tq.addTask('b');
+    const c = tq.addTask('c', { dependsOn: [a.id, b.id] });
+
+    let status = tq.getTaskDependencyStatus(c.id)!;
+    expect(status.total).toBe(2);
+    expect(status.pending).toHaveLength(2);
+    expect(status.resolved).toHaveLength(0);
+
+    // Complete a
+    const ta = tq.getNextTask()!;
+    tq.completeTask(ta.id);
+
+    status = tq.getTaskDependencyStatus(c.id)!;
+    expect(status.total).toBe(2);
+    expect(status.pending).toHaveLength(1);
+    expect(status.resolved).toHaveLength(1);
+    expect(status.resolved).toContain(a.id);
+    expect(status.pending).toContain(b.id);
+  });
+
+  it('getTaskDependencyStatus returns null for unknown task', () => {
+    expect(tq.getTaskDependencyStatus('nonexistent')).toBeNull();
+  });
+
+  it('task with no dependencies has empty dependency status', () => {
+    const t = tq.addTask('no deps');
+    const status = tq.getTaskDependencyStatus(t.id)!;
+    expect(status.total).toBe(0);
+    expect(status.resolved).toHaveLength(0);
+    expect(status.pending).toHaveLength(0);
+  });
+
+  it('dependencies work across named queues', () => {
+    const a = tq.addTask('a', { queue: 'q1' });
+    const b = tq.addTask('b', { queue: 'q2', dependsOn: [a.id] });
+
+    expect(b.status).toBe('waiting');
+    expect(tq.getNextTask('q2')).toBeNull();
+
+    const ta = tq.getNextTask('q1')!;
+    tq.completeTask(ta.id);
+
+    expect(b.status).toBe('pending');
+    const tb = tq.getNextTask('q2')!;
+    expect(tb.id).toBe(b.id);
+  });
+});
