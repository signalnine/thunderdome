+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/TaskQueue.js';
+
+describe('Phase 3: Priority', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should default priority to 5', () => {
+    const task = queue.addTask('no priority');
+    expect(task.priority).toBe(5);
+  });
+
+  it('should accept priority 1-10', () => {
+    const t1 = queue.addTask('high', { priority: 1 });
+    const t10 = queue.addTask('low', { priority: 10 });
+    expect(t1.priority).toBe(1);
+    expect(t10.priority).toBe(10);
+  });
+
+  it('should reject invalid priority values', () => {
+    expect(() => queue.addTask('bad', { priority: 0 })).toThrow();
+    expect(() => queue.addTask('bad', { priority: 11 })).toThrow();
+    expect(() => queue.addTask('bad', { priority: -1 })).toThrow();
+    expect(() => queue.addTask('bad', { priority: 1.5 })).toThrow();
+  });
+
+  it('should process higher-priority tasks first (lower number = higher priority)', async () => {
+    queue.addTask('low', { priority: 10 });
+    queue.addTask('high', { priority: 1 });
+    queue.addTask('medium', { priority: 5 });
+
+    const results: string[] = [];
+    const handler = (data: string) => { results.push(data); };
+
+    await queue.process(handler);
+    await queue.process(handler);
+    await queue.process(handler);
+
+    expect(results).toEqual(['high', 'medium', 'low']);
+  });
+
+  it('should maintain FIFO order within the same priority', async () => {
+    queue.addTask('first', { priority: 3 });
+    queue.addTask('second', { priority: 3 });
+    queue.addTask('third', { priority: 3 });
+
+    const results: string[] = [];
+    const handler = (data: string) => { results.push(data); };
+
+    await queue.process(handler);
+    await queue.process(handler);
+    await queue.process(handler);
+
+    expect(results).toEqual(['first', 'second', 'third']);
+  });
+
+  it('should handle mixed default and explicit priorities', async () => {
+    queue.addTask('default1');                    // priority 5
+    queue.addTask('urgent', { priority: 1 });     // priority 1
+    queue.addTask('default2');                    // priority 5
+    queue.addTask('low', { priority: 8 });        // priority 8
+
+    const results: string[] = [];
+    const handler = (data: string) => { results.push(data); };
+
+    await queue.process(handler);
+    await queue.process(handler);
+    await queue.process(handler);
+    await queue.process(handler);
+
+    expect(results).toEqual(['urgent', 'default1', 'default2', 'low']);
+  });
+
+  it('should work with named queues independently', async () => {
+    const q1 = new TaskQueue('q1');
+    const q2 = new TaskQueue('q2');
+
+    q1.addTask('q1-low', { priority: 10 });
+    q1.addTask('q1-high', { priority: 1 });
+    q2.addTask('q2-low', { priority: 10 });
+    q2.addTask('q2-high', { priority: 1 });
+
+    const r1: string[] = [];
+    const r2: string[] = [];
+
+    await q1.process((d: string) => { r1.push(d); });
+    await q1.process((d: string) => { r1.push(d); });
+    await q2.process((d: string) => { r2.push(d); });
+    await q2.process((d: string) => { r2.push(d); });
+
+    expect(r1).toEqual(['q1-high', 'q1-low']);
+    expect(r2).toEqual(['q2-high', 'q2-low']);
+  });
+});
