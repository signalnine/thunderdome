+      expect(result).toBe('cdeh');
+    });
+
+    it('transforms non-overlapping deletes (B before A)', () => {
+      const doc = 'abcdefgh';
+      const a: DeleteOp = { type: 'delete', position: 5, count: 2 };
+      const b: DeleteOp = { type: 'delete', position: 0, count: 2 };
+      const result = verifyConvergence(doc, a, b);
+      expect(result).toBe('cdeh');
+    });
+
+    it('transforms identical deletes', () => {
+      const doc = 'abcde';
+      const a: DeleteOp = { type: 'delete', position: 1, count: 2 };
+      const b: DeleteOp = { type: 'delete', position: 1, count: 2 };
+      const result = verifyConvergence(doc, a, b);
+      expect(result).toBe('ade');
+    });
+
+    it('transforms overlapping deletes', () => {
+      const doc = 'abcdefgh';
+      const a: DeleteOp = { type: 'delete', position: 1, count: 4 };
+      const b: DeleteOp = { type: 'delete', position: 3, count: 4 };
+      const result = verifyConvergence(doc, a, b);
+      expect(result).toBe('ah');
+    });
+
+    it('transforms when A covers B', () => {
+      const doc = 'abcdefgh';
+      const a: DeleteOp = { type: 'delete', position: 1, count: 6 };
+      const b: DeleteOp = { type: 'delete', position: 2, count: 2 };
+      const result = verifyConvergence(doc, a, b);
