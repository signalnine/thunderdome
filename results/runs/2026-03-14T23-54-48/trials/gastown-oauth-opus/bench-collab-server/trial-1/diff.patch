+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp, type AppInstance } from '../src/server.js';
+import type { WsMessage, Document } from '../src/types.js';
+
+let app: AppInstance;
+let port: number;
+let baseUrl: string;
+
+function wsUrl(documentId: string): string {
+  return `ws://127.0.0.1:${port}/ws/${documentId}`;
+}
+
+function connectWs(documentId: string): Promise<{ ws: WebSocket; syncMsg: WsMessage }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(documentId));
+    ws.on('error', reject);
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString()) as WsMessage;
+      if (msg.type === 'sync') {
+        resolve({ ws, syncMsg: msg });
+      }
+    });
+  });
+}
+
+function waitForMessage(ws: WebSocket, type?: string): Promise<WsMessage> {
+  return new Promise((resolve) => {
+    const handler = (data: WebSocket.RawData) => {
+      const msg = JSON.parse(data.toString()) as WsMessage;
+      if (!type || msg.type === type) {
+        ws.off('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+  });
+}
+
+function sendOperation(
+  ws: WebSocket,
+  documentId: string,
+  op: { type: 'insert' | 'delete'; position: number; text: string; version: number }
+): void {
+  const msg: WsMessage = {
+    type: 'operation',
+    documentId,
+    operation: op,
+  };
+  ws.send(JSON.stringify(msg));
+}
+
+beforeEach(async () => {
+  app = createApp();
+  port = await app.start(0);
+  baseUrl = `http://127.0.0.1:${port}`;
