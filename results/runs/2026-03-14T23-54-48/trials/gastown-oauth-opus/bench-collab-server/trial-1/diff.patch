+import { describe, it, expect } from 'vitest';
+import { applyOperation, applyOperations, transformOp, transformAgainstOps, validateOperation } from '../src/ot.js';
+import type { Operation, InsertOp, DeleteOp } from '../src/types.js';
+
+describe('applyOperation', () => {
+  it('inserts text at position', () => {
+    expect(applyOperation('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+  });
+
+  it('inserts text at beginning', () => {
+    expect(applyOperation('world', { type: 'insert', position: 0, text: 'hello ' })).toBe('hello world');
+  });
+
+  it('inserts text in middle', () => {
+    expect(applyOperation('hllo', { type: 'insert', position: 1, text: 'e' })).toBe('hello');
+  });
+
+  it('deletes text at position', () => {
+    expect(applyOperation('hello world', { type: 'delete', position: 5, count: 6 })).toBe('hello');
+  });
+
+  it('deletes text from beginning', () => {
+    expect(applyOperation('hello', { type: 'delete', position: 0, count: 2 })).toBe('llo');
+  });
+
+  it('throws on out-of-bounds insert', () => {
+    expect(() => applyOperation('hi', { type: 'insert', position: 10, text: 'x' })).toThrow();
+  });
+
+  it('throws on out-of-bounds delete', () => {
+    expect(() => applyOperation('hi', { type: 'delete', position: 1, count: 5 })).toThrow();
+  });
+
+  it('inserts into empty document', () => {
+    expect(applyOperation('', { type: 'insert', position: 0, text: 'hello' })).toBe('hello');
+  });
+
+  it('handles noop delete (count 0)', () => {
+    expect(applyOperation('hello', { type: 'delete', position: 0, count: 0 })).toBe('hello');
+  });
+});
+
+describe('applyOperations', () => {
+  it('applies a sequence of operations', () => {
+    const result = applyOperations('hello', [
+      { type: 'insert', position: 5, text: ' world' },
+      { type: 'delete', position: 0, count: 5 },
+    ]);
+    expect(result).toBe(' world');
+  });
+});
+
+describe('transformOp', () => {
+  // Helper to verify the convergence property using operation arrays
+  function verifyConvergence(doc: string, opA: Operation, opB: Operation) {
+    const [aPrime, bPrime] = transformOp(opA, opB);
+    const pathAB = applyOperations(applyOperation(doc, opA), bPrime);
+    const pathBA = applyOperations(applyOperation(doc, opB), aPrime);
+    expect(pathAB).toBe(pathBA);
+    return pathAB;
+  }
+
+  describe('insert vs insert', () => {
+    it('transforms two inserts at different positions', () => {
