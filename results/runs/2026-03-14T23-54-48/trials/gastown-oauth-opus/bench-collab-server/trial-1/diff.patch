+  it('transforms concurrent operations', async () => {
+    const doc = await createDocument('OT Test', 'abcde');
+    const ws1 = await connectWs(doc.id);
+    const ws2 = await connectWs(doc.id);
+    try {
+      await waitForMessage(ws1);
+      await waitForMessage(ws2);
+
+      // Both clients send edits based on version 0
+      // ws1: insert 'X' at position 0 -> 'Xabcde'
+      ws1.send(JSON.stringify({
+        type: 'edit',
+        operation: { type: 'insert', position: 0, text: 'X' },
+        baseVersion: 0,
+      }));
+
+      // Wait for ws1 ack before sending ws2 edit
+      const ack1 = await waitForMessage<AckMessage>(ws1);
+      expect(ack1.type).toBe('ack');
+
+      // ws2: insert 'Y' at position 5 based on original version
+      ws2.send(JSON.stringify({
+        type: 'edit',
+        operation: { type: 'insert', position: 5, text: 'Y' },
+        baseVersion: 0,
+      }));
+
+      // ws2 should receive the broadcast from ws1 first
+      const broadcast1 = await waitForMessage<BroadcastMessage>(ws2);
+      expect(broadcast1.type).toBe('operation');
+
+      // ws2 gets ack for its own operation
+      const ack2 = await waitForMessage<AckMessage>(ws2);
+      expect(ack2.type).toBe('ack');
+
+      // Verify final document state via REST
+      const res = await fetch(`${baseUrl}/documents/${doc.id}`);
+      const final = await res.json() as { content: string };
+      // Both inserts should be preserved: 'X' at start, 'Y' at end
+      expect(final.content).toBe('XabcdeY');
+    } finally {
+      ws1.close();
+      ws2.close();
+    }
+  });
+
