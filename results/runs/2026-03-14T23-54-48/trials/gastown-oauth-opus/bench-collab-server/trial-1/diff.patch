+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp, type AppInstance } from '../src/server.js';
+
+describe('Document REST API', () => {
+  let instance: AppInstance;
+
+  beforeEach(() => {
+    instance = createApp(':memory:');
+  });
+
+  afterEach(async () => {
+    await instance.stop();
+  });
+
+  describe('POST /api/documents', () => {
+    it('should create a document with title and content', async () => {
+      const res = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Test Doc', content: 'Hello world' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello world');
+      expect(res.body.id).toBeDefined();
+      expect(res.body.createdAt).toBeDefined();
+      expect(res.body.updatedAt).toBeDefined();
+    });
+
+    it('should create a document with empty content when not provided', async () => {
+      const res = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'No Content' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.content).toBe('');
+    });
+
+    it('should return 400 when title is missing', async () => {
+      const res = await request(instance.app)
+        .post('/api/documents')
+        .send({ content: 'No title' });
+
+      expect(res.status).toBe(400);
+      expect(res.body.error).toBeDefined();
+    });
+
+    it('should return 400 when title is empty', async () => {
+      const res = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: '  ' });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('should return 400 when body is empty', async () => {
+      const res = await request(instance.app)
+        .post('/api/documents')
+        .send({});
+
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('GET /api/documents', () => {
+    it('should return an empty array when no documents exist', async () => {
+      const res = await request(instance.app).get('/api/documents');
+
+      expect(res.status).toBe(200);
+      expect(res.body).toEqual([]);
+    });
+
+    it('should return all documents', async () => {
+      await request(instance.app).post('/api/documents').send({ title: 'Doc 1' });
+      await request(instance.app).post('/api/documents').send({ title: 'Doc 2' });
+
+      const res = await request(instance.app).get('/api/documents');
+
+      expect(res.status).toBe(200);
+      expect(res.body).toHaveLength(2);
+    });
+  });
+
+  describe('GET /api/documents/:id', () => {
+    it('should return a specific document', async () => {
+      const createRes = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'My Doc', content: 'Content' });
+
+      const res = await request(instance.app).get(`/api/documents/${createRes.body.id}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('Content');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      const res = await request(instance.app).get('/api/documents/nonexistent-id');
+
+      expect(res.status).toBe(404);
+      expect(res.body.error).toBeDefined();
+    });
+  });
+
+  describe('PUT /api/documents/:id', () => {
+    it('should update title', async () => {
+      const createRes = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Old Title', content: 'Content' });
+
+      const res = await request(instance.app)
+        .put(`/api/documents/${createRes.body.id}`)
+        .send({ title: 'New Title' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('New Title');
+      expect(res.body.content).toBe('Content');
+    });
+
+    it('should update content', async () => {
+      const createRes = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Title', content: 'Old content' });
+
+      const res = await request(instance.app)
+        .put(`/api/documents/${createRes.body.id}`)
+        .send({ content: 'New content' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('Title');
+      expect(res.body.content).toBe('New content');
+    });
+
+    it('should update both title and content', async () => {
+      const createRes = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Title', content: 'Content' });
+
+      const res = await request(instance.app)
+        .put(`/api/documents/${createRes.body.id}`)
+        .send({ title: 'New Title', content: 'New Content' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('New Title');
+      expect(res.body.content).toBe('New Content');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      const res = await request(instance.app)
+        .put('/api/documents/nonexistent-id')
+        .send({ title: 'Title' });
+
+      expect(res.status).toBe(404);
+    });
+
+    it('should return 400 when no fields provided', async () => {
+      const createRes = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Title' });
+
+      const res = await request(instance.app)
+        .put(`/api/documents/${createRes.body.id}`)
+        .send({});
+
+      expect(res.status).toBe(400);
+    });
+
+    it('should return 400 when title is empty string', async () => {
+      const createRes = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Title' });
+
+      const res = await request(instance.app)
+        .put(`/api/documents/${createRes.body.id}`)
+        .send({ title: '' });
+
+      expect(res.status).toBe(400);
+    });
+  });
+
+  describe('DELETE /api/documents/:id', () => {
+    it('should delete a document', async () => {
+      const createRes = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'To Delete' });
+
+      const res = await request(instance.app).delete(`/api/documents/${createRes.body.id}`);
+      expect(res.status).toBe(204);
+
+      const getRes = await request(instance.app).get(`/api/documents/${createRes.body.id}`);
+      expect(getRes.status).toBe(404);
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      const res = await request(instance.app).delete('/api/documents/nonexistent-id');
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('GET /api/documents/:id/versions', () => {
+    it('should return version history', async () => {
+      const createRes = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Versioned Doc', content: 'v1' });
+
+      await request(instance.app)
+        .put(`/api/documents/${createRes.body.id}`)
+        .send({ content: 'v2' });
+
+      await request(instance.app)
+        .put(`/api/documents/${createRes.body.id}`)
+        .send({ content: 'v3' });
+
+      const res = await request(instance.app)
+        .get(`/api/documents/${createRes.body.id}/versions`);
+
+      expect(res.status).toBe(200);
+      expect(res.body).toHaveLength(3);
+      expect(res.body[0].version).toBe(1);
+      expect(res.body[0].content).toBe('v1');
+      expect(res.body[1].version).toBe(2);
+      expect(res.body[1].content).toBe('v2');
+      expect(res.body[2].version).toBe(3);
+      expect(res.body[2].content).toBe('v3');
+    });
+
