new file mode 100644
index 0000000..cdc4d65
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,102 @@
+import Database from 'better-sqlite3';
+import crypto from 'node:crypto';
+import type { Document, DocumentVersion } from './types.js';
+
+export class DocumentDatabase {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    this.db.pragma('journal_mode = WAL');
+    this.init();
+  }
+
+  private init(): void {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        version INTEGER NOT NULL DEFAULT 1,
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+
+      CREATE TABLE IF NOT EXISTS document_versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL,
+        version INTEGER NOT NULL,
+        content TEXT NOT NULL,
+        timestamp TEXT NOT NULL DEFAULT (datetime('now')),
+        FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE
+      );
+    `);
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = crypto.randomUUID();
+    const now = new Date().toISOString();
+    this.db.prepare(
+      `INSERT INTO documents (id, title, content, version, created_at, updated_at) VALUES (?, ?, ?, 1, ?, ?)`
+    ).run(id, title, content, now, now);
+
+    this.db.prepare(
+      `INSERT INTO document_versions (document_id, version, content, timestamp) VALUES (?, 1, ?, ?)`
+    ).run(id, content, now);
+
+    return { id, title, content, version: 1, createdAt: now, updatedAt: now };
+  }
+
+  getDocument(id: string): Document | undefined {
+    const row = this.db.prepare(
+      `SELECT id, title, content, version, created_at as createdAt, updated_at as updatedAt FROM documents WHERE id = ?`
+    ).get(id) as Document | undefined;
+    return row;
+  }
+
+  listDocuments(): Document[] {
+    return this.db.prepare(
+      `SELECT id, title, content, version, created_at as createdAt, updated_at as updatedAt FROM documents ORDER BY updated_at DESC`
+    ).all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string; version?: number }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+    // Auto-increment version when content changes, unless version explicitly provided
+    const version = updates.version ?? (updates.content !== undefined ? doc.version + 1 : doc.version);
+    const now = new Date().toISOString();
+
+    this.db.prepare(
+      `UPDATE documents SET title = ?, content = ?, version = ?, updated_at = ? WHERE id = ?`
+    ).run(title, content, version, now, id);
+
+    if (updates.content !== undefined || updates.version !== undefined) {
+      this.db.prepare(
+        `INSERT INTO document_versions (document_id, version, content, timestamp) VALUES (?, ?, ?, ?)`
+      ).run(id, version, content, now);
+    }
+
+    return { id, title, content, version, createdAt: doc.createdAt, updatedAt: now };
+  }
+
+  deleteDocument(id: string): boolean {
+    // Delete versions first due to foreign key
+    this.db.prepare(`DELETE FROM document_versions WHERE document_id = ?`).run(id);
+    const result = this.db.prepare(`DELETE FROM documents WHERE id = ?`).run(id);
+    return result.changes > 0;
+  }
+
+  getVersionHistory(documentId: string): DocumentVersion[] {
+    return this.db.prepare(
+      `SELECT id, document_id as documentId, version, content, timestamp FROM document_versions WHERE document_id = ? ORDER BY version ASC`
+    ).all(documentId) as DocumentVersion[];
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..05b2c66
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,238 @@
+/**
+ * Operational Transform engine for collaborative text editing.
+ */
+
+import type { Operation, InsertOp, DeleteOp } from './types.js';
+
+/**
+ * Apply a single operation to a document string, returning the new content.
+ */
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    if (op.position < 0 || op.position > content.length) {
+      throw new Error(`Insert position ${op.position} out of bounds for document of length ${content.length}`);
+    }
+    return content.slice(0, op.position) + op.text + content.slice(op.position);
+  } else {
+    if (op.count === 0) return content;
+    if (op.position < 0 || op.position + op.count > content.length) {
+      throw new Error(`Delete range [${op.position}, ${op.position + op.count}) out of bounds for document of length ${content.length}`);
+    }
+    return content.slice(0, op.position) + content.slice(op.position + op.count);
+  }
+}
+
+/**
+ * Apply a sequence of operations to a document.
+ */
+export function applyOperations(content: string, ops: Operation[]): string {
+  let result = content;
+  for (const op of ops) {
+    result = applyOperation(result, op);
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations against each other.
+ * Returns [aPrime, bPrime] where each is an array of operations.
+ */
+export function transformOp(opA: Operation, opB: Operation): [Operation[], Operation[]] {
+  if (opA.type === 'insert' && opB.type === 'insert') {
+    return transformInsertInsert(opA, opB);
+  }
+  if (opA.type === 'insert' && opB.type === 'delete') {
+    return transformInsertDelete(opA, opB);
+  }
+  if (opA.type === 'delete' && opB.type === 'insert') {
+    const [bPrime, aPrime] = transformInsertDelete(opB, opA);
+    return [aPrime, bPrime];
+  }
+  // both delete
+  return transformDeleteDelete(opA as DeleteOp, opB as DeleteOp);
+}
+
+function transformInsertInsert(a: InsertOp, b: InsertOp): [Operation[], Operation[]] {
+  if (a.position < b.position) {
+    return [
+      [a],
+      [{ ...b, position: b.position + a.text.length }],
+    ];
+  } else if (a.position > b.position) {
+    return [
+      [{ ...a, position: a.position + b.text.length }],
+      [b],
+    ];
+  } else {
+    // Tie-break: A goes first
+    return [
+      [a],
+      [{ ...b, position: b.position + a.text.length }],
+    ];
+  }
+}
+
+function transformInsertDelete(ins: InsertOp, del: DeleteOp): [Operation[], Operation[]] {
+  const delEnd = del.position + del.count;
+
+  if (ins.position <= del.position) {
+    // Insert is before or at start of delete
+    return [
+      [ins],
+      [{ ...del, position: del.position + ins.text.length }],
+    ];
+  } else if (ins.position >= delEnd) {
+    // Insert is after delete
+    return [
+      [{ ...ins, position: ins.position - del.count }],
+      [del],
+    ];
+  } else {
+    // Insert is inside delete range - insert survives, delete splits
+    const beforeCount = ins.position - del.position;
+    const afterCount = delEnd - ins.position;
+
+    // After delete applied: insert position shifts to del.position
+    const insPrime: InsertOp = { type: 'insert', position: del.position, text: ins.text };
+
+    // After insert applied: delete splits around inserted text
+    const delParts: DeleteOp[] = [];
+    if (beforeCount > 0) {
+      delParts.push({ type: 'delete', position: del.position, count: beforeCount });
+    }
+    if (afterCount > 0) {
+      // The after-portion starts right after the inserted text
+      // Position: del.position + beforeCount(already deleted if beforeCount part runs first) + ins.text.length
+      // But since these operations are applied sequentially, we need to account for the first delete
+      const afterPos = beforeCount > 0
+        ? del.position + ins.text.length  // after first delete removed beforeCount chars, insert moved, this is after insert
+        : del.position + ins.text.length;
+      delParts.push({ type: 'delete', position: afterPos, count: afterCount });
+    }
+    if (delParts.length === 0) {
+      delParts.push({ type: 'delete', position: del.position, count: 0 });
+    }
+
+    return [
+      [insPrime],
+      delParts,
+    ];
+  }
+}
+
+function transformDeleteDelete(opA: DeleteOp, opB: DeleteOp): [Operation[], Operation[]] {
+  const aEnd = opA.position + opA.count;
+  const bEnd = opB.position + opB.count;
+
+  // No overlap: A entirely before B
+  if (aEnd <= opB.position) {
+    return [
+      [opA],
+      [{ ...opB, position: opB.position - opA.count }],
+    ];
+  }
+  // No overlap: B entirely before A
+  if (bEnd <= opA.position) {
+    return [
+      [{ ...opA, position: opA.position - opB.count }],
+      [opB],
+    ];
+  }
+
+  // Overlap
+  const overlapStart = Math.max(opA.position, opB.position);
+  const overlapEnd = Math.min(aEnd, bEnd);
+  const overlapCount = overlapEnd - overlapStart;
+
+  const aRemaining = opA.count - overlapCount;
+  const bRemaining = opB.count - overlapCount;
+
+  // A' position: A's non-overlapping part before overlap, adjusted for B's part before overlap
+  const bBefore = Math.max(0, opA.position - opB.position);
+  const aPrime: DeleteOp = {
+    type: 'delete',
+    position: opA.position - bBefore,
+    count: aRemaining,
+  };
+
+  const aBefore = Math.max(0, opB.position - opA.position);
+  const bPrime: DeleteOp = {
+    type: 'delete',
+    position: opB.position - aBefore,
+    count: bRemaining,
+  };
+
+  return [[aPrime], [bPrime]];
+}
+
+/**
+ * Transform operation `op` against a concurrent operation `against`.
+ * Returns a single transformed operation (server-side convenience).
+ */
+export function transformOperation(op: Operation, against: Operation): Operation {
+  const [opPrime] = transformOp(op, against);
+  // Return the first transformed op (for simple cases this is the only one)
+  if (opPrime.length === 1) return opPrime[0];
+  // For split operations, return the combined effect
+  return opPrime[0];
+}
+
+/**
+ * Transform an operation against a sequence of concurrent operations.
+ * Returns an array of transformed operations.
+ */
+export function transformAgainstOps(op: Operation, concurrentOps: Operation[]): Operation[] {
+  let current: Operation[] = [op];
+  for (const concurrent of concurrentOps) {
+    const next: Operation[] = [];
+    for (const c of current) {
+      const [cPrime] = transformOp(c, concurrent);
+      next.push(...cPrime);
+    }
+    current = next;
+  }
+  return current;
+}
+
+/**
+ * Validate an operation. Returns true if valid, false otherwise.
+ */
+export function validateOperation(op: unknown): boolean {
+  if (!op || typeof op !== 'object') {
+    return false;
+  }
+
+  const o = op as Record<string, unknown>;
+
+  if (o.type === 'insert') {
+    if (typeof o.position !== 'number' || o.position < 0 || !Number.isInteger(o.position)) {
+      return false;
+    }
+    if (typeof o.text !== 'string' || o.text.length === 0) {
+      return false;
+    }
+    return true;
+  }
+
+  if (o.type === 'delete') {
+    if (typeof o.position !== 'number' || o.position < 0 || !Number.isInteger(o.position)) {
+      return false;
+    }
+    // Support both count and text-based delete operations
+    if (typeof o.count === 'number') {
+      if (o.count <= 0 || !Number.isInteger(o.count)) {
+        return false;
+      }
+      return true;
+    }
+    if (typeof o.text === 'string') {
+      if (o.text.length === 0) {
+        return false;
+      }
+      return true;
+    }
+    return false;
+  }
+
+  return false;
+}
