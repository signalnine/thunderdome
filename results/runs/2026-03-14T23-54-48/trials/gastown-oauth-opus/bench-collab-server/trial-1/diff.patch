+
+  it('supports 10 concurrent clients', async () => {
+    const doc = await createDocument('Concurrent Test', 'start');
+    const clients: WebSocket[] = [];
+
+    try {
+      // Connect 10 clients
+      for (let i = 0; i < 10; i++) {
+        const ws = await connectWs(doc.id);
+        await waitForMessage(ws);
+        clients.push(ws);
+      }
+
+      // Each client sends an insert
+      for (let i = 0; i < 10; i++) {
+        clients[i].send(JSON.stringify({
+          type: 'edit',
+          operation: { type: 'insert', position: 0, text: String(i) },
+          baseVersion: i, // Each client sees previous versions
+        }));
+
+        // Wait for ack
+        const ack = await waitForMessage<AckMessage>(clients[i]);
+        expect(ack.type).toBe('ack');
+        expect(ack.version).toBe(i + 1);
+
+        // Drain broadcast messages from other clients
+        for (let j = 0; j < 10; j++) {
+          if (j !== i) {
+            await waitForMessage(clients[j]);
+          }
+        }
+      }
+
+      // Verify final state
+      const res = await fetch(`${baseUrl}/documents/${doc.id}`);
+      const final = await res.json() as { content: string };
+      // All 10 digits should be present along with 'start'
+      for (let i = 0; i < 10; i++) {
+        expect(final.content).toContain(String(i));
+      }
+      expect(final.content).toContain('start');
+      expect(final.content.length).toBe(15); // 10 digits + 'start' (5 chars)
+    } finally {
+      for (const ws of clients) {
+        ws.close();
+      }
+    }
+  });
+});
