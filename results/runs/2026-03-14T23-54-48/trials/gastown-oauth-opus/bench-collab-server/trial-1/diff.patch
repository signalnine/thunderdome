+      const a: InsertOp = { type: 'insert', position: 0, text: 'A' };
+      const b: InsertOp = { type: 'insert', position: 5, text: 'B' };
+      const result = verifyConvergence(doc, a, b);
+      expect(result).toBe('AhelloB');
+    });
+
+    it('transforms two inserts at same position (tiebreak)', () => {
+      const doc = 'hello';
+      const a: InsertOp = { type: 'insert', position: 2, text: 'A' };
