+      expect(result).toBe('aXe');
+    });
+  });
+
+  describe('delete vs insert', () => {
+    it('transforms delete before insert', () => {
+      const doc = 'abcde';
+      const del: DeleteOp = { type: 'delete', position: 0, count: 2 };
+      const ins: InsertOp = { type: 'insert', position: 4, text: 'X' };
