new file mode 100644
index 0000000..9c854f0
--- /dev/null
+++ b/src/routes.ts
@@ -0,0 +1,75 @@
+import { Router } from 'express';
+import type { DocumentDatabase } from './db.js';
+
+export function createDocumentRouter(db: DocumentDatabase): Router {
+  const router = Router();
+
+  // List all documents
+  router.get('/documents', (_req, res) => {
+    const docs = db.listDocuments();
+    res.json(docs);
+  });
+
+  // Create a document
+  router.post('/documents', (req, res) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== 'string' || title.trim().length === 0) {
+      res.status(400).json({ error: 'Title is required and must be a non-empty string' });
+      return;
+    }
+    const doc = db.createDocument(title, content || '');
+    res.status(201).json(doc);
+  });
+
+  // Get a document by ID
+  router.get('/documents/:id', (req, res) => {
+    const doc = db.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document
+  router.put('/documents/:id', (req, res) => {
+    const { title, content } = req.body;
+    if (title !== undefined && (typeof title !== 'string' || title.trim().length === 0)) {
+      res.status(400).json({ error: 'Title must be a non-empty string' });
+      return;
+    }
+    if (title === undefined && content === undefined) {
+      res.status(400).json({ error: 'At least one of title or content must be provided' });
+      return;
+    }
+    const doc = db.updateDocument(req.params.id, { title, content });
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req, res) => {
+    const deleted = db.deleteDocument(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get version history for a document
+  router.get('/documents/:id/versions', (req, res) => {
+    const doc = db.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = db.getVersionHistory(req.params.id);
+    res.json(versions);
+  });
+
+  return router;
+}
