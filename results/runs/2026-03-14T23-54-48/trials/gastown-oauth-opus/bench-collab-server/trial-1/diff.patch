+import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from 'vitest';
+import WebSocket from 'ws';
+import { createApp } from '../src/server.js';
+import type { AppInstance, SyncMessage, BroadcastMessage, AckMessage, ErrorMessage } from '../src/types.js';
+
+let app: AppInstance;
+let port: number;
+let baseUrl: string;
+
+function wsUrl(docId: string): string {
+  return `ws://localhost:${port}/ws/documents/${docId}`;
+}
+
+/** Message queue for a WebSocket, to avoid race conditions */
+const messageQueues = new WeakMap<WebSocket, Array<unknown>>();
+const messageWaiters = new WeakMap<WebSocket, Array<(msg: unknown) => void>>();
+
+function setupMessageQueue(ws: WebSocket): void {
+  const queue: Array<unknown> = [];
+  const waiters: Array<(msg: unknown) => void> = [];
+  messageQueues.set(ws, queue);
+  messageWaiters.set(ws, waiters);
+  ws.on('message', (data) => {
+    const parsed = JSON.parse(data.toString());
+    if (waiters.length > 0) {
+      const waiter = waiters.shift()!;
+      waiter(parsed);
+    } else {
+      queue.push(parsed);
+    }
+  });
+}
+
+function waitForMessage<T = SyncMessage | BroadcastMessage | AckMessage | ErrorMessage>(
+  ws: WebSocket,
+  timeout = 5000
+): Promise<T> {
+  return new Promise((resolve, reject) => {
+    const queue = messageQueues.get(ws);
+    const waiters = messageWaiters.get(ws);
+    if (!queue || !waiters) {
+      reject(new Error('WebSocket message queue not set up'));
+      return;
+    }
+    if (queue.length > 0) {
+      resolve(queue.shift() as T);
+      return;
+    }
+    const timer = setTimeout(() => {
+      const idx = waiters.indexOf(handler);
+      if (idx >= 0) waiters.splice(idx, 1);
+      reject(new Error('Timeout waiting for message'));
+    }, timeout);
+    const handler = (msg: unknown) => {
+      clearTimeout(timer);
+      resolve(msg as T);
+    };
+    waiters.push(handler);
+  });
+}
+
+function connectWs(docId: string): Promise<WebSocket> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(docId));
+    setupMessageQueue(ws);
+    ws.on('open', () => resolve(ws));
+    ws.on('error', reject);
+  });
+}
