+
+describe('validateOperation', () => {
+  it('validates a correct insert operation', () => {
+    expect(validateOperation({ type: 'insert', position: 0, text: 'hello' })).toBe(true);
+  });
+
+  it('validates a correct delete operation', () => {
+    expect(validateOperation({ type: 'delete', position: 0, count: 5 })).toBe(true);
+  });
+
+  it('rejects null', () => {
+    expect(validateOperation(null)).toBe(false);
+  });
+
+  it('rejects non-objects', () => {
+    expect(validateOperation('insert')).toBe(false);
+    expect(validateOperation(42)).toBe(false);
