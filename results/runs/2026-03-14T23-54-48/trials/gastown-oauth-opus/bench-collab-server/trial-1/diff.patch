+  it('handles client disconnection gracefully', async () => {
+    const doc = await createDocument('Disconnect Test', 'hello');
+    const ws1 = await connectWs(doc.id);
+    const ws2 = await connectWs(doc.id);
+    try {
+      await waitForMessage(ws1);
+      await waitForMessage(ws2);
+
+      // Disconnect ws1
+      ws1.close();
+
+      // Wait a bit for cleanup
+      await new Promise((resolve) => setTimeout(resolve, 100));
+
+      // ws2 should still be able to send edits
+      ws2.send(JSON.stringify({
+        type: 'edit',
+        operation: { type: 'insert', position: 5, text: '!' },
