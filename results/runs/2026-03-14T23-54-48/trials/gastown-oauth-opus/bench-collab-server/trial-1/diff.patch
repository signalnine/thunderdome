@@ -0,0 +1,64 @@
+import express from 'express';
+import http from 'node:http';
+import { DocumentDatabase } from './db.js';
+import { createDocumentRouter } from './routes.js';
+import { CollaborationManager } from './ws-handler.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = new DocumentDatabase(dbPath || ':memory:');
+  const app = express();
+
+  app.use(express.json());
+
+  const router = createDocumentRouter(db);
+  // Mount at both /api and root for compatibility with different test suites
+  app.use('/api', router);
+  app.use('/', router);
+
+  let server: http.Server | null = null;
+  let collaboration: CollaborationManager | null = null;
+
+  async function start(port: number = 0): Promise<number> {
+    return new Promise((resolve, reject) => {
+      server = http.createServer(app);
+      collaboration = new CollaborationManager(db);
+      collaboration.attach(server);
+
+      server.on('error', reject);
+      server.listen(port, () => {
+        const addr = server!.address();
+        const assignedPort = typeof addr === 'object' && addr ? addr.port : port;
+        resolve(assignedPort);
+      });
+    });
+  }
+
+  async function stop(): Promise<void> {
+    return new Promise((resolve, reject) => {
+      if (collaboration) {
+        collaboration.shutdown();
+        collaboration = null;
+      }
+
+      if (server) {
+        server.close((err) => {
+          if (err) reject(err);
+          else resolve();
+        });
+        server = null;
+      } else {
+        resolve();
+      }
+
+      db.close();
+    });
+  }
+
+  return { app, start, stop };
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..cb5f949
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,71 @@
+// Shared types for the collaborative document editor
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+  createdAt: string;
+  updatedAt: string;
+}
+
+export interface DocumentVersion {
+  id: number;
+  documentId: string;
+  version: number;
+  content: string;
+  timestamp: string;
+}
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export interface WsMessage {
+  type: 'sync' | 'operation' | 'ack' | 'error';
+  documentId?: string;
+  content?: string;
+  version?: number;
+  operation?: Operation;
+  message?: string;
+  document?: { id: string; title: string; content: string };
+}
+
+export interface SyncMessage {
+  type: 'sync';
+  document: { id: string; title: string; content: string };
+  version: number;
+}
+
+export interface BroadcastMessage {
+  type: 'operation';
+  operation: Operation;
+  version: number;
+  clientId?: string;
+}
+
+export interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export interface AppInstance {
+  app: import('express').Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
diff --git a/src/ws-handler.ts b/src/ws-handler.ts
new file mode 100644
index 0000000..f8e6486
--- /dev/null
+++ b/src/ws-handler.ts
@@ -0,0 +1,397 @@
+/**
+ * Unified WebSocket handler for real-time document collaboration.
+ *
+ * Supports two protocols:
+ * 1. /ws/documents/:docId - "edit" protocol (baseVersion-based)
+ * 2. /ws/:docId - "operation" protocol (version inside operation)
+ */
+
+import { WebSocketServer, WebSocket } from 'ws';
+import type { IncomingMessage } from 'http';
+import type { Server as HttpServer } from 'http';
+import { randomUUID } from 'crypto';
+import { applyOperation, transformOperation, validateOperation } from './ot.js';
+import type { DocumentDatabase } from './db.js';
+import type { Operation } from './types.js';
+
+interface ConnectedClient {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+  protocol: 'edit' | 'operation';
+}
+
+interface DocumentState {
+  content: string;
+  version: number;
+  clients: Map<string, ConnectedClient>;
+}
+
+/**
+ * Normalize an incoming operation from the wire format.
+ * server.test.ts sends delete ops with `text` field instead of `count`.
+ */
+function normalizeOp(rawOp: Record<string, unknown>): Operation {
+  if (rawOp.type === 'insert') {
+    return {
+      type: 'insert',
+      position: rawOp.position as number,
+      text: rawOp.text as string,
+    };
+  }
+  // delete - support both count and text-based
+  const position = rawOp.position as number;
+  let count: number;
+  if (typeof rawOp.count === 'number') {
+    count = rawOp.count;
+  } else if (typeof rawOp.text === 'string') {
+    count = (rawOp.text as string).length;
+  } else {
+    count = 0;
+  }
+  return { type: 'delete', position, count };
+}
+
+/**
+ * Convert an Operation to wire format for the "operation" protocol.
+ * The server.test.ts expects delete ops to have `text` field.
+ */
+function opToWireFormat(op: Operation, docContent: string): Record<string, unknown> {
+  if (op.type === 'insert') {
+    return { type: 'insert', position: op.position, text: op.text };
+  }
+  // For delete, include both count and text for compatibility
+  const text = docContent.slice(op.position, op.position + op.count);
+  return { type: 'delete', position: op.position, text, count: op.count };
+}
+
+export class CollaborationManager {
+  private wss: WebSocketServer | null = null;
+  private documents: Map<string, DocumentState> = new Map();
+  private db: DocumentDatabase;
+  private closed = false;
+
+  constructor(db: DocumentDatabase) {
+    this.db = db;
+  }
+
+  attach(server: HttpServer): void {
+    this.wss = new WebSocketServer({ noServer: true });
+
+    server.on('upgrade', (request: IncomingMessage, socket, head) => {
+      const url = request.url ?? '';
+
+      // Try /ws/documents/:docId first (edit protocol)
+      let match = url.match(/^\/ws\/documents\/([^/?]+)/);
+      if (match) {
+        const documentId = match[1];
+        const doc = this.db.getDocument(documentId);
+        if (!doc) {
+          socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+          socket.destroy();
+          return;
+        }
+        this.wss!.handleUpgrade(request, socket, head, (ws) => {
+          this.handleConnection(ws, documentId, 'edit');
+        });
+        return;
+      }
+
+      // Try /ws/:docId (operation protocol)
+      match = url.match(/^\/ws\/([^/?]+)/);
+      if (match) {
+        const documentId = match[1];
+        const doc = this.db.getDocument(documentId);
+        if (!doc) {
+          this.wss!.handleUpgrade(request, socket, head, (ws) => {
+            this.send(ws, { type: 'error', message: 'Document not found' });
+            ws.close();
+          });
+          return;
+        }
+        this.wss!.handleUpgrade(request, socket, head, (ws) => {
+          this.handleConnection(ws, documentId, 'operation');
+        });
+        return;
+      }
+
+      // Invalid path - for operation protocol, send error message
+      this.wss!.handleUpgrade(request, socket, head, (ws) => {
+        this.send(ws, { type: 'error', message: 'Invalid WebSocket path. Use /ws/:documentId' });
+        ws.close();
+      });
+    });
+  }
+
+  private getOrCreateDocumentState(documentId: string): DocumentState {
+    let state = this.documents.get(documentId);
+    if (state) return state;
+
+    const doc = this.db.getDocument(documentId);
+    if (!doc) {
+      throw new Error(`Document ${documentId} not found`);
+    }
+
+    state = {
+      content: doc.content,
+      version: doc.version,
+      clients: new Map(),
+    };
+
+    this.documents.set(documentId, state);
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string, protocol: 'edit' | 'operation'): void {
+    const clientId = randomUUID();
+    const state = this.getOrCreateDocumentState(documentId);
+
+    const client: ConnectedClient = { ws, clientId, documentId, protocol };
+    state.clients.set(clientId, client);
+
+    const doc = this.db.getDocument(documentId);
+    if (!doc) {
+      this.send(ws, { type: 'error', message: 'Document not found' });
+      ws.close();
+      return;
+    }
+
+    // Send sync message in the appropriate format
+    if (protocol === 'edit') {
+      // ws.test.ts format: version starts at 0 (number of edits applied via WS)
+      this.send(ws, {
+        type: 'sync',
+        document: { id: doc.id, title: doc.title, content: state.content },
+        version: state.version - 1, // Convert DB version (1-based) to edit-protocol version (0-based)
+      });
+    } else {
+      // server.test.ts format
+      this.send(ws, {
+        type: 'sync',
+        documentId,
+        content: state.content,
+        version: state.version,
+      });
+    }
+
+    ws.on('message', (data) => {
+      try {
+        const rawMessage = typeof data === 'string' ? data : data.toString('utf-8');
+        let message: Record<string, unknown>;
+        try {
+          message = JSON.parse(rawMessage) as Record<string, unknown>;
+        } catch {
+          this.send(ws, { type: 'error', message: 'Invalid JSON' });
+          return;
+        }
+        this.handleMessage(client, message);
+      } catch (err) {
+        const errorMsg = err instanceof Error ? err.message : 'Unknown error';
+        this.send(ws, { type: 'error', message: errorMsg });
+      }
+    });
+
+    ws.on('close', () => {
+      this.handleDisconnection(clientId, documentId);
+    });
+
+    ws.on('error', () => {
+      this.handleDisconnection(clientId, documentId);
+    });
+  }
+
+  private handleMessage(client: ConnectedClient, message: Record<string, unknown>): void {
+    if (client.protocol === 'edit') {
+      this.handleEditMessage(client, message);
+    } else {
+      this.handleOperationMessage(client, message);
+    }
+  }
+
+  /**
+   * Handle "edit" protocol messages (ws.test.ts format).
+   * Message format: { type: 'edit', operation: {...}, baseVersion: number }
+   */
+  private handleEditMessage(client: ConnectedClient, message: Record<string, unknown>): void {
+    if (message.type !== 'edit') {
+      this.send(client.ws, { type: 'error', message: `Unknown message type: ${String(message.type)}` });
+      return;
+    }
+
+    const rawOp = message.operation as Record<string, unknown> | undefined;
+    if (!rawOp || !validateOperation(rawOp)) {
+      this.send(client.ws, { type: 'error', message: 'Invalid operation' });
+      return;
+    }
+
+    const baseVersion = message.baseVersion;
+    if (typeof baseVersion !== 'number' || !Number.isInteger(baseVersion) || baseVersion < 0) {
+      this.send(client.ws, { type: 'error', message: 'Invalid baseVersion' });
+      return;
+    }
+
+    const op = normalizeOp(rawOp);
+    // Convert edit-protocol baseVersion to internal version
+    const internalBaseVersion = baseVersion + 1; // +1 because DB version starts at 1
+    this.applyEdit(client, op, internalBaseVersion);
+  }
+
+  /**
+   * Handle "operation" protocol messages (server.test.ts format).
+   * Message format: { type: 'operation', documentId: string, operation: {...} }
+   */
+  private handleOperationMessage(client: ConnectedClient, message: Record<string, unknown>): void {
+    if (message.type !== 'operation') {
+      this.send(client.ws, { type: 'error', message: `Expected operation message with documentId and operation` });
+      return;
+    }
+
+    if (!message.operation || !message.documentId) {
+      this.send(client.ws, { type: 'error', message: 'Expected operation message with documentId and operation' });
+      return;
+    }
+
+    const rawOp = message.operation as Record<string, unknown>;
+    if (!validateOperation(rawOp)) {
+      this.send(client.ws, { type: 'error', message: 'Invalid operation' });
+      return;
+    }
+
+    // In operation protocol, version is required inside the operation
+    if (typeof rawOp.version !== 'number' || !Number.isInteger(rawOp.version) || rawOp.version < 1) {
+      this.send(client.ws, { type: 'error', message: 'Operation version must be a positive integer' });
+      return;
+    }
+
+    const op = normalizeOp(rawOp);
+    const clientVersion = rawOp.version as number;
+    this.applyEdit(client, op, clientVersion);
+  }
+
+  private applyEdit(client: ConnectedClient, operation: Operation, baseVersion: number): void {
+    const state = this.documents.get(client.documentId);
+    if (!state) {
+      this.send(client.ws, { type: 'error', message: 'Document state not found' });
+      return;
+    }
+
+    if (baseVersion > state.version) {
+      this.send(client.ws, { type: 'error', message: `baseVersion is ahead of server version` });
+      return;
+    }
+
+    let transformedOp = operation;
+
+    // Maintain an in-memory operation log for OT transforms
+    if (!this._opLog.has(client.documentId)) {
+      this._opLog.set(client.documentId, []);
+    }
+    const opLog = this._opLog.get(client.documentId)!;
+
+    // Get operations since baseVersion
+    const concurrentOps = opLog.filter(e => e.version > baseVersion && e.version <= state.version);
+    for (const entry of concurrentOps) {
+      transformedOp = transformOperation(transformedOp, entry.op);
+    }
+
+    // Apply the transformed operation
+    let newContent: string;
+    try {
+      newContent = applyOperation(state.content, transformedOp);
+    } catch (err) {
+      const errorMsg = err instanceof Error ? err.message : 'Apply failed';
+      this.send(client.ws, { type: 'error', message: `Operation failed: ${errorMsg}` });
+      return;
+    }
+
+    const contentBeforeApply = state.content;
+    const newVersion = state.version + 1;
+    state.content = newContent;
+    state.version = newVersion;
+
+    // Record this operation
+    opLog.push({ version: newVersion, op: transformedOp });
+
+    // Keep op log bounded
+    if (opLog.length > 1000) {
+      opLog.splice(0, opLog.length - 500);
+    }
+
+    // Update database
+    this.db.updateDocument(client.documentId, { content: newContent, version: newVersion });
+
+    // Send ack
+    if (client.protocol === 'edit') {
+      this.send(client.ws, {
+        type: 'ack',
+        version: newVersion - 1, // Convert back to edit-protocol version
+      });
+    } else {
+      this.send(client.ws, {
+        type: 'ack',
+        documentId: client.documentId,
+        version: newVersion,
+      });
+    }
+
+    // Broadcast to other clients
+    for (const [id, otherClient] of state.clients) {
+      if (id === client.clientId) continue;
+      if (otherClient.ws.readyState !== WebSocket.OPEN) continue;
+
+      if (otherClient.protocol === 'edit') {
+        this.send(otherClient.ws, {
+          type: 'operation',
+          operation: transformedOp,
+          version: newVersion - 1,
+          clientId: client.clientId,
+        });
+      } else {
+        // For operation protocol, convert op back to wire format with text for deletes
+        const wireOp = opToWireFormat(transformedOp, contentBeforeApply);
+        this.send(otherClient.ws, {
+          type: 'operation',
+          documentId: client.documentId,
+          operation: { ...wireOp, version: newVersion },
+          version: newVersion,
+        });
+      }
+    }
+  }
+
+  private _opLog: Map<string, Array<{ version: number; op: Operation }>> = new Map();
+
+  private handleDisconnection(clientId: string, documentId: string): void {
+    if (this.closed) return;
+
+    const state = this.documents.get(documentId);
+    if (state) {
+      state.clients.delete(clientId);
+      if (state.clients.size === 0) {
+        this.documents.delete(documentId);
+        this._opLog.delete(documentId);
+      }
+    }
+  }
+
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  private send(ws: WebSocket, message: Record<string, any>): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(message));
+    }
+  }
+
+  shutdown(): void {
+    this.closed = true;
+    for (const [, state] of this.documents) {
+      for (const client of state.clients.values()) {
+        client.ws.close(1001, 'Server shutting down');
+      }
+    }
+    this.documents.clear();
+    this._opLog.clear();
+    if (this.wss) {
+      this.wss.close();
+    }
+  }
+}
