@@ -0,0 +1,432 @@
+/**
+ * Cell reference parsing, coordinate conversion, range expansion,
+ * and dependency graph with circular reference detection.
+ */
+
+// --- Cell reference regex ---
+// Matches cell references like A1, B2, Z100, AA1, AZ99, etc.
+const CELL_REF_REGEX = /^([A-Z]+)(\d+)$/;
+
+/**
+ * Parse a cell reference string (e.g. "A1", "AA23") into column letters and row number.
+ * Returns null if the string is not a valid cell reference.
+ */
+export function parseCellRef(ref: string): { col: string; row: number } | null {
+  const match = ref.toUpperCase().match(CELL_REF_REGEX);
+  if (!match) return null;
+  const col = match[1];
+  const row = parseInt(match[2], 10);
+  if (row < 1) return null;
+  return { col, row };
+}
+
+/**
+ * Convert column letters to a 1-based column number.
+ * A -> 1, B -> 2, ..., Z -> 26, AA -> 27, AZ -> 52, BA -> 53, etc.
+ */
+export function columnLetterToNumber(letters: string): number {
+  let result = 0;
+  const upper = letters.toUpperCase();
+  for (let i = 0; i < upper.length; i++) {
+    result = result * 26 + (upper.charCodeAt(i) - 64); // 'A' is 65, so 65-64=1
+  }
+  return result;
+}
+
+/**
+ * Convert a 1-based column number to column letters.
+ * 1 -> A, 2 -> B, ..., 26 -> Z, 27 -> AA, 52 -> AZ, 53 -> BA, etc.
+ */
+export function columnNumberToLetter(num: number): string {
+  let result = '';
+  let n = num;
+  while (n > 0) {
+    n--; // make 0-indexed
+    result = String.fromCharCode(65 + (n % 26)) + result;
+    n = Math.floor(n / 26);
+  }
+  return result;
+}
+
+/**
+ * Convert a cell reference string to numeric coordinates { col: number, row: number }.
+ * Both are 1-based.
+ */
+export function cellRefToCoords(ref: string): { col: number; row: number } | null {
+  const parsed = parseCellRef(ref);
+  if (!parsed) return null;
+  return { col: columnLetterToNumber(parsed.col), row: parsed.row };
+}
+
+/**
+ * Convert numeric coordinates to a cell reference string.
+ */
+export function coordsToCellRef(col: number, row: number): string {
+  return columnNumberToLetter(col) + row.toString();
+}
+
+/**
+ * Normalize a cell reference to uppercase canonical form (e.g. "a1" -> "A1").
+ */
+export function normalizeCellRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+/**
+ * Expand a range like "A1:C3" into a flat list of cell reference strings.
+ * Handles column ranges (A1:A5), row ranges (A1:C1), and block ranges (A1:C3).
+ */
+export function expandRange(rangeStr: string): string[] {
+  const parts = rangeStr.split(':');
+  if (parts.length !== 2) return [];
+
+  const start = cellRefToCoords(parts[0].trim());
+  const end = cellRefToCoords(parts[1].trim());
+  if (!start || !end) return [];
+
+  const minCol = Math.min(start.col, end.col);
+  const maxCol = Math.max(start.col, end.col);
+  const minRow = Math.min(start.row, end.row);
+  const maxRow = Math.max(start.row, end.row);
+
+  const cells: string[] = [];
+  for (let row = minRow; row <= maxRow; row++) {
+    for (let col = minCol; col <= maxCol; col++) {
+      cells.push(coordsToCellRef(col, row));
+    }
+  }
+  return cells;
+}
+
+/**
+ * Extract all cell references from a formula string.
+ * This finds standalone cell references (not part of a range).
+ */
+export function extractCellRefs(formula: string): string[] {
+  // Match cell refs, but not those that are part of ranges (handled separately)
+  const refs: string[] = [];
+  // Match all cell references (including those in ranges)
+  const allRefRegex = /[A-Z]+\d+/gi;
+  let match: RegExpExecArray | null;
+  while ((match = allRefRegex.exec(formula)) !== null) {
+    const ref = match[0].toUpperCase();
+    if (parseCellRef(ref)) {
+      refs.push(ref);
+    }
+  }
+  return refs;
+}
+
+/**
+ * Extract all ranges from a formula string (e.g. "A1:C3").
+ */
+export function extractRanges(formula: string): string[] {
+  const rangeRegex = /([A-Z]+\d+)\s*:\s*([A-Z]+\d+)/gi;
+  const ranges: string[] = [];
+  let match: RegExpExecArray | null;
+  while ((match = rangeRegex.exec(formula)) !== null) {
+    ranges.push(match[1].toUpperCase() + ':' + match[2].toUpperCase());
+  }
+  return ranges;
+}
+
+/**
+ * Extract all cell dependencies from a formula.
+ * This expands ranges into individual cell refs and combines with standalone refs.
+ */
+export function extractDependencies(formula: string): string[] {
+  const deps = new Set<string>();
+
+  // First, find ranges and expand them
+  const ranges = extractRanges(formula);
+  for (const range of ranges) {
+    const expanded = expandRange(range);
+    for (const ref of expanded) {
+      deps.add(ref);
+    }
+  }
+
+  // Remove range text from formula to find standalone refs
+  let formulaWithoutRanges = formula;
+  const rangeRegex = /[A-Z]+\d+\s*:\s*[A-Z]+\d+/gi;
+  formulaWithoutRanges = formulaWithoutRanges.replace(rangeRegex, '');
+
+  // Find standalone refs
+  const standaloneRefs = extractCellRefs(formulaWithoutRanges);
+  for (const ref of standaloneRefs) {
+    deps.add(ref);
+  }
+
+  return Array.from(deps);
+}
+
+
+// --- Dependency Graph ---
+
+export class DependencyGraph {
+  // Maps a cell to the set of cells it depends on (its formula references)
+  private dependencies: Map<string, Set<string>> = new Map();
+  // Maps a cell to the set of cells that depend on it (reverse index)
+  private dependents: Map<string, Set<string>> = new Map();
+
+  /**
+   * Set the dependencies for a cell. Replaces any previous dependencies.
+   * @param cell - The cell reference (e.g. "A1")
+   * @param deps - The cell references that this cell depends on
+   */
+  setDependencies(cell: string, deps: string[]): void {
+    const normalizedCell = normalizeCellRef(cell);
+    const normalizedDeps = deps.map(normalizeCellRef);
+
+    // Remove old reverse index entries
+    this.clearDependencies(normalizedCell);
+
+    // Set new dependencies
+    if (normalizedDeps.length > 0) {
+      this.dependencies.set(normalizedCell, new Set(normalizedDeps));
+    }
+
+    // Update reverse index
+    for (const dep of normalizedDeps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(normalizedCell);
+    }
+  }
+
+  /**
+   * Clear all dependencies for a cell (e.g. when it's set to a plain value).
+   */
+  clearDependencies(cell: string): void {
+    const normalizedCell = normalizeCellRef(cell);
+    const oldDeps = this.dependencies.get(normalizedCell);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        const rev = this.dependents.get(dep);
+        if (rev) {
+          rev.delete(normalizedCell);
+          if (rev.size === 0) {
+            this.dependents.delete(dep);
+          }
+        }
+      }
+      this.dependencies.delete(normalizedCell);
+    }
+  }
+
+  /**
+   * Get the direct dependencies of a cell (what it references).
+   */
+  getDependencies(cell: string): string[] {
+    const deps = this.dependencies.get(normalizeCellRef(cell));
+    return deps ? Array.from(deps) : [];
+  }
+
+  /**
+   * Get the direct dependents of a cell (what references it).
+   */
+  getDependents(cell: string): string[] {
+    const rev = this.dependents.get(normalizeCellRef(cell));
+    return rev ? Array.from(rev) : [];
+  }
+
+  /**
+   * Get all cells that transitively depend on the given cell.
+   * Uses BFS to find all downstream dependents.
+   */
+  getAllDependents(cell: string): string[] {
+    const normalizedCell = normalizeCellRef(cell);
+    const visited = new Set<string>();
+    const queue = [normalizedCell];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const directDependents = this.getDependents(current);
+      for (const dep of directDependents) {
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          queue.push(dep);
+        }
+      }
+    }
+
+    return Array.from(visited);
+  }
+
+  /**
+   * Get a topological ordering of cells that need to be recalculated
+   * when a given cell changes. Returns cells in order such that
+   * dependencies are calculated before dependents.
+   */
+  getRecalcOrder(cell: string): string[] {
+    const normalizedCell = normalizeCellRef(cell);
+    const allDeps = this.getAllDependents(normalizedCell);
+
+    // Topological sort using Kahn's algorithm on the subgraph.
+    // The source cell is treated as already computed, so we only count
+    // in-degrees from other nodes *within* the subgraph.
+    const subgraph = new Set(allDeps);
+    const inDegree = new Map<string, number>();
+
+    for (const node of subgraph) {
+      inDegree.set(node, 0);
+    }
+
+    // For each node in the subgraph, count how many of its dependencies
+    // are also in the subgraph (not counting the source cell, which is
+    // already resolved).
+    for (const node of subgraph) {
+      const deps = this.getDependencies(node);
+      let count = 0;
+      for (const dep of deps) {
+        if (subgraph.has(dep)) {
+          count++;
+        }
+      }
+      inDegree.set(node, count);
+    }
+
+    const queue: string[] = [];
+    for (const [node, degree] of inDegree) {
+      if (degree === 0) {
+        queue.push(node);
+      }
+    }
+
+    const result: string[] = [];
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      result.push(current);
+      const dependents = this.getDependents(current);
+      for (const dep of dependents) {
+        if (subgraph.has(dep)) {
+          const newDegree = (inDegree.get(dep) ?? 0) - 1;
+          inDegree.set(dep, newDegree);
+          if (newDegree === 0) {
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    return result;
+  }
+
+  /**
+   * Check if setting the given cell to depend on the given deps would create
+   * a circular reference. Uses DFS cycle detection.
+   * @returns true if a cycle would be created
+   */
+  wouldCreateCycle(cell: string, deps: string[]): boolean {
+    const normalizedCell = normalizeCellRef(cell);
+    const normalizedDeps = deps.map(normalizeCellRef);
+
+    // Check if cell depends (transitively) on itself through the proposed deps
+    // We do DFS from each dep, following the existing dependency graph edges
+    // (dependents direction), checking if we can reach `cell`
+    // But actually we need to check if any dep can reach cell through the
+    // *existing* dependency chains. The question is: does `cell` appear
+    // in the transitive dependencies of any of the proposed deps?
+    // Or equivalently: can we reach any of the proposed deps from cell
+    // by following the dependents graph?
+    //
+    // Simpler approach: temporarily set the dependencies and check for cycles
+    // using DFS, then revert.
+    //
+    // Most efficient: DFS from `cell` following the existing dependents edges.
+    // If we can reach any of the proposed deps, then adding cell->deps creates a cycle.
+    // Wait, that's backwards. If cell depends on dep, and dep already (transitively)
+    // depends on cell, that's a cycle. So we check: from each proposed dep,
+    // can we reach `cell` by following the existing dependency edges (not dependents)?
+    // i.e., does dep transitively depend on cell?
+
+    for (const dep of normalizedDeps) {
+      if (dep === normalizedCell) return true; // self-reference
+
+      // DFS from dep, following dependencies (what dep depends on)
+      // to see if we can reach cell
+      if (this.canReach(dep, normalizedCell, new Set())) {
+        return true;
+      }
+    }
+
+    return false;
+  }
+
+  /**
+   * Check if `from` can transitively reach `target` by following the
+   * dependency edges (i.e., what `from` depends on, and what those depend on, etc.)
+   * This checks if `from` transitively depends on `target`.
+   */
+  private canReach(from: string, target: string, visited: Set<string>): boolean {
+    if (from === target) return true;
+    if (visited.has(from)) return false;
+    visited.add(from);
+
+    // Follow the dependencies: cells that `from` depends on
+    const deps = this.getDependencies(from);
+    for (const dep of deps) {
+      if (this.canReach(dep, target, visited)) {
+        return true;
+      }
+    }
+
+    return false;
+  }
+
+  /**
+   * Detect if there's any cycle in the entire dependency graph.
+   * Uses DFS with coloring (white/gray/black).
+   * @returns An array of cell references forming the cycle, or null if no cycle.
+   */
+  detectCycle(): string[] | null {
+    const WHITE = 0, GRAY = 1, BLACK = 2;
+    const color = new Map<string, number>();
+    const parent = new Map<string, string | null>();
+
+    // Initialize all nodes as white
+    for (const cell of this.dependencies.keys()) {
+      color.set(cell, WHITE);
+    }
+
+    for (const cell of this.dependencies.keys()) {
+      if (color.get(cell) === WHITE) {
+        const cycle = this.dfsCycleDetect(cell, color, parent, WHITE, GRAY, BLACK);
+        if (cycle) return cycle;
+      }
+    }
+
+    return null;
+  }
+
+  private dfsCycleDetect(
+    node: string,
+    color: Map<string, number>,
+    parent: Map<string, string | null>,
+    WHITE: number,
+    GRAY: number,
+    BLACK: number
+  ): string[] | null {
+    color.set(node, GRAY);
+
+    const deps = this.dependencies.get(node);
+    if (deps) {
+      for (const dep of deps) {
+        const depColor = color.get(dep) ?? WHITE;
+        if (depColor === GRAY) {
+          // Found a cycle, reconstruct it
+          return [dep, node];
+        }
+        if (depColor === WHITE) {
+          parent.set(dep, node);
+          const cycle = this.dfsCycleDetect(dep, color, parent, WHITE, GRAY, BLACK);
+          if (cycle) return cycle;
+        }
+      }
+    }
+
+    color.set(node, BLACK);
+    return null;
+  }
+}
