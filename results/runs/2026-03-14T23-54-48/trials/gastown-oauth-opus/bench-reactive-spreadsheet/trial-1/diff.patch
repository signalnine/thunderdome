+// ─── AST Node Types ────────────────────────────────────────────────────────
+
+export type ASTNode =
+  | NumberLiteral
+  | StringLiteral
+  | BooleanLiteral
+  | CellRef
+  | RangeRef
+  | BinaryOp
+  | UnaryOp
+  | FunctionCall;
+
+export interface NumberLiteral {
+  type: 'number';
+  value: number;
+}
+
+export interface StringLiteral {
+  type: 'string';
+  value: string;
+}
+
+export interface BooleanLiteral {
+  type: 'boolean';
+  value: boolean;
+}
+
+export interface CellRef {
+  type: 'cell';
+  ref: string; // e.g. "A1", "AA23"
+}
+
+export interface RangeRef {
+  type: 'range';
+  start: string; // e.g. "A1"
+  end: string;   // e.g. "C3"
+}
+
+export type BinaryOperator = '+' | '-' | '*' | '/' | '>' | '<' | '>=' | '<=' | '=' | '<>';
+
+export interface BinaryOp {
+  type: 'binary';
+  operator: BinaryOperator;
+  left: ASTNode;
+  right: ASTNode;
+}
+
+export interface UnaryOp {
+  type: 'unary';
+  operator: '+' | '-';
+  operand: ASTNode;
+}
+
+export interface FunctionCall {
+  type: 'function';
+  name: string;
+  args: ASTNode[];
+}
+
+// ─── Tokenizer ─────────────────────────────────────────────────────────────
+
+export type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'IDENT'    // function names or cell refs
+  | 'COLON'
+  | 'COMMA'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'PLUS'
+  | 'MINUS'
+  | 'STAR'
+  | 'SLASH'
+  | 'GT'
+  | 'LT'
+  | 'GTE'
+  | 'LTE'
+  | 'EQ'
+  | 'NEQ'
+  | 'EOF';
+
+export interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    const ch = input[i];
+
+    // Skip whitespace
+    if (ch === ' ' || ch === '\t' || ch === '\r' || ch === '\n') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      i++; // skip opening quote
+      let str = '';
+      while (i < input.length && input[i] !== '"') {
+        if (input[i] === '\\' && i + 1 < input.length) {
+          i++;
+          str += input[i];
+        } else {
+          str += input[i];
+        }
+        i++;
+      }
+      if (i < input.length) i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Number literal
+    if (ch >= '0' && ch <= '9') {
+      let num = '';
+      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {
+        num += input[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    // Identifiers (cell refs, function names, booleans)
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z') || ch === '_') {
+      let ident = '';
+      while (i < input.length && ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z') || (input[i] >= '0' && input[i] <= '9') || input[i] === '_')) {
+        ident += input[i];
+        i++;
+      }
+      const upper = ident.toUpperCase();
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: upper });
+      } else {
+        tokens.push({ type: 'IDENT', value: ident });
+      }
+      continue;
+    }
+
+    // Two-character operators
+    if (ch === '<' && i + 1 < input.length && input[i + 1] === '>') {
+      tokens.push({ type: 'NEQ', value: '<>' });
+      i += 2;
+      continue;
+    }
+    if (ch === '>' && i + 1 < input.length && input[i + 1] === '=') {
+      tokens.push({ type: 'GTE', value: '>=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<' && i + 1 < input.length && input[i + 1] === '=') {
+      tokens.push({ type: 'LTE', value: '<=' });
+      i += 2;
+      continue;
+    }
+
+    // Single-character tokens
+    switch (ch) {
+      case '+': tokens.push({ type: 'PLUS', value: '+' }); break;
+      case '-': tokens.push({ type: 'MINUS', value: '-' }); break;
+      case '*': tokens.push({ type: 'STAR', value: '*' }); break;
+      case '/': tokens.push({ type: 'SLASH', value: '/' }); break;
+      case '(': tokens.push({ type: 'LPAREN', value: '(' }); break;
+      case ')': tokens.push({ type: 'RPAREN', value: ')' }); break;
+      case ',': tokens.push({ type: 'COMMA', value: ',' }); break;
+      case ':': tokens.push({ type: 'COLON', value: ':' }); break;
+      case '=': tokens.push({ type: 'EQ', value: '=' }); break;
+      case '>': tokens.push({ type: 'GT', value: '>' }); break;
+      case '<': tokens.push({ type: 'LT', value: '<' }); break;
+      default:
+        throw new Error(`Unexpected character: '${ch}' at position ${i}`);
+    }
+    i++;
+  }
+
+  tokens.push({ type: 'EOF', value: '' });
+  return tokens;
+}
+
+// ─── Parser ────────────────────────────────────────────────────────────────
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    const t = this.tokens[this.pos];
+    this.pos++;
+    return t;
+  }
+
+  private expect(type: TokenType): Token {
+    const t = this.peek();
+    if (t.type !== type) {
+      throw new Error(`Expected ${type} but got ${t.type} ('${t.value}')`);
+    }
+    return this.advance();
+  }
+
+  // Entry: parse a full expression
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    if (this.peek().type !== 'EOF') {
+      throw new Error(`Unexpected token: ${this.peek().value}`);
+    }
+    return node;
+  }
