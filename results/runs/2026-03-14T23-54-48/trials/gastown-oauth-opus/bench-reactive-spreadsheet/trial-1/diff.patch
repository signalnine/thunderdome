+    });
+  });
+
+  it('parses parenthesized expressions', () => {
+    const ast = parseFormula('=(A1+B1)*2');
+    expect(ast.type).toBe('binary');
+    if (ast.type === 'binary') {
+      expect(ast.operator).toBe('*');
+      expect(ast.left.type).toBe('binary');
+    }
+  });
+
+  it('parses comparison operators', () => {
+    expect(parseFormula('=A1>10')).toMatchObject({
+      type: 'binary', operator: '>'
+    });
+    expect(parseFormula('=A1<10')).toMatchObject({
+      type: 'binary', operator: '<'
+    });
+    expect(parseFormula('=A1>=10')).toMatchObject({
+      type: 'binary', operator: '>='
+    });
+    expect(parseFormula('=A1<=10')).toMatchObject({
+      type: 'binary', operator: '<='
+    });
+    expect(parseFormula('=A1=10')).toMatchObject({
+      type: 'binary', operator: '='
+    });
+    expect(parseFormula('=A1<>10')).toMatchObject({
+      type: 'binary', operator: '<>'
+    });
+  });
+
+  it('parses range reference', () => {
+    const ast = parseFormula('=A1:C3');
+    expect(ast).toEqual({ type: 'range', start: 'A1', end: 'C3' });
+  });
+
+  it('parses SUM function', () => {
+    const ast = parseFormula('=SUM(A1:A5)');
+    expect(ast).toEqual({
+      type: 'function',
+      name: 'SUM',
+      args: [{ type: 'range', start: 'A1', end: 'A5' }],
+    });
+  });
+
+  it('parses AVERAGE function', () => {
+    const ast = parseFormula('=AVERAGE(A1:A5)');
+    expect(ast).toMatchObject({
+      type: 'function',
+      name: 'AVERAGE',
+    });
+  });
+
+  it('parses IF function with three arguments', () => {
+    const ast = parseFormula('=IF(A1>30, "big", "small")');
+    expect(ast.type).toBe('function');
+    if (ast.type === 'function') {
+      expect(ast.name).toBe('IF');
+      expect(ast.args).toHaveLength(3);
+      expect(ast.args[0]).toMatchObject({ type: 'binary', operator: '>' });
+      expect(ast.args[1]).toEqual({ type: 'string', value: 'big' });
+      expect(ast.args[2]).toEqual({ type: 'string', value: 'small' });
+    }
+  });
+
+  it('parses nested function calls', () => {
+    const ast = parseFormula('=SUM(A1, MAX(B1:B5))');
+    expect(ast.type).toBe('function');
+    if (ast.type === 'function') {
+      expect(ast.name).toBe('SUM');
+      expect(ast.args).toHaveLength(2);
+      expect(ast.args[1]).toMatchObject({ type: 'function', name: 'MAX' });
+    }
+  });
+
+  it('parses unary minus', () => {
+    const ast = parseFormula('=-5');
+    expect(ast).toEqual({ type: 'unary', operator: '-', operand: { type: 'number', value: 5 } });
+  });
+
+  it('parses without leading =', () => {
+    const ast = parseFormula('42');
+    expect(ast).toEqual({ type: 'number', value: 42 });
+  });
+
+  it('parses function names case insensitively', () => {
+    const ast = parseFormula('=sum(A1:A5)');
+    expect(ast).toMatchObject({ type: 'function', name: 'SUM' });
+  });
+});
+
+// ─── evaluate ──────────────────────────────────────────────────────────────
+
+describe('evaluate', () => {
+  const emptyLookup: CellLookup = () => null;
+
+  it('evaluates number literal', () => {
+    const ast = parseFormula('=42');
+    expect(evaluate(ast, emptyLookup)).toBe(42);
+  });
+
+  it('evaluates string literal', () => {
+    const ast = parseFormula('="hello"');
+    expect(evaluate(ast, emptyLookup)).toBe('hello');
+  });
+
+  it('evaluates boolean literal', () => {
+    expect(evaluate(parseFormula('=TRUE'), emptyLookup)).toBe(true);
+    expect(evaluate(parseFormula('=FALSE'), emptyLookup)).toBe(false);
+  });
+
+  it('evaluates cell reference', () => {
+    const lookup: CellLookup = (ref) => {
+      if (ref === 'A1') return 10;
+      if (ref === 'B1') return 20;
+      return null;
+    };
+    const ast = parseFormula('=A1');
+    expect(evaluate(ast, lookup)).toBe(10);
+  });
+
+  it('evaluates addition', () => {
+    const lookup: CellLookup = (ref) => {
+      if (ref === 'A1') return 10;
+      if (ref === 'B1') return 20;
+      return null;
+    };
+    const ast = parseFormula('=A1+B1');
+    expect(evaluate(ast, lookup)).toBe(30);
+  });
+
+  it('evaluates subtraction', () => {
+    expect(evaluate(parseFormula('=10-3'), emptyLookup)).toBe(7);
+  });
+
+  it('evaluates multiplication', () => {
+    expect(evaluate(parseFormula('=3*4'), emptyLookup)).toBe(12);
+  });
+
+  it('evaluates division', () => {
+    expect(evaluate(parseFormula('=10/4'), emptyLookup)).toBe(2.5);
+  });
+
+  it('throws on division by zero', () => {
+    expect(() => evaluate(parseFormula('=10/0'), emptyLookup)).toThrow('#DIV/0!');
+  });
+
+  it('evaluates operator precedence correctly', () => {
+    expect(evaluate(parseFormula('=2+3*4'), emptyLookup)).toBe(14);
+    expect(evaluate(parseFormula('=(2+3)*4'), emptyLookup)).toBe(20);
+  });
+
+  it('evaluates comparison operators', () => {
+    expect(evaluate(parseFormula('=5>3'), emptyLookup)).toBe(true);
+    expect(evaluate(parseFormula('=5<3'), emptyLookup)).toBe(false);
+    expect(evaluate(parseFormula('=5>=5'), emptyLookup)).toBe(true);
+    expect(evaluate(parseFormula('=5<=4'), emptyLookup)).toBe(false);
+    expect(evaluate(parseFormula('=5=5'), emptyLookup)).toBe(true);
+    expect(evaluate(parseFormula('=5<>5'), emptyLookup)).toBe(false);
+    expect(evaluate(parseFormula('=5<>3'), emptyLookup)).toBe(true);
+  });
+
+  it('evaluates unary minus', () => {
+    expect(evaluate(parseFormula('=-5'), emptyLookup)).toBe(-5);
+    expect(evaluate(parseFormula('=-(3+2)'), emptyLookup)).toBe(-5);
+  });
+
+  it('evaluates SUM', () => {
+    const lookup: CellLookup = (ref) => {
+      const vals: Record<string, number> = { A1: 1, A2: 2, A3: 3, A4: 4, A5: 5 };
+      return vals[ref] ?? null;
+    };
+    expect(evaluate(parseFormula('=SUM(A1:A5)'), lookup)).toBe(15);
+  });
+
+  it('evaluates AVERAGE', () => {
+    const lookup: CellLookup = (ref) => {
+      const vals: Record<string, number> = { A1: 10, A2: 20, A3: 30 };
+      return vals[ref] ?? null;
+    };
+    expect(evaluate(parseFormula('=AVERAGE(A1:A3)'), lookup)).toBe(20);
+  });
+
+  it('evaluates MIN', () => {
+    const lookup: CellLookup = (ref) => {
+      const vals: Record<string, number> = { A1: 10, A2: 5, A3: 20 };
+      return vals[ref] ?? null;
+    };
+    expect(evaluate(parseFormula('=MIN(A1:A3)'), lookup)).toBe(5);
+  });
+
+  it('evaluates MAX', () => {
+    const lookup: CellLookup = (ref) => {
+      const vals: Record<string, number> = { A1: 10, A2: 5, A3: 20 };
+      return vals[ref] ?? null;
+    };
+    expect(evaluate(parseFormula('=MAX(A1:A3)'), lookup)).toBe(20);
+  });
+
+  it('evaluates COUNT', () => {
+    const lookup: CellLookup = (ref) => {
+      const vals: Record<string, number | string | null> = { A1: 10, A2: 5, A3: null as any };
+      return vals[ref] ?? null;
+    };
+    expect(evaluate(parseFormula('=COUNT(A1:A3)'), lookup)).toBe(2);
+  });
+
+  it('evaluates IF true branch', () => {
+    const lookup: CellLookup = (ref) => {
+      if (ref === 'A1') return 50;
+      return null;
+    };
+    expect(evaluate(parseFormula('=IF(A1>30, "big", "small")'), lookup)).toBe('big');
+  });
+
+  it('evaluates IF false branch', () => {
+    const lookup: CellLookup = (ref) => {
+      if (ref === 'A1') return 10;
+      return null;
+    };
+    expect(evaluate(parseFormula('=IF(A1>30, "big", "small")'), lookup)).toBe('small');
+  });
+
+  it('handles null cell references as 0 in arithmetic', () => {
+    expect(evaluate(parseFormula('=A1+5'), emptyLookup)).toBe(5);
+  });
+
+  it('evaluates SUM with mixed args (range + scalar)', () => {
+    const lookup: CellLookup = (ref) => {
+      const vals: Record<string, number> = { A1: 1, A2: 2 };
+      return vals[ref] ?? null;
+    };
+    expect(evaluate(parseFormula('=SUM(A1:A2, 10)'), lookup)).toBe(13);
+  });
+
+  it('handles complex nested formula', () => {
+    const lookup: CellLookup = (ref) => {
+      const vals: Record<string, number> = { A1: 10, A2: 20, B1: 5, B2: 15 };
+      return vals[ref] ?? null;
+    };
+    const ast = parseFormula('=SUM(A1:A2) + MAX(B1:B2)');
+    expect(evaluate(ast, lookup)).toBe(45);
+  });
+});
+
+// ─── extractDependencies ───────────────────────────────────────────────────
+
+describe('extractDependencies', () => {
+  it('extracts cell references', () => {
+    const ast = parseFormula('=A1+B1');
+    const deps = extractDependencies(ast);
+    expect(deps.sort()).toEqual(['A1', 'B1']);
+  });
+
+  it('extracts range references', () => {
+    const ast = parseFormula('=SUM(A1:A3)');
+    const deps = extractDependencies(ast);
+    expect(deps.sort()).toEqual(['A1', 'A2', 'A3']);
+  });
+
+  it('returns empty for literals', () => {
+    expect(extractDependencies(parseFormula('=42'))).toEqual([]);
+    expect(extractDependencies(parseFormula('="hi"'))).toEqual([]);
+  });
+
+  it('extracts from nested expressions', () => {
+    const ast = parseFormula('=IF(A1>0, B1, C1)');
+    const deps = extractDependencies(ast);
+    expect(deps.sort()).toEqual(['A1', 'B1', 'C1']);
+  });
+});
+
+// ─── Spreadsheet integration ───────────────────────────────────────────────
+
+describe('Spreadsheet', () => {
+  // Dynamically import to avoid issues if Spreadsheet class isn't available
+  let Spreadsheet: any;
+
+  beforeAll(async () => {
+    const mod = await import('../src/index.js');
+    Spreadsheet = mod.Spreadsheet;
+  });
+
+  it('sets and gets raw values', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    expect(sheet.get('A1')).toBe(10);
+  });
+
+  it('evaluates simple formula', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('A2', 20);
+    sheet.set('A3', '=A1+A2');
+    expect(sheet.get('A3')).toBe(30);
+  });
+
+  it('reactively updates on change', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
