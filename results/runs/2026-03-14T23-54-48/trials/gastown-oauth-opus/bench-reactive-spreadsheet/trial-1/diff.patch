+  });
+
+  it('parses multiplication with correct precedence', () => {
+    const ast = parseFormula('=2+3*4');
+    expect(ast).toEqual({
+      type: 'binary',
+      operator: '+',
+      left: { type: 'number', value: 2 },
+      right: {
+        type: 'binary',
+        operator: '*',
+        left: { type: 'number', value: 3 },
+        right: { type: 'number', value: 4 },
