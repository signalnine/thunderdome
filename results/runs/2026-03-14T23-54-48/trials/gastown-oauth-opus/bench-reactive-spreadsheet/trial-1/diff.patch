+    }
+
+    if (t.type === 'IDENT') {
+      const ident = this.advance();
+
+      // Check if this is a function call
+      if (this.peek().type === 'LPAREN') {
+        // Could be function call — check if this looks like a function name (all letters)
+        // Functions: SUM, AVERAGE, MIN, MAX, COUNT, IF, etc.
+        // Cell refs: A1, B2, AA10 — these have digits in them
+        // We distinguish by: if ident is followed by '(', it's a function call
+        return this.parseFunctionCall(ident.value);
+      }
+
+      // Check if this is a range reference (IDENT ':' IDENT)
+      if (this.peek().type === 'COLON') {
+        this.advance(); // consume ':'
+        const endIdent = this.expect('IDENT');
+        return { type: 'range', start: ident.value.toUpperCase(), end: endIdent.value.toUpperCase() };
+      }
+
+      // It's a cell reference
+      return { type: 'cell', ref: ident.value.toUpperCase() };
+    }
+
+    throw new Error(`Unexpected token: ${t.type} ('${t.value}')`);
+  }
+
+  private parseFunctionCall(name: string): FunctionCall {
+    this.expect('LPAREN');
+    const args: ASTNode[] = [];
+
+    if (this.peek().type !== 'RPAREN') {
+      args.push(this.parseComparison());
+      while (this.peek().type === 'COMMA') {
+        this.advance(); // consume ','
+        args.push(this.parseComparison());
+      }
+    }
+
+    this.expect('RPAREN');
+    return { type: 'function', name: name.toUpperCase(), args };
+  }
+}
+
+/**
+ * Parse a formula string (with or without leading '=') into an AST.
+ */
+export function parseFormula(formula: string): ASTNode {
+  let input = formula;
+  if (input.startsWith('=')) {
+    input = input.slice(1);
+  }
+  const tokens = tokenize(input);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// ─── Cell Reference Utilities ──────────────────────────────────────────────
+
+/**
+ * Parse a cell reference string like "A1" or "AA23" into column and row.
+ * Returns { col: 0-based column index, row: 1-based row number }.
+ */
+export function parseCellRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/i);
+  if (!match) {
+    throw new Error(`Invalid cell reference: ${ref}`);
+  }
+  const colStr = match[1].toUpperCase();
+  const row = parseInt(match[2], 10);
+
+  let col = 0;
+  for (let i = 0; i < colStr.length; i++) {
+    col = col * 26 + (colStr.charCodeAt(i) - 64);
+  }
+  col -= 1; // 0-based
+
+  return { col, row };
+}
+
+/**
+ * Convert a 0-based column index back to a column letter string (A, B, ..., Z, AA, ...).
+ */
+export function columnToLetter(col: number): string {
+  let result = '';
+  let c = col + 1; // 1-based
+  while (c > 0) {
+    c--;
+    result = String.fromCharCode(65 + (c % 26)) + result;
+    c = Math.floor(c / 26);
+  }
+  return result;
+}
+
+/**
+ * Expand a range like A1:C3 into an array of cell reference strings.
+ */
+export function expandRange(start: string, end: string): string[] {
+  const s = parseCellRef(start);
+  const e = parseCellRef(end);
+
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+
+  const refs: string[] = [];
+  for (let row = minRow; row <= maxRow; row++) {
+    for (let col = minCol; col <= maxCol; col++) {
+      refs.push(`${columnToLetter(col)}${row}`);
+    }
+  }
+  return refs;
+}
+
+// ─── Evaluator ─────────────────────────────────────────────────────────────
+
+/**
+ * A lookup function that resolves a cell reference to its computed value.
+ * Returns null for empty cells.
+ */
+export type CellLookup = (ref: string) => string | number | boolean | null;
+
+/**
+ * Evaluate an AST node given a cell lookup function.
+ */
+export function evaluate(node: ASTNode, lookup: CellLookup): string | number | boolean | null {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+
+    case 'string':
+      return node.value;
+
+    case 'boolean':
+      return node.value;
+
+    case 'cell':
+      return lookup(node.ref.toUpperCase());
+
+    case 'range':
+      // A bare range should not appear outside a function call context;
+      // if it does, expand and return the first cell's value as a fallback.
+      return lookup(node.start.toUpperCase());
+
+    case 'unary': {
+      const operand = evaluate(node.operand, lookup);
+      const numVal = toNumber(operand);
+      return node.operator === '-' ? -numVal : numVal;
+    }
+
+    case 'binary':
+      return evaluateBinary(node, lookup);
+
+    case 'function':
+      return evaluateFunction(node, lookup);
+  }
+}
+
+function toNumber(val: string | number | boolean | null): number {
+  if (val === null) return 0;
+  if (typeof val === 'number') return val;
+  if (typeof val === 'boolean') return val ? 1 : 0;
+  const n = parseFloat(val);
+  return isNaN(n) ? 0 : n;
+}
+
+function evaluateBinary(node: BinaryOp, lookup: CellLookup): string | number | boolean {
+  const left = evaluate(node.left, lookup);
+  const right = evaluate(node.right, lookup);
+
+  switch (node.operator) {
+    case '+': {
+      // If both are strings, concatenate
+      if (typeof left === 'string' && typeof right === 'string') {
+        return left + right;
+      }
+      return toNumber(left) + toNumber(right);
+    }
+    case '-':
+      return toNumber(left) - toNumber(right);
+    case '*':
+      return toNumber(left) * toNumber(right);
+    case '/': {
+      const divisor = toNumber(right);
+      if (divisor === 0) {
+        throw new Error('#DIV/0!');
+      }
+      return toNumber(left) / divisor;
+    }
+    case '>':
+      return toNumber(left) > toNumber(right);
+    case '<':
+      return toNumber(left) < toNumber(right);
+    case '>=':
+      return toNumber(left) >= toNumber(right);
+    case '<=':
+      return toNumber(left) <= toNumber(right);
+    case '=':
+      // Equality comparison — works on same types
+      if (left === null && right === null) return true;
+      if (left === null || right === null) return false;
+      if (typeof left === typeof right) return left === right;
+      return toNumber(left) === toNumber(right);
+    case '<>':
+      if (left === null && right === null) return false;
+      if (left === null || right === null) return true;
+      if (typeof left === typeof right) return left !== right;
+      return toNumber(left) !== toNumber(right);
+  }
+}
+
+/**
+ * Collect numeric values from a list of AST arguments, expanding ranges.
+ */
+function collectValues(args: ASTNode[], lookup: CellLookup): (string | number | boolean | null)[] {
+  const values: (string | number | boolean | null)[] = [];
+
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      const refs = expandRange(arg.start, arg.end);
+      for (const ref of refs) {
+        values.push(lookup(ref));
+      }
+    } else {
+      values.push(evaluate(arg, lookup));
+    }
+  }
+
+  return values;
+}
+
+function evaluateFunction(node: FunctionCall, lookup: CellLookup): string | number | boolean | null {
+  switch (node.name) {
+    case 'SUM': {
+      const values = collectValues(node.args, lookup);
+      let sum = 0;
+      for (const v of values) {
+        if (typeof v === 'number') sum += v;
+        else if (typeof v === 'boolean') sum += v ? 1 : 0;
+        else if (typeof v === 'string') {
+          const n = parseFloat(v);
+          if (!isNaN(n)) sum += n;
+        }
+        // null is skipped (treated as 0 contribution)
+      }
+      return sum;
+    }
+
+    case 'AVERAGE': {
+      const values = collectValues(node.args, lookup);
+      let sum = 0;
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') {
+          sum += v;
+          count++;
+        }
+      }
+      if (count === 0) return 0;
+      return sum / count;
+    }
+
+    case 'MIN': {
+      const values = collectValues(node.args, lookup);
+      let min = Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v < min) min = v;
+      }
+      return min === Infinity ? 0 : min;
+    }
+
+    case 'MAX': {
+      const values = collectValues(node.args, lookup);
+      let max = -Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v > max) max = v;
+      }
+      return max === -Infinity ? 0 : max;
+    }
+
+    case 'COUNT': {
+      const values = collectValues(node.args, lookup);
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') count++;
+      }
+      return count;
+    }
+
+    case 'IF': {
+      if (node.args.length < 2) {
+        throw new Error('IF requires at least 2 arguments');
+      }
+      const condition = evaluate(node.args[0], lookup);
+      const isTruthy = condition !== false && condition !== 0 && condition !== null && condition !== '';
+      if (isTruthy) {
+        return evaluate(node.args[1], lookup);
+      } else {
+        if (node.args.length >= 3) {
+          return evaluate(node.args[2], lookup);
+        }
+        return false;
+      }
+    }
+
+    default:
+      throw new Error(`Unknown function: ${node.name}`);
+  }
+}
+
+// ─── Dependency Extraction ─────────────────────────────────────────────────
+
+/**
+ * Extract all cell references from an AST (for dependency tracking).
+ * This includes individual cell refs and all cells within range refs.
+ */
+export function extractDependencies(node: ASTNode): string[] {
+  const deps: Set<string> = new Set();
+  collectDeps(node, deps);
+  return Array.from(deps);
+}
+
+function collectDeps(node: ASTNode, deps: Set<string>): void {
+  switch (node.type) {
+    case 'number':
+    case 'string':
+    case 'boolean':
+      break;
+    case 'cell':
+      deps.add(node.ref.toUpperCase());
+      break;
+    case 'range': {
+      const refs = expandRange(node.start, node.end);
+      for (const ref of refs) {
+        deps.add(ref);
+      }
+      break;
+    }
+    case 'unary':
+      collectDeps(node.operand, deps);
+      break;
+    case 'binary':
+      collectDeps(node.left, deps);
+      collectDeps(node.right, deps);
+      break;
+    case 'function':
+      for (const arg of node.args) {
+        collectDeps(arg, deps);
+      }
+      break;
+  }
+}
