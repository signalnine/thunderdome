+export {
+  parseCellRef,
+  columnLetterToNumber,
+  columnNumberToLetter,
+  cellRefToCoords,
+  coordsToCellRef,
+  normalizeCellRef,
+  expandRange,
+  extractCellRefs,
+  extractRanges,
+  extractDependencies,
+  DependencyGraph,
+} from './cellRef.js';
+
+export {
+  parseFormula,
+  evaluate,
+  extractDependencies as extractFormulaDependencies,
+  expandRange as expandFormulaRange,
+  parseCellRef as parseFormulaCellRef,
+  columnToLetter,
+} from './formula.js';
+
+export type {
+  ASTNode,
+  NumberLiteral,
+  StringLiteral,
+  BooleanLiteral,
+  CellRef,
+  RangeRef,
+  BinaryOp,
+  UnaryOp,
+  FunctionCall,
+  BinaryOperator,
+  CellLookup,
+} from './formula.js';
+
+import { parseFormula, evaluate, extractDependencies, type ASTNode, type CellLookup } from './formula.js';
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: string | number | boolean | null;
+  deps: string[];
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private dependents: Map<string, Set<string>> = new Map(); // cell -> cells that depend on it
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    // Save old state for rollback
+    const oldData = this.cells.get(ref) ?? null;
+
+    // Remove old dependency edges
+    if (oldData) {
+      for (const dep of oldData.deps) {
+        const s = this.dependents.get(dep);
+        if (s) {
+          s.delete(ref);
+          if (s.size === 0) this.dependents.delete(dep);
+        }
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps: string[] = [];
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value);
+      deps = extractDependencies(formula);
+    }
+
+    // Register new dependency edges
+    for (const dep of deps) {
+      let s = this.dependents.get(dep);
+      if (!s) {
+        s = new Set();
+        this.dependents.set(dep, s);
+      }
+      s.add(ref);
+    }
+
+    // Store cell data (computed value will be set after cycle check)
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      value: null,
+      deps,
+    };
+    this.cells.set(ref, cellData);
+
+    // Detect circular references before evaluating
+    try {
+      this.detectCycle(ref);
+    } catch (e) {
+      // Rollback: remove new dependency edges
+      for (const dep of deps) {
+        const s = this.dependents.get(dep);
+        if (s) {
+          s.delete(ref);
+          if (s.size === 0) this.dependents.delete(dep);
+        }
+      }
+      // Restore old state
+      if (oldData) {
+        this.cells.set(ref, oldData);
+        for (const dep of oldData.deps) {
+          if (!this.dependents.has(dep)) {
+            this.dependents.set(dep, new Set());
+          }
+          this.dependents.get(dep)!.add(ref);
+        }
+      } else {
+        this.cells.delete(ref);
+      }
+      throw e;
+    }
+
+    // Evaluate this cell
+    const lookup: CellLookup = (r: string) => {
+      const d = this.cells.get(r.toUpperCase());
+      return d ? d.value : null;
+    };
+
+    if (formula) {
+      try {
+        cellData.value = evaluate(formula, lookup);
+      } catch (evalError: any) {
+        cellData.value = evalError?.message ?? '#ERROR!';
+      }
+    } else {
+      cellData.value = value;
+    }
+
+    // Reactively update dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const data = this.cells.get(cell.toUpperCase());
+    return data ? data.value : null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null || value === undefined) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, any> {
+    const result = new Map<string, any>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  // ── Cycle detection (DFS with gray/black coloring) ──────────────
+
+  private detectCycle(startRef: string): void {
+    const visited = new Set<string>();
+    const stack = new Set<string>();
+
+    const dfs = (ref: string): void => {
+      if (stack.has(ref)) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      stack.add(ref);
+
+      const data = this.cells.get(ref);
+      if (data) {
+        for (const dep of data.deps) {
+          dfs(dep);
+        }
+      }
+
+      stack.delete(ref);
+    };
+
+    dfs(startRef);
+  }
+
+  // ── Topological propagation ────────────────────────────────────
+
+  private propagate(changedRef: string): void {
+    const order = this.topologicalSort(changedRef);
+
+    const lookup: CellLookup = (r: string) => {
+      const d = this.cells.get(r.toUpperCase());
+      return d ? d.value : null;
+    };
+
+    // Recompute each dependent (skip the changedRef itself, already evaluated)
+    for (const ref of order) {
+      if (ref === changedRef) continue;
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        try {
+          data.value = evaluate(data.formula, lookup);
+        } catch (evalError: any) {
+          data.value = evalError?.message ?? '#ERROR!';
+        }
+      }
+    }
+  }
+
+  private topologicalSort(startRef: string): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const dfs = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      // Visit all cells that depend on this cell
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          dfs(dep);
+        }
+      }
+      result.push(ref);
+    };
+
+    dfs(startRef);
+
+    // Reverse to get topological order (dependencies first)
+    result.reverse();
+    return result;
+  }
+}
