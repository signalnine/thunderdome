+    it('should handle functions combined with cell references and arithmetic', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)+100');
+      sheet.set('C1', '=B1/2');
+      expect(sheet.get('B1')).toBe(160);
+      expect(sheet.get('C1')).toBe(80);
