+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  parseCellRef,
+  columnLetterToNumber,
+  columnNumberToLetter,
+  cellRefToCoords,
+  coordsToCellRef,
+  normalizeCellRef,
+  expandRange,
+  extractCellRefs,
+  extractRanges,
+  extractDependencies,
+  DependencyGraph,
+} from './cellRef.js';
+
+describe('parseCellRef', () => {
+  it('should parse simple cell references', () => {
+    expect(parseCellRef('A1')).toEqual({ col: 'A', row: 1 });
+    expect(parseCellRef('B2')).toEqual({ col: 'B', row: 2 });
+    expect(parseCellRef('Z100')).toEqual({ col: 'Z', row: 100 });
+  });
+
+  it('should parse multi-letter column references', () => {
+    expect(parseCellRef('AA1')).toEqual({ col: 'AA', row: 1 });
+    expect(parseCellRef('AZ52')).toEqual({ col: 'AZ', row: 52 });
+    expect(parseCellRef('BA1')).toEqual({ col: 'BA', row: 1 });
+  });
+
+  it('should handle lowercase input', () => {
+    expect(parseCellRef('a1')).toEqual({ col: 'A', row: 1 });
+    expect(parseCellRef('aa1')).toEqual({ col: 'AA', row: 1 });
+  });
+
+  it('should return null for invalid references', () => {
+    expect(parseCellRef('')).toBeNull();
+    expect(parseCellRef('1A')).toBeNull();
+    expect(parseCellRef('A')).toBeNull();
+    expect(parseCellRef('1')).toBeNull();
+    expect(parseCellRef('A0')).toBeNull();
+    expect(parseCellRef('hello')).toBeNull();
+    expect(parseCellRef('A1B2')).toBeNull();
+  });
+});
+
+describe('columnLetterToNumber', () => {
+  it('should convert single letters', () => {
+    expect(columnLetterToNumber('A')).toBe(1);
+    expect(columnLetterToNumber('B')).toBe(2);
+    expect(columnLetterToNumber('Z')).toBe(26);
+  });
+
+  it('should convert double letters', () => {
+    expect(columnLetterToNumber('AA')).toBe(27);
+    expect(columnLetterToNumber('AB')).toBe(28);
+    expect(columnLetterToNumber('AZ')).toBe(52);
+    expect(columnLetterToNumber('BA')).toBe(53);
+  });
+
+  it('should handle lowercase', () => {
+    expect(columnLetterToNumber('a')).toBe(1);
+    expect(columnLetterToNumber('aa')).toBe(27);
+  });
+});
+
+describe('columnNumberToLetter', () => {
+  it('should convert single-letter columns', () => {
+    expect(columnNumberToLetter(1)).toBe('A');
+    expect(columnNumberToLetter(2)).toBe('B');
+    expect(columnNumberToLetter(26)).toBe('Z');
+  });
+
+  it('should convert double-letter columns', () => {
+    expect(columnNumberToLetter(27)).toBe('AA');
+    expect(columnNumberToLetter(28)).toBe('AB');
+    expect(columnNumberToLetter(52)).toBe('AZ');
+    expect(columnNumberToLetter(53)).toBe('BA');
+  });
+
+  it('should be inverse of columnLetterToNumber', () => {
+    for (let i = 1; i <= 100; i++) {
+      expect(columnLetterToNumber(columnNumberToLetter(i))).toBe(i);
+    }
+  });
+});
+
+describe('cellRefToCoords', () => {
+  it('should convert cell refs to numeric coords', () => {
+    expect(cellRefToCoords('A1')).toEqual({ col: 1, row: 1 });
+    expect(cellRefToCoords('B2')).toEqual({ col: 2, row: 2 });
+    expect(cellRefToCoords('AA1')).toEqual({ col: 27, row: 1 });
+    expect(cellRefToCoords('Z26')).toEqual({ col: 26, row: 26 });
+  });
+
+  it('should return null for invalid refs', () => {
+    expect(cellRefToCoords('invalid')).toBeNull();
+  });
+});
+
+describe('coordsToCellRef', () => {
+  it('should convert coords to cell ref strings', () => {
+    expect(coordsToCellRef(1, 1)).toBe('A1');
+    expect(coordsToCellRef(2, 2)).toBe('B2');
+    expect(coordsToCellRef(27, 1)).toBe('AA1');
+    expect(coordsToCellRef(26, 26)).toBe('Z26');
+  });
+});
+
+describe('normalizeCellRef', () => {
+  it('should uppercase cell references', () => {
+    expect(normalizeCellRef('a1')).toBe('A1');
+    expect(normalizeCellRef('aa1')).toBe('AA1');
+    expect(normalizeCellRef('A1')).toBe('A1');
+  });
+});
+
+describe('expandRange', () => {
+  it('should expand a column range', () => {
+    expect(expandRange('A1:A5')).toEqual(['A1', 'A2', 'A3', 'A4', 'A5']);
+  });
+
+  it('should expand a row range', () => {
+    expect(expandRange('A1:C1')).toEqual(['A1', 'B1', 'C1']);
+  });
+
+  it('should expand a block range', () => {
+    const result = expandRange('A1:C3');
+    expect(result).toEqual([
+      'A1', 'B1', 'C1',
+      'A2', 'B2', 'C2',
+      'A3', 'B3', 'C3',
+    ]);
+  });
+
+  it('should handle reversed ranges', () => {
+    expect(expandRange('C3:A1')).toEqual([
+      'A1', 'B1', 'C1',
+      'A2', 'B2', 'C2',
+      'A3', 'B3', 'C3',
+    ]);
+  });
+
+  it('should handle single cell range', () => {
+    expect(expandRange('A1:A1')).toEqual(['A1']);
+  });
+
+  it('should return empty for invalid ranges', () => {
+    expect(expandRange('invalid')).toEqual([]);
+    expect(expandRange('A1')).toEqual([]);
+    expect(expandRange('A1:B:C')).toEqual([]);
+  });
+});
+
+describe('extractCellRefs', () => {
+  it('should extract cell references from a formula', () => {
+    const refs = extractCellRefs('A1+B2');
+    expect(refs).toContain('A1');
+    expect(refs).toContain('B2');
+  });
+
+  it('should extract multi-letter refs', () => {
+    const refs = extractCellRefs('AA1+AB2');
+    expect(refs).toContain('AA1');
+    expect(refs).toContain('AB2');
+  });
+});
+
+describe('extractRanges', () => {
+  it('should extract ranges from a formula', () => {
+    expect(extractRanges('SUM(A1:C3)')).toEqual(['A1:C3']);
+  });
+
+  it('should extract multiple ranges', () => {
+    const ranges = extractRanges('SUM(A1:A5)+SUM(B1:B5)');
+    expect(ranges).toEqual(['A1:A5', 'B1:B5']);
+  });
+});
+
+describe('extractDependencies', () => {
+  it('should extract standalone refs', () => {
+    const deps = extractDependencies('A1+B2');
+    expect(deps).toContain('A1');
+    expect(deps).toContain('B2');
+  });
+
+  it('should expand ranges into individual refs', () => {
+    const deps = extractDependencies('SUM(A1:A3)');
+    expect(deps).toContain('A1');
+    expect(deps).toContain('A2');
+    expect(deps).toContain('A3');
+  });
+
+  it('should combine standalone refs and range refs', () => {
+    const deps = extractDependencies('A1+SUM(B1:B3)');
+    expect(deps).toContain('A1');
+    expect(deps).toContain('B1');
+    expect(deps).toContain('B2');
+    expect(deps).toContain('B3');
+  });
+
+  it('should deduplicate refs', () => {
+    const deps = extractDependencies('A1+SUM(A1:A3)');
+    const a1Count = deps.filter(d => d === 'A1').length;
+    expect(a1Count).toBe(1);
+  });
+});
+
+describe('DependencyGraph', () => {
+  let graph: DependencyGraph;
+
+  beforeEach(() => {
+    graph = new DependencyGraph();
+  });
+
+  describe('setDependencies / getDependencies', () => {
+    it('should set and get dependencies', () => {
+      graph.setDependencies('B1', ['A1', 'A2']);
+      expect(graph.getDependencies('B1').sort()).toEqual(['A1', 'A2']);
+    });
+
+    it('should replace old dependencies', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('B1', ['A2', 'A3']);
+      expect(graph.getDependencies('B1').sort()).toEqual(['A2', 'A3']);
+    });
+
+    it('should return empty for cells with no dependencies', () => {
+      expect(graph.getDependencies('A1')).toEqual([]);
+    });
+  });
+
+  describe('getDependents', () => {
+    it('should track reverse dependencies', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('C1', ['A1']);
+      expect(graph.getDependents('A1').sort()).toEqual(['B1', 'C1']);
+    });
+
+    it('should update when dependencies change', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('B1', ['A2']); // no longer depends on A1
+      expect(graph.getDependents('A1')).toEqual([]);
+      expect(graph.getDependents('A2')).toEqual(['B1']);
+    });
+  });
+
+  describe('clearDependencies', () => {
+    it('should clear dependencies and update reverse index', () => {
+      graph.setDependencies('B1', ['A1', 'A2']);
+      graph.clearDependencies('B1');
+      expect(graph.getDependencies('B1')).toEqual([]);
+      expect(graph.getDependents('A1')).toEqual([]);
+      expect(graph.getDependents('A2')).toEqual([]);
+    });
+  });
+
+  describe('getAllDependents', () => {
+    it('should find all transitive dependents', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('C1', ['B1']);
+      graph.setDependencies('D1', ['C1']);
+      const allDeps = graph.getAllDependents('A1');
+      expect(allDeps.sort()).toEqual(['B1', 'C1', 'D1']);
+    });
+
+    it('should handle branching dependencies', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('C1', ['A1']);
+      graph.setDependencies('D1', ['B1', 'C1']);
+      const allDeps = graph.getAllDependents('A1');
+      expect(allDeps.sort()).toEqual(['B1', 'C1', 'D1']);
+    });
+  });
+
+  describe('getRecalcOrder', () => {
+    it('should return topological order for recalculation', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('C1', ['B1']);
+      const order = graph.getRecalcOrder('A1');
+      expect(order.indexOf('B1')).toBeLessThan(order.indexOf('C1'));
+    });
+
+    it('should handle diamond dependencies', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('C1', ['A1']);
+      graph.setDependencies('D1', ['B1', 'C1']);
+      const order = graph.getRecalcOrder('A1');
+      expect(order.indexOf('B1')).toBeLessThan(order.indexOf('D1'));
+      expect(order.indexOf('C1')).toBeLessThan(order.indexOf('D1'));
+    });
+  });
+
+  describe('wouldCreateCycle', () => {
+    it('should detect direct self-reference', () => {
+      expect(graph.wouldCreateCycle('A1', ['A1'])).toBe(true);
+    });
+
+    it('should detect simple cycle', () => {
+      graph.setDependencies('B1', ['A1']);
+      expect(graph.wouldCreateCycle('A1', ['B1'])).toBe(true);
+    });
+
+    it('should detect indirect cycle', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('C1', ['B1']);
+      expect(graph.wouldCreateCycle('A1', ['C1'])).toBe(true);
+    });
+
+    it('should not flag non-cycles', () => {
+      graph.setDependencies('B1', ['A1']);
+      expect(graph.wouldCreateCycle('C1', ['A1'])).toBe(false);
+      expect(graph.wouldCreateCycle('C1', ['B1'])).toBe(false);
+    });
+
+    it('should handle complex non-cycle graphs', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('C1', ['A1']);
+      graph.setDependencies('D1', ['B1', 'C1']);
+      // E1 depending on D1 should not be a cycle
+      expect(graph.wouldCreateCycle('E1', ['D1'])).toBe(false);
+      // But A1 depending on D1 would be
+      expect(graph.wouldCreateCycle('A1', ['D1'])).toBe(true);
+    });
+  });
+
+  describe('detectCycle', () => {
+    it('should return null when no cycle exists', () => {
+      graph.setDependencies('B1', ['A1']);
+      graph.setDependencies('C1', ['B1']);
+      expect(graph.detectCycle()).toBeNull();
+    });
+
+    it('should detect a cycle in the graph', () => {
+      // Manually create a cycle (bypassing wouldCreateCycle check)
+      graph.setDependencies('A1', ['B1']);
+      graph.setDependencies('B1', ['A1']);
+      expect(graph.detectCycle()).not.toBeNull();
+    });
+  });
+});
