+import { describe, it, expect } from 'vitest';
+import {
+  parseFormula,
+  evaluate,
+  extractDependencies,
+  expandRange,
+  parseCellRef,
+  columnToLetter,
+  type ASTNode,
+  type CellLookup,
+} from '../src/formula.js';
+
+// ─── parseCellRef ──────────────────────────────────────────────────────────
+
+describe('parseCellRef', () => {
+  it('parses single-letter column', () => {
+    expect(parseCellRef('A1')).toEqual({ col: 0, row: 1 });
+    expect(parseCellRef('B2')).toEqual({ col: 1, row: 2 });
+    expect(parseCellRef('Z100')).toEqual({ col: 25, row: 100 });
+  });
+
+  it('parses multi-letter column', () => {
+    expect(parseCellRef('AA1')).toEqual({ col: 26, row: 1 });
+    expect(parseCellRef('AZ1')).toEqual({ col: 51, row: 1 });
+    expect(parseCellRef('BA1')).toEqual({ col: 52, row: 1 });
+  });
+
+  it('is case insensitive', () => {
+    expect(parseCellRef('a1')).toEqual({ col: 0, row: 1 });
+  });
+
+  it('throws on invalid ref', () => {
+    expect(() => parseCellRef('123')).toThrow();
+    expect(() => parseCellRef('')).toThrow();
+  });
+});
+
+// ─── columnToLetter ────────────────────────────────────────────────────────
+
+describe('columnToLetter', () => {
+  it('converts 0-based index to letter', () => {
+    expect(columnToLetter(0)).toBe('A');
+    expect(columnToLetter(1)).toBe('B');
+    expect(columnToLetter(25)).toBe('Z');
+    expect(columnToLetter(26)).toBe('AA');
+    expect(columnToLetter(51)).toBe('AZ');
+    expect(columnToLetter(52)).toBe('BA');
+  });
+});
+
+// ─── expandRange ───────────────────────────────────────────────────────────
+
+describe('expandRange', () => {
+  it('expands a column range', () => {
+    const refs = expandRange('A1', 'A3');
+    expect(refs).toEqual(['A1', 'A2', 'A3']);
+  });
+
+  it('expands a row range', () => {
+    const refs = expandRange('A1', 'C1');
+    expect(refs).toEqual(['A1', 'B1', 'C1']);
+  });
+
+  it('expands a block range', () => {
+    const refs = expandRange('A1', 'B2');
+    expect(refs).toEqual(['A1', 'B1', 'A2', 'B2']);
+  });
+
+  it('handles reversed coordinates', () => {
+    const refs = expandRange('C3', 'A1');
+    expect(refs).toEqual(['A1', 'B1', 'C1', 'A2', 'B2', 'C2', 'A3', 'B3', 'C3']);
+  });
+});
+
+// ─── parseFormula ──────────────────────────────────────────────────────────
+
+describe('parseFormula', () => {
+  it('parses number literal', () => {
+    const ast = parseFormula('=42');
+    expect(ast).toEqual({ type: 'number', value: 42 });
+  });
+
+  it('parses decimal number', () => {
+    const ast = parseFormula('=3.14');
+    expect(ast).toEqual({ type: 'number', value: 3.14 });
+  });
+
+  it('parses string literal', () => {
+    const ast = parseFormula('="hello"');
+    expect(ast).toEqual({ type: 'string', value: 'hello' });
+  });
+
+  it('parses boolean literals', () => {
+    expect(parseFormula('=TRUE')).toEqual({ type: 'boolean', value: true });
+    expect(parseFormula('=FALSE')).toEqual({ type: 'boolean', value: false });
+    expect(parseFormula('=true')).toEqual({ type: 'boolean', value: true });
+  });
+
+  it('parses cell reference', () => {
+    const ast = parseFormula('=A1');
+    expect(ast).toEqual({ type: 'cell', ref: 'A1' });
+  });
+
+  it('parses cell reference case insensitive', () => {
+    const ast = parseFormula('=a1');
+    expect(ast).toEqual({ type: 'cell', ref: 'A1' });
+  });
+
+  it('parses addition', () => {
+    const ast = parseFormula('=A1+B1');
+    expect(ast).toEqual({
+      type: 'binary',
+      operator: '+',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'cell', ref: 'B1' },
+    });
+  });
+
+  it('parses subtraction', () => {
+    const ast = parseFormula('=10-3');
+    expect(ast).toEqual({
+      type: 'binary',
+      operator: '-',
+      left: { type: 'number', value: 10 },
+      right: { type: 'number', value: 3 },
