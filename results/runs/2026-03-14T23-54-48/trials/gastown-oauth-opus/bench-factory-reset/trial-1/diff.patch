@@ -0,0 +1,174 @@
+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from '../src/index.js';
+
+describe('solveToggle', () => {
+  it('should return null when no solution exists (example from TASK.md)', () => {
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should solve a simple single-button toggle', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should return empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [[0], [1]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should find minimum presses', () => {
+    // Two buttons toggle the same light. Only 1 press needed.
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    // Either button 0 or button 1 works, minimum is 1 press
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(1);
+    // Lex smallest with 1 press: [0]
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle identity system', () => {
+    // Each button toggles exactly one light
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0], [1], [2]],
+    });
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('should handle overlapping buttons', () => {
+    // Button 0: toggles light 0, 1
+    // Button 1: toggles light 1, 2
+    // Target: [true, false, true]
+    // b0 XOR 0 = 1 (light 0) => b0 = 1
+    // b0 XOR b1 = 0 (light 1) => b1 = 1
+    // b1 XOR 0 = 1 (light 2) => b1 = 1 ✓
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should handle more buttons than lights (free variables)', () => {
+    // 2 lights, 3 buttons
+    // Button 0: [0], Button 1: [1], Button 2: [0, 1]
+    // Target: [true, true]
+    // Light 0: b0 XOR b2 = 1
+    // Light 1: b1 XOR b2 = 1
+    // Solutions: b0=1,b1=1,b2=0 (2 presses) or b0=0,b1=0,b2=1 (1 press)
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    });
+    expect(result).toEqual([2]); // minimum presses = 1
+  });
+
+  it('should handle zero buttons', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should handle all off target with no buttons', () => {
+    const result = solveToggle({
+      target: [false],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should solve larger system', () => {
+    // 5 lights, 5 buttons, identity mapping
+    const result = solveToggle({
+      target: [true, true, true, true, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    });
+    expect(result).toEqual([0, 1, 2, 3, 4]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should solve a simple counter puzzle', () => {
+    // 1 counter, 1 button, modulus 5
+    // Button 0 increments counter 0
+    // Target: counter 0 = 3
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // 1 counter, 0 buttons, target = 1
+    const result = solveCounter([1], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should return all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0], [[0], [1]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should handle overlapping buttons', () => {
+    // 2 counters, 2 buttons, modulus 5
+    // Button 0: increments counter 0, 1
+    // Button 1: increments counter 1
+    // Target: [2, 3]
+    // Counter 0: b0 = 2 (mod 5)
+    // Counter 1: b0 + b1 = 3 (mod 5) => b1 = 1
+    const result = solveCounter([2, 3], [[0, 1], [1]], 5);
+    expect(result).toEqual([2, 1]);
+  });
+
+  it('should find minimum total presses with free variables', () => {
+    // 1 counter, 2 buttons, modulus 5
+    // Button 0: increments counter 0
+    // Button 1: increments counter 0
+    // Target: [3]
+    // b0 + b1 = 3 (mod 5)
+    // Solutions: (0,3)=3, (1,2)=3, (2,1)=3, (3,0)=3, (4,4)=8
+    // All have sum 3 except (4,4). Lex smallest with sum 3: (0,3)
+    const result = solveCounter([3], [[0], [0]], 5);
+    expect(result).toEqual([0, 3]);
+  });
+
+  it('should handle modulus 2 (like toggle)', () => {
+    const result = solveCounter([1, 1, 0], [[0], [1], [2]], 2);
+    expect(result).toEqual([1, 1, 0]);
+  });
+
+  it('should handle larger modulus', () => {
+    // modulus = 7, 2 counters, 2 buttons
+    // Button 0: [0], Button 1: [1]
+    // Target: [6, 5]
+    const result = solveCounter([6, 5], [[0], [1]], 7);
+    expect(result).toEqual([6, 5]);
+  });
+
+  it('should return null for inconsistent system', () => {
+    // 2 counters, 1 button, modulus 3
+    // Button 0: increments counter 0 and counter 1
+    // Target: [1, 2]
+    // b0 = 1 (counter 0), b0 = 2 (counter 1) → inconsistent
+    const result = solveCounter([1, 2], [[0, 1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should handle identity system with prime modulus', () => {
+    const result = solveCounter([1, 2, 3, 4], [[0], [1], [2], [3]], 5);
+    expect(result).toEqual([1, 2, 3, 4]);
+  });
+});
