+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve toggle puzzle using Gaussian elimination over GF(2).
+ * Each button toggles a set of lights; find minimum buttons to press.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(2): rows = lights, cols = buttons + 1 (augment)
+  // matrix[i][j] = 1 if button j toggles light i
+  // matrix[i][numButtons] = target[i] ? 1 : 0
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx < numLights) {
+        matrix[lightIdx][j] = 1;
+      }
+    }
+  }
+
+  // Track column-to-pivot-row mapping for back substitution
+  const pivotCol: number[] = []; // pivotCol[row] = column index of pivot in that row
+  const pivotRow: number[] = new Array(numButtons).fill(-1); // pivotRow[col] = row where this col is a pivot
+
+  let row = 0;
+  for (let col = 0; col < numButtons && row < numLights; col++) {
+    // Find pivot row
+    let pivot = -1;
+    for (let r = row; r < numLights; r++) {
+      if (matrix[r][col] === 1) {
+        pivot = r;
+        break;
+      }
+    }
+    if (pivot === -1) continue; // free variable
+
+    // Swap rows
+    [matrix[row], matrix[pivot]] = [matrix[pivot], matrix[row]];
+
+    // Eliminate column in all other rows
+    for (let r = 0; r < numLights; r++) {
+      if (r !== row && matrix[r][col] === 1) {
+        for (let c = col; c <= numButtons; c++) {
+          matrix[r][c] ^= matrix[row][c];
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow[col] = row;
+    row++;
+  }
+
+  const rank = row;
+
+  // Check for inconsistency: any row with all zeros on left but 1 on right
+  for (let r = rank; r < numLights; r++) {
+    if (matrix[r][numButtons] === 1) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Enumerate all 2^numFree combinations
+  let bestSolution: number[] | null = null;
+  let bestCount = Infinity;
+
+  const totalCombinations = 1 << numFree;
+
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const solution = new Array(numButtons).fill(0);
+
+    // Set free variables from mask
+    for (let f = 0; f < numFree; f++) {
+      solution[freeVars[f]] = (mask >> f) & 1;
+    }
+
+    // Back-substitute to find pivot variables
+    // Process pivot rows from bottom to top
+    for (let r = rank - 1; r >= 0; r--) {
+      const col = pivotCol[r];
+      let val = matrix[r][numButtons];
+      for (let c = col + 1; c < numButtons; c++) {
+        if (matrix[r][c] === 1) {
+          val ^= solution[c];
+        }
+      }
+      solution[col] = val;
+    }
+
+    // Count presses
+    const pressedIndices: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if (solution[i] === 1) {
+        pressedIndices.push(i);
+      }
+    }
+
+    const count = pressedIndices.length;
+    if (count < bestCount || (count === bestCount && compareLex(pressedIndices, bestSolution!) < 0)) {
+      bestCount = count;
+      bestSolution = pressedIndices;
+    }
+  }
+
+  return bestSolution;
+}
+
+/** Compare two sorted arrays lexicographically. Returns < 0 if a < b. */
+function compareLex(a: number[], b: number[]): number {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return a.length - b.length;
+}
+
+/**
+ * Modular exponentiation: base^exp mod m
+ */
+function modPow(base: number, exp: number, m: number): number {
+  let result = 1;
+  base = ((base % m) + m) % m;
+  while (exp > 0) {
+    if (exp & 1) {
+      result = (result * base) % m;
+    }
+    exp >>= 1;
+    base = (base * base) % m;
+  }
+  return result;
+}
+
+/**
+ * Modular inverse using Fermat's little theorem: a^(p-2) mod p
+ */
+function modInverse(a: number, p: number): number {
+  return modPow(a, p - 2, p);
+}
+
+/**
+ * Solve counter puzzle using Gaussian elimination over GF(p).
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+  const p = modulus;
+
+  // Build augmented matrix over GF(p): rows = counters, cols = buttons + 1
+  // matrix[i][j] = 1 if button j affects counter i (increment by 1)
+  // matrix[i][numButtons] = lights[i] (target value mod p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = ((lights[i] % p) + p) % p;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const counterIdx of buttons[j]) {
+      if (counterIdx < numCounters) {
+        matrix[counterIdx][j] = 1;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  let row = 0;
+
+  for (let col = 0; col < numButtons && row < numCounters; col++) {
+    // Find pivot row (non-zero in this column)
+    let pivot = -1;
+    for (let r = row; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) {
+        pivot = r;
+        break;
+      }
+    }
+    if (pivot === -1) continue; // free variable
+
+    // Swap rows
+    [matrix[row], matrix[pivot]] = [matrix[pivot], matrix[row]];
+
+    // Scale pivot row so pivot element = 1
+    const inv = modInverse(matrix[row][col], p);
+    for (let c = col; c <= numButtons; c++) {
+      matrix[row][c] = (matrix[row][c] * inv) % p;
+    }
+
+    // Eliminate column in all other rows
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== row && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = col; c <= numButtons; c++) {
+          matrix[r][c] = (((matrix[r][c] - factor * matrix[row][c]) % p) + p) % p;
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    row++;
+  }
+
+  const rank = row;
+
+  // Check for inconsistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // For free variable enumeration: p^numFree combinations
+  // If too large, we need a smarter approach
+  const totalCombinations = Math.pow(p, numFree);
+
+  if (totalCombinations > 10_000_000) {
+    // Use meet-in-the-middle or greedy approach for large search spaces
+    return solveCounterLargeSearch(matrix, pivotCol, freeVars, numButtons, rank, p);
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  // Enumerate all p^numFree combinations
+  const freeValues = new Array(numFree).fill(0);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    // Decode combo into freeValues
+    let temp = combo;
+    for (let f = 0; f < numFree; f++) {
+      freeValues[f] = temp % p;
+      temp = Math.floor(temp / p);
+    }
+
+    const solution = new Array(numButtons).fill(0);
+
+    // Set free variables
+    for (let f = 0; f < numFree; f++) {
+      solution[freeVars[f]] = freeValues[f];
+    }
+
+    // Back-substitute pivot variables
+    for (let r = rank - 1; r >= 0; r--) {
+      const col = pivotCol[r];
+      let val = matrix[r][numButtons];
+      for (let c = col + 1; c < numButtons; c++) {
+        if (matrix[r][c] !== 0) {
+          val = (((val - matrix[r][c] * solution[c]) % p) + p) % p;
+        }
+      }
+      solution[col] = val % p;
+    }
+
+    // Compute total presses
+    let sum = 0;
+    for (let i = 0; i < numButtons; i++) {
+      sum += solution[i];
+    }
+
+    if (sum < bestSum || (sum === bestSum && compareArrayLex(solution, bestSolution!) < 0)) {
+      bestSum = sum;
+      bestSolution = solution.slice();
+    }
+  }
+
+  return bestSolution;
+}
+
+/** Compare two arrays lexicographically. */
+function compareArrayLex(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
+
+/**
+ * For large search spaces, use coordinate-descent optimization.
+ * Try all p values for each free variable, picking the best greedily.
+ */
+function solveCounterLargeSearch(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  numButtons: number,
+  rank: number,
+  p: number
+): number[] | null {
+  const solution = new Array(numButtons).fill(0);
+
+  // Compute pivot values for current free variable assignment (all zeros)
+  const computePivotValues = (sol: number[]) => {
+    for (let r = rank - 1; r >= 0; r--) {
+      const col = pivotCol[r];
+      let val = matrix[r][numButtons];
+      for (let c = col + 1; c < numButtons; c++) {
+        if (matrix[r][c] !== 0) {
+          val = (((val - matrix[r][c] * sol[c]) % p) + p) % p;
+        }
+      }
+      sol[col] = val;
+    }
+  };
+
+  const computeSum = (sol: number[]) => {
+    let s = 0;
+    for (let i = 0; i < numButtons; i++) s += sol[i];
+    return s;
+  };
+
+  // Try each free variable value independently, greedily picking the best
+  // Repeat until no improvement
+  let improved = true;
+  computePivotValues(solution);
+  let bestSum = computeSum(solution);
+  let bestSol = solution.slice();
+
+  while (improved) {
+    improved = false;
+    for (let f = 0; f < freeVars.length; f++) {
+      const freeCol = freeVars[f];
+      let bestVal = solution[freeCol];
+      let bestLocalSum = bestSum;
+      let bestLocalSol = bestSol;
+
+      for (let v = 0; v < p; v++) {
+        if (v === solution[freeCol]) continue;
+        const testSol = solution.slice();
+        testSol[freeCol] = v;
+        computePivotValues(testSol);
+        const s = computeSum(testSol);
+        if (s < bestLocalSum || (s === bestLocalSum && compareArrayLex(testSol, bestLocalSol) < 0)) {
+          bestLocalSum = s;
+          bestVal = v;
+          bestLocalSol = testSol;
+        }
+      }
+
+      if (bestVal !== solution[freeCol]) {
+        solution[freeCol] = bestVal;
+        computePivotValues(solution);
+        bestSum = bestLocalSum;
+        bestSol = bestLocalSol.slice();
+        improved = true;
+      }
+    }
+  }
+
+  return bestSol;
+}
