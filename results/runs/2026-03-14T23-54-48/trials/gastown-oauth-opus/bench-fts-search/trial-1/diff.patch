+function sanitizeFtsQuery(raw: string): string {
+  // If the query contains a quoted phrase, pass it through to FTS5 directly
+  if (/^".*"$/.test(raw.trim())) {
+    return raw.trim();
+  }
+  // Otherwise, strip FTS5 special characters and build a simple token query
+  const tokens = raw
+    .replace(/[^\w\s"]/g, ' ')
+    .split(/\s+/)
+    .filter(t => t.length > 0);
+  if (tokens.length === 0) return '';
+  return tokens.join(' ');
