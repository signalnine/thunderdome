@@ -0,0 +1,59 @@
+import { EventBus } from '../bus.js';
+import {
+  InventoryService,
+  Events,
+  InventoryUpdatedEvent,
+  LowStockAlertEvent,
+} from '../types.js';
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  const stock = new Map<string, number>();
+  const reserved = new Map<string, number>();
+  const thresholds = new Map<string, number>();
+
+  return {
+    setStock(productId: string, quantity: number) {
+      stock.set(productId, quantity);
+
+      const event: InventoryUpdatedEvent = { productId, quantity };
+      bus.emit(Events.INVENTORY_UPDATED, event);
+
+      const threshold = thresholds.get(productId) ?? 0;
+      if (quantity <= threshold) {
+        const alertEvent: LowStockAlertEvent = {
+          productId,
+          currentQuantity: quantity,
+          threshold,
+        };
+        bus.emit(Events.LOW_STOCK_ALERT, alertEvent);
+      }
+    },
+
+    getStock(productId: string): number {
+      return (stock.get(productId) ?? 0) - (reserved.get(productId) ?? 0);
+    },
+
+    reserve(productId: string, quantity: number): boolean {
+      const currentStock = stock.get(productId) ?? 0;
+      const currentReserved = reserved.get(productId) ?? 0;
+      const available = currentStock - currentReserved;
+
+      if (available < quantity) {
+        return false;
+      }
+
+      reserved.set(productId, currentReserved + quantity);
+      return true;
+    },
+
+    release(productId: string, quantity: number) {
+      const currentReserved = reserved.get(productId) ?? 0;
+      const newReserved = Math.max(0, currentReserved - quantity);
+      reserved.set(productId, newReserved);
+    },
+
+    setLowStockThreshold(productId: string, threshold: number) {
+      thresholds.set(productId, threshold);
+    },
+  };
+}
