@@ -0,0 +1,91 @@
+import { EventBus } from '../bus.js';
+import {
+  PaymentService,
+  PaymentStatus,
+  Events,
+  PaymentProcessedEvent,
+} from '../types.js';
+
+interface PaymentOptions {
+  successRate?: number;
+  failureRate?: number;
+  timeoutRate?: number;
+  delayMs?: number;
+}
+
+export function createPaymentService(
+  bus: EventBus,
+  options: PaymentOptions = {}
+): PaymentService {
+  const {
+    successRate = 0.8,
+    failureRate = 0.15,
+    timeoutRate = 0.05,
+    delayMs = 100,
+  } = options;
+
+  const transactions = new Map<string, { orderId: string; amount: number; status: PaymentStatus }>();
+  let transactionCounter = 0;
+
+  function generateTransactionId(): string {
+    return `txn_${++transactionCounter}`;
+  }
+
+  function determineStatus(): PaymentStatus {
+    const rand = Math.random();
+    if (rand < successRate) {
+      return PaymentStatus.SUCCESS;
+    } else if (rand < successRate + failureRate) {
+      return PaymentStatus.FAILED;
+    } else if (rand < successRate + failureRate + timeoutRate) {
+      return PaymentStatus.TIMEOUT;
+    } else {
+      // Fallback to success if rates don't sum to 1
+      return PaymentStatus.SUCCESS;
+    }
+  }
+
+  return {
+    async processPayment(orderId: string, amount: number) {
+      await new Promise(resolve => setTimeout(resolve, delayMs));
+
+      const status = determineStatus();
+      const transactionId = generateTransactionId();
+
+      const result: { status: PaymentStatus; transactionId?: string; error?: string } = {
+        status,
+      };
+
+      if (status === PaymentStatus.SUCCESS) {
+        result.transactionId = transactionId;
+        transactions.set(transactionId, { orderId, amount, status });
+      } else if (status === PaymentStatus.FAILED) {
+        result.error = 'Payment failed';
+      } else if (status === PaymentStatus.TIMEOUT) {
+        result.error = 'Payment timeout';
+      }
+
+      const event: PaymentProcessedEvent = {
+        orderId,
+        status,
+        transactionId: result.transactionId,
+        error: result.error,
+      };
+      bus.emit(Events.PAYMENT_PROCESSED, event);
+
+      return result;
+    },
+
+    async refund(transactionId: string) {
+      const transaction = transactions.get(transactionId);
+      if (!transaction || transaction.status !== PaymentStatus.SUCCESS) {
+        return false;
+      }
+
+      await new Promise(resolve => setTimeout(resolve, delayMs));
+
+      transaction.status = PaymentStatus.FAILED;
+      return true;
+    },
+  };
+}
