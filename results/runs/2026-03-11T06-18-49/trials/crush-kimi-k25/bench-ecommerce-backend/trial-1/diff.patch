@@ -0,0 +1,95 @@
+import { EventBus } from '../bus.js';
+import {
+  NotificationService,
+  OrderStatus,
+  Events,
+  OrderStatusChangedEvent,
+  PaymentProcessedEvent,
+  NotificationSentEvent,
+  OrderCreatedEvent,
+} from '../types.js';
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const subscribers = new Set<string>();
+  const notifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();
+  const orderUserMap = new Map<string, string>();
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderUserMap.set(event.orderId, event.userId);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {
+    const event = payload as OrderStatusChangedEvent;
+    const userId = orderUserMap.get(event.orderId);
+
+    if (userId && subscribers.has(userId)) {
+      const statusMessages: Record<OrderStatus, string> = {
+        [OrderStatus.PENDING]: `Order ${event.orderId} is pending`,
+        [OrderStatus.CONFIRMED]: `Order ${event.orderId} has been confirmed`,
+        [OrderStatus.SHIPPED]: `Order ${event.orderId} has been shipped`,
+        [OrderStatus.DELIVERED]: `Order ${event.orderId} has been delivered`,
+        [OrderStatus.CANCELLED]: `Order ${event.orderId} has been cancelled`,
+      };
+
+      const message = statusMessages[event.status] ?? `Order ${event.orderId} status changed to ${event.status}`;
+      const notification = {
+        type: 'order_status',
+        message,
+        timestamp: Date.now(),
+      };
+
+      const userNotifications = notifications.get(userId) ?? [];
+      userNotifications.push(notification);
+      notifications.set(userId, userNotifications);
+
+      const sentEvent: NotificationSentEvent = {
+        userId,
+        type: 'order_status',
+        message,
+      };
+      bus.emit(Events.NOTIFICATION_SENT, sentEvent);
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    const userId = orderUserMap.get(event.orderId);
+
+    if (userId && subscribers.has(userId)) {
+      let message: string;
+      if (event.status === 'success') {
+        message = `Payment for order ${event.orderId} was successful`;
+      } else {
+        message = `Payment for order ${event.orderId} failed: ${event.error}`;
+      }
+
+      const notification = {
+        type: 'payment',
+        message,
+        timestamp: Date.now(),
+      };
+
+      const userNotifications = notifications.get(userId) ?? [];
+      userNotifications.push(notification);
+      notifications.set(userId, userNotifications);
+
+      const sentEvent: NotificationSentEvent = {
+        userId,
+        type: 'payment',
+        message,
+      };
+      bus.emit(Events.NOTIFICATION_SENT, sentEvent);
+    }
+  });
+
+  return {
+    subscribe(userId: string) {
+      subscribers.add(userId);
+    },
+
+    getNotifications(userId: string) {
+      return notifications.get(userId) ?? [];
+    },
+  };
+}
