@@ -0,0 +1,70 @@
+import { EventBus } from '../bus.js';
+import {
+  OrderService,
+  OrderStatus,
+  Events,
+  OrderCreatedEvent,
+  OrderStatusChangedEvent,
+} from '../types.js';
+
+export function createOrderService(bus: EventBus): OrderService {
+  const orders = new Map<string, { id: string; userId: string; cartId: string; status: OrderStatus; total: number }>();
+  const userOrders = new Map<string, string[]>();
+  let idCounter = 0;
+
+  function generateId(): string {
+    return `order_${++idCounter}`;
+  }
+
+  return {
+    createOrder(userId: string, cartId: string, total: number): string {
+      const id = generateId();
+      const order = {
+        id,
+        userId,
+        cartId,
+        status: OrderStatus.PENDING,
+        total,
+      };
+      orders.set(id, order);
+
+      const userOrderList = userOrders.get(userId) ?? [];
+      userOrderList.push(id);
+      userOrders.set(userId, userOrderList);
+
+      const event: OrderCreatedEvent = { orderId: id, userId, cartId, total };
+      bus.emit(Events.ORDER_CREATED, event);
+
+      return id;
+    },
+
+    getOrder(orderId: string) {
+      const order = orders.get(orderId);
+      if (!order) return null;
+      return { id: order.id, userId: order.userId, status: order.status, total: order.total };
+    },
+
+    updateStatus(orderId: string, status: OrderStatus) {
+      const order = orders.get(orderId);
+      if (!order) return;
+
+      const previousStatus = order.status;
+      order.status = status;
+
+      const event: OrderStatusChangedEvent = {
+        orderId,
+        status,
+        previousStatus,
+      };
+      bus.emit(Events.ORDER_STATUS_CHANGED, event);
+    },
+
+    listOrders(userId: string) {
+      const orderIds = userOrders.get(userId) ?? [];
+      return orderIds
+        .map(id => orders.get(id))
+        .filter((order): order is NonNullable<typeof order> => order !== undefined)
+        .map(order => ({ id: order.id, status: order.status, total: order.total }));
+    },
+  };
+}
