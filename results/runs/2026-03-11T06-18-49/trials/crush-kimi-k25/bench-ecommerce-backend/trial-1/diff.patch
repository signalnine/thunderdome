@@ -0,0 +1,90 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  Events,
+  OrderCreatedEvent,
+  PaymentProcessedEvent,
+  CartUpdatedEvent,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  const productQuantities = new Map<string, number>();
+  const cartIds = new Set<string>();
+  const orderIds = new Set<string>();
+  let totalRevenue = 0;
+
+  bus.on(Events.PRODUCT_CREATED, () => {
+    eventCounts.set(Events.PRODUCT_CREATED, (eventCounts.get(Events.PRODUCT_CREATED) ?? 0) + 1);
+  });
+
+  bus.on(Events.INVENTORY_UPDATED, () => {
+    eventCounts.set(Events.INVENTORY_UPDATED, (eventCounts.get(Events.INVENTORY_UPDATED) ?? 0) + 1);
+  });
+
+  bus.on(Events.LOW_STOCK_ALERT, () => {
+    eventCounts.set(Events.LOW_STOCK_ALERT, (eventCounts.get(Events.LOW_STOCK_ALERT) ?? 0) + 1);
+  });
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as CartUpdatedEvent;
+    cartIds.add(event.cartId);
+    eventCounts.set(Events.CART_UPDATED, (eventCounts.get(Events.CART_UPDATED) ?? 0) + 1);
+  });
+
+  bus.on(Events.PRICE_CALCULATED, () => {
+    eventCounts.set(Events.PRICE_CALCULATED, (eventCounts.get(Events.PRICE_CALCULATED) ?? 0) + 1);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderIds.add(event.orderId);
+    eventCounts.set(Events.ORDER_CREATED, (eventCounts.get(Events.ORDER_CREATED) ?? 0) + 1);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, () => {
+    eventCounts.set(Events.ORDER_STATUS_CHANGED, (eventCounts.get(Events.ORDER_STATUS_CHANGED) ?? 0) + 1);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    eventCounts.set(Events.PAYMENT_PROCESSED, (eventCounts.get(Events.PAYMENT_PROCESSED) ?? 0) + 1);
+
+    if (event.status === 'success' && event.transactionId) {
+      // Revenue tracking would need order amount - we'll track via order events
+    }
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, () => {
+    eventCounts.set(Events.NOTIFICATION_SENT, (eventCounts.get(Events.NOTIFICATION_SENT) ?? 0) + 1);
+  });
+
+  // Track product quantities from order events
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    // Track order amount as revenue proxy (total includes tax, but we'll use it)
+    totalRevenue += event.total;
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return totalRevenue;
+    },
+
+    getConversionRate(): number {
+      if (cartIds.size === 0) return 0;
+      return orderIds.size / cartIds.size;
+    },
+
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> {
+      return Array.from(productQuantities.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
