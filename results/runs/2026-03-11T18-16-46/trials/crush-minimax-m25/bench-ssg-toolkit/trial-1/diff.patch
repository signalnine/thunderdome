+import { Plugin, BuildContext, ContentFile } from '../core/types.js';
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        const { config, output, data } = ctx;
+        const baseUrl = config.baseUrl;
+
+        const urls: string[] = [];
+
+        // Collect all URLs from output
+        for (const [path] of output) {
+          // Skip non-HTML and non-XML outputs (like JSON)
+          if (path.endsWith('.html') || path.endsWith('.xml')) {
+            urls.push(`${baseUrl}/${path}`);
+          }
+        }
+
+        // Get taxonomy tags to include tag pages
+        const tagMap = data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (tagMap && tagMap.size > 0) {
+          for (const tag of tagMap.keys()) {
+            urls.push(`${baseUrl}/tags/${tag}.html`);
+          }
+        }
+
+        // Include feed.xml if present
+        if (output.has('feed.xml')) {
+          urls.push(`${baseUrl}/feed.xml`);
+        }
+
+        // Build sitemap XML
+        let sitemap = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+`;
+
+        for (const url of urls) {
+          sitemap += `  <url>
+    <loc>${escapeXml(url)}</loc>
+  </url>
+`;
+        }
+
+        sitemap += `</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemap);
+      },
+    },
+  };
+}
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&')
+    .replace(/</g, '<')
+    .replace(/>/g, '>')
+    .replace(/"/g, '"')
+    .replace(/'/g, "'");
+}
