+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Match <pre><code class="language-xxx">...</code></pre> blocks
+        // Only process blocks that have a language class
+        content = content.replace(
+          /<pre><code class="language-(\w+)"([^>]*)>([\s\S]*?)<\/code><\/pre>/g,
+          (match, lang, extraAttrs, code) => {
+            // Add highlighted class to code and data-language to pre
+            return `<pre data-language="${lang}"><code class="language-${lang} highlighted"${extraAttrs}>${code}</code></pre>`;
+          }
+        );
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
