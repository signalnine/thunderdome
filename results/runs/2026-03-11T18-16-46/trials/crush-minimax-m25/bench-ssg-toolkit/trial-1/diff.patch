+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Get or initialize asset manifest
+        let manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (!manifest) {
+          manifest = { assets: [] };
+          ctx.data.set('asset-manifest', manifest);
+        }
+
+        // Rewrite relative image src URLs
+        content = content.replace(
+          /<img\s+([^>]*)>/gi,
+          (match, attrs) => {
+            // Check if already rewritten
+            if (attrs.includes('src="/assets/')) {
+              return match;
+            }
+            
+            // Check for relative src
+            const srcMatch = attrs.match(/src="(\.\/[^"]+)"/);
+            if (srcMatch) {
+              const relativePath = srcMatch[1];
+              const filename = relativePath.replace(/^\.\//, '');
+              
+              // Add to manifest if not already present
+              if (!manifest!.assets.includes(filename)) {
+                manifest!.assets.push(filename);
+              }
+              
+              // Rewrite the URL
+              const newAttrs = attrs.replace(srcMatch[0], `src="/assets/${filename}"`);
+              return `<img ${newAttrs}>`;
+            }
+            
+            return match;
+          }
+        );
+
+        // Rewrite relative link href URLs
+        content = content.replace(
+          /<a\s+([^>]*)>/gi,
+          (match, attrs) => {
+            // Check if already rewritten
+            if (attrs.includes('href="/assets/')) {
+              return match;
+            }
+            
+            // Check for relative href
+            const hrefMatch = attrs.match(/href="(\.\/[^"]+)"/);
+            if (hrefMatch) {
+              const relativePath = hrefMatch[1];
+              const filename = relativePath.replace(/^\.\//, '');
+              
+              // Add to manifest if not already present
+              if (!manifest!.assets.includes(filename)) {
+                manifest!.assets.push(filename);
+              }
+              
+              // Rewrite the URL
+              const newAttrs = attrs.replace(hrefMatch[0], `href="/assets/${filename}"`);
+              return `<a ${newAttrs}>`;
+            }
+            
+            return match;
+          }
+        );
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
