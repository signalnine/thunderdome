+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx: BuildContext): void => {
+        const tagMap = new Map<string, ContentFile[]>();
+
+        for (const file of ctx.files) {
+          if (file.tags && file.tags.length > 0) {
+            for (const tag of file.tags) {
+              const normalizedTag = tag.toLowerCase();
+              if (!tagMap.has(normalizedTag)) {
+                tagMap.set(normalizedTag, []);
+              }
+              tagMap.get(normalizedTag)!.push(file);
+            }
+          }
+        }
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: (ctx: BuildContext): void => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+        
+        if (!tagMap || tagMap.size === 0) {
+          return;
+        }
+
+        for (const [tag, files] of tagMap) {
+          const tagPageContent = generateTagPage(tag, files, ctx.config.baseUrl);
+          ctx.output.set(`tags/${tag}.html`, tagPageContent);
+        }
+      },
+    },
+  };
+}
+
+function generateTagPage(tag: string, files: ContentFile[], baseUrl: string): string {
+  let html = `<!DOCTYPE html>
+<html>
+<head>
+  <title>Tag: ${tag}</title>
+</head>
+<body>
+  <h1>Tagged: ${tag}</h1>
+  <ul>
+`;
+
+  for (const file of files) {
+    const url = `${baseUrl}/${file.slug}.html`;
+    html += `    <li><a href="${url}">${file.title}</a></li>\n`;
+  }
+
+  html += `  </ul>
+</body>
+</html>`;
+
+  return html;
+}
