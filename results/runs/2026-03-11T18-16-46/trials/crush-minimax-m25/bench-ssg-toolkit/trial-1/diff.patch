+import { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        const routes: Array<{ path: string; handler: string }> = [];
+        const assetPaths: string[] = [];
+
+        // Get asset paths from asset-manifest
+        const assetManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (assetManifest && assetManifest.assets) {
+          for (const asset of assetManifest.assets) {
+            assetPaths.push(asset);
+            routes.push({
+              path: `/assets/${asset}`,
+              handler: 'asset',
+            });
+          }
+        }
+
+        // Get content routes from output
+        for (const [path] of ctx.output) {
+          if (path.endsWith('.html')) {
+            routes.push({
+              path: `/${path}`,
+              handler: 'static',
+            });
+          }
+        }
+
+        // Determine search index path
+        let searchIndexPath = '';
+        if (ctx.output.has('search-index.json')) {
+          searchIndexPath = '/search-index.json';
+        }
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath,
+        };
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
