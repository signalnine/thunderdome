+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        const index: Array<{
+          slug: string;
+          title: string;
+          content: string;
+          tags?: string[];
+        }> = [];
+
+        for (const file of ctx.files) {
+          // Strip HTML tags but preserve code block content
+          const plainText = stripHtmlKeepCode(file.content);
+
+          const entry: {
+            slug: string;
+            title: string;
+            content: string;
+            tags?: string[];
+          } = {
+            slug: file.slug,
+            title: file.title,
+            content: plainText,
+          };
+
+          if (file.tags && file.tags.length > 0) {
+            entry.tags = file.tags;
+          }
+
+          index.push(entry);
+        }
+
+        ctx.output.set('search-index.json', JSON.stringify(index));
+      },
+    },
+  };
+}
+
+function stripHtmlKeepCode(html: string): string {
+  // First extract code block content to preserve it
+  const codeBlocks: string[] = [];
+  let result = html.replace(
+    /<pre><code class="language-(\w+)"[^>]*>([\s\S]*?)<\/code><\/pre>/g,
+    (match, lang, code) => {
+      const placeholder = `__CODE_BLOCK_${codeBlocks.length}__`;
+      codeBlocks.push(code);
+      return placeholder;
+    }
+  );
+
+  // Strip remaining HTML tags
+  result = result.replace(/<[^>]+>/g, ' ');
+  
+  // Restore code blocks
+  for (let i = 0; i < codeBlocks.length; i++) {
+    result = result.replace(`__CODE_BLOCK_${i}__`, codeBlocks[i]);
+  }
+
+  // Clean up whitespace
+  result = result.replace(/\s+/g, ' ').trim();
+  
+  return result;
+}
