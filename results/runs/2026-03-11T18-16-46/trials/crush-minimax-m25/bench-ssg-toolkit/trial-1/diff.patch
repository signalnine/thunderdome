+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import { marked } from 'marked';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Skip if already HTML
+        if (content.trim().startsWith('<')) {
+          return file;
+        }
+
+        // Extract footnote definitions BEFORE marked processes them
+        const footnoteDefs: Array<{ num: string; text: string }> = [];
+        content = content.replace(/\[\^(\d+)\]:\s*([^\n]+)/g, (match, num, text) => {
+          footnoteDefs.push({ num, text });
+          return ''; // Remove the definition from content
+        });
+
+        // Parse markdown
+        const html = marked.parse(content, { gfm: true, breaks: false }) as string;
+
+        // Replace footnote references with superscript links
+        let processedHtml = html.replace(/\[\^(\d+)\]/g, '<sup><a href="#fn-$1">$1</a></sup>');
+
+        // If we have footnotes, add the footnotes section
+        if (footnoteDefs.length > 0) {
+          // Sort by number
+          footnoteDefs.sort((a, b) => parseInt(a.num) - parseInt(b.num));
+
+          let footnotesSection = '<section class="footnotes">\n<ol>\n';
+          for (const fn of footnoteDefs) {
+            footnotesSection += `<li id="fn-${fn.num}">${fn.text}</li>\n`;
+          }
+          footnotesSection += '</ol>\n</section>';
+          processedHtml += '\n' + footnotesSection;
+        }
+
+        // Process admonitions
+        processedHtml = processAdmonitions(processedHtml);
+
+        return {
+          ...file,
+          content: processedHtml,
+        };
+      },
+    },
+  };
+}
+
+function processAdmonitions(html: string): string {
+  // Pattern: :::note\ncontent\n:::
+  const pattern = /:::(\w+)\n([\s\S]*?)\n:::/g;
+  
+  return html.replace(pattern, (match, type, content) => {
+    const trimmedContent = content.trim();
+    return `<div class="admonition admonition-${type}">${trimmedContent}</div>`;
+  });
+}
