+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  // Handle empty lights (no constraints)
+  if (numLights === 0) {
+    return [];
+  }
+
+  // Build augmented matrix [A|b] over GF(2)
+  // A[i][j] = 1 if button j toggles light i
+  // b[i] = target[i] (since lights start at 0/false)
+  const augmented: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row: number[] = [];
+    for (let j = 0; j < numButtons; j++) {
+      row.push(buttons[j].includes(i) ? 1 : 0);
+    }
+    row.push(target[i] ? 1 : 0);
+    augmented.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const rowEchelon = gaussianEliminationGF2(augmented);
+
+  if (rowEchelon === null) {
+    return null; // Inconsistent system
+  }
+
+  // Extract pivot columns and free columns
+  const { matrix: echelon, pivotCols, numRows } = rowEchelon;
+
+  // Determine free columns (non-pivot columns, excluding the augmented column)
+  const pivotSet = new Set(pivotCols);
+  const freeCols: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (!pivotSet.has(j)) {
+      freeCols.push(j);
+    }
+  }
+
+  // Find particular solution (set all free variables to 0)
+  const particular: number[] = new Array(numButtons).fill(0);
+  for (let row = 0; row < numRows; row++) {
+    const pivotCol = pivotCols[row];
+    particular[pivotCol] = echelon[row][numButtons];
+  }
+
+  // Build null space basis
+  const nullSpaceBasis: number[][] = [];
+  for (let i = 0; i < freeCols.length; i++) {
+    const freeCol = freeCols[i];
+    const basisVec = new Array(numButtons).fill(0);
+    basisVec[freeCol] = 1;
+
+    // For each row, if it has the free column, set pivot to that value
+    for (let row = 0; row < numRows; row++) {
+      const pivotCol = pivotCols[row];
+      if (echelon[row][freeCol] === 1) {
+        basisVec[pivotCol] = 1;
+      }
+    }
+    nullSpaceBasis.push(basisVec);
+  }
+
+  // Enumerate all solutions and find minimum weight
+  let bestSolution: number[] | null = null;
+  let bestWeight = Infinity;
+
+  const numFree = freeCols.length;
+
+  if (numFree === 0) {
+    // Unique solution
+    const weight = particular.reduce((a, b) => a + b, 0);
+    if (weight === 0) {
+      return [];
+    }
+    const indices = particular.map((v, i) => v === 1 ? i : -1).filter(i => i >= 0);
+    return indices.length > 0 ? indices : [];
+  }
+
+  // Iterate through all 2^numFree combinations
+  for (let mask = 0; mask < (1 << numFree); mask++) {
+    // Build solution: particular + sum(mask_i * basis_i)
+    const solution = [...particular];
+
+    for (let i = 0; i < numFree; i++) {
+      if ((mask >> i) & 1) {
+        for (let j = 0; j < numButtons; j++) {
+          solution[j] ^= nullSpaceBasis[i][j];
+        }
+      }
+    }
+
+    const weight = solution.reduce((a, b) => a + b, 0);
+
+    // Convert solution to indices for comparison
+    const indices = solution.map((v, i) => v === 1 ? i : -1).filter(i => i >= 0);
+    const bestIndices = bestSolution ? bestSolution.map((v, i) => v === 1 ? i : -1).filter(i => i >= 0) : null;
+
+    if (weight < bestWeight ||
+        (weight === bestWeight && bestIndices !== null && isLexicographicallySmaller(indices, bestIndices))) {
+      bestWeight = weight;
+      bestSolution = solution;
+    }
+  }
+
+  if (bestSolution === null) {
+    return null;
+  }
+
+  // Convert to indices
+  const indices: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (bestSolution[i] === 1) {
+      indices.push(i);
+    }
+  }
+
+  return indices;
+}
+
+function gaussianEliminationGF2(matrix: number[][]): { matrix: number[][], pivotCols: number[], numRows: number } | null {
+  const numRows = matrix.length;
+  const numCols = matrix[0].length;
+
+  let row = 0;
+  const pivotCols: number[] = [];
+
+  for (let col = 0; col < numCols - 1 && row < numRows; col++) {
+    // Find pivot row
+    let pivotRow = -1;
+    for (let i = row; i < numRows; i++) {
+      if (matrix[i][col] === 1) {
+        pivotRow = i;
+        break;
+      }
+    }
+
+    if (pivotRow === -1) {
+      continue; // No pivot in this column
+    }
+
+    // Swap rows
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+
+    // Eliminate below
+    for (let i = 0; i < numRows; i++) {
+      if (i !== row && matrix[i][col] === 1) {
+        for (let j = col; j < numCols; j++) {
+          matrix[i][j] ^= matrix[row][j];
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    row++;
+  }
+
+  // Check for inconsistency (row with all zeros except augmented column)
+  for (let i = row; i < numRows; i++) {
+    let allZero = true;
+    for (let j = 0; j < numCols - 1; j++) {
+      if (matrix[i][j] === 1) {
+        allZero = false;
+        break;
+      }
+    }
+    if (allZero && matrix[i][numCols - 1] === 1) {
+      return null; // Inconsistent
+    }
+  }
+
+  return { matrix, pivotCols, numRows: row };
+}
+
+function isLexicographicallySmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) {
+      return a[i] < b[i];
+    }
+  }
+  return false;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every(l => l === 0) ? [] : null;
+  }
+
+  // Handle empty counters (no constraints)
+  if (numCounters === 0) {
+    return new Array(numButtons).fill(0);
+  }
+
+  // Build augmented matrix [A|b] over Z_modulus
+  const augmented: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row: number[] = [];
+    for (let j = 0; j < numButtons; j++) {
+      row.push(buttons[j].includes(i) ? 1 : 0);
+    }
+    row.push(lights[i] % modulus);
+    augmented.push(row);
+  }
+
+  // Gaussian elimination over Z_p (p is prime)
+  const rowEchelon = gaussianEliminationModPrime(augmented, modulus);
+
+  if (rowEchelon === null) {
+    return null;
+  }
+
+  const { matrix: echelon, pivotCols, numRows } = rowEchelon;
+
+  // Determine free columns
+  const pivotSet = new Set(pivotCols);
+  const freeCols: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (!pivotSet.has(j)) {
+      freeCols.push(j);
+    }
+  }
+
+  // Find particular solution (set all free variables to 0)
+  const particular: number[] = new Array(numButtons).fill(0);
+  for (let row = 0; row < numRows; row++) {
+    const pivotCol = pivotCols[row];
+    particular[pivotCol] = echelon[row][numButtons];
+  }
+
+  // Build null space basis
+  const nullSpaceBasis: number[][] = [];
+  for (let i = 0; i < freeCols.length; i++) {
+    const freeCol = freeCols[i];
+    const basisVec = new Array(numButtons).fill(0);
+    basisVec[freeCol] = 1;
+
+    for (let row = 0; row < numRows; row++) {
+      const pivotCol = pivotCols[row];
+      const coeff = echelon[row][freeCol];
+      if (coeff !== 0) {
+        // x[pivotCol] = -coeff * x[freeCol] = (modulus - coeff) * x[freeCol]
+        basisVec[pivotCol] = (modulus - coeff) % modulus;
+      }
+    }
+    nullSpaceBasis.push(basisVec);
+  }
+
+  // Enumerate all solutions and find minimum total presses
+  let bestSolution: number[] | null = null;
+  let bestWeight = Infinity;
+
+  const numFree = freeCols.length;
+
+  if (numFree === 0) {
+    const weight = particular.reduce((a, b) => (a + b) % modulus, 0);
+    return weight === 0 ? new Array(numButtons).fill(0) : particular;
+  }
+
+  // For each combination of free variables, we need to also consider
+  // that free variables can take any value 0 to modulus-1
+  // This is modulus^numFree combinations, which could be large
+
+  // Instead, use a smarter approach: for each free variable,
+  // we can optimize its value to minimize total weight
+
+  // Actually, let's iterate through all combinations - worst case is small
+  // (modulus=97, numFree could be small)
+
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  // If too many combinations, use a different approach
+  if (totalCombinations > 100000) {
+    // Use iterative optimization: for each free variable, find optimal value
+    // considering current solution
+    return solveCounterOptimized(lights, buttons, modulus, echelon, pivotCols, freeCols, numButtons);
+  }
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    // Decode combo into free variable values
+    let temp = combo;
+    const freeVals: number[] = [];
+    for (let i = 0; i < numFree; i++) {
+      freeVals.push(temp % modulus);
+      temp = Math.floor(temp / modulus);
+    }
+
+    // Build solution
+    const solution = [...particular];
+    for (let i = 0; i < numFree; i++) {
+      if (freeVals[i] !== 0) {
+        for (let j = 0; j < numButtons; j++) {
+          solution[j] = (solution[j] + freeVals[i] * nullSpaceBasis[i][j]) % modulus;
+        }
+      }
+    }
+
+    const weight = solution.reduce((a, b) => a + b, 0);
+
+    if (weight < bestWeight ||
+        (weight === bestWeight && isLexicographicallySmallerNumArray(solution, bestSolution!))) {
+      bestWeight = weight;
+      bestSolution = solution;
+    }
+  }
+
+  return bestSolution;
+}
+
+// Optimized version for large search space
+function solveCounterOptimized(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+  echelon: number[][],
+  pivotCols: number[],
+  freeCols: number[],
+  numButtons: number
+): number[] | null {
+  const numCols = numButtons + 1;
+  const numRows = echelon.length;
+  const numFree = freeCols.length;
+
+  // Start with particular solution
+  let solution = new Array(numButtons).fill(0);
+  for (let row = 0; row < numRows; row++) {
+    const pivotCol = pivotCols[row];
+    solution[pivotCol] = echelon[row][numCols - 1];
+  }
+
+  // For each free variable, find the optimal value that minimizes total
+  // We can do this iteratively since the problem separates
+
+  // Actually, this is a linear programming problem over Z_p
+  // Let's use a simple iterative improvement approach
+
+  let improved = true;
+  let bestSolution = [...solution];
+  let bestWeight = bestSolution.reduce((a, b) => a + b, 0);
+
+  // Since modulus is prime and small (≤97), and numFree is likely small,
+  // we can try random restarts or local search
+  const maxIterations = 10000;
+
+  for (let iter = 0; iter < maxIterations && improved; iter++) {
+    improved = false;
+
+    for (let i = 0; i < numFree; i++) {
+      const freeCol = freeCols[i];
+
+      // Try all values for this free variable
+      for (let val = 0; val < modulus; val++) {
+        const testSolution = [...solution];
+        testSolution[freeCol] = val;
+
+        // Update pivot variables based on this free variable value
+        for (let row = 0; row < numRows; row++) {
+          const pivotCol = pivotCols[row];
+          const rhs = echelon[row][numCols - 1];
+
+          // x[pivot] = rhs - sum(echelon[row][free] * x[free]) for all free
+          let sum = 0;
+          for (let j = 0; j < numFree; j++) {
+            const fc = freeCols[j];
+            sum = (sum + echelon[row][fc] * testSolution[fc]) % modulus;
+          }
+          testSolution[pivotCol] = (rhs - sum + modulus) % modulus;
+        }
+
+        const weight = testSolution.reduce((a, b) => a + b, 0);
+
+        if (weight < bestWeight ||
+            (weight === bestWeight && isLexicographicallySmallerNumArray(testSolution, bestSolution))) {
+          bestWeight = weight;
+          bestSolution = testSolution;
+          solution = testSolution;
+          improved = true;
+        }
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+function gaussianEliminationModPrime(matrix: number[][], modulus: number): { matrix: number[][], pivotCols: number[], numRows: number } | null {
+  const numRows = matrix.length;
+  const numCols = matrix[0].length;
+
+  // Clone matrix to avoid mutation
+  const mat = matrix.map(row => [...row]);
+
+  let row = 0;
+  const pivotCols: number[] = [];
+
+  for (let col = 0; col < numCols - 1 && row < numRows; col++) {
+    // Find pivot row
+    let pivotRow = -1;
+    for (let i = row; i < numRows; i++) {
+      if (mat[i][col] !== 0) {
+        pivotRow = i;
+        break;
+      }
+    }
+
+    if (pivotRow === -1) {
+      continue;
+    }
+
+    // Swap rows
+    [mat[row], mat[pivotRow]] = [mat[pivotRow], mat[row]];
+
+    // Scale pivot row to make pivot = 1
+    const pivotVal = mat[row][col];
+    const invPivot = modInverse(pivotVal, modulus);
+    for (let j = col; j < numCols; j++) {
+      mat[row][j] = (mat[row][j] * invPivot) % modulus;
+    }
+
+    // Eliminate other rows
+    for (let i = 0; i < numRows; i++) {
+      if (i !== row && mat[i][col] !== 0) {
+        const factor = mat[i][col];
+        for (let j = col; j < numCols; j++) {
+          mat[i][j] = (mat[i][j] - factor * mat[row][j]) % modulus;
+          if (mat[i][j] < 0) mat[i][j] += modulus;
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    row++;
+  }
+
+  // Check for inconsistency
+  for (let i = row; i < numRows; i++) {
+    let allZero = true;
+    for (let j = 0; j < numCols - 1; j++) {
+      if (mat[i][j] !== 0) {
+        allZero = false;
+        break;
+      }
+    }
+    if (allZero && mat[i][numCols - 1] !== 0) {
+      return null;
+    }
+  }
+
+  return { matrix: mat, pivotCols, numRows: row };
+}
+
+function modInverse(a: number, modulus: number): number {
+  // Extended Euclidean Algorithm
+  let t = 0, newT = 1;
+  let r = modulus, newR = a % modulus;
+
+  while (newR !== 0) {
+    const quotient = Math.floor(r / newR);
+    const tempT = t - quotient * newT;
+    t = newT;
+    newT = tempT;
+    const tempR = r - quotient * newR;
+    r = newR;
+    newR = tempR;
+  }
+
+  if (r > 1) return -1; // No inverse
+  if (t < 0) t += modulus;
+  return t;
+}
+
+function isLexicographicallySmallerNumArray(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) {
+      return a[i] < b[i];
+    }
+  }
+  return false;
+}
