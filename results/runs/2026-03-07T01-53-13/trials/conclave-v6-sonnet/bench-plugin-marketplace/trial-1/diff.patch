+    });
+
+    it('returns false when version does not satisfy range', () => {
+      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+    });
+
+    it('handles exact version ranges', () => {
+      expect(resolver.satisfies('1.0.0', '1.0.0')).toBe(true);
+    });
+
+    it('handles tilde ranges', () => {
+      expect(resolver.satisfies('1.2.5', '~1.2.0')).toBe(true);
+      expect(resolver.satisfies('1.3.0', '~1.2.0')).toBe(false);
+    });
+  });
+
+  describe('maxSatisfying', () => {
+    it('returns the highest version satisfying a range', () => {
+      const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];
+      expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');
+    });
+
+    it('returns null when no version satisfies', () => {
+      const versions = ['2.0.0', '3.0.0'];
+      expect(resolver.maxSatisfying(versions, '^1.0.0')).toBeNull();
+    });
+
+    it('returns null for empty version list', () => {
+      expect(resolver.maxSatisfying([], '^1.0.0')).toBeNull();
+    });
+  });
+
+  describe('validRange', () => {
+    it('returns true for valid semver ranges', () => {
+      expect(resolver.validRange('^1.0.0')).toBe(true);
+      expect(resolver.validRange('~2.3.0')).toBe(true);
+      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+    });
+
+    it('returns false for invalid ranges', () => {
+      expect(resolver.validRange('not-a-version')).toBe(false);
+    });
+  });
+
+  describe('resolve', () => {
+    it('resolves a single constraint to the best matching version', () => {
+      const constraints: VersionConstraint[] = [
+        { name: 'lodash', range: '^4.0.0' },
+      ];
+      const available = { lodash: ['4.0.0', '4.17.21', '3.10.0'] };
+      const result = resolver.resolve(constraints, available);
+      expect(result).toHaveLength(1);
+      expect(result[0].name).toBe('lodash');
+      expect(result[0].version).toBe('4.17.21');
+      expect(result[0].satisfies).toBe('^4.0.0');
+    });
+
+    it('resolves multiple constraints independently', () => {
+      const constraints: VersionConstraint[] = [
+        { name: 'lib-a', range: '^1.0.0' },
+        { name: 'lib-b', range: '~2.1.0' },
+      ];
+      const available = {
+        'lib-a': ['1.0.0', '1.5.0', '2.0.0'],
+        'lib-b': ['2.0.0', '2.1.0', '2.1.5', '2.2.0'],
+      };
+      const result = resolver.resolve(constraints, available);
+      expect(result).toHaveLength(2);
+      const a = result.find(r => r.name === 'lib-a');
+      const b = result.find(r => r.name === 'lib-b');
+      expect(a?.version).toBe('1.5.0');
+      expect(b?.version).toBe('2.1.5');
+    });
+
+    it('returns empty array when no versions available for constraint', () => {
+      const constraints: VersionConstraint[] = [
+        { name: 'missing-dep', range: '^1.0.0' },
+      ];
+      const available: Record<string, string[]> = {};
+      const result = resolver.resolve(constraints, available);
+      expect(result).toHaveLength(0);
+    });
+
+    it('skips constraints where no version satisfies the range', () => {
+      const constraints: VersionConstraint[] = [
+        { name: 'lib-x', range: '^5.0.0' },
+      ];
+      const available = { 'lib-x': ['1.0.0', '2.0.0'] };
+      const result = resolver.resolve(constraints, available);
+      expect(result).toHaveLength(0);
+    });
+  });
+});
