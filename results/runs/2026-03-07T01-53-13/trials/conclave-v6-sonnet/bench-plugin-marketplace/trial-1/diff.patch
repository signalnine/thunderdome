+  name: 'my-plugin',
+  version: '1.0.0',
+  description: 'A plugin',
+  author: 'test',
+  dependencies: {},
+  entryPoint: '42',  // will be executed as code
+  permissions: [],
+  ...overrides,
+});
+
+describe('createMarketplace', () => {
+  let marketplace: ReturnType<typeof createMarketplace>;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('exposes all five services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('installs a plugin with no deps successfully', async () => {
+      const manifest = makeManifest({ entryPoint: '"installed"' });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe('installed');
+      expect(result.resolvedDeps).toEqual([]);
+    });
+
+    it('registers the plugin in the catalog after install', async () => {
+      const manifest = makeManifest();
+      await marketplace.installPlugin(manifest);
+      const found = marketplace.registry.get('my-plugin');
+      expect(found).not.toBeNull();
+      expect(found?.name).toBe('my-plugin');
+    });
+
+    it('resolves dependency versions that are in the registry', async () => {
+      // Pre-register a dependency
+      marketplace.registry.register(makeManifest({ name: 'dep-lib', version: '2.5.0' }));
+
+      const pluginWithDep = makeManifest({
+        name: 'consumer-plugin',
+        entryPoint: '"ok"',
+        dependencies: { 'dep-lib': '^2.0.0' },
+      });
+      const result = await marketplace.installPlugin(pluginWithDep);
+      expect(result.resolvedDeps).toHaveLength(1);
+      expect(result.resolvedDeps[0].name).toBe('dep-lib');
+      expect(result.resolvedDeps[0].version).toBe('2.5.0');
+    });
+
+    it('rejects plugin with missing required field: name', async () => {
+      const invalid = makeManifest({ name: '' });
+      await expect(marketplace.installPlugin(invalid)).rejects.toThrow();
+    });
+
+    it('rejects plugin with missing required field: version', async () => {
+      const invalid = makeManifest({ version: '' });
+      await expect(marketplace.installPlugin(invalid)).rejects.toThrow();
+    });
+
+    it('rejects plugin with missing required field: entryPoint', async () => {
+      const invalid = makeManifest({ entryPoint: '' });
+      await expect(marketplace.installPlugin(invalid)).rejects.toThrow();
+    });
+
+    it('rejects plugin installation when circular dependency is detected', async () => {
+      // Set up a circular dep: A -> B -> A
+      marketplace.registry.register(makeManifest({ name: 'circ-b', version: '1.0.0', dependencies: { 'circ-a': '1.0.0' } }));
+      const circA = makeManifest({
+        name: 'circ-a',
+        version: '1.0.0',
+        entryPoint: '1',
+        dependencies: { 'circ-b': '1.0.0' },
+      });
