pendencies.find(d => d.name === 'lib-b');\n      expect(libB).toBeDefined();\n      expect(libB?.dependencies).toHaveLength(1);\n      expect(libB?.dependencies[0].name).toBe('lib-c');\n    });\n\n    it('builds a leaf node for plugin with no deps', () => {\n      const tree = deps.buildTree('lib-c', registry);\n      expect(tree.name).toBe('lib-c');\n      expect(tree.dependencies).toHaveLength(0);\n    });\n  });\n\n  describe('detectCycles', () => {\n    it('returns null when there are no cycles', () => {\n      const cycles = deps.detectCycles('plugin-a', registry);\n      expect(cycles).toBeNull();\n    });\n\n    it('detects a direct circular dependency', () => {\n      // a -> b -> a (cycle)\n      const cycleReg = createRegistry();\n      cycleReg.register(makeManifest('cycler-a', '1.0.0', { 'cycler-b': '1.0.0' }));\n      cycleReg.register(makeManifest('cycler-b', '1.0.0', { 'cycler-a': '1.0.0' }));\n      const cycles = deps.detectCycles('cycler-a', cycleReg);\n      expect(cycles).not.toBeNull();\n      expect(cycles!.length).toBeGreaterThan(0);\n    });\n\n    it('detects an indirect circular dependency', () => {\n      // a -> b -> c -> a\n      const cycleReg = createRegistry();\n      cycleReg.register(makeManifest('xa', '1.0.0', { 'xb': '1.0.0' }));\n      cycleReg.register(makeManifest('xb', '1.0.0', { 'xc': '1.0.0' }));\n      cycleReg.register(makeManifest('xc', '1.0.0', { 'xa': '1.0.0' }));\n      const cycles = deps.detectCycles('xa', cycleReg);\n      expect(cycles).not.toBeNull();\n    });\n  });\n\n  describe('hasCircularDependency', () => {\n    it('returns false when there are no cycles', () => {\n      expect(deps.hasCircularDependency('plugin-a', registry)).toBe(false);\n    });\n\n    it('returns true when there is a cycle', () => {\n      const cycleReg = createRegistry();\n      cycleReg.register(makeManifest('ca', '1.0.0', { 'cb': '1.0.0' }));\n      cycleReg.register(makeManifest('cb', '1.0.0', { 'ca': '1.0.0' }));\n      expect(deps.hasCircularDependency('ca', cycleReg)).toBe(true);\n    });\n  });\n\n  describe('topologicalSort', () => {\n    it('produces a valid topological order', () => {\n      const order = deps.topologicalSort('plugin-a', registry);\n      // lib-c must come before lib-b and plugin-a\n      const idxC = order.indexOf('lib-c');\n      const idxB = order.indexOf('lib-b');\n      const idxA = order.indexOf('plugin-a');\n      expect(idxC).toBeLessThan(idxB);\n      expect(idxB).toBeLessThan(idxA);\n      expect(idxA).toBeLessThan(order.length);\n    });\n\n    it('includes all dependencies in the order', () => {\n      const order = deps.topologicalSort('plugin-a', registry);\n      expect(order).toContain('plugin-a');\n      expect(order).toContain('lib-b');\n      expect(order).toContain('lib-c');\n    });\n\n    it('returns just the plugin when it has no deps', () => {\n      const order = deps.topologicalSort('lib-c', registry);\n      expect(order).toEqual(['lib-c']);\n    });\n  });\n\n  describe('flattenDependencies', () => {\n    it('returns all transitive dependencies', () => {\n      const flat = deps.flattenDependencies('plugin-a', registry);\n      expect(flat).toContain('lib-b');\n      expect(flat).toContain('lib-c');\n      // Should not include the root plugin itself\n      expect(flat).not.toContain('plugin-a');\n    });\n\n    it('deduplicates shared dependencies', () => {\n      // Both plugin-a and lib-b depend on lib-c; should only appear once\n      const flat = deps.flattenDependencies('plugin-a', registry);\n      const count = flat.filter(d => d === 'lib-c').length;\n      expect(count).toBe(1);\n    });\n\n    it('returns empty array for a plugin with no deps', () => {\n      expect(deps.flattenDependencies('lib-c', registry)).toEqual([]);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":321,"cache_read_input_tokens":41662,"cache_creation":{"ephemer