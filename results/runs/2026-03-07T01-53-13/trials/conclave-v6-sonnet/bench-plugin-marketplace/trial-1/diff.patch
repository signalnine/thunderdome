    getReviewCount(pluginName: string): number {\n      return Array.from(reviews.values())\n        .filter(r => r.pluginName === pluginName)\n        .length;\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":334,"cache_read_input_tokens":40419,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":334},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"97ee607c-cada-4892-bf15-cfb55a487f06","uuid":"a36cd7ca-60ff-40d9-a990-93660d4824eb"}
