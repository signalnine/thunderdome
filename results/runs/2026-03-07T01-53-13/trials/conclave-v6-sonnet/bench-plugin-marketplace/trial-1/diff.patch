d.some(review => review.id === r.id)).toBe(true);\n    });\n  });\n\n  describe('getFlaggedReviews', () => {\n    it('returns all flagged reviews across all plugins', () => {\n      const r1 = service.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: '' });\n      service.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'u2', rating: 5, comment: '' });\n      service.flagReview(r1.id);\n      const flagged = service.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].id).toBe(r1.id);\n    });\n  });\n\n  describe('removeReview', () => {\n    it('removes an existing review and returns true', () => {\n      const r = service.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });\n      expect(service.removeReview(r.id)).toBe(true);\n      expect(service.getReviews('p')).toHaveLength(0);\n    });\n\n    it('returns false when removing non-existent review', () => {\n      expect(service.removeReview(999)).toBe(false);\n    });\n  });\n\n  describe('getReviewsByUser', () => {\n    it('returns all reviews by a specific user', () => {\n      service.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: '' });\n      service.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: '' });\n      service.addReview({ pluginName: 'c', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: '' });\n      const aliceReviews = service.getReviewsByUser('alice');\n      expect(aliceReviews).toHaveLength(2);\n      expect(aliceReviews.every(r => r.userId === 'alice')).toBe(true);\n    });\n\n    it('returns empty array for user with no reviews', () => {\n      expect(service.getReviewsByUser('ghost-user')).toEqual([]);\n    });\n  });\n\n  describe('getReviewCount', () => {\n    it('returns the count of all reviews for a plugin', () => {\n      service.addReview({ pluginName: 'p', pluginVersio