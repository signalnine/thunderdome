@@ -0,0 +1,57 @@
+import vm from 'node:vm';
+import type { RunnerService, SandboxResult } from '../types.js';
+
+export function createRunner(): RunnerService {
+  function runInSandbox(
+    code: string,
+    context: Record<string, unknown>,
+    timeoutMs: number
+  ): SandboxResult {
+    const start = performance.now();
+    const memBefore = process.memoryUsage().heapUsed;
+
+    try {
+      // Create a clean sandbox context with no Node globals
+      const sandbox: Record<string, unknown> = { ...context };
+      vm.createContext(sandbox);
+
+      const script = new vm.Script(code);
+      const output = script.runInContext(sandbox, { timeout: timeoutMs });
+
+      const duration = performance.now() - start;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - memBefore);
+
+      return {
+        success: true,
+        output,
+        duration,
+        memoryUsed,
+      };
+    } catch (err) {
+      const duration = performance.now() - start;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - memBefore);
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed,
+        error: err instanceof Error ? err.message : String(err),
+      };
+    }
+  }
+
+  return {
+    async execute(code: string, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+      return runInSandbox(code, context, 5000);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context: Record<string, unknown> = {}
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, context, timeoutMs);
+    },
+  };
+}
