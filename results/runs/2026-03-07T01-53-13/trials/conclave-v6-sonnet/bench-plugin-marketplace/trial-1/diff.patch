@@ -0,0 +1,115 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeInner(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    if (visited.has(name)) {
+      // Cycle: return node without expanding further
+      return { name, version: manifest.version, dependencies: [] };
+    }
+
+    visited.add(name);
+    const children: DependencyNode[] = Object.keys(manifest.dependencies).map(depName =>
+      buildTreeInner(depName, registry, new Set(visited))
+    );
+    visited.delete(name);
+
+    return { name, version: manifest.version, dependencies: children };
+  }
+
+  function detectCyclesInner(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    cycles: string[][]
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      const cycleStart = path.indexOf(depName);
+      if (cycleStart !== -1) {
+        // Found a cycle
+        cycles.push([...path.slice(cycleStart), depName]);
+      } else {
+        detectCyclesInner(depName, registry, [...path, depName], cycles);
+      }
+    }
+  }
+
+  function topoSortInner(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        topoSortInner(depName, registry, visited, result);
+      }
+    }
+
+    result.push(name);
+  }
+
+  function flattenInner(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: Set<string>
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!visited.has(depName)) {
+        visited.add(depName);
+        result.add(depName);
+        flattenInner(depName, registry, visited, result);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeInner(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles: string[][] = [];
+      detectCyclesInner(name, registry, [name], cycles);
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const result: string[] = [];
+      topoSortInner(name, registry, new Set(), result);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const result = new Set<string>();
+      const visited = new Set<string>([name]);
+      flattenInner(name, registry, visited, result);
+      return Array.from(result);
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const cycles: string[][] = [];
+      detectCyclesInner(name, registry, [name], cycles);
+      return cycles.length > 0;
+    },
+  };
+}
