@@ -0,0 +1,83 @@
+import type { PluginManifest, RegistryService } from '../types.js';
+
+export function createRegistry(): RegistryService {
+  // In-memory store: name -> version -> manifest
+  const store = new Map<string, Map<string, PluginManifest>>();
+
+  function getVersionMap(name: string): Map<string, PluginManifest> {
+    if (!store.has(name)) {
+      store.set(name, new Map());
+    }
+    return store.get(name)!;
+  }
+
+  return {
+    register(manifest: PluginManifest): void {
+      const versions = getVersionMap(manifest.name);
+      versions.set(manifest.version, { ...manifest });
+    },
+
+    get(name: string): PluginManifest | null {
+      const versions = store.get(name);
+      if (!versions || versions.size === 0) return null;
+      // Return the last registered version
+      const entries = Array.from(versions.values());
+      return entries[entries.length - 1];
+    },
+
+    getVersion(name: string, version: string): PluginManifest | null {
+      return store.get(name)?.get(version) ?? null;
+    },
+
+    list(): PluginManifest[] {
+      const result: PluginManifest[] = [];
+      for (const versions of store.values()) {
+        if (versions.size > 0) {
+          const entries = Array.from(versions.values());
+          result.push(entries[entries.length - 1]);
+        }
+      }
+      return result;
+    },
+
+    search(query: string): PluginManifest[] {
+      const lower = query.toLowerCase();
+      const seen = new Set<string>();
+      const result: PluginManifest[] = [];
+      for (const [, versions] of store) {
+        for (const manifest of versions.values()) {
+          if (
+            !seen.has(manifest.name) &&
+            (manifest.name.toLowerCase().includes(lower) ||
+              manifest.description.toLowerCase().includes(lower))
+          ) {
+            seen.add(manifest.name);
+            result.push(manifest);
+          }
+        }
+      }
+      return result;
+    },
+
+    remove(name: string, version: string): boolean {
+      const versions = store.get(name);
+      if (!versions || !versions.has(version)) return false;
+      versions.delete(version);
+      return true;
+    },
+
+    listVersions(name: string): string[] {
+      const versions = store.get(name);
+      if (!versions) return [];
+      return Array.from(versions.keys());
+    },
+
+    update(name: string, version: string, updates: Partial<PluginManifest>): void {
+      const versions = store.get(name);
+      if (!versions) return;
+      const existing = versions.get(version);
+      if (!existing) return;
+      versions.set(version, { ...existing, ...updates });
+    },
+  };
+}
