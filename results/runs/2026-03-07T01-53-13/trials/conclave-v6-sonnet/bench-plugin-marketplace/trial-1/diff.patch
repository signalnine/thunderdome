+
+    it('returns failure result for syntax errors', async () => {
+      const result = await runner.execute('{{{{invalid syntax');
+      expect(result.success).toBe(false);
+      expect(result.error).toBeDefined();
+    });
+
+    it('includes timing information in the result', async () => {
+      const result = await runner.execute('42');
+      expect(typeof result.duration).toBe('number');
+      expect(result.duration).toBeGreaterThanOrEqual(0);
+    });
+
+    it('includes memory info in the result', async () => {
+      const result = await runner.execute('42');
+      expect(typeof result.memoryUsed).toBe('number');
+      expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+    });
+
+    it('sandbox cannot access Node.js process object by default', async () => {
