+  // We'll attempt to schedule in topological order, trying to maximize events.
+  // Strategy: for each event in topo order, try to place it in the best room.
+  // "Best" means: preferred room first, then earliest available slot.
+  // If an event can't fit, mark it unscheduled.
+
+  for (const eventId of topoOrder) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+
+    // Determine minimum start time from prerequisites
+    const minStart = getMinStartFromPrereqs(eventId);
+    if (minStart === null) {
+      unscheduled.add(eventId);
+      continue;
+    }
+
+    // Filter rooms by capacity
+    const eligibleRooms = rooms.filter(r => r.capacity >= attendees);
+
+    if (eligibleRooms.length === 0) {
+      unscheduled.add(eventId);
+      continue;
+    }
+
+    // Try preferred room first, then all eligible rooms sorted by earliest slot
+    const preferredRoomId = event.preferredRoom;
+    const orderedRooms = preferredRoomId
+      ? [
+          ...eligibleRooms.filter(r => r.id === preferredRoomId),
+          ...eligibleRooms.filter(r => r.id !== preferredRoomId),
+        ]
+      : eligibleRooms;
+
+    let bestAssignment: Assignment | null = null;
+
+    for (const room of orderedRooms) {
+      const roomSlots = roomAssignments.get(room.id) ?? [];
+      const startTime = findEarliestSlot(
+        roomSlots,
