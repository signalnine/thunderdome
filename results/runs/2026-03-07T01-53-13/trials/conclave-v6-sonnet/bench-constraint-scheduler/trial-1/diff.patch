+    // room for 2+ unscheduled events.
+    let improved = true;
+    while (improved) {
+      improved = false;
+
+      for (const [candidateId, candidateAssignment] of assignedEvents) {
+        // Tentatively remove this event and re-attempt the unscheduled ones
+        const tentativeAssigned = new Map(assignedEvents);
+        tentativeAssigned.delete(candidateId);
+
+        const tentativeRoomAssignments = new Map<string, Assignment[]>(
+          rooms.map(r => [r.id, []]),
+        );
+        for (const [, a] of tentativeAssigned) {
+          tentativeRoomAssignments.get(a.roomId)!.push(a);
+        }
+        tentativeRoomAssignments.get(candidateAssignment.roomId)!;
+
+        // Try to schedule the candidate's dependents would be blocked — skip
+        // events that depend on candidateId
+        const dependsOnCandidate = new Set<string>();
+        for (const [id, evt] of eventMap) {
