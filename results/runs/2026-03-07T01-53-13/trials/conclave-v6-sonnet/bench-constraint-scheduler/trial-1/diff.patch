+          bestAssignment = {
+            eventId,
+            roomId: room.id,
+            startTime,
+            endTime: startTime + event.duration,
+          };
+        }
+      }
+    }
+
+    if (bestAssignment === null) {
+      unscheduled.add(eventId);
+      continue;
+    }
+
+    // Record the assignment
+    assignedEvents.set(eventId, bestAssignment);
+    roomAssignments.get(bestAssignment.roomId)!.push(bestAssignment);
+  }
