+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Topologically sort events using Kahn's algorithm.
+ * Throws if a cycle (including self-references) is detected.
+ * Returns event IDs in topological order.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjacency = new Map<string, string[]>(); // prereq -> dependents
+
+  for (const e of events) {
+    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);
+    if (!adjacency.has(e.id)) adjacency.set(e.id, []);
+  }
+
+  for (const e of events) {
+    const prereqs = e.prerequisites ?? [];
+    for (const prereq of prereqs) {
+      // Self-reference check
+      if (prereq === e.id) {
+        throw new Error(`Cycle detected: event '${e.id}' is its own prerequisite`);
+      }
+      // Unknown prereq — we'll handle it later in scheduling (not a cycle)
+      if (!eventIds.has(prereq)) continue;
+
+      adjacency.get(prereq)!.push(e.id);
+      inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const order: string[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    order.push(id);
+    for (const dep of adjacency.get(id) ?? []) {
+      const newDeg = (inDegree.get(dep) ?? 0) - 1;
+      inDegree.set(dep, newDeg);
+      if (newDeg === 0) queue.push(dep);
+    }
+  }
+
+  if (order.length < events.length) {
+    throw new Error('Cycle detected in prerequisite graph');
+  }
+
+  return order;
+}
+
+/**
+ * Find the earliest slot in a room for an event, given a minimum start time.
+ * Returns the start time, or null if it cannot fit.
+ */
+function findEarliestSlot(
+  roomAssignments: Assignment[],
+  minStart: number,
+  duration: number,
+  gap: number,
+  windowEnd: number,
+): number | null {
+  // Sort existing assignments in this room by start time
+  const sorted = roomAssignments.slice().sort((a, b) => a.startTime - b.startTime);
+
+  let candidate = minStart;
+
+  for (const existing of sorted) {
+    // If candidate + duration fits before existing event starts, we found a slot
+    if (candidate + duration <= existing.startTime) {
+      break;
+    }
+    // Otherwise, we must push start to after this existing event (with gap)
+    const afterThis = existing.endTime + gap;
+    if (afterThis > candidate) {
+      candidate = afterThis;
+    }
+  }
+
+  // Check if candidate fits in window
+  if (candidate + duration <= windowEnd) {
+    return candidate;
+  }
+
+  return null;
+}
+
+/**
+ * Schedule events into rooms respecting all constraints.
+ * Maximizes the number of events scheduled.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+): ScheduleResult {
+  if (events.length === 0) return { assignments: [], unscheduled: [] };
+
+  const gap = options.gap ?? 15;
+
+  // Detect cycles and get topological order
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>(events.map(e => [e.id, e]));
+  const eventIds = new Set(events.map(e => e.id));
+
+  // Track assignments per room
+  const roomAssignments = new Map<string, Assignment[]>(
+    rooms.map(r => [r.id, []]),
+  );
+
+  // Track final assignment per event
+  const assignedEvents = new Map<string, Assignment>();
+  const unscheduled = new Set<string>();
+
+  // Determine if an event has any unresolvable prerequisites (unknown or unscheduled)
+  function getMinStartFromPrereqs(eventId: string): number | null {
+    const event = eventMap.get(eventId)!;
+    const prereqs = event.prerequisites ?? [];
+    let minStart = options.startTime;
+
+    for (const prereqId of prereqs) {
+      if (!eventIds.has(prereqId)) {
+        // Unknown prerequisite — event cannot be scheduled
+        return null;
+      }
+      if (unscheduled.has(prereqId)) {
+        // Prerequisite failed to schedule — this event also cannot be scheduled
+        return null;
+      }
+      const prereqAssignment = assignedEvents.get(prereqId);
+      if (!prereqAssignment) {
+        // Prerequisite not yet scheduled in this pass — shouldn't happen in topo order
+        return null;
+      }
+      const earliest = prereqAssignment.endTime + gap;
+      if (earliest > minStart) {
+        minStart = earliest;
+      }
+    }
+
+    return minStart;
+  }
