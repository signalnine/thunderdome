n: 60 },\n      { id: 'e3', name: 'C', duration: 60 },\n      { id: 'e4', name: 'D', duration: 60 },\n    ];\n    const rooms = makeRooms(10);\n    const result = schedule(events, rooms, opts);\n    expect(result.assignments).toHaveLength(4);\n  });\n\n  it('places unschedulable events in unscheduled list', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Impossible', duration: 60, attendees: 999 },\n    ];\n    const rooms = makeRooms(10);\n    const result = schedule(events, rooms, opts);\n    expect(result.unscheduled).toContain('e1');\n    expect(result.assignments).toHaveLength(0);\n  });\n});\n\n// ─── Edge cases ───────────────────────────────────────────────────────────────\n\ndescribe('edge cases', () => {\n  it('handles zero-gap option', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'A', duration: 60 },\n      { id: 'e2', name: 'B', duration: 60 },\n    ];\n    const rooms = makeRooms(10);\n    const zeroGapOpts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 0 };\n    const result = schedule(events, rooms, zeroGapOpts);\n    expect(result.assignments).toHaveLength(2);\n    const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n    expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);\n  });\n\n  it('handles event with unknown prerequisite (treats it as unschedulable)', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Talk', duration: 60, prerequisites: ['nonexistent'] },\n    ];\n    const rooms = makeRooms(10);\n    const result = schedule(events, rooms, opts);\n    expect(result.unscheduled).toContain('e1');\n  });\n\n  it('returns event IDs in unscheduled, not names', () => {\n    const events: Event[] = [\n      { id: 'my-event-id', name: 'My Event Name', duration: 60, attendees: 999 },\n    ];\n    const rooms = makeRooms(10);\n    const result = schedule(events, rooms, opts);\n    expect(result.unscheduled).toContain('my-event-id');\n    expect(result.unscheduled).not.toContain('My Event Name');\n  });\n\n  it('handles no rooms', () => {\n    const events: Event[] = [{ id: 'e1', name: 'Talk', duration: 60 }];\n    const result = schedule(events, [], opts);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toContain('e1');\n  });\n\n  it('handles event with empty prerequisites array', () => {\n    const events: Event[] = [{ id: 'e1', name: 'Talk', duration: 60, prerequisites: [] }];\n    const rooms = makeRooms(10);\n    const result = schedule(events, rooms, opts);\n    expect(result.assignments).toHaveLength(1);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
