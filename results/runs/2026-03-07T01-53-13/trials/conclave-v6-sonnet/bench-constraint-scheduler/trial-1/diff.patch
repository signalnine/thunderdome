+          for (const prereqId of uEvent.prerequisites ?? []) {
+            if (!eventIds.has(prereqId)) { uMinStart = null; break; }
+            if (!tentativeAssigned.has(prereqId) && !gainable.includes(prereqId)) {
+              uMinStart = null; break;
+            }
+            const prereqA = tentativeAssigned.get(prereqId);
+            if (prereqA) {
+              const earliest = prereqA.endTime + gap;
+              if (earliest > uMinStart!) uMinStart = earliest;
+            }
+          }
+          if (uMinStart === null) continue;
+
+          for (const room of preferredFirst) {
+            const slots = tentativeRoomAssignments.get(room.id) ?? [];
+            const st = findEarliestSlot(slots, uMinStart, uEvent.duration, gap, options.endTime);
+            if (st !== null) {
+              const newA: Assignment = {
+                eventId: uId,
+                roomId: room.id,
+                startTime: st,
+                endTime: st + uEvent.duration,
+              };
+              tentativeRoomAssignments.get(room.id)!.push(newA);
+              gainable.push(uId);
+              break;
+            }
+          }
+        }
+
+        // If removing candidateId gains more than 1 extra event, it's worth it
+        if (gainable.length > 1) {
+          // Apply tentative changes
+          assignedEvents.delete(candidateId);
+          unscheduled.add(candidateId);
+
+          // Rebuild roomAssignments from scratch
+          for (const [rid] of roomAssignments) {
+            roomAssignments.set(rid, []);
+          }
+          for (const [, a] of tentativeAssigned) {
+            roomAssignments.get(a.roomId)!.push(a);
+          }
+
+          for (const gId of gainable) {
+            const gEvent = eventMap.get(gId)!;
+            const gAttendees = gEvent.attendees ?? 1;
+            const eligRooms = rooms.filter(r => r.capacity >= gAttendees);
+            const preferredFirst = gEvent.preferredRoom
+              ? [
+                  ...eligRooms.filter(r => r.id === gEvent.preferredRoom),
+                  ...eligRooms.filter(r => r.id !== gEvent.preferredRoom),
+                ]
+              : eligRooms;
+
+            let gMinStart: number | null = options.startTime;
+            for (const prereqId of gEvent.prerequisites ?? []) {
+              if (!eventIds.has(prereqId)) { gMinStart = null; break; }
+              const prereqA = assignedEvents.get(prereqId);
+              if (!prereqA) { gMinStart = null; break; }
+              const earliest = prereqA.endTime + gap;
+              if (earliest > gMinStart!) gMinStart = earliest;
+            }
+            if (gMinStart === null) continue;
+
+            for (const room of preferredFirst) {
+              const slots = roomAssignments.get(room.id) ?? [];
+              const st = findEarliestSlot(slots, gMinStart, gEvent.duration, gap, options.endTime);
+              if (st !== null) {
+                const newA: Assignment = {
+                  eventId: gId,
+                  roomId: room.id,
+                  startTime: st,
+                  endTime: st + gEvent.duration,
+                };
+                assignedEvents.set(gId, newA);
+                unscheduled.delete(gId);
+                roomAssignments.get(room.id)!.push(newA);
+                break;
+              }
+            }
+          }
+
+          improved = true;
+          break; // restart the loop
+        }
+      }
+    }
+  }
+
+  return {
+    assignments: [...assignedEvents.values()],
+    unscheduled: [...unscheduled],
+  };
+}
+
+export default schedule;
