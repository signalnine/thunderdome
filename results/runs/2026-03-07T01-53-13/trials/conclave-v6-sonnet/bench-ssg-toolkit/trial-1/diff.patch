@@ -0,0 +1,35 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function stripHtml(html: string): string {
+  return html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
+}
+
+interface SearchEntry {
+  slug: string;
+  title: string;
+  content: string;
+  tags?: string[];
+}
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const index: SearchEntry[] = ctx.files.map((file: ContentFile) => {
+          const entry: SearchEntry = {
+            slug: file.slug,
+            title: file.title,
+            content: stripHtml(file.content),
+          };
+          if (file.tags) entry.tags = file.tags;
+          return entry;
+        });
+
+        ctx.output.set('search-index.json', JSON.stringify(index));
+      },
+    },
+  };
+}
