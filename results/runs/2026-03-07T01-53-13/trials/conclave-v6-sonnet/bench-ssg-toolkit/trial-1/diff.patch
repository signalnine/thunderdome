+import type { Plugin, BuildContext } from '../core/types.js';
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const { config } = ctx;
+        const baseUrl = config.baseUrl.replace(/\/$/, '');
+
+        const urls: string[] = [];
+
+        // Add all pages from ctx.output (except sitemap.xml itself)
+        for (const path of ctx.output.keys()) {
+          if (path === 'sitemap.xml') continue;
+          urls.push(`${baseUrl}/${path}`);
+        }
+
+        const urlEntries = urls
+          .map((url) => `  <url>\n    <loc>${url}</loc>\n  </url>`)
+          .join('\n');
+
+        const xml = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+${urlEntries}
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', xml);
+      },
+    },
+  };
+}
