+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        // Match <pre><code class="language-XXX">...</code></pre>
+        const content = file.content.replace(
+          /<pre><code class="language-([^"]+)">/g,
+          (_m, lang: string) =>
+            `<pre data-language="${lang}"><code class="language-${lang} highlighted">`
+        );
+        return { ...file, content };
+      },
+    },
+  };
+}
