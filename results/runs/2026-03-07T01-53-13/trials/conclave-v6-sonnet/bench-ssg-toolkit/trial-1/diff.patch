@@ -0,0 +1,53 @@
+import type { Plugin, BuildContext } from '../core/types.js';
+
+interface Route {
+  path: string;
+  handler: string;
+}
+
+interface DevServerConfig {
+  port: number;
+  routes: Route[];
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+interface AssetManifest {
+  assets: string[];
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const manifest = ctx.data.get('asset-manifest') as AssetManifest | undefined;
+        const assetPaths = manifest?.assets ?? [];
+
+        const routes: Route[] = [];
+
+        // Asset routes
+        for (const asset of assetPaths) {
+          routes.push({ path: `/assets/${asset}`, handler: 'asset' });
+        }
+
+        // Content routes from ctx.output
+        for (const path of ctx.output.keys()) {
+          if (path === 'search-index.json') continue;
+          routes.push({ path: `/${path}`, handler: 'static' });
+        }
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath: '/search-index.json',
+        };
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
