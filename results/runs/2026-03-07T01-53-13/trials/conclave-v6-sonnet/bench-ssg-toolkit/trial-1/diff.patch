+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,45 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+interface AssetManifest {
+  assets: string[];
+}
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+        const discovered: string[] = [];
+
+        // Rewrite relative src="./..." → src="/assets/..."
+        let content = file.content.replace(
+          /src="\.\/([^"]+)"/g,
+          (_m, path: string) => {
+            discovered.push(path);
+            return `src="/assets/${path}"`;
+          }
+        );
+
+        // Rewrite relative href="./..." → href="/assets/..."
+        content = content.replace(
+          /href="\.\/([^"]+)"/g,
+          (_m, path: string) => {
+            discovered.push(path);
+            return `href="/assets/${path}"`;
+          }
+        );
+
+        // Update manifest in ctx.data
+        if (discovered.length > 0) {
+          const existing = (ctx.data.get('asset-manifest') as AssetManifest | undefined) ?? { assets: [] };
+          const updated: AssetManifest = { assets: [...existing.assets, ...discovered] };
+          ctx.data.set('asset-manifest', updated);
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
