.registerTemplate(createDefaultTemplate());\n    52→    const file = makeFile({ title: 'My Post', content: '<p>Content here</p>' });\n    53→    const ctx = await engine.build([file]);\n    54→    const output = ctx.output.get('test-post.html')!;\n    55→    expect(output).toContain('<!DOCTYPE html>');\n    56→    expect(output).toContain('My Post');\n    57→    expect(output).toContain('<p>Content here</p>');\n    58→    expect(output).toContain('Test Site');\n    59→  });\n    60→\n    61→  it('builds with list template and renders list HTML', async () => {\n    62→    const engine = new BuildEngine(testConfig);\n    63→    engine.registerTemplate(createListTemplate());\n    64→    const file = makeFile({ title: 'My List', content: '<ul><li>Item</li></ul>', template: 'list' });\n    65→    const ctx = await engine.build([file]);\n    66→    const output = ctx.output.get('test-post.html')!;\n    67→    expect(output).toContain('<!DOCTYPE html>');\n    68→    expect(output).toContain('My List');\n    69→    expect(output).toContain('<div class=\"list\">');\n    70→    expect(output).toContain('<ul><li>Item</li></ul>');\n    71→  });\n    72→\n    73→  it('outputs raw content when no matching template', async () => {\n    74→    const engine = new BuildEngine(testConfig);\n    75→    const file = makeFile({ content: '<p>Raw content</p>' });\n    76→    const ctx = await engine.build([file]);\n    77→    expect(ctx.output.get('test-post.html')).toBe('<p>Raw content</p>');\n    78→  });\n    79→\n    80→  it('calls plugin beforeBuild hook', async () => {\n    81→    const engine = new BuildEngine(testConfig);\n    82→    let called = false;\n    83→    engine.registerPlugin(makePlugin({\n    84→      hooks: {\n    85→        beforeBuild: () => { called = true; },\n    86→      },\n    87→    }));\n    88→    await engine.build([]);\n    89→    expect(called).toBe(true);\n    90→  });\n    91→\n    92→  it('calls plugin transformContent hook to transform files', async () => {\n    93→    const engine = new BuildEngine(testConfig);\n    94→    engine.registerPlugin(makePlugin({\n    95→      hooks: {\n    96→        transformContent: (file) => ({\n    97→          ...file,\n    98→          content: file.content.toUpperCase(),\n    99→        }),\n   100→      },\n   101→    }));\n   102→    const ctx = await engine.build([makeFile({ content: 'hello' })]);\n   103→    expect(ctx.files[0].content).toBe('HELLO');\n   104→  });\n   105→\n   106→  it('calls plugin afterBuild hook', async () => {\n   107→    const engine = new BuildEngine(testConfig);\n   108→    let called = false;\n   109→    engine.registerPlugin(makePlugin({\n   110→      hooks: {\n   111→        afterBuild: () => { called = true; },\n   112→      },\n   113→    }));\n   114→    await engine.build([]);\n   115→    expect(called).toBe(true);\n   116→  });\n   117→\n   118→  it('executes plugins in dependency order', () => {\n   119→    const engine = new BuildEngine(testConfig);\n   120→    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n   121→    engine.registerPlugin(makePlugin({ name: 'a', dependencies: [] }));\n   122→    const order = engine.resolvePluginOrder();\n   123→    expect(order.map(p => p.name)).toEqual(['a', 'b']);\n   124→  });\n   125→\n   126→  it('throws on circular dependency', () => {\n   127→    const engine = new BuildEngine(testConfig);\n   128→    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['b'] }));\n   129→    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n   130→    expect(() => engine.resolvePluginOrder()).toThrow('Circular dependency');\n   131→  });\n   132→\n   133→  it('throws on missing dependency', () => {\n   134→    const engine = new BuildEngine(testConfig);\n   135→    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['missing'] }));\n   136→    expect(() => engine.resolvePluginOrder()).toThrow('Missing dependency');\n   137→  });\n   138→\n   139→  it('applies multiple plugins transformContent in order', async () => {\n   140→    const engine = new BuildEngine(testConfig);\n   141→    engine.registerPlugin(makePlugin({\n   142→      name: 'first',\n   143→      hooks: {\n   144→        transformContent: (file) => ({\n   145→          ...file,\n   146→          content: file.content + ' [first]',\n   147→        }),\n   148→      },\n   149→    }));\n   150→    engine.registerPlugin(makePlugin({\n   151→      name: 'second',\n   152→      hooks: {\n   153→        transformContent: (file) => ({\n   154→          ...file,\n   155→          content: file.content + ' [second]',\n   156→        }),\n   157→      },\n   158→    }));\n   159→    const ctx = await engine.build([makeFile({ content: 'start' })]);\n   160→    expect(ctx.files[0].content).toBe('start [first] [second]');\n   161→  });\n   162→\n   163→  it('provides shared data store in build context', async () => {\n   164→    const engine = new BuildEngine(testConfig);\n   165→    engine.registerPlugin(makePlugin({\n   166→      hooks: {\n   167→        beforeBuild: (ctx) => { ctx.data.set('key', 'value'); },\n   168→      },\n   169→    }));\n   170→    const ctx = await engine.build([]);\n   171→    expect(ctx.data.get('key')).toBe('value');\n   172→  });\n   173→\n   174→  it('retains file metadata through build', async () => {\n   175→    const engine = new BuildEngine(testConfig);\n   176→    const file = makeFile({\n   177→      metadata: { author: 'Alice', category: 'tech' },\n   178→      date: '2024-01-01',\n   179→      tags: ['js', 'node'],\n   180→    });\n   181→    const ctx = await engine.build([file]);\n   182→    expect(ctx.files[0].metadata).toEqual({ author: 'Alice', category: 'tech' });\n   183→    expect(ctx.files[0].date).toBe('2024-01-01');\n   184→    expect(ctx.files[0].tags).toEqual(['js', 'node']);\n   185→  });\n   186→\n   187→  it('produces empty output for empty file list', async () => {\n   188→    const engine = new BuildEngine(testConfig);\n   189→    engine.registerTemplate(createDefaultTemplate());\n   190→    const ctx = await engine.build([]);\n   191→    expect(ctx.output.size).toBe(0);\n   192→    expect(ctx.files).toHaveLength(0);\n   193→  });\n   194→});\n   195→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01JZvociZqb2yqL27iK7BWJ6","session_id":"af57acaa-4cf1-469e-b7c0-c8f067ef643e","uuid":"28f68dae-3bc3-4447-af41-b9b705b3ecf9"}
