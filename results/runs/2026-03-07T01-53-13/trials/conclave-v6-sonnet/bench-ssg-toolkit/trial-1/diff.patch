+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,62 @@
+import { marked } from 'marked';
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonition containers before markdown parsing
+        content = content.replace(
+          /^:::(note|warning|tip)\n([\s\S]*?)\n:::$/gm,
+          (_match, type: string, inner: string) =>
+            `<div class="admonition admonition-${type}">${inner.trim()}</div>`
+        );
+
+        // Process footnotes: collect definitions
+        const footnoteRefs: Record<string, string> = {};
+        content = content.replace(/\[\^(\w+)\]: (.+)/g, (_m, id: string, text: string) => {
+          footnoteRefs[id] = text;
+          return '';
+        });
+
+        // Replace inline footnote references
+        content = content.replace(
+          /\[\^(\w+)\]/g,
+          (_m, id: string) => `[^${id}]`
+        );
+
+        // Convert markdown to HTML
+        let html = marked.parse(content) as string;
+
+        // Replace footnote inline markers with superscript links
+        // marked may have already processed them or left them as-is
+        // We need a numeric mapping
+        const footnoteIds = Object.keys(footnoteRefs);
+        const idToNum: Record<string, number> = {};
+        footnoteIds.forEach((id, i) => {
+          idToNum[id] = i + 1;
+        });
+
+        html = html.replace(/\[\^(\w+)\]/g, (_m, id: string) => {
+          const num = idToNum[id] ?? id;
+          return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+        });
+
+        // Append footnotes section if any
+        if (footnoteIds.length > 0) {
+          const items = footnoteIds
+            .map((id) => `<li id="fn-${idToNum[id]}">${footnoteRefs[id]}</li>`)
+            .join('\n');
+          html += `\n<section class="footnotes"><ol>\n${items}\n</ol></section>`;
+        }
+
+        return { ...file, content: html };
+      },
+    },
+  };
+}
