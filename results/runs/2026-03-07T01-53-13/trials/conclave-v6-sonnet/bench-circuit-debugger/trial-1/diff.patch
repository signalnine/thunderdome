ring): Gate | undefined {\n    return byStructure.get(gateKey(op, a, b));\n  }\n\n  const byOpInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const key = `${g.op}:${w}`;\n      const arr = byOpInput.get(key) ?? [];\n      arr.push(g);\n      byOpInput.set(key, arr);\n    }\n  }\n  function findByOpInput(op: Gate['op'], wire: string): Gate[] {\n    return byOpInput.get(`${op}:${wire}`) ?? [];\n  }\n\n  // We track carry by its actual wire name in the (possibly swapped) circuit.\n  // After detecting a swap in bit i, we correct carry before processing bit i+1.\n  let carry: string | undefined;\n\n  for (let i = 0; i < bits; i++) {\n    const xi = wireName('x', i);\n    const yi = wireName('y', i);\n    const zi = wireName('z', i);\n\n    if (i === 0) {\n      // ── Bit 0: half adder ──────────────────────────────────────────────────\n      // xi XOR yi -> z0  (required)\n      const xorGate = findGate('XOR', xi, yi);\n      if (xorGate && xorGate.out !== zi) {\n        swapped.add(xorGate.out);\n        swapped.add(zi);\n      }\n\n      // xi AND yi -> carry0\n      const andGate = findGate('AND', xi, yi);\n      if (andGate) carry = andGate.out;\n\n    } else {\n      // ── Bit i: full adder ──────────────────────────────────────────────────\n      if (carry === undefined) break;\n\n      // Partial sum wire: xi XOR yi -> t\n      const tGate = findGate('XOR', xi, yi);\n      if (!tGate) continue;\n      let t = tGate.out;\n\n      // ── Step 1: Determine t and carry correctly ────────────────────────────\n      // We need t XOR carry -> zi.\n      // Check: does the gate with inputs (t, carry) exist?\n      // If not, one of t or carry is mislabeled (swapped).\n\n      let sumGate = findGate('XOR', t, carry);\n\n      if (!sumGate) {\n        // Recovery: look at zi gate and the tGate/carry context to determine swaps.\n        // The correct sum gate XOR exists in the circuit; its output should be zi.\n        // Find it by looking at XOR gates that have carry as one input,\n        // OR XOR gates that have t as one input.\n\n        // Case A: t is wrong (t-gate output was swapped with something)\n        // The real partial-sum wire feeds into a XOR-with-carry gate.\n        // Look for any XOR gate that uses carry as one input.\n        const xorWithCarry = findByOpInput('XOR', carry).filter(\n          g => g.in1 !== xi && g.in2 !== xi && g.in1 !== yi && g.in2 !== yi\n        );\n\n        if (xorWithCarry.length === 1) {\n          const realT = xorWithCarry[0].in1 === carry ? xorWithCarry[0].in2 : xorWithCarry[0].in1;\n          if (realT !== t) {\n            swapped.add(t);\n            swapped.add(realT);\n            t = realT;\n          }\n          sumGate = xorWithCarry[0];\n        } else {\n          // Case B: carry is wrong. But we can't easily recover that here.\n          // Skip this bit.\n          continue;\n        }\n      }\n\n      // ── Step 2: Check sumGate outputs zi ──────────────────────────────────\n      if (sumGate.out !== zi) {\n        swapped.add(sumGate.out);\n        swapped.add(zi);\n        // After swap correction: sumGate still has the right structure,\n        // just wrong output name. Continue with t and carry unchanged.\n      }\n\n      // ── Step 3: Advance carry chain ────────────────────────────────────────\n      // gen = xi AND yi\n      const genGate = findGate('AND', xi, yi);\n      if (!genGate) continue;\n      const gen = genGate.out;\n\n      // prop = t AND carry\n      const propGate = findGate('AND', t, carry);\n      const prop = propGate?.out;\n\n      if (prop === undefined) {\n        // t is wrong (swapped) or carry is wrong; can't find carry chain\n        // Try finding next carry from OR gate that uses gen\n        const orFromGen = findByOpInput('OR', gen);\n        if (orFromGen.length > 0) {\n          carry = orFromGen[0].out;\n        }\n        continue;\n      }\n\n      // carry_out = gen OR prop\n      let carryGate = findGate('OR', gen, prop);\n\n      if (!carryGate) {\n        // gen or prop might be swapped\n        const orFromGen = findByOpInput('OR', gen);\n        const orFromProp = findByOpInput('OR', prop);\n\n        if (orFromGen.length === 1 && orFromProp.length === 0) {\n          const cg = orFromGen[0];\n          const realProp = cg.in1 === gen ? cg.in2 : cg.in1;\n          swapped.add(prop);\n          swapped.add(realProp);\n          carry = cg.out;\n        } else if (orFromProp.length === 1 && orFromGen.length === 0) {\n          const cg = orFromProp[0];\n          const realGen = cg.in1 === prop ? cg.in2 : cg.in1;\n          swapped.add(gen);\n          swapped.add(realGen);\n          carry = cg.out;\n        }\n        // else leave carry, can't recover\n        continue;\n      }\n\n      carry = carryGate.out;\n    }\n  }\n\n  // ── Final carry check ──────────────────────────────────────────────────────\n  // The last carry should be z<bits> (MSB of the sum).\n  // In a real circuit, the last OR gate directly outputs z<bits>.\n  // In some test circuits, carry feeds through a single dummy gate.\n  const zFinal = wireName('z', bits);\n  if (carry !== undefined && carry !== zFinal) {\n    // Allow: carry feeds directly into zFinal through a trivial gate\n    const zFinalGate = byOut.get(zFinal);\n    const carryDrivesZFinal = zFinalGate &&\n      (zFinalGate.in1 === carry || zFinalGate.in2 === carry);\n    if (!carryDrivesZFinal && byOut.has(zFinal)) {\n      swapped.add(carry);\n      swapped.add(zFinal);\n    }\n  }\n\n  return [...swapped].sort();\n}\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction wireName(prefix: string, index: number): string {\n  return `${prefix}${String(index).padStart(2, '0')}`;\n}\n\nfunction gateKey(op: string, a: string, b: string): string {\n  return `${op}:${a}:${b}`;\n}\n\nfunction countBits(gates: Gate[]): number {\n  let max = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      if (w.startsWith('x') || w.startsWith('y')) {\n        const n = parseInt(w.slice(1), 10);\n        if (!isNaN(n) && n > max) max = n;\n      }\n    }\n  }\n  return max + 1;\n}\n","structuredPatch":[{"oldStart":40,"oldLines":31,"newStart":40,"newLines":26,"lines":["  * Find all 8 wires involved in 4 swap pairs in a broken binary adder circuit.","  * Returns a sorted array of wire names.","  *","- * Strategy: structural analysis of a ripple-carry adder.","+ * Strategy: structural rule-checking for a ripple-carry adder.","  *","- * Rules for a correct N-bit adder:","+ * Rules (for a correct N-bit adder with x00..xN-1, y00..yN-1, z00..zN):","  *","- * Bit 0 (half adder):","- *   x00 XOR y00 -> z00","- *   x00 AND y00 -> carry0","+ * 1. Every z-output wire (except the final carry z_N) must come from an XOR gate.","+ * 2. z00 = x00 XOR y00 (half adder sum, direct inputs only).","+ * 3. For i>0, the XOR gate outputting z_i must have inputs:","+ *    - an XOR gate that takes xi, yi as inputs (partial sum)","+ *    - an OR gate (carry-in from previous stage)","+ * 4. Every OR gate must have two AND gates as inputs.","+ * 5. AND gates feeding OR must take either (xi,yi) or (partial_sum, carry_in).","+ * 6. The carry chain must reach z_N.","  *","- * Bit i (full adder, i > 0):","- *   xi XOR yi -> t_i           (partial sum)","- *   t_i XOR carry_{i-1} -> z_i (sum bit)","- *   xi AND yi -> gen_i","- *   t_i AND carry_{i-1} -> prop_i","- *   gen_i OR prop_i -> carry_i","+ * We trace the carry chain forward (bit by bit), and for each bit we check","+ * the structural constraints on z_i. When a violation is found, we determine","+ * which two wires are swapped by examining what the gates actually output","+ * vs. what they should output.","  *","- * Final: carry_{N-1} == z_N (or feeds directly into z_N)","- *","- * We check structural rules and flag violations:","- * - z_i must be output of XOR gate","- * - z_i's 