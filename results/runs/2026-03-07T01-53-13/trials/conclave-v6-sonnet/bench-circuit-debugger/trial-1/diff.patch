 We check structural rules and flag violations:\n * - z_i must be output of XOR gate\n * - z_i's XOR gate inputs must include t_i (xi XOR yi) and carry_{i-1}\n * - carry chain must come from OR gate\n *\n * Recovery: when we detect a violation at bit i, we record the swapped wires\n * and try to continue tracing. Specifically, when a gate has the right\n * structure but wrong output name, the output name is swapped.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const bits = countBits(gates);\n  const swapped = new Set<string>();\n\n  const byOut = new Map<string, Gate>();\n  for (const g of gates) byOut.set(g.out, g);\n\n  const byStructure = new Map<string, Gate>();\n  for (const g of gates) {\n    byStructure.set(gateKey(g.op, g.in1, g.in2), g);\n    byStructure.set(gateKey(g.op, g.in2, g.in1), g);\n  }\n  function findGate(op: Gate['op'], a: string, b: string): Gate | undefined {\n    return byStructure.get(gateKey(op, a, b));\n  }\n\n  // Index by (op, one_input) for partial lookups\n  const byOpInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const key = `${g.op}:${w}`;\n      const arr = byOpInput.get(key) ?? [];\n      arr.push(g);\n      byOpInput.set(key, arr);\n    }\n  }\n  function findByOpInput(op: Gate['op'], wire: string): Gate[] {\n    return byOpInput.get(`${op}:${wire}`) ?? [];\n  }\n\n  let carry: string | undefined;\n\n  for (let i = 0; i < bits; i++) {\n    const xi = wireName('x', i);\n    const yi = wireName('y', i);\n    const zi = wireName('z', i);\n\n    if (i === 0) {\n      // ── Bit 0: half adder ──────────────────────────────────────────────────\n      // Check XOR -> z00\n      const xorGate = findGate('XOR', xi, yi);\n      if (xorGate && xorGate.out !== zi) {\n        swapped.add(xorGate.out);\n        swapped.add(zi);\n      }\n      // z00 gate must be an XOR\n      const ziGate = byOut.get(zi);\n      if (ziGate && ziGate.op !== 'XOR') {\n        swapped.add(zi);\n      }\n\n      // AND gate output is carry-out for bit 0\n      const andGate = findGate('AND', xi, yi);\n      if (andGate) carry = andGate.out;\n\n    } else {\n      // ── Bit i: full adder ──────────────────────────────────────────────────\n      if (carry === undefined) break;\n\n      // t = xi XOR yi (partial sum)\n      const tGate = findGate('XOR', xi, yi);\n      if (!tGate) continue;\n      const t = tGate.out;\n\n      // ── Check sum gate ─────────────────────────────────────────────────────\n      // Expected: t XOR carry -> zi\n      checkSumGate(t, carry, zi);\n\n      // ── Locate gen and prop to find next carry ─────────────────────────────\n      // gen = xi AND yi\n      const genGate = findGate('AND', xi, yi);\n      if (!genGate) continue;\n      const gen = genGate.out;\n\n      // prop = t AND carry\n      const propGate = findGate('AND', t, carry);\n      const prop = propGate?.out;\n\n      // carry_out = gen OR prop\n      if (prop !== undefined) {\n        const carryGate = findGate('OR', gen, prop);\n        if (carryGate) {\n          carry = carryGate.out;\n        } else {\n          // gen or prop may be swapped; find OR gate by one known input\n          const orFromGen = findByOpInput('OR', gen);\n          const orFromProp = findByOpInput('OR', prop);\n\n          if (orFromGen.length > 0 && orFromProp.length === 0) {\n            const cg = orFromGen[0];\n            const realProp = cg.in1 === gen ? cg.in2 : cg.in1;\n            swapped.add(prop);\n            swapped.add(realProp);\n            carry = cg.out;\n          } else if (orFromProp.length > 0 && orFromGen.length === 0) {\n            const cg = orFromProp[0];\n            const realGen = cg.in1 === prop ? cg.in2 : cg.in1;\n            swapped.add(gen);\n            swapped.add(realGen);\n            carry = cg.out;\n          }\n          // else: can't recover, leave carry unchanged\n        }\n      } else {\n        // prop gate not found — t might be wrong, or carry is wrong\n        // Try finding the AND gate for carry with any partner\n        const andCarryGates = findByOpInput('AND', carry).filter(\n          g => g.in1 !== xi && g.in2 !== xi && g.in1 !== yi && g.in2 !== yi\n        );\n        if (andCarryGates.length > 0) {\n          const realProp = andCarryGates[0].out;\n          const orFromProp = findByOpInput('OR', realProp);\n          if (orFromProp.length > 0) {\n            carry = orFromProp[0].out;\n          }\n        }\n      }\n    }\n  }\n\n  // Final carry check: carry should equal z<bits>\n  const zFinal = wireName('z', bits);\n  if (carry !== undefined && carry !== zFinal) {\n    const zFinalGate = byOut.get(zFinal);\n    const carryDrivesZFinal = zFinalGate &&\n      (zFinalGate.in1 === carry || zFinalGate.in2 === carry);\n    if (!carryDrivesZFinal && byOut.has(zFinal)) {\n      swapped.add(carry);\n      swapped.add(zFinal);\n    }\n  }\n\n  return [...swapped].sort();\n\n  // ── Inner helpers ──────────────────────────────────────────────────────────\n\n  function checkSumGate(t: string, carry: string, zi: string): void {\n    const sumGate = findGate('XOR', t, carry);\n    if (sumGate) {\n      if (sumGate.out !== zi) {\n        swapped.add(sumGate.out);\n        swapped.add(zi);\n      }\n      return;\n    }\n\n    // sumGate not found: t or carry may be the wrong wire.\n    // Look at what outputs zi.\n    const ziGate = byOut.get(zi);\n    if (ziGate?.op === 'XOR') {\n      // If one input is carry, the other should be t\n      if (ziGate.in1 === carry || ziGate.in2 === carry) {\n        const trueT = ziGate.in1 === carry ? ziGate.in2 : ziGate.in1;\n        if (trueT !== t) {\n          swapped.add(t);\n          swapped.add(trueT);\n        }\n        return;\n      }\n      // If one input is t, the other should be carry\n      if (ziGate.in1 === t || ziGate.in2 === t) {\n        const trueCarry = ziGate.in1 === t ? ziGate.in2 : ziGate.in1;\n        if (trueCarry !== carry) {\n          swapped.add(carry);\n          swapped.add(trueCarry);\n        }\n        return;\n      }\n    }\n\n    // zi is not a XOR gate — zi itself is swapped\n    if (ziGate) swapped.add(zi);\n\n    // Find XOR gate that uses t; its output should be zi\n    const xorFromT = findByOpInput('XOR', t).filter(g => g.in1 === carry || g.in2 === carry);\n    if (xorFromT.length > 0) {\n      swapped.add(xorFromT[0].out);\n      swapped.add(zi);\n    }\n  }\n}\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction wireName(prefix: string, index: number): string {\n  return `${prefix}${String(index).padStart(2, '0')}`;\n}\n\nfunction gateKey(op: string, a: string, b: string): string {\n  return `${op}:${a}:${b}`;\n}\n\nfunction countBits(gates: Gate[]): number {\n  let max = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      if (w.startsWith('x') || w.startsWith('y')) {\n        const n = parseInt(w.slice(1), 10);\n        if (!isNaN(n) && n > max) max = n;\n      }\n    }\n  }\n  return max + 1;\n}\n"}}
