n;\n      }\n    }\n  }\n  return max + 1;\n}\n","structuredPatch":[{"oldStart":191,"oldLines":7,"newStart":191,"newLines":7,"lines":["       }"," ","       // carry_out = gen OR prop","-      let carryGate = findGate('OR', gen, prop);","+      const carryGate = findGate('OR', gen, prop);"," ","       if (!carryGate) {","         // gen or prop might be swapped"]}],"userModified":false,"replaceAll":false}}
