 continue tracing with corrected assumptions.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const bits = countBits(gates);\n  const swapped = new Set<string>();\n\n  // Index gates by output wire\n  const byOut = new Map<string, Gate>();\n  for (const g of gates) byOut.set(g.out, g);\n\n  // Index by canonical key: op + sorted(in1, in2)\n  const byStructure = new Map<string, Gate>();\n  for (const g of gates) {\n    byStructure.set(gateKey(g.op, g.in1, g.in2), g);\n    byStructure.set(gateKey(g.op, g.in2, g.in1), g);\n  }\n\n  function findGate(op: Gate['op'], a: string, b: string): Gate | undefined {\n    return byStructure.get(gateKey(op, a, b));\n  }\n\n  // For each gate, also index by (op, one-input) so we can find partial matches\n  // Maps: \"op:wire\" -> all gates with that op and wire as one input\n  const byOpAndOneInput = new Map<string, Gate[]>();\n  function addToOpInput(op: string, wire: string, gate: Gate) {\n    const key = `${op}:${wire}`;\n    let list = byOpAndOneInput.get(key);\n    if (!list) { list = []; byOpAndOneInput.set(key, list); }\n    list.push(gate);\n  }\n  for (const g of gates) {\n    addToOpInput(g.op, g.in1, g);\n    addToOpInput(g.op, g.in2, g);\n  }\n\n  function findGateByOpAndOneInput(op: Gate['op'], wire: string): Gate[] {\n    return byOpAndOneInput.get(`${op}:${wire}`) ?? [];\n  }\n\n  let carry: string | undefined;\n\n  for (let i = 0; i < bits; i++) {\n    const xi = wireName('x', i);\n    const yi = wireName('y', i);\n    const zi = wireName('z', i);\n\n    if (i === 0) {\n      // Bit 0: half adder\n      // xi XOR yi -> z0\n      const xorGate = findGate('XOR', xi, yi);\n      if (xorGate && xorGate.out !== zi) {\n        // xorGate's output is wrong; zi gate has wrong output too\n        swapped.add(xorGate.out);\n        swapped.add(zi);\n      } else if (!xorGate) {\n        swapped.add(zi);\n      }\n\n      // xi AND yi -> carry\n      const andGate = findGate('AND', xi, yi);\n      if (andGate) {\n        carry = andGate.out;\n      }\n    } else {\n      if (carry === undefined) break;\n\n      // xi XOR yi -> t (partial sum)\n      const tGate = findGate('XOR', xi, yi);\n      if (!tGate) continue;\n      let t = tGate.out;\n\n      // t XOR carry -> zi (full sum output)\n      const sumGate = findGate('XOR', t, carry);\n\n      if (!sumGate) {\n        // t might be swapped. Check what the gate is that outputs zi.\n        const ziGate = byOut.get(zi);\n        if (ziGate?.op === 'XOR') {\n          // ziGate is the sum gate; one of its inputs is carry, the other is t's true value\n          const trueT = ziGate.in1 === carry ? ziGate.in2 : ziGate.in1;\n          swapped.add(t);\n          swapped.add(trueT);\n          t = trueT;\n        }\n        // If we still can't find sumGate, mark zi as suspicious\n        const sumGate2 = findGate('XOR', t, carry);\n        if (sumGate2 && sumGate2.out !== zi) {\n          swapped.add(sumGate2.out);\n          swapped.add(zi);\n        }\n      } else if (sumGate.out !== zi) {\n        swapped.add(sumGate.out);\n        swapped.add(zi);\n      }\n\n      // xi AND yi -> gen (generate)\n      const genGate = findGate('AND', xi, yi);\n      if (!genGate) continue;\n      let gen = genGate.out;\n\n      // t AND carry -> prop (propagate)\n      const propGate = findGate('AND', t, carry);\n      if (!propGate) {\n        // gen might be swapped — find AND gate that has carry as one input\n        const andCarryGates = findGateByOpAndOneInput('AND', carry);\n        // Prefer one whose other input is not xi/yi (i.e., it's the propagate gate)\n        const candidate = andCarryGates.find(g => g.in1 !== xi && g.in2 !== xi && g.in1 !== yi && g.in2 !== yi);\n        if (candidate) {\n          // This is the prop gate, but it might be using the wrong t\n        }\n        continue;\n      }\n      const prop = propGate.out;\n\n      // gen OR prop -> next carry\n      const carryGate = findGate('OR', gen, prop);\n