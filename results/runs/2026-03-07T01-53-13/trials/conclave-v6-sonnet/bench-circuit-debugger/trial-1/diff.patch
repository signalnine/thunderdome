+import { describe, test, expect } from 'vitest';
+import { simulate, findSwappedWires } from './index.js';
+import type { Gate } from './index.js';
+
+// ─── simulate() tests ────────────────────────────────────────────────────────
+
+describe('simulate', () => {
+  test('AND gate: 1 AND 1 = 1', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result['c']).toBe(1);
+  });
+
+  test('AND gate: 1 AND 0 = 0', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result['c']).toBe(0);
+  });
+
+  test('OR gate: 0 OR 0 = 0', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 0, b: 0 });
+    expect(result['c']).toBe(0);
+  });
+
+  test('OR gate: 0 OR 1 = 1', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 0, b: 1 });
+    expect(result['c']).toBe(1);
+  });
+
+  test('XOR gate: 1 XOR 1 = 0', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result['c']).toBe(0);
+  });
+
+  test('XOR gate: 1 XOR 0 = 1', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result['c']).toBe(1);
+  });
+
+  test('returns all wire values including inputs', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result['a']).toBe(1);
+    expect(result['b']).toBe(0);
+    expect(result['c']).toBe(0);
+  });
+
+  test('handles dependency ordering: chained gates', () => {
+    // a AND b -> c, then c OR d -> e
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },   // listed first but depends on c
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const result = simulate(gates, { a: 1, b: 1, d: 0 });
+    expect(result['c']).toBe(1);
+    expect(result['e']).toBe(1);
+  });
+
+  test('4-bit adder: 0 + 0 = 0', () => {
+    const gates = make4BitAdder();
+    const inputs = makeAdderInputs(0, 0, 4);
+    const result = simulate(gates, inputs);
+    expect(readZ(result, 5)).toBe(0);
+  });
+
+  test('4-bit adder: 3 + 5 = 8', () => {
+    const gates = make4BitAdder();
+    const inputs = makeAdderInputs(3, 5, 4);
+    const result = simulate(gates, inputs);
+    expect(readZ(result, 5)).toBe(8);
+  });
+
+  test('4-bit adder: 15 + 15 = 30', () => {
+    const gates = make4BitAdder();
+    const inputs = makeAdderInputs(15, 15, 4);
+    const result = simulate(gates, inputs);
+    expect(readZ(result, 5)).toBe(30);
+  });
+});
+
+// ─── findSwappedWires() tests ────────────────────────────────────────────────
+
+describe('findSwappedWires', () => {
+  test('returns empty array for correct 4-bit adder', () => {
+    const gates = make4BitAdder();
+    const swapped = findSwappedWires(gates);
+    expect(swapped).toEqual([]);
+  });
+
+  test('finds one swapped pair in 4-bit adder', () => {
+    const gates = make4BitAdder();
+    // Swap z00 and c00 outputs
+    swapOutputs(gates, 'z00', 'c00');
+    const swapped = findSwappedWires(gates);
+    expect(swapped.sort()).toEqual(['c00', 'z00']);
+  });
+
+  test('finds two swapped pairs in 4-bit adder', () => {
+    const gates = make4BitAdder();
+    swapOutputs(gates, 'z00', 'c00');
+    swapOutputs(gates, 'z02', 'a02');
+    const swapped = findSwappedWires(gates);
+    expect(swapped.sort()).toEqual(['a02', 'c00', 'z00', 'z02']);
+  });
+
+  test('finds four swapped pairs in 4-bit adder', () => {
+    const gates = make4BitAdder();
+    swapOutputs(gates, 'z00', 'c00');
+    swapOutputs(gates, 'z01', 'a01');
+    swapOutputs(gates, 'z02', 'a02');
+    swapOutputs(gates, 'z03', 'a03');
+    const swapped = findSwappedWires(gates);
+    expect(swapped.sort()).toEqual(['a01', 'a02', 'a03', 'c00', 'z00', 'z01', 'z02', 'z03']);
+  });
+
+  test('returns sorted array', () => {
+    const gates = make4BitAdder();
+    swapOutputs(gates, 'z01', 'a01');
+    const swapped = findSwappedWires(gates);
+    const copy = [...swapped];
+    expect(swapped).toEqual(copy.sort());
+  });
+});
+
+// ─── Test helpers ─────────────────────────────────────────────────────────────
+
+/** Swap two gates' output wires in place (simulates a swap bug). */
+function swapOutputs(gates: Gate[], wireA: string, wireB: string): void {
+  const gA = gates.find(g => g.out === wireA);
+  const gB = gates.find(g => g.out === wireB);
+  if (!gA || !gB) throw new Error(`Wire not found: ${wireA} or ${wireB}`);
+  gA.out = wireB;
+  gB.out = wireA;
+}
+
+/** Build a correct 4-bit ripple-carry adder as Gate[]. */
+function make4BitAdder(): Gate[] {
+  // Bit 0: half adder
+  const gates: Gate[] = [
+    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+  ];
+
+  for (let i = 1; i <= 3; i++) {
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+    const cin = `c${String(i - 1).padStart(2, '0')}`;
+    const ti = `t${String(i).padStart(2, '0')}`;
+    const ai = `a${String(i).padStart(2, '0')}`;
+    const bi = `b${String(i).padStart(2, '0')}`;
+    const cout = `c${String(i).padStart(2, '0')}`;
+
+    gates.push(
+      { op: 'XOR', in1: xi, in2: yi, out: ti },
+      { op: 'XOR', in1: ti, in2: cin, out: zi },
+      { op: 'AND', in1: xi, in2: yi, out: ai },
+      { op: 'AND', in1: ti, in2: cin, out: bi },
+      { op: 'OR',  in1: ai, in2: bi, out: cout },
+    );
+  }
+
+  // Final carry is the MSB of Z
+  gates.push({ op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' });
+
+  return gates;
+}
+
+/** Create x/y input wire values for an N-bit adder. */
+function makeAdderInputs(x: number, y: number, bits: number): Record<string, number> {
+  const inputs: Record<string, number> = {};
+  for (let i = 0; i < bits; i++) {
+    inputs[`x${String(i).padStart(2, '0')}`] = (x >> i) & 1;
+    inputs[`y${String(i).padStart(2, '0')}`] = (y >> i) & 1;
+  }
+  return inputs;
+}
+
+/** Read a Z-register value from wire values. */
+function readZ(wires: Record<string, number>, bits: number): number {
+  let value = 0;
+  for (let i = 0; i < bits; i++) {
+    const wire = `z${String(i).padStart(2, '0')}`;
+    if (wires[wire]) value |= (1 << i);
+  }
+  return value;
+}
