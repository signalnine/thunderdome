rue;\n      }\n    }\n    if (!progress) break;\n  }\n\n  return wires;\n}\n\n// ─── findSwappedWires ─────────────────────────────────────────────────────────\n\n/**\n * Find all 8 wires involved in 4 swap pairs in a broken binary adder circuit.\n * Returns a sorted array of wire names.\n *\n * Strategy: structural rule-checking for a ripple-carry adder.\n *\n * Rules (for a correct N-bit adder with x00..xN-1, y00..yN-1, z00..zN):\n *\n * 1. Every z-output wire (except the final carry z_N) must come from an XOR gate.\n * 2. z00 = x00 XOR y00 (half adder sum, direct inputs only).\n * 3. For i>0, the XOR gate outputting z_i must have inputs:\n *    - an XOR gate that takes xi, yi as inputs (partial sum)\n *    - an OR gate (carry-in from previous stage)\n * 4. Every OR gate must have two AND gates as inputs.\n * 5. AND gates feeding OR must take either (xi,yi) or (partial_sum, carry_in).\n * 6. The carry chain must reach z_N.\n *\n * We trace the carry chain forward (bit by bit), and for each bit we check\n * the structural constraints on z_i. When a violation is found, we determine\n * which two wires are swapped by examining what the gates actually output\n * vs. what they should output.\n *\n * Critical insight for recovery: we track carry by STRUCTURE, not by name.\n * After detecting a swap, we correct the carry name before continuing.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const bits = countBits(gates);\n  const swapped = new Set<string>();\n\n  const byOut = new Map<string, Gate>();\n  for (const g of gates) byOut.set(g.out, g);\n\n  const byStructure = new Map<string, Gate>();\n  for (const g of gates) {\n    byStructure.set(gateKey(g.op, g.in1, g.in2), g);\n    byStructure.set(gateKey(g.op, g.in2, g.in1), g);\n  }\n  function findGate(op: Gate['op'], a: string, b: string): Gate | undefined {\n    return byStructure.get(gateKey(op, a, b));\n  }\n\n  const byOpInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const key = `${g.op}:${w}`;\n      const arr = byOpInput.get(key) ?? [];\n      arr.push(g);\n      byOpInput.set(key, arr);\n    }\n  }\n  function findByOpInput(op: Gate['op'], wire: string): Gate[] {\n    return byOpInput.get(`${op}:${wire}`) ?? [];\n  }\n\n  // We track carry by its actual wire name in the (possibly swapped) circuit.\n  // After detecting a swap in bit i, we correct carry before processing bit i+1.\n  let carry: string | undefined;\n\n  for (let i = 0; i < bits; i++) {\n    const xi = wireName('x', i);\n    const yi = wireName('y', i);\n    const zi = wireName('z', i);\n\n    if (i === 0) {\n      // ── Bit 0: half adder ──────────────────────────────────────────────────\n      // xi XOR yi -> z0  (required)\n      const xorGate = findGate('XOR', xi, yi);\n      if (xorGate && xorGate.out !== zi) {\n        swapped.add(xorGate.out);\n        swapped.add(zi);\n      }\n\n      // xi AND yi -> carry0\n      const andGate = findGate('AND', xi, yi);\n      if (andGate) carry = andGate.out;\n\n    } else {\n      // ── Bit i: full adder ──────────────────────────────────────────────────\n      if (carry === undefined) break;\n\n      // Partial sum wire: xi XOR yi -> t\n      const tGate = findGate('XOR', xi, yi);\n      if (!tGate) continue;\n      let t = tGate.out;\n\n      // ── Step 1: Determine t and carry correctly ────────────────────────────\n      // We need t XOR carry -> zi.\n      // Check: does the gate with inputs (t, carry) exist?\n      // If not, one of t or carry is mislabeled (swapped).\n\n      let sumGate = findGate('XOR', t, carry);\n\n      if (!sumGate) {\n        // Recovery: look at zi gate and the tGate/carry context to determine swaps.\n        // The correct sum gate XOR exists in the circuit; its output should be zi.\n        // Find it by looking at XOR gates that have carry as one input,\n        // OR XOR gates that have t as one input.\n\n        // Case A: t is wrong (t-gate output was swapped with something)\n        // The real partial-sum wire feeds into a XOR-with-carry gate.\n        // Look for any XOR gate that uses carry as one input.\n        const xorWithCarry = findByOpInput('XOR', carry).filter(\n          g => g.in1 !== xi && g.in2 !== xi && g.in1 !== yi && g.in2 !== yi\n        );\n\n        if (xorWithCarry.length === 1) {\n          const realT = xorWithCarry[0].in1 === carry ? xorWithCarry[0].in2 : xorWithCarry[0].in1;\n          if (realT !== t) {\n            swapped.add(t);\n            swapped.add(realT);\n            t = realT;\n          }\n          sumGate = xorWithCarry[0];\n        } else {\n          // Case B: carry is wrong. But we can't easily recover that here.\n          // Skip this bit.\n          continue;\n        }\n      }\n\n      // ── Step 2: Check sumGate outputs zi ──────────────────────────────────\n      if (sumGate.out !== zi) {\n        swapped.add(sumGate.out);\n        swapped.add(zi);\n        // After swap correction: sumGate still has the right structure,\n        // just wrong output name. Continue with t and carry unchanged.\n      }\n\n      // ── Step 3: Advance carry chain ────────────────────────────────────────\n      // gen = xi AND yi\n      const genGate = findGate('AND', xi, yi);\n      if (!genGate) continue;\n      const gen = genGate.out;\n\n      // prop = t AND carry\n      const propGate = findGate('AND', t, carry);\n      const prop = propGate?.out;\n\n      if (prop === undefined) {\n        // t is wrong (swapped) or carry is wrong; can't find carry chain\n        // Try finding next carry from OR gate that uses gen\n        const orFromGen = findByOpInput('OR', gen);\n        if (orFromGen.length > 0) {\n          carry = orFromGen[0].out;\n        }\n        continue;\n      }\n\n      // carry_out = gen OR prop\n      let carryGate = findGate('OR', gen, prop);\n\n      if (!carryGate) {\n        // gen or prop might be swapped\n        const orFromGen = findByOpIn