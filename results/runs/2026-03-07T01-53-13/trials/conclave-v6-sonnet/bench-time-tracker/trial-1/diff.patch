IT\",\n+      \"dependencies\": {\n+        \"emoji-regex\": \"^8.0.0\",\n+        \"is-fullwidth-code-point\": \"^3.0.0\",\n+        \"strip-ansi\": \"^6.0.1\"\n+      },\n+      \"engines\": {\n+        \"node\": \">=8\"\n+      }\n+    },\n+    \"node_modules/wrap-ansi/node_modules/ansi-regex\": {\n+      \"version\": \"6.2.2\",\n+      \"resolved\": \"https://registry.npmjs.org/ansi-regex/-/ansi-regex-6.2.2.tgz\",\n+      \"integrity\": \"sha512-Bq3SmSpyFHaWjPk8If9yc6svM8c56dB5BAtW4Qbw5jHTwwXXcTLoRMkpDJp6VL0XzlWaCHTXrkFURMYmD0sLqg==\",\n+      \"dev\": true,\n+      \"license\": \"MIT\",\n+      \"engines\": {\n+        \"node\": \">=12\"\n+      },\n+      \"funding\": {\n+        \"url\": \"https://github.com/chalk/ansi-regex?sponsor=1\"\n+      }\n+    },\n+    \"node_modules/wrap-ansi/node_modules/ansi-styles\": {\n+      \"version\": \"6.2.3\",\n+      \"resolved\": \"https://registry.npmjs.org/ansi-styles/-/ansi-styles-6.2.3.tgz\",\n+      \"integrity\": \"sha512-4Dj6M28JB+oAH8kFkTLUo+a2jwOFkuqb3yucU0CANcRRUbxS0cP0nZYCGjcc3BNXwRIsUVmDGgzawme7zvJHvg==\",\n+      \"dev\": true,\n+      \"license\": \"MIT\",\n+      \"engines\": {\n+        \"node\": \">=12\"\n+      },\n+      \"funding\": {\n+        \"url\": \"https://github.com/chalk/ansi-styles?sponsor=1\"\n+      }\n+    },\n+    \"node_modules/wrap-ansi/node_modules/strip-ansi\": {\n+      \"version\": \"7.2.0\",\n+      \"resolved\": \"https://registry.npmjs.org/strip-ansi/-/strip-ansi-7.2.0.tgz\",\n+      \"integrity\": \"sha512-yDPMNjp4WyfYBkHnjIRLfca1i6KMyGCtsVgoKe/z1+6vukgaENdgGBZt+ZmKPc4gavvEZ5OgHfHdrazhgNyG7w==\",\n+      \"dev\": true,\n+      \"license\": \"MIT\",\n+      \"dependencies\": {\n+        \"ansi-regex\": \"^6.2.2\"\n+      },\n+      \"engines\": {\n+        \"node\": \">=12\"\n+      },\n+      \"funding\": {\n+        \"url\": \"https://github.com/chalk/strip-ansi?sponsor=1\"\n+      }\n+    },\n     \"node_modules/wrappy\": {\n       \"version\": \"1.0.2\",\n       \"resolved\": \"https://registry.npmjs.org/wrappy/-/wrappy-1.0.2.tgz\",\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..0cc9888\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,2 @@\n+export { TimeTracker } from './tracker.js';\n+export type { TimeEntry, GetEntriesOptions } from './tracker.js';\ndiff --git a/src/tracker.test.ts b/src/tracker.test.ts\nnew file mode 100644\nindex 0000000..7e5cf62\n--- /dev/null\n+++ b/src/tracker.test.ts\n@@ -0,0 +1,230 @@\n+import { describe, test, expect, beforeEach, afterEach } from 'vitest';\n+import * as fs from 'node:fs';\n+import * as path from 'node:path';\n+import * as os from 'node:os';\n+import { TimeTracker } from './tracker.js';\n+\n+let tmpDir: string;\n+let dataFile: string;\n+\n+beforeEach(() => {\n+  tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'time-tracker-test-'));\n+  dataFile = path.join(tmpDir, 'data.json');\n+});\n+\n+afterEach(() => {\n+  fs.rmSync(tmpDir, { recursive: true, force: true });\n+});\n+\n+describe('starting timers', () => {\n+  test('starts a named timer and records a running entry', () => {\n+    const tracker = new TimeTracker(dataFile);\n+    tracker.start('coding');\n+    const entries = tracker.getEntries();\n+    expect(entries).toHaveLength(1);\n+    expect(entries[0].name).toBe('coding');\n+    expect(entries[0].startedAt).toBeInstanceOf(Date);\n+    expect(entries[0].stoppedAt).toBeNull();\n+  });\n+\n+  test('throws when starting a timer with an empty name', () => {\n+    const tracker = new TimeTracker(dataFile);\n+    expect(() => tracker.start('')).toThrow();\n+  });\n+\n+  test('throws when starting a timer with whitespace-only name', () => {\n+    const tracker = new TimeTracker(dataFile);\n+    expect(() => tracker.start('   ')).toThrow();\n+  });\n+\n+  test('auto-stops the previous timer when starting a new one', () => {\n+    const tracker = new TimeTracker(dataFile);\n+    tracker.start('coding');\n+    tracker.start('meetings');\n+    const entries = tracke