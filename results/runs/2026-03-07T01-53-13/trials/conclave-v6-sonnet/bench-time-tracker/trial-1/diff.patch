@@ -0,0 +1,106 @@
+import * as fs from 'node:fs';
+import * as path from 'node:path';
+
+export interface TimeEntry {
+  name: string;
+  startedAt: Date;
+  stoppedAt: Date | null;
+}
+
+interface SerializedEntry {
+  name: string;
+  startedAt: string;
+  stoppedAt: string | null;
+}
+
+interface StorageData {
+  entries: SerializedEntry[];
+}
+
+export interface GetEntriesOptions {
+  from?: Date;
+  to?: Date;
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  start(name: string): void {
+    if (!name.trim()) {
+      throw new Error('Task name cannot be empty.');
+    }
+
+    // Auto-stop any running timer
+    const running = this.entries.find((e) => e.stoppedAt === null);
+    if (running) {
+      running.stoppedAt = new Date();
+    }
+
+    this.entries.push({ name, startedAt: new Date(), stoppedAt: null });
+    this.save();
+  }
+
+  stop(): void {
+    const running = this.entries.find((e) => e.stoppedAt === null);
+    if (!running) {
+      throw new Error('No timer is currently running.');
+    }
+    running.stoppedAt = new Date();
+    this.save();
+  }
+
+  getEntries(options?: GetEntriesOptions): TimeEntry[] {
+    let result = this.entries;
+    if (options?.from) {
+      const from = options.from;
+      result = result.filter((e) => e.startedAt >= from);
+    }
+    if (options?.to) {
+      const to = options.to;
+      result = result.filter((e) => e.startedAt <= to);
+    }
+    return result;
+  }
+
+  getSummary(): Record<string, number> {
+    const now = Date.now();
+    const summary: Record<string, number> = {};
+    for (const entry of this.entries) {
+      const end = entry.stoppedAt ? entry.stoppedAt.getTime() : now;
+      const duration = end - entry.startedAt.getTime();
+      summary[entry.name] = (summary[entry.name] ?? 0) + duration;
+    }
+    return summary;
+  }
+
+  private load(): TimeEntry[] {
+    if (!fs.existsSync(this.filePath)) {
+      return [];
+    }
+    const raw: StorageData = JSON.parse(fs.readFileSync(this.filePath, 'utf8'));
+    return raw.entries.map((e) => ({
+      name: e.name,
+      startedAt: new Date(e.startedAt),
+      stoppedAt: e.stoppedAt ? new Date(e.stoppedAt) : null,
+    }));
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    const data: StorageData = {
+      entries: this.entries.map((e) => ({
+        name: e.name,
+        startedAt: e.startedAt.toISOString(),
+        stoppedAt: e.stoppedAt ? e.stoppedAt.toISOString() : null,
+      })),
+    };
+    fs.writeFileSync(this.filePath, JSON.stringify(data, null, 2));
+  }
+}
