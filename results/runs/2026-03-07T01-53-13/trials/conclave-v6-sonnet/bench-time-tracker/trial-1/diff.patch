+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01NNzaW4y4XZXuCHoTias2Hy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TKP4SQQU6eDD2jHBzJF4gP","name":"Write","input":{"file_path":"/workspace/src/tracker.test.ts","content":"import { describe, test, expect, beforeEach, afterEach } from 'vitest';\nimport * as fs from 'node:fs';\nimport * as path from 'node:path';\nimport * as os from 'node:os';\nimport { TimeTracker } from './tracker.js';\n\nlet tmpDir: string;\nlet dataFile: string;\n\nbeforeEach(() => {\n  tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'time-tracker-test-'));\n  dataFile = path.join(tmpDir, 'data.json');\n});\n\nafterEach(() => {\n  fs.rmSync(tmpDir, { recursive: true, force: true });\n});\n\ndescribe('starting timers', () => {\n  test('starts a named timer and records a running entry', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(1);\n    expect(entries[0].name).toBe('coding');\n    expect(entries[0].startedAt).toBeInstanceOf(Date);\n    expect(entries[0].stoppedAt).toBeNull();\n  });\n\n  test('throws when starting a timer with an empty name', () => {\n    const tracker = new TimeTracker(dataFile);\n    expect(() => tracker.start('')).toThrow();\n  });\n\n  test('throws when starting a timer with whitespace-only name', () => {\n    const tracker = new TimeTracker(dataFile);\n    expect(() => tracker.start('   ')).toThrow();\n  });\n\n  test('auto-stops the previous timer when starting a new one', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n    tracker.start('meetings');\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(2);\n    expect(entries[0].name).toBe('coding');\n    expect(entries[0].stoppedAt).toBeInstanceOf(Date);\n    expect(entries[1].name).toBe('meetings');\n    expect(entries[1].stoppedAt).toBeNull();\n  });\n\n  test('supports unicode and emoji in task names', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('コーディング 🚀');\n    const entries = tracker.getEntries();\n    expect(entries[0].name).toBe('コーディング 🚀');\n  });\n});\n\ndescribe('stopping timers', () => {\n  test('stops the running timer and records stop time', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n    tracker.stop();\n    const entries = tracker.getEntries();\n    expect(entries[0].stoppedAt).toBeInstanceOf(Date);\n  });\n\n  test('throws when stopping with no running timer', () => {\n    const tracker = new TimeTracker(dataFile);\n    expect(() => tracker.stop()).toThrow();\n  });\n\n  test('throws when stopping after already stopped', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n    tracker.stop();\n    expect(() => tracker.stop()).toThrow();\n  });\n});\n\ndescribe('persistence', () => {\n  test('saves data to the JSON file automatically', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n    expect(fs.existsSync(dataFile)).toBe(true);\n    const raw = JSON.parse(fs.readFileSync(dataFile, 'utf8'));\n    expect(raw.entries).toHaveLength(1);\n  });\n\n  test('creates parent directories if they do not exist', () => {\n    const deepFile = path.join(tmpDir, 'a', 'b', 'c', 'data.json');\n    const tracker = new TimeTracker(deepFile);\n    tracker.start('coding');\n    expect(fs.existsSync(deepFile)).toBe(true);\n  });\n\n  test('loads existing data when instantiated with an existing file', () => {\n    const tracker1 = new TimeTracker(dataFile);\n    tracker1.start('coding');\n    tracker1.stop();\n\n    const tracker2 = new TimeTracker(dataFile);\n    const entries = tracker2.getEntries();\n    expect(entries).toHaveLength(1);\n    expect(entries[0].name).toBe('coding');\n    expect(entries[0].stoppedAt).toBeInstanceOf(Date);\n  });\n\n  test('continues a running timer loaded from disk', () => {\n    const tracker1 = new TimeTracker(dataFile);\n    tracker1.start('coding');\n\n    const tracker2 = new TimeTracker(dataFile);\n    tracker2.stop(); // should work — a timer is running\n    const entries = tracker2.getEntries();\n    expect(entries[0].stoppedAt).toBeInstanceOf(Date);\n  });\n});\n\ndescribe('querying entries', () => {\n  test('returns all entries when no filter is provided', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n    tracker.stop();\n    tracker.start('meetings');\n    tracker.stop();\n    expect(tracker.getEntries()).toHaveLength(2);\n  });\n\n  test('filters entries by start date (from)', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('old task');\n    tracker.stop();\n\n    // Manually backdate the first entry\n    const entries = tracker.getEntries();\n    const yesterday = new Date(Date.now() - 86400000);\n    // Overwrite via a second tracker reading the file directly\n    const raw = JSON.parse(fs.readFileSync(dataFile, 'utf8'));\n    raw.entries[0].startedAt = yesterday.toISOString();\n    raw.entries[0].stoppedAt = new Date(yesterday.getTime() + 1000).toISOString();\n    fs.writeFileSync(dataFile, JSON.stringify(raw));\n\n    tracker.start('new task');\n    tracker.stop();\n\n    const reloaded = new TimeTracker(dataFile);\n    const filtered = reloaded.getEntries({ from: new Date(Date.now() - 3600000) });\n    expect(filtered).toHaveLength(1);\n    expect(filtered[0].name).toBe('new task');\n    void entries; // suppress unused warning\n  });\n\n  test('filters entries by end date (to)', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('task A');\n    tracker.stop();\n    tracker.start('task B');\n    tracker.stop();\n\n    // Backdate task A's entry to yesterday\n    const raw = JSON.parse(fs.readFileSync(dataFile, 'utf8'));\n    const yesterday = new Date(Date.now() - 86400000);\n    raw.entries[0].startedAt = yesterday.toISOString();\n    raw.entries[0].stoppedAt = new Date(yesterday.getTime() + 1000).toISOString();\n    fs.writeFileSync(dataFile, JSON.stringify(raw));\n\n    const reloaded = new TimeTracker(dataFile);\n    // to = 1 hour ago, should exclude recent \"task B\"\n    const filtered = reloaded.getEntries({ to: new Date(Date.now() - 3600000) });\n    expect(filtered).toHaveLength(1);\n    expect(filtered[0].name).toBe('task A');\n  });\n});\n\ndescribe('summarizing time', () => {\n  test('returns total milliseconds per task name', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n    tracker.stop();\n    tracker.start('coding');\n    tracker.stop();\n\n    // Set known durations via file manipulation\n    const raw = JSON.parse(fs.readFileSync(dataFile, 'utf8'));\n    const base = new Date('2024-01-01T10:00:00Z');\n    raw.entries[0].startedAt = base.toISOString();\n    raw.entries[0].stoppedAt = new Date(base.getTime() + 1000).toISOString(); // 1s\n    raw.entries[1].startedAt = new Date(base.getTime() + 5000).toISOString();\n    raw.entries[1].stoppedAt = new Date(base.getTime() + 7000).toISOString(); // 2s\n    fs.writeFileSync(dataFile, JSON.stringify(raw));\n\n    const reloaded = new TimeTracker(dataFile);\n    const summary = reloaded.getSummary();\n    expect(summary['coding']).toBe(3000); // 1000 + 2000\n  });\n\n  test('includes running task duration using current time', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n\n    const before = Date.now();\n    const summary = tracker.getSummary();\n    const after = Date.now();\n\n    expect(summary['coding']).toBeGreaterThanOrEqual(0);\n    expect(summary['coding']).toBeLessThanOrEqual(after - before + 100);\n  });\n\n  test('sums multiple entries with the same name', () => {\n    const tracker = new TimeTracker(dataFile);\n    tracker.start('coding');\n    tracker.stop();\n    tracker.start('meetings');\n    tracker.stop();\n    tracker.start('coding');\n    tracker.stop();\n\n    const raw = JSON.parse(fs.readFileSync(dataFile, 'utf8'));\n    const base = new Date('2024-01-01T10:00:00Z');\n    raw.entries[0].startedAt = base.toISOString();\n    raw.entries[0].stoppedAt = new Date(base.getTime() + 500).toISOString();\n    raw.entries[1].startedAt = new Date(base.getTime() + 1000).toISOString();\n    raw.entries[1].stoppedAt = new Date(base.getTime() + 2000).toISOString();\n    raw.entries[2].startedAt = new Date(base.getTime() + 3000).toISOString();\n    raw.entries[2].stoppedAt = new Date(base.getTime() + 4500).toISOString();\n    fs.writeFileSync(dataFile, JSON.stringify(raw));\n\n    const reloaded = new TimeTracker(dataFile);\n    const summary = reloaded.getSummary();\n    expect(summary['coding']).toBe(2000); // 500 + 1500\n    expect(summary['meetings']).toBe(1000);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":249,"cache_read_input_tokens":26507,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":249},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ead7459c-8fce-4bc5-9d1a-55c9c1aa67b3","uuid":"3673ae08-ef38-4a59-a660-7a1093d6375b"}
