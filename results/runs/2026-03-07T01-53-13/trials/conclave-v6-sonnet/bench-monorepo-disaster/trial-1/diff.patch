n#### packages/api/tests/auth.test.ts\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport { createApp } from '../src/index.js';\nimport { resetDefaultConnection } from '@monorepo/core';\n\ndescribe('Auth Routes', () => {\n  let app: ReturnType<typeof createApp>;\n\n  beforeEach(() => {\n    resetDefaultConnection();\n    app = createApp();\n  });\n\n  it('registers a new user', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ name: 'New User', email: 'new@test.com' });\n    expect(res.status).toBe(201);\n    expect(res.body.token).toBeDefined();\n    expect(res.body.user.role).toBe('user');\n  });\n\n  it('rejects registration with invalid data', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ name: '', email: 'bad' });\n    expect(res.status).toBe(400);\n  });\n\n  it('handles login', async () => {\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ email: 'user@test.com' });\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n  });\n\n  it('rejects login without email', async () => {\n    const res = await request(app)\n      .post('/auth/login')\n      .send({});\n    expect(res.status).toBe(400);\n  });\n\n  it('verifies valid token', async () => {\n    const res = await request(app)\n      .get('/auth/verify')\n      .set('Authorization', 'Bearer mock-token-1');\n    expect(res.status).toBe(200);\n    expect(res.body.valid).toBe(true);\n  });\n\n  it('rejects invalid token', async () => {\n    const res = await request(app)\n      .get('/auth/verify')\n      .set('Authorization', 'Bearer bad-token');\n    expect(res.status).toBe(401);\n  });\n\n  it('rejects request without token', async () => {\n    const res = await request(app).get('/auth/verify');\n    expect(res.status).toBe(401);\n  });\n});\n```\n\n#### packages/api/tests/users.test.ts (WITH ME