+// Sanitize FTS query: allow quoted phrases, otherwise only keep safe characters
+function sanitizeFtsQuery(q: string): string {
+  // If it looks like a quoted phrase, strip any inner special chars and return
+  if (/^"[^"]*"$/.test(q)) {
+    // Remove chars that could break inside a quoted phrase
+    const inner = q.slice(1, -1).replace(/['"]/g, '');
+    return `"${inner}"`;
+  }
+
+  // For non-phrase queries: keep only word characters and spaces
+  const sanitized = q.replace(/[^\w\s]/g, ' ').trim();
+  return sanitized || 'zzznomatch';
