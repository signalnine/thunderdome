+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J2sDgVc5FnazqBPaHHcFoi","type":"tool_result","content":"The file /workspace/src/routes.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"e3fef43b-c020-4c3c-9d2f-941db17d8bc8","uuid":"a44cf68a-9a4f-4f5a-b667-7370813f4ba4","tool_use_result":{"filePath":"/workspace/src/routes.ts","oldString":"  return router;\n}","newString":"  return router;\n}\n\n// Sanitize FTS query: allow quoted phrases, escape special FTS5 characters otherwise\nfunction sanitizeFtsQuery(q: string): string {\n  // If it looks like a quoted phrase, pass it through (strip only the outer quotes logic)\n  // Otherwise escape characters that would cause FTS5 parse errors\n  // Allow: alphanumeric, spaces, quotes (for phrase matching), and * for prefix\n  // We'll handle it by checking if user provided quoted phrases\n  if (/^\"[^\"]*\"$/.test(q)) {\n    // Pure quoted phrase - pass through as-is\n    return q;\n  }\n\n  // For general queries, strip characters that cause FTS5 syntax errors\n  // but keep alphanumeric, spaces, apostrophes (contractions), and allow quoted phrases\n  // Replace characters that could break FTS5 syntax with spaces\n  return q.replace(/[<>(){}[\\]|\\\\^~`!@#$%^&*+=]/g, ' ').trim() || q;\n}","originalFile":"import { Router, Request, Response, NextFunction } from 'express';\nimport Database from 'better-sqlite3';\nimport { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\nimport { NotFoundError, ValidationError } from './errors.js';\n\nexport function createRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // GET /notes/search/suggest?q=prefix - Autocomplete suggestions\n  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = req.query.q as string | undefined;\n      if (!q || q.trim() === '') {\n        throw new ValidationError('q parameter is required');\n      }\n\n      // Use FTS5 prefix search with * suffix\n      const prefix = q.trim().replace(/['\"*]/g, '') + '*';\n      const stmt = db.prepare(`\n        SELECT notes.id, notes.title\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        LIMIT 5\n      `);\n\n      const results = stmt.all(prefix) as SuggestResult[];\n      res.json({ results });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/search?q=query - Full-text search\n  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = req.query.q as string | undefined;\n      if (!q || q.trim() === '') {\n        throw new ValidationError('q parameter is required');\n      }\n\n      const page = Math.max(1, parseInt(req.query.page as string) || 1);\n      const perPage = 20;\n      const offset = (page - 1) * perPage;\n\n      // Sanitize query: allow quoted phrases, strip dangerous chars otherwise\n      const query = sanitizeFtsQuery(q.trim());\n\n      // Get total count\n      const countStmt = db.prepare(`\n        SELECT COUNT(*) as count FROM notes_fts WHERE notes_fts MATCH ?\n      `);\n      const countRow = countStmt.get(query) as { count: number };\n      const total = countRow.count;\n\n      // Get ranked results with snippets\n      const stmt = db.prepare(`\n        SELECT\n          notes.id,\n          notes.title,\n          snippet(notes_fts, 1, '<mark>', '</mark>', '...', 20) AS snippet,\n          notes_fts.rank AS rank\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY notes_fts.rank\n        LIMIT ? OFFSET ?\n      `);\n\n      const results = stmt.all(query, perPage, offset) as SearchResult[];\n      res.json({ results, total, page, perPage });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes - List all notes (with optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const tag = req.query.tag as string | undefined;\n\n      let notes: Note[];\n      if (tag) {\n        // Use a join with json_each for tag filtering\n        const tagStmt = db.prepare(`\n          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n          WHERE json_each.value = ?\n          ORDER BY created_at DESC\n        `);\n        notes = tagStmt.all(tag) as Note[];\n      } else {\n        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n        notes = stmt.all() as Note[];\n      }\n\n      res.json({ notes });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/:id - Get single note\n  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n      const note = stmt.get(id) as Note | undefined;\n\n      if (!note) {\n        throw new NotFoundError('Note not found');\n      }\n\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // POST /notes - Create note\n  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const input = req.body as NoteInput;\n\n      if (!input.title || input.title.trim() === '') {\n        throw new ValidationError('Title is required');\n      }\n      if (!input.body || input.body.trim() === '') {\n        throw new ValidationError('Body is required');\n      }\n\n      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n      const stmt = db.prepare(`\n        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n      `);\n      const result = stmt.run(input.title, input.body, tags);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n      res.status(201).json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // PUT /notes/:id - Update note\n  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      const input = req.body as Partial<NoteInput>;\n      const title = input.title ?? existing.title;\n      const body = input.body ?? existing.body;\n      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n\n      const stmt = db.prepare(`\n        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n        WHERE id = ?\n      `);\n      stmt.run(title, body, tags, id);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // DELETE /notes/:id - Delete note\n  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n      res.status(204).send();\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":188,"oldLines":3,"newStart":188,"newLines":20,"lines":[" ","   return router;"," }","+","+// Sanitize FTS query: allow quoted phrases, escape special FTS5 characters otherwise","+function sanitizeFtsQuery(q: string): string {","+  // If it looks like a quoted phrase, pass it through (strip only the outer quotes logic)","+  // Otherwise escape characters that would cause FTS5 parse errors","+  // Allow: alphanumeric, spaces, quotes (for phrase matching), and * for prefix","+  // We'll handle it by checking if user provided quoted phrases","+  if (/^\"[^\"]*\"$/.test(q)) {","+    // Pure quoted phrase - pass through as-is","+    return q;","+  }","+","+  // For general queries, strip characters that cause FTS5 syntax errors","+  // but keep alphanumeric, spaces, apostrophes (contractions), and allow quoted phrases","+  // Replace characters that could break FTS5 syntax with spaces","+  return q.replace(/[<>(){}[\\]|\\\\^~`!@#$%^&*+=]/g, ' ').trim() || q;","+}"]}],"userModified":false,"replaceAll":false}}
