ddress.city = 'LA';\n    expect(store.get('doc1')).toEqual({ name: 'Alice', address: { city: 'NYC' } });\n  });\n\n  it('deep clones on retrieval - mutations of returned value do not affect stored document', () => {\n    store.create('doc1', { name: 'Alice', address: { city: 'NYC' } });\n    const retrieved = store.get('doc1') as { name: string; address: { city: string } };\n    retrieved.address.city = 'LA';\n    expect(store.get('doc1')).toEqual({ name: 'Alice', address: { city: 'NYC' } });\n  });\n});\n\ndescribe('DocumentStore - Version History', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  it('records a version on create', () => {\n    store.create('doc1', { name: 'Alice' });\n    const history = store.getHistory('doc1');\n    expect(history).toHaveLength(1);\n    expect(history[0].content).toEqual({ name: 'Alice' });\n  });\n\n  it('records a version on each update', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.update('doc1', { name: 'Bob' });\n    store.update('doc1', { name: 'Charlie' });\n    const history = store.getHistory('doc1');\n    expect(history).toHaveLength(3);\n    expect(history[0].content).toEqual({ name: 'Alice' });\n    expect(history[1].content).toEqual({ name: 'Bob' });\n    expect(history[2].content).toEqual({ name: 'Charlie' });\n  });\n\n  it('versions have unique ids', () => {\n    store.create('doc1', { name: 'Alice' });\n    store.update('doc1', { name: 'Bob' });\n    const history = store.getHistory('doc1');\n    expect(history[0].id).not.toEqual(history[1].id);\n  });\n\n  it('versions have timestamps', () => {\n    const before = Date.now();\n    store.create('doc1', { name: 'Alice' });\n    const after = Date.now();\n    const history = store.getHistory('doc1');\n    expect(history[0].timestamp).toBeGreaterThanOrEqual(before);\n    expect(history[0].timestamp).toBeLessThanOrEqual(after);\n  });\n\n  it('retrieves a specific version by id', () => {\n 