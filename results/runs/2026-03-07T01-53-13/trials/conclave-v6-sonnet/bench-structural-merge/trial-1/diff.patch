@@ -0,0 +1,33 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface DocumentEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+export interface BranchState {
+  // documentId -> DocumentEntry (or null if deleted)
+  documents: Map<string, DocumentEntry>;
+  // point in the parent branch's document versions where this branch was created
+  // key: documentId, value: version id at branch point (undefined if doc didn't exist)
+  divergePoint: Map<string, string | null>;
+}
diff --git a/src/utils.ts b/src/utils.ts
new file mode 100644
index 0000000..6edb5bf
--- /dev/null
+++ b/src/utils.ts
@@ -0,0 +1,54 @@
+let counter = 0;
+
+export function generateId(): string {
+  return `v-${Date.now()}-${++counter}`;
+}
+
+export function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+/**
+ * Returns a flat map of all leaf paths in a nested object.
+ * e.g. { a: { b: 1 }, c: 2 } -> { 'a.b': 1, 'c': 2 }
+ */
+export function flattenPaths(
+  obj: Record<string, unknown>,
+  prefix = ''
+): Record<string, unknown> {
+  const result: Record<string, unknown> = {};
+  for (const [key, value] of Object.entries(obj)) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    if (
+      value !== null &&
+      typeof value === 'object' &&
+      !Array.isArray(value)
+    ) {
+      const nested = flattenPaths(value as Record<string, unknown>, path);
+      Object.assign(result, nested);
+    } else {
+      result[path] = value;
+    }
+  }
+  return result;
+}
+
+/**
+ * Sets a value at a dot-separated path in an object.
+ */
+export function setPath(
+  obj: Record<string, unknown>,
+  path: string,
+  value: unknown
+): void {
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null) {
+      current[part] = {};
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  current[parts[parts.length - 1]] = value;
+}
