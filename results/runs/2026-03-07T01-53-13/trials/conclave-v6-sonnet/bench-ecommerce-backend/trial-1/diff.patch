rtId: 'c1', total: 50 };\n    await bus.emit(Events.ORDER_CREATED, o1);\n\n    // Cart c2 has 2 of prod2\n    const c2: CartUpdatedEvent = { cartId: 'c2', userId: 'u2', items: [{ productId: 'prod2', quantity: 2 }] };\n    await bus.emit(Events.CART_UPDATED, c2);\n    const o2: OrderCreatedEvent = { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 30 };\n    await bus.emit(Events.ORDER_CREATED, o2);\n\n    // prod1: 3, prod2: 1+2=3 — tied; prod2 wins in sort by insertion if equal,\n    // just verify we have 2 results and both products are present\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top.map((p) => p.productId)).toContain('prod1');\n    expect(top.map((p) => p.productId)).toContain('prod2');\n    expect(top.find((p) => p.productId === 'prod1')?.count).toBe(3);\n    expect(top.find((p) => p.productId === 'prod2')?.count).toBe(3);\n  });","originalFile":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../bus.js';\nimport { createAnalyticsService } from './index.js';\nimport { Events, PaymentStatus, OrderStatus } from '../types.js';\nimport type { PaymentProcessedEvent, OrderCreatedEvent, OrderStatusChangedEvent, CartUpdatedEvent } from '../types.js';\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('counts events by type', async () => {\n    const event: OrderCreatedEvent = { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 };\n    await bus.emit(Events.ORDER_CREATED, event);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 50 });\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(2);\n  });\n\n  it('returns 0 for event type with no occurrences', () => {\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(0);\n  });\n\n  it('tracks revenue from successful payments', async () => {\n    const p1: PaymentProcessedEvent = { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'txn1' };\n    const p2: PaymentProcessedEvent = { orderId: 'o2', status: PaymentStatus.SUCCESS, transactionId: 'txn2' };\n    // Revenue comes from order totals — emit orders first\n    const o1: OrderCreatedEvent = { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 };\n    const o2: OrderCreatedEvent = { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 50 };\n    await bus.emit(Events.ORDER_CREATED, o1);\n    await bus.emit(Events.ORDER_CREATED, o2);\n    await bus.emit(Events.PAYMENT_PROCESSED, p1);\n    await bus.emit(Events.PAYMENT_PROCESSED, p2);\n    expect(analytics.getRevenue()).toBe(150);\n  });\n\n  it('does not count failed payments in revenue', async () => {\n    const o1: OrderCreatedEvent = { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 };\n    await bus.emit(Events.ORDER_CREATED, o1);\n    const p1: PaymentProcessedEvent = { orderId: 'o1', status: PaymentStatus.FAILED, error: 'declined' };\n    await bus.emit(Events.PAYMENT_PROCESSED, p1);\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('calculates conversion rate as orders divided by unique carts', async () => {\n    // 2 unique carts\n    const c1: CartUpdatedEvent = { cartId: 'c1', userId: 'u1', items: [] };\n    const c2: CartUpdatedEvent = { cartId: 'c2', userId: 'u2', items: [] };\n    await bus.emit(Events.CART_UPDATED, c1);\n    await bus.emit(Events.CART_UPDATED, c2);\n    // 1 order\n    const o1: OrderCreatedEvent = { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 };\n    await bus.emit(Events.ORDER_CREATED, o1);\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('returns 0 conversion rate when no carts exist', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('ranks top products by order quantity', async () => {\n    // order with 3 of prod1, 1 of prod2\n    const o1: OrderCreatedEvent = { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 };\n    await bus.emit(Events.ORDER_CREATED, o1);\n    // We need cart data to track product quantities\n    const c1: CartUpdatedEvent = { cartId: 'c1', userId: 'u1', items: [{ productId: 'prod1', quantity: 3 }, { productId: 'prod2', quantity: 1 }] };\n    await bus.emit(Events.CART_UPDATED, c1);\n    // Simulate another order with 2 of prod2\n    const c2: CartUpdatedEvent = { cartId: 'c2', userId: 'u2', items: [{ productId: 'prod2', quantity: 2 }] };\n    await bus.emit(Events.CART_UPDATED, c2);\n    const o2: OrderCreatedEvent = { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 30 };\n    await bus.emit(Events.ORDER_CREATED, o2);\n\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe('prod2'); // 3 total (1+2)\n    expect(top[0].count).toBe(3);\n    expect(top[1].productId).toBe('prod1'); // 3 total but ordered second — wait, same count\n    // Actually prod1: 3, prod2: 3 — let's just check we get 2 results\n    expect(top).toHaveLength(2);\n  });\n});\n","structuredPatch":[{"oldStart":62,"oldLines":23,"newStart":62,"newLines":25,"lines":["   });"," ","   it('ranks top products by order quantity', async () => {","-    // order with 3 of prod1, 1 of prod2","-    const o1: OrderCreatedEvent = { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 };","-    await bus.emit(Events.ORDER_CREATED, o1);","-    // We need cart data to track product quantities","+    // Cart c1 has 3 of prod1 and 1 of prod2","     const c1: CartUpdatedEvent = { cartId: 'c1', userId: 'u1', items: [{ productId: 'prod1', quantity: 3 }, { productId: 'prod2', quantity: 1 }] };","     await bus.emit(Events.CART_UPDATED, c1);","-    // Simulate another order with 2 of prod2","+    const o1: OrderCreatedEvent = { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 };","+    await bus.emit(Events.ORDER_CREATED, o1);","+","+    // Cart c2 has 2 of prod2","     const c2: CartUpdat