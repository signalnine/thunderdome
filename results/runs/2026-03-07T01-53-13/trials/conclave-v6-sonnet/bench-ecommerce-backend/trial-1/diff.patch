    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('emits ORDER_STATUS_CHANGED with previous status on update', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.ORDER_STATUS_CHANGED, (p) => events.push(p));\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise((r) => setTimeout(r, 0));\n    expect(events).toHaveLength(1);\n    expect(events[0]).toMatchObject({\n      orderId: id,\n      status: OrderStatus.CONFIRMED,\n      previousStatus: OrderStatus.PENDING,\n    });\n  });\n\n  it('lists orders for a user', () => {\n    const id1 = orders.createOrder('user1', 'cart1', 10);\n    orders.createOrder('user2', 'cart2', 20);\n    const id3 = orders.createOrder('user1', 'cart3', 30);\n    const list = orders.listOrders('user1');\n    expect(list).toHaveLength(2);\n    expect(list.map((o) => o.id)).toContain(id1);\n    expect(list.map((o) => o.id)).toContain(id3);\n  });\n\n  it('cancels order by setting status to CANCELLED', async () => {\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":756,"cache_read_input_tokens":33641,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":756},"output_tokens":22,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f9f8b5f3-7a1f-463c-901f-daf893462ca8","uuid":"20a6a5df-853a-44f9-ac21-cf53be577db0"}
