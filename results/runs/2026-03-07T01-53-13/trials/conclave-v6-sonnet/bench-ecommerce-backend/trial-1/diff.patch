+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { createNotificationService } from './index.js';
+import { Events, OrderStatus, PaymentStatus } from '../types.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent, PaymentProcessedEvent } from '../types.js';
+
+describe('NotificationService', () => {
+  let bus: EventBus;
+  let notifications: ReturnType<typeof createNotificationService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    notifications = createNotificationService(bus);
+  });
+
+  it('returns empty notifications for subscribed user with no events', () => {
+    notifications.subscribe('user1');
+    expect(notifications.getNotifications('user1')).toEqual([]);
+  });
+
+  it('notifies subscribed user on order status change', async () => {
+    notifications.subscribe('user1');
+    // First emit ORDER_CREATED so service knows which user owns the order
+    const created: OrderCreatedEvent = { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 };
+    await bus.emit(Events.ORDER_CREATED, created);
+
+    const changed: OrderStatusChangedEvent = {
+      orderId: 'o1',
+      status: OrderStatus.CONFIRMED,
+      previousStatus: OrderStatus.PENDING,
+    };
+    await bus.emit(Events.ORDER_STATUS_CHANGED, changed);
+
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs).toHaveLength(1);
+    expect(notifs[0].type).toBe('order_status');
+  });
+
+  it('does not notify unsubscribed user', async () => {
+    // Subscribe user2 but not user1
+    notifications.subscribe('user2');
+
+    const created: OrderCreatedEvent = { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 };
+    await bus.emit(Events.ORDER_CREATED, created);
+
+    const changed: OrderStatusChangedEvent = {
+      orderId: 'o1',
+      status: OrderStatus.CONFIRMED,
+      previousStatus: OrderStatus.PENDING,
+    };
+    await bus.emit(Events.ORDER_STATUS_CHANGED, changed);
+
+    expect(notifications.getNotifications('user1')).toEqual([]);
+  });
+
+  it('notifies user on payment processed event', async () => {
+    notifications.subscribe('user1');
+
+    const created: OrderCreatedEvent = { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 };
+    await bus.emit(Events.ORDER_CREATED, created);
+
+    const payment: PaymentProcessedEvent = {
+      orderId: 'o1',
+      status: PaymentStatus.SUCCESS,
+      transactionId: 'txn1',
+    };
+    await bus.emit(Events.PAYMENT_PROCESSED, payment);
+
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs).toHaveLength(1);
+    expect(notifs[0].type).toBe('payment');
+  });
+
+  it('notification includes a timestamp', async () => {
+    notifications.subscribe('user1');
+
+    const created: OrderCreatedEvent = { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 };
+    await bus.emit(Events.ORDER_CREATED, created);
+
+    const changed: OrderStatusChangedEvent = {
+      orderId: 'o1',
+      status: OrderStatus.SHIPPED,
+      previousStatus: OrderStatus.CONFIRMED,
+    };
+    await bus.emit(Events.ORDER_STATUS_CHANGED, changed);
+
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs[0].timestamp).toBeGreaterThan(0);
+  });
+});
