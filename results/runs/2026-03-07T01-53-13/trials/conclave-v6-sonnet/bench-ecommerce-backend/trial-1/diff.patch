+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { createInventoryService } from './index.js';
+import { Events } from '../types.js';
+
+describe('InventoryService', () => {
+  let bus: EventBus;
+  let inventory: ReturnType<typeof createInventoryService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    inventory = createInventoryService(bus);
+  });
+
+  it('returns 0 stock for unknown product', () => {
+    expect(inventory.getStock('p1')).toBe(0);
+  });
+
+  it('sets and retrieves stock', () => {
+    inventory.setStock('p1', 100);
+    expect(inventory.getStock('p1')).toBe(100);
+  });
+
+  it('reserves stock and reduces available quantity', () => {
+    inventory.setStock('p1', 10);
+    const result = inventory.reserve('p1', 3);
+    expect(result).toBe(true);
+    expect(inventory.getStock('p1')).toBe(7);
+  });
+
+  it('returns false when insufficient stock for reservation', () => {
+    inventory.setStock('p1', 2);
+    const result = inventory.reserve('p1', 5);
+    expect(result).toBe(false);
+    expect(inventory.getStock('p1')).toBe(2);
+  });
+
+  it('releases reserved stock back', () => {
+    inventory.setStock('p1', 10);
+    inventory.reserve('p1', 3);
+    inventory.release('p1', 3);
+    expect(inventory.getStock('p1')).toBe(10);
+  });
+
+  it('emits LOW_STOCK_ALERT when stock falls below threshold', async () => {
+    const alerts: unknown[] = [];
+    bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });
+    inventory.setLowStockThreshold('p1', 5);
