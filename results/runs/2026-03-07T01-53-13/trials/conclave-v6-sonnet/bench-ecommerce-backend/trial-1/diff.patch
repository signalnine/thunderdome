@@ -0,0 +1,40 @@
+import { v4 as uuidv4 } from 'uuid';
+import type { EventBus } from '../bus.js';
+import { Events, PaymentStatus } from '../types.js';
+import type { PaymentService, PaymentProcessedEvent } from '../types.js';
+
+interface PaymentOptions {
+  result?: 'success' | 'failure' | 'timeout';
+}
+
+export function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {
+  const transactions = new Set<string>();
+
+  return {
+    async processPayment(orderId, _amount) {
+      const mode = options.result ?? 'success';
+
+      let result: { status: PaymentStatus; transactionId?: string; error?: string };
+
+      if (mode === 'failure') {
+        result = { status: PaymentStatus.FAILED, error: 'Payment declined' };
+      } else if (mode === 'timeout') {
+        result = { status: PaymentStatus.TIMEOUT };
+      } else {
+        const transactionId = uuidv4();
+        transactions.add(transactionId);
+        result = { status: PaymentStatus.SUCCESS, transactionId };
+      }
+
+      const event: PaymentProcessedEvent = { orderId, ...result };
+      await bus.emit(Events.PAYMENT_PROCESSED, event);
+      return result;
+    },
+
+    async refund(transactionId) {
+      if (!transactions.has(transactionId)) return false;
+      transactions.delete(transactionId);
+      return true;
+    },
+  };
+}
