+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { createCartService } from './index.js';
+
+describe('CartService', () => {
+  let bus: EventBus;
+  let cart: ReturnType<typeof createCartService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    cart = createCartService(bus);
+  });
+
+  it('creates a cart for a user and returns unique cart id', () => {
+    const id1 = cart.createCart('user1');
+    const id2 = cart.createCart('user2');
+    expect(id1).toBeTruthy();
+    expect(id2).not.toBe(id1);
+  });
+
+  it('retrieves a cart by id', () => {
+    const id = cart.createCart('user1');
+    const c = cart.getCart(id);
+    expect(c).toMatchObject({ id, userId: 'user1', items: [] });
+  });
+
+  it('returns null for unknown cart', () => {
+    expect(cart.getCart('ghost')).toBeNull();
+  });
+
+  it('adds item to cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'prod1', 2);
+    const c = cart.getCart(id);
+    expect(c?.items).toEqual([{ productId: 'prod1', quantity: 2 }]);
+  });
+
+  it('consolidates same product added multiple times', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'prod1', 2);
+    cart.addItem(id, 'prod1', 3);
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(1);
+    expect(c?.items[0]).toEqual({ productId: 'prod1', quantity: 5 });
+  });
+
+  it('removes item from cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'prod1', 2);
+    cart.addItem(id, 'prod2', 1);
+    cart.removeItem(id, 'prod1');
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(1);
+    expect(c?.items[0].productId).toBe('prod2');
+  });
+
+  it('updates quantity of item in cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'prod1', 2);
+    cart.updateQuantity(id, 'prod1', 10);
+    const c = cart.getCart(id);
+    expect(c?.items[0].quantity).toBe(10);
+  });
+
+  it('clears all items from cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'prod1', 2);
+    cart.addItem(id, 'prod2', 1);
+    cart.clearCart(id);
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(0);
+  });
+});
