@@ -0,0 +1,62 @@
+import type { EventBus } from '../bus.js';
+import { Events } from '../types.js';
+import type { NotificationService, OrderCreatedEvent, OrderStatusChangedEvent, PaymentProcessedEvent } from '../types.js';
+
+interface Notification {
+  type: string;
+  message: string;
+  timestamp: number;
+}
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const subscribed = new Set<string>();
+  const notifications = new Map<string, Notification[]>();
+  // track which user owns which order
+  const orderOwners = new Map<string, string>();
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const event = payload as OrderCreatedEvent;
+    orderOwners.set(event.orderId, event.userId);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {
+    const event = payload as OrderStatusChangedEvent;
+    const userId = orderOwners.get(event.orderId);
+    if (!userId || !subscribed.has(userId)) return;
+    const notif: Notification = {
+      type: 'order_status',
+      message: `Order ${event.orderId} status changed to ${event.status}`,
+      timestamp: Date.now(),
+    };
+    const list = notifications.get(userId) ?? [];
+    list.push(notif);
+    notifications.set(userId, list);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const event = payload as PaymentProcessedEvent;
+    const userId = orderOwners.get(event.orderId);
+    if (!userId || !subscribed.has(userId)) return;
+    const notif: Notification = {
+      type: 'payment',
+      message: `Payment for order ${event.orderId} ${event.status}`,
+      timestamp: Date.now(),
+    };
+    const list = notifications.get(userId) ?? [];
+    list.push(notif);
+    notifications.set(userId, list);
+  });
+
+  return {
+    subscribe(userId) {
+      subscribed.add(userId);
+      if (!notifications.has(userId)) {
+        notifications.set(userId, []);
+      }
+    },
+
+    getNotifications(userId) {
+      return notifications.get(userId) ?? [];
+    },
+  };
+}
