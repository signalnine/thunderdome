@@ -0,0 +1,81 @@
+import type { EventBus } from '../bus.js';
+import { Events, PaymentStatus } from '../types.js';
+import type { AnalyticsService, OrderCreatedEvent, PaymentProcessedEvent, CartUpdatedEvent } from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const uniqueCarts = new Set<string>();
+  let orderCount = 0;
+  // track cart items at the time of cart update, keyed by cartId
+  const cartSnapshots = new Map<string, Array<{ productId: string; quantity: number }>>();
+  // accumulate product order quantities
+  const productQuantities = new Map<string, number>();
+  // track order totals by orderId for revenue lookups
+  const orderTotals = new Map<string, number>();
+
+  function increment(eventType: string) {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  bus.on(Events.CART_UPDATED, (payload) => {
+    const event = payload as CartUpdatedEvent;
+    increment(Events.CART_UPDATED);
+    uniqueCarts.add(event.cartId);
+    cartSnapshots.set(event.cartId, event.items);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const event = payload as OrderCreatedEvent;
+    increment(Events.ORDER_CREATED);
+    orderCount++;
+    orderTotals.set(event.orderId, event.total);
+    // accumulate product quantities from the cart snapshot
+    const items = cartSnapshots.get(event.cartId) ?? [];
+    for (const item of items) {
+      productQuantities.set(
+        item.productId,
+        (productQuantities.get(item.productId) ?? 0) + item.quantity
+      );
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const event = payload as PaymentProcessedEvent;
+    increment(Events.PAYMENT_PROCESSED);
+    if (event.status === PaymentStatus.SUCCESS) {
+      const total = orderTotals.get(event.orderId) ?? 0;
+      revenue += total;
+    }
+  });
+
+  bus.on(Events.PRODUCT_CREATED, () => increment(Events.PRODUCT_CREATED));
+  bus.on(Events.ORDER_STATUS_CHANGED, () => increment(Events.ORDER_STATUS_CHANGED));
+  bus.on(Events.LOW_STOCK_ALERT, () => increment(Events.LOW_STOCK_ALERT));
+  bus.on(Events.PRICE_CALCULATED, () => increment(Events.PRICE_CALCULATED));
+  bus.on(Events.NOTIFICATION_SENT, () => increment(Events.NOTIFICATION_SENT));
+  bus.on(Events.ANALYTICS_EVENT, () => increment(Events.ANALYTICS_EVENT));
+  bus.on(Events.INVENTORY_UPDATED, () => increment(Events.INVENTORY_UPDATED));
+
+  return {
+    getEventCount(eventType) {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue() {
+      return revenue;
+    },
+
+    getConversionRate() {
+      if (uniqueCarts.size === 0) return 0;
+      return orderCount / uniqueCarts.size;
+    },
+
+    getTopProducts(limit) {
+      return Array.from(productQuantities.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
