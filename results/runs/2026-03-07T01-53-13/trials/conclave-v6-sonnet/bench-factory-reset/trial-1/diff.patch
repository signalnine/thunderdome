here partial sum already exceeds S.","-","-  // Also: the minimum possible sum is 0 (all zeros), maximum is nButtons*(p-1).","-  // We enumerate in order of increasing total sum.","-","-  // Practical approach for large F: exhaustive with early termination and pruning.","-  // For F up to 40 and p up to 97, we split into chunks and use a recursive","-  // search with pruning.","-","   let best: number[] | null = null;","   let bestSum = Infinity;"," ","-  const enumerateRight = (j: number, current: number[], partialSum: number) => {","+  const enumerate = (j: number, x: number[]) => {","+    const curSum = x.reduce((s, v) => s + v, 0);","+    if (curSum > bestSum) return; // prune (sum can only grow or stay — not guaranteed for mod)","+","     if (j === F) {","-      if (partialSum < bestSum ||","-          (partialSum === bestSum && betterCounterSolution(current, best!) === current)) {","-        best = [...current];","-        bestSum = partialSum;","+      if (curSum < bestSum || (curSum === bestSum && compareCounter(x, best!) < 0)) {","+        best = [...x];","+        bestSum = curSum;","       }","       return;","     }","-    // Try each value for free var j","+","+    // Try c_j = 0, 1, ..., p-1","     for (let c = 0; c < p; c++) {","-      const next = current.map((v, i) => ((v + c * nullSpace[j][i]) % p + p) % p);","+      const next = x.map((v, i) => ((v + c * nullSpace[j][i]) % p + p) % p);","       const nextSum = next.reduce((s, v) => s + v, 0);","-      // Pruning: if partial sum (of full x) already exceeds best, skip","-      // (can't be improved since all values ≥ 0)","-      if (nextSum > bestSum) continue;","-      // Check if remaining free vars could reduce sum (they add non-negative values)","-      // Minimum additional sum = 0 (choose c=0 for all remaining)","-      // So prune only if nextSum >= bestSum (with equality, still might be lex better)","-      enumerateRight(j + 1, next, nextSum);","+      if (nextSum <= bestSum) {","+        e