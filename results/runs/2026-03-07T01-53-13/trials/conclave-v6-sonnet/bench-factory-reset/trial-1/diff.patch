────────\n// solveToggle: GF(2) case, minimize popcount, then lex smallest\n// ─────────────────────────────────────────────────────────────\n\n/**\n * Compare two solutions: first by length (fewer is better),\n * then lexicographically.\n */\nfunction betterToggleSolution(a: number[], b: number[]): number[] {\n  if (a.length !== b.length) return a.length < b.length ? a : b;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i] ? a : b;\n  }\n  return a;\n}\n\n/**\n * Convert a binary x vector to sorted indices of pressed buttons.\n */\nfunction xToIndices(x: number[]): number[] {\n  const result: number[] = [];\n  for (let i = 0; i < x.length; i++) {\n    if (x[i]) result.push(i);\n  }\n  return result;\n}\n\n/**\n * Add two vectors mod p.\n */\nfunction addVecMod(a: number[], b: number[], p: number): number[] {\n  return a.map((v, i) => ((v + b[i]) % p + p) % p);\n}\n\n/**\n * Scale vector by scalar mod p.\n */\nfunction scaleVec(v: number[], s: number, p: number): number[] {\n  return v.map(x => ((x * s) % p + p) % p);\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const nLights = machine.target.length;\n  const nButtons = machine.buttons.length;\n\n  // Build matrix A[light][button] over GF(2)\n  const A: number[][] = Array.from({ length: nLights }, () => new Array(nButtons).fill(0));\n  for (let b = 0; b < nButtons; b++) {\n    for (const l of machine.buttons[b]) {\n      if (l >= 0 && l < nLights) {\n        A[l][b] = 1;\n      }\n    }\n  }\n  const bVec = machine.target.map(t => t ? 1 : 0);\n\n  const { particular, nullSpace, solvable } = gaussianElimination(A, bVec, 2, nLights, nButtons);\n\n  if (!solvable) return null;\n\n  // If no null space, unique solution\n  if (nullSpace.length === 0) {\n    return xToIndices(particular);\n  }\n\n  const F = nullSpace.length;\n\n  // Enumerate all 2^F combinations of free variables\n  // For F ≤ 24: brute force; for F > 24: meet in middle\n  if (F <= 24) {\n   