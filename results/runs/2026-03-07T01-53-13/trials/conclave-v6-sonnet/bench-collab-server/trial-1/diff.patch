ete(ws);\n  }\n\n  handleOperation(ws: WebSocket, msg: ClientMessage): void {\n    // Validate operation structure\n    if (!msg.op || typeof msg.op.type !== 'string') {\n      this.send(ws, { type: 'error', message: 'Invalid operation' });\n      return;\n    }\n\n    if (msg.op.type === 'insert') {\n      if (typeof msg.op.pos !== 'number' || typeof msg.op.text !== 'string') {\n        this.send(ws, { type: 'error', message: 'Invalid insert operation: pos and text required' });\n        return;\n      }\n    } else if (msg.op.type === 'delete') {\n      if (typeof msg.op.pos !== 'number' || typeof msg.op.length !== 'number') {\n        this.send(ws, { type: 'error', message: 'Invalid delete operation: pos and length required' });\n        return;\n      }\n    } else {\n      this.send(ws, { type: 'error', message: `Unknown operation type: ${msg.op.type}` });\n      return;\n    }\n\n    // Transform op against all server ops since client's version\n    let op = msg.op;\n    const clientVersion = typeof msg.clientVersion === 'number' ? msg.clientVersion : this.serverVersion;\n    const opsToTransformAgainst = this.opLog.filter(\n      (p) => p.serverVersion > clientVersion,\n    );\n    for (const pending of opsToTransformAgainst) {\n      op = transformOp(op, pending.op);\n    }\n\n    // Apply to DB\n    const updated = this.repo.applyOperation(this.docId, op, this.serverVersion);\n    if (!updated) {\n      this.send(ws, { type: 'error', message: 'Failed to apply operation' });\n      return;\n    }\n\n    this.serverVersion = updated.version;\n    this.opLog.push({ op, serverVersion: this.serverVersion });\n\n    // Ack to sender\n    this.send(ws, { type: 'ack', version: this.serverVersion });\n\n    // Broadcast to others\n    const broadcast: ServerMessage = { type: 'operation', op, version: this.serverVersion };\n    for (const client of this.clients) {\n      if (client !== ws && client.readyState === WS_OPEN) {\n        this.send(client, broadcast);\n      }\n    }\n  }\n\n  private send(ws: WebSocket, msg: ServerMessage): void {\n    if (ws.readyState === WS_OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n}\n\nexport class RoomManager {\n  private rooms = new Map<string, DocumentRoom>();\n\n  constructor(private repo: DocumentRepository) {}\n\n  getOrCreate(docId: string): DocumentRoom {\n    let room = this.rooms.get(docId);\n    if (!room) {\n      room = new DocumentRoom(docId, this.repo);\n      this.rooms.set(docId, room);\n    }\n    return room;\n  }\n\n  remove(docId: string): void {\n    this.rooms.delete(docId);\n  }\n}\n","structuredPatch":[{"oldStart":75,"oldLines":7,"newStart":75,"newLines":8,"lines":["         return;","       }","     } else {","-      this.send(ws, { type: 'error', message: `Unknown operation type: ${msg.op.type}` });","+      const unknownOp = msg.op as { type: string };","+      this.send(ws, { type: 'error', message: `Unknown operation type: ${unknownOp.type}` });","       return;","     }"," "]}],"userModified":false,"replaceAll":false}}
