+import { describe, it, expect, beforeEach } from 'vitest';
+import { openDb } from '../db.js';
+import { DocumentRepository } from '../documents.js';
+
+describe('DocumentRepository', () => {
+  let repo: DocumentRepository;
+
+  beforeEach(() => {
+    const db = openDb(':memory:');
+    repo = new DocumentRepository(db);
+  });
+
+  it('creates a document and retrieves it by id', () => {
+    const doc = repo.create({ title: 'Test Doc', content: 'Hello' });
+    expect(doc.id).toBeTruthy();
+    expect(doc.title).toBe('Test Doc');
+    expect(doc.content).toBe('Hello');
+
+    const found = repo.findById(doc.id);
+    expect(found).toBeDefined();
+    expect(found!.title).toBe('Test Doc');
+  });
+
+  it('lists all documents', () => {
+    repo.create({ title: 'A', content: '' });
+    repo.create({ title: 'B', content: '' });
+    const all = repo.list();
+    expect(all.length).toBe(2);
+  });
+
+  it('updates document title and content', () => {
+    const doc = repo.create({ title: 'Old', content: 'old content' });
+    const updated = repo.update(doc.id, { title: 'New', content: 'new content' });
+    expect(updated).toBeDefined();
+    expect(updated!.title).toBe('New');
+    expect(updated!.content).toBe('new content');
+  });
+
+  it('returns null for non-existent document', () => {
+    expect(repo.findById('no-such-id')).toBeNull();
+  });
+
+  it('deletes a document', () => {
+    const doc = repo.create({ title: 'Bye', content: '' });
+    const deleted = repo.delete(doc.id);
+    expect(deleted).toBe(true);
+    expect(repo.findById(doc.id)).toBeNull();
+  });
+
+  it('delete returns false for non-existent document', () => {
+    expect(repo.delete('nonexistent')).toBe(false);
+  });
+
+  it('saves version history on update', () => {
+    const doc = repo.create({ title: 'Doc', content: 'v1' });
+    repo.update(doc.id, { content: 'v2' });
+    repo.update(doc.id, { content: 'v3' });
+    const history = repo.getHistory(doc.id);
+    expect(history.length).toBeGreaterThanOrEqual(2);
+  });
+
+  it('applies an operation and records version', () => {
+    const doc = repo.create({ title: 'Doc', content: 'hello' });
+    const op = { type: 'insert' as const, pos: 5, text: ' world' };
+    const updated = repo.applyOperation(doc.id, op, 0);
+    expect(updated).toBeDefined();
+    expect(updated!.content).toBe('hello world');
+    const history = repo.getHistory(doc.id);
+    expect(history.length).toBeGreaterThanOrEqual(1);
+  });
+
+  it('applies a delete operation', () => {
+    const doc = repo.create({ title: 'Doc', content: 'hello world' });
+    const op = { type: 'delete' as const, pos: 5, length: 6 };
+    const updated = repo.applyOperation(doc.id, op, 0);
+    expect(updated).toBeDefined();
+    expect(updated!.content).toBe('hello');
+  });
+
+  it('returns null for applyOperation on nonexistent doc', () => {
+    const op = { type: 'insert' as const, pos: 0, text: 'x' };
+    expect(repo.applyOperation('nonexistent', op, 0)).toBeNull();
+  });
+
+  it('version increments with each operation', () => {
+    const doc = repo.create({ title: 'Doc', content: 'hello' });
+    expect(doc.version).toBe(0);
+    const v1 = repo.applyOperation(doc.id, { type: 'insert', pos: 5, text: '!' }, 0);
+    expect(v1!.version).toBe(1);
+    const v2 = repo.applyOperation(doc.id, { type: 'insert', pos: 6, text: '?' }, 1);
+    expect(v2!.version).toBe(2);
+  });
+});
