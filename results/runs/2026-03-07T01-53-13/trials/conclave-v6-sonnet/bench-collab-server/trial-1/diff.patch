+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../server.js';
+
+describe('REST API', () => {
+  let server: ReturnType<typeof createApp>;
+
+  beforeEach(async () => {
+    server = createApp(':memory:');
+    await server.start(0);
+  });
+
+  afterEach(async () => {
+    await server.stop();
+  });
+
+  it('POST /documents creates a document', async () => {
+    const res = await request(server.app)
+      .post('/documents')
+      .send({ title: 'My Doc', content: 'Hello' })
+      .expect(201);
+
+    expect(res.body.id).toBeTruthy();
+    expect(res.body.title).toBe('My Doc');
+    expect(res.body.content).toBe('Hello');
+  });
+
+  it('GET /documents lists documents', async () => {
+    await request(server.app).post('/documents').send({ title: 'A' });
+    await request(server.app).post('/documents').send({ title: 'B' });
+    const res = await request(server.app).get('/documents').expect(200);
+    expect(res.body.length).toBe(2);
+  });
+
+  it('GET /documents/:id returns a document', async () => {
+    const create = await request(server.app)
+      .post('/documents')
+      .send({ title: 'Doc' });
+    const res = await request(server.app)
+      .get(`/documents/${create.body.id}`)
+      .expect(200);
+    expect(res.body.title).toBe('Doc');
+  });
+
+  it('GET /documents/:id returns 404 for missing doc', async () => {
+    await request(server.app).get('/documents/nonexistent').expect(404);
+  });
+
+  it('PUT /documents/:id updates a document', async () => {
+    const create = await request(server.app)
+      .post('/documents')
+      .send({ title: 'Old', content: 'old' });
+    const res = await request(server.app)
+      .put(`/documents/${create.body.id}`)
+      .send({ title: 'New', content: 'new' })
+      .expect(200);
+    expect(res.body.title).toBe('New');
+    expect(res.body.content).toBe('new');
+  });
+
+  it('DELETE /documents/:id deletes a document', async () => {
+    const create = await request(server.app)
+      .post('/documents')
+      .send({ title: 'Bye' });
+    await request(server.app)
+      .delete(`/documents/${create.body.id}`)
+      .expect(204);
+    await request(server.app)
+      .get(`/documents/${create.body.id}`)
+      .expect(404);
+  });
+
+  it('GET /documents/:id/history returns version history', async () => {
+    const create = await request(server.app)
+      .post('/documents')
+      .send({ title: 'Doc', content: 'v1' });
+    await request(server.app)
+      .put(`/documents/${create.body.id}`)
+      .send({ content: 'v2' });
+    const res = await request(server.app)
+      .get(`/documents/${create.body.id}/history`)
+      .expect(200);
+    expect(res.body.length).toBeGreaterThanOrEqual(1);
+  });
+
+  it('POST /documents rejects missing title', async () => {
+    await request(server.app)
+      .post('/documents')
+      .send({ content: 'no title' })
+      .expect(400);
+  });
+
+  it('PUT /documents/:id returns 404 for missing doc', async () => {
+    await request(server.app)
+      .put('/documents/nonexistent')
+      .send({ title: 'New' })
+      .expect(404);
+  });
+
+  it('DELETE /documents/:id returns 404 for missing doc', async () => {
+    await request(server.app)
+      .delete('/documents/nonexistent')
+      .expect(404);
+  });
+});
