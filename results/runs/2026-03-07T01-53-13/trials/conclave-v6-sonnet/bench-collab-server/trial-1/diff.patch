: unknown;\n      try {\n        msg = JSON.parse(data.toString());\n      } catch {\n        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));\n        return;\n      }\n\n      if (typeof msg !== 'object' || msg === null || !('type' in msg)) {\n        ws.send(JSON.stringify({ type: 'error', message: 'Missing type field' }));\n        return;\n      }\n\n      const typed = msg as Record<string, unknown>;\n      if (typed['type'] === 'operation') {\n        room.handleOperation(ws, typed as unknown as ClientMessage);\n      } else {\n        ws.send(JSON.stringify({ type: 'error', message: 'Unknown message type' }));\n      }\n    });\n\n    ws.on('close', () => {\n      room.leave(ws);\n    });\n\n    ws.on('error', (err) => {\n      console.error(`WebSocket error on doc ${docId}:`, err.message);\n      room.leave(ws);\n    });\n  });\n\n  let listening = false;\n\n  return {\n    app,\n    start(port = 0): Promise<number> {\n      return new Promise((resolve, reject) => {\n        if (listening) {\n          const addr = httpServer.address();\n          resolve(typeof addr === 'object' && addr ? addr.port : 0);\n          return;\n        }\n        httpServer.listen(port, () => {\n          listening = true;\n          const addr = httpServer.address();\n          resolve(typeof addr === 'object' && addr ? addr.port : 0);\n        });\n        httpServer.once('error', reject);\n      });\n    },\n    stop(): Promise<void> {\n      return new Promise((resolve, reject) => {\n        // Close all WebSocket connections\n        wss.clients.forEach((client) => client.terminate());\n        wss.close();\n        httpServer.close((err) => {\n          if (err) reject(err);\n          else {\n            listening = false;\n            db.close();\n            resolve();\n          }\n        });\n      });\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens"