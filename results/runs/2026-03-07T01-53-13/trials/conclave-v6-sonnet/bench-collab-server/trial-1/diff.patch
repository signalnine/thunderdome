'error') return msg;\n      // It's a broadcast - skip and keep waiting\n    }\n  }","originalFile":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport WebSocket from 'ws';\nimport request from 'supertest';\nimport { createApp } from '../server.js';\n\ntype ServerMsg = {\n  type: string;\n  content?: string;\n  version?: number;\n  op?: unknown;\n  message?: string;\n  documentId?: string;\n};\n\n/**\n * A WebSocket client wrapper that buffers incoming messages so we never miss one.\n */\nclass WsClient {\n  private ws: WebSocket;\n  private messageQueue: ServerMsg[] = [];\n  private waiters: Array<(msg: ServerMsg) => void> = [];\n  private openPromise: Promise<void>;\n  private closePromise: Promise<void>;\n\n  constructor(url: string) {\n    this.ws = new WebSocket(url);\n\n    this.openPromise = new Promise<void>((resolve, reject) => {\n      this.ws.once('open', resolve);\n      this.ws.once('error', reject);\n    });\n\n    this.closePromise = new Promise<void>((resolve) => {\n      this.ws.once('close', () => resolve());\n    });\n\n    // Buffer messages as soon as they arrive - BEFORE open resolves\n    this.ws.on('message', (data) => {\n      let msg: ServerMsg;\n      try {\n        msg = JSON.parse(data.toString()) as ServerMsg;\n      } catch {\n        return;\n      }\n      if (this.waiters.length > 0) {\n        const waiter = this.waiters.shift()!;\n        waiter(msg);\n      } else {\n        this.messageQueue.push(msg);\n      }\n    });\n  }\n\n  async open(): Promise<void> {\n    await this.openPromise;\n  }\n\n  nextMessage(timeoutMs = 5000): Promise<ServerMsg> {\n    if (this.messageQueue.length > 0) {\n      return Promise.resolve(this.messageQueue.shift()!);\n    }\n    return new Promise<ServerMsg>((resolve, reject) => {\n      const timer = setTimeout(() => {\n        const idx = this.waiters.indexOf(resolve);\n        if (idx >= 0) this.waiters.splice(idx, 1);\n        reject(new Error(`nextMessage timeout after ${timeoutMs}ms`));\n      }, timeoutMs);\n\n      this.waiters.push((msg) => {\n        clearTimeout(timer);\n        resolve(msg);\n      });\n    });\n  }\n\n  send(data: unknown): void {\n    this.ws.send(JSON.stringify(data));\n  }\n\n  sendRaw(data: string): void {\n    this.ws.send(data);\n  }\n\n  close(): Promise<void> {\n    if (this.ws.readyState === WebSocket.CLOSED) return Promise.resolve();\n    this.ws.close();\n    return this.closePromise;\n  }\n}\n\nfunction makeClient(port: number, docId: string): WsClient {\n  return new WsClient(`ws://localhost:${port}/documents/${docId}/ws`);\n}\n\ndescribe('WebSocket collaboration', () => {\n  let server: ReturnType<typeof createApp>;\n  let port: number;\n  let docId: string;\n\n  beforeEach(async () => {\n    server = createApp(':memory:');\n    port = await server.start(0);\n    const res = await request(server.app)\n      .post('/documents')\n      .send({ title: 'Collab Doc', content: 'hello' });\n    docId = res.body.id as string;\n  });\n\n  afterEach(async () => {\n    await server.stop();\n  });\n\n  it('sends sync message on connect', async () => {\n    const client = makeClient(port, docId);\n    await client.open();\n    const msg = await client.nextMessage();\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(typeof msg.version).toBe('number');\n    await client.close();\n  });\n\n  it('returns error for nonexistent document', async () => {\n    const client = makeClient(port, 'nonexistent-doc-id');\n    // Don't await open - it may close immediately after error\n    const msg = await client.nextMessage(5000);\n    expect(msg.type).toBe('error');\n    await client.close();\n  });\n\n  it('applies an insert operation and acks', async () => {\n    const client = makeClient(port, docId);\n    await client.open();\n    const sync = await client.nextMessage();\n    expect(sync.type).toBe('sync');\n\n    client.send({\n      type: 'operation',\n      clientVersion: sync.version,\n      op: { type: 'insert', pos: 5, text: ' world' },\n    });\n\n    const ack = await client.nextMessage();\n    expect(ack.type).toBe('ack');\n    expect(typeof ack.version).toBe('number');\n\n    // Verify via REST\n    const res = await request(server.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n    await client.close();\n  });\n\n  it('applies a delete operation and acks', async () => {\n    const client = makeClient(port, docId);\n    await client.open();\n    const sync = await client.nextMessage();\n\n    client.send({\n      type: 'operation',\n      clientVersion: sync.version,\n      op: { type: 'delete', pos: 0, length: 5 },\n    });\n\n    const ack = await client.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    const res = await request(server.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('');\n    await client.close();\n  });\n\n  it('broadcasts operation to other clients', async () => {\n    const c1 = makeClient(port, docId);\n    const c2 = makeClient(port, docId);\n    await Promise.all([c1.open(), c2.open()]);\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    c1.send({\n      type: 'operation',\n      clientVersion: 0,\n      op: { type: 'insert', pos: 5, text: '!' },\n    });\n\n    const ack = await c1.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await c2.nextMessage();\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.op as { text?: string }).text).toBe('!');\n\n    await c1.close();\n    await c2.close();\n  });\n\n  it('converges concurrent edits from two clients', async () => {\n    // Start: \"hello\"\n    // Client A inserts \" world\" at pos 5 (version 0)\n    // Client B inserts \"!\" at pos 5 (version 0) - concurrent\n    // Both edits must be preserved in final content\n    const c1 = makeClient(port, docId);\n    const c2 = makeClient(port, docId);\n    await Promise.all([c1.open(), c2.open()]);\n\n    const sync1 = await c1.nextMessage();\n    const sync2 = await c2.nextMessage();\n\n    expect(sync1.version).toBe(sync2.version);\n    expect(sync1.content).toBe('hello');\n\n    const opA = { type: 'insert', pos: 5, text: ' world' };\n    const opB = { type: 'insert', pos: 5, text: '!' };\n\n    c1.send({ type: 'operation', clientVersion: sync1.version, op: opA });\n    const ackA = await c1.nextMessage();\n    expect(ackA.type).toBe('ack');\n\n    // c2 gets broadcast of opA\n    const broadcastA = await c2.nextMessage();\n    expect(broadcastA.type).toBe('operation');\n\n    // c2 sends its op at old version - server will transform it\n    c2.send({ type: 'operation', clientVersion: sync2.version, op: opB });\n    const ackB = await c2.nextMessage();\n    expect(ackB.type).toBe('ack');\n\n    // c1 gets broadcast of transformed opB\n    const broadcastB = await c1.nextMessage();\n    expect(broadcastB.type).toBe('operation');\n\n    // Verify final content contains both edits\n    const res = await request(server.app).get(`/documents/${docId}`);\n    const finalContent = res.body.content as string;\n    expect(finalContent).toContain('world');\n    expect(finalContent).toContain('!');\n\n    await c1.close();\n    await c2.close();\n  });\n\n  it('rejects malformed operation (missing required fields)', async () => {\n    const client = makeClient(port, docId);\n    await client.open();\n    await client.nextMessage(); // sync\n\n    client.send({ type: 'operation', clientVersion: 0, op: { type: 'insert' } });\n    const err = await client.nextMessage();\n    expect(err.type).toBe('error');\n    await client.close();\n  });\n\n  it('rejects invalid JSON', async () => {\n    const client = makeClient(port, docId);\n    await client.open();\n    await client.nextMessage(); // sync\n\n    client.sendRaw('not-valid-json');\n    const err = await client.nextMessage();\n    expect(err.type).toBe('error');\n    await client.close();\n  });\n\n  it('rejects unknown message type', async () => {\n    const client = makeClient(port, docId);\n    await client.open();\n    await client.nextMessage(); // sync\n\n    client.send({ type: 'unknown' });\n    const err = await client.nextMessage();\n    expect(err.type).toBe('error');\n    await client.close();\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const N = 10;\n    const clients: WsClient[] = [];\n\n    for (let i = 0; i < N; i++) {\n      const c = makeClient(port, docId);\n      await c.open();\n      await c.nextMessage(); // sync\n      clients.push(c);\n    }\n\n    // Each client sends one insert at position 0\n    for (const [i, c] of clients.entries()) {\n      c.send({\n        type: 'operation',\n        clientVersion: 0,\n        op: { type: 'insert', pos: 0, text: `${i}` },\n      });\n    }\n\n    // Wait for all acks\n    const acks = await Promise.all(clients.map((c) => c.nextMessage()));\n    expect(acks.every((a) => a.type === 'ack')).toBe(true);\n\n    // Final content should contain all 10 digits\n    const res = await request(server.app).get(`/documents/${docId}`);\n    const content = res.body.content as string;\n    for (let i = 0; i < N; i++) {\n      expect(content).toContain(`${i}`);\n    }\n\n    await Promise.all(clients.map((c) => c.close()));\n  });\n});\n","structuredPatch":[{"oldStart":73,"oldLines":6,"newStart":73,"newLines":18,"lines":["     });","   }"," ","+  /** Drain messages until we get an ack (skipping broadcasts from other clients). */","+  async nextAck(timeoutMs = 8000): Promise<ServerMsg> {","+    const deadline = Date.now() + timeoutMs;","+    while (true) {","+      const remaining = deadline - Date.now();","+      if (remaining <= 0) throw new Error('nextAck timeout');","+      const msg = await this.nextMessage(remaining);","+      if (msg.type === 'ack' || msg.type === 'error') return msg;","+      // It's a broadcast - skip and keep waiting","+    }","+  }","+"