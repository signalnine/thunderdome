d = res.locals.userId as string;\n\n    if (!doc) {\n      return res.status(404).json({ error: 'document not found' });\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'editor')) {\n      return res.status(403).json({ error: 'forbidden' });\n    }\n\n    const { title, content } = req.body;\n    if (title !== undefined) doc.title = title;\n    if (content !== undefined) doc.content = content;\n    doc.updatedAt = new Date();\n\n    return res.json(doc);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const doc = store.documents.get(req.params.id);\n    const userId = res.locals.userId as string;\n\n    if (!doc) {\n      return res.status(404).json({ error: 'document not found' });\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'owner')) {\n      return res.status(403).json({ error: 'forbidden' });\n    }\n\n    store.documents.delete(req.params.id);\n    return res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":466,"cache_read_input_tokens":40774,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":466},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"92580e83-ab2c-4ee7-b38c-9a68f0de93e9","uuid":"610b315b-a027-488c-9bcc-72c56dfc3835"}
