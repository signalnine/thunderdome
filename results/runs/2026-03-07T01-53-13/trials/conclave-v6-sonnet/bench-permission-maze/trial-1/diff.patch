+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import { createStore } from './store.js';
+
+async function setupUser(app: ReturnType<typeof createApp>, username: string, password = 'secret') {
+  const regRes = await request(app).post('/auth/register').send({ username, password });
+  const loginRes = await request(app).post('/auth/login').send({ username, password });
+  return { token: loginRes.body.token as string, userId: regRes.body.id as string };
+}
+
+describe('Activity Log', () => {
+  let app: ReturnType<typeof createApp>;
+  let token: string;
+  let userId: string;
+
+  beforeEach(async () => {
+    app = createApp(createStore());
+    ({ token, userId } = await setupUser(app, 'alice'));
+  });
+
+  it('GET /activity returns empty list initially', async () => {
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body).toEqual([]);
+  });
+
+  it('logs document creation', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Folder' });
+
+    await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'My Doc', content: 'Hello', folderId: folderRes.body.id });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    const docCreated = res.body.find((e: { action: string }) => e.action === 'document.created');
+    expect(docCreated).toBeDefined();
+    expect(docCreated.userId).toBe(userId);
+    expect(docCreated.resourceType).toBe('document');
+    expect(docCreated.timestamp).toBeDefined();
+  });
+
+  it('logs document update', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Folder' });
+
+    const docRes = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'Hello', folderId: folderRes.body.id });
+
+    await request(app)
+      .put(`/documents/${docRes.body.id}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Updated' });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    const docUpdated = res.body.find((e: { action: string }) => e.action === 'document.updated');
+    expect(docUpdated).toBeDefined();
+  });
+
+  it('logs document deletion', async () => {
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Folder' });
+
+    const docRes = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'Bye', folderId: folderRes.body.id });
+
+    await request(app)
+      .delete(`/documents/${docRes.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    const docDeleted = res.body.find((e: { action: string }) => e.action === 'document.deleted');
+    expect(docDeleted).toBeDefined();
+  });
+
+  it('logs sharing events', async () => {
+    const bob = await setupUser(app, 'bob');
+
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Folder' });
+
+    const docRes = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'Hello', folderId: folderRes.body.id });
+
+    await request(app)
+      .post(`/documents/${docRes.body.id}/share`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ userId: bob.userId, role: 'viewer' });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    const shareEvent = res.body.find((e: { action: string }) => e.action === 'document.shared');
+    expect(shareEvent).toBeDefined();
+    expect(shareEvent.userId).toBe(userId);
+  });
+
+  it('returns 401 if not authenticated', async () => {
+    const res = await request(app).get('/activity');
+    expect(res.status).toBe(401);
+  });
+});
diff --git a/src/app.ts b/src/app.ts
new file mode 100644
index 0000000..d7f4ce4
--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,27 @@
+import express from 'express';
+import type { Store } from './types.js';
+import { createStore } from './store.js';
+import { createAuthRouter } from './auth.js';
+import { createAuthMiddleware } from './middleware.js';
+import { createFoldersRouter } from './folders.js';
+import { createDocumentsRouter } from './documents.js';
+
+export function createApp(store: Store = createStore()) {
+  const app = express();
+  app.use(express.json());
+
+  // Public routes
+  app.use('/auth', createAuthRouter(store));
+
+  // All routes below require authentication
+  app.use(createAuthMiddleware(store));
+
+  app.use('/folders', createFoldersRouter(store));
+  app.use('/documents', createDocumentsRouter(store));
+
+  app.get('/activity', (_req, res) => {
+    return res.json(store.activityLog);
+  });
+
+  return app;
+}
