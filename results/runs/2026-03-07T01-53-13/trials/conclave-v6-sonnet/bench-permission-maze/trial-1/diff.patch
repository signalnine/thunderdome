index 0000000..491ce4b
--- /dev/null
+++ b/src/auth.ts
@@ -0,0 +1,42 @@
+import { Router } from 'express';
+import { randomUUID } from 'crypto';
+import type { Store } from './types.js';
+
+export function createAuthRouter(store: Store) {
+  const router = Router();
+
+  router.post('/register', (req, res) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      return res.status(400).json({ error: 'username and password required' });
+    }
+
+    const existing = [...store.users.values()].find(u => u.username === username);
+    if (existing) {
+      return res.status(409).json({ error: 'username already taken' });
+    }
+
+    const id = randomUUID();
+    store.users.set(id, { id, username, passwordHash: password }); // simple plain storage for in-memory
+    return res.status(201).json({ id, username });
+  });
+
+  router.post('/login', (req, res) => {
+    const { username, password } = req.body;
+
+    const user = [...store.users.values()].find(
+      u => u.username === username && u.passwordHash === password,
+    );
+
+    if (!user) {
+      return res.status(401).json({ error: 'invalid credentials' });
+    }
+
+    const token = randomUUID();
+    store.tokens.set(token, user.id);
+    return res.status(200).json({ token });
+  });
+
+  return router;
+}
