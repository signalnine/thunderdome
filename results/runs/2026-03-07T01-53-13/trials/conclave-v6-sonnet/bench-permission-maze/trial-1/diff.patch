+import { randomUUID } from 'crypto';
+import type { Store, ActivityLogEntry } from './types.js';
+
+export function logActivity(
+  store: Store,
+  action: string,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+): void {
+  const entry: ActivityLogEntry = {
+    id: randomUUID(),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date(),
+  };
+  store.activityLog.push(entry);
+}
