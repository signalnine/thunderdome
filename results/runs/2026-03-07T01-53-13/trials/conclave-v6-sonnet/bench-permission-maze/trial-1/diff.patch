7","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/documents.ts","content":"import { Router } from 'express';\nimport { randomUUID } from 'crypto';\nimport type { Store } from './types.js';\nimport { hasRole } from './permissions.js';\n\nexport function createDocumentsRouter(store: Store) {\n  const router = Router();\n\n  router.post('/', (req, res) => {\n    const { title, content, folderId } = req.body;\n    const userId = res.locals.userId as string;\n\n    if (!title || !folderId) {\n      return res.status(400).json({ error: 'title and folderId are required' });\n    }\n\n    if (!store.folders.has(folderId)) {\n      return res.status(404).json({ error: 'folder not found' });\n    }\n\n    if (!hasRole(store, userId, 'folder', folderId, 'editor')) {\n      return res.status(403).json({ error: 'forbidden' });\n    }\n\n    const id = randomUUID();\n    const now = new Date();\n    const doc = {\n      id,\n      title,\n      content: content ?? '',\n      folderId,\n      ownerId: userId,\n      createdAt: now,\n      updatedAt: now,\n    };\n    store.documents.set(id, doc);\n\n    store.permissions.push({\n      resourceType: 'document',\n      resourceId: id,\n      userId,\n      role: 'owner',\n    });\n\n    return res.status(201).json(doc);\n  });\n\n  router.get('/:id', (req, res) => {\n    const doc = store.documents.get(req.params.id);\n    const userId = res.locals.userId as string;\n\n    if (!doc) {\n      return res.status(404).json({ error: 'document not found' });\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'viewer')) {\n      return res.status(403).json({ error: 'forbidden' });\n    }\n\n    return res.json(doc);\n  });\n\n  router.put('/:id', (req, res) => {\n    const doc = store.documents.get(req.params.id);\n    const userId = res.locals.userId as string;\n\n    if (!doc) {\n      return res.status(404).json({ error: 'document not found' });\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'editor')) {\n      return res.status(403).json({ error: 'forbidden' });\n    }\n\n    const { title, content } = req.body;\n    if (title !== undefined) doc.title = title;\n    if (content !== undefined) doc.content = content;\n    doc.updatedAt = new Date();\n\n    return res.json(doc);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const doc = store.documents.get(req.params.id);\n    const userId = res.locals.userId as string;\n\n    if (!doc) {\n      return res.status(404).json({ error: 'document not found' });\n    }\n\n    if (!hasRole(store, userId, 'document', doc.id, 'owner')) {\n      return res.status(403).json({ error: 'forbidden' });\n    }\n\n    store.documents.delete(req.params.id);\n    return res.status(204).send();\n  });\n\n  return router;\n}\n","numLines":101,"startLine":1,"totalLines":101}}}
