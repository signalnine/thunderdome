+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../app.js';
+import { initDb, closeDb } from '../db.js';
+import type { Express } from 'express';
+
+let app: Express;
+let token: string;
+let otherToken: string;
+
+beforeEach(async () => {
+  initDb(':memory:');
+  app = createApp();
+
+  const res = await request(app).post('/api/auth/register').send({
+    email: 'alice@acme.com',
+    password: 'password123',
+    tenant_id: 'acme',
+  });
+  token = res.body.token as string;
+
+  const res2 = await request(app).post('/api/auth/register').send({
+    email: 'bob@other.com',
+    password: 'password123',
+    tenant_id: 'other',
+  });
+  otherToken = res2.body.token as string;
+});
+
+afterEach(() => {
+  closeDb();
+});
+
+describe('Create Dashboard', () => {
+  it('creates a dashboard for the tenant', async () => {
+    const res = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Traffic Overview' });
+
+    expect(res.status).toBe(201);
+    expect(res.body.id).toBeDefined();
+    expect(res.body.name).toBe('Traffic Overview');
+    expect(res.body.tenant_id).toBe('acme');
+  });
+
+  it('rejects creation without a name', async () => {
+    const res = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({});
+
+    expect(res.status).toBe(400);
+  });
+
+  it('requires authentication', async () => {
+    const res = await request(app)
+      .post('/api/dashboards')
+      .send({ name: 'My Dashboard' });
+
+    expect(res.status).toBe(401);
+  });
+});
+
+describe('List Dashboards', () => {
+  beforeEach(async () => {
+    await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Dashboard 1' });
+
+    await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Dashboard 2' });
+
+    // Other tenant dashboard (should not appear)
+    await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${otherToken}`)
+      .send({ name: 'Other Dashboard' });
+  });
+
+  it('lists only own tenant dashboards', async () => {
+    const res = await request(app)
+      .get('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body).toHaveLength(2);
+    expect(res.body.every((d: { tenant_id: string }) => d.tenant_id === 'acme')).toBe(true);
+  });
+
+  it('requires authentication', async () => {
+    const res = await request(app).get('/api/dashboards');
+    expect(res.status).toBe(401);
+  });
+});
+
+describe('Get Dashboard', () => {
+  let dashboardId: string;
+
+  beforeEach(async () => {
+    const res = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard' });
+    dashboardId = res.body.id as string;
+  });
+
+  it('returns a specific dashboard', async () => {
+    const res = await request(app)
+      .get(`/api/dashboards/${dashboardId}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.id).toBe(dashboardId);
+    expect(res.body.name).toBe('My Dashboard');
+  });
+
+  it('returns 404 for dashboard not in tenant', async () => {
+    const res = await request(app)
+      .get(`/api/dashboards/${dashboardId}`)
+      .set('Authorization', `Bearer ${otherToken}`);
+
+    expect(res.status).toBe(404);
+  });
+
+  it('returns 404 for unknown dashboard', async () => {
+    const res = await request(app)
+      .get('/api/dashboards/nonexistent-id')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(404);
+  });
+});
+
+describe('Update Dashboard', () => {
+  let dashboardId: string;
+
+  beforeEach(async () => {
+    const res = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Original Name' });
+    dashboardId = res.body.id as string;
+  });
+
+  it('updates dashboard name', async () => {
+    const res = await request(app)
+      .put(`/api/dashboards/${dashboardId}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Updated Name' });
+
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('Updated Name');
+  });
+
+  it('cannot update dashboard from another tenant', async () => {
+    const res = await request(app)
+      .put(`/api/dashboards/${dashboardId}`)
+      .set('Authorization', `Bearer ${otherToken}`)
+      .send({ name: 'Hacked' });
+
+    expect(res.status).toBe(404);
+  });
+});
+
+describe('Delete Dashboard', () => {
+  let dashboardId: string;
+
+  beforeEach(async () => {
+    const res = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'To Delete' });
+    dashboardId = res.body.id as string;
+  });
+
+  it('deletes dashboard', async () => {
+    const delRes = await request(app)
+      .delete(`/api/dashboards/${dashboardId}`)
+      .set('Authorization', `Bearer ${token}`);
