--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,55 @@
+export interface User {
+  id: string;
+  email: string;
+  password_hash: string;
+  tenant_id: string;
+  role: 'admin' | 'editor' | 'viewer';
+  created_at: string;
+}
+
+export interface Event {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string; // JSON string
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+export interface Dashboard {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string; // JSON string
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Widget {
+  id: string;
+  dashboard_id: string;
+  type: 'counter' | 'timeseries' | 'breakdown' | 'funnel';
+  config: string; // JSON string
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export interface AuthUser {
+  id: string;
+  email: string;
+  tenant_id: string;
+  role: 'admin' | 'editor' | 'viewer';
+}
+
+declare global {
+  // eslint-disable-next-line @typescript-eslint/no-namespace
+  namespace Express {
+    interface Request {
+      user?: AuthUser;
+    }
+  }
+}
