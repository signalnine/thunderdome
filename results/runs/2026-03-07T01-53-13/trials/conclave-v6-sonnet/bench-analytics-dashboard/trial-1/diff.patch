+import express from 'express';
+import usersRouter from './routes/users.js';
+import eventsRouter from './routes/events.js';
+import queryRouter from './routes/query.js';
+import dashboardsRouter from './routes/dashboards.js';
+import exportRouter from './routes/export.js';
+
+export function createApp(): express.Express {
+  const app = express();
+  app.use(express.json());
+  app.use('/api', usersRouter);
+  app.use('/api/events', eventsRouter);
+  app.use('/api/query', queryRouter);
+  app.use('/api/dashboards', dashboardsRouter);
+  app.use('/api/export', exportRouter);
+  return app;
+}
diff --git a/src/auth.ts b/src/auth.ts
new file mode 100644
index 0000000..58a6699
--- /dev/null
+++ b/src/auth.ts
@@ -0,0 +1,55 @@
+import { Request, Response, NextFunction } from 'express';
+import jwt from 'jsonwebtoken';
+
+export const JWT_SECRET = process.env.JWT_SECRET ?? 'dev-secret-key-change-in-production';
+
+export interface JwtPayload {
+  id: string;
+  email: string;
+  tenant_id: string;
+  role: 'admin' | 'editor' | 'viewer';
+}
+
+export function signToken(payload: JwtPayload): string {
+  return jwt.sign(payload, JWT_SECRET, { expiresIn: '24h' });
+}
+
+export function verifyToken(token: string): JwtPayload {
+  return jwt.verify(token, JWT_SECRET) as JwtPayload;
+}
+
+export function requireAuth(req: Request, res: Response, next: NextFunction): void {
+  const authHeader = req.headers.authorization;
+  if (!authHeader?.startsWith('Bearer ')) {
+    res.status(401).json({ error: 'Authentication required' });
+    return;
+  }
+
+  const token = authHeader.slice(7);
+  try {
+    const payload = verifyToken(token);
+    req.user = {
+      id: payload.id,
+      email: payload.email,
+      tenant_id: payload.tenant_id,
+      role: payload.role,
+    };
+    next();
+  } catch {
+    res.status(401).json({ error: 'Invalid or expired token' });
+  }
+}
+
+export function requireRole(...roles: string[]) {
+  return (req: Request, res: Response, next: NextFunction): void => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+    if (!roles.includes(req.user.role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+    next();
+  };
+}
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..3442493
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,30 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join } from 'path';
+
+let db: Database.Database | null = null;
+
+export function getDb(): Database.Database {
+  if (!db) {
+    throw new Error('Database not initialized. Call initDb first.');
+  }
+  return db;
+}
+
+export function initDb(dbPath: string = ':memory:'): Database.Database {
+  db = new Database(dbPath);
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  const schema = readFileSync(join(process.cwd(), 'schema.sql'), 'utf-8');
+  db.exec(schema);
+
+  return db;
+}
+
+export function closeDb(): void {
+  if (db) {
+    db.close();
+    db = null;
+  }
+}
diff --git a/src/routes/dashboards.ts b/src/routes/dashboards.ts
new file mode 100644
index 0000000..a4926ea
--- /dev/null
+++ b/src/routes/dashboards.ts
@@ -0,0 +1,106 @@
+import { Router, Request, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { requireAuth } from '../auth.js';
+import type { Dashboard } from '../types.js';
+
+const router = Router();
+
+router.use(requireAuth);
+
+function parseDashboard(d: Dashboard) {
+  return {
+    ...d,
+    config: JSON.parse(d.config) as unknown,
+  };
+}
+
+// POST /api/dashboards
+router.post('/', (req: Request, res: Response): void => {
+  const { name, config } = req.body as Record<string, unknown>;
+
+  if (!name || typeof name !== 'string') {
+    res.status(400).json({ error: 'name is required' });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const now = new Date().toISOString();
+  const configStr = config ? JSON.stringify(config) : '{}';
+
+  db.prepare(
+    'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, req.user!.tenant_id, name, req.user!.id, configStr, now, now);
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id) as Dashboard;
+  res.status(201).json(parseDashboard(dashboard));
+});
+
+// GET /api/dashboards
+router.get('/', (req: Request, res: Response): void => {
+  const db = getDb();
+  const dashboards = db
+    .prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC')
+    .all(req.user!.tenant_id) as Dashboard[];
+
+  res.status(200).json(dashboards.map(parseDashboard));
+});
+
+// GET /api/dashboards/:id
+router.get('/:id', (req: Request, res: Response): void => {
+  const db = getDb();
+  const dashboard = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenant_id) as Dashboard | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  res.status(200).json(parseDashboard(dashboard));
+});
+
+// PUT /api/dashboards/:id
+router.put('/:id', (req: Request, res: Response): void => {
+  const db = getDb();
+  const existing = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenant_id) as Dashboard | undefined;
+
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  const { name, config } = req.body as Record<string, unknown>;
+  const updatedName = (name as string) ?? existing.name;
+  const updatedConfig = config ? JSON.stringify(config) : existing.config;
+  const now = new Date().toISOString();
+
+  db.prepare(
+    'UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?'
+  ).run(updatedName, updatedConfig, now, req.params.id);
+
+  const updated = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(req.params.id) as Dashboard;
+  res.status(200).json(parseDashboard(updated));
+});
+
+// DELETE /api/dashboards/:id
+router.delete('/:id', (req: Request, res: Response): void => {
+  const db = getDb();
+  const existing = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenant_id) as Dashboard | undefined;
+
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);
+  res.status(204).send();
+});
+
+export default router;
