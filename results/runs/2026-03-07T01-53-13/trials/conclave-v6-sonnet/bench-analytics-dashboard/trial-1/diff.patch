ant_id = ?')\n    .get(req.params.id, req.user!.tenant_id) as Dashboard | undefined;\n\n  if (!dashboard) {\n    res.status(404).json({ error: 'Dashboard not found' });\n    return;\n  }\n\n  res.status(200).json(parseDashboard(dashboard));\n});\n\n// PUT /api/dashboards/:id\nrouter.put('/:id', (req: Request, res: Response): void => {\n  const db = getDb();\n  const existing = db\n    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n    .get(req.params.id, req.user!.tenant_id) as Dashboard | undefined;\n\n  if (!existing) {\n    res.status(404).json({ error: 'Dashboard not found' });\n    return;\n  }\n\n  const { name, config } = req.body as Record<string, unknown>;\n  const updatedName = (name as string) ?? existing.name;\n  const updatedConfig = config ? JSON.stringify(config) : existing.config;\n  const now = new Date().toISOString();\n\n  db.prepare(\n    'UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?'\n  ).run(updatedName, updatedConfig, now, req.params.id);\n\n  const updated = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(req.params.id) as Dashboard;\n  res.status(200).json(parseDashboard(updated));\n});\n\n// DELETE /api/dashboards/:id\nrouter.delete('/:id', (req: Request, res: Response): void => {\n  const db = getDb();\n  const existing = db\n    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n    .get(req.params.id, req.user!.tenant_id) as Dashboard | undefined;\n\n  if (!existing) {\n    res.status(404).json({ error: 'Dashboard not found' });\n    return;\n  }\n\n  db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);\n  res.status(204).send();\n});\n\nexport default router;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":458,"cache_read_input_tokens":48246,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":458},"output_tokens":25,"service_tier":"standard","