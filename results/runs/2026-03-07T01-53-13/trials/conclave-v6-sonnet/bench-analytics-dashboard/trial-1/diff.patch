+import { Router, Request, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { requireAuth } from '../auth.js';
+
+const router = Router();
+
+router.use(requireAuth);
+
+// POST /api/events
+router.post('/', (req: Request, res: Response): void => {
+  const { name, properties, timestamp } = req.body as Record<string, unknown>;
+
+  if (!name || typeof name !== 'string') {
+    res.status(400).json({ error: 'event name is required' });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const props = properties ? JSON.stringify(properties) : '{}';
+  const ts = (timestamp as string) ?? new Date().toISOString();
+
+  db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+  ).run(id, req.user!.tenant_id, name, props, ts, req.user!.id);
+
+  const event = db.prepare('SELECT * FROM events WHERE id = ?').get(id) as {
+    id: string;
+    tenant_id: string;
+    name: string;
+    properties: string;
+    timestamp: string;
+    user_id: string | null;
+  };
+
+  res.status(201).json({
+    ...event,
+    properties: JSON.parse(event.properties) as unknown,
+  });
+});
+
+// POST /api/events/batch
+router.post('/batch', (req: Request, res: Response): void => {
+  const { events } = req.body as { events?: unknown[] };
+
+  if (!Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: 'events array is required and must not be empty' });
+    return;
+  }
+
+  const db = getDb();
+  const ids: string[] = [];
+
+  const insert = db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+  );
+
+  const insertMany = db.transaction((evts: unknown[]) => {
+    for (const evt of evts) {
+      const e = evt as Record<string, unknown>;
+      if (!e.name || typeof e.name !== 'string') continue;
+      const id = uuidv4();
+      const props = e.properties ? JSON.stringify(e.properties) : '{}';
+      const ts = (e.timestamp as string) ?? new Date().toISOString();
+      insert.run(id, req.user!.tenant_id, e.name, props, ts, req.user!.id);
+      ids.push(id);
+    }
+  });
+
+  insertMany(events);
+
+  res.status(201).json({ count: ids.length, ids });
+});
+
+export default router;
