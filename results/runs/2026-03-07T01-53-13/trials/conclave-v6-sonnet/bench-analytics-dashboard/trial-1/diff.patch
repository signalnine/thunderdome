e(201);\n    expect(res.body.timestamp).toBe(timestamp);\n  });\n\n  it('ingests event with no properties', async () => {\n    const res = await request(app)\n      .post('/api/events')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'signup' });\n\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('signup');\n  });\n\n  it('rejects event without a name', async () => {\n    const res = await request(app)\n      .post('/api/events')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ properties: { url: '/home' } });\n\n    expect(res.status).toBe(400);\n  });\n\n  it('requires authentication', async () => {\n    const res = await request(app)\n      .post('/api/events')\n      .send({ name: 'page_view' });\n\n    expect(res.status).toBe(401);\n  });\n\n  it('associates event with correct tenant (not other tenants)', async () => {\n    await request(app)\n      .post('/api/events')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'page_view' });\n\n    await request(app)\n      .post('/api/events')\n      .set('Authorization', `Bearer ${otherTenantToken}`)\n      .send({ name: 'page_view' });\n\n    const { getDb } = await import('../db.js');\n    const db = getDb();\n    const acmeEvents = db.prepare('SELECT * FROM events WHERE tenant_id = ?').all('acme');\n    const otherEvents = db.prepare('SELECT * FROM events WHERE tenant_id = ?').all('other-tenant');\n\n    expect(acmeEvents).toHaveLength(1);\n    expect(otherEvents).toHaveLength(1);\n  });\n});\n\ndescribe('Batch Event Ingestion', () => {\n  it('ingests a batch of events', async () => {\n    const events = [\n      { name: 'page_view', properties: { url: '/home' } },\n      { name: 'click', properties: { element: 'button' } },\n      { name: 'purchase', properties: { amount: 29.99 } },\n    ];\n\n    const res = await request(app)\n      .post('/api/events/batch')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ events });\n\n    