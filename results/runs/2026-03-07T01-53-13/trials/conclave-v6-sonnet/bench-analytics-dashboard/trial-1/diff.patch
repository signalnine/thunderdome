+import { Router, Request, Response } from 'express';
+import { getDb } from '../db.js';
+import { requireAuth } from '../auth.js';
+import type { Event, Dashboard } from '../types.js';
+
+const router = Router();
+
+router.use(requireAuth);
+
+function toCSV(rows: Record<string, unknown>[]): string {
+  if (rows.length === 0) return '';
+  const headers = Object.keys(rows[0]);
+  const lines = [
+    headers.join(','),
+    ...rows.map(row =>
+      headers.map(h => {
+        const val = row[h];
+        const str = val === null || val === undefined ? '' : String(val);
+        // Escape quotes and wrap in quotes if contains comma, quote, or newline
+        if (str.includes(',') || str.includes('"') || str.includes('\n')) {
+          return `"${str.replace(/"/g, '""')}"`;
+        }
+        return str;
+      }).join(',')
+    ),
+  ];
+  return lines.join('\n');
+}
+
+// GET /api/export/events?format=json|csv&name=xxx
+router.get('/events', (req: Request, res: Response): void => {
+  const format = (req.query.format as string) ?? 'json';
+  const nameFilter = req.query.name as string | undefined;
+
+  const db = getDb();
+
+  let query = 'SELECT * FROM events WHERE tenant_id = ?';
+  const params: unknown[] = [req.user!.tenant_id];
+
+  if (nameFilter) {
+    query += ' AND name = ?';
+    params.push(nameFilter);
+  }
+
+  query += ' ORDER BY timestamp ASC';
+
+  const events = db.prepare(query).all(...params) as Event[];
+
+  if (format === 'csv') {
+    const rows = events.map(e => ({
+      id: e.id,
+      tenant_id: e.tenant_id,
+      name: e.name,
+      properties: e.properties,
+      timestamp: e.timestamp,
+      user_id: e.user_id ?? '',
+      session_id: e.session_id ?? '',
+    }));
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.status(200).send(toCSV(rows as Record<string, unknown>[]));
+    return;
+  }
+
+  // JSON format
+  const parsed = events.map(e => ({
+    ...e,
+    properties: JSON.parse(e.properties) as unknown,
+  }));
+  res.status(200).json(parsed);
+});
+
+// GET /api/export/dashboards/:id?format=json|csv
+router.get('/dashboards/:id', (req: Request, res: Response): void => {
+  const format = (req.query.format as string) ?? 'json';
+  const db = getDb();
+
+  const dashboard = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenant_id) as Dashboard | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  if (format === 'csv') {
+    const row: Record<string, unknown> = {
+      id: dashboard.id,
+      tenant_id: dashboard.tenant_id,
+      name: dashboard.name,
+      owner_id: dashboard.owner_id,
+      config: dashboard.config,
+      created_at: dashboard.created_at,
+      updated_at: dashboard.updated_at,
+    };
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.csv"`);
+    res.status(200).send(toCSV([row]));
+    return;
+  }
+
+  res.status(200).json({
+    ...dashboard,
+    config: JSON.parse(dashboard.config) as unknown,
+  });
+});
+
+export default router;
diff --git a/src/routes/query.ts b/src/routes/query.ts
new file mode 100644
index 0000000..9b73b4c
--- /dev/null
+++ b/src/routes/query.ts
@@ -0,0 +1,115 @@
+import { Router, Request, Response } from 'express';
+import { getDb } from '../db.js';
+import { requireAuth } from '../auth.js';
+
+const router = Router();
+
+router.use(requireAuth);
+
+interface EventFilter {
+  name?: string;
+  start?: string;
+  end?: string;
+}
+
+function buildWhereClause(tenantId: string, filter: EventFilter): { sql: string; params: unknown[] } {
+  const conditions: string[] = ['tenant_id = ?'];
+  const params: unknown[] = [tenantId];
+
+  if (filter.name) {
+    conditions.push('name = ?');
+    params.push(filter.name);
+  }
+  if (filter.start) {
+    conditions.push('timestamp >= ?');
+    params.push(filter.start);
+  }
+  if (filter.end) {
+    conditions.push('timestamp <= ?');
+    params.push(filter.end + 'T23:59:59Z');
+  }
+
+  return { sql: conditions.join(' AND '), params };
+}
+
+// POST /api/query/count
+router.post('/count', (req: Request, res: Response): void => {
+  const { filter = {} } = req.body as { filter?: EventFilter };
+  const db = getDb();
+
+  const { sql, params } = buildWhereClause(req.user!.tenant_id, filter);
+  const result = db.prepare(`SELECT COUNT(*) as count FROM events WHERE ${sql}`).get(...params) as { count: number };
+
+  res.status(200).json({ count: result.count });
+});
+
+// POST /api/query/timeseries
+router.post('/timeseries', (req: Request, res: Response): void => {
+  const { filter = {}, interval = 'day', start, end } = req.body as {
+    filter?: EventFilter;
+    interval?: string;
+    start?: string;
+    end?: string;
+  };
+
+  const db = getDb();
+
+  const effectiveFilter: EventFilter = { ...filter };
+  if (start) effectiveFilter.start = start;
+  if (end) effectiveFilter.end = end;
+
+  const { sql, params } = buildWhereClause(req.user!.tenant_id, effectiveFilter);
+
+  let dateTrunc: string;
+  if (interval === 'hour') {
+    dateTrunc = "strftime('%Y-%m-%dT%H:00:00Z', timestamp)";
+  } else if (interval === 'month') {
+    dateTrunc = "strftime('%Y-%m-01', timestamp)";
+  } else {
+    // default: day
+    dateTrunc = "strftime('%Y-%m-%d', timestamp)";
+  }
+
+  const rows = db
+    .prepare(
+      `SELECT ${dateTrunc} as date, COUNT(*) as count
+       FROM events
+       WHERE ${sql}
+       GROUP BY ${dateTrunc}
+       ORDER BY date ASC`
+    )
+    .all(...params) as Array<{ date: string; count: number }>;
+
+  res.status(200).json({ data: rows });
+});
+
+// POST /api/query/breakdown
+router.post('/breakdown', (req: Request, res: Response): void => {
+  const { filter = {}, breakdown_by } = req.body as {
+    filter?: EventFilter;
+    breakdown_by?: string;
+  };
+
+  if (!breakdown_by || typeof breakdown_by !== 'string') {
+    res.status(400).json({ error: 'breakdown_by property is required' });
+    return;
+  }
+
+  const db = getDb();
+  const { sql, params } = buildWhereClause(req.user!.tenant_id, filter);
+
+  // Extract JSON property from properties column
+  const rows = db
+    .prepare(
+      `SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count
+       FROM events
+       WHERE ${sql}
+       GROUP BY value
+       ORDER BY count DESC`
+    )
+    .all(breakdown_by, ...params) as Array<{ value: unknown; count: number }>;
+
+  res.status(200).json({ data: rows });
+});
+
+export default router;
