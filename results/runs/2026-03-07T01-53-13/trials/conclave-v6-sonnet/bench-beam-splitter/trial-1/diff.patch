s(grid: string[][]): bigint {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [sr, sc] = findSource(grid);\n\n  // Map from state key to number of paths reaching that state.\n  // Process row by row to ensure all parents at row R are fully accumulated\n  // before children at row R+1 are processed.\n  const pathCounts = new Map<string, bigint>();\n  const stateKey = (row: number, col: number, dir: Direction) => `${row},${col},${dir}`;\n\n  const initialKey = stateKey(sr, sc, 'down');\n  pathCounts.set(initialKey, 1n);\n\n  // Frontier: set of (row, col, dir) states to process at the current row\n  let frontier: BeamState[] = [{ row: sr, col: sc, dir: 'down' }];\n\n  let totalExitPaths = 0n;\n\n  while (frontier.length > 0) {\n    const nextFrontier = new Map<string, BeamState>();\n\n    for (const { row, col, dir } of frontier) {\n      const currentCount = pathCounts.get(stateKey(row, col, dir)) ?? 0n;\n\n      const [nr, nc] = nextPosition(row, col, dir);\n      if (!inBounds(nr, nc, rows, cols)) {\n        totalExitPaths += currentCount;\n        continue;\n      }\n\n      const cell = grid[nr][nc];\n      const nextDirs: Direction[] = cell === '^' ? ['dl', 'dr'] : [dir];\n\n      for (const nd of nextDirs) {\n        const key = stateKey(nr, nc, nd);\n        const prev = pathCounts.get(key) ?? 0n;\n        pathCounts.set(key, prev + currentCount);\n\n        if (!nextFrontier.has(key)) {\n          nextFrontier.set(key, { row: nr, col: nc, dir: nd });\n        }\n      }\n    }\n\n    frontier = Array.from(nextFrontier.values());\n  }\n\n  return totalExitPaths;\n}","originalFile":"// Beam directions\n// 'down': row+1, same col\n// 'dl':   row+1, col-1\n// 'dr':   row+1, col+1\n\ntype Direction = 'down' | 'dl' | 'dr';\n\ninterface BeamState {\n  row: number;\n  col: number;\n  dir: Direction;\n}\n\nfunction nextPosition(row: number, col: number, dir: Direction): [number, number] {\n  switch (dir) {\n    case 'down': return [row + 1, col];\n    case 'dl':   return [row + 1, col - 1];\n    case 'dr':   return [row + 1, col + 1];\n  }\n}\n\nfunction inBounds(row: number, col: number, rows: number, cols: number): boolean {\n  return row >= 0 && row < rows && col >= 0 && col < cols;\n}\n\nfunction findSource(grid: string[][]): [number, number] {\n  for (let c = 0; c < grid[0].length; c++) {\n    if (grid[0][c] === 'S') return [0, c];\n  }\n  throw new Error('No source found');\n}\n\nexport function countBeamCells(grid: string[][]): number {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [sr, sc] = findSource(grid);\n\n  const visitedCells = new Set<string>();\n  const visitedStates = new Set<string>();\n\n  const queue: BeamState[] = [{ row: sr, col: sc, dir: 'down' }];\n  visitedCells.add(`${sr},${sc}`);\n\n  while (queue.length > 0) {\n    const { row, col, dir } = queue.shift()!;\n\n    const [nr, nc] = nextPosition(row, col, dir);\n    if (!inBounds(nr, nc, rows, cols)) continue;\n\n    visitedCells.add(`${nr},${nc}`);\n\n    const cell = grid[nr][nc];\n    const nextStates: BeamState[] = cell === '^'\n      ? [\n          { row: nr, col: nc, dir: 'dl' },\n          { row: nr, col: nc, dir: 'dr' },\n        ]\n      : [{ row: nr, col: nc, dir }];\n\n    for (const state of nextStates) {\n      const key = `${state.row},${state.col},${state.dir}`;\n      if (!visitedStates.has(key)) {\n        visitedStates.add(key);\n        queue.push(state);\n      }\n    }\n  }\n\n  return visitedCells.size;\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [sr, sc] = findSource(grid);\n\n  // Map from state key to number of paths reaching that state\n  const pathCounts = new Map<string, bigint>();\n  const stateKey = (row: number, col: number, dir: Direction) => `${row},${col},${dir}`;\n\n  const initialKey = stateKey(sr, sc, 'down');\n  pathCounts.set(initialKey, 1n);\n\n  // Process states in row order (b