+export class Spreadsheet {
+  // Raw stored values (formula strings or primitive values)
+  private rawValues = new Map<string, string | number | boolean>();
+  // Computed values
+  private computed = new Map<string, string | number | boolean>();
+  // Dependencies: cell -> set of cells it depends on
+  private deps = new Map<string, Set<string>>();
+  // Reverse dependencies: cell -> set of cells that depend on it
+  private rdeps = new Map<string, Set<string>>();
+
+  set(cell: string, value: string | number | boolean): void {
+    const normalCell = cell.toUpperCase();
+
+    // If setting a formula, check for circular deps before committing
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const newDeps = this.extractDeps(value);
+      this.checkCircular(normalCell, newDeps);
+    }
+
+    // Remove old dependency edges for this cell
+    this.removeDeps(normalCell);
+
+    // Store raw value
+    this.rawValues.set(normalCell, value);
+
+    // Recompute this cell and all transitive dependents
+    this.recompute(normalCell);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const normalCell = cell.toUpperCase();
+    const val = this.computed.get(normalCell);
+    return val !== undefined ? val : null;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, string | number | boolean> {
+    return new Map(this.computed);
+  }
+
+  // ─── Internals ────────────────────────────────────────────────────────────
+
+  private removeDeps(cell: string): void {
+    const oldDeps = this.deps.get(cell);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.rdeps.get(dep)?.delete(cell);
+      }
+    }
+    this.deps.delete(cell);
+  }
+
+  private recompute(cell: string): void {
+    const raw = this.rawValues.get(cell);
+    if (raw === undefined) {
+      this.computed.delete(cell);
+    } else if (typeof raw === 'string' && raw.startsWith('=')) {
+      const formula = raw.slice(1);
+      const cellDeps = new Set<string>();
+      const result = this.evalFormula(formula, cellDeps);
+      // Register deps
+      this.deps.set(cell, cellDeps);
+      for (const dep of cellDeps) {
+        if (!this.rdeps.has(dep)) this.rdeps.set(dep, new Set());
+        this.rdeps.get(dep)!.add(cell);
+      }
+      this.computed.set(cell, result);
+    } else {
+      this.computed.set(cell, raw as string | number | boolean);
+    }
+
+    // Propagate to reverse dependents (topological order via BFS)
+    const visited = new Set<string>();
+    const queue: string[] = [cell];
+    while (queue.length > 0) {
+      const cur = queue.shift()!;
+      const dependents = this.rdeps.get(cur);
+      if (!dependents) continue;
+      for (const dep of dependents) {
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          // Recompute dep (but don't recurse into this function — just compute directly)
+          this.recomputeCell(dep);
+          queue.push(dep);
+        }
+      }
+    }
+  }
+
+  private recomputeCell(cell: string): void {
+    const raw = this.rawValues.get(cell);
+    if (raw === undefined || !(typeof raw === 'string' && raw.startsWith('='))) return;
+    const formula = raw.slice(1);
+    // Remove old dep edges for this cell
+    const oldDeps = this.deps.get(cell);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.rdeps.get(dep)?.delete(cell);
+      }
+    }
+    const cellDeps = new Set<string>();
+    const result = this.evalFormula(formula, cellDeps);
+    this.deps.set(cell, cellDeps);
+    for (const dep of cellDeps) {
+      if (!this.rdeps.has(dep)) this.rdeps.set(dep, new Set());
+      this.rdeps.get(dep)!.add(cell);
+    }
+    this.computed.set(cell, result);
+  }
+
+  // Check if setting `cell` with `newDeps` would create a cycle
+  private checkCircular(cell: string, newDeps: Set<string>): void {
+    // DFS: from each newDep, can we reach `cell`?
+    const visited = new Set<string>();
+    const stack = [...newDeps];
+    while (stack.length > 0) {
+      const cur = stack.pop()!;
+      if (cur === cell) {
+        throw new Error(`Circular reference detected involving ${cell}`);
+      }
+      if (visited.has(cur)) continue;
+      visited.add(cur);
+      const curDeps = this.deps.get(cur);
+      if (curDeps) {
+        for (const d of curDeps) stack.push(d);
+      }
+    }
+  }
+
+  // Extract all cell references from a formula string
+  private extractDeps(formula: string): Set<string> {
+    const deps = new Set<string>();
+    // Match cell references like A1, AA1, Z100 (not inside function names)
+    const cellRefRe = /\b([A-Z]+)(\d+)\b/g;
+    const body = formula.slice(1); // remove '='
+    let m: RegExpExecArray | null;
+    while ((m = cellRefRe.exec(body)) !== null) {
+      deps.add(m[0].toUpperCase());
+    }
+    return deps;
+  }
+
+  // ─── Formula Evaluator ────────────────────────────────────────────────────
+
+  private evalFormula(expr: string, deps: Set<string>): string | number | boolean {
+    const tokens = this.tokenize(expr);
+    const pos = { i: 0 };
+    const result = this.parseComparison(tokens, pos, deps);
+    return result;
+  }
+
+  // Grammar (lowest to highest precedence):
+  //   comparison = additive ((<|>|<=|>=|=|<>) additive)*
+  //   additive   = multiplicative ((+|-) multiplicative)*
+  //   multiplicative = unary ((*|/) unary)*
+  //   unary      = primary
+  //   primary    = number | string | bool | cellRef | range-func | '(' comparison ')'
+
+  private parseComparison(
+    tokens: Token[],
+    pos: { i: number },
+    deps: Set<string>,
+  ): string | number | boolean {
+    let left = this.parseAdditive(tokens, pos, deps);
+    while (pos.i < tokens.length) {
+      const tok = tokens[pos.i];
+      if (tok.type === 'op' && ['>=', '<=', '<>', '>', '<', '='].includes(tok.value)) {
+        pos.i++;
+        const right = this.parseAdditive(tokens, pos, deps);
+        left = this.applyComparison(tok.value, left, right);
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parseAdditive(
+    tokens: Token[],
+    pos: { i: number },
+    deps: Set<string>,
+  ): string | number | boolean {
+    let left = this.parseMultiplicative(tokens, pos, deps);
+    while (pos.i < tokens.length) {
+      const tok = tokens[pos.i];
+      if (tok.type === 'op' && (tok.value === '+' || tok.value === '-')) {
+        pos.i++;
+        const right = this.parseMultiplicative(tokens, pos, deps);
+        left = (left as number) + (tok.value === '+' ? 1 : -1) * (right as number);
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parseMultiplicative(
+    tokens: Token[],
+    pos: { i: number },
+    deps: Set<string>,
+  ): string | number | boolean {
+    let left = this.parsePrimary(tokens, pos, deps);
+    while (pos.i < tokens.length) {
+      const tok = tokens[pos.i];
+      if (tok.type === 'op' && (tok.value === '*' || tok.value === '/')) {
+        pos.i++;
+        const right = this.parsePrimary(tokens, pos, deps);
+        left =
+          tok.value === '*'
+            ? (left as number) * (right as number)
+            : (left as number) / (right as number);
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parsePrimary(
+    tokens: Token[],
+    pos: { i: number },
+    deps: Set<string>,
+  ): string | number | boolean {
+    if (pos.i >= tokens.length) return 0;
+    const tok = tokens[pos.i];
+
+    if (tok.type === 'lparen') {
+      pos.i++;
+      const val = this.parseComparison(tokens, pos, deps);
+      pos.i++; // consume ')'
+      return val;
+    }
+
+    if (tok.type === 'number') {
+      pos.i++;
+      return tok.numVal!;
+    }
+
+    if (tok.type === 'string') {
+      pos.i++;
+      return tok.value;
+    }
+
+    if (tok.type === 'bool') {
+      pos.i++;
+      return tok.value === 'TRUE';
+    }
+
+    if (tok.type === 'ident') {
+      const name = tok.value.toUpperCase();
+      // Check if it's a function call
+      if (pos.i + 1 < tokens.length && tokens[pos.i + 1].type === 'lparen') {
+        pos.i += 2; // consume name and '('
+        return this.parseFunction(name, tokens, pos, deps);
+      }
+      // It's a cell reference
+      pos.i++;
+      deps.add(name);
+      const val = this.computed.get(name);
+      if (val === undefined) return 0;
+      return val;
+    }
+
+    return 0;
+  }
+
+  private parseFunction(
+    name: string,
+    tokens: Token[],
+    pos: { i: number },
+    deps: Set<string>,
+  ): string | number | boolean {
+    // Collect args separated by commas, ending at ')'
+    const args: Array<string | number | boolean> = [];
+    let rangeArg: string | null = null;
+
+    // Check if first arg is a range (for SUM, AVERAGE, MIN, MAX, COUNT)
+    if (pos.i < tokens.length && tokens[pos.i].type !== 'rparen') {
+      // Peek ahead: ident:ident pattern = range
+      if (
+        pos.i + 2 < tokens.length &&
+        tokens[pos.i].type === 'ident' &&
+        tokens[pos.i + 1].type === 'colon' &&
+        tokens[pos.i + 2].type === 'ident'
+      ) {
+        rangeArg = tokens[pos.i].value + ':' + tokens[pos.i + 2].value;
+        pos.i += 3;
+        // consume closing paren
+        if (pos.i < tokens.length && tokens[pos.i].type === 'rparen') pos.i++;
+        return this.applyRangeFunction(name, rangeArg, deps);
+      }
+
+      // Parse first arg
+      args.push(this.parseComparison(tokens, pos, deps));
+      while (pos.i < tokens.length && tokens[pos.i].type === 'comma') {
+        pos.i++; // consume comma
+        args.push(this.parseComparison(tokens, pos, deps));
+      }
+    }
+
+    if (pos.i < tokens.length && tokens[pos.i].type === 'rparen') pos.i++;
+
+    if (name === 'IF') {
+      const cond = args[0];
+      const trueVal = args[1] ?? 0;
+      const falseVal = args[2] ?? 0;
+      return cond ? trueVal : falseVal;
+    }
+
+    return 0;
+  }
+
+  private applyRangeFunction(name: string, rangeStr: string, deps: Set<string>): number {
+    const cells = this.expandRange(rangeStr);
+    for (const c of cells) deps.add(c);
+    const values = cells
+      .map((c) => this.computed.get(c))
+      .filter((v): v is number => typeof v === 'number');
+
+    switch (name) {
+      case 'SUM':
+        return values.reduce((a, b) => a + b, 0);
+      case 'AVERAGE':
+        return values.length === 0 ? 0 : values.reduce((a, b) => a + b, 0) / values.length;
+      case 'MIN':
+        return values.length === 0 ? 0 : Math.min(...values);
+      case 'MAX':
+        return values.length === 0 ? 0 : Math.max(...values);
+      case 'COUNT':
+        return values.length;
+      default:
+        return 0;
+    }
+  }
+
+  private expandRange(rangeStr: string): string[] {
+    const [start, end] = rangeStr.split(':');
+    const startCol = this.colLetters(start);
+    const startRow = this.rowNum(start);
+    const endCol = this.colLetters(end);
+    const endRow = this.rowNum(end);
+
+    const colStart = this.colIndex(startCol);
+    const colEnd = this.colIndex(endCol);
+    const rowStart = Math.min(startRow, endRow);
+    const rowEnd = Math.max(startRow, endRow);
+    const colMin = Math.min(colStart, colEnd);
+    const colMax = Math.max(colStart, colEnd);
+
+    const cells: string[] = [];
+    for (let row = rowStart; row <= rowEnd; row++) {
+      for (let col = colMin; col <= colMax; col++) {
+        cells.push(this.colName(col) + row);
+      }
+    }
+    return cells;
+  }
+
+  private colLetters(cellRef: string): string {
+    return cellRef.replace(/[0-9]/g, '');
+  }
+
+  private rowNum(cellRef: string): number {
+    return parseInt(cellRef.replace(/[A-Z]/g, ''), 10);
+  }
+
+  private colIndex(letters: string): number {
+    let result = 0;
+    for (const ch of letters) {
+      result = result * 26 + (ch.charCodeAt(0) - 64);
+    }
+    return result;
+  }
+
+  private colName(index: number): string {
+    let name = '';
+    while (index > 0) {
+      const rem = (index - 1) % 26;
+      name = String.fromCharCode(65 + rem) + name;
+      index = Math.floor((index - 1) / 26);
+    }
+    return name;
+  }
+
+  private applyComparison(
+    op: string,
+    left: string | number | boolean,
+    right: string | number | boolean,
+  ): boolean {
+    switch (op) {
+      case '>':
+        return (left as number) > (right as number);
+      case '<':
+        return (left as number) < (right as number);
+      case '>=':
+        return (left as number) >= (right as number);
+      case '<=':
+        return (left as number) <= (right as number);
+      case '=':
+        return left === right;
+      case '<>':
+        return left !== right;
+      default:
+        return false;
+    }
+  }
+
+  // ─── Tokenizer ────────────────────────────────────────────────────────────
+
+  private tokenize(expr: string): Token[] {
+    const tokens: Token[] = [];
+    let i = 0;
+    while (i < expr.length) {
+      const ch = expr[i];
+
+      if (ch === ' ') { i++; continue; }
+
+      if (ch === '(') { tokens.push({ type: 'lparen', value: '(' }); i++; continue; }
+      if (ch === ')') { tokens.push({ type: 'rparen', value: ')' }); i++; continue; }
+      if (ch === ',') { tokens.push({ type: 'comma', value: ',' }); i++; continue; }
+      if (ch === ':') { tokens.push({ type: 'colon', value: ':' }); i++; continue; }
+      if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+        tokens.push({ type: 'op', value: ch }); i++; continue;
+      }
+
+      // Multi-char operators
+      if (ch === '>' || ch === '<' || ch === '=') {
+        if (expr[i + 1] === '=') {
+          tokens.push({ type: 'op', value: ch + '=' }); i += 2;
+        } else if (ch === '<' && expr[i + 1] === '>') {
+          tokens.push({ type: 'op', value: '<>' }); i += 2;
+        } else {
+          tokens.push({ type: 'op', value: ch }); i++;
+        }
+        continue;
+      }
+
+      // String literals
+      if (ch === '"') {
+        let s = '';
+        i++;
+        while (i < expr.length && expr[i] !== '"') { s += expr[i++]; }
+        i++; // closing quote
+        tokens.push({ type: 'string', value: s });
+        continue;
+      }
+
+      // Numbers
+      if (ch >= '0' && ch <= '9' || (ch === '.' && expr[i + 1] >= '0' && expr[i + 1] <= '9')) {
+        let s = '';
+        while (i < expr.length && (expr[i] >= '0' && expr[i] <= '9' || expr[i] === '.')) {
+          s += expr[i++];
+        }
+        tokens.push({ type: 'number', value: s, numVal: parseFloat(s) });
+        continue;
+      }
+
+      // Identifiers / cell references / function names / booleans
+      if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+        let s = '';
+        while (i < expr.length && ((expr[i] >= 'A' && expr[i] <= 'Z') || (expr[i] >= 'a' && expr[i] <= 'z') || (expr[i] >= '0' && expr[i] <= '9'))) {
+          s += expr[i++];
+        }
+        const upper = s.toUpperCase();
+        if (upper === 'TRUE' || upper === 'FALSE') {
+          tokens.push({ type: 'bool', value: upper });
+        } else {
+          tokens.push({ type: 'ident', value: upper });
+        }
+        continue;
+      }
+
+      i++; // skip unknown
+    }
+    return tokens;
+  }
+}
+
+type Token =
+  | { type: 'number'; value: string; numVal: number }
+  | { type: 'string'; value: string }
+  | { type: 'bool'; value: string }
+  | { type: 'ident'; value: string }
+  | { type: 'op'; value: string }
+  | { type: 'lparen'; value: string }
+  | { type: 'rparen'; value: string }
+  | { type: 'comma'; value: string }
+  | { type: 'colon'; value: string };
