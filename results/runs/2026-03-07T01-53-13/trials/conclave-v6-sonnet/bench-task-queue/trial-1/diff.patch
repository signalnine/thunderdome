+**Step 3: Implement `reportProgress()`**
+
+```typescript
+reportProgress(taskId: string, progress: number, message?: string): void {
+  const task = this.tasks.get(taskId);
+  if (!task) throw new Error(`Task ${taskId} not found`);
+  if (task.status !== 'processing') throw new Error(`Task ${taskId} is not processing`);
+  if (progress < 0 || progress > 100) throw new Error('Progress must be 0-100');
+
+  task.progress = progress;
+  task.progressMessage = message;
+
+  const listeners = this.progressListeners.get(taskId);
+  if (listeners) {
+    for (const listener of listeners) {
+      listener(progress, message);
+    }
+  }
+}
+```
+
+**Step 4: Implement `onProgress()` returning unsubscribe**
+
+```typescript
+onProgress(taskId: string, listener: ProgressListener): () => void {
+  if (!this.progressListeners.has(taskId)) {
+    this.progressListeners.set(taskId, new Set());
+  }
+  const listeners = this.progressListeners.get(taskId)!;
+  listeners.add(listener);
+
+  return () => {
+    listeners.delete(listener);
+    if (listeners.size === 0) {
+      this.progressListeners.delete(taskId);
+    }
+  };
+}
+```
+
+**Step 5: Implement `cancel()`**
+
+```typescript
+cancel(taskId: string): void {
+  const task = this.tasks.get(taskId);
+  if (!task) throw new Error(`Task ${taskId} not found`);
+
+  if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {
+    throw new Error(`Task ${taskId} cannot be cancelled in status: ${task.status}`);
+  }
+
+  const q = this.queues.get(task.queueName);
+
+  if (task.status === 'pending' || task.status === 'blocked') {
+    // Remove from pending list
+    if (q) {
+      const idx = q.pending.findIndex(t => t.id === taskId);
+      if (idx !== -1) q.pending.splice(idx, 1);
+    }
+  } else if (task.status === 'processing') {
+    if (q) q.processing.delete(taskId);
+  }
+
+  task.status = 'cancelled';
+  // Clean up listeners
+  this.progressListeners.delete(taskId);
+}
+```
