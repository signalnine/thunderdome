+import { describe, it, expect } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  it('complete() marks task as completed', () => {
+    const q = new TaskQueue();
+    const t = q.add({ payload: 'x' });
+    q.dequeue();
+    q.complete(t.id);
+    expect(t.status).toBe('completed');
+  });
+
+  it('fail() with retries remaining re-queues with backoff delay', () => {
+    const now = 0;
+    const q = new TaskQueue(() => now);
+    const t = q.add({ payload: 'x', maxRetries: 3, baseDelay: 1000 });
+    q.dequeue(); // attempts=1
+    q.fail(t.id, new Error('oops'));
+    // backoff = 1000 * 2^(1-1) = 1000
+    expect(t.status).toBe('pending');
+    expect(t.availableAt.getTime()).toBe(1000);
+    expect(t.error?.message).toBe('oops');
+  });
+
+  it('fail() uses exponential backoff: baseDelay * 2^(attempt-1)', () => {
+    let now = 0;
+    const q = new TaskQueue(() => now);
+    // maxRetries=3 means 3 total attempts; 2 retries possible
+    const t = q.add({ payload: 'x', maxRetries: 3, baseDelay: 100 });
+
+    q.dequeue(); q.fail(t.id); // attempt 1 of 3, backoff=100*2^0=100
+    expect(t.availableAt.getTime()).toBe(100);
+    expect(t.status).toBe('pending');
+
+    now = 200; q.dequeue(); q.fail(t.id); // attempt 2 of 3, backoff=100*2^1=200
+    expect(t.availableAt.getTime()).toBe(400);
+    expect(t.status).toBe('pending');
+
+    // attempt 3 of 3: exhausts retries, goes to DLQ
+    now = 500; q.dequeue(); q.fail(t.id);
+    expect(t.status).toBe('failed');
+  });
+
+  it('fail() with no retries left marks as failed', () => {
+    const q = new TaskQueue();
+    const t = q.add({ payload: 'x', maxRetries: 1 });
+    q.dequeue();
+    q.fail(t.id, new Error('fatal'));
+    expect(t.status).toBe('failed');
+  });
+
+  it('retried task keeps original queue and priority', () => {
+    const q = new TaskQueue();
+    const t = q.add({ payload: 'x', priority: 2 }, 'myqueue');
+    q.dequeue('myqueue');
+    q.fail(t.id);
+    expect(t.queueName).toBe('myqueue');
+    expect(t.priority).toBe(2);
+  });
+
+  it('tracks attempt count', () => {
+    let now = 0;
+    const q = new TaskQueue(() => now);
+    const t = q.add({ payload: 'x', maxRetries: 3, baseDelay: 100 });
+    q.dequeue(); // attempts=1
+    q.fail(t.id); // re-queued with availableAt=100
+    expect(t.attempts).toBe(1);
+    now = 200; q.dequeue(); // attempts=2
+    expect(t.attempts).toBe(2);
+  });
+
+  it('maxRetries defaults to 3', () => {
+    const t = new TaskQueue().add({ payload: 'x' });
+    expect(t.maxRetries).toBe(3);
+  });
+
+  it('baseDelay defaults to 1000', () => {
+    const t = new TaskQueue().add({ payload: 'x' });
+    expect(t.baseDelay).toBe(1000);
+  });
+
+  it('complete() throws if task not processing', () => {
+    const q = new TaskQueue();
+    const t = q.add({ payload: 'x' });
+    expect(() => q.complete(t.id)).toThrow();
+  });
+
+  it('fail() with maxRetries=0 immediately goes to failed', () => {
+    const q = new TaskQueue();
+    const t = q.add({ payload: 'x', maxRetries: 0 });
+    q.dequeue();
+    q.fail(t.id);
+    expect(t.status).toBe('failed');
+  });
+});
