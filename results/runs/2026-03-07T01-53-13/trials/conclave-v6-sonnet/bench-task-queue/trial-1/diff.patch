+import { describe, it, expect } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  /**
+   * Exhausts all retries for a task. maxRetries=N means N total attempts.
+   * Uses baseDelay=0 to avoid clock issues in tests.
+   */
+  function makeExhaustedTask(maxRetries: number, queueName = 'default') {
+    const q = new TaskQueue();
+    const t = q.add({ payload: 'x', maxRetries, baseDelay: 0 }, queueName);
+    for (let i = 0; i < maxRetries; i++) {
+      q.dequeue(queueName);
+      q.fail(t.id, new Error(`fail-${i}`));
+    }
+    return { q, t };
+  }
+
+  it('failed task after maxRetries goes to DLQ', () => {
+    const { q, t } = makeExhaustedTask(1);
+    expect(q.getDLQ()).toHaveLength(1);
+    expect(q.getDLQ()[0].id).toBe(t.id);
+  });
+
+  it('DLQ tasks retain error info', () => {
+    const q = new TaskQueue();
+    const t = q.add({ payload: 'x', maxRetries: 1, baseDelay: 0 });
+    q.dequeue();
+    q.fail(t.id, new Error('terminal'));
+    const dlq = q.getDLQ();
+    expect(dlq[0].error?.message).toBe('terminal');
+  });
+
+  it('DLQ tasks retain attempt count', () => {
+    const { q } = makeExhaustedTask(2);
+    expect(q.getDLQ()[0].attempts).toBe(2);
+  });
+
+  it('requeueFromDLQ moves task back to pending with reset attempts', () => {
+    const { q, t } = makeExhaustedTask(1);
+    q.requeueFromDLQ(t.id);
+    expect(t.status).toBe('pending');
+    expect(t.attempts).toBe(0);
+    expect(q.getDLQ()).toHaveLength(0);
+    expect(q.dequeue()?.id).toBe(t.id);
+  });
+
+  it('clearDLQ empties dead letter queue', () => {
+    const { q } = makeExhaustedTask(1);
+    q.clearDLQ();
+    expect(q.getDLQ()).toHaveLength(0);
+  });
+
+  it('each named queue has independent DLQ', () => {
+    const q = new TaskQueue();
+    const t1 = q.add({ payload: 'a', maxRetries: 1, baseDelay: 0 }, 'qa');
+    const t2 = q.add({ payload: 'b', maxRetries: 1, baseDelay: 0 }, 'qb');
+
+    q.dequeue('qa'); q.fail(t1.id, new Error('fail'));
+    q.dequeue('qb'); q.fail(t2.id, new Error('fail'));
+
+    expect(q.getDLQ('qa')).toHaveLength(1);
+    expect(q.getDLQ('qb')).toHaveLength(1);
+    q.clearDLQ('qa');
+    expect(q.getDLQ('qa')).toHaveLength(0);
+    expect(q.getDLQ('qb')).toHaveLength(1);
+  });
+
+  it('getDLQ returns a copy (not the internal array)', () => {
+    const { q, t } = makeExhaustedTask(1);
+    const dlq = q.getDLQ();
+    expect(dlq[0].id).toBe(t.id);
+    dlq.pop();
+    expect(q.getDLQ()).toHaveLength(1);
+  });
+});
