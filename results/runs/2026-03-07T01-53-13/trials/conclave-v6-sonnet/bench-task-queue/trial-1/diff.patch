ect(t.status).toBe('cancelled');\n  });\n\n  it('reportProgress throws on invalid range', () => {\n    const t = q.add({ payload: 'x' });\n    q.dequeue();\n    expect(() => q.reportProgress(t.id, 101)).toThrow();\n    expect(() => q.reportProgress(t.id, -1)).toThrow();\n  });\n\n  it('pendingCount does not include cancelled tasks', () => {\n    const t = q.add({ payload: 'x' });\n    q.cancel(t.id);\n    expect(q.pendingCount()).toBe(0);\n  });\n\n  it('progress message is optional', () => {\n    const t = q.add({ payload: 'x' });\n    q.dequeue();\n    q.reportProgress(t.id, 50);\n    expect(t.progress).toBe(50);\n    expect(t.progressMessage).toBeUndefined();\n  });\n\n  it('multiple listeners on same task all receive updates', () => {\n    const t = q.add({ payload: 'x' });\n    q.dequeue();\n    const a: number[] = [], b: number[] = [];\n    q.onProgress(t.id, p => a.push(p));\n    q.onProgress(t.id, p => b.push(p));\n    q.reportProgress(t.id, 50);\n    expect(a).toEqual([50]);\n    expect(b).toEqual([50]);\n  });\n\n  it('cancel throws on completed task', () => {\n    const t = q.add({ payload: 'x' });\n    q.dequeue();\n    q.complete(t.id);\n    expect(() => q.cancel(t.id)).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1119,"cache_read_input_tokens":69017,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1119},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"18fce2bb-6502-4a68-a464-ea2d12dfaf15","uuid":"d15e2884-a19e-49e5-b34d-54ecf9a10567"}
