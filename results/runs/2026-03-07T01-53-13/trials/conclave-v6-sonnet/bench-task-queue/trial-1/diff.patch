+import { describe, it, expect } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 4: Delayed Tasks', () => {
+  it('delayed task is not returned until delay passes', () => {
+    let now = 1000;
+    const q = new TaskQueue(() => now);
+    q.add({ payload: 'delayed', delay: 500 });
+    expect(q.dequeue()).toBeNull();
+    now = 1600;
+    const t = q.dequeue();
+    expect(t?.payload).toBe('delayed');
+  });
+
+  it('non-delayed tasks preferred over not-yet-available delayed', () => {
+    const now = 1000;
+    const q = new TaskQueue(() => now);
+    q.add({ payload: 'delayed', delay: 500, priority: 1 });
+    q.add({ payload: 'immediate', priority: 5 });
+    // delayed has higher priority but not yet available
+    expect(q.dequeue()?.payload).toBe('immediate');
+  });
+
+  it('availableAt can be set as a specific date', () => {
+    let now = 0;
+    const q = new TaskQueue(() => now);
+    const future = new Date(5000);
+    q.add({ payload: 'scheduled', availableAt: future });
+    expect(q.dequeue()).toBeNull();
+    now = 5000;
+    expect(q.dequeue()?.payload).toBe('scheduled');
+  });
+
+  it('task exposes availableAt', () => {
+    const now = 1000;
+    const q = new TaskQueue(() => now);
+    const t = q.add({ payload: 'x', delay: 300 });
+    expect(t.availableAt.getTime()).toBe(1300);
+  });
+
+  it('multiple delayed tasks available simultaneously ordered by priority then FIFO', () => {
+    let now = 0;
+    const q = new TaskQueue(() => now);
+    q.add({ payload: 'p5-first', delay: 100, priority: 5 });
+    q.add({ payload: 'p3', delay: 100, priority: 3 });
+    q.add({ payload: 'p5-second', delay: 100, priority: 5 });
+    now = 200;
+    expect(q.dequeue()?.payload).toBe('p3');
+    expect(q.dequeue()?.payload).toBe('p5-first');
+    expect(q.dequeue()?.payload).toBe('p5-second');
+  });
+
+  it('works with named queues', () => {
+    let now = 0;
+    const q = new TaskQueue(() => now);
+    q.add({ payload: 'x', delay: 100 }, 'myqueue');
+    expect(q.dequeue('myqueue')).toBeNull();
+    now = 200;
+    expect(q.dequeue('myqueue')?.payload).toBe('x');
+  });
+
+  it('zero delay task is immediately available', () => {
+    const q = new TaskQueue(() => 1000);
+    q.add({ payload: 'x', delay: 0 });
+    expect(q.dequeue()?.payload).toBe('x');
+  });
+});
