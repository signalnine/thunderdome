t(q.getDLQ()).toHaveLength(0);\n  });\n\n  it('each named queue has independent DLQ', () => {\n    const q = new TaskQueue();\n    const t1 = q.add({ payload: 'a', maxRetries: 1 }, 'qa');\n    const t2 = q.add({ payload: 'b', maxRetries: 1 }, 'qb');\n    exhaustRetries(q, t1.id, 1);\n    exhaustRetries(q, t2.id, 1);\n    expect(q.getDLQ('qa')).toHaveLength(1);\n    expect(q.getDLQ('qb')).toHaveLength(1);\n    q.clearDLQ('qa');\n    expect(q.getDLQ('qa')).toHaveLength(0);\n    expect(q.getDLQ('qb')).toHaveLength(1);\n  });\n\n  it('getDLQ returns a copy (not the internal array)', () => {\n    const q = new TaskQueue();\n    const t = q.add({ payload: 'x', maxRetries: 1 });\n    q.dequeue(); q.fail(t.id);\n    const dlq = q.getDLQ();\n    dlq.pop();\n    expect(q.getDLQ()).toHaveLength(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1170,"cache_read_input_tokens":65590,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1170},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"18fce2bb-6502-4a68-a464-ea2d12dfaf15","uuid":"160ad24f-37c8-4419-ac87-fe1a9e434921"}
