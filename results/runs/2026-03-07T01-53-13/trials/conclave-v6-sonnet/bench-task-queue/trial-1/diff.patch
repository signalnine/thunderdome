+```typescript
+private middlewares = new Map<string, MiddlewareFn[]>();
+private handlers = new Map<string, HandlerFn>();
+```
+
+**Step 3: Add `use()` and `registerHandler()`**
+
+```typescript
+use(queueName: string, middleware: MiddlewareFn): void {
+  if (!this.middlewares.has(queueName)) {
+    this.middlewares.set(queueName, []);
+  }
+  this.middlewares.get(queueName)!.push(middleware);
+}
+
+registerHandler(queueName: string, handler: HandlerFn): void {
+  this.handlers.set(queueName, handler);
+}
+```
+
+**Step 4: Add `process()` that dequeues and runs middleware + handler**
+
+```typescript
+async process(queueName = 'default'): Promise<boolean> {
+  const task = this.dequeue(queueName);
+  if (!task) return false;
+
+  const middlewares = this.middlewares.get(queueName) ?? [];
+  const handler = this.handlers.get(queueName);
+
+  // Build middleware chain
+  const chain = [...middlewares];
+
+  let index = 0;
+  const next = async (): Promise<void> => {
+    if (index < chain.length) {
+      const mw = chain[index++];
+      await mw(task, next);
+    } else if (handler) {
+      await handler(task);
+    }
+  };
+
+  try {
+    await next();
+    // If handler completed normally, mark complete
+    if (task.status === 'processing') {
+      this.complete(task.id);
+    }
+  } catch (err) {
+    if (task.status === 'processing') {
+      this.fail(task.id, err instanceof Error ? err : new Error(String(err)));
+    }
+  }
+
+  return true;
+}
+```
