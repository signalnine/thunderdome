+**Step 5: Implement `shutdown()`**
+
+```typescript
+async shutdown(timeoutMs = 30000): Promise<ShutdownResult> {
+  // Idempotent - return same result if already shut down
+  if (this._shutdownResult) return this._shutdownResult;
+  if (this._shuttingDown) {
+    // Wait for ongoing shutdown
+    return new Promise(resolve => {
+      const check = setInterval(() => {
+        if (this._shutdownResult) {
+          clearInterval(check);
+          resolve(this._shutdownResult);
+        }
+      }, 10);
+    });
+  }
+
+  this._shuttingDown = true;
+  const startTime = this.clock();
+
+  // Run shutdown callbacks
+  for (const cb of this._shutdownCallbacks) {
+    await cb();
+  }
+
+  // Count initially processing tasks
+  let processingIds: string[] = [];
+  for (const [, q] of this.queues) {
+    processingIds.push(...q.processing);
+  }
+
+  // If no processing tasks, done immediately
+  if (processingIds.length === 0) {
+    const result: ShutdownResult = {
+      completed: 0,
+      forceCancelled: 0,
+      durationMs: this.clock() - startTime,
+    };
+    this._shutdownResult = result;
+    return result;
+  }
+
+  // Wait for processing tasks to drain
+  const deadline = startTime + timeoutMs;
+
+  return new Promise<ShutdownResult>(resolve => {
+    const checkDone = () => {
+      const nowMs = this.clock();
+
+      // Collect still-processing task IDs
+      const stillProcessing: string[] = [];
+      for (const [, q] of this.queues) {
+        stillProcessing.push(...q.processing);
+      }
+
+      if (stillProcessing.length === 0) {
+        // All done naturally
+        const result: ShutdownResult = {
+          completed: processingIds.length, // all were completed
+          forceCancelled: 0,
+          durationMs: nowMs - startTime,
+        };
+        this._shutdownResult = result;
+        resolve(result);
+        return;
+      }
+
+      if (nowMs >= deadline) {
+        // Timeout — force cancel remaining
+        let forceCancelled = 0;
+        for (const id of stillProcessing) {
+          const task = this.tasks.get(id);
+          if (task && task.status === 'processing') {
+            const q = this.queues.get(task.queueName)!;
+            q.processing.delete(id);
+            task.status = 'cancelled';
+            forceCancelled++;
+          }
+        }
+        const completed = processingIds.length - forceCancelled;
+        const result: ShutdownResult = {
+          completed,
+          forceCancelled,
+          durationMs: nowMs - startTime,
+        };
+        this._shutdownResult = result;
+        resolve(result);
+        return;
+      }
+
+      setTimeout(checkDone, 10);
+    };
+
+    checkDone();
+  });
+}
+```
