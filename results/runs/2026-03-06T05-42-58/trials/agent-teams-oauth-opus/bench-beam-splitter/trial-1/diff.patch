+import { describe, it, expect } from "vitest";
+import { countBeamCells, countBeamPaths } from "../src/index.js";
+
+describe("countBeamCells", () => {
+  it("example 1: single splitter", () => {
+    const grid = [
+      [".", "S", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+      [".", "^", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it("example 2: two splitters", () => {
+    const grid = [
+      [".", "S", ".", ".", "."],
+      [".", "^", ".", ".", "."],
+      ["^", ".", "^", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it("no splitters: beam goes straight down", () => {
+    const grid = [
+      [".", "S", "."],
+      [".", ".", "."],
+      [".", ".", "."],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it("single row grid", () => {
+    const grid = [["S"]];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it("beam exits left boundary", () => {
+    const grid = [
+      ["S", ".", "."],
+      ["^", ".", "."],
+      [".", ".", "."],
+    ];
+    // S at (0,0), DOWN to (1,0) = splitter
+    // DL: (2,-1) out of bounds
+    // DR: (2,1) in bounds
+    // Visited: (0,0), (1,0), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it("beam exits right boundary", () => {
+    const grid = [
+      [".", ".", "S"],
+      [".", ".", "^"],
+      [".", ".", "."],
+    ];
+    // S at (0,2), DOWN to (1,2) = splitter
+    // DL: (2,1) in bounds
+    // DR: (2,3) out of bounds
+    // Visited: (0,2), (1,2), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it("splitter on last row", () => {
+    const grid = [
+      [".", "S", "."],
+      [".", ".", "."],
+      [".", "^", "."],
+    ];
+    // S at (0,1), DOWN through (1,1), (2,1) = splitter
+    // DL: (3,0) out of bounds
+    // DR: (3,2) out of bounds
+    // Visited: (0,1), (1,1), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it("no source returns 0", () => {
+    const grid = [
+      [".", ".", "."],
+      [".", "^", "."],
+    ];
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it("empty grid returns 0", () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it("chain of splitters along diagonal", () => {
+    const grid = [
+      [".", ".", "S", ".", "."],
+      [".", ".", "^", ".", "."],
+      [".", ".", ".", "^", "."],
+      [".", ".", ".", ".", "^"],
+      [".", ".", ".", ".", "."],
+    ];
+    // S at (0,2), DOWN to (1,2) = splitter
+    // DL from (1,2): (2,1), (3,0), (4,-1) out. Cells: (2,1), (3,0)
+    // DR from (1,2): (2,3) = splitter
+    //   DL from (2,3): (3,2), (4,1), (5,0) out. Cells: (3,2), (4,1)
+    //   DR from (2,3): (3,4) = splitter
+    //     DL from (3,4): (4,3), (5,2) out. Cells: (4,3)
+    //     DR from (3,4): (4,5) out. No cells.
+    // Visited: (0,2), (1,2), (2,1), (3,0), (2,3), (3,2), (4,1), (3,4), (4,3) = 9
+    expect(countBeamCells(grid)).toBe(9);
+  });
+
+  it("multiple beams visit same cell", () => {
+    // Two beams converge on the same cell
+    const grid = [
+      [".", ".", "S", ".", "."],
+      [".", ".", "^", ".", "."],
+      [".", ".", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    // S at (0,2), DOWN to (1,2) = splitter
+    // DL: (2,1), (3,0). DR: (2,3), (3,4)
+    // Visited: (0,2), (1,2), (2,1), (3,0), (2,3), (3,4) = 6
+    expect(countBeamCells(grid)).toBe(6);
+  });
+});
+
+describe("countBeamPaths", () => {
+  it("example 1: single splitter → 2 paths", () => {
+    const grid = [
+      [".", "S", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+      [".", "^", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it("example 2: two splitters → 4 paths", () => {
+    const grid = [
+      [".", "S", ".", ".", "."],
+      [".", "^", ".", ".", "."],
+      ["^", ".", "^", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it("no splitters → 1 path", () => {
+    const grid = [
+      [".", "S", "."],
+      [".", ".", "."],
+      [".", ".", "."],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it("single row → 1 path (immediately exits)", () => {
+    const grid = [["S"]];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it("splitter on last row → 2 paths (both immediately exit)", () => {
+    const grid = [
+      [".", "S", "."],
+      [".", ".", "."],
+      [".", "^", "."],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it("chain of 3 splitters → exponential paths", () => {
+    const grid = [
+      [".", ".", "S", ".", "."],
+      [".", ".", "^", ".", "."],
+      [".", ".", ".", "^", "."],
+      [".", ".", ".", ".", "^"],
+      [".", ".", ".", ".", "."],
+    ];
+    // Splitter at (1,2): splits into DL and DR
+    // DL from (1,2): no more splitters → 1 path
+    // DR from (1,2): hits (2,3) splitter
+    //   DL from (2,3): no more splitters → 1 path
+    //   DR from (2,3): hits (3,4) splitter
+    //     DL from (3,4): 1 path
+    //     DR from (3,4): 1 path
+    //     Total: 2
+    //   Total: 1 + 2 = 3
+    // Total: 1 + 3 = 4
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it("no source returns 0n", () => {
+    const grid = [
+      [".", ".", "."],
+      [".", "^", "."],
+    ];
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it("empty grid returns 0n", () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it("two splitters in same column (stacked)", () => {
+    const grid = [
+      [".", "S", "."],
+      [".", "^", "."],
+      [".", "^", "."],
+      [".", ".", "."],
+    ];
+    // S at (0,1), DOWN to (1,1) = splitter
+    // DL from (1,1): (2,0) not splitter, (3,-1) out. 1 path.
+    // DR from (1,1): (2,2) not splitter, (3,3) out. 1 path.
+    // Total: 2
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it("performance: large grid with many splitters", () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array(cols).fill(".")
+    );
+    grid[0][100] = "S";
+
+    // Place splitters in a chain going down-right
+    let r = 1,
+      c = 100;
+    for (let i = 0; i < 50 && r < rows && c < cols; i++) {
+      grid[r][c] = "^";
+      r += 1;
+      c += 1;
+    }
+
+    const start = performance.now();
+    const paths = countBeamPaths(grid);
+    const cells = countBeamCells(grid);
+    const elapsed = performance.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(paths).toBeGreaterThan(0n);
+    expect(cells).toBeGreaterThan(0);
+  });
+});
