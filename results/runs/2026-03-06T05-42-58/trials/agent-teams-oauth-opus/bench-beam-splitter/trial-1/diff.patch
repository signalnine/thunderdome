onst sourceCol = findSource(grid);\n  if (sourceCol === -1) return 0;\n\n  const visited = new Set<number>();\n  const processed = new Set<number>();\n\n  // Encode (row, col) as a single number for fast Set operations\n  const encode = (r: number, c: number) => r * cols + c;\n  // Encode (row, col, dir) where dir is 0=DOWN, 1=DL, 2=DR\n  const encodeState = (r: number, c: number, d: number) =>\n    (r * cols + c) * 3 + d;\n  const dirIndex = (d: Direction) =>\n    d === \"DOWN\" ? 0 : d === \"DOWN_LEFT\" ? 1 : 2;\n\n  function process(r: number, c: number, dir: Direction): void {\n    const key = encodeState(r, c, dirIndex(dir));\n    if (processed.has(key)) return;\n    processed.add(key);\n\n    const [dr, dc] = DR[dir];\n    let cr = r,\n      cc = c;\n\n    for (;;) {\n      visited.add(encode(cr, cc));\n      const nr = cr + dr;\n      const nc = cc + dc;\n      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) break;\n      if (grid[nr][nc] === \"^\") {\n        visited.add(encode(nr, nc));\n        process(nr, nc, \"DOWN_LEFT\");\n        process(nr, nc, \"DOWN_RIGHT\");\n        break;\n      }\n      cr = nr;\n      cc = nc;\n    }\n  }\n\n  process(0, sourceCol, \"DOWN\");\n  return visited.size;\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  const rows = grid.length;\n  if (rows === 0) return 0n;\n  const cols = grid[0].length;\n  const sourceCol = findSource(grid);\n  if (sourceCol === -1) return 0n;\n\n  const memo = new Map<number, bigint>();\n\n  const encodeState = (r: number, c: number, d: number) =>\n    (r * cols + c) * 3 + d;\n  const dirIndex = (d: Direction) =>\n    d === \"DOWN\" ? 0 : d === \"DOWN_LEFT\" ? 1 : 2;\n\n  function pathCount(r: number, c: number, dir: Direction): bigint {\n    const key = encodeState(r, c, dirIndex(dir));\n    const cached = memo.get(key);\n    if (cached !== undefined) return cached;\n\n    const [dr, dc] = DR[dir];\n    let cr = r,\n      cc = c;\n\n    while (true) {\n      const nr = cr +