al: 2\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  it(\"performance: large grid with many splitters\", () => {\n    const rows = 200;\n    const cols = 200;\n    const grid: string[][] = Array.from({ length: rows }, () =>\n      Array(cols).fill(\".\")\n    );\n    grid[0][100] = \"S\";\n\n    // Place splitters in a chain going down-right\n    let r = 1,\n      c = 100;\n    for (let i = 0; i < 50 && r < rows && c < cols; i++) {\n      grid[r][c] = \"^\";\n      r += 1;\n      c += 1;\n    }\n\n    const start = performance.now();\n    const paths = countBeamPaths(grid);\n    const cells = countBeamCells(grid);\n    const elapsed = performance.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(paths).toBeGreaterThan(0n);\n    expect(cells).toBeGreaterThan(0);\n  });\n});\n","structuredPatch":[{"oldStart":98,"oldLines":12,"newStart":98,"newLines":12,"lines":["     // S at (0,2), DOWN to (1,2) = splitter","     // DL from (1,2): (2,1), (3,0), (4,-1) out. Cells: (2,1), (3,0)","     // DR from (1,2): (2,3) = splitter","-    //   DL from (2,3): (3,2), (4,1) out. Cells: (3,2)","+    //   DL from (2,3): (3,2), (4,1), (5,0) out. Cells: (3,2), (4,1)","     //   DR from (2,3): (3,4) = splitter","-    //     DL from (3,4): (4,3). Cells: (4,3)","+    //     DL from (3,4): (4,3), (5,2) out. Cells: (4,3)","     //     DR from (3,4): (4,5) out. No cells.","-    // Visited: (0,2), (1,2), (2,1), (3,0), (2,3), (3,2), (3,4), (4,3) = 8","-    expect(countBeamCells(grid)).toBe(8);","+    // Visited: (0,2), (1,2), (2,1), (3,0), (2,3), (3,2), (4,1), (3,4), (4,3) = 9","+    expect(countBeamCells(grid)).toBe(9);","   });"," ","   it(\"multiple beams visit same cell\", () => {"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"45a85051-10a6-4ec2-b72e-51dabd0d7e29"}
