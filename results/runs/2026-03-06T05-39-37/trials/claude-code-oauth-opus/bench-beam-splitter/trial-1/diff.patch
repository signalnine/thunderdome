+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const visited = new Set<number>();
+  const seenStates = new Set<number>();
+
+  const encodeCell = (r: number, c: number): number => r * cols + c;
+  const dirIndex = (d: Direction): number =>
+    d === 'down' ? 0 : d === 'down-left' ? 1 : 2;
+  const encodeState = (r: number, c: number, d: Direction): number =>
+    (r * cols + c) * 3 + dirIndex(d);
+
+  const beams: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+  visited.add(encodeCell(source[0], source[1]));
+  seenStates.add(encodeState(source[0], source[1], 'down'));
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const [nr, nc] = nextPos(beam.row, beam.col, beam.dir);
+
+    if (!inBounds(nr, nc, rows, cols)) continue;
+
+    visited.add(encodeCell(nr, nc));
+
+    if (grid[nr][nc] === '^') {
+      const dl: Direction = 'down-left';
+      const dr: Direction = 'down-right';
+      const sL = encodeState(nr, nc, dl);
+      const sR = encodeState(nr, nc, dr);
+      if (!seenStates.has(sL)) {
+        seenStates.add(sL);
+        beams.push({ row: nr, col: nc, dir: dl });
+      }
+      if (!seenStates.has(sR)) {
+        seenStates.add(sR);
+        beams.push({ row: nr, col: nc, dir: dr });
+      }
+    } else {
+      const s = encodeState(nr, nc, beam.dir);
+      if (!seenStates.has(s)) {
+        seenStates.add(s);
+        beams.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // Trace a beam from (r, c) in direction dir until it hits a splitter or exits.
+  // Returns the splitter position or null (if exits grid).
+  function traceToEnd(r: number, c: number, dir: Direction): [number, number] | null {
+    for (;;) {
+      const [nr, nc] = nextPos(r, c, dir);
+      if (!inBounds(nr, nc, rows, cols)) return null;
+      if (grid[nr][nc] === '^') return [nr, nc];
+      r = nr;
+      c = nc;
+    }
+  }
+
+  // Aggregate path counts by (row, col, direction) state to avoid
+  // exponential queue growth when multiple beams converge.
+  const dirIndex = (d: Direction): number =>
+    d === 'down' ? 0 : d === 'down-left' ? 1 : 2;
+  const encodeState = (r: number, c: number, d: Direction): number =>
+    (r * cols + c) * 3 + dirIndex(d);
+
+  let totalPaths = 0n;
+
+  // Accumulate path counts per state before processing
+  let current = new Map<number, [number, number, Direction, bigint]>();
+  const initState = encodeState(source[0], source[1], 'down');
+  current.set(initState, [source[0], source[1], 'down', 1n]);
+
+  while (current.size > 0) {
+    const next = new Map<number, [number, number, Direction, bigint]>();
+
+    const addToNext = (r: number, c: number, d: Direction, count: bigint) => {
+      const key = encodeState(r, c, d);
+      const existing = next.get(key);
+      if (existing) {
+        existing[3] += count;
+      } else {
+        next.set(key, [r, c, d, count]);
+      }
+    };
+
+    for (const [, [r, c, dir, pathCount]] of current) {
+      const target = traceToEnd(r, c, dir);
+      if (target === null) {
+        totalPaths += pathCount;
+      } else {
+        const [tr, tc] = target;
+        addToNext(tr, tc, 'down-left', pathCount);
+        addToNext(tr, tc, 'down-right', pathCount);
+      }
+    }
+
+    current = next;
+  }
+
+  return totalPaths;
+}
