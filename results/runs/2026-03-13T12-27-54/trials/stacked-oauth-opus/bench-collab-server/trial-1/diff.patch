+import express from 'express';
+import { createServer, type Server as HttpServer } from 'http';
+import { createDatabase } from './db.js';
+import { DocumentStore } from './documents.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './collaboration.js';
+import type Database from 'better-sqlite3';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db: Database.Database = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+  const app = express();
+  let server: HttpServer | null = null;
+
+  const router = createRouter(store);
+  app.use('/api', router);
+
+  const collaboration = new CollaborationManager(store);
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        server = createServer(app);
+        collaboration.attach(server);
+
+        server.listen(port ?? 0, () => {
+          const addr = server!.address();
+          const assignedPort = typeof addr === 'object' && addr ? addr.port : 0;
+          resolve(assignedPort);
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      collaboration.closeAll();
+
+      return new Promise((resolve, reject) => {
+        if (server) {
+          server.close((err) => {
+            db.close();
+            if (err) reject(err);
+            else resolve();
+          });
+          server = null;
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    },
+  };
+}
