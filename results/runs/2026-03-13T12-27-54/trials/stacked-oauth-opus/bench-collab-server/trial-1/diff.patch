+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp, type AppInstance } from './server.js';
+import { createInsert, createDelete, type Operation } from './ot.js';
+
+let app: AppInstance;
+let port: number;
+
+function wsUrl(docId: string): string {
+  return `ws://localhost:${port}/ws/documents/${docId}`;
+}
+
+interface WsConnection {
+  ws: WebSocket;
+  firstMessage: Promise<unknown>;
+}
+
+function connectWs(docId: string, wsPort?: number): Promise<WsConnection> {
+  const url = wsPort
+    ? `ws://localhost:${wsPort}/ws/documents/${docId}`
+    : wsUrl(docId);
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(url);
+    // Set up message listener BEFORE open fires to never miss the sync message
+    const firstMessage = new Promise<unknown>((res, rej) => {
+      const timeout = setTimeout(() => rej(new Error('Timeout waiting for first message')), 5000);
+      ws.once('message', (data) => {
+        clearTimeout(timeout);
+        res(JSON.parse(data.toString()));
+      });
+    });
+    ws.on('open', () => resolve({ ws, firstMessage }));
+    ws.on('error', reject);
+  });
+}
+
+function waitForMessage<T = unknown>(ws: WebSocket): Promise<T> {
+  return new Promise((resolve, reject) => {
+    const timeout = setTimeout(() => reject(new Error('Timeout waiting for message')), 5000);
+    ws.once('message', (data) => {
+      clearTimeout(timeout);
+      resolve(JSON.parse(data.toString()));
+    });
+  });
+}
+
+describe('REST API', () => {
+  beforeEach(async () => {
+    app = createApp(); // in-memory db
+    port = await app.start(0);
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  it('should create a document', async () => {
+    const res = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'Test Doc', content: 'Hello' })
+      .expect(201);
+
+    expect(res.body.title).toBe('Test Doc');
+    expect(res.body.content).toBe('Hello');
+    expect(res.body.id).toBeDefined();
+  });
+
+  it('should reject document creation without title', async () => {
+    await request(app.app)
+      .post('/api/documents')
+      .send({ content: 'Hello' })
+      .expect(400);
+  });
+
+  it('should list documents', async () => {
+    await request(app.app).post('/api/documents').send({ title: 'Doc 1' });
+    await request(app.app).post('/api/documents').send({ title: 'Doc 2' });
+
+    const res = await request(app.app).get('/api/documents').expect(200);
+    expect(res.body.length).toBe(2);
+  });
+
+  it('should get a document by id', async () => {
+    const created = await request(app.app)
+      .post('/api/documents')
+      .send({ title: 'Test' });
+
+    const res = await request(app.app)
+      .get(`/api/documents/${created.body.id}`)
+      .expect(200);
+
+    expect(res.body.title).toBe('Test');
+  });
+
