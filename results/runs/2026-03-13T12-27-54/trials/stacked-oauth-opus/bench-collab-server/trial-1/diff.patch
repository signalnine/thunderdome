index 0000000..6c9e54f
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,252 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server as HttpServer } from 'http';
+import type { DocumentStore } from './documents.js';
+import {
+  type Operation,
+  type ServerMessage,
+  apply,
+  transform,
+  validateOperation,
+  baseLength,
+} from './ot.js';
+import { randomUUID } from 'crypto';
+
+interface ClientConnection {
+  id: string;
+  ws: WebSocket;
+  docId: string;
+}
+
+interface DocumentSession {
+  docId: string;
+  /** Server version - increments with each applied operation */
+  version: number;
+  /** Current document content */
+  content: string;
+  /** History of operations applied, indexed by version (1-based) */
+  operations: Operation[];
+  /** Connected clients */
+  clients: Map<string, ClientConnection>;
+}
+
+export class CollaborationManager {
+  private wss: WebSocketServer | null = null;
+  private sessions: Map<string, DocumentSession> = new Map();
+  private store: DocumentStore;
+  private allClients: Set<WebSocket> = new Set();
+
+  constructor(store: DocumentStore) {
+    this.store = store;
+  }
+
+  attach(server: HttpServer): void {
+    this.wss = new WebSocketServer({ server });
+
+    this.wss.on('connection', (ws, req) => {
+      this.allClients.add(ws);
+
+      // Extract document ID from URL path: /ws/documents/:docId
+      const url = req.url || '';
+      const match = url.match(/\/ws\/documents\/([^/?]+)/);
+      if (!match) {
+        this.sendMessage(ws, { type: 'error', message: 'Invalid WebSocket URL. Expected /ws/documents/:docId' });
+        ws.close(1008, 'Invalid URL');
+        return;
+      }
+
+      const docId = match[1];
+      const doc = this.store.getById(docId);
+      if (!doc) {
+        this.sendMessage(ws, { type: 'error', message: 'Document not found' });
+        ws.close(1008, 'Document not found');
+        return;
+      }
+
+      const clientId = randomUUID();
+      const client: ClientConnection = { id: clientId, ws, docId };
+
+      // Get or create session
+      let session = this.sessions.get(docId);
+      if (!session) {
+        const currentVersion = this.store.getCurrentVersion(docId);
+        session = {
+          docId,
+          version: currentVersion,
+          content: doc.content,
+          operations: [],
+          clients: new Map(),
+        };
+        this.sessions.set(docId, session);
+      }
+
+      session.clients.set(clientId, client);
+
+      // Send sync message with current state
+      this.sendMessage(ws, {
+        type: 'sync',
+        docId,
+        content: session.content,
+        version: session.version,
+      });
+
+      ws.on('message', (data) => {
+        try {
+          const message = JSON.parse(data.toString());
+          this.handleMessage(client, message);
+        } catch (err) {
+          this.sendMessage(ws, {
+            type: 'error',
+            message: `Invalid message: ${err instanceof Error ? err.message : 'parse error'}`,
+          });
+        }
+      });
+
+      ws.on('close', () => {
+        this.allClients.delete(ws);
+        const sess = this.sessions.get(docId);
+        if (sess) {
+          sess.clients.delete(clientId);
+          if (sess.clients.size === 0) {
+            // Persist and clean up session when all clients disconnect
+            this.store.updateContent(sess.docId, sess.content);
+            this.sessions.delete(docId);
+          }
+        }
+      });
+
+      ws.on('error', () => {
+        // Handled by close event
+      });
+    });
+  }
+
+  private handleMessage(client: ClientConnection, message: unknown): void {
+    if (!message || typeof message !== 'object') {
+      this.sendMessage(client.ws, { type: 'error', message: 'Invalid message format' });
+      return;
+    }
+
+    const msg = message as Record<string, unknown>;
+
+    if (msg.type !== 'operation') {
+      this.sendMessage(client.ws, { type: 'error', message: `Unknown message type: ${msg.type}` });
+      return;
+    }
+
+    const { operation, version } = msg as { operation: unknown; version: unknown };
+
+    if (typeof version !== 'number' || !Number.isInteger(version) || version < 0) {
+      this.sendMessage(client.ws, { type: 'error', message: 'Invalid version number' });
+      return;
+    }
+
+    if (!validateOperation(operation)) {
+      this.sendMessage(client.ws, { type: 'error', message: 'Invalid operation format' });
+      return;
+    }
+
+    const session = this.sessions.get(client.docId);
+    if (!session) {
+      this.sendMessage(client.ws, { type: 'error', message: 'Session not found' });
+      return;
+    }
+
+    if (version > session.version) {
+      this.sendMessage(client.ws, { type: 'error', message: 'Version is ahead of server' });
+      return;
+    }
+
+    try {
+      // Transform the operation against all operations that happened since the client's version
+      let op = operation as Operation;
+      const startIdx = version - (session.version - session.operations.length);
+
+      if (startIdx < 0) {
+        this.sendMessage(client.ws, { type: 'error', message: 'Version too old, please resync' });
+        return;
+      }
+
+      for (let i = startIdx; i < session.operations.length; i++) {
+        const serverOp = session.operations[i];
+        // Check base lengths match before transform
+        if (baseLength(op) !== baseLength(serverOp)) {
+          // The op might be based on a different doc length - we need to
+          // transform it step by step
+          this.sendMessage(client.ws, { type: 'error', message: 'Operation base length mismatch during transform' });
+          return;
+        }
+        const [transformedClient] = transform(op, serverOp);
+        op = transformedClient;
+      }
+
+      // Validate the operation against current document
+      if (baseLength(op) !== session.content.length) {
+        this.sendMessage(client.ws, {
+          type: 'error',
+          message: `Operation base length (${baseLength(op)}) does not match document length (${session.content.length})`,
+        });
+        return;
+      }
+
+      // Apply the transformed operation
+      const newContent = apply(session.content, op);
+      session.content = newContent;
+      session.version++;
+      session.operations.push(op);
+
+      // Persist periodically (every operation for safety)
+      this.store.updateContent(session.docId, newContent, JSON.stringify(op));
+
+      // Ack the sender
+      this.sendMessage(client.ws, { type: 'ack', version: session.version });
+
+      // Broadcast to other clients
+      for (const [cid, c] of session.clients) {
+        if (cid !== client.id && c.ws.readyState === WebSocket.OPEN) {
+          this.sendMessage(c.ws, {
+            type: 'operation',
+            docId: session.docId,
+            clientId: client.id,
+            version: session.version,
+            operation: op,
+          });
+        }
+      }
+    } catch (err) {
+      this.sendMessage(client.ws, {
+        type: 'error',
+        message: `Failed to apply operation: ${err instanceof Error ? err.message : 'unknown error'}`,
+      });
+    }
+  }
+
+  private sendMessage(ws: WebSocket, message: ServerMessage): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(message));
+    }
+  }
+
+  closeAll(): void {
+    // Persist all active sessions
+    for (const session of this.sessions.values()) {
+      this.store.updateContent(session.docId, session.content);
+      for (const client of session.clients.values()) {
+        client.ws.close(1001, 'Server shutting down');
+      }
+    }
+    this.sessions.clear();
+
+    // Close any remaining connections
+    for (const ws of this.allClients) {
+      if (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING) {
+        ws.close(1001, 'Server shutting down');
+      }
+    }
+    this.allClients.clear();
+
+    if (this.wss) {
+      this.wss.close();
+      this.wss = null;
+    }
+  }
+}
