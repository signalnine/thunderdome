diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..bc0cc7a
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,215 @@
+import { describe, it, expect } from 'vitest';
+import {
+  apply,
+  transform,
+  compose,
+  normalize,
+  validateOperation,
+  createInsert,
+  createDelete,
+  baseLength,
+  targetLength,
+  type Operation,
+} from './ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply an insert operation', () => {
+      expect(apply('hello', [5, ' world'])).toBe('hello world');
+    });
+
+    it('should apply an insert at the beginning', () => {
+      expect(apply('world', ['hello ', 5])).toBe('hello world');
+    });
+
+    it('should apply a delete operation', () => {
+      expect(apply('hello world', [5, -6])).toBe('hello');
+    });
+
+    it('should apply a combined insert and delete', () => {
+      expect(apply('hello world', [5, -6, ' there'])).toBe('hello there');
+    });
+
+    it('should handle retain-only (identity)', () => {
+      expect(apply('hello', [5])).toBe('hello');
+    });
+
+    it('should handle empty document insert', () => {
+      expect(apply('', ['hello'])).toBe('hello');
+    });
+
+    it('should throw on mismatched base length', () => {
+      expect(() => apply('hello', [10])).toThrow();
+    });
+  });
+
+  describe('baseLength and targetLength', () => {
+    it('should calculate base length correctly', () => {
+      expect(baseLength([3, 'abc', -2, 5])).toBe(10); // 3 retain + 2 delete + 5 retain
+    });
+
+    it('should calculate target length correctly', () => {
+      expect(targetLength([3, 'abc', -2, 5])).toBe(11); // 3 retain + 3 insert + 5 retain
+    });
+  });
+
+  describe('normalize', () => {
+    it('should merge adjacent retains', () => {
+      expect(normalize([3, 2])).toEqual([5]);
+    });
+
+    it('should merge adjacent inserts', () => {
+      expect(normalize(['hello', ' world'])).toEqual(['hello world']);
+    });
+
+    it('should merge adjacent deletes', () => {
+      expect(normalize([-3, -2])).toEqual([-5]);
+    });
+
+    it('should not merge different types', () => {
+      expect(normalize([3, 'hi', -2])).toEqual([3, 'hi', -2]);
+    });
+
+    it('should remove zero retains', () => {
+      expect(normalize([0, 3, 0])).toEqual([3]);
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should accept valid operations', () => {
+      expect(validateOperation([3, 'hello', -2])).toBe(true);
+    });
+
+    it('should reject non-arrays', () => {
+      expect(validateOperation('hello')).toBe(false);
+      expect(validateOperation(42)).toBe(false);
+    });
+
+    it('should reject zero components', () => {
+      expect(validateOperation([0])).toBe(false);
+    });
+
+    it('should reject empty string components', () => {
+      expect(validateOperation([''])).toBe(false);
+    });
+
+    it('should reject non-integer numbers', () => {
+      expect(validateOperation([1.5])).toBe(false);
+    });
+  });
+
+  describe('transform', () => {
+    it('should handle two inserts at different positions', () => {
+      const doc = 'hello';
+      const op1: Operation = [5, ' world'];   // insert " world" at end
+      const op2: Operation = ['oh ', 5];      // insert "oh " at beginning
+      const [op1p, op2p] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+    });
+
+    it('should handle two inserts at same position (op1 wins)', () => {
+      const doc = 'hello';
+      const op1: Operation = ['A', 5];  // insert A at beginning
+      const op2: Operation = ['B', 5];  // insert B at beginning
+      const [op1p, op2p] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+      // Both inserts must be present
+      expect(result1).toContain('A');
+      expect(result1).toContain('B');
+    });
+
+    it('should handle insert vs delete', () => {
+      const doc = 'abcde';
+      const op1: Operation = [2, 'X', 3]; // insert X at position 2
+      const op2: Operation = [1, -2, 2];  // delete 2 chars at position 1
+      const [op1p, op2p] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+    });
+
+    it('should handle two deletes of same region', () => {
+      const doc = 'abcde';
+      const op1: Operation = [1, -3, 1]; // delete "bcd"
+      const op2: Operation = [1, -3, 1]; // delete "bcd"
+      const [op1p, op2p] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+      expect(result1).toBe('ae');
+    });
+
+    it('should handle identity transform', () => {
+      const doc = 'hello';
+      const op1: Operation = [5]; // retain all
+      const op2: Operation = [5]; // retain all
+      const [op1p, op2p] = transform(op1, op2);
+
+      expect(apply(apply(doc, op1), op2p)).toBe('hello');
+      expect(apply(apply(doc, op2), op1p)).toBe('hello');
+    });
+
+    it('should preserve convergence for complex concurrent edits', () => {
+      const doc = 'the quick brown fox';
+      // Client 1: insert "very " before "quick"
+      const op1: Operation = [4, 'very ', 15];
+      // Client 2: delete "brown " (positions 10-15)
+      const op2: Operation = [10, -6, 3];
+      const [op1p, op2p] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two consecutive operations', () => {
+      const doc = 'hello';
+      const op1: Operation = [5, ' world'];   // "hello world"
+      const op2: Operation = ['Hey! ', 11];    // "Hey! hello world"
+      const composed = compose(op1, op2);
+
+      expect(apply(doc, composed)).toBe(apply(apply(doc, op1), op2));
+    });
+
+    it('should compose insert then delete', () => {
+      const doc = 'hello';
+      const op1: Operation = [5, ' world']; // "hello world"
+      const op2: Operation = [5, -6];       // "hello"
+      const composed = compose(op1, op2);
+
+      expect(apply(doc, composed)).toBe('hello');
+    });
+  });
+
+  describe('createInsert and createDelete helpers', () => {
+    it('should create an insert at the beginning', () => {
+      const op = createInsert(0, 'hello ', 5);
+      expect(apply('world', op)).toBe('hello world');
+    });
+
+    it('should create an insert in the middle', () => {
+      const op = createInsert(5, ' beautiful', 11);
+      expect(apply('hello world', op)).toBe('hello beautiful world');
+    });
+
+    it('should create a delete at the beginning', () => {
+      const op = createDelete(0, 6, 11);
+      expect(apply('hello world', op)).toBe('world');
+    });
+
+    it('should create a delete at the end', () => {
+      const op = createDelete(5, 6, 11);
+      expect(apply('hello world', op)).toBe('hello');
+    });
+  });
+});
