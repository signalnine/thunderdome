new file mode 100644
index 0000000..b2cf7fc
--- /dev/null
+++ b/src/documents.ts
@@ -0,0 +1,106 @@
+import type Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+  }
+
+  create(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    this.db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    ).run(id, title, content);
+
+    // Create initial version
+    this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    ).run(id, 1, content, null);
+
+    return this.getById(id)!;
+  }
+
+  getById(id: string): Document | undefined {
+    return this.db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document | undefined;
+  }
+
+  list(): Document[] {
+    return this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as Document[];
+  }
+
+  update(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getById(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    this.db.prepare(
+      "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(title, content, id);
+
+    return this.getById(id);
+  }
+
+  updateContent(id: string, content: string, operation?: string): number {
+    this.db.prepare(
+      "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(content, id);
+
+    // Get current max version
+    const row = this.db.prepare(
+      'SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?'
+    ).get(id) as { max_version: number };
+
+    const newVersion = row.max_version + 1;
+
+    this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    ).run(id, newVersion, content, operation || null);
+
+    return newVersion;
+  }
+
+  delete(id: string): boolean {
+    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(docId: string): Version[] {
+    return this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    ).all(docId) as Version[];
+  }
+
+  getVersion(docId: string, version: number): Version | undefined {
+    return this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? AND version = ?'
+    ).get(docId, version) as Version | undefined;
+  }
+
+  getCurrentVersion(docId: string): number {
+    const row = this.db.prepare(
+      'SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?'
+    ).get(docId) as { max_version: number };
+    return row.max_version;
+  }
+}
