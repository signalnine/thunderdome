--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,433 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are represented as arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string at the current position
+ * - number < 0: delete |N| characters
+ *
+ * The "base length" of an operation is the total length of the document it
+ * expects as input (sum of retains + sum of |deletes|). The "target length"
+ * is the document length after applying the operation (sum of retains +
+ * sum of insert lengths).
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  clientId: string;
+  version: number; // the version this op was generated against
+  operation: Operation;
+}
+
+export interface SyncMessage {
+  type: 'sync';
+  docId: string;
+  content: string;
+  version: number;
+}
+
+export interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export type ServerMessage = SyncMessage | AckMessage | ErrorMessage | (OperationMessage & { type: 'operation' });
+
+export type ClientMessage = OperationMessage;
+
+/** Calculate the base length (input document length) of an operation. */
+export function baseLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      else len += Math.abs(c);   // delete
+    }
+    // inserts don't consume input characters
+  }
+  return len;
+}
+
+/** Calculate the target length (output document length) of an operation. */
+export function targetLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      // deletes don't produce output characters
+    } else {
+      len += c.length;           // insert
+    }
+  }
+  return len;
+}
+
+/** Normalize an operation by merging adjacent same-type components and removing no-ops. */
+export function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (c === 0 || c === '') continue;
+    const last = result.length > 0 ? result[result.length - 1] : undefined;
+    if (typeof c === 'number' && typeof last === 'number') {
+      // Both are numbers (retain or delete)
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = (last as number) + c;
+        continue;
+      }
+    } else if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+      continue;
+    }
+    result.push(c);
+  }
+  // Remove trailing retain (it's a no-op at the end)
+  if (result.length > 0 && typeof result[result.length - 1] === 'number' && (result[result.length - 1] as number) > 0) {
+    // Keep trailing retains - they're needed for correctness
+  }
+  return result;
+}
+
+/** Apply an operation to a document string, returning the new document. */
+export function apply(doc: string, op: Operation): string {
+  const bLen = baseLength(op);
+  if (bLen !== doc.length) {
+    throw new Error(`Operation base length (${bLen}) does not match document length (${doc.length})`);
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        // retain
+        if (pos + c > doc.length) {
+          throw new Error(`Retain past end of document at position ${pos}, retain ${c}, doc length ${doc.length}`);
+        }
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        const delCount = Math.abs(c);
+        if (pos + delCount > doc.length) {
+          throw new Error(`Delete past end of document`);
+        }
+        pos += delCount;
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Compose two consecutive operations into a single operation.
+ * compose(a, b) produces an operation equivalent to applying a then b.
+ */
+export function compose(op1: Operation, op2: Operation): Operation {
+  if (targetLength(op1) !== baseLength(op2)) {
+    throw new Error('Compose: op1 target length must equal op2 base length');
+  }
+
+  const result: Operation = [];
+  let i1 = 0, i2 = 0;
+  let c1: OpComponent | undefined = op1[i1];
+  let c2: OpComponent | undefined = op2[i2];
+
+  const push = (c: OpComponent) => {
+    if (c === 0 || c === '') return;
+    const last = result.length > 0 ? result[result.length - 1] : undefined;
+    if (typeof c === 'number' && typeof last === 'number' && ((c > 0 && last > 0) || (c < 0 && last < 0))) {
+      result[result.length - 1] = (last as number) + c;
+    } else if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+    } else {
+      result.push(c);
+    }
+  };
+
+  while (c1 !== undefined || c2 !== undefined) {
+    // Delete from op1
+    if (typeof c1 === 'number' && c1 < 0) {
+      push(c1);
+      i1++;
+      c1 = op1[i1];
+      continue;
+    }
+    // Insert from op2
+    if (typeof c2 === 'string') {
+      push(c2);
+      i2++;
+      c2 = op2[i2];
+      continue;
+    }
+
+    if (c1 === undefined || c2 === undefined) {
+      throw new Error('Compose: operations are incompatible');
+    }
+
+    // Both retain
+    if (typeof c1 === 'number' && c1 > 0 && typeof c2 === 'number' && c2 > 0) {
+      if (c1 > c2) {
+        push(c2);
+        c1 = c1 - c2;
+        i2++;
+        c2 = op2[i2];
+      } else if (c1 < c2) {
+        push(c1);
+        c2 = c2 - c1;
+        i1++;
+        c1 = op1[i1];
+      } else {
+        push(c1);
+        i1++; i2++;
+        c1 = op1[i1]; c2 = op2[i2];
+      }
+    }
+    // Insert from op1, retain from op2
+    else if (typeof c1 === 'string' && typeof c2 === 'number' && c2 > 0) {
+      if (c1.length > c2) {
+        push(c1.slice(0, c2));
+        c1 = c1.slice(c2);
+        i2++;
+        c2 = op2[i2];
+      } else if (c1.length < c2) {
+        push(c1);
+        c2 = c2 - c1.length;
+        i1++;
+        c1 = op1[i1];
+      } else {
+        push(c1);
+        i1++; i2++;
+        c1 = op1[i1]; c2 = op2[i2];
+      }
+    }
+    // Insert from op1, delete from op2
+    else if (typeof c1 === 'string' && typeof c2 === 'number' && c2 < 0) {
+      const delCount = Math.abs(c2);
+      if (c1.length > delCount) {
+        c1 = c1.slice(delCount);
+        i2++;
+        c2 = op2[i2];
+      } else if (c1.length < delCount) {
+        c2 = -(delCount - c1.length);
+        i1++;
+        c1 = op1[i1];
+      } else {
+        i1++; i2++;
+        c1 = op1[i1]; c2 = op2[i2];
+      }
+    }
+    // Retain from op1, delete from op2
+    else if (typeof c1 === 'number' && c1 > 0 && typeof c2 === 'number' && c2 < 0) {
+      const delCount = Math.abs(c2);
+      if (c1 > delCount) {
+        push(c2);
+        c1 = c1 - delCount;
+        i2++;
+        c2 = op2[i2];
+      } else if (c1 < delCount) {
+        push(-c1);
+        c2 = -(delCount - c1);
+        i1++;
+        c1 = op1[i1];
+      } else {
+        push(c2);
+        i1++; i2++;
+        c1 = op1[i1]; c2 = op2[i2];
+      }
+    }
+    else {
+      throw new Error(`Compose: unexpected component types: ${JSON.stringify(c1)}, ${JSON.stringify(c2)}`);
+    }
+  }
+
+  return normalize(result);
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in either order.
+ *
+ * Given operations A and B that were both generated against the same document:
+ *   transform(A, B) returns [A', B']
+ *   such that apply(apply(doc, A), B') === apply(apply(doc, B), A')
+ *
+ * This is the core of OT conflict resolution.
+ */
+export function transform(op1: Operation, op2: Operation): [Operation, Operation] {
+  if (baseLength(op1) !== baseLength(op2)) {
+    throw new Error(`Transform: operations have different base lengths (${baseLength(op1)} vs ${baseLength(op2)})`);
+  }
+
+  const op1prime: Operation = [];
+  const op2prime: Operation = [];
+  let i1 = 0, i2 = 0;
+  let c1: OpComponent | undefined = op1[i1];
+  let c2: OpComponent | undefined = op2[i2];
+
+  const push1 = (c: OpComponent) => {
+    if (c === 0 || c === '') return;
+    const last = op1prime.length > 0 ? op1prime[op1prime.length - 1] : undefined;
+    if (typeof c === 'number' && typeof last === 'number' && ((c > 0 && last > 0) || (c < 0 && last < 0))) {
+      op1prime[op1prime.length - 1] = (last as number) + c;
+    } else if (typeof c === 'string' && typeof last === 'string') {
+      op1prime[op1prime.length - 1] = last + c;
+    } else {
+      op1prime.push(c);
+    }
+  };
+
+  const push2 = (c: OpComponent) => {
+    if (c === 0 || c === '') return;
+    const last = op2prime.length > 0 ? op2prime[op2prime.length - 1] : undefined;
+    if (typeof c === 'number' && typeof last === 'number' && ((c > 0 && last > 0) || (c < 0 && last < 0))) {
+      op2prime[op2prime.length - 1] = (last as number) + c;
+    } else if (typeof c === 'string' && typeof last === 'string') {
+      op2prime[op2prime.length - 1] = last + c;
+    } else {
+      op2prime.push(c);
+    }
+  };
+
+  while (c1 !== undefined || c2 !== undefined) {
+    // Insert from op1 (op1 has priority for insert ordering)
+    if (typeof c1 === 'string') {
+      push1(c1);
+      push2(c1.length); // op2' must retain over op1's insert
+      i1++;
+      c1 = op1[i1];
+      continue;
+    }
+    // Insert from op2
+    if (typeof c2 === 'string') {
+      push1(c2.length); // op1' must retain over op2's insert
+      push2(c2);
+      i2++;
+      c2 = op2[i2];
+      continue;
+    }
+
+    if (c1 === undefined || c2 === undefined) {
+      throw new Error('Transform: operations are incompatible');
+    }
+
+    // Both retain
+    if (typeof c1 === 'number' && c1 > 0 && typeof c2 === 'number' && c2 > 0) {
+      const min = Math.min(c1, c2);
+      push1(min);
+      push2(min);
+      if (c1 > c2) {
+        c1 = c1 - c2;
+        i2++; c2 = op2[i2];
+      } else if (c1 < c2) {
+        c2 = c2 - c1;
+        i1++; c1 = op1[i1];
+      } else {
+        i1++; i2++;
+        c1 = op1[i1]; c2 = op2[i2];
+      }
+    }
+    // op1 deletes, op2 deletes
+    else if (typeof c1 === 'number' && c1 < 0 && typeof c2 === 'number' && c2 < 0) {
+      const d1 = Math.abs(c1), d2 = Math.abs(c2);
+      if (d1 > d2) {
+        c1 = -(d1 - d2);
+        i2++; c2 = op2[i2];
+      } else if (d1 < d2) {
+        c2 = -(d2 - d1);
+        i1++; c1 = op1[i1];
+      } else {
+        i1++; i2++;
+        c1 = op1[i1]; c2 = op2[i2];
+      }
+    }
+    // op1 deletes, op2 retains
+    else if (typeof c1 === 'number' && c1 < 0 && typeof c2 === 'number' && c2 > 0) {
+      const d1 = Math.abs(c1);
+      if (d1 > c2) {
+        push1(-c2);
+        c1 = -(d1 - c2);
+        i2++; c2 = op2[i2];
+      } else if (d1 < c2) {
+        push1(c1);
+        c2 = c2 - d1;
+        i1++; c1 = op1[i1];
+      } else {
+        push1(c1);
+        i1++; i2++;
+        c1 = op1[i1]; c2 = op2[i2];
+      }
+    }
+    // op1 retains, op2 deletes
+    else if (typeof c1 === 'number' && c1 > 0 && typeof c2 === 'number' && c2 < 0) {
+      const d2 = Math.abs(c2);
+      if (c1 > d2) {
+        push2(c2);
+        c1 = c1 - d2;
+        i2++; c2 = op2[i2];
+      } else if (c1 < d2) {
+        push2(-c1);
+        c2 = -(d2 - c1);
+        i1++; c1 = op1[i1];
+      } else {
+        push2(c2);
+        i1++; i2++;
+        c1 = op1[i1]; c2 = op2[i2];
+      }
+    }
+    else {
+      throw new Error(`Transform: unexpected component types: ${JSON.stringify(c1)}, ${JSON.stringify(c2)}`);
+    }
+  }
+
+  return [normalize(op1prime), normalize(op2prime)];
+}
+
+/** Validate that an operation is well-formed. */
+export function validateOperation(op: unknown): op is Operation {
+  if (!Array.isArray(op)) return false;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c) || c === 0) return false;
+    } else if (typeof c === 'string') {
+      if (c.length === 0) return false;
+    } else {
+      return false;
+    }
+  }
+  return true;
+}
+
+/**
+ * Create an insert operation at a given position in a document of given length.
+ */
+export function createInsert(pos: number, text: string, docLength: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(text);
+  if (docLength - pos > 0) op.push(docLength - pos);
+  return op;
+}
+
+/**
+ * Create a delete operation at a given position in a document of given length.
+ */
+export function createDelete(pos: number, count: number, docLength: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(-count);
+  if (docLength - pos - count > 0) op.push(docLength - pos - count);
+  return op;
+}
