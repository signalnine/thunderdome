+import { randomUUID } from 'node:crypto';
+import type {
+  Task,
+  TaskOptions,
+  ProgressListener,
+  Schedule,
+  MiddlewareFunction,
+  HandlerFunction,
+  ShutdownOptions,
+  ShutdownSummary,
+} from './types.js';
+
+const DEFAULT_QUEUE = 'default';
+const DEFAULT_PRIORITY = 5;
+const DEFAULT_MAX_RETRIES = 3;
+const DEFAULT_BACKOFF_DELAY = 1000;
+
+interface QueueState {
+  tasks: Map<string, Task>;
+  deadLetterQueue: Task[];
+  concurrencyLimit: number | null;
+  middlewares: MiddlewareFunction[];
+  handler: HandlerFunction | null;
+}
+
+export class TaskQueue {
+  private queues: Map<string, QueueState> = new Map();
+  private allTasks: Map<string, Task> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private shutdownState: {
+    initiated: boolean;
+    promise: Promise<ShutdownSummary> | null;
+  } = { initiated: false, promise: null };
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // --- Phase 1: Basic FIFO Queue ---
+
+  addTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.shutdownState.initiated) {
+      throw new Error('Cannot add tasks: queue system is shutting down');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? DEFAULT_PRIORITY;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    const now = new Date();
+    let availableAt = now;
+
+    if (options.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options.delay !== undefined && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    }
+
+    // Validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.allTasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: 'pending',
+      queue: queueName,
+      priority,
+      createdAt: now,
+      availableAt,
+      attempt: 0,
+      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,
+      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,
+      failureCount: 0,
+      dependencies,
+      progress: 0,
+    };
+
+    // Check circular dependencies
+    if (dependencies.length > 0) {
+      this.detectCircularDependencies(task.id, dependencies);
+    }
+
+    const queue = this.getOrCreateQueue(queueName);
+    queue.tasks.set(task.id, task);
+    this.allTasks.set(task.id, task);
+
+    return task;
+  }
+
+  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+
+    // Check concurrency limit
+    if (queue.concurrencyLimit !== null) {
+      const activeCount = this.getActiveCount(queueName);
+      if (activeCount >= queue.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+    const candidates: Task[] = [];
+
+    for (const task of queue.tasks.values()) {
+      if (task.status !== 'pending') continue;
+      if (task.availableAt > now) continue;
+      if (!this.areDependenciesMet(task)) continue;
+      candidates.push(task);
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Sort by: priority (ascending = higher priority first), then availableAt, then createdAt (FIFO)
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      if (a.availableAt.getTime() !== b.availableAt.getTime()) {
+        return a.availableAt.getTime() - b.availableAt.getTime();
+      }
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempt++;
+    return task;
+  }
+
+  getWaitingCount(queueName: string = DEFAULT_QUEUE): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+
+    let count = 0;
+    for (const task of queue.tasks.values()) {
+      if (task.status === 'pending') count++;
+    }
+    return count;
+  }
+
+  // --- Phase 2: Named Queues ---
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // --- Phase 5: Retry with Backoff ---
+
+  completeTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in '${task.status}' state`);
+    }
+    task.status = 'completed';
+
+    // Clean up progress listeners
+    this.progressListeners.delete(taskId);
+  }
+
+  failTask(taskId: string, error?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in '${task.status}' state`);
+    }
+
+    task.error = error;
+    task.failureCount++;
+
+    // maxRetries is the number of retries allowed after the initial attempt.
+    // attempt tracks which try we're on (1-based, incremented in getNextTask).
+    // Retry when attempt <= maxRetries (i.e., we haven't used all retries yet).
+    // e.g., maxRetries=3: retry on attempts 1,2,3; fail permanently on attempt 4.
+    if (task.attempt <= task.maxRetries) {
+      // Re-add with backoff delay: baseDelay * 2^(attempt - 1)
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.availableAt = new Date(Date.now() + delay);
+      task.status = 'pending';
+      task.progress = 0;
+      task.progressMessage = undefined;
+    } else {
+      // All retries exhausted
+      task.status = 'failed';
+
+      // Clean up progress listeners
+      this.progressListeners.delete(taskId);
+
+      // Move to dead letter queue
+      const queue = this.queues.get(task.queue);
+      if (queue) {
+        queue.tasks.delete(task.id);
+        queue.deadLetterQueue.push(task);
+      }
+    }
+  }
+
+  // --- Phase 6: Dead Letter Queue ---
+
+  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {
+    const queue = this.queues.get(queueName);
+    if (!queue) return [];
+    return [...queue.deadLetterQueue];
+  }
+
+  redriveTask(taskId: string): Task {
+    for (const queue of this.queues.values()) {
+      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);
+      if (index !== -1) {
+        const task = queue.deadLetterQueue[index];
+        queue.deadLetterQueue.splice(index, 1);
+
+        // Reset task for fresh retries
+        task.status = 'pending';
+        task.attempt = 0;
+        task.failureCount = 0;
+        task.error = undefined;
+        task.availableAt = new Date();
+        task.progress = 0;
+        task.progressMessage = undefined;
+
+        // Re-add to its original queue
+        queue.tasks.set(task.id, task);
+        return task;
+      }
+    }
+    throw new Error(`Task not found in any dead letter queue: ${taskId}`);
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    const queue = this.queues.get(queueName);
+    if (queue) {
+      for (const task of queue.deadLetterQueue) {
+        this.allTasks.delete(task.id);
+      }
+      queue.deadLetterQueue = [];
+    }
+  }
+
+  // --- Phase 7: Task Dependencies ---
+
+  getTaskDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const resolved: string[] = [];
+    const pending: string[] = [];
+
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (dep && dep.status === 'completed') {
+        resolved.push(depId);
+      } else {
+        pending.push(depId);
+      }
+    }
+
+    return { dependencies: [...task.dependencies], resolved, pending };
+  }
+
+  // --- Phase 8: Concurrency Control ---
+
+  setConcurrencyLimit(queueName: string, limit: number | null): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.concurrencyLimit = limit;
+  }
+
+  getConcurrencyLimit(queueName: string = DEFAULT_QUEUE): number | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    return queue.concurrencyLimit;
+  }
+
+  getActiveCount(queueName: string = DEFAULT_QUEUE): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+
+    let count = 0;
+    for (const task of queue.tasks.values()) {
+      if (task.status === 'processing') count++;
+    }
+    return count;
+  }
+
+  // --- Phase 9: Progress and Cancellation ---
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot update progress for task in '${task.status}' state`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  getTaskProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+        if (listeners.size === 0) {
+          this.progressListeners.delete(taskId);
+        }
+      }
+    };
+  }
+
+  cancelTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in '${task.status}' state`);
+    }
+
+    task.status = 'cancelled';
+
+    // Remove from queue
+    const queue = this.queues.get(task.queue);
+    if (queue) {
+      queue.tasks.delete(task.id);
+    }
+
+    // Clean up progress listeners
+    this.progressListeners.delete(taskId);
+  }
+
+  // --- Phase 10: Recurring Tasks ---
+
+  addSchedule(
+    cronExpression: string,
+    queueName: string,
+    payload: unknown,
+    taskOptions?: Omit<TaskOptions, 'queue'>
+  ): Schedule {
+    this.validateCronExpression(cronExpression);
+
+    const schedule: Schedule = {
+      id: randomUUID(),
+      cronExpression,
+      queue: queueName,
+      payload,
+      taskOptions,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule not found: ${scheduleId}`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now: Date = new Date()): Task[] {
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRunSchedule(schedule, now)) {
+        const task = this.addTask(schedule.payload, {
+          ...schedule.taskOptions,
+          queue: schedule.queue,
+        });
+        created.push(task);
+        schedule.lastRun = now;
+      }
+    }
+
+    return created;
+  }
+
+  // --- Phase 11: Middleware ---
+
+  use(queueName: string, middleware: MiddlewareFunction): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.middlewares.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFunction): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.handler = handler;
+  }
+
+  async processTask(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {
+    const task = this.getNextTask(queueName);
+    if (!task) return null;
+
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+
+    const middlewares = [...queue.middlewares];
+    const handler = queue.handler;
+
+    try {
+      const handlerReached = await this.runMiddlewarePipeline(task, middlewares, handler);
+      if (task.status === 'processing' && handlerReached) {
+        this.completeTask(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.failTask(task.id, err instanceof Error ? err.message : String(err));
+      }
+    }
+
+    return task;
+  }
+
+  // --- Phase 12: Graceful Shutdown ---
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownSummary> {
+    if (this.shutdownState.promise) {
+      return this.shutdownState.promise;
+    }
+
+    this.shutdownState.initiated = true;
+    this.shutdownState.promise = this.performShutdown(options);
+    return this.shutdownState.promise;
+  }
+
+  isShuttingDown(): boolean {
+    return this.shutdownState.initiated;
+  }
+
+  // --- Task Lookup ---
+
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  // --- Private Helpers ---
+
+  private getOrCreateQueue(name: string): QueueState {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, {
+        tasks: new Map(),
+        deadLetterQueue: [],
+        concurrencyLimit: null,
+        middlewares: [],
+        handler: null,
+      });
+    }
+    return this.queues.get(name)!;
+  }
+
+  private areDependenciesMet(task: Task): boolean {
+    if (task.dependencies.length === 0) return true;
+
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (!dep || dep.status !== 'completed') {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  private detectCircularDependencies(newTaskId: string, dependencies: string[]): void {
+    // Check if adding this new task with these dependencies would create a cycle.
+    // Since the new task isn't in allTasks yet, a cycle would mean one of the dependencies
+    // transitively depends on the new task. But since the new task doesn't exist yet,
+    // no existing task can reference it as a dependency. Therefore true circular
+    // dependencies are structurally impossible with our create-only API.
+    //
+    // However, we still validate to satisfy the requirement and future-proof the code.
+    // We check that the dependency graph among existing tasks (including transitive deps
+    // of our direct deps) doesn't contain a cycle that would include the new task.
+    // In practice, this means verifying that none of the dependencies can be reached
+    // from each other through the dependency chain (which would have been caught earlier).
+
+    // Validate no self-dependency
+    for (const depId of dependencies) {
+      if (depId === newTaskId) {
+        throw new Error(`Circular dependency detected: task ${newTaskId} depends on itself`);
+      }
+    }
+
+    // Check that following dependencies from any dep doesn't lead back to any other dep
+    // in a way that would create issues. Since each task was validated at creation time,
+    // the existing graph is acyclic. Adding the new task with these deps maintains acyclicity
+    // because no existing task can depend on the new task (it doesn't exist yet).
+    // This check is a safeguard.
+    const visited = new Set<string>();
+    const stack = [...dependencies];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === newTaskId) {
+        throw new Error(`Circular dependency detected involving task ${newTaskId}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const task = this.allTasks.get(current);
+      if (task) {
+        for (const depId of task.dependencies) {
+          if (!visited.has(depId)) {
+            stack.push(depId);
+          }
+        }
+      }
+    }
+  }
+
+  private validateCronExpression(expr: string): void {
+    const parts = expr.split(' ');
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expr}. Must have 5 fields.`);
+    }
+
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Check supported patterns
+    const everyNMatch = minute.match(/^\*\/(\d+)$/);
+    const isEveryNMinutes = everyNMatch !== null && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';
+    const isEveryHour = minute === '0' && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';
+    const isEveryDay = minute === '0' && hour === '0' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';
+
+    if (!isEveryNMinutes && !isEveryHour && !isEveryDay) {
+      throw new Error(`Unsupported cron expression: ${expr}`);
+    }
+
+    // Validate */N has N >= 1
+    if (isEveryNMinutes && everyNMatch) {
+      const n = parseInt(everyNMatch[1], 10);
+      if (n < 1) {
+        throw new Error(`Invalid cron interval: ${n}. Must be at least 1.`);
+      }
+    }
+  }
+
+  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {
+    const parts = schedule.cronExpression.split(' ');
+    const [minutePart, hourPart] = parts;
+
+    if (minutePart.startsWith('*/')) {
+      // Every N minutes
+      const n = parseInt(minutePart.slice(2), 10);
+      const currentMinute = now.getMinutes();
+      if (currentMinute % n !== 0) return false;
+
+      // Check if we already ran this slot
+      if (schedule.lastRun) {
+        const lastMinuteSlot = Math.floor(schedule.lastRun.getTime() / (n * 60000));
+        const currentMinuteSlot = Math.floor(now.getTime() / (n * 60000));
+        if (lastMinuteSlot >= currentMinuteSlot) return false;
+      }
+      return true;
+    }
+
+    if (minutePart === '0' && hourPart === '*') {
+      // Every hour on the hour
+      if (now.getMinutes() !== 0) return false;
+
+      if (schedule.lastRun) {
+        const lastHour = Math.floor(schedule.lastRun.getTime() / 3600000);
+        const currentHour = Math.floor(now.getTime() / 3600000);
+        if (lastHour >= currentHour) return false;
+      }
+      return true;
+    }
+
+    if (minutePart === '0' && hourPart === '0') {
+      // Every day at midnight
+      if (now.getHours() !== 0 || now.getMinutes() !== 0) return false;
+
+      if (schedule.lastRun) {
+        const lastDay = Math.floor(schedule.lastRun.getTime() / 86400000);
+        const currentDay = Math.floor(now.getTime() / 86400000);
+        if (lastDay >= currentDay) return false;
+      }
+      return true;
+    }
+
+    return false;
+  }
+
+  private async runMiddlewarePipeline(
+    task: Task,
+    middlewares: MiddlewareFunction[],
+    handler: HandlerFunction | null
+  ): Promise<boolean> {
+    let index = 0;
+    let handlerReached = false;
+
+    const next = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const currentIndex = index++;
+        const middleware = middlewares[currentIndex];
+        await middleware(task, next);
+      } else if (handler) {
+        handlerReached = true;
+        await handler(task);
+      } else {
+        handlerReached = true;
+      }
+    };
+
+    await next();
+    return handlerReached;
+  }
+
+  private async performShutdown(options: ShutdownOptions): Promise<ShutdownSummary> {
+    const startTime = Date.now();
+    const timeout = options.timeout ?? 30000;
+    let completed = 0;
+    let forceCancelled = 0;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Collect all processing tasks
+    const processingTasks: Task[] = [];
+    for (const queue of this.queues.values()) {
+      for (const task of queue.tasks.values()) {
+        if (task.status === 'processing') {
+          processingTasks.push(task);
+        }
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return { completed: 0, forceCancelled: 0, duration: Date.now() - startTime };
+    }
+
+    // Wait for processing tasks with timeout
+    const waitResult = await Promise.race([
+      this.waitForProcessingTasks(processingTasks),
+      new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),
+    ]);
+
+    if (waitResult === 'timeout') {
+      // Force cancel remaining processing tasks
+      for (const task of processingTasks) {
+        if (task.status === 'processing') {
+          task.status = 'cancelled';
+          // Remove from queue
+          const queue = this.queues.get(task.queue);
+          if (queue) {
+            queue.tasks.delete(task.id);
+          }
+          forceCancelled++;
+        } else if (task.status === 'completed' || task.status === 'failed') {
+          completed++;
+        }
+      }
+    } else {
+      // All tasks finished
+      for (const task of processingTasks) {
+        if (task.status === 'completed' || task.status === 'failed') {
+          completed++;
+        }
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  private waitForProcessingTasks(tasks: Task[]): Promise<void> {
+    return new Promise<void>(resolve => {
+      const check = () => {
+        const allDone = tasks.every(t => t.status !== 'processing');
+        if (allDone) {
+          resolve();
+        } else {
+          setTimeout(check, 10);
+        }
+      };
+      check();
+    });
+  }
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..8160ac8
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,53 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue'>;
+  lastRun?: Date;
+}
+
+export type MiddlewareFunction = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFunction = (task: Task) => Promise<void> | void;
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
