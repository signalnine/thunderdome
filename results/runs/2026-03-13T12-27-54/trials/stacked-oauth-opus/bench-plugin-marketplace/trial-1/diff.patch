@@ -0,0 +1,135 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from '../src/index.js';
+import type { Marketplace } from '../src/index.js';
+import type { PluginManifest } from '../src/types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '2 + 2',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Marketplace Integration', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  describe('createMarketplace', () => {
+    it('should create a marketplace with all services', () => {
+      expect(marketplace.registry).toBeDefined();
+      expect(marketplace.resolver).toBeDefined();
+      expect(marketplace.runner).toBeDefined();
+      expect(marketplace.reviews).toBeDefined();
+      expect(marketplace.deps).toBeDefined();
+      expect(marketplace.installPlugin).toBeDefined();
+    });
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin with no dependencies', async () => {
+      const manifest = makeManifest({ entryPoint: '40 + 2' });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.resolvedDependencies).toHaveLength(0);
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe(42);
+    });
+
+    it('should register the plugin in the registry', async () => {
+      const manifest = makeManifest();
+      await marketplace.installPlugin(manifest);
+      const registered = marketplace.registry.get('test-plugin');
+      expect(registered).not.toBeNull();
+      expect(registered!.name).toBe('test-plugin');
+    });
+
+    it('should resolve dependencies during install', async () => {
+      // First register the dependency
+      marketplace.registry.register(makeManifest({
+        name: 'dep-plugin',
+        version: '1.0.0',
+        entryPoint: '"dep loaded"',
+      }));
+
+      const manifest = makeManifest({
+        name: 'main-plugin',
+        dependencies: { 'dep-plugin': '^1.0.0' },
+        entryPoint: '"main loaded"',
+      });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-plugin');
+      expect(result.resolvedDependencies[0].version).toBe('1.0.0');
+    });
+
+    it('should reject plugins with circular dependencies', async () => {
+      // Register a plugin that depends on our target
+      marketplace.registry.register(makeManifest({
+        name: 'a-plugin',
+        version: '1.0.0',
+        dependencies: { 'b-plugin': '^1.0.0' },
+        entryPoint: '"a"',
+      }));
+
+      // Try to install b-plugin that depends on a-plugin (creating a cycle)
+      const manifest = makeManifest({
+        name: 'b-plugin',
+        version: '1.0.0',
+        dependencies: { 'a-plugin': '^1.0.0' },
+        entryPoint: '"b"',
+      });
+
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency');
+    });
+
+    it('should reject manifest without name', async () => {
+      const manifest = makeManifest({ name: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');
+    });
+
+    it('should reject manifest without version', async () => {
+      const manifest = makeManifest({ version: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');
+    });
+
+    it('should reject manifest without entryPoint', async () => {
+      const manifest = makeManifest({ entryPoint: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('entryPoint');
+    });
+
+    it('should handle entry point errors gracefully', async () => {
+      const manifest = makeManifest({ entryPoint: 'throw new Error("boom")' });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.sandboxResult.success).toBe(false);
+      expect(result.sandboxResult.error).toBe('boom');
+    });
+
+    it('should remove plugin from registry when circular dep detected', async () => {
+      marketplace.registry.register(makeManifest({
+        name: 'x',
+        version: '1.0.0',
+        dependencies: { y: '^1.0.0' },
+        entryPoint: '"x"',
+      }));
+
+      const manifest = makeManifest({
+        name: 'y',
+        version: '1.0.0',
+        dependencies: { x: '^1.0.0' },
+        entryPoint: '"y"',
+      });
+
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow();
+      // Plugin should be removed from registry
+      expect(marketplace.registry.get('y')).toBeNull();
+    });
+  });
+});
