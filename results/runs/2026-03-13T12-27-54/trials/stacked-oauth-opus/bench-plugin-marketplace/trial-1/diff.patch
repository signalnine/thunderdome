@@ -0,0 +1,124 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeImpl(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    if (visited.has(name)) {
+      return node;
+    }
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      node.dependencies.push(buildTreeImpl(depName, registry, new Set(visited)));
+    }
+
+    return node;
+  }
+
+  function detectCyclesImpl(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    allCycles: string[][]
+  ): void {
+    const idx = path.indexOf(name);
+    if (idx !== -1) {
+      // Found a cycle - extract it
+      const cycle = path.slice(idx);
+      cycle.push(name);
+      allCycles.push(cycle);
+      return;
+    }
+
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    path.push(name);
+    for (const depName of Object.keys(manifest.dependencies)) {
+      detectCyclesImpl(depName, registry, [...path], allCycles);
+    }
+  }
+
+  function topoSortImpl(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        topoSortImpl(depName, registry, visited, result);
+      }
+    }
+
+    result.push(name);
+  }
+
+  function flattenDepsImpl(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!visited.has(depName)) {
+        visited.add(depName);
+        result.push(depName);
+        flattenDepsImpl(depName, registry, visited, result);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeImpl(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const allCycles: string[][] = [];
+      detectCyclesImpl(name, registry, [], allCycles);
+      return allCycles.length > 0 ? allCycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      topoSortImpl(name, registry, visited, result);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      flattenDepsImpl(name, registry, visited, result);
+      return result;
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const allCycles: string[][] = [];
+      detectCyclesImpl(name, registry, [], allCycles);
+      return allCycles.length > 0;
+    },
+  };
+}
