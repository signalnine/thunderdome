dep of deps) {\n   400→          this.dependents.get(dep)?.delete(ref);\n   401→        }\n   402→        // Restore old deps\n   403→        if (oldDeps) {\n   404→          this.dependencies.set(ref, oldDeps);\n   405→          for (const dep of oldDeps) {\n   406→            if (!this.dependents.has(dep)) {\n   407→              this.dependents.set(dep, new Set());\n   408→            }\n   409→            this.dependents.get(dep)!.add(ref);\n   410→          }\n   411→        }\n   412→        throw new Error(`Circular reference detected`);\n   413→      }\n   414→\n   415→      this.cellData.set(ref, { raw: value, formula });\n   416→      this.asts.set(ref, ast);\n   417→    } else {\n   418→      this.cellData.set(ref, { raw: value, formula: null });\n   419→      this.asts.delete(ref);\n   420→      this.dependencies.set(ref, new Set());\n   421→    }\n   422→\n   423→    this.recompute(ref);\n   424→    this.propagate(ref);\n   425→  }\n   426→\n   427→  get(cell: string): CellValue {\n   428→    const ref = this.normalizeRef(cell);\n   429→    if (!this.cellData.has(ref)) return null;\n   430→    return this.computed.get(ref) ?? null;\n   431→  }\n   432→\n   433→  getDisplay(cell: string): string {\n   434→    const value = this.get(cell);\n   435→    if (value === null) return '';\n   436→    return String(value);\n   437→  }\n   438→\n   439→  getCells(): Map<string, any> {\n   440→    const result = new Map<string, any>();\n   441→    for (const ref of this.cellData.keys()) {\n   442→      result.set(ref, this.computed.get(ref) ?? null);\n   443→    }\n   444→    return result;\n   445→  }\n   446→\n   447→  private hasCycle(start: string): boolean {\n   448→    const visited = new Set<string>();\n   449→    const stack = [start];\n   450→    while (stack.length > 0) {\n   451→      const current = stack.pop()!;\n   452→      const deps = this.dependencies.get(current);\n   453→      if (!deps) continue;\n   454→      for (const dep of deps) {\n   455→