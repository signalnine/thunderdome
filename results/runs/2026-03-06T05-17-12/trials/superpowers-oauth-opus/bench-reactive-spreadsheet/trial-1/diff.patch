+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: string | null;
+}
+
+// Token types for the formula lexer
+type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'CELL_REF'
+  | 'RANGE'
+  | 'FUNC'
+  | 'PLUS'
+  | 'MINUS'
+  | 'STAR'
+  | 'SLASH'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'COMMA'
+  | 'GT'
+  | 'LT'
+  | 'GTE'
+  | 'LTE'
+  | 'EQ'
+  | 'NEQ'
+  | 'COLON';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+// AST node types
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell_ref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binary'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'unary'; op: string; operand: ASTNode }
+  | { type: 'function'; name: string; args: ASTNode[] };
+
+function tokenize(expr: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < expr.length) {
+    const ch = expr[i];
+
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    if (ch === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < expr.length && expr[i] !== '"') {
+        str += expr[i];
+        i++;
+      }
+      i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    if (ch >= '0' && ch <= '9' || ch === '.') {
+      let num = '';
+      while (i < expr.length && ((expr[i] >= '0' && expr[i] <= '9') || expr[i] === '.')) {
+        num += expr[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let ident = '';
+      while (i < expr.length && ((expr[i] >= 'A' && expr[i] <= 'Z') || (expr[i] >= 'a' && expr[i] <= 'z') || (expr[i] >= '0' && expr[i] <= '9'))) {
+        ident += expr[i];
+        i++;
+      }
+
+      const upper = ident.toUpperCase();
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: upper });
+      } else if (i < expr.length && expr[i] === '(') {
+        // Check if it's a function name (all letters, no digits)
+        const isFunc = /^[A-Za-z]+$/.test(ident);
+        if (isFunc && !/^[A-Z]+\d+$/.test(upper)) {
+          tokens.push({ type: 'FUNC', value: upper });
+        } else {
+          tokens.push({ type: 'CELL_REF', value: upper });
+        }
+      } else {
+        // cell reference like A1, AA12
+        tokens.push({ type: 'CELL_REF', value: upper });
+      }
+      continue;
+    }
+
+    switch (ch) {
+      case '+': tokens.push({ type: 'PLUS', value: '+' }); break;
+      case '-': tokens.push({ type: 'MINUS', value: '-' }); break;
+      case '*': tokens.push({ type: 'STAR', value: '*' }); break;
+      case '/': tokens.push({ type: 'SLASH', value: '/' }); break;
+      case '(': tokens.push({ type: 'LPAREN', value: '(' }); break;
+      case ')': tokens.push({ type: 'RPAREN', value: ')' }); break;
+      case ',': tokens.push({ type: 'COMMA', value: ',' }); break;
+      case ':': tokens.push({ type: 'COLON', value: ':' }); break;
+      case '>':
+        if (i + 1 < expr.length && expr[i + 1] === '=') {
+          tokens.push({ type: 'GTE', value: '>=' });
+          i++;
+        } else {
+          tokens.push({ type: 'GT', value: '>' });
+        }
+        break;
+      case '<':
+        if (i + 1 < expr.length && expr[i + 1] === '=') {
+          tokens.push({ type: 'LTE', value: '<=' });
+          i++;
+        } else if (i + 1 < expr.length && expr[i + 1] === '>') {
+          tokens.push({ type: 'NEQ', value: '<>' });
+          i++;
+        } else {
+          tokens.push({ type: 'LT', value: '<' });
+        }
+        break;
+      case '=':
+        tokens.push({ type: 'EQ', value: '=' });
+        break;
+      default:
+        throw new Error(`Unexpected character: ${ch}`);
+    }
+    i++;
+  }
+
+  return tokens;
+}
+
+// Recursive descent parser
+class Parser {
+  private tokens: Token[];
+  private pos = 0;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    return node;
+  }
+
+  private peek(): Token | null {
+    return this.pos < this.tokens.length ? this.tokens[this.pos] : null;
+  }
+
+  private consume(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private expect(type: TokenType): Token {
+    const tok = this.consume();
+    if (tok.type !== type) {
+      throw new Error(`Expected ${type} but got ${tok.type}`);
+    }
+    return tok;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAddSub();
+    const tok = this.peek();
+    if (tok && (tok.type === 'GT' || tok.type === 'LT' || tok.type === 'GTE' || tok.type === 'LTE' || tok.type === 'EQ' || tok.type === 'NEQ')) {
+      this.consume();
+      const right = this.parseAddSub();
+      return { type: 'binary', op: tok.value, left, right };
+    }
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    while (true) {
+      const tok = this.peek();
+      if (tok && (tok.type === 'PLUS' || tok.type === 'MINUS')) {
+        this.consume();
+        const right = this.parseMulDiv();
+        left = { type: 'binary', op: tok.value, left, right };
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    while (true) {
+      const tok = this.peek();
+      if (tok && (tok.type === 'STAR' || tok.type === 'SLASH')) {
+        this.consume();
+        const right = this.parseUnary();
+        left = { type: 'binary', op: tok.value, left, right };
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    const tok = this.peek();
+    if (tok && tok.type === 'MINUS') {
+      this.consume();
+      const operand = this.parseUnary();
+      return { type: 'unary', op: '-', operand };
+    }
+    if (tok && tok.type === 'PLUS') {
+      this.consume();
+      return this.parseUnary();
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const tok = this.peek();
+    if (!tok) throw new Error('Unexpected end of expression');
+
+    if (tok.type === 'NUMBER') {
+      this.consume();
+      return { type: 'number', value: parseFloat(tok.value) };
+    }
+
+    if (tok.type === 'STRING') {
+      this.consume();
+      return { type: 'string', value: tok.value };
+    }
+
+    if (tok.type === 'BOOLEAN') {
+      this.consume();
+      return { type: 'boolean', value: tok.value === 'TRUE' };
+    }
+
+    if (tok.type === 'FUNC') {
+      const name = tok.value;
+      this.consume();
+      this.expect('LPAREN');
+      const args: ASTNode[] = [];
+      if (this.peek()?.type !== 'RPAREN') {
+        args.push(this.parse());
+        while (this.peek()?.type === 'COMMA') {
+          this.consume();
+          args.push(this.parse());
+        }
+      }
+      this.expect('RPAREN');
+      return { type: 'function', name, args };
+    }
+
+    if (tok.type === 'CELL_REF') {
+      this.consume();
+      // Check if it's a range
+      if (this.peek()?.type === 'COLON') {
+        this.consume();
+        const endTok = this.expect('CELL_REF');
+        return { type: 'range', start: tok.value, end: endTok.value };
+      }
+      return { type: 'cell_ref', ref: tok.value };
+    }
+
+    if (tok.type === 'LPAREN') {
+      this.consume();
+      const expr = this.parse();
+      this.expect('RPAREN');
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${tok.type} (${tok.value})`);
+  }
+}
+
+function parseRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  const colStr = match[1];
+  const row = parseInt(match[2], 10);
+  let col = 0;
+  for (let i = 0; i < colStr.length; i++) {
+    col = col * 26 + (colStr.charCodeAt(i) - 64);
+  }
+  return { col, row };
+}
+
+function colToStr(col: number): string {
+  let s = '';
+  while (col > 0) {
+    const rem = (col - 1) % 26;
+    s = String.fromCharCode(65 + rem) + s;
+    col = Math.floor((col - 1) / 26);
+  }
+  return s;
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseRef(start);
+  const e = parseRef(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const refs: string[] = [];
+  for (let c = minCol; c <= maxCol; c++) {
+    for (let r = minRow; r <= maxRow; r++) {
+      refs.push(colToStr(c) + r);
+    }
+  }
+  return refs;
+}
+
+function collectDependencies(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+  const visit = (n: ASTNode) => {
+    switch (n.type) {
+      case 'cell_ref':
+        deps.add(n.ref);
+        break;
+      case 'range':
+        for (const ref of expandRange(n.start, n.end)) {
+          deps.add(ref);
+        }
+        break;
+      case 'binary':
+        visit(n.left);
+        visit(n.right);
+        break;
+      case 'unary':
+        visit(n.operand);
+        break;
+      case 'function':
+        for (const arg of n.args) {
+          visit(arg);
+        }
+        break;
+    }
+  };
+  visit(node);
+  return deps;
+}
+
+export class Spreadsheet {
+  private cellData = new Map<string, CellData>();
+  private computed = new Map<string, CellValue>();
+  private asts = new Map<string, ASTNode>();
+  // dependency graph: dependents[A] = set of cells that depend on A
+  private dependents = new Map<string, Set<string>>();
+  // dependencies: deps[A] = set of cells A depends on
+  private dependencies = new Map<string, Set<string>>();
+
+  private normalizeRef(ref: string): string {
+    return ref.toUpperCase();
+  }
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = this.normalizeRef(cell);
+
+    // Remove old dependencies
+    const oldDeps = this.dependencies.get(ref);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formula = value.slice(1);
+      const tokens = tokenize(formula);
+      const ast = new Parser(tokens).parse();
+      const deps = collectDependencies(ast);
+
+      // Check for circular references before committing
+      this.dependencies.set(ref, deps);
+      for (const dep of deps) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      // Detect cycles
+      if (this.hasCycle(ref)) {
+        // Rollback
+        this.dependencies.delete(ref);
+        for (const dep of deps) {
+          this.dependents.get(dep)?.delete(ref);
+        }
+        // Restore old deps
+        if (oldDeps) {
+          this.dependencies.set(ref, oldDeps);
+          for (const dep of oldDeps) {
+            if (!this.dependents.has(dep)) {
+              this.dependents.set(dep, new Set());
+            }
+            this.dependents.get(dep)!.add(ref);
+          }
+        }
+        throw new Error(`Circular reference detected`);
+      }
+
+      this.cellData.set(ref, { raw: value, formula });
+      this.asts.set(ref, ast);
+    } else {
+      this.cellData.set(ref, { raw: value, formula: null });
+      this.asts.delete(ref);
+      this.dependencies.set(ref, new Set());
+    }
+
+    this.recompute(ref);
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = this.normalizeRef(cell);
+    if (!this.cellData.has(ref)) return null;
+    return this.computed.get(ref) ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, any> {
+    const result = new Map<string, any>();
+    for (const ref of this.cellData.keys()) {
+      result.set(ref, this.computed.get(ref) ?? null);
+    }
+    return result;
+  }
+
+  private hasCycle(start: string): boolean {
+    const visited = new Set<string>();
+    const stack = [start];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      const deps = this.dependencies.get(current);
+      if (!deps) continue;
+      for (const dep of deps) {
+        if (dep === start) return true;
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          stack.push(dep);
+        }
+      }
+    }
+    return false;
+  }
+
+  private recompute(ref: string): void {
+    const ast = this.asts.get(ref);
+    if (ast) {
+      this.computed.set(ref, this.evaluate(ast));
+    } else {
+      const data = this.cellData.get(ref);
+      if (data) {
+        this.computed.set(ref, data.raw as CellValue);
+      }
+    }
+  }
+
+  private propagate(changedRef: string): void {
+    // Topological sort of dependents
+    const order = this.topologicalSort(changedRef);
+    for (const ref of order) {
+      if (ref !== changedRef) {
+        this.recompute(ref);
+      }
+    }
+  }
+
+  private topologicalSort(start: string): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (ref: string) => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      result.push(ref);
+    };
+
+    visit(start);
+    return result.reverse();
+  }
+
+  private evaluate(node: ASTNode): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cell_ref': {
+        const val = this.get(node.ref);
+        return val;
+      }
+      case 'binary': {
+        const left = this.evaluate(node.left);
+        const right = this.evaluate(node.right);
+        return this.evalBinary(node.op, left, right);
+      }
+      case 'unary': {
+        const operand = this.evaluate(node.operand);
+        if (node.op === '-') {
+          return -(this.toNumber(operand));
+        }
+        return operand;
+      }
+      case 'function':
+        return this.evalFunction(node.name, node.args);
+      case 'range':
+        throw new Error('Range used outside of function');
+    }
+  }
+
+  private toNumber(val: CellValue): number {
+    if (typeof val === 'number') return val;
+    if (typeof val === 'boolean') return val ? 1 : 0;
+    if (val === null) return 0;
+    const n = Number(val);
+    return isNaN(n) ? 0 : n;
+  }
+
+  private evalBinary(op: string, left: CellValue, right: CellValue): CellValue {
+    const l = this.toNumber(left);
+    const r = this.toNumber(right);
+    switch (op) {
+      case '+': return l + r;
+      case '-': return l - r;
+      case '*': return l * r;
+      case '/': return l / r;
+      case '>': return l > r;
+      case '<': return l < r;
+      case '>=': return l >= r;
+      case '<=': return l <= r;
+      case '=': return l === r;
+      case '<>': return l !== r;
+      default: throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  private resolveRangeValues(node: ASTNode): CellValue[] {
+    if (node.type === 'range') {
+      const refs = expandRange(node.start, node.end);
+      return refs.map(ref => this.get(ref));
+    }
+    return [this.evaluate(node)];
+  }
+
+  private evalFunction(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        const values = args.flatMap(a => this.resolveRangeValues(a));
+        return values.reduce((sum: number, v) => sum + this.toNumber(v), 0);
+      }
+      case 'AVERAGE': {
+        const values = args.flatMap(a => this.resolveRangeValues(a));
+        const numericValues = values.filter(v => typeof v === 'number') as number[];
+        const sum = numericValues.reduce((s: number, v) => s + v, 0);
+        return numericValues.length > 0 ? sum / numericValues.length : 0;
+      }
+      case 'MIN': {
+        const values = args.flatMap(a => this.resolveRangeValues(a));
+        const nums = values.filter(v => typeof v === 'number') as number[];
+        return nums.length > 0 ? Math.min(...nums) : 0;
+      }
+      case 'MAX': {
+        const values = args.flatMap(a => this.resolveRangeValues(a));
+        const nums = values.filter(v => typeof v === 'number') as number[];
+        return nums.length > 0 ? Math.max(...nums) : 0;
+      }
+      case 'COUNT': {
+        const values = args.flatMap(a => this.resolveRangeValues(a));
+        return values.filter(v => typeof v === 'number').length;
+      }
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evaluate(args[0]);
+        const isTruthy = typeof condition === 'boolean' ? condition : this.toNumber(condition) !== 0;
+        return isTruthy ? this.evaluate(args[1]) : this.evaluate(args[2]);
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
