+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('B1')).toBe(70);
+    });
+
+    test('replacing formula with value removes dependencies', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      expect(sheet.get('B1')).toBe(11);
+
+      sheet.set('B1', 99);
+      sheet.set('A1', 50);
+      expect(sheet.get('B1')).toBe(99);
+    });
+
+    test('example from spec', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+      expect(sheet.getDisplay('A3')).toBe('30');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(70);
+
+      sheet.set('C1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('C1')).toBe('big');
+    });
+  });
+
+  describe('circular reference detection', () => {
+    test('direct self-reference', () => {
+      const sheet = new Spreadsheet();
+      expect(() => sheet.set('A1', '=A1')).toThrow();
+    });
+
+    test('simple two-cell cycle', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      expect(() => sheet.set('B1', '=A1')).toThrow();
+    });
+
+    test('indirect cycle through three cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      sheet.set('B1', '=C1');
+      expect(() => sheet.set('C1', '=A1')).toThrow();
+    });
+
+    test('no false positive for non-circular references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1');
+      sheet.set('C1', '=A1+B1');
+      // This should not throw - diamond dependency is fine
+      expect(sheet.get('C1')).toBe(20);
+    });
+
+    test('circular ref does not corrupt state', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      expect(sheet.get('B1')).toBe(11);
+
+      expect(() => sheet.set('A1', '=B1')).toThrow();
+      // A1 should still be 10 since the set was rolled back
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('B1')).toBe(11);
+    });
+  });
+});
