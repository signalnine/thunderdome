+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    test('returns string representation of number', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    test('returns string value as-is', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    test('returns string representation of boolean', () => {
+      const sheet = new Spreadsheet();
