[i];\n        i++;\n      }\n      tokens.push({ type: 'NUMBER', value: num });\n      continue;\n    }\n\n    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {\n      let ident = '';\n      while (i < expr.length && ((expr[i] >= 'A' && expr[i] <= 'Z') || (expr[i] >= 'a' && expr[i] <= 'z') || (expr[i] >= '0' && expr[i] <= '9'))) {\n        ident += expr[i];\n        i++;\n      }\n\n      const upper = ident.toUpperCase();\n      if (upper === 'TRUE' || upper === 'FALSE') {\n        tokens.push({ type: 'BOOLEAN', value: upper });\n      } else if (i < expr.length && expr[i] === '(') {\n        // Check if it's a function name (all letters, no digits)\n        const isFunc = /^[A-Za-z]+$/.test(ident);\n        if (isFunc && !/^[A-Z]+\\d+$/.test(upper)) {\n          tokens.push({ type: 'FUNC', value: upper });\n        } else {\n          tokens.push({ type: 'CELL_REF', value: upper });\n        }\n      } else {\n        // cell reference like A1, AA12\n        tokens.push({ type: 'CELL_REF', value: upper });\n      }\n      continue;\n    }\n\n    switch (ch) {\n      case '+': tokens.push({ type: 'PLUS', value: '+' }); break;\n      case '-': tokens.push({ type: 'MINUS', value: '-' }); break;\n      case '*': tokens.push({ type: 'STAR', value: '*' }); break;\n      case '/': tokens.push({ type: 'SLASH', value: '/' }); break;\n      case '(': tokens.push({ type: 'LPAREN', value: '(' }); break;\n      case ')': tokens.push({ type: 'RPAREN', value: ')' }); break;\n      case ',': tokens.push({ type: 'COMMA', value: ',' }); break;\n      case ':': tokens.push({ type: 'COLON', value: ':' }); break;\n      case '>':\n        if (i + 1 < expr.length && expr[i + 1] === '=') {\n          tokens.push({ type: 'GTE', value: '>=' });\n          i++;\n        } else {\n          tokens.push({ type: 'GT', value: '>' });\n        }\n        break;\n      case '<':\n        if (i + 1 < expr.length && expr[i + 1] === '=') {\n          tokens.push({ type: 'LTE', value: '<='