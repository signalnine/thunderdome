= new Spreadsheet();\n      sheet.set('A1', 'hello');\n      expect(sheet.getDisplay('A1')).toBe('hello');\n    });\n\n    test('returns string representation of boolean', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', true);\n      expect(sheet.getDisplay('A1')).toBe('true');\n    });\n  });\n\n  describe('getCells', () => {\n    test('returns empty map when no cells set', () => {\n      const sheet = new Spreadsheet();\n      const cells = sheet.getCells();\n      expect(cells.size).toBe(0);\n    });\n\n    test('returns all set cells with computed values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 'hello');\n      const cells = sheet.getCells();\n      expect(cells.size).toBe(2);\n      expect(cells.get('A1')).toBe(10);\n      expect(cells.get('B1')).toBe('hello');\n    });\n  });\n\n  describe('formulas - arithmetic', () => {\n    test('simple number literal formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=42');\n      expect(sheet.get('A1')).toBe(42);\n    });\n\n    test('addition', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=1+2');\n      expect(sheet.get('A1')).toBe(3);\n    });\n\n    test('subtraction', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=10-3');\n      expect(sheet.get('A1')).toBe(7);\n    });\n\n    test('multiplication', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=3*4');\n      expect(sheet.get('A1')).toBe(12);\n    });\n\n    test('division', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=10/4');\n      expect(sheet.get('A1')).toBe(2.5);\n    });\n\n    test('operator precedence: multiplication before addition', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=2+3*4');\n      expect(sheet.get('A1')).toBe(14);\n    });\n\n    test('parentheses override precedence', () => {\n      const sheet = new 