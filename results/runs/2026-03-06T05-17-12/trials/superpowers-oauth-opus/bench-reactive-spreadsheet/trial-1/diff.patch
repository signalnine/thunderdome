     const tok = this.peek();\n      if (tok && (tok.type === 'STAR' || tok.type === 'SLASH')) {\n        this.consume();\n        const right = this.parseUnary();\n        left = { type: 'binary', op: tok.value, left, right };\n      } else {\n        break;\n      }\n    }\n    return left;\n  }\n\n  private parseUnary(): ASTNode {\n    const tok = this.peek();\n    if (tok && tok.type === 'MINUS') {\n      this.consume();\n      const operand = this.parseUnary();\n      return { type: 'unary', op: '-', operand };\n    }\n    if (tok && tok.type === 'PLUS') {\n      this.consume();\n      return this.parseUnary();\n    }\n    return this.parsePrimary();\n  }\n\n  private parsePrimary(): ASTNode {\n    const tok = this.peek();\n    if (!tok) throw new Error('Unexpected end of expression');\n\n    if (tok.type === 'NUMBER') {\n      this.consume();\n      return { type: 'number', value: parseFloat(tok.value) };\n    }\n\n    if (tok.type === 'STRING') {\n      this.consume();\n      return { type: 'string', value: tok.value };\n    }\n\n    if (tok.type === 'BOOLEAN') {\n      this.consume();\n      return { type: 'boolean', value: tok.value === 'TRUE' };\n    }\n\n    if (tok.type === 'FUNC') {\n      const name = tok.value;\n      this.consume();\n      this.expect('LPAREN');\n      const args: ASTNode[] = [];\n      if (this.peek()?.type !== 'RPAREN') {\n        args.push(this.parse());\n        while (this.peek()?.type === 'COMMA') {\n          this.consume();\n          args.push(this.parse());\n        }\n      }\n      this.expect('RPAREN');\n      return { type: 'function', name, args };\n    }\n\n    if (tok.type === 'CELL_REF') {\n      this.consume();\n      // Check if it's a range\n      if (this.peek()?.type === 'COLON') {\n        this.consume();\n        const endTok = this.expect('CELL_REF');\n        return { type: 'range', start: tok.value, end: endTok.value };\n      }\n      return { type: 'cell_ref', ref: tok.value };\n    }\n\n    if (tok.type