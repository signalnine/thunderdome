+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    test('set and get a number', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    test('set and get a string', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    test('set and get a boolean', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    test('set overwrites previous value', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A1', 20);
+      expect(sheet.get('A1')).toBe(20);
+    });
+
+    test('cell references are case-insensitive', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+  });
+
+  describe('getDisplay', () => {
