nction parseRef(ref: string): { col: number; row: number } {\n   289→  const match = ref.match(/^([A-Z]+)(\\d+)$/);\n   290→  if (!match) throw new Error(`Invalid cell reference: ${ref}`);\n   291→  const colStr = match[1];\n   292→  const row = parseInt(match[2], 10);\n   293→  let col = 0;\n   294→  for (let i = 0; i < colStr.length; i++) {\n   295→    col = col * 26 + (colStr.charCodeAt(i) - 64);\n   296→  }\n   297→  return { col, row };\n   298→}\n   299→\n   300→function colToStr(col: number): string {\n   301→  let s = '';\n   302→  while (col > 0) {\n   303→    const rem = (col - 1) % 26;\n   304→    s = String.fromCharCode(65 + rem) + s;\n   305→    col = Math.floor((col - 1) / 26);\n   306→  }\n   307→  return s;\n   308→}\n   309→\n   310→function expandRange(start: string, end: string): string[] {\n   311→  const s = parseRef(start);\n   312→  const e = parseRef(end);\n   313→  const minCol = Math.min(s.col, e.col);\n   314→  const maxCol = Math.max(s.col, e.col);\n   315→  const minRow = Math.min(s.row, e.row);\n   316→  const maxRow = Math.max(s.row, e.row);\n   317→  const refs: string[] = [];\n   318→  for (let c = minCol; c <= maxCol; c++) {\n   319→    for (let r = minRow; r <= maxRow; r++) {\n   320→      refs.push(colToStr(c) + r);\n   321→    }\n   322→  }\n   323→  return refs;\n   324→}\n   325→\n   326→function collectDependencies(node: ASTNode): Set<string> {\n   327→  const deps = new Set<string>();\n   328→  const visit = (n: ASTNode) => {\n   329→    switch (n.type) {\n   330→      case 'cell_ref':\n   331→        deps.add(n.ref);\n   332→        break;\n   333→      case 'range':\n   334→        for (const ref of expandRange(n.start, n.end)) {\n   335→          deps.add(ref);\n   336→        }\n   337→        break;\n   338→      case 'binary':\n   339→        visit(n.left);\n   340→        visit(n.right);\n   341→        break;\n   342→      case 'unary':\n   343→        visit(n.operand);\n   344→        break;\n   345→      case 'funct