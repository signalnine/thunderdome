find((e) => e.stop === null);\n  }\n\n  getEntries(from?: Date, to?: Date): TimeEntry[] {\n    let result = this.entries;\n\n    if (from) {\n      const fromMs = from.getTime();\n      result = result.filter((e) => e.start >= fromMs);\n    }\n\n    if (to) {\n      const toMs = to.getTime();\n      result = result.filter((e) => e.start <= toMs);\n    }\n\n    return result.map((e) => ({ ...e }));\n  }\n\n  getSummary(from?: Date, to?: Date): TimeSummary {\n    const entries = this.getEntries(from, to);\n    const summary: TimeSummary = {};\n\n    for (const entry of entries) {\n      const end = entry.stop ?? Date.now();\n      const duration = end - entry.start;\n      summary[entry.task] = (summary[entry.task] ?? 0) + duration;\n    }\n\n    return summary;\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":234,"cache_read_input_tokens":19853,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":234},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"638f9cd3-59a8-42ca-a891-3ae7e7acaac4","uuid":"661434f1-1bce-4ab3-80b7-e4bf813e598e"}
