--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,107 @@
+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: number;
+  stop: number | null;
+}
+
+interface StorageData {
+  entries: TimeEntry[];
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.load();
+  }
+
+  private load(): void {
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      const parsed: StorageData = JSON.parse(data);
+      this.entries = parsed.entries;
+    } catch {
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    const data: StorageData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Stop any currently running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = Date.now();
+    }
+
+    this.entries.push({
+      task,
+      start: Date.now(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = Date.now();
+    this.save();
+    return { ...running };
+  }
+
+  getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((e) => e.stop === null);
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    let result = this.entries;
+
+    if (from) {
+      const fromMs = from.getTime();
+      result = result.filter((e) => e.start >= fromMs);
+    }
+
+    if (to) {
+      const toMs = to.getTime();
+      result = result.filter((e) => e.start <= toMs);
+    }
+
+    return result.map((e) => ({ ...e }));
+  }
+
+  getSummary(from?: Date, to?: Date): TimeSummary {
+    const entries = this.getEntries(from, to);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const end = entry.stop ?? Date.now();
+      const duration = end - entry.start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+}
