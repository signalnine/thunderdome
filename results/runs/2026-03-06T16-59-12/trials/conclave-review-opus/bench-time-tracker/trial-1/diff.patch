ries.push({\n+      task,\n+      start: Date.now(),\n+      stop: null,\n+    });\n+\n+    this.save();\n+  }\n+\n+  stop(): TimeEntry {\n+    const running = this.getRunningEntry();\n+    if (!running) {\n+      throw new Error(\"No timer is currently running\");\n+    }\n+\n+    running.stop = Date.now();\n+    this.save();\n+    return { ...running };\n+  }\n+\n+  getRunningEntry(): TimeEntry | undefined {\n+    return this.entries.find((e) => e.stop === null);\n+  }\n+\n+  getEntries(from?: Date, to?: Date): TimeEntry[] {\n+    let result = this.entries;\n+\n+    if (from) {\n+      const fromMs = from.getTime();\n+      result = result.filter((e) => e.start >= fromMs);\n+    }\n+\n+    if (to) {\n+      const toMs = to.getTime();\n+      result = result.filter((e) => e.start <= toMs);\n+    }\n+\n+    return result.map((e) => ({ ...e }));\n+  }\n+\n+  getSummary(from?: Date, to?: Date): TimeSummary {\n+    const entries = this.getEntries(from, to);\n+    const summary: TimeSummary = {};\n+\n+    for (const entry of entries) {\n+      const end = entry.stop ?? Date.now();\n+      const duration = end - entry.start;\n+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;\n+    }\n+\n+    return summary;\n+  }\n+}\ndiff --git a/tests/tracker.test.ts b/tests/tracker.test.ts\nindex 7c389bc..0bbe82d 100644\n--- a/tests/tracker.test.ts\n+++ b/tests/tracker.test.ts\n@@ -1,314 +1,243 @@\n-import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n-import { TimeTracker } from '../src/index.js';\n-import { mkdtempSync, rmSync, existsSync } from 'fs';\n-import { join } from 'path';\n-import { tmpdir } from 'os';\n+import { describe, it, expect, beforeEach, afterEach, vi } from \"vitest\";\n+import { TimeTracker, TimeEntry } from \"../src/index.js\";\n+import { mkdirSync, rmSync, existsSync } from \"node:fs\";\n+import { join } from \"node:path\";\n+import { tmpdir } from \"node:os\";\n \n-let tempDir: string;\n-let filePath: string;\n+const testDi