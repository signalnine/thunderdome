+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D1rWCRvmfdLyqHyMvgeWYW","type":"tool_result","content":"diff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..e13ce6d\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,2 @@\n+export { TimeTracker } from \"./tracker.js\";\n+export type { TimeEntry, TimeSummary } from \"./tracker.js\";\ndiff --git a/src/tracker.ts b/src/tracker.ts\nnew file mode 100644\nindex 0000000..d9c8375\n--- /dev/null\n+++ b/src/tracker.ts\n@@ -0,0 +1,107 @@\n+import { readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n+import { dirname } from \"node:path\";\n+\n+export interface TimeEntry {\n+  task: string;\n+  start: number;\n+  stop: number | null;\n+}\n+\n+interface StorageData {\n+  entries: TimeEntry[];\n+}\n+\n+export interface TimeSummary {\n+  [task: string]: number;\n+}\n+\n+export class TimeTracker {\n+  private entries: TimeEntry[] = [];\n+  private filePath: string;\n+\n+  constructor(filePath: string) {\n+    this.filePath = filePath;\n+    this.load();\n+  }\n+\n+  private load(): void {\n+    try {\n+      const data = readFileSync(this.filePath, \"utf-8\");\n+      const parsed: StorageData = JSON.parse(data);\n+      this.entries = parsed.entries;\n+    } catch {\n+      this.entries = [];\n+    }\n+  }\n+\n+  private save(): void {\n+    const dir = dirname(this.filePath);\n+    mkdirSync(dir, { recursive: true });\n+    const data: StorageData = { entries: this.entries };\n+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), \"utf-8\");\n+  }\n+\n+  start(task: string): void {\n+    if (!task || task.trim().length === 0) {\n+      throw new Error(\"Task name cannot be empty\");\n+    }\n+\n+    // Stop any currently running timer\n+    const running = this.getRunningEntry();\n+    if (running) {\n+      running.stop = Date.now();\n+    }\n+\n+    this.entries.push({\n+      task,\n+      start: Date.now(),\n+      stop: null,\n+    });\n+\n+    this.save();\