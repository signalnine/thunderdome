rice: 50 },\n   207→        { description: 'Product B', quantity: 5, unit_price: 100 },\n   208→      ],\n   209→    });\n   210→    const invoice = getInvoiceById(db, id);\n   211→    // subtotal = 500 + 500 = 1000\n   212→    // discounted = 1000 * 0.85 = 850\n   213→    // total = 850 * 1.0 = 850\n   214→    expect(invoice!.total).toBe(850);\n   215→  });\n   216→});\n   217→\n   218→// ─── Date Range Queries (7 tests) ──────────────────────────────────\n   219→\n   220→describe('Date Range Queries', () => {\n   221→  beforeEach(() => {\n   222→    // Seed some invoices across different dates\n   223→    const dates = [\n   224→      '2024-01-15', '2024-01-31', '2024-02-01',\n   225→      '2024-02-28', '2024-03-01', '2024-03-31',\n   226→      '2024-06-30',\n   227→    ];\n   228→    dates.forEach((date, i) => {\n   229→      createInvoice(db, {\n   230→        customer_id: `cust-${i}`,\n   231→        date,\n   232→        subtotal: (i + 1) * 100,\n   233→        discount_rate: 0,\n   234→        tax_rate: 0,\n   235→        total: (i + 1) * 100,\n   236→        status: 'paid',\n   237→      });\n   238→    });\n   239→  });\n   240→\n   241→  it('returns invoices within a date range', () => {\n   242→    const invoices = getInvoicesByDateRange(db, '2024-02-01', '2024-03-15');\n   243→    expect(invoices).toHaveLength(3);\n   244→  });\n   245→\n   246→  it('returns empty array when no invoices match', () => {\n   247→    const invoices = getInvoicesByDateRange(db, '2025-01-01', '2025-12-31');\n   248→    expect(invoices).toHaveLength(0);\n   249→  });\n   250→\n   251→  it('includes invoices on start date boundary', () => {\n   252→    const invoices = getInvoicesByDateRange(db, '2024-01-15', '2024-01-20');\n   253→    expect(invoices).toHaveLength(1);\n   254→    expect(invoices[0].date).toBe('2024-01-15');\n   255→  });\n   256→\n   257→  it('includes invoices on end date boundary', () => {\n   258→    // Should include the invoice on 2024-03-31\n   259→    const invoices = getInvoicesByDateRange(db, '2024-03-15', '2024-03-31');\n   260→    expect(invoices).toHaveLength(1);\n   261→    expect(invoices[0].date).toBe('2024-03-31');\n   262→  });\n   263→\n   264→  it('handles single-month range correctly', () => {\n   265→    const invoices = getInvoicesByDateRange(db, '2024-02-01', '2024-02-29');\n   266→    expect(invoices).toHaveLength(2);\n   267→  });\n   268→\n   269→  it('returns all invoices for full year range', () => {\n   270→    const invoices = getInvoicesByDateRange(db, '2024-01-01', '2024-12-31');\n   271→    expect(invoices).toHaveLength(7);\n   272→  });\n   273→\n   274→  it('handles cross-month boundary range', () => {\n   275→    // Jan 15 to Mar 02 should span across months\n   276→    const invoices = getInvoicesByDateRange(db, '2024-01-15', '2024-03-02');\n   277→    expect(invoices).toHaveLength(5);\n   278→  });\n   279→});\n   280→\n   281→// ─── Monthly Reporting (7 tests) ───────────────────────────────────\n   282→\n   283→describe('Monthly Reporting', () => {\n   284→  beforeEach(() => {\n   285→    // Seed invoices across months (avoiding 1st-of-month dates in seed data)\n   286→    const data: { date: string; total: number }[] = [\n   287→      { date: '2024-01-10', total: 100 },\n   288→      { date: '2024-01-25', total: 200 },\n   289→      { date: '2024-02-15', total: 300 },\n   290→      { date: '2024-03-10', total: 400 },\n   291→      { date: '2024-03-20', total: 150 },\n   292→    ];\n   293→    data.forEach(({ date, total }) => {\n   294→      createInvoice(db, {\n   295→        customer_id: 'cust-1',\n   296→        date,\n   297→        subtotal: total,\n   298→        discount_rate: 0,\n   299→        tax_rate: 0,\n   300→        total,\n   301→        status: 'paid',\n   302→      });\n   303→    });\n   304→  });\n   305→\n   306→  it('generates monthly report with correct counts', () => {\n   307→    const report = getMonthlyReport(db, 2024);\n   308→    expect(report).toHaveLength(3);\n   309→    expect(report[0].count).toBe(2); // January\n   310→    expect(report[1].count).toBe(1); // February\n   311→    expect(report[2].count).toBe(2); // March\n   312→  });\n   313→\n   314→  it('generates monthly report with correct totals', () => {\n   315→    const report = getMonthlyReport(db, 2024);\n   316→    expect(report[0].total_revenue).toBe(300); // Jan: 100 + 200\n   317→    expect(report[1].total_revenue).toBe(300); // Feb: 300\n   318→    expect(report[2].total_revenue).toBe(550); // Mar: 400 + 150\n   319→  });\n   320→\n   321→  it('returns empty report for year with no invoices', () => {\n   322→    const report = getMonthlyReport(db, 2025);\n   323→    expect(report).toHaveLength(0);\n   324→  });\n   325→\n   326→  it('groups invoices correctly at month boundaries', () => {\n   327→    // Add invoices at exact month boundaries\n   328→    createInvoice(db, {\n   329→      customer_id: 'cust-2',\n   330→      date: '2024-01-31',\n   331→      subtotal: 50, discount_rate: 0, tax_rate: 0, total: 50, status: 'paid',\n   332→    });\n   333→    createInvoice(db, {\n   334→      customer_id: 'cust-2',\n   335→      date: '2024-02-01',\n   336→      subtotal: 75, discount_rate: 0, tax_rate: 0, total: 75, status: 'paid',\n   337→    });\n   338→\n   339→    const report = getMonthlyReport(db, 2024);\n   340→    const jan = report.find(r => r.month === 1)!;\n   341→    const feb = report.find(r => r.month === 2)!;\n   342→\n   343→    // Jan should have 3 invoices (10th, 25th, 31st) = 100 + 200 + 50 = 350\n   344→    expect(jan.count).toBe(3);\n   345→    expect(jan.total_revenue).toBe(350);\n   346→\n   347→    // Feb should have 2 invoices (15th, 1st) = 300 + 75 = 375\n   348→    expect(feb.count).toBe(2);\n   349→    expect(feb.total_revenue).toBe(375);\n   350→  });\n   351→\n   352→  it('reports correct year in summaries', () => {\n   353→    const report = getMonthlyReport(db, 2024);\n   354→    expect(report.every(r => r.year === 