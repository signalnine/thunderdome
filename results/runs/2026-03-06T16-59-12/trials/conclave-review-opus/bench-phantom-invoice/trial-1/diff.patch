+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jf2PdeatZZgS8TT51VxNED","type":"tool_result","content":"     1→export interface LineItem {\n     2→  id?: number;\n     3→  invoice_id?: number;\n     4→  description: string;\n     5→  quantity: number;\n     6→  unit_price: number;\n     7→}\n     8→\n     9→export interface Invoice {\n    10→  id?: number;\n    11→  customer_id: string;\n    12→  date: string; // ISO date string YYYY-MM-DD\n    13→  subtotal: number;\n    14→  discount_rate: number; // 0.0 to 1.0\n    15→  tax_rate: number; // 0.0 to 1.0\n    16→  total: number;\n    17→  status: 'draft' | 'sent' | 'paid' | 'cancelled';\n    18→  line_items?: LineItem[];\n    19→}\n    20→\n    21→export interface InvoiceCreateInput {\n    22→  customer_id: string;\n    23→  date: string;\n    24→  discount_rate: number;\n    25→  tax_rate: number;\n    26→  status?: 'draft' | 'sent' | 'paid' | 'cancelled';\n    27→  line_items: LineItem[];\n    28→}\n    29→\n    30→export interface InvoiceSummary {\n    31→  month: number;\n    32→  year: number;\n    33→  count: number;\n    34→  total_revenue: number;\n    35→}\n    36→\n    37→export interface CustomerReport {\n    38→  customer_id: string;\n    39→  invoice_count: number;\n    40→  total_spent: number;\n    41→  average_invoice: number;\n    42→}\n    43→"}]},"parent_tool_use_id":"toolu_017dDLuMoQwshyL4A8sKFMYR","session_id":"4d70e52e-62bb-4faf-a49a-489819420f65","uuid":"e9278f17-098e-44b0-a91c-43fa1a2a6af8"}
