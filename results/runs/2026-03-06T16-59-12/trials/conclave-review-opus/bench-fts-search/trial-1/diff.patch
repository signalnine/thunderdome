+      phrases.push(`"${inner}"`);
+    }
+    return '';
+  });
+  // Strip non-alphanumeric/non-Unicode-letter chars except spaces
+  const cleanedTerms = withoutPhrases.replace(/[^\p{L}\p{N}\s]/gu, ' ').trim();
+  const parts = [...phrases];
+  if (cleanedTerms) {
+    // Quote each individual term to neutralize FTS5 keyword operators (OR, AND, NOT, NEAR)
+    const quotedTerms = cleanedTerms
+      .split(/\s+/)
+      .filter(t => t.length > 0)
+      .map(t => `"${t}"`)
+      .join(' ');
+    parts.push(quotedTerms);
+  }
+  return parts.join(' ').trim();
