+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nq4yu6QuND8eDWTcdkzQxh","type":"tool_result","content":"     1→import { Router, Request, Response, NextFunction } from 'express';\n     2→import Database from 'better-sqlite3';\n     3→import { Note, NoteInput } from './models.js';\n     4→import { NotFoundError, ValidationError } from './errors.js';\n     5→\n     6→function sanitizeFtsQuery(q: string): string {\n     7→  // Remove FTS5 special operators/syntax chars to prevent syntax errors\n     8→  // Keep double-quoted phrases intact for phrase search, strip everything else problematic\n     9→  // First, extract quoted phrases\n    10→  const phrases: string[] = [];\n    11→  const withoutPhrases = q.replace(/\"([^\"]*)\"/g, (_match, inner) => {\n    12→    phrases.push(`\"${inner}\"`);\n    13→    return '';\n    14→  });\n    15→  // Strip all non-alphanumeric chars except spaces from non-phrase parts\n    16→  const cleanedTerms = withoutPhrases.replace(/[^a-zA-Z0-9\\s]/g, ' ').trim();\n    17→  const parts = [...phrases];\n    18→  if (cleanedTerms) {\n    19→    parts.push(cleanedTerms);\n    20→  }\n    21→  return parts.join(' ').trim();\n    22→}\n    23→\n    24→export function createRoutes(db: Database.Database): Router {\n    25→  const router = Router();\n    26→\n    27→  // GET /notes/search - Full-text search\n    28→  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    29→    try {\n    30→      const q = req.query.q as string | undefined;\n    31→      if (!q || q.trim() === '') {\n    32→        throw new ValidationError('Search query is required');\n    33→      }\n    34→\n    35→      const page = Math.max(1, parseInt(req.query.page as string) || 1);\n    36→      const perPage = 20;\n    37→      const offset = (page - 1) * perPage;\n    38→\n    39→      const sanitized = sanitizeFtsQuery(q);\n    40→      if (sanitized === '') {\n    41→        res.json({ results: [], total: 0, page, perPage });\n    42→        return;\n    43→      }\n    44→\n    45→      // Count total matches\n    46→      const countStmt = db.prepare(`\n    47→        SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?\n    48→      `);\n    49→      const { total } = countStmt.get(sanitized) as { total: number };\n    50→\n    51→      // Fetch results with BM25 ranking and snippets\n    52→      const searchStmt = db.prepare(`\n    53→        SELECT\n    54→          notes.id,\n    55→          notes.title,\n    56→          snippet(notes_fts, 1, '<mark>', '</mark>', '...', 32) as snippet,\n    57→          bm25(notes_fts) as rank\n    58→        FROM notes_fts\n    59→        JOIN notes ON notes.id = notes_fts.rowid\n    60→        WHERE notes_fts MATCH ?\n    61→        ORDER BY bm25(notes_fts)\n    62→        LIMIT ? OFFSET ?\n    63→      `);\n    64→      const results = searchStmt.all(sanitized, perPage, offset);\n    65→\n    66→      res.json({ results, total, page, perPage });\n    67→    } catch (err) {\n    68→      next(err);\n    69→    }\n    70→  });\n    71→\n    72→  // GET /notes/search/suggest - Autocomplete suggestions\n    73→  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n    74→    try {\n    75→      const q = req.query.q as string | undefined;\n    76→      if (!q || q.trim() === '') {\n    77→        throw new ValidationError('Search query is required');\n    78→      }\n    79→\n    80→      const sanitized = sanitizeFtsQuery(q);\n    81→      if (sanitized === '') {\n    82→        res.json({ results: [] });\n    83→        return;\n    84→      }\n    85→\n    86→      // Use prefix matching for autocomplete\n    87→      const prefixQuery = sanitized.split(/\\s+/).map(term => `\"${term}\"*`).join(' ');\n    88→\n    89→      const suggestStmt = db.prepare(`\n    90→        SELECT notes.id, notes.title\n    91→        FROM notes_fts\n    92→        JOIN notes ON notes.id = notes_fts.rowid\n    93→        WHERE notes_fts MATCH ?\n    94→        ORDER BY bm25(notes_fts)\n    95→        LIMIT 5\n    96→      `);\n    97→      const results = suggestStmt.all(prefixQuery);\n    98→\n    99→      res.json({ results });\n   100→    } catch (err) {\n   101→      next(err);\n   102→    }\n   103→  });\n   104→\n   105→  // GET /notes - List all notes (with optional tag filter)\n   106→  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n   107→    try {\n   108→      const tag = req.query.tag as string | undefined;\n   109→\n   110→      let notes: Note[];\n   111→      if (tag) {\n   112→        // Use a join with json_each for tag filtering\n   113→        const tagStmt = db.prepare(`\n   114→          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n   115→          WHERE json_each.value = ?\n   116→          ORDER BY created_at DESC\n   117→        `);\n   118→        notes = tagStmt.all(tag) as Note[];\n   119→      } else {\n   120→        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n   121→        notes = stmt.all() as Note[];\n   122→      }\n   123→\n   124→      res.json({ notes });\n   125→    } catch (err) {\n   126→      next(err);\n   127→    }\n   128→  });\n   129→\n   130→  // GET /notes/:id - Get single note\n   131→  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   132→    try {\n   133→      const id = parseInt(req.params.id);\n   134→      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n   135→      const note = stmt.get(id) as Note | undefined;\n   136→\n   137→      if (!note) {\n   138→        throw new NotFoundError('Note not found');\n   139→      }\n   140→\n   141→      res.json({ note });\n   142→    } catch (err) {\n   143→      next(err);\n   144→    }\n   145→  });\n   146→\n   147→  // POST /notes - Create note\n   148→  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n   149→    try {\n   150→      const input = req.body as NoteInput;\n   151→\n   152→      if (!input.title || input.title.trim() === '') {\n   153→        throw new ValidationError('Title is required');\n   154→      }\n   155→      if (!input.body || input.body.trim() === '') {\n   156→        throw new ValidationError('Body is required');\n   157→      }\n   158→\n   159→      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n   160→      const stmt = db.prepare(`\n   161→        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n   162→      `);\n   163→      const result = stmt.run(input.title, input.body, tags);\n   164→\n   165→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n   166→      res.status(201).json({ note });\n   167→    } catch (err) {\n   168→      next(err);\n   169→    }\n   170→  });\n   171→\n   172→  // PUT /notes/:id - Update note\n   173→  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   174→    try {\n   175→      const id = parseInt(req.params.id);\n   176→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   177→\n   178→      if (!existing) {\n   179→        throw new NotFoundError('Note not found');\n   180→      }\n   181→\n   182→      const input = req.body as Partial<NoteInput>;\n   183→      const title = input.title ?? existing.title;\n   184→      const body = input.body ?? existing.body;\n   185→      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n   186→\n   187→      const stmt = db.prepare(`\n   188→        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n   189→        WHERE id = ?\n   190→      `);\n   191→      stmt.run(title, body, tags, id);\n   192→\n   193→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n   194→      res.json({ note });\n   195→    } catch (err) {\n   196→      next(err);\n   197→    }\n   198→  });\n   199→\n   200→  // DELETE /notes/:id - Delete note\n   201→  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   202→    try {\n   203→      const id = parseInt(req.params.id);\n   204→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   205→\n   206→      if (!existing) {\n   207→        throw new NotFoundError('Note not found');\n   208→      }\n   209→\n   210→      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n   211→      res.status(204).send();\n   212→    } catch (err) {\n   213→      next(err);\n   214→    }\n   215→  });\n   216→\n   217→  return router;\n   218→}\n   219→"}]},"parent_tool_use_id":"toolu_016fJKMYDJYDpKX4EwwBjD11","session_id":"337462a2-9445-47f8-b33b-23f85d1a74c0","uuid":"248a0f83-7df8-41ff-a08b-d75b95981922"}
