+import express from 'express';
+import { createServer, type Server as HttpServer } from 'http';
+import type Database from 'better-sqlite3';
+import { createDb } from './db.js';
+import { createRouter } from './routes.js';
+import { createCollaborationServer, type CollaborationServer } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  httpServer: HttpServer;
+  db: Database.Database;
+  collaboration: CollaborationServer;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDb(dbPath);
+  const app = express();
+  const router = createRouter(db);
+
+  app.use('/api', router);
+
+  // Health check
+  app.get('/health', (_req, res) => {
+    res.json({ status: 'ok' });
+  });
+
+  const httpServer = createServer(app);
+  const collaboration = createCollaborationServer(httpServer, db);
+
+  return {
+    app,
+    httpServer,
+    db,
+    collaboration,
+    start(port = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        httpServer.listen(port, () => {
+          const addr = httpServer.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Failed to get server address'));
+          }
+        });
+        httpServer.once('error', reject);
+      });
+    },
+    stop(): Promise<void> {
+      return new Promise((resolve, reject) => {
+        collaboration.close();
+
+        // Close all remaining socket connections on the HTTP server
+        httpServer.close((err) => {
+          db.close();
+          if (err) reject(err);
+          else resolve();
+        });
+
+        // Force-close all open connections so the server can shut down quickly
+        httpServer.closeAllConnections?.();
+      });
+    },
+  };
+}
