+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019h5SqyBfBJH3pKH6Y7DBfH","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import type { Server as HttpServer } from 'http';\n     3→import type Database from 'better-sqlite3';\n     4→import { apply, transform, baseLength, type Op } from './ot.js';\n     5→import { getDocument, getLatestVersion, addVersion, updateDocumentContent, getVersions } from './db.js';\n     6→\n     7→interface ClientConnection {\n     8→  ws: WebSocket;\n     9→  clientId: string;\n    10→  docId: string;\n    11→}\n    12→\n    13→interface DocumentSession {\n    14→  docId: string;\n    15→  clients: Map<string, ClientConnection>;\n    16→  /** Server's current document content */\n    17→  content: string;\n    18→  /** Current version number */\n    19→  version: number;\n    20→  /** History of operations applied, indexed by version they produced */\n    21→  history: Op[];\n    22→}\n    23→\n    24→export interface CollaborationServer {\n    25→  wss: WebSocketServer;\n    26→  sessions: Map<string, DocumentSession>;\n    27→  close(): void;\n    28→}\n    29→\n    30→/**\n    31→ * Message types from client to server:\n    32→ * - { type: 'operation', version: number, ops: Op, clientId: string }\n    33→ *\n    34→ * Message types from server to client:\n    35→ * - { type: 'sync', content: string, version: number, clientId: string }\n    36→ * - { type: 'operation', ops: Op, version: number, clientId: string }\n    37→ * - { type: 'ack', version: number }\n    38→ * - { type: 'error', message: string }\n    39→ */\n    40→\n    41→function sendJson(ws: WebSocket, data: unknown): void {\n    42→  if (ws.readyState === WebSocket.OPEN) {\n    43→    ws.send(JSON.stringify(data));\n    44→  }\n    45→}\n    46→\n    47→function getOrCreateSession(db: Database.Database, sessions: Map<string, DocumentSession>, docId: string): DocumentSession | null {\n    48→  let session = sessions.get(docId);\n    49→  if (session) return session;\n    50→\n    51→  const doc = getDocument(db, docId);\n    52→  if (!doc) return null;\n    53→\n    54→  const version = getLatestVersion(db, docId);\n    55→\n    56→  // Load operation history from DB\n    57→  const versions = getVersions(db, docId);\n    58→  const history: Op[] = [];\n    59→  for (const v of versions) {\n    60→    if (v.operation) {\n    61→      history.push(JSON.parse(v.operation) as Op);\n    62→    }\n    63→  }\n    64→\n    65→  session = {\n    66→    docId,\n    67→    clients: new Map(),\n    68→    content: doc.content,\n    69→    version,\n    70→    history,\n    71→  };\n    72→  sessions.set(docId, session);\n    73→  return session;\n    74→}\n    75→\n    76→function validateOp(ops: Op, expectedBaseLen: number): string | null {\n    77→  if (!Array.isArray(ops)) return 'ops must be an array';\n    78→  for (const c of ops) {\n    79→    if (typeof c !== 'number' && typeof c !== 'string') {\n    80→      return 'each op component must be a number or string';\n    81→    }\n    82→  }\n    83→  const bl = baseLength(ops);\n    84→  if (bl !== expectedBaseLen) {\n    85→    return `operation base length (${bl}) does not match expected (${expectedBaseLen})`;\n    86→  }\n    87→  return null;\n    88→}\n    89→\n    90→export function createCollaborationServer(httpServer: HttpServer, db: Database.Database): CollaborationServer {\n    91→  const sessions = new Map<string, DocumentSession>();\n    92→\n    93→  const wss = new WebSocketServer({ server: httpServer });\n    94→\n    95→  wss.on('connection', (ws, req) => {\n    96→    // Extract document ID from URL path: /ws/:docId\n    97→    const url = req.url ?? '';\n    98→    const match = url.match(/^\\/ws\\/([^/?]+)/);\n    99→    if (!match) {\n   100→      sendJson(ws, { type: 'error', message: 'Invalid URL. Expected /ws/:docId' });\n   101→      ws.close();\n   102→      return;\n   103→    }\n   104→\n   105→    const docId = match[1];\n   106→    const clientId = Math.random().toString(36).substring(2, 15);\n   107→\n   108→    const session = getOrCreateSession(db, sessions, docId);\n   109→    if (!session) {\n   110→      sendJson(ws, { type: 'error', message: 'Document not found' });\n   111→      ws.close();\n   112→      return;\n   113→    }\n   114→\n   115→    const conn: ClientConnection = { ws, clientId, docId };\n   116→    session.clients.set(clientId, conn);\n   117→\n   118→    // Send sync message with current state\n   119→    sendJson(ws, {\n   120→      type: 'sync',\n   121→      content: session.content,\n   122→      version: session.version,\n   123→      clientId,\n   124→    });\n   125→\n   126→    ws.on('message', (raw) => {\n   127→      let msg: { type: string; version?: number; ops?: Op; clientId?: string };\n   128→      try {\n   129→        msg = JSON.parse(raw.toString());\n   130→      } catch {\n   131→        sendJson(ws, { type: 'error', message: 'Invalid JSON' });\n   132→        return;\n   133→      }\n   134→\n   135→      if (msg.type !== 'operation') {\n   136→        sendJson(ws, { type: 'error', message: `Unknown message type: ${msg.type}` });\n   137→        return;\n   138→      }\n   139→\n   140→      if (typeof msg.version !== 'number' || !Array.isArray(msg.ops)) {\n   141→        sendJson(ws, { type: 'error', message: 'operation message must have version (number) and ops (array)' });\n   142→        return;\n   143→      }\n   144→\n   145→      const clientVersion = msg.version;\n   146→      const clientOps = msg.ops;\n   147→\n   148→      // The client's operation was generated against `clientVersion`.\n   149→      // The server is at `session.version`. We need to transform the\n   150→      // client op against all ops that happened between clientVersion\n   151→      // and session.version.\n   152→\n   153→      if (clientVersion < 0 || clientVersion > session.version) {\n   154→        sendJson(ws, { type: 'error', message: `Invalid version: ${clientVersion}. Server is at version ${session.version}` });\n   155→        return;\n   156→      }\n   157→\n   158→      // Determine correct base length for this client version\n   159→      // The client's op should be against the document as it was at clientVersion\n   160→      let expectedBaseLen: number;\n   161→      if (clientVersion === session.version) {\n   162→        expectedBaseLen = session.content.length;\n   163→      } else {\n   164→        // We need to figure out what the doc length was at clientVersion\n   165→        // We can reconstruct this from the version history in the DB\n   166→        const versionRows = getVersions(db, docId);\n   167→        const vRow = versionRows.find(v => v.version === clientVersion);\n   168→        if (vRow) {\n   169→          expectedBaseLen = vRow.content.length;\n   170→        } else {\n   171→          expectedBaseLen = session.content.length;\n   172→        }\n   173→      }\n   174→\n   175→      const validationError = validateOp(clientOps, expectedBaseLen);\n   176→      if (validationError) {\n   177→        sendJson(ws, { type: 'error', message: validationError });\n   178→        return;\n   179→      }\n   180→\n   181→      // Transform against concurrent operations\n   182→      let transformedOps: Op = clientOps;\n   183→      try {\n   184→          for (let i = clientVersion; i < session.version; i++) {\n   185→          const histIdx = i - (session.version - session.history.length);\n   186→          if (histIdx < 0 || histIdx >= session.history.length) {\n   187→            sendJson(ws, { type: 'error', message: 'Cannot transform: missing history' });\n   188→            return;\n   189→          }\n   190→          const serverOp = session.history[histIdx];\n   191→          const [aPrime] = transform(transformedOps, serverOp);\n   192→          transformedOps = aPrime;\n   193→        }\n   194→      } catch (err) {\n   195→        sendJson(ws, { type: 'error', message: `Transform error: ${(err as Error).message}` });\n   196→        return;\n   197→      }\n   198→\n   199→      // Apply the transformed operation\n   200→      let newContent: string;\n   201→      try {\n   202→        newContent = apply(session.content, transformedOps);\n   203→      } catch (err) {\n   204→        sendJson(ws, { type: 'error', message: `Apply error: ${(err as Error).message}` });\n   205→        return;\n   206→      }\n   207→\n   208→      // Commit\n   209→      session.version++;\n   210→      session.content = newContent;\n   211→      session.history.push(transformedOps);\n   212→\n   213→      // Persist\n   214→      addVersion(db, docId, session.version, newContent, JSON.stringify(transformedOps));\n   215→      updateDocumentContent(db, docId, newContent);\n   216→\n   217→      // Ack the sender\n   218→      sendJson(ws, { type: 'ack', version: session.version });\n   219→\n   220→      // Broadcast to other clients\n   221→      for (const [cid, client] of session.clients) {\n   222→        if (cid === clientId) continue;\n   223→        sendJson(client.ws, {\n   224→          type: 'operation',\n   225→          ops: transformedOps,\n   226→          version: session.version,\n   227→          clientId,\n   228→        });\n   229→      }\n   230→    });\n   231→\n   232→    ws.on('close', () => {\n   233→      session.clients.delete(clientId);\n   234→      // If no more clients, we can optionally keep the session for fast reconnect\n   235→      // but we'll clean it up to save memory for tests\n   236→      if (session.clients.size === 0) {\n   237→        sessions.delete(docId);\n   238→      }\n   239→    });\n   240→  });\n   241→\n   242→  return {\n   243→    wss,\n   244→    sessions,\n   245→    close() {\n   246→      for (const session of sessions.values()) {\n   247→        for (const client of session.clients.values()) {\n   248→          client.ws.close();\n   249→        }\n   250→      }\n   251→      sessions.clear();\n   252→      wss.close();\n   253→    },\n   254→  };\n   255→}\n   256→"}]},"parent_tool_use_id":"toolu_01Fuofs2rScuGjdhah9yAxpG","session_id":"60613535-c5c1-4ce6-8418-7c44b8964a95","uuid":"c55adf93-869f-4200-8799-129ecabea089"}
