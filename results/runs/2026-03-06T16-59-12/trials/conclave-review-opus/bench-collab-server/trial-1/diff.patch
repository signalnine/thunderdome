+/**
+ * Operational Transformation engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ *   - number > 0: retain that many characters
+ *   - string:     insert that string
+ *   - number < 0: delete abs(n) characters
+ *
+ * The "base length" of an op is the length of the document it applies to.
+ * The "target length" is the length of the document after applying it.
+ */
+
+export type OpComponent = number | string;
+export type Op = OpComponent[];
+
+// ---------------------------------------------------------------------------
+// Helpers
+// ---------------------------------------------------------------------------
+
+export function baseLength(op: Op): number {
+  let n = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) n += c;        // retain
+      else n += Math.abs(c);     // delete
+    }
+    // inserts don't consume base characters
+  }
+  return n;
+}
+
+export function targetLength(op: Op): number {
+  let n = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) n += c;        // retain
+      // deletes don't produce characters
+    } else {
+      n += c.length;             // insert
+    }
+  }
+  return n;
+}
+
+/** Normalize an op: merge adjacent same-type components, remove no-ops. */
+export function normalize(op: Op): Op {
+  const result: Op = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+    if (result.length === 0) { result.push(c); continue; }
+    const last = result[result.length - 1];
+    if (typeof c === 'number' && typeof last === 'number') {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = (last as number) + (c as number);
+        continue;
+      }
+    }
+    if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+      continue;
+    }
+    result.push(c);
+  }
+  return result;
+}
+
+// ---------------------------------------------------------------------------
+// Apply
+// ---------------------------------------------------------------------------
+
+/** Apply an operation to a document string, returning the new string. */
+export function apply(doc: string, op: Op): string {
+  const bl = baseLength(op);
+  if (bl !== doc.length) {
+    throw new Error(`Operation base length (${bl}) does not match document length (${doc.length})`);
+  }
+  let pos = 0;
+  let result = '';
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        // retain
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        pos += Math.abs(c);
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+  return result;
+}
+
+// ---------------------------------------------------------------------------
+// Transform  (the core of OT)
+// ---------------------------------------------------------------------------
+
+/**
+ * Transform two concurrent operations a and b (both against the same document)
+ * so that apply(apply(doc, a), b') === apply(apply(doc, b), a').
+ *
+ * Returns [a', b'] where a' is a transformed against b and b' is b
+ * transformed against a.
+ *
+ * Priority: when both insert at the same position, `a` goes first (a has
+ * priority).
+ */
+export function transform(a: Op, b: Op): [Op, Op] {
+  if (baseLength(a) !== baseLength(b)) {
+    throw new Error('transform: operations have different base lengths');
+  }
+
+  const aPrime: Op = [];
+  const bPrime: Op = [];
+
+  // Iterators over components
+  let ia = 0;
+  let ib = 0;
+  let oa: OpComponent | null = a[ia] ?? null;
+  let ob: OpComponent | null = b[ib] ?? null;
+
+  const nextA = (): void => { ia++; oa = a[ia] ?? null; };
+  const nextB = (): void => { ib++; ob = b[ib] ?? null; };
+
+  while (oa !== null || ob !== null) {
+    // Insert in a has priority
+    if (typeof oa === 'string') {
+      aPrime.push(oa);
+      bPrime.push(oa.length);  // b' must retain a's insert
+      nextA();
+      continue;
+    }
+    // Insert in b
+    if (typeof ob === 'string') {
+      aPrime.push(ob.length);  // a' must retain b's insert
+      bPrime.push(ob);
+      nextB();
+      continue;
+    }
+
+    if (oa === null || ob === null) {
+      throw new Error('transform: operations have mismatched lengths');
+    }
+
+    // Both are numbers (retain or delete)
+    const aIsRetain = (oa as number) > 0;
+    const bIsRetain = (ob as number) > 0;
+    const aLen = Math.abs(oa as number);
+    const bLen = Math.abs(ob as number);
+
+    if (aIsRetain && bIsRetain) {
+      // Both retain
+      const min = Math.min(aLen, bLen);
+      aPrime.push(min);
+      bPrime.push(min);
+      if (aLen === bLen) { nextA(); nextB(); }
+      else if (aLen < bLen) { nextA(); ob = bLen - aLen; }
+      else { nextB(); oa = aLen - bLen; }
+    } else if (!aIsRetain && !bIsRetain) {
+      // Both delete the same region
+      // Neither prime needs to delete – the other already did
+      if (aLen === bLen) { nextA(); nextB(); }
+      else if (aLen < bLen) { nextA(); ob = -(bLen - aLen); }
+      else { nextB(); oa = -(aLen - bLen); }
+    } else if (!aIsRetain && bIsRetain) {
+      // a deletes, b retains
+      const min = Math.min(aLen, bLen);
+      aPrime.push(-min);
+      // b' doesn't retain chars that a deleted
+      if (aLen === bLen) { nextA(); nextB(); }
+      else if (aLen < bLen) { nextA(); ob = bLen - aLen; }
+      else { nextB(); oa = -(aLen - bLen); }
+    } else {
+      // a retains, b deletes
+      const min = Math.min(aLen, bLen);
+      // a' doesn't retain chars that b deleted
+      bPrime.push(-min);
+      if (aLen === bLen) { nextA(); nextB(); }
+      else if (aLen < bLen) { nextA(); ob = -(bLen - aLen); }
+      else { nextB(); oa = aLen - bLen; }
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+// ---------------------------------------------------------------------------
+// Compose  (combine two sequential operations into one)
+// ---------------------------------------------------------------------------
+
+/** Compose op a followed by op b into a single operation. */
+export function compose(a: Op, b: Op): Op {
+  if (targetLength(a) !== baseLength(b)) {
+    throw new Error('compose: target length of a does not match base length of b');
+  }
+
+  const result: Op = [];
+  let ia = 0;
+  let ib = 0;
+  let oa: OpComponent | null = a[ia] ?? null;
+  let ob: OpComponent | null = b[ib] ?? null;
+
+  const nextA = (): void => { ia++; oa = a[ia] ?? null; };
+  const nextB = (): void => { ib++; ob = b[ib] ?? null; };
+
+  const push = (c: OpComponent): void => { result.push(c); };
+
+  while (oa !== null || ob !== null) {
+    // Delete in a
+    if (typeof oa === 'number' && oa < 0) {
+      push(oa);
+      nextA();
+      continue;
+    }
+    // Insert in b
+    if (typeof ob === 'string') {
+      push(ob);
+      nextB();
+      continue;
+    }
+
+    if (oa === null || ob === null) {
+      throw new Error('compose: mismatched lengths');
+    }
+
+    // Both are retain or a is insert
+    if (typeof oa === 'string') {
+      // a inserts, b consumes
+      if (typeof ob === 'number' && ob > 0) {
+        const aLen: number = oa.length;
+        const bLen: number = ob;
+        const min = Math.min(aLen, bLen);
+        push(oa.slice(0, min));
+        if (aLen === bLen) { nextA(); nextB(); }
+        else if (aLen < bLen) { nextA(); ob = bLen - aLen; }
+        else { nextB(); oa = oa.slice(min); }
+      } else {
+        // b deletes what a inserted
+        const aLen: number = oa.length;
+        const bLen: number = Math.abs(ob as number);
+        const min = Math.min(aLen, bLen);
+        // These cancel out
+        if (aLen === bLen) { nextA(); nextB(); }
+        else if (aLen < bLen) { nextA(); ob = -(bLen - aLen); }
+        else { nextB(); oa = oa.slice(min); }
+      }
+    } else {
+      // a is retain (positive number)
+      const aLen: number = oa as number;
+      if (typeof ob === 'number' && ob > 0) {
+        const bLen: number = ob;
+        const min = Math.min(aLen, bLen);
+        push(min);
+        if (aLen === bLen) { nextA(); nextB(); }
+        else if (aLen < bLen) { nextA(); ob = bLen - aLen; }
+        else { nextB(); oa = aLen - bLen; }
+      } else {
+        // b deletes
+        const bLen: number = Math.abs(ob as number);
+        const min = Math.min(aLen, bLen);
+        push(-min);
+        if (aLen === bLen) { nextA(); nextB(); }
+        else if (aLen < bLen) { nextA(); ob = -(bLen - aLen); }
+        else { nextB(); oa = aLen - bLen; }
+      }
+    }
+  }
+
+  return normalize(result);
+}
+
+// ---------------------------------------------------------------------------
+// Convenience builders
+// ---------------------------------------------------------------------------
+
+/** Build an insert operation at a given position in a document of given length. */
+export function buildInsert(docLen: number, pos: number, text: string): Op {
+  if (pos < 0 || pos > docLen) {
+    throw new Error(`buildInsert: pos ${pos} out of range [0, ${docLen}]`);
+  }
+  const op: Op = [];
+  if (pos > 0) op.push(pos);
+  op.push(text);
+  if (docLen - pos > 0) op.push(docLen - pos);
+  return normalize(op);
+}
+
+/** Build a delete operation at a given position in a document of given length. */
+export function buildDelete(docLen: number, pos: number, count: number): Op {
+  if (pos < 0 || pos > docLen) {
+    throw new Error(`buildDelete: pos ${pos} out of range [0, ${docLen}]`);
+  }
+  if (count < 0 || pos + count > docLen) {
+    throw new Error(`buildDelete: count ${count} out of range at pos ${pos} for docLen ${docLen}`);
+  }
+  const op: Op = [];
+  if (pos > 0) op.push(pos);
+  op.push(-count);
+  if (docLen - pos - count > 0) op.push(docLen - pos - count);
+  return normalize(op);
+}
