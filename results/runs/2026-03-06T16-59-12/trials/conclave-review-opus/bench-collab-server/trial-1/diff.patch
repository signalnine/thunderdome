+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sd8LTgiXWm9ts3vFBy8Sri","type":"tool_result","content":"     1→/**\n     2→ * Operational Transformation engine for collaborative text editing.\n     3→ *\n     4→ * Operations are arrays of components:\n     5→ *   - number > 0: retain that many characters\n     6→ *   - string:     insert that string\n     7→ *   - number < 0: delete abs(n) characters\n     8→ *\n     9→ * The \"base length\" of an op is the length of the document it applies to.\n    10→ * The \"target length\" is the length of the document after applying it.\n    11→ */\n    12→\n    13→export type OpComponent = number | string;\n    14→export type Op = OpComponent[];\n    15→\n    16→export interface Operation {\n    17→  docId: string;\n    18→  version: number;  // the document version this op was created against\n    19→  ops: Op;\n    20→  clientId: string;\n    21→}\n    22→\n    23→// ---------------------------------------------------------------------------\n    24→// Helpers\n    25→// ---------------------------------------------------------------------------\n    26→\n    27→export function baseLength(op: Op): number {\n    28→  let n = 0;\n    29→  for (const c of op) {\n    30→    if (typeof c === 'number') {\n    31→      if (c > 0) n += c;        // retain\n    32→      else n += Math.abs(c);     // delete\n    33→    }\n    34→    // inserts don't consume base characters\n    35→  }\n    36→  return n;\n    37→}\n    38→\n    39→export function targetLength(op: Op): number {\n    40→  let n = 0;\n    41→  for (const c of op) {\n    42→    if (typeof c === 'number') {\n    43→      if (c > 0) n += c;        // retain\n    44→      // deletes don't produce characters\n    45→    } else {\n    46→      n += c.length;             // insert\n    47→    }\n    48→  }\n    49→  return n;\n    50→}\n    51→\n    52→/** Normalize an op: merge adjacent same-type components, remove no-ops. */\n    53→export function normalize(op: Op): Op {\n    54→  const result: Op = [];\n    55→  for (const c of op) {\n    56→    if (typeof c === 'number' && c === 0) continue;\n    57→    if (typeof c === 'string' && c === '') continue;\n    58→    if (result.length === 0) { result.push(c); continue; }\n    59→    const last = result[result.length - 1];\n    60→    if (typeof c === 'number' && typeof last === 'number') {\n    61→      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {\n    62→        result[result.length - 1] = (last as number) + (c as number);\n    63→        continue;\n    64→      }\n    65→    }\n    66→    if (typeof c === 'string' && typeof last === 'string') {\n    67→      result[result.length - 1] = last + c;\n    68→      continue;\n    69→    }\n    70→    result.push(c);\n    71→  }\n    72→  return result;\n    73→}\n    74→\n    75→// ---------------------------------------------------------------------------\n    76→// Apply\n    77→// ---------------------------------------------------------------------------\n    78→\n    79→/** Apply an operation to a document string, returning the new string. */\n    80→export function apply(doc: string, op: Op): string {\n    81→  const bl = baseLength(op);\n    82→  if (bl !== doc.length) {\n    83→    throw new Error(`Operation base length (${bl}) does not match document length (${doc.length})`);\n    84→  }\n    85→  let pos = 0;\n    86→  let result = '';\n    87→  for (const c of op) {\n    88→    if (typeof c === 'number') {\n    89→      if (c > 0) {\n    90→        // retain\n    91→        result += doc.slice(pos, pos + c);\n    92→        pos += c;\n    93→      } else {\n    94→        // delete\n    95→        pos += Math.abs(c);\n    96→      }\n    97→    } else {\n    98→      // insert\n    99→      result += c;\n   100→    }\n   101→  }\n   102→  return result;\n   103→}\n   104→\n   105→// ---------------------------------------------------------------------------\n   106→// Transform  (the core of OT)\n   107→// ---------------------------------------------------------------------------\n   108→\n   109→/**\n   110→ * Transform two concurrent operations a and b (both against the same document)\n   111→ * so that apply(apply(doc, a), b') === apply(apply(doc, b), a').\n   112→ *\n   113→ * Returns [a', b'] where a' is a transformed against b and b' is b\n   114→ * transformed against a.\n   115→ *\n   116→ * Priority: when both insert at the same position, `a` goes first (a has\n   117→ * priority).\n   118→ */\n   119→export function transform(a: Op, b: Op): [Op, Op] {\n   120→  if (baseLength(a) !== baseLength(b)) {\n   121→    throw new Error('transform: operations have different base lengths');\n   122→  }\n   123→\n   124→  const aPrime: Op = [];\n   125→  const bPrime: Op = [];\n   126→\n   127→  // Iterators over components\n   128→  let ia = 0;\n   129→  let ib = 0;\n   130→  let oa: OpComponent | null = a[ia] ?? null;\n   131→  let ob: OpComponent | null = b[ib] ?? null;\n   132→\n   133→  const nextA = (): void => { ia++; oa = a[ia] ?? null; };\n   134→  const nextB = (): void => { ib++; ob = b[ib] ?? null; };\n   135→\n   136→  while (oa !== null || ob !== null) {\n   137→    // Insert in a has priority\n   138→    if (typeof oa === 'string') {\n   139→      aPrime.push(oa);\n   140→      bPrime.push(oa.length);  // b' must retain a's insert\n   141→      nextA();\n   142→      continue;\n   143→    }\n   144→    // Insert in b\n   145→    if (typeof ob === 'string') {\n   146→      aPrime.push(ob.length);  // a' must retain b's insert\n   147→      bPrime.push(ob);\n   148→      nextB();\n   149→      continue;\n   150→    }\n   151→\n   152→    if (oa === null || ob === null) {\n   153→      throw new Error('transform: operations have mismatched lengths');\n   154→    }\n   155→\n   156→    // Both are numbers (retain or delete)\n   157→    const aIsRetain = (oa as number) > 0;\n   158→    const bIsRetain = (ob as number) > 0;\n   159→    const aLen = Math.abs(oa as number);\n   160→    const bLen = Math.abs(ob as number);\n   161→\n   162→    if (aIsRetain && bIsRetain) {\n   163→      // Both retain\n   164→      const min = Math.min(aLen, bLen);\n   165→      aPrime.push(min);\n   166→      bPrime.push(min);\n   167→      if (aLen === bLen) { nextA(); nextB(); }\n   168→      else if (aLen < bLen) { nextA(); ob = bLen - aLen; }\n   169→      else { nextB(); oa = aLen - bLen; }\n   170→    } else if (!aIsRetain && !bIsRetain) {\n   171→      // Both delete the same region\n   172→      // Neither prime needs to delete – the other already did\n   173→      if (aLen === bLen) { nextA(); nextB(); }\n   174→      else if (aLen < bLen) { nextA(); ob = -(bLen - aLen); }\n   175→      else { nextB(); oa = -(aLen - bLen); }\n   176→    } else if (!aIsRetain && bIsRetain) {\n   177→      // a deletes, b retains\n   178→      const min = Math.min(aLen, bLen);\n   179→      aPrime.push(-min);\n   180→      // b' doesn't retain chars that a deleted\n   181→      if (aLen === bLen) { nextA(); nextB(); }\n   182→      else if (aLen < bLen) { nextA(); ob = bLen - aLen; }\n   183→      else { nextB(); oa = -(aLen - bLen); }\n   184→    } else {\n   185→      // a retains, b deletes\n   186→      const min = Math.min(aLen, bLen);\n   187→      // a' doesn't retain chars that b deleted\n   188→      bPrime.push(-min);\n   189→      if (aLen === bLen) { nextA(); nextB(); }\n   190→      else if (aLen < bLen) { nextA(); ob = -(bLen - aLen); }\n   191→      else { nextB(); oa = aLen - bLen; }\n   192→    }\n   193→  }\n   194→\n   195→  return [normalize(aPrime), normalize(bPrime)];\n   196→}\n   197→\n   198→// ---------------------------------------------------------------------------\n   199→// Compose  (combine two sequential operations into one)\n   200→// ---------------------------------------------------------------------------\n   201→\n   202→/** Compose op a followed by op b into a single operation. */\n   203→export function compose(a: Op, b: Op): Op {\n   204→  if (targetLength(a) !== baseLength(b)) {\n   205→    throw new Error('compose: target length of a does not match base length of b');\n   206→  }\n   207→\n   208→  const result: Op = [];\n   209→  let ia = 0;\n   210→  let ib = 0;\n   211→  let oa: OpComponent | null = a[ia] ?? null;\n   212→  let ob: OpComponent | null = b[ib] ?? null;\n   213→\n   214→  const nextA = (): void => { ia++; oa = a[ia] ?? null; };\n   215→  const nextB = (): void => { ib++; ob = b[ib] ?? null; };\n   216→\n   217→  const push = (c: OpComponent): void => { result.push(c); };\n   218→\n   219→  while (oa !== null || ob !== null) {\n   220→    // Delete in a\n   221→    if (typeof oa === 'number' && oa < 0) {\n   222→      push(oa);\n   223→      nextA();\n   224→      continue;\n   225→    }\n   226→    // Insert in b\n   227→    if (typeof ob === 'string') {\n   228→      push(ob);\n   229→      nextB();\n   230→      continue;\n   231→    }\n   232→\n   233→    if (oa === null || ob === null) {\n   234→      throw new Error('compose: mismatched lengths');\n   235→    }\n   236→\n   237→    // Both are retain or a is insert\n   238→    if (typeof oa === 'string') {\n   239→      // a inserts, b consumes\n   240→      if (typeof ob === 'number' && ob > 0) {\n   241→        const aLen: number = oa.length;\n   242→        const bLen: number = ob;\n   243→        const min = Math.min(aLen, bLen);\n   244→        push(oa.slice(0, min));\n   245→        if (aLen === bLen) { nextA(); nextB(); }\n   246→        else if (aLen < bLen) { nextA(); ob = bLen - aLen; }\n   247→        else { nextB(); oa = oa.slice(min); }\n   248→      } else {\n   249→        // b deletes what a inserted\n   250→        const aLen: number = oa.length;\n   251→        const bLen: number = Math.abs(ob as number);\n   252→        const min = Math.min(aLen, bLen);\n   253→        // These cancel out\n   254→        if (aLen === bLen) { nextA(); nextB(); }\n   255→        else if (aLen < bLen) { nextA(); ob = -(bLen - aLen); }\n   256→        else { nextB(); oa = oa.slice(min); }\n   257→      }\n   258→    } else {\n   259→      // a is retain (positive number)\n   260→      const aLen: number = oa as number;\n   261→      if (typeof ob === 'number' && ob > 0) {\n   262→        const bLen: number = ob;\n   263→        const min = Math.min(aLen, bLen);\n   264→        push(min);\n   265→        if (aLen === bLen) { nextA(); nextB(); }\n   266→        else if (aLen < bLen) { nextA(); ob = bLen - aLen; }\n   267→        else { nextB(); oa = aLen - bLen; }\n   268→      } else {\n   269→        // b deletes\n   270→        const bLen: number = Math.abs(ob as number);\n   271→        const min = Math.min(aLen, bLen);\n   272→        push(-min);\n   273→        if (aLen === bLen) { nextA(); nextB(); }\n   274→        else if (aLen < bLen) { nextA(); ob = -(bLen - aLen); }\n   275→        else { nextB(); oa = aLen - bLen; }\n   276→      }\n   277→    }\n   278→  }\n   279→\n   280→  return normalize(result);\n   281→}\n   282→\n   283→// ---------------------------------------------------------------------------\n   284→// Convenience builders\n   285→// ---------------------------------------------------------------------------\n   286→\n   287→/** Build an insert operation at a given position in a document of given length. */\n   288→export function buildInsert(docLen: number, pos: number, text: string): Op {\n   289→  const op: Op = [];\n   290→  if (pos > 0) op.push(pos);\n   291→  op.push(text);\n   292→  if (docLen - pos > 0) op.push(docLen - pos);\n   293→  return normalize(op);\n   294→}\n   295→\n   296→/** Build a delete operation at a given position in a document of given length. */\n   297→export function buildDelete(docLen: number, pos: number, count: number): Op {\n   298→  const op: Op = [];\n   299→  if (pos > 0) op.push(pos);\n   300→  op.push(-count);\n   301→  if (docLen - pos - count > 0) op.push(docLen - pos - count);\n   302→  return normalize(op);\n   303→}\n   304→"}]},"parent_tool_use_id":"toolu_01Fuofs2rScuGjdhah9yAxpG","session_id":"60613535-c5c1-4ce6-8418-7c44b8964a95","uuid":"d52495ec-9917-465c-9477-a8bcc4ad9956"}
