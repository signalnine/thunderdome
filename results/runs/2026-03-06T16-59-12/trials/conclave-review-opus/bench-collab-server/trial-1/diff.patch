+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NT4NMae4ag3VbcLW92HxYo","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { readFileSync } from 'fs';\n     3→import { resolve, dirname } from 'path';\n     4→import { fileURLToPath } from 'url';\n     5→\n     6→const __dirname = dirname(fileURLToPath(import.meta.url));\n     7→\n     8→export interface DocRow {\n     9→  id: string;\n    10→  title: string;\n    11→  content: string;\n    12→  created_at: string;\n    13→  updated_at: string;\n    14→}\n    15→\n    16→export interface VersionRow {\n    17→  id: number;\n    18→  document_id: string;\n    19→  version: number;\n    20→  content: string;\n    21→  operation: string | null;\n    22→  created_at: string;\n    23→}\n    24→\n    25→export function createDb(dbPath?: string): Database.Database {\n    26→  const db = new Database(dbPath ?? ':memory:');\n    27→  db.pragma('journal_mode = WAL');\n    28→  db.pragma('foreign_keys = ON');\n    29→\n    30→  const schemaPath = resolve(__dirname, '..', 'schema.sql');\n    31→  const schema = readFileSync(schemaPath, 'utf-8');\n    32→  db.exec(schema);\n    33→\n    34→  return db;\n    35→}\n    36→\n    37→// ---------------------------------------------------------------------------\n    38→// Document CRUD\n    39→// ---------------------------------------------------------------------------\n    40→\n    41→export function createDocument(db: Database.Database, id: string, title: string, content: string): DocRow {\n    42→  const stmt = db.prepare(\n    43→    `INSERT INTO documents (id, title, content) VALUES (?, ?, ?) RETURNING *`\n    44→  );\n    45→  const row = stmt.get(id, title, content) as DocRow;\n    46→\n    47→  // Create initial version\n    48→  db.prepare(\n    49→    `INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, NULL)`\n    50→  ).run(id, content);\n    51→\n    52→  return row;\n    53→}\n    54→\n    55→export function getDocument(db: Database.Database, id: string): DocRow | undefined {\n    56→  return db.prepare(`SELECT * FROM documents WHERE id = ?`).get(id) as DocRow | undefined;\n    57→}\n    58→\n    59→export function listDocuments(db: Database.Database): DocRow[] {\n    60→  return db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`).all() as DocRow[];\n    61→}\n    62→\n    63→export function updateDocument(db: Database.Database, id: string, updates: { title?: string; content?: string }): DocRow | undefined {\n    64→  const doc = getDocument(db, id);\n    65→  if (!doc) return undefined;\n    66→\n    67→  const title = updates.title ?? doc.title;\n    68→  const content = updates.content ?? doc.content;\n    69→\n    70→  db.prepare(\n    71→    `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`\n    72→  ).run(title, content, id);\n    73→\n    74→  return getDocument(db, id);\n    75→}\n    76→\n    77→export function deleteDocument(db: Database.Database, id: string): boolean {\n    78→  const result = db.prepare(`DELETE FROM documents WHERE id = ?`).run(id);\n    79→  return result.changes > 0;\n    80→}\n    81→\n    82→// ---------------------------------------------------------------------------\n    83→// Version history\n    84→// ---------------------------------------------------------------------------\n    85→\n    86→export function getVersions(db: Database.Database, docId: string): VersionRow[] {\n    87→  return db.prepare(\n    88→    `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`\n    89→  ).all(docId) as VersionRow[];\n    90→}\n    91→\n    92→export function getLatestVersion(db: Database.Database, docId: string): number {\n    93→  const row = db.prepare(\n    94→    `SELECT COALESCE(MAX(version), 0) as v FROM versions WHERE document_id = ?`\n    95→  ).get(docId) as { v: number };\n    96→  return row.v;\n    97→}\n    98→\n    99→export function addVersion(db: Database.Database, docId: string, version: number, content: string, operation: string | null): void {\n   100→  db.prepare(\n   101→    `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`\n   102→  ).run(docId, version, content, operation);\n   103→}\n   104→\n   105→export function updateDocumentContent(db: Database.Database, docId: string, content: string): void {\n   106→  db.prepare(\n   107→    `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`\n   108→  ).run(content, docId);\n   109→}\n   110→"}]},"parent_tool_use_id":"toolu_01Fuofs2rScuGjdhah9yAxpG","session_id":"60613535-c5c1-4ce6-8418-7c44b8964a95","uuid":"8315a0aa-ae07-4222-8f91-728a3c3f0bed"}
