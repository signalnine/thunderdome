new file mode 100644
index 0000000..48254b3
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,255 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server as HttpServer } from 'http';
+import type Database from 'better-sqlite3';
+import { apply, transform, baseLength, type Op } from './ot.js';
+import { getDocument, getLatestVersion, addVersion, updateDocumentContent, getVersions } from './db.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  docId: string;
+}
+
+interface DocumentSession {
+  docId: string;
+  clients: Map<string, ClientConnection>;
+  /** Server's current document content */
+  content: string;
+  /** Current version number */
+  version: number;
+  /** History of operations applied, indexed by version they produced */
+  history: Op[];
+}
+
+export interface CollaborationServer {
+  wss: WebSocketServer;
+  sessions: Map<string, DocumentSession>;
+  close(): void;
+}
+
+/**
+ * Message types from client to server:
+ * - { type: 'operation', version: number, ops: Op, clientId: string }
+ *
+ * Message types from server to client:
+ * - { type: 'sync', content: string, version: number, clientId: string }
+ * - { type: 'operation', ops: Op, version: number, clientId: string }
+ * - { type: 'ack', version: number }
+ * - { type: 'error', message: string }
+ */
+
+function sendJson(ws: WebSocket, data: unknown): void {
+  if (ws.readyState === WebSocket.OPEN) {
+    ws.send(JSON.stringify(data));
+  }
+}
+
+function getOrCreateSession(db: Database.Database, sessions: Map<string, DocumentSession>, docId: string): DocumentSession | null {
+  let session = sessions.get(docId);
+  if (session) return session;
+
+  const doc = getDocument(db, docId);
+  if (!doc) return null;
+
+  const version = getLatestVersion(db, docId);
+
+  // Load operation history from DB
+  const versions = getVersions(db, docId);
+  const history: Op[] = [];
+  for (const v of versions) {
+    if (v.operation) {
+      history.push(JSON.parse(v.operation) as Op);
+    }
+  }
+
+  session = {
+    docId,
+    clients: new Map(),
+    content: doc.content,
+    version,
+    history,
+  };
+  sessions.set(docId, session);
+  return session;
+}
+
+function validateOp(ops: Op, expectedBaseLen: number): string | null {
+  if (!Array.isArray(ops)) return 'ops must be an array';
+  for (const c of ops) {
+    if (typeof c !== 'number' && typeof c !== 'string') {
+      return 'each op component must be a number or string';
+    }
+  }
+  const bl = baseLength(ops);
+  if (bl !== expectedBaseLen) {
+    return `operation base length (${bl}) does not match expected (${expectedBaseLen})`;
+  }
+  return null;
+}
+
+export function createCollaborationServer(httpServer: HttpServer, db: Database.Database): CollaborationServer {
+  const sessions = new Map<string, DocumentSession>();
+
+  const wss = new WebSocketServer({ server: httpServer });
+
+  wss.on('connection', (ws, req) => {
+    // Extract document ID from URL path: /ws/:docId
+    const url = req.url ?? '';
+    const match = url.match(/^\/ws\/([^/?]+)/);
+    if (!match) {
+      sendJson(ws, { type: 'error', message: 'Invalid URL. Expected /ws/:docId' });
+      ws.close();
+      return;
+    }
+
+    const docId = match[1];
+    const clientId = Math.random().toString(36).substring(2, 15);
+
+    const session = getOrCreateSession(db, sessions, docId);
+    if (!session) {
+      sendJson(ws, { type: 'error', message: 'Document not found' });
+      ws.close();
+      return;
+    }
+
+    const conn: ClientConnection = { ws, clientId, docId };
+    session.clients.set(clientId, conn);
+
+    // Send sync message with current state
+    sendJson(ws, {
+      type: 'sync',
+      content: session.content,
+      version: session.version,
+      clientId,
+    });
+
+    ws.on('message', (raw) => {
+      let msg: { type: string; version?: number; ops?: Op; clientId?: string };
+      try {
+        msg = JSON.parse(raw.toString());
+      } catch {
+        sendJson(ws, { type: 'error', message: 'Invalid JSON' });
+        return;
+      }
+
+      if (msg.type !== 'operation') {
+        sendJson(ws, { type: 'error', message: `Unknown message type: ${msg.type}` });
+        return;
+      }
+
+      if (typeof msg.version !== 'number' || !Array.isArray(msg.ops)) {
+        sendJson(ws, { type: 'error', message: 'operation message must have version (number) and ops (array)' });
+        return;
+      }
+
+      const clientVersion = msg.version;
+      const clientOps = msg.ops;
+
+      // The client's operation was generated against `clientVersion`.
+      // The server is at `session.version`. We need to transform the
+      // client op against all ops that happened between clientVersion
+      // and session.version.
+
+      if (clientVersion < 0 || clientVersion > session.version) {
+        sendJson(ws, { type: 'error', message: `Invalid version: ${clientVersion}. Server is at version ${session.version}` });
+        return;
+      }
+
+      // Determine correct base length for this client version
+      // The client's op should be against the document as it was at clientVersion
+      let expectedBaseLen: number;
+      if (clientVersion === session.version) {
+        expectedBaseLen = session.content.length;
+      } else {
+        // We need to figure out what the doc length was at clientVersion
+        // We can reconstruct this from the version history in the DB
+        const versionRows = getVersions(db, docId);
+        const vRow = versionRows.find(v => v.version === clientVersion);
+        if (vRow) {
+          expectedBaseLen = vRow.content.length;
+        } else {
+          expectedBaseLen = session.content.length;
+        }
+      }
+
+      const validationError = validateOp(clientOps, expectedBaseLen);
+      if (validationError) {
+        sendJson(ws, { type: 'error', message: validationError });
+        return;
+      }
+
+      // Transform against concurrent operations
+      let transformedOps: Op = clientOps;
+      try {
+          for (let i = clientVersion; i < session.version; i++) {
+          const histIdx = i - (session.version - session.history.length);
+          if (histIdx < 0 || histIdx >= session.history.length) {
+            sendJson(ws, { type: 'error', message: 'Cannot transform: missing history' });
+            return;
+          }
+          const serverOp = session.history[histIdx];
+          const [aPrime] = transform(transformedOps, serverOp);
+          transformedOps = aPrime;
+        }
+      } catch (err) {
+        sendJson(ws, { type: 'error', message: `Transform error: ${(err as Error).message}` });
+        return;
+      }
+
+      // Apply the transformed operation
+      let newContent: string;
+      try {
+        newContent = apply(session.content, transformedOps);
+      } catch (err) {
+        sendJson(ws, { type: 'error', message: `Apply error: ${(err as Error).message}` });
+        return;
+      }
+
+      // Commit
+      session.version++;
+      session.content = newContent;
+      session.history.push(transformedOps);
+
+      // Persist
+      addVersion(db, docId, session.version, newContent, JSON.stringify(transformedOps));
+      updateDocumentContent(db, docId, newContent);
+
+      // Ack the sender
+      sendJson(ws, { type: 'ack', version: session.version });
+
+      // Broadcast to other clients
+      for (const [cid, client] of session.clients) {
+        if (cid === clientId) continue;
+        sendJson(client.ws, {
+          type: 'operation',
+          ops: transformedOps,
+          version: session.version,
+          clientId,
+        });
+      }
+    });
+
+    ws.on('close', () => {
+      session.clients.delete(clientId);
+      // If no more clients, we can optionally keep the session for fast reconnect
+      // but we'll clean it up to save memory for tests
+      if (session.clients.size === 0) {
+        sessions.delete(docId);
+      }
+    });
+  });
+
+  return {
+    wss,
+    sessions,
+    close() {
+      for (const session of sessions.values()) {
+        for (const client of session.clients.values()) {
+          client.ws.close();
+        }
+      }
+      sessions.clear();
+      wss.close();
+    },
+  };
+}
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..037235a
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,109 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { resolve, dirname } from 'path';
+import { fileURLToPath } from 'url';
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export interface DocRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDb(dbPath?: string): Database.Database {
+  const db = new Database(dbPath ?? ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  const schemaPath = resolve(__dirname, '..', 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+
+  return db;
+}
+
+// ---------------------------------------------------------------------------
+// Document CRUD
+// ---------------------------------------------------------------------------
+
+export function createDocument(db: Database.Database, id: string, title: string, content: string): DocRow {
+  const stmt = db.prepare(
+    `INSERT INTO documents (id, title, content) VALUES (?, ?, ?) RETURNING *`
+  );
+  const row = stmt.get(id, title, content) as DocRow;
+
+  // Create initial version
+  db.prepare(
+    `INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, NULL)`
+  ).run(id, content);
+
+  return row;
+}
+
+export function getDocument(db: Database.Database, id: string): DocRow | undefined {
+  return db.prepare(`SELECT * FROM documents WHERE id = ?`).get(id) as DocRow | undefined;
+}
+
+export function listDocuments(db: Database.Database): DocRow[] {
+  return db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`).all() as DocRow[];
+}
+
+export function updateDocument(db: Database.Database, id: string, updates: { title?: string; content?: string }): DocRow | undefined {
+  const doc = getDocument(db, id);
+  if (!doc) return undefined;
+
+  const title = updates.title ?? doc.title;
+  const content = updates.content ?? doc.content;
+
+  db.prepare(
+    `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+  ).run(title, content, id);
+
+  return getDocument(db, id);
+}
+
+export function deleteDocument(db: Database.Database, id: string): boolean {
+  const result = db.prepare(`DELETE FROM documents WHERE id = ?`).run(id);
+  return result.changes > 0;
+}
+
+// ---------------------------------------------------------------------------
+// Version history
+// ---------------------------------------------------------------------------
+
+export function getVersions(db: Database.Database, docId: string): VersionRow[] {
+  return db.prepare(
+    `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+  ).all(docId) as VersionRow[];
+}
+
+export function getLatestVersion(db: Database.Database, docId: string): number {
+  const row = db.prepare(
+    `SELECT COALESCE(MAX(version), 0) as v FROM versions WHERE document_id = ?`
+  ).get(docId) as { v: number };
+  return row.v;
+}
+
+export function addVersion(db: Database.Database, docId: string, version: number, content: string, operation: string | null): void {
+  db.prepare(
+    `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`
+  ).run(docId, version, content, operation);
+}
+
+export function updateDocumentContent(db: Database.Database, docId: string, content: string): void {
+  db.prepare(
+    `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`
+  ).run(content, docId);
+}
