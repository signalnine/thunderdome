d);\n\n  // Load operation history from DB\n  const versions = getVersions(db, docId);\n  const history: Op[] = [];\n  for (const v of versions) {\n    if (v.operation) {\n      history.push(JSON.parse(v.operation) as Op);\n    }\n  }\n\n  session = {\n    docId,\n    clients: new Map(),\n    content: doc.content,\n    version,\n    history,\n  };\n  sessions.set(docId, session);\n  return session;\n}\n\nfunction validateOp(ops: Op, expectedBaseLen: number): string | null {\n  if (!Array.isArray(ops)) return 'ops must be an array';\n  for (const c of ops) {\n    if (typeof c !== 'number' && typeof c !== 'string') {\n      return 'each op component must be a number or string';\n    }\n  }\n  const bl = baseLength(ops);\n  if (bl !== expectedBaseLen) {\n    return `operation base length (${bl}) does not match expected (${expectedBaseLen})`;\n  }\n  return null;\n}\n\nexport function createCollaborationServer(httpServer: HttpServer, db: Database.Database): CollaborationServer {\n  const sessions = new Map<string, DocumentSession>();\n\n  const wss = new WebSocketServer({ server: httpServer });\n\n  wss.on('connection', (ws, req) => {\n    // Extract document ID from URL path: /ws/:docId\n    const url = req.url ?? '';\n    const match = url.match(/^\\/ws\\/([^/?]+)/);\n    if (!match) {\n      sendJson(ws, { type: 'error', message: 'Invalid URL. Expected /ws/:docId' });\n      ws.close();\n      return;\n    }\n\n    const docId = match[1];\n    const clientId = Math.random().toString(36).substring(2, 15);\n\n    const session = getOrCreateSession(db, sessions, docId);\n    if (!session) {\n      sendJson(ws, { type: 'error', message: 'Document not found' });\n      ws.close();\n      return;\n    }\n\n    const conn: ClientConnection = { ws, clientId, docId };\n    session.clients.set(clientId, conn);\n\n    // Send sync message with current state\n    sendJson(ws, {\n      type: 'sync',\n      content: session.content,\n      version: session.version,\n      clientId,\n    });\n\n    ws.on('message', (raw) => {\n      let msg: { type: string; version?: number; ops?: Op; clientId?: string };\n      try {\n        msg = JSON.parse(raw.toString());\n      } catch {\n        sendJson(ws, { type: 'error', message: 'Invalid JSON' });\n        return;\n      }\n\n      if (msg.type !== 'operation') {\n        sendJson(ws, { type: 'error', message: `Unknown message type: ${msg.type}` });\n        return;\n      }\n\n      if (typeof msg.version !== 'number' || !Array.isArray(msg.ops)) {\n        sendJson(ws, { type: 'error', message: 'operation message must have version (number) and ops (array)' });\n        return;\n      }\n\n      const clientVersion = msg.version;\n      const clientOps = msg.ops;\n\n      // The client's operation was generated against `clientVersion`.\n      // The server is at `session.version`. We need to transform the\n      // client op against all ops that happened between clientVersion\n      // and session.version.\n\n      if (clientVersion < 0 || clientVersion > session.version) {\n        sendJson(ws, { type: 'error', message: `Invalid version: ${clientVersion}. Server is at version ${session.version}` });\n        return;\n      }\n\n      // Determine correct base length for this client version\n      // The client's op should be against the document as it was at clientVersion\n      let expectedBaseLen: number;\n      if (clientVersion === session.version) {\n        expectedBaseLen = session.content.length;\n      } else {\n        // We need to figure out what the doc length was at clientVersion\n        // We can reconstruct this from the version history in the DB\n        const versionRows = getVersions(db, docId);\n        const vRow = versionRows.find(v => v.version === clientVersion);\n        if (vRow) {\n          expectedBaseLen = vRow.content.length;\n        } else {\n          expectedBaseLen = session.content.length;\n        }\n      }\n\n      const validationError = validateOp(clientOps, expectedBaseLen);\n      if (validationError) {\n        sendJson(ws, { type: 'error', message: validationError });\n        return;\n      }\n\n      // Transform against concurrent operations\n      let transformedOps: Op = clientOps;\n      try {\n        const startIdx = clientVersion - (session.version - session.history.length);\n        for (let i = clientVersion; i < session.version; i++) {\n          const histIdx = i - (session.version - session.history.length);\n          if (histIdx < 0 || histIdx >= session.history.length) {\n            sendJson(ws, { type: 'error', message: 'Cannot transform: missing history' });\n            return;\n          }\n          const serverOp = session.history[histIdx];\n          const [aPrime] = transform(transformedOps, serverOp);\n          transformedOps = aPrime;\n        }\n      } catch (err) {\n        sendJson(ws, { type: 'error', message: `Transform error: ${(err as Error).message}` });\n        return;\n      }\n\n      // Apply the transformed operation\n      let newContent: string;\n      try {\n        newContent = apply(session.content, transformedOps);\n      } catch (err) {\n        sendJson(ws, { type: 'error', message: `Apply error: ${(err as Error).message}` });\n        return;\n      }\n\n      // Commit\n      session.version++;\n      session.content = newContent;\n      session.history.push(transformedOps);\n\n      // Persist\n      addVersion(db, docId, session.version, newContent, JSON.stringify(transformedOps));\n      updateDocumentContent(db, docId, newContent);\n\n      // Ack the sender\n      sendJson(ws, { type: 'ack', version: session.version });\n\n      // Broadcast to other clients\n      for (const [cid, client] of session.clients) {\n        if (cid === clientId) continue;\n        sendJson(client.ws, {\n          type: 'operation',\n          ops: transformedOps,\n          version: session.version,\n          clientId,\n        });\n      }\n    });\n\n    ws.on('close', ()