n  router.get('/documents/:id', (req, res) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  // Update document\n  router.put('/documents/:id', (req, res) => {\n    const { title, content } = req.body;\n    const doc = updateDocument(db, req.params.id, { title, content });\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  // Delete document\n  router.delete('/documents/:id', (req, res) => {\n    const deleted = deleteDocument(db, req.params.id);\n    if (!deleted) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get version history\n  router.get('/documents/:id/versions', (req, res) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = getVersions(db, req.params.id);\n    res.json(versions);\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":38,"oldLines":6,"newStart":38,"newLines":14,"lines":["   // Update document","   router.put('/documents/:id', (req, res) => {","     const { title, content } = req.body;","+    if (title !== undefined && typeof title !== 'string') {","+      res.status(400).json({ error: 'title must be a string' });","+      return;","+    }","+    if (content !== undefined && typeof content !== 'string') {","+      res.status(400).json({ error: 'content must be a string' });","+      return;","+    }","     const doc = updateDocument(db, req.params.id, { title, content });","     if (!doc) {","       res.status(404).json({ error: 'Document not found' });"]}],"userModified":false,"replaceAll":false}}
