}/versions`).expect(200);\n    expect(res.body.length).toBe(3); // version 1 (initial), 2, 3\n    expect(res.body[0].content).toBe('a');\n    expect(res.body[1].content).toBe('ab');\n    expect(res.body[2].content).toBe('abc');\n\n    ws.close();\n  });\n});\n\ndescribe('Concurrent clients (10+)', () => {\n  it('handles 10 concurrent clients without corruption', async () => {\n    const created = await request(app.app).post('/api/documents').send({ title: 'Stress', content: '' });\n    const docId = created.body.id;\n    const numClients = 10;\n\n    // Connect all clients\n    const clients: { ws: WebSocket; sync: { version: number; clientId: string } }[] = [];\n    for (let i = 0; i < numClients; i++) {\n      const client = await connectWs(docId);\n      clients.push(client);\n    }\n\n    // Each client inserts its index number at position 0 sequentially\n    // This is simpler and avoids race conditions in the test\n    let currentVersion = 1;\n    for (let i = 0; i < numClients; i++) {\n      const { ws } = clients[i];\n      const contentLen = i;  // content grows by 1 each iteration\n      const op = buildInsert(contentLen, contentLen, String(i));\n      sendOp(ws, currentVersion, op);\n      const ack = await waitForMessage(ws, 'ack');\n      currentVersion = ack.version as number;\n\n      // Let other clients receive the broadcast\n      for (let j = 0; j < numClients; j++) {\n        if (j !== i) {\n          await waitForMessage(clients[j].ws, 'operation');\n        }\n      }\n    }\n\n    // Verify final state - should contain all digits 0-9\n    const res = await request(app.app).get(`/api/documents/${docId}`).expect(200);\n    expect(res.body.content.length).toBe(10);\n    for (let i = 0; i < numClients; i++) {\n      expect(res.body.content).toContain(String(i));\n    }\n\n    // Close all\n    for (const c of clients) {\n      c.ws.close();\n    }\n  });\n\n  it('handles truly concurrent edits from multiple clients', async () => {\n    const created = await request(app.app).post('/api/documents').send({ title: 'TrueConcurrent', content: '-----' });\n    const docId = created.body.id;\n    const numClients = 10;\n\n    // Connect all clients\n    const clients: { ws: WebSocket; sync: { version: number; clientId: string } }[] = [];\n    for (let i = 0; i < numClients; i++) {\n      const client = await connectWs(docId);\n      clients.push(client);\n    }\n\n    // All clients simultaneously insert at different positions against version 1\n    // Each inserts at position i (clamped to doc length = 5)\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < numClients; i++) {\n      const { ws, sync } = clients[i];\n      const pos = Math.min(i, 5);\n      const op = buildInsert(5, pos, String.fromCharCode(65 + i)); // A, B, C, ...\n      ackPromises.push(waitForMessage(ws, 'ack'));\n      sendOp(ws, sync.version, op);\n    }\n\n    // Wait for all acks\n    await Promise.all(ackPromises);\n\n    // Verify final state\n    const res = await request(app.app).get(`/api/documents/${docId}`).expect(200);\n    // The content should have the original 5 dashes plus 10 inserted characters\n    expect(res.body.content.length).toBe(15);\n    // All inserted chars should be present\n    for (let i = 0; i < numClients; i++) {\n      expect(res.body.content).toContain(String.fromCharCode(65 + i));\n    }\n    // Original dashes should still be there\n    expect(res.body.content.replace(/[A-Z]/g, '')).toBe('-----');\n\n    for (const c of clients) {\n      c.ws.close();\n    }\n  });\n});\n\ndescribe('Persistence', () => {\n  it('data survives server restart (with file DB)', async () => {\n    // Stop the default app\n    await app.stop();\n\n    const tmpDb = '/tmp/collab-test-persist.db';\n    // Remove old db if exists\n    try { (await import('fs')).unlinkSync(tmpDb); } catch { /* ignore */ }\n\n    // Start with file-based DB\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n\n    // Create a document\n    const res1 = await request(app1.app).post('/api/documents').send({ title: 'Persist', content: 'survive' });\n    const docId = res1.body.id;\n    await app1.stop();\n\n    // Start a new server with the same DB\n    const app2 = createApp(tmpDb);\n    await app2.start(0);\n\n    const res2 = await request(app2.app).get(`/api/documents/${docId}`).expect(200);\n    expect(res2.body.title).toBe('Persist');\n    expect(res2.body.content).toBe('survive');\n\n    await app2.stop();\n\n    // Clean up - reassign so afterEach doesn't fail\n    app = createApp();\n    port = await app.start(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2356,"cache_read_input_tokens":34833,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2356},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"60613535-c5c1-4ce6-8418-7c44b8964a95","uuid":"fc2b2611-e153-40f1-b249-386a43a09453"}
