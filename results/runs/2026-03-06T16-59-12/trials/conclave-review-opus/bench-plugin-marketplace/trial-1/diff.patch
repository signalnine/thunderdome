60→export interface ResolverService {\n    61→  resolve(constraints: VersionConstraint[], available: Record<string, string[]>): ResolvedVersion[];\n    62→  satisfies(version: string, range: string): boolean;\n    63→  maxSatisfying(versions: string[], range: string): string | null;\n    64→  validRange(range: string): boolean;\n    65→}\n    66→\n    67→export interface RunnerService {\n    68→  execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult>;\n    69→  executeWithTimeout(code: string, timeoutMs: number, context?: Record<string, unknown>): Promise<SandboxResult>;\n    70→}\n    71→\n    72→export interface ReviewService {\n    73→  addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review;\n    74→  getReviews(pluginName: string): Review[];\n    75→  getAverageRating(pluginName: string): number;\n    76→  flagReview(reviewId: number): void;\n    77→  getFlaggedReviews(): Review[];\n    78→  removeReview(reviewId: number): boolean;\n    79→  getReviewsByUser(userId: string): Review[];\n    80→  getReviewCount(pluginName: string): number;\n    81→}\n    82→\n    83→export interface DepsService {\n    84→  buildTree(name: string, registry: RegistryService): DependencyNode;\n    85→  detectCycles(name: string, registry: RegistryService): string[][] | null;\n    86→  topologicalSort(name: string, registry: RegistryService): string[];\n    87→  flattenDependencies(name: string, registry: RegistryService): string[];\n    88→  hasCircularDependency(name: string, registry: RegistryService): boolean;\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_0175YWBYR3rmfaMQFc5NRm8W","session_id":"eb7a9eca-78b6-451b-aaba-f4cd85e91db6","uuid":"4f19a111-7dee-45b1-8d3a-3bc888956c55"}
