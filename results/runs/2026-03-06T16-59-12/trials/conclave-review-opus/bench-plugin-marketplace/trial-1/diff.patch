er.resolve(\n    49→          [{ name: 'foo', range: '^3.0.0' }],\n    50→          { foo: ['1.0.0', '2.0.0'] },\n    51→        ),\n    52→      ).toThrow('No version of foo satisfies range ^3.0.0');\n    53→    });\n    54→\n    55→    it('should handle exact version constraints', () => {\n    56→      const result = resolver.resolve(\n    57→        [{ name: 'foo', range: '1.2.3' }],\n    58→        { foo: ['1.2.3', '1.2.4'] },\n    59→      );\n    60→      expect(result[0].version).toBe('1.2.3');\n    61→    });\n    62→\n    63→    it('should handle wildcard ranges', () => {\n    64→      const result = resolver.resolve(\n    65→        [{ name: 'foo', range: '*' }],\n    66→        { foo: ['1.0.0', '2.0.0', '3.0.0'] },\n    67→      );\n    68→      expect(result[0].version).toBe('3.0.0');\n    69→    });\n    70→  });\n    71→\n    72→  describe('satisfies', () => {\n    73→    it('should return true for satisfying version', () => {\n    74→      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);\n    75→    });\n    76→\n    77→    it('should return false for non-satisfying version', () => {\n    78→      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    79→    });\n    80→\n    81→    it('should handle tilde ranges', () => {\n    82→      expect(resolver.satisfies('1.2.5', '~1.2.0')).toBe(true);\n    83→      expect(resolver.satisfies('1.3.0', '~1.2.0')).toBe(false);\n    84→    });\n    85→  });\n    86→\n    87→  describe('maxSatisfying', () => {\n    88→    it('should return the highest satisfying version', () => {\n    89→      const result = resolver.maxSatisfying(\n    90→        ['1.0.0', '1.1.0', '1.2.0', '2.0.0'],\n    91→        '^1.0.0',\n    92→      );\n    93→      expect(result).toBe('1.2.0');\n    94→    });\n    95→\n    96→    it('should return null when none satisfy', () => {\n    97→      const result = resolver.maxSatisfying(['1.0.0'], '^2.0.0');\n    98→      expect(result).toBeNull();\n    99→    });\n   100→  })