ddReview({\n    46→        pluginName: 'plugin-b', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'ok',\n    47→      });\n    48→      reviews.addReview({\n    49→        pluginName: 'plugin-a', pluginVersion: '1.0.0', userId: 'u3', rating: 5, comment: 'great',\n    50→      });\n    51→\n    52→      const result = reviews.getReviews('plugin-a');\n    53→      expect(result).toHaveLength(2);\n    54→      expect(result.every(r => r.pluginName === 'plugin-a')).toBe(true);\n    55→    });\n    56→\n    57→    it('should return empty array for unknown plugin', () => {\n    58→      expect(reviews.getReviews('nonexistent')).toEqual([]);\n    59→    });\n    60→  });\n    61→\n    62→  describe('getAverageRating', () => {\n    63→    it('should compute average rating', () => {\n    64→      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });\n    65→      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: '' });\n    66→      expect(reviews.getAverageRating('p')).toBe(3);\n    67→    });\n    68→\n    69→    it('should exclude flagged reviews from average', () => {\n    70→      const r1 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    71→      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n    72→      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'spam' });\n    73→\n    74→      // Flag the 1-star spam review\n    75→      const allReviews = reviews.getReviews('p');\n    76→      const spamReview = allReviews.find(r => r.comment === 'spam');\n    77→      reviews.flagReview(spamReview!.id);\n    78→\n    79→      // Average should be (5 + 3) / 2 = 4\n    80→      expect(reviews.getAverageRating('p')).toBe(4);\n    81→    });\n    82→\n    83→    it('should return 0 for plugin with no reviews', () => {