+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GDohgoeZDg8GpkaNTonkxe","type":"tool_result","content":"     1→import type { PluginManifest, RegistryService } from '../types.js';\n     2→import Database from 'better-sqlite3';\n     3→\n     4→export function createRegistry(dbPath: string = ':memory:'): RegistryService {\n     5→  const db = new Database(dbPath);\n     6→  db.pragma('journal_mode = WAL');\n     7→\n     8→  db.exec(`\n     9→    CREATE TABLE IF NOT EXISTS plugins (\n    10→      name TEXT NOT NULL,\n    11→      version TEXT NOT NULL,\n    12→      description TEXT NOT NULL DEFAULT '',\n    13→      author TEXT NOT NULL DEFAULT '',\n    14→      dependencies TEXT NOT NULL DEFAULT '{}',\n    15→      entryPoint TEXT NOT NULL DEFAULT '',\n    16→      permissions TEXT NOT NULL DEFAULT '[]',\n    17→      PRIMARY KEY (name, version)\n    18→    )\n    19→  `);\n    20→\n    21→  const insertStmt = db.prepare(`\n    22→    INSERT OR REPLACE INTO plugins (name, version, description, author, dependencies, entryPoint, permissions)\n    23→    VALUES (?, ?, ?, ?, ?, ?, ?)\n    24→  `);\n    25→\n    26→  const getLatestStmt = db.prepare(`\n    27→    SELECT * FROM plugins WHERE name = ? ORDER BY version DESC LIMIT 1\n    28→  `);\n    29→\n    30→  const getVersionStmt = db.prepare(`\n    31→    SELECT * FROM plugins WHERE name = ? AND version = ?\n    32→  `);\n    33→\n    34→  const listStmt = db.prepare(`SELECT * FROM plugins ORDER BY name, version`);\n    35→\n    36→  const searchStmt = db.prepare(`\n    37→    SELECT * FROM plugins WHERE name LIKE ? OR description LIKE ? OR author LIKE ?\n    38→  `);\n    39→\n    40→  const removeStmt = db.prepare(`DELETE FROM plugins WHERE name = ? AND version = ?`);\n    41→\n    42→  const listVersionsStmt = db.prepare(`SELECT version FROM plugins WHERE name = ? ORDER BY version`);\n    43→\n    44→  const updateStmt = db.prepare(`\n    45→    UPDATE plugins SET description = ?, author = ?, dependencies = ?, entryPoint = ?, permissions = ?\n    46→    WHERE name = ? AND version = ?\n    47→  `);\n    48→\n    49→  function rowToManifest(row: Record<string, unknown>): PluginManifest {\n    50→    return {\n    51→      name: row.name as string,\n    52→      version: row.version as string,\n    53→      description: row.description as string,\n    54→      author: row.author as string,\n    55→      dependencies: JSON.parse(row.dependencies as string) as Record<string, string>,\n    56→      entryPoint: row.entryPoint as string,\n    57→      permissions: JSON.parse(row.permissions as string) as string[],\n    58→    };\n    59→  }\n    60→\n    61→  return {\n    62→    register(manifest: PluginManifest): void {\n    63→      insertStmt.run(\n    64→        manifest.name,\n    65→        manifest.version,\n    66→        manifest.description,\n    67→        manifest.author,\n    68→        JSON.stringify(manifest.dependencies),\n    69→        manifest.entryPoint,\n    70→        JSON.stringify(manifest.permissions),\n    71→      );\n    72→    },\n    73→\n    74→    get(name: string): PluginManifest | null {\n    75→      const row = getLatestStmt.get(name) as Record<string, unknown> | undefined;\n    76→      return row ? rowToManifest(row) : null;\n    77→    },\n    78→\n    79→    getVersion(name: string, version: string): PluginManifest | null {\n    80→      const row = getVersionStmt.get(name, version) as Record<string, unknown> | undefined;\n    81→      return row ? rowToManifest(row) : null;\n    82→    },\n    83→\n    84→    list(): PluginManifest[] {\n    85→      const rows = listStmt.all() as Record<string, unknown>[];\n    86→      return rows.map(rowToManifest);\n    87→    },\n    88→\n    89→    search(query: string): PluginManifest[] {\n    90→      const pattern = `%${query}%`;\n    91→      const rows = searchStmt.all(pattern, pattern, pattern) as Record<string, unknown>[];\n    92→      return rows.map(rowToManifest);\n    93→    },\n    94→\n    95→    remove(name: string, version: string): boolean {\n    96→      const result = removeStmt.run(name, version);\n    97→      return result.changes > 0;\n    98→    },\n    99→\n   100→    listVersions(name: string): string[] {\n   101→      const rows = listVersionsStmt.all(name) as { version: string }[];\n   102→      return rows.map(r => r.version);\n   103→    },\n   104→\n   105→    update(name: string, version: string, updates: Partial<PluginManifest>): void {\n   106→      const existing = getVersionStmt.get(name, version) as Record<string, unknown> | undefined;\n   107→      if (!existing) {\n   108→        throw new Error(`Plugin ${name}@${version} not found`);\n   109→      }\n   110→      const current = rowToManifest(existing);\n   111→      const merged = { ...current, ...updates, name, version };\n   112→      updateStmt.run(\n   113→        merged.description,\n   114→        merged.author,\n   115→        JSON.stringify(merged.dependencies),\n   116→        merged.entryPoint,\n   117→        JSON.stringify(merged.permissions),\n   118→        name,\n   119→        version,\n   120→      );\n   121→    },\n   122→  };\n   123→}\n   124→"}]},"parent_tool_use_id":"toolu_0175YWBYR3rmfaMQFc5NRm8W","session_id":"eb7a9eca-78b6-451b-aaba-f4cd85e91db6","uuid":"69d029b8-7a2b-4509-9cd9-24ec015ae1e8"}
