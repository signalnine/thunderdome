+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019B9WwzaLkwvGgKgihvZNU6","type":"tool_result","content":"     1→import type { Review, ReviewService } from '../types.js';\n     2→import Database from 'better-sqlite3';\n     3→\n     4→export function createReviewService(dbPath: string = ':memory:'): ReviewService {\n     5→  const db = new Database(dbPath);\n     6→  db.pragma('journal_mode = WAL');\n     7→\n     8→  db.exec(`\n     9→    CREATE TABLE IF NOT EXISTS reviews (\n    10→      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    11→      pluginName TEXT NOT NULL,\n    12→      pluginVersion TEXT NOT NULL,\n    13→      userId TEXT NOT NULL,\n    14→      rating INTEGER NOT NULL CHECK(rating >= 1 AND rating <= 5),\n    15→      comment TEXT NOT NULL DEFAULT '',\n    16→      flagged INTEGER NOT NULL DEFAULT 0,\n    17→      createdAt TEXT NOT NULL\n    18→    )\n    19→  `);\n    20→\n    21→  const insertStmt = db.prepare(`\n    22→    INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt)\n    23→    VALUES (?, ?, ?, ?, ?, 0, ?)\n    24→  `);\n    25→\n    26→  const getByPluginStmt = db.prepare(`\n    27→    SELECT * FROM reviews WHERE pluginName = ? ORDER BY createdAt DESC\n    28→  `);\n    29→\n    30→  const avgRatingStmt = db.prepare(`\n    31→    SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0\n    32→  `);\n    33→\n    34→  const flagStmt = db.prepare(`UPDATE reviews SET flagged = 1 WHERE id = ?`);\n    35→\n    36→  const getFlaggedStmt = db.prepare(`SELECT * FROM reviews WHERE flagged = 1 ORDER BY createdAt DESC`);\n    37→\n    38→  const removeStmt = db.prepare(`DELETE FROM reviews WHERE id = ?`);\n    39→\n    40→  const getByUserStmt = db.prepare(`SELECT * FROM reviews WHERE userId = ? ORDER BY createdAt DESC`);\n    41→\n    42→  const countStmt = db.prepare(`SELECT COUNT(*) as count FROM reviews WHERE pluginName = ?`);\n    43→\n    44→  const getByIdStmt = db.prepare(`SELECT * FROM reviews WHERE id = ?`);\n    45→\n    46→  function rowToReview(row: Record<string, unknown>): Review {\n    47→    return {\n    48→      id: row.id as number,\n    49→      pluginName: row.pluginName as string,\n    50→      pluginVersion: row.pluginVersion as string,\n    51→      userId: row.userId as string,\n    52→      rating: row.rating as number,\n    53→      comment: row.comment as string,\n    54→      flagged: (row.flagged as number) === 1,\n    55→      createdAt: row.createdAt as string,\n    56→    };\n    57→  }\n    58→\n    59→  return {\n    60→    addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {\n    61→      const createdAt = new Date().toISOString();\n    62→      const result = insertStmt.run(\n    63→        review.pluginName,\n    64→        review.pluginVersion,\n    65→        review.userId,\n    66→        review.rating,\n    67→        review.comment,\n    68→        createdAt,\n    69→      );\n    70→      const inserted = getByIdStmt.get(result.lastInsertRowid) as Record<string, unknown>;\n    71→      return rowToReview(inserted);\n    72→    },\n    73→\n    74→    getReviews(pluginName: string): Review[] {\n    75→      const rows = getByPluginStmt.all(pluginName) as Record<string, unknown>[];\n    76→      return rows.map(rowToReview);\n    77→    },\n    78→\n    79→    getAverageRating(pluginName: string): number {\n    80→      const row = avgRatingStmt.get(pluginName) as { avg: number | null };\n    81→      return row.avg ?? 0;\n    82→    },\n    83→\n    84→    flagReview(reviewId: number): void {\n    85→      flagStmt.run(reviewId);\n    86→    },\n    87→\n    88→    getFlaggedReviews(): Review[] {\n    89→      const rows = getFlaggedStmt.all() as Record<string, unknown>[];\n    90→      return rows.map(rowToReview);\n    91→    },\n    92→\n    93→    removeReview(reviewId: number): boolean {\n    94→      const result = removeStmt.run(reviewId);\n    95→      return result.changes > 0;\n    96→    },\n    97→\n    98→    getReviewsByUser(userId: string): Review[] {\n    99→      const rows = getByUserStmt.all(userId) as Record<string, unknown>[];\n   100→      return rows.map(rowToReview);\n   101→    },\n   102→\n   103→    getReviewCount(pluginName: string): number {\n   104→      const row = countStmt.get(pluginName) as { count: number };\n   105→      return row.count;\n   106→    },\n   107→  };\n   108→}\n   109→"}]},"parent_tool_use_id":"toolu_0175YWBYR3rmfaMQFc5NRm8W","session_id":"eb7a9eca-78b6-451b-aaba-f4cd85e91db6","uuid":"59df127e-a027-43e6-86f2-76a82de8bc7e"}
