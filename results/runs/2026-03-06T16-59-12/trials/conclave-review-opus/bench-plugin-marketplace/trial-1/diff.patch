iew({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: '' });\n   127→      expect(reviews.removeReview(r.id)).toBe(true);\n   128→      expect(reviews.getReviews('p')).toEqual([]);\n   129→    });\n   130→\n   131→    it('should return false for nonexistent review', () => {\n   132→      expect(reviews.removeReview(9999)).toBe(false);\n   133→    });\n   134→  });\n   135→\n   136→  describe('getReviewsByUser', () => {\n   137→    it('should return reviews by a specific user', () => {\n   138→      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: '' });\n   139→      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: '' });\n   140→      reviews.addReview({ pluginName: 'p3', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: '' });\n   141→\n   142→      const aliceReviews = reviews.getReviewsByUser('alice');\n   143→      expect(aliceReviews).toHaveLength(2);\n   144→      expect(aliceReviews.every(r => r.userId === 'alice')).toBe(true);\n   145→    });\n   146→  });\n   147→\n   148→  describe('getReviewCount', () => {\n   149→    it('should count reviews for a plugin', () => {\n   150→      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: '' });\n   151→      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });\n   152→      reviews.addReview({ pluginName: 'other', pluginVersion: '1.0.0', userId: 'u3', rating: 5, comment: '' });\n   153→      expect(reviews.getReviewCount('p')).toBe(2);\n   154→    });\n   155→\n   156→    it('should return 0 for unknown plugin', () => {\n   157→      expect(reviews.getReviewCount('nonexistent')).toBe(0);\n   158→    });\n   159→  });\n   160→});\n   161→"}]},"parent_tool_use_id":"toolu_0175YWBYR3rmfaMQFc5NRm8W","session_id":"eb7a9eca-78b6-451b-aaba-f4cd85e91db6","uuid":"979c042d-32af-4cc2-a033-0f2bb3717f7