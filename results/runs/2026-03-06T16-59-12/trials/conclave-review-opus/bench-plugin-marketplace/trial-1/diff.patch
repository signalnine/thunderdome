n\n    it('should handle plugin code that throws', async () => {\n      const manifest = makeManifest({ entryPoint: 'throw new Error(\"init failed\")' });\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.sandboxResult.success).toBe(false);\n      expect(result.sandboxResult.error).toBe('init failed');\n    });\n  });\n\n  describe('composed services', () => {\n    it('should expose registry service', () => {\n      expect(marketplace.registry).toBeDefined();\n      expect(typeof marketplace.registry.register).toBe('function');\n    });\n\n    it('should expose resolver service', () => {\n      expect(marketplace.resolver).toBeDefined();\n      expect(typeof marketplace.resolver.resolve).toBe('function');\n    });\n\n    it('should expose runner service', () => {\n      expect(marketplace.runner).toBeDefined();\n      expect(typeof marketplace.runner.execute).toBe('function');\n    });\n\n    it('should expose reviews service', () => {\n      expect(marketplace.reviews).toBeDefined();\n      expect(typeof marketplace.reviews.addReview).toBe('function');\n    });\n\n    it('should expose deps service', () => {\n      expect(marketplace.deps).toBeDefined();\n      expect(typeof marketplace.deps.buildTree).toBe('function');\n    });\n  });\n\n  describe('end-to-end workflow', () => {\n    it('should support full plugin lifecycle', async () => {\n      // 1. Install a plugin\n      const manifest = makeManifest({\n        entryPoint: '\"initialized\"',\n      });\n      const installResult = await marketplace.installPlugin(manifest);\n      expect(installResult.sandboxResult.success).toBe(true);\n\n      // 2. Search for it\n      const found = marketplace.registry.search('test');\n      expect(found).toHaveLength(1);\n\n      // 3. Leave a review\n      const review = marketplace.reviews.addReview({\n        pluginName: 'test-plugin',\n        pluginVersion: '1.0.0',\n        userId: 'user1',\n        rating: 5,\n        comment: 'Works great!',\n      });\n      expect(review.id).toBeDefined();\n\n      // 4. Check rating\n      expect(marketplace.reviews.getAverageRating('test-plugin')).toBe(5);\n\n      // 5. Remove plugin version\n      expect(marketplace.registry.remove('test-plugin', '1.0.0')).toBe(true);\n      expect(marketplace.registry.get('test-plugin')).toBeNull();\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
