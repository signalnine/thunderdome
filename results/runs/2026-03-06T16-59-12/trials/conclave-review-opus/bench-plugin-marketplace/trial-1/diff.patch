   49→\n    50→  it('should list all plugins', () => {\n    51→    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    52→    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    53→    const list = registry.list();\n    54→    expect(list).toHaveLength(2);\n    55→    expect(list.map(p => p.name)).toContain('a');\n    56→    expect(list.map(p => p.name)).toContain('b');\n    57→  });\n    58→\n    59→  it('should search plugins by name', () => {\n    60→    registry.register(makeManifest({ name: 'auth-plugin' }));\n    61→    registry.register(makeManifest({ name: 'logger-plugin' }));\n    62→    const results = registry.search('auth');\n    63→    expect(results).toHaveLength(1);\n    64→    expect(results[0].name).toBe('auth-plugin');\n    65→  });\n    66→\n    67→  it('should search plugins by description', () => {\n    68→    registry.register(makeManifest({ name: 'foo', description: 'handles authentication' }));\n    69→    registry.register(makeManifest({ name: 'bar', description: 'handles logging' }));\n    70→    const results = registry.search('authentication');\n    71→    expect(results).toHaveLength(1);\n    72→    expect(results[0].name).toBe('foo');\n    73→  });\n    74→\n    75→  it('should remove a specific version', () => {\n    76→    registry.register(makeManifest({ version: '1.0.0' }));\n    77→    registry.register(makeManifest({ version: '2.0.0' }));\n    78→    const removed = registry.remove('test-plugin', '1.0.0');\n    79→    expect(removed).toBe(true);\n    80→    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n    81→    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n    82→  });\n    83→\n    84→  it('should return false when removing nonexistent version', () => {\n    85→    expect(registry.remove('test-plugin', '1.0.0')).toBe(false);\n    86→  });\n    87→\n    88→  it('should list all versions of a plugin', () => {\n    89→    registry.register(makeManifest({ version: '1.0.0' }));\n    90→    registry.register(makeManifest({ version: '2.0.0' }));\n    91→    registry.register(makeManifest({ version: '1.5.0' }));\n    92→    const versions = registry.listVersions('test-plugin');\n    93→    expect(versions).toHaveLength(3);\n    94→    expect(versions).toContain('1.0.0');\n    95→    expect(versions).toContain('1.5.0');\n    96→    expect(versions).toContain('2.0.0');\n    97→  });\n    98→\n    99→  it('should return empty array for unknown plugin versions', () => {\n   100→    expect(registry.listVersions('nonexistent')).toEqual([]);\n   101→  });\n   102→\n   103→  it('should update a plugin', () => {\n   104→    registry.register(makeManifest());\n   105→    registry.update('test-plugin', '1.0.0', { description: 'updated description' });\n   106→    const updated = registry.getVersion('test-plugin', '1.0.0');\n   107→    expect(updated?.description).toBe('updated description');\n   108→    expect(updated?.author).toBe('tester'); // unchanged\n   109→  });\n   110→\n   111→  it('should throw when updating nonexistent plugin', () => {\n   112→    expect(() => registry.update('nonexistent', '1.0.0', { description: 'x' })).toThrow();\n   113→  });\n   114→\n   115→  it('should handle multiple versions with get() returning latest by sort', () => {\n   116→    registry.register(makeManifest({ version: '1.0.0' }));\n   117→    registry.register(makeManifest({ version: '3.0.0' }));\n   118→    registry.register(makeManifest({ version: '2.0.0' }));\n   119→    // get() returns the latest by descending version string sort\n   120→    const latest = registry.get('test-plugin');\n   121→    expect(latest).not.toBeNull();\n   122→  });\n   123→\n   124→  it('should store and retrieve dependencies correctly', () => {\n   125→    const manifest = makeManifest({\n   126→      dependencies: { 'dep-a': '^1.0.0', 'dep-b': '~2.0.0' },\n   127→    });\n   128→    registry.register(manifest);\n   129→    const retrieved = registry.get('