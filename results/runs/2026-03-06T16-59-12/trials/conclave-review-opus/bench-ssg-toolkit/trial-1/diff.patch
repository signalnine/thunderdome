+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TcfWxkRwxLWiauXc5j9ni8","type":"tool_result","content":"     1→import { Plugin, BuildContext } from '../core/types.js';\n     2→\n     3→export function createSitemapPlugin(): Plugin {\n     4→  return {\n     5→    name: 'sitemap',\n     6→    version: '1.0.0',\n     7→    dependencies: ['taxonomy', 'rss-feed'],\n     8→    hooks: {\n     9→      afterBuild(ctx: BuildContext): void {\n    10→        const { config, output } = ctx;\n    11→\n    12→        const urls: string[] = [];\n    13→        for (const key of output.keys()) {\n    14→          if (key === 'sitemap.xml') continue;\n    15→          urls.push(`${config.baseUrl}/${key}`);\n    16→        }\n    17→\n    18→        const urlEntries = urls\n    19→          .map(url => `  <url>\\n    <loc>${url}</loc>\\n  </url>`)\n    20→          .join('\\n');\n    21→\n    22→        const sitemap = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n    23→<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n    24→${urlEntries}\n    25→</urlset>`;\n    26→\n    27→        ctx.output.set('sitemap.xml', sitemap);\n    28→      },\n    29→    },\n    30→  };\n    31→}\n    32→"}]},"parent_tool_use_id":"toolu_01LVRcAvdYQUtjJCHmwCu37y","session_id":"1812e0c7-6cf2-41d2-afeb-9d6c0a577574","uuid":"10a71d8d-c4ea-4646-9429-1e0b6ed088eb"}
