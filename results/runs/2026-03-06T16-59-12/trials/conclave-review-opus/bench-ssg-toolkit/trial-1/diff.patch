0→  });\n    91→\n    92→  it('handles site with no tag pages', async () => {\n    93→    const output = new Map<string, string>();\n    94→    output.set('post.html', '<html></html>');\n    95→    const ctx = makeCtx(output);\n    96→    await plugin.hooks.afterBuild!(ctx);\n    97→    const sitemap = ctx.output.get('sitemap.xml')!;\n    98→    expect(sitemap).toContain('https://example.com/post.html');\n    99→    expect(sitemap).not.toContain('/tags/');\n   100→  });\n   101→});\n   102→"}]},"parent_tool_use_id":"toolu_011a2wMXfZ9A8vDwEr72rt1W","session_id":"1812e0c7-6cf2-41d2-afeb-9d6c0a577574","uuid":"92de9e03-4c57-472f-af9d-1e7d4c0ca7cf"}
