oid {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items = [];\n      emitCartUpdated(cart);\n    },\n\n    updateQuantity(cartId: string, productId: string, quantity: number): void {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      const item = cart.items.find(i => i.productId === productId);\n      if (item) {\n        item.quantity = quantity;\n      }\n      emitCartUpdated(cart);\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":385,"cache_read_input_tokens":22763,"cache_creation":{"ephemeral_5m_input_tokens":385,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4795a57b-939a-45f3-8f91-f6b781b5386d","uuid":"ba588866-83fa-4d6f-adfd-6b6b75c971db"}
