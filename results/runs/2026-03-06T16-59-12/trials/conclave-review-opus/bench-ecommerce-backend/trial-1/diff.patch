\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n\n    // Subscribe user\n    notifications.subscribe('alice');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'electronics');\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 50);\n    inventory.setStock(p2, 200);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('alice');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Calculate price\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const priceResult = pricing.calculateTotal(items);\n    expect(priceResult.subtotal).toBe(1057); // 999 + 29*2\n\n    // Reserve inventory\n    for (const item of cart.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Create order\n    const orderId = orders.createOrder('alice', cartId, priceResult.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, priceResult.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Check notifications\n    const notifs = notifications.getNotifications('alice');\n    expect(notifs.length).toBeGreaterThanOrEqual(3); // order_created, payment, order_status\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBe(priceResult.tota