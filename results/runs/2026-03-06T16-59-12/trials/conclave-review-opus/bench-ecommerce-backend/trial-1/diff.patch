diff --git a/tests/services.test.ts b/tests/services.test.ts
new file mode 100644
index 0000000..b20bd2a
--- /dev/null
+++ b/tests/services.test.ts
@@ -0,0 +1,431 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../src/bus.js';
+import {
+  createCatalogService,
+  createInventoryService,
+  createCartService,
+  createPricingService,
+  createOrderService,
+  createPaymentService,
+  createNotificationService,
+  createAnalyticsService,
+} from '../src/index.js';
+import { OrderStatus, PaymentStatus, Events } from '../src/types.js';
+
+let bus: EventBus;
+
+beforeEach(() => {
+  bus = new EventBus();
+});
+
+describe('CatalogService', () => {
+  it('should create and retrieve a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    const product = catalog.getProduct(id);
+    expect(product).not.toBeNull();
+    expect(product!.name).toBe('Widget');
+    expect(product!.price).toBe(9.99);
+    expect(product!.category).toBe('gadgets');
+  });
+
+  it('should list products by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    catalog.createProduct('C', 3, 'cat1');
+    expect(catalog.listProducts('cat1')).toHaveLength(2);
+    expect(catalog.listProducts('cat2')).toHaveLength(1);
+    expect(catalog.listProducts()).toHaveLength(3);
+  });
+
+  it('should search products', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Blue Widget', 1, 'gadgets');
+    catalog.createProduct('Red Gizmo', 2, 'tools');
+    expect(catalog.searchProducts('widget')).toHaveLength(1);
+    expect(catalog.searchProducts('GADGETS')).toHaveLength(1);
+  });
+
+  it('should update a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.updateProduct(id, { price: 14.99 });
+    expect(catalog.getProduct(id)!.price).toBe(14.99);
+  });
+
+  it('should remove a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    expect(catalog.removeProduct(id)).toBe(true);
+    expect(catalog.getProduct(id)).toBeNull();
+    expect(catalog.removeProduct('nonexistent')).toBe(false);
+  });
+
+  it('should emit product:created event', async () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    // Allow async events to settle
+    await new Promise(r => setTimeout(r, 10));
+    const log = bus.getLog();
+    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);
+  });
+});
+
+describe('InventoryService', () => {
+  it('should set and get stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 100);
+    expect(inventory.getStock('p1')).toBe(100);
+  });
+
+  it('should reserve and release stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 10);
+    expect(inventory.reserve('p1', 3)).toBe(true);
+    expect(inventory.getStock('p1')).toBe(7);
+    inventory.release('p1', 2);
+    expect(inventory.getStock('p1')).toBe(9);
+  });
+
+  it('should fail to reserve insufficient stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 5);
+    expect(inventory.reserve('p1', 6)).toBe(false);
+  });
+
+  it('should emit low stock alert', async () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('p1', 10);
+    inventory.setLowStockThreshold('p1', 5);
+    inventory.setStock('p1', 3);
+    await new Promise(r => setTimeout(r, 10));
+    const log = bus.getLog();
+    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);
+  });
+});
+
+describe('CartService', () => {
+  it('should create a cart and add items', () => {
+    const cart = createCartService(bus);
+    const cartId = cart.createCart('user1');
+    cart.addItem(cartId, 'p1', 2);
+    const result = cart.getCart(cartId);
+    expect(result).not.toBeNull();
+    expect(result!.items).toHaveLength(1);
+    expect(result!.items[0].quantity).toBe(2);
+  });
+
+  it('should consolidate same-product items', () => {
+    const cart = createCartService(bus);
+    const cartId = cart.createCart('user1');
+    cart.addItem(cartId, 'p1', 2);
+    cart.addItem(cartId, 'p1', 3);
+    const result = cart.getCart(cartId);
+    expect(result!.items).toHaveLength(1);
+    expect(result!.items[0].quantity).toBe(5);
+  });
+
+  it('should remove items', () => {
+    const cart = createCartService(bus);
+    const cartId = cart.createCart('user1');
+    cart.addItem(cartId, 'p1', 2);
+    cart.removeItem(cartId, 'p1');
+    expect(cart.getCart(cartId)!.items).toHaveLength(0);
+  });
+
+  it('should update quantity', () => {
+    const cart = createCartService(bus);
+    const cartId = cart.createCart('user1');
+    cart.addItem(cartId, 'p1', 2);
+    cart.updateQuantity(cartId, 'p1', 10);
+    expect(cart.getCart(cartId)!.items[0].quantity).toBe(10);
+  });
+
+  it('should clear cart', () => {
+    const cart = createCartService(bus);
+    const cartId = cart.createCart('user1');
+    cart.addItem(cartId, 'p1', 2);
+    cart.clearCart(cartId);
+    expect(cart.getCart(cartId)!.items).toHaveLength(0);
+  });
+
+  it('should return null for nonexistent cart', () => {
+    const cart = createCartService(bus);
+    expect(cart.getCart('nonexistent')).toBeNull();
+  });
+});
+
+describe('PricingService', () => {
+  it('should calculate total with tax', () => {
+    const pricing = createPricingService(bus);
+    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 2, price: 10 }]);
+    expect(result.subtotal).toBe(20);
+    expect(result.discount).toBe(0);
+    expect(result.tax).toBe(2);
+    expect(result.total).toBe(22);
+  });
+
+  it('should apply discount code', () => {
+    const pricing = createPricingService(bus);
+    pricing.addDiscountCode('SAVE10', 10);
+    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 1, price: 100 }], 'SAVE10');
+    expect(result.subtotal).toBe(100);
+    expect(result.discount).toBe(10);
+    expect(result.tax).toBe(9); // 90 * 0.1
+    expect(result.total).toBe(99); // 90 + 9
+  });
+
+  it('should track product prices from events', async () => {
+    const pricing = createPricingService(bus);
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    await new Promise(r => setTimeout(r, 10));
+    // Since product ID is generated, we check via events
+    const log = bus.getLog();
+    const created = log.find(e => e.event === Events.PRODUCT_CREATED);
+    expect(created).toBeDefined();
+    const payload = created!.payload as { productId: string; price: number };
