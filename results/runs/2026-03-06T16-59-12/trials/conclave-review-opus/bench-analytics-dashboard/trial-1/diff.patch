+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KwFQu7P6rioVGUqPJyFTtu","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import type Database from \"better-sqlite3\";\n     3→import { AuthRequest, authMiddleware } from \"../auth.js\";\n     4→\n     5→interface EventRow {\n     6→  id: string;\n     7→  tenant_id: string;\n     8→  name: string;\n     9→  properties: string;\n    10→  timestamp: string;\n    11→  user_id: string | null;\n    12→  session_id: string | null;\n    13→}\n    14→\n    15→function eventsToCsv(events: EventRow[]): string {\n    16→  const headers = \"id,name,properties,timestamp,user_id,session_id\";\n    17→  const rows = events.map((e) => {\n    18→    const props = e.properties.replace(/\"/g, '\"\"');\n    19→    return `${e.id},${e.name},\"${props}\",${e.timestamp},${e.user_id || \"\"},${e.session_id || \"\"}`;\n    20→  });\n    21→  return [headers, ...rows].join(\"\\n\");\n    22→}\n    23→\n    24→export function createExportRoutes(db: Database.Database): Router {\n    25→  const router = Router();\n    26→\n    27→  // Export events as JSON\n    28→  router.get(\"/events/json\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    29→    const tenant_id = req.user!.tenant_id;\n    30→    const { event_name, start_date, end_date } = req.query;\n    31→\n    32→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    33→    const params: unknown[] = [tenant_id];\n    34→\n    35→    if (event_name) {\n    36→      sql += \" AND name = ?\";\n    37→      params.push(event_name);\n    38→    }\n    39→    if (start_date) {\n    40→      sql += \" AND timestamp >= ?\";\n    41→      params.push(start_date);\n    42→    }\n    43→    if (end_date) {\n    44→      sql += \" AND timestamp <= ?\";\n    45→      params.push(end_date);\n    46→    }\n    47→\n    48→    sql += \" ORDER BY timestamp DESC\";\n    49→\n    50→    const events = db.prepare(sql).all(...params) as EventRow[];\n    51→\n    52→    const parsed = events.map((e) => ({\n    53→      ...e,\n    54→      properties: JSON.parse(e.properties),\n    55→    }));\n    56→\n    57→    res.setHeader(\"Content-Type\", \"application/json\");\n    58→    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.json\");\n    59→    res.json({ events: parsed });\n    60→  });\n    61→\n    62→  // Export events as CSV\n    63→  router.get(\"/events/csv\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    64→    const tenant_id = req.user!.tenant_id;\n    65→    const { event_name, start_date, end_date } = req.query;\n    66→\n    67→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    68→    const params: unknown[] = [tenant_id];\n    69→\n    70→    if (event_name) {\n    71→      sql += \" AND name = ?\";\n    72→      params.push(event_name);\n    73→    }\n    74→    if (start_date) {\n    75→      sql += \" AND timestamp >= ?\";\n    76→      params.push(start_date);\n    77→    }\n    78→    if (end_date) {\n    79→      sql += \" AND timestamp <= ?\";\n    80→      params.push(end_date);\n    81→    }\n    82→\n    83→    sql += \" ORDER BY timestamp DESC\";\n    84→\n    85→    const events = db.prepare(sql).all(...params) as EventRow[];\n    86→\n    87→    res.setHeader(\"Content-Type\", \"text/csv\");\n    88→    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    89→    res.send(eventsToCsv(events));\n    90→  });\n    91→\n    92→  // Export dashboard data as JSON\n    93→  router.get(\"/dashboards/:id/json\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    94→    const tenant_id = req.user!.tenant_id;\n    95→\n    96→    const dashboard = db.prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id) as Record<string, unknown> | undefined;\n    97→\n    98→    if (!dashboard) {\n    99→      res.status(404).json({ error: \"Dashboard not found\" });\n   100→      return;\n   101→    }\n   102→\n   103→    const widgets = db.prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\").all(req.params.id) as Array<Record<string, unknown>>;\n   104→\n   105→    res.setHeader(\"Content-Type\", \"application/json\");\n   106→    res.setHeader(\"Content-Disposition\", `attachment; filename=dashboard-${req.params.id}.json`);\n   107→    res.json({\n   108→      dashboard: { ...dashboard, config: JSON.parse(dashboard.config as string) },\n   109→      widgets: widgets.map((w) => ({ ...w, config: JSON.parse(w.config as string) })),\n   110→    });\n   111→  });\n   112→\n   113→  // Export dashboard data as CSV\n   114→  router.get(\"/dashboards/:id/csv\", authMiddleware, (req: AuthRequest, res: Response): void => {\n   115→    const tenant_id = req.user!.tenant_id;\n   116→\n   117→    const dashboard = db.prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id) as Record<string, unknown> | undefined;\n   118→\n   119→    if (!dashboard) {\n   120→      res.status(404).json({ error: \"Dashboard not found\" });\n   121→      return;\n   122→    }\n   123→\n   124→    const widgets = db.prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\").all(req.params.id) as Array<Record<string, unknown>>;\n   125→\n   126→    const headers = \"widget_id,type,config,position_x,position_y,width,height\";\n   127→    const rows = widgets.map((w) => {\n   128→      const config = (w.config as string).replace(/\"/g, '\"\"');\n   129→      return `${w.id},${w.type},\"${config}\",${w.position_x},${w.position_y},${w.width},${w.height}`;\n   130→    });\n   131→\n   132→    const csv = `dashboard_id,name,config\\n${dashboard.id},\"${(dashboard.name as string).replace(/\"/g, '\"\"')}\",\"${(dashboard.config as string).replace(/\"/g, '\"\"')}\"\\n\\n${headers}\\n${rows.join(\"\\n\")}`;\n   133→\n   134→    res.setHeader(\"Content-Type\", \"text/csv\");\n   135→    res.setHeader(\"Content-Disposition\", `attachment; filename=dashboard-${req.params.id}.csv`);\n   136→    res.send(csv);\n   137→  });\n   138→\n   139→  return router;\n   140→}\n   141→"}]},"parent_tool_use_id":"toolu_01Jf2v5QKaPojZ1BJrvntMtu","session_id":"11ef50d5-460e-43ac-9e6b-de75eb11b90c","uuid":"1c8f8f7f-9305-43bb-a6f5-a0bc233d184e"}
