+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HVymPDaYcv84EBJmBPfBNf","type":"tool_result","content":"     1→import Database from \"better-sqlite3\";\n     2→import { readFileSync } from \"fs\";\n     3→import { join } from \"path\";\n     4→\n     5→export function createDatabase(dbPath: string = \":memory:\"): Database.Database {\n     6→  const db = new Database(dbPath);\n     7→  db.pragma(\"journal_mode = WAL\");\n     8→  db.pragma(\"foreign_keys = ON\");\n     9→\n    10→  const schema = readFileSync(join(__dirname, \"..\", \"schema.sql\"), \"utf-8\");\n    11→  db.exec(schema);\n    12→\n    13→  return db;\n    14→}\n    15→"}]},"parent_tool_use_id":"toolu_01Jf2v5QKaPojZ1BJrvntMtu","session_id":"11ef50d5-460e-43ac-9e6b-de75eb11b90c","uuid":"9f891625-3df6-4a41-9556-33fee479c848"}
