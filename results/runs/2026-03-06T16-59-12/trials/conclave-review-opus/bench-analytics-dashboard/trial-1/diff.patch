rsed });\n  });\n\n  // Get dashboard by ID\n  router.get(\"/:id\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    const tenant_id = req.user!.tenant_id;\n    const dashboard = db.prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id) as Record<string, unknown> | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const widgets = db.prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\").all(req.params.id) as Array<Record<string, unknown>>;\n\n    res.json({\n      dashboard: { ...dashboard, config: JSON.parse(dashboard.config as string) },\n      widgets: widgets.map((w) => ({ ...w, config: JSON.parse(w.config as string) })),\n    });\n  });\n\n  // Update dashboard\n  router.put(\"/:id\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    const tenant_id = req.user!.tenant_id;\n    const { name, config } = req.body;\n\n    const existing = db.prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id) as Record<string, unknown> | undefined;\n\n    if (!existing) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const updatedName = name || existing.name;\n    const updatedConfig = config !== undefined ? JSON.stringify(config) : (existing.config as string);\n    const now = new Date().toISOString();\n\n    db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n      updatedName,\n      updatedConfig,\n      now,\n      req.params.id\n    );\n\n    res.json({\n      dashboard: {\n        id: req.params.id,\n        tenant_id,\n        name: updatedName,\n        owner_id: existing.owner_id,\n        config: config !== undefined ? config : JSON.parse(existing.config as string),\n        created_at: existing.created_at,\n        updated_at: now,\n      },\n    });\n  });\n\n  // Delete dashboard\n  router.delete(\"/:id\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    const tenant_id = req.user!.tenant_id;\n\n    const existing = db.prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id);\n\n    if (!existing) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n\n    res.json({ message: \"Dashboard deleted\" });\n  });\n\n  // Add widget to dashboard\n  router.post(\"/:id/widgets\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    const tenant_id = req.user!.tenant_id;\n\n    const dashboard = db.prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id);\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    const { type, config, position_x, position_y, width, height } = req.body;\n\n    if (!type || ![\"counter\", \"timeseries\", \"breakdown\", \"funnel\"].includes(type)) {\n      res.status(400).json({ error: \"Valid widget type is required (counter, timeseries, breakdown, funnel)\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const widgetConfig = JSON.stringify(config || {});\n\n    db.prepare(\n      \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n    ).run(id, req.params.id, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);\n\n    res.status(201).json({\n      widget: { id, dashboard_id: req.params.id, type, config: config || {}, position_x: position_x || 0, position_y: position_y || 0, width: width || 1, height: height || 1 },\n    });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
