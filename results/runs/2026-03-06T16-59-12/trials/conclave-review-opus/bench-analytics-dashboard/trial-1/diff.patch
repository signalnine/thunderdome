hboards/${create.body.dashboard.id}`).set(\"Authorization\", `Bearer ${token}`);\n   275→    expect(res.status).toBe(200);\n   276→    const get = await request(app).get(`/api/dashboards/${create.body.dashboard.id}`).set(\"Authorization\", `Bearer ${token}`);\n   277→    expect(get.status).toBe(404);\n   278→  });\n   279→\n   280→  it(\"tenant isolation: different tenant cannot see dashboards\", async () => {\n   281→    await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n   282→    const otherToken = await registerAndLogin(app, \"other@example.com\", \"t2\");\n   283→    const res = await request(app).get(\"/api/dashboards\").set(\"Authorization\", `Bearer ${otherToken}`);\n   284→    expect(res.body.dashboards.length).toBe(0);\n   285→  });\n   286→\n   287→  it(\"adds a widget to a dashboard\", async () => {\n   288→    const create = await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n   289→    const res = await request(app)\n   290→      .post(`/api/dashboards/${create.body.dashboard.id}/widgets`)\n   291→      .set(\"Authorization\", `Bearer ${token}`)\n   292→      .send({ type: \"counter\", config: { event_name: \"page_view\" } });\n   293→    expect(res.status).toBe(201);\n   294→    expect(res.body.widget.type).toBe(\"counter\");\n   295→  });\n   296→});\n   297→\n   298→describe(\"Data Export\", () => {\n   299→  let token: string;\n   300→\n   301→  beforeEach(async () => {\n   302→    token = await registerAndLogin(app, \"test@example.com\", \"t1\");\n   303→    await request(app)\n   304→      .post(\"/api/events/batch\")\n   305→      .set(\"Authorization\", `Bearer ${token}`)\n   306→      .send({\n   307→        events: [\n   308→          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00Z\" },\n   309→          { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-02T12:00:00Z\" },\n   310→        ],\n   311→      });\n   312→  });\n   313→\n   314→  it(\"exports events as JSON\", async () => {\n   315→    const res = await request(app).get(\"/api/export/events/json\").set(\"Authorization\", `Bearer ${token}`);\n   316→    expect(res.status).toBe(200);\n   317→    expect(res.body.events.length).toBe(2);\n   318→    expect(res.headers[\"content-disposition\"]).toContain(\"events.json\");\n   319→  });\n   320→\n   321→  it(\"exports events as CSV\", async () => {\n   322→    const res = await request(app).get(\"/api/export/events/csv\").set(\"Authorization\", `Bearer ${token}`);\n   323→    expect(res.status).toBe(200);\n   324→    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n   325→    expect(res.text).toContain(\"id,name,properties,timestamp,user_id,session_id\");\n   326→  });\n   327→\n   328→  it(\"exports dashboard as JSON\", async () => {\n   329→    const dash = await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n   330→    const res = await request(app).get(`/api/export/dashboards/${dash.body.dashboard.id}/json`).set(\"Authorization\", `Bearer ${token}`);\n   331→    expect(res.status).toBe(200);\n   332→    expect(res.body.dashboard.name).toBe(\"D1\");\n   333→  });\n   334→\n   335→  it(\"exports dashboard as CSV\", async () => {\n   336→    const dash = await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n   337→    const res = await request(app).get(`/api/export/dashboards/${dash.body.dashboard.id}/csv`).set(\"Authorization\", `Bearer ${token}`);\n   338→    expect(res.status).toBe(200);\n   339→    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n   340→  });\n   341→\n   342→  it(\"tenant isolation: cannot export other tenant's events\", async () => {\n   343→    const otherToken = await registerAndLogin(app, \"other@example.com\", \"t2\");\n   344→    const res = a