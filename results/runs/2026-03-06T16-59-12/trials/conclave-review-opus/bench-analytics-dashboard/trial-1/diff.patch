+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013jni8HTsLzRwqwH3zTzGaV","type":"tool_result","content":"     1→import { Request, Response, NextFunction } from \"express\";\n     2→import jwt from \"jsonwebtoken\";\n     3→import { createHash } from \"crypto\";\n     4→import type Database from \"better-sqlite3\";\n     5→\n     6→const JWT_SECRET = process.env.JWT_SECRET || \"analytics-dashboard-secret\";\n     7→\n     8→export interface AuthUser {\n     9→  id: string;\n    10→  email: string;\n    11→  tenant_id: string;\n    12→  role: string;\n    13→}\n    14→\n    15→export interface AuthRequest extends Request {\n    16→  user?: AuthUser;\n    17→  db?: Database.Database;\n    18→}\n    19→\n    20→export function hashPassword(password: string): string {\n    21→  return createHash(\"sha256\").update(password).digest(\"hex\");\n    22→}\n    23→\n    24→export function generateToken(user: AuthUser): string {\n    25→  return jwt.sign(\n    26→    { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role },\n    27→    JWT_SECRET,\n    28→    { expiresIn: \"24h\" }\n    29→  );\n    30→}\n    31→\n    32→export function verifyToken(token: string): AuthUser {\n    33→  return jwt.verify(token, JWT_SECRET) as AuthUser;\n    34→}\n    35→\n    36→export function authMiddleware(req: AuthRequest, res: Response, next: NextFunction): void {\n    37→  const header = req.headers.authorization;\n    38→  if (!header || !header.startsWith(\"Bearer \")) {\n    39→    res.status(401).json({ error: \"Authentication required\" });\n    40→    return;\n    41→  }\n    42→\n    43→  const token = header.slice(7);\n    44→  try {\n    45→    const user = verifyToken(token);\n    46→    req.user = user;\n    47→    next();\n    48→  } catch {\n    49→    res.status(401).json({ error: \"Invalid or expired token\" });\n    50→  }\n    51→}\n    52→\n    53→export function requireRole(...roles: string[]) {\n    54→  return (req: AuthRequest, res: Response, next: NextFunction): void => {\n    55→    if (!req.user) {\n    56→      res.status(401).json({ error: \"Authentication required\" });\n    57→      return;\n    58→    }\n    59→    if (!roles.includes(req.user.role)) {\n    60→      res.status(403).json({ error: \"Insufficient permissions\" });\n    61→      return;\n    62→    }\n    63→    next();\n    64→  };\n    65→}\n    66→"}]},"parent_tool_use_id":"toolu_01Jf2v5QKaPojZ1BJrvntMtu","session_id":"11ef50d5-460e-43ac-9e6b-de75eb11b90c","uuid":"b7157815-1a73-4fb5-ba67-172744667538"}
