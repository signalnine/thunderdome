-    (req as Record<string, unknown>).user = { id: userId, tenantId };
-    next();
-  };
-}
-
-function createPublicApp() {
-  const app = express();
-  app.use(express.json());
-  app.use('/users', usersRouter);
-  app.use(errorHandler);
-  return app;
-}
-
-function createAuthedApp(userId: string, tenantId: string) {
-  const app = express();
-  app.use(express.json());
-  app.use(mockAuth(userId, tenantId));
-  app.use('/users', usersRouter);
-  app.use(errorHandler);
-  return app;
-}
-
