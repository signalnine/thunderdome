({ name: \"Updated\" });\n    expect(res.status).toBe(200);\n    expect(res.body.dashboard.name).toBe(\"Updated\");\n  });\n\n  it(\"deletes a dashboard\", async () => {\n    const create = await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n    const res = await request(app).delete(`/api/dashboards/${create.body.dashboard.id}`).set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    const get = await request(app).get(`/api/dashboards/${create.body.dashboard.id}`).set(\"Authorization\", `Bearer ${token}`);\n    expect(get.status).toBe(404);\n  });\n\n  it(\"tenant isolation: different tenant cannot see dashboards\", async () => {\n    await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n    const otherToken = await registerAndLogin(app, \"other@example.com\", \"t2\");\n    const res = await request(app).get(\"/api/dashboards\").set(\"Authorization\", `Bearer ${otherToken}`);\n    expect(res.body.dashboards.length).toBe(0);\n  });\n\n  it(\"adds a widget to a dashboard\", async () => {\n    const create = await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n    const res = await request(app)\n      .post(`/api/dashboards/${create.body.dashboard.id}/widgets`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ type: \"counter\", config: { event_name: \"page_view\" } });\n    expect(res.status).toBe(201);\n    expect(res.body.widget.type).toBe(\"counter\");\n  });\n});\n\ndescribe(\"Data Export\", () => {\n  let token: string;\n\n  beforeEach(async () => {\n    token = await registerAndLogin(app, \"test@example.com\", \"t1\");\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00Z\" },\n          { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-02T12:00:00Z\" },\n        ],\n      });\n  });\n\n  it(\"exports events as JSON\", async () => {\n    const res = await request(app).get(\"/api/export/events/json\").set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(2);\n    expect(res.headers[\"content-disposition\"]).toContain(\"events.json\");\n  });\n\n  it(\"exports events as CSV\", async () => {\n    const res = await request(app).get(\"/api/export/events/csv\").set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,name,properties,timestamp,user_id,session_id\");\n  });\n\n  it(\"exports dashboard as JSON\", async () => {\n    const dash = await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n    const res = await request(app).get(`/api/export/dashboards/${dash.body.dashboard.id}/json`).set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboard.name).toBe(\"D1\");\n  });\n\n  it(\"exports dashboard as CSV\", async () => {\n    const dash = await request(app).post(\"/api/dashboards\").set(\"Authorization\", `Bearer ${token}`).send({ name: \"D1\" });\n    const res = await request(app).get(`/api/export/dashboards/${dash.body.dashboard.id}/csv`).set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n  });\n\n  it(\"tenant isolation: cannot export other tenant's events\", async () => {\n    const otherToken = await registerAndLogin(app, \"other@example.com\", \"t2\");\n    const res = await request(app).get(\"/api/export/events/json\").set(\"Authorization\", `Bearer ${otherToken}`);\n    expect(res.body.events.length).toBe(0);\n  });\n\n  it(\"returns 401 without auth\", async () => {\n    const res = await request(app).get(\"/api/export/events/json\");\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
