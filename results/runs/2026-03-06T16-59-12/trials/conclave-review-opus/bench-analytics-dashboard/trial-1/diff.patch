+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VnuuxDuTqb6hecr4Whc8hm","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import { v4 as uuidv4 } from \"uuid\";\n     3→import type Database from \"better-sqlite3\";\n     4→import { AuthRequest, authMiddleware } from \"../auth.js\";\n     5→\n     6→export function createEventRoutes(db: Database.Database): Router {\n     7→  const router = Router();\n     8→\n     9→  // Ingest single event\n    10→  router.post(\"/\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    11→    const { name, properties, timestamp, session_id } = req.body;\n    12→\n    13→    if (!name) {\n    14→      res.status(400).json({ error: \"Event name is required\" });\n    15→      return;\n    16→    }\n    17→\n    18→    const id = uuidv4();\n    19→    const tenant_id = req.user!.tenant_id;\n    20→    const user_id = req.user!.id;\n    21→    const eventTimestamp = timestamp || new Date().toISOString();\n    22→    const eventProperties = JSON.stringify(properties || {});\n    23→\n    24→    db.prepare(\n    25→      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    26→    ).run(id, tenant_id, name, eventProperties, eventTimestamp, user_id, session_id || null);\n    27→\n    28→    res.status(201).json({ event: { id, tenant_id, name, properties: properties || {}, timestamp: eventTimestamp, user_id, session_id: session_id || null } });\n    29→  });\n    30→\n    31→  // Batch ingest events\n    32→  router.post(\"/batch\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    33→    const { events } = req.body;\n    34→\n    35→    if (!Array.isArray(events) || events.length === 0) {\n    36→      res.status(400).json({ error: \"events array is required and must not be empty\" });\n    37→      return;\n    38→    }\n    39→\n    40→    const tenant_id = req.user!.tenant_id;\n    41→    const user_id = req.user!.id;\n    42→\n    43→    const insert = db.prepare(\n    44→      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    45→    );\n    46→\n    47→    const insertMany = db.transaction((evts: Array<Record<string, unknown>>) => {\n    48→      const results: Array<Record<string, unknown>> = [];\n    49→      for (const evt of evts) {\n    50→        if (!evt.name) continue;\n    51→        const id = uuidv4();\n    52→        const eventTimestamp = (evt.timestamp as string) || new Date().toISOString();\n    53→        const eventProperties = JSON.stringify(evt.properties || {});\n    54→        insert.run(id, tenant_id, evt.name, eventProperties, eventTimestamp, user_id, (evt.session_id as string) || null);\n    55→        results.push({ id, name: evt.name, timestamp: eventTimestamp });\n    56→      }\n    57→      return results;\n    58→    });\n    59→\n    60→    const results = insertMany(events);\n    61→    res.status(201).json({ inserted: results.length, events: results });\n    62→  });\n    63→\n    64→  return router;\n    65→}\n    66→"}]},"parent_tool_use_id":"toolu_01Jf2v5QKaPojZ1BJrvntMtu","session_id":"11ef50d5-460e-43ac-9e6b-de75eb11b90c","uuid":"4719c4c3-dfc2-408d-a281-c6c03098cd8f"}
