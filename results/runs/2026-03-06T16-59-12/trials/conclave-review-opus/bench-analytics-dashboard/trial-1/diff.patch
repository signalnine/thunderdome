+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EDjEz1DMckcCpBA6ogxtcq","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import { v4 as uuidv4 } from \"uuid\";\n     3→import type Database from \"better-sqlite3\";\n     4→import { AuthRequest, authMiddleware } from \"../auth.js\";\n     5→\n     6→export function createDashboardRoutes(db: Database.Database): Router {\n     7→  const router = Router();\n     8→\n     9→  // Create dashboard\n    10→  router.post(\"/\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    11→    const { name, config } = req.body;\n    12→\n    13→    if (!name) {\n    14→      res.status(400).json({ error: \"Dashboard name is required\" });\n    15→      return;\n    16→    }\n    17→\n    18→    const id = uuidv4();\n    19→    const tenant_id = req.user!.tenant_id;\n    20→    const owner_id = req.user!.id;\n    21→    const dashConfig = JSON.stringify(config || {});\n    22→    const now = new Date().toISOString();\n    23→\n    24→    db.prepare(\n    25→      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    26→    ).run(id, tenant_id, name, owner_id, dashConfig, now, now);\n    27→\n    28→    res.status(201).json({\n    29→      dashboard: { id, tenant_id, name, owner_id, config: config || {}, created_at: now, updated_at: now },\n    30→    });\n    31→  });\n    32→\n    33→  // List dashboards (tenant-scoped)\n    34→  router.get(\"/\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    35→    const tenant_id = req.user!.tenant_id;\n    36→    const dashboards = db.prepare(\"SELECT * FROM dashboards WHERE tenant_id = ?\").all(tenant_id) as Array<Record<string, unknown>>;\n    37→\n    38→    const parsed = dashboards.map((d) => ({\n    39→      ...d,\n    40→      config: JSON.parse(d.config as string),\n    41→    }));\n    42→\n    43→    res.json({ dashboards: parsed });\n    44→  });\n    45→\n    46→  // Get dashboard by ID\n    47→  router.get(\"/:id\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    48→    const tenant_id = req.user!.tenant_id;\n    49→    const dashboard = db.prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id) as Record<string, unknown> | undefined;\n    50→\n    51→    if (!dashboard) {\n    52→      res.status(404).json({ error: \"Dashboard not found\" });\n    53→      return;\n    54→    }\n    55→\n    56→    const widgets = db.prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\").all(req.params.id) as Array<Record<string, unknown>>;\n    57→\n    58→    res.json({\n    59→      dashboard: { ...dashboard, config: JSON.parse(dashboard.config as string) },\n    60→      widgets: widgets.map((w) => ({ ...w, config: JSON.parse(w.config as string) })),\n    61→    });\n    62→  });\n    63→\n    64→  // Update dashboard\n    65→  router.put(\"/:id\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    66→    const tenant_id = req.user!.tenant_id;\n    67→    const { name, config } = req.body;\n    68→\n    69→    const existing = db.prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id) as Record<string, unknown> | undefined;\n    70→\n    71→    if (!existing) {\n    72→      res.status(404).json({ error: \"Dashboard not found\" });\n    73→      return;\n    74→    }\n    75→\n    76→    const updatedName = name || existing.name;\n    77→    const updatedConfig = config !== undefined ? JSON.stringify(config) : (existing.config as string);\n    78→    const now = new Date().toISOString();\n    79→\n    80→    db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n    81→      updatedName,\n    82→      updatedConfig,\n    83→      now,\n    84→      req.params.id\n    85→    );\n    86→\n    87→    res.json({\n    88→      dashboard: {\n    89→        id: req.params.id,\n    90→        tenant_id,\n    91→        name: updatedName,\n    92→        owner_id: existing.owner_id,\n    93→        config: config !== undefined ? config : JSON.parse(existing.config as string),\n    94→        created_at: existing.created_at,\n    95→        updated_at: now,\n    96→      },\n    97→    });\n    98→  });\n    99→\n   100→  // Delete dashboard\n   101→  router.delete(\"/:id\", authMiddleware, (req: AuthRequest, res: Response): void => {\n   102→    const tenant_id = req.user!.tenant_id;\n   103→\n   104→    const existing = db.prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id);\n   105→\n   106→    if (!existing) {\n   107→      res.status(404).json({ error: \"Dashboard not found\" });\n   108→      return;\n   109→    }\n   110→\n   111→    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n   112→\n   113→    res.json({ message: \"Dashboard deleted\" });\n   114→  });\n   115→\n   116→  // Add widget to dashboard\n   117→  router.post(\"/:id/widgets\", authMiddleware, (req: AuthRequest, res: Response): void => {\n   118→    const tenant_id = req.user!.tenant_id;\n   119→\n   120→    const dashboard = db.prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\").get(req.params.id, tenant_id);\n   121→    if (!dashboard) {\n   122→      res.status(404).json({ error: \"Dashboard not found\" });\n   123→      return;\n   124→    }\n   125→\n   126→    const { type, config, position_x, position_y, width, height } = req.body;\n   127→\n   128→    if (!type || ![\"counter\", \"timeseries\", \"breakdown\", \"funnel\"].includes(type)) {\n   129→      res.status(400).json({ error: \"Valid widget type is required (counter, timeseries, breakdown, funnel)\" });\n   130→      return;\n   131→    }\n   132→\n   133→    const id = uuidv4();\n   134→    const widgetConfig = JSON.stringify(config || {});\n   135→\n   136→    db.prepare(\n   137→      \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n   138→    ).run(id, req.params.id, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);\n   139→\n   140→    res.status(201).json({\n   141→      widget: { id, dashboard_id: req.params.id, type, config: config || {}, position_x: position_x || 0, position_y: position_y || 0, width: width || 1, height: height || 1 },\n   142→    });\n   143→  });\n   144→\n   145→  return router;\n   146→}\n   147→"}]},"parent_tool_use_id":"toolu_01Jf2v5QKaPojZ1BJrvntMtu","session_id":"11ef50d5-460e-43ac-9e6b-de75eb11b90c","uuid":"bbdb634a-f000-4511-9878-ccf96e0e4e9e"}
