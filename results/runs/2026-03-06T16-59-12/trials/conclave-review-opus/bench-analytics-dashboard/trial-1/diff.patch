+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KyfADzg14DnebKzCUgB5Eh","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import { v4 as uuidv4 } from \"uuid\";\n     3→import type Database from \"better-sqlite3\";\n     4→import { AuthRequest, hashPassword, generateToken, authMiddleware, requireRole } from \"../auth.js\";\n     5→\n     6→export function createUserRoutes(db: Database.Database): Router {\n     7→  const router = Router();\n     8→\n     9→  // Register\n    10→  router.post(\"/register\", (req: AuthRequest, res: Response): void => {\n    11→    const { email, password, tenant_id, role } = req.body;\n    12→\n    13→    if (!email || !password || !tenant_id) {\n    14→      res.status(400).json({ error: \"email, password, and tenant_id are required\" });\n    15→      return;\n    16→    }\n    17→\n    18→    const existing = db.prepare(\"SELECT id FROM users WHERE email = ?\").get(email);\n    19→    if (existing) {\n    20→      res.status(409).json({ error: \"Email already registered\" });\n    21→      return;\n    22→    }\n    23→\n    24→    const id = uuidv4();\n    25→    const password_hash = hashPassword(password);\n    26→    const userRole = role && [\"admin\", \"viewer\", \"editor\"].includes(role) ? role : \"viewer\";\n    27→\n    28→    db.prepare(\n    29→      \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n    30→    ).run(id, email, password_hash, tenant_id, userRole);\n    31→\n    32→    const user = { id, email, tenant_id, role: userRole };\n    33→    const token = generateToken(user);\n    34→\n    35→    res.status(201).json({ user, token });\n    36→  });\n    37→\n    38→  // Login\n    39→  router.post(\"/login\", (req: AuthRequest, res: Response): void => {\n    40→    const { email, password } = req.body;\n    41→\n    42→    if (!email || !password) {\n    43→      res.status(400).json({ error: \"email and password are required\" });\n    44→      return;\n    45→    }\n    46→\n    47→    const user = db.prepare(\"SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?\").get(email) as {\n    48→      id: string;\n    49→      email: string;\n    50→      password_hash: string;\n    51→      tenant_id: string;\n    52→      role: string;\n    53→    } | undefined;\n    54→\n    55→    if (!user || user.password_hash !== hashPassword(password)) {\n    56→      res.status(401).json({ error: \"Invalid email or password\" });\n    57→      return;\n    58→    }\n    59→\n    60→    const token = generateToken({\n    61→      id: user.id,\n    62→      email: user.email,\n    63→      tenant_id: user.tenant_id,\n    64→      role: user.role,\n    65→    });\n    66→\n    67→    res.json({\n    68→      user: { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role },\n    69→      token,\n    70→    });\n    71→  });\n    72→\n    73→  // Get profile\n    74→  router.get(\"/me\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    75→    const user = db.prepare(\"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\").get(req.user!.id) as Record<string, unknown> | undefined;\n    76→\n    77→    if (!user) {\n    78→      res.status(404).json({ error: \"User not found\" });\n    79→      return;\n    80→    }\n    81→\n    82→    res.json({ user });\n    83→  });\n    84→\n    85→  // Update user role (admin only)\n    86→  router.put(\"/:userId/role\", authMiddleware, requireRole(\"admin\"), (req: AuthRequest, res: Response): void => {\n    87→    const { userId } = req.params;\n    88→    const { role } = req.body;\n    89→\n    90→    if (!role || ![\"admin\", \"viewer\", \"editor\"].includes(role)) {\n    91→      res.status(400).json({ error: \"Valid role is required (admin, viewer, editor)\" });\n    92→      return;\n    93→    }\n    94→\n    95→    const target = db.prepare(\"SELECT id, tenant_id FROM users WHERE id = ?\").get(userId) as { id: string; tenant_id: string } | undefined;\n    96→\n    97→    if (!target) {\n    98→      res.status(404).json({ error: \"User not found\" });\n    99→      return;\n   100→    }\n   101→\n   102→    if (target.tenant_id !== req.user!.tenant_id) {\n   103→      res.status(403).json({ error: \"Cannot modify users in other tenants\" });\n   104→      return;\n   105→    }\n   106→\n   107→    db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, userId);\n   108→\n   109→    res.json({ message: \"Role updated\", userId, role });\n   110→  });\n   111→\n   112→  return router;\n   113→}\n   114→"}]},"parent_tool_use_id":"toolu_01Jf2v5QKaPojZ1BJrvntMtu","session_id":"11ef50d5-460e-43ac-9e6b-de75eb11b90c","uuid":"efad3f95-0648-4e6f-aeeb-ee066e0ae99a"}
