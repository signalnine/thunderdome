+import { describe, it, expect, beforeEach } from "vitest";
+import request from "supertest";
+import { createApp } from "./app.js";
+import { createDatabase } from "./db.js";
+import type Database from "better-sqlite3";
+import type { Express } from "express";
+
+let db: Database.Database;
+let app: Express;
+
+beforeEach(() => {
+  db = createDatabase();
+  app = createApp(db);
+});
+
+describe("Health", () => {
+  it("GET /health returns ok", async () => {
+    const res = await request(app).get("/health");
+    expect(res.status).toBe(200);
+    expect(res.body.status).toBe("ok");
+  });
+});
+
+describe("User Management", () => {
+  it("registers a new user", async () => {
+    const res = await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+    expect(res.status).toBe(201);
+    expect(res.body.user.email).toBe("test@example.com");
+    expect(res.body.user.tenant_id).toBe("t1");
+    expect(res.body.user.role).toBe("viewer");
+    expect(res.body.token).toBeDefined();
+  });
+
+  it("registers with specified role", async () => {
+    const res = await request(app)
+      .post("/api/users/register")
+      .send({ email: "admin@example.com", password: "pass123", tenant_id: "t1", role: "admin" });
+    expect(res.status).toBe(201);
+    expect(res.body.user.role).toBe("admin");
+  });
+
+  it("rejects duplicate email", async () => {
+    await request(app).post("/api/users/register").send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+    const res = await request(app).post("/api/users/register").send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+    expect(res.status).toBe(409);
+  });
+
+  it("logs in with valid credentials", async () => {
+    await request(app).post("/api/users/register").send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+    const res = await request(app).post("/api/users/login").send({ email: "test@example.com", password: "pass123" });
+    expect(res.status).toBe(200);
+    expect(res.body.token).toBeDefined();
+    expect(res.body.user.email).toBe("test@example.com");
+  });
+
+  it("rejects invalid login", async () => {
+    await request(app).post("/api/users/register").send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+    const res = await request(app).post("/api/users/login").send({ email: "test@example.com", password: "wrong" });
+    expect(res.status).toBe(401);
+  });
+
+  it("gets user profile", async () => {
+    const reg = await request(app).post("/api/users/register").send({ email: "test@example.com", password: "pass123", tenant_id: "t1" });
+    const res = await request(app).get("/api/users/me").set("Authorization", `Bearer ${reg.body.token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.user.email).toBe("test@example.com");
+  });
+
+  it("returns 401 for unauthenticated profile request", async () => {
+    const res = await request(app).get("/api/users/me");
+    expect(res.status).toBe(401);
+  });
+
+  it("admin can change user role within same tenant", async () => {
+    const admin = await request(app).post("/api/users/register").send({ email: "admin@example.com", password: "pass123", tenant_id: "t1", role: "admin" });
+    const viewer = await request(app).post("/api/users/register").send({ email: "viewer@example.com", password: "pass123", tenant_id: "t1" });
+    const res = await request(app)
+      .put(`/api/users/${viewer.body.user.id}/role`)
+      .set("Authorization", `Bearer ${admin.body.token}`)
+      .send({ role: "editor" });
+    expect(res.status).toBe(200);
+    expect(res.body.role).toBe("editor");
+  });
+
+  it("admin cannot change role of user in different tenant", async () => {
+    const admin = await request(app).post("/api/users/register").send({ email: "admin@example.com", password: "pass123", tenant_id: "t1", role: "admin" });
+    const other = await request(app).post("/api/users/register").send({ email: "other@example.com", password: "pass123", tenant_id: "t2" });
+    const res = await request(app)
+      .put(`/api/users/${other.body.user.id}/role`)
+      .set("Authorization", `Bearer ${admin.body.token}`)
+      .send({ role: "editor" });
+    expect(res.status).toBe(403);
+  });
+
+  it("non-admin cannot change roles", async () => {
+    const viewer = await request(app).post("/api/users/register").send({ email: "viewer@example.com", password: "pass123", tenant_id: "t1" });
+    const other = await request(app).post("/api/users/register").send({ email: "other@example.com", password: "pass123", tenant_id: "t1" });
+    const res = await request(app)
+      .put(`/api/users/${other.body.user.id}/role`)
+      .set("Authorization", `Bearer ${viewer.body.token}`)
+      .send({ role: "editor" });
+    expect(res.status).toBe(403);
+  });
+});
+
+async function registerAndLogin(appInstance: Express, email: string, tenantId: string, role = "viewer") {
+  const reg = await request(appInstance).post("/api/users/register").send({ email, password: "pass123", tenant_id: tenantId, role });
+  return reg.body.token as string;
+}
+
+describe("Event Ingestion", () => {
+  it("ingests a single event", async () => {
+    const token = await registerAndLogin(app, "test@example.com", "t1");
+    const res = await request(app)
+      .post("/api/events")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ name: "page_view", properties: { url: "/home" } });
+    expect(res.status).toBe(201);
+    expect(res.body.event.name).toBe("page_view");
+    expect(res.body.event.properties.url).toBe("/home");
+  });
+
+  it("ingests batch events", async () => {
+    const token = await registerAndLogin(app, "test@example.com", "t1");
+    const res = await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ events: [{ name: "click" }, { name: "page_view" }, { name: "scroll" }] });
+    expect(res.status).toBe(201);
+    expect(res.body.inserted).toBe(3);
+  });
+
+  it("returns 401 without auth", async () => {
+    const res = await request(app).post("/api/events").send({ name: "page_view" });
+    expect(res.status).toBe(401);
+  });
+
+  it("returns 400 without event name", async () => {
+    const token = await registerAndLogin(app, "test@example.com", "t1");
+    const res = await request(app)
+      .post("/api/events")
+      .set("Authorization", `Bearer ${token}`)
+      .send({});
+    expect(res.status).toBe(400);
+  });
+});
+
+describe("Query Engine", () => {
+  let token: string;
+
+  beforeEach(async () => {
+    token = await registerAndLogin(app, "test@example.com", "t1");
+    await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-01T10:00:00Z" },
+          { name: "page_view", properties: { url: "/about" }, timestamp: "2024-01-01T14:00:00Z" },
+          { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-02T10:00:00Z" },
+          { name: "click", properties: { button: "signup" }, timestamp: "2024-01-02T12:00:00Z" },
+        ],
+      });
+  });
+
+  it("counts events", async () => {
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ event_name: "page_view" });
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(3);
+  });
+
+  it("counts all events without filter", async () => {
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({});
+    expect(res.body.count).toBe(4);
+  });
+
+  it("counts events with date range", async () => {
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ event_name: "page_view", start_date: "2024-01-02", end_date: "2024-01-03" });
+    expect(res.body.count).toBe(1);
+  });
+
+  it("counts events with property filter", async () => {
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ event_name: "page_view", filters: { url: "/home" } });
+    expect(res.body.count).toBe(2);
+  });
+
+  it("timeseries query", async () => {
+    const res = await request(app)
+      .post("/api/queries/timeseries")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ event_name: "page_view", interval: "day" });
+    expect(res.status).toBe(200);
+    expect(res.body.timeseries.length).toBe(2);
+  });
+
+  it("breakdown query", async () => {
+    const res = await request(app)
+      .post("/api/queries/breakdown")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ event_name: "page_view", property: "url" });
+    expect(res.status).toBe(200);
+    expect(res.body.breakdown.length).toBe(2);
+    expect(res.body.breakdown[0].count).toBe(2);
+  });
+
+  it("tenant isolation: different tenant cannot see events", async () => {
+    const otherToken = await registerAndLogin(app, "other@example.com", "t2");
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${otherToken}`)
+      .send({});
+    expect(res.body.count).toBe(0);
+  });
+});
+
+describe("Dashboard CRUD", () => {
+  let token: string;
+
+  beforeEach(async () => {
+    token = await registerAndLogin(app, "test@example.com", "t1");
+  });
+
+  it("creates a dashboard", async () => {
+    const res = await request(app)
+      .post("/api/dashboards")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ name: "My Dashboard", config: { theme: "dark" } });
+    expect(res.status).toBe(201);
+    expect(res.body.dashboard.name).toBe("My Dashboard");
+    expect(res.body.dashboard.config.theme).toBe("dark");
+  });
+
+  it("lists dashboards for tenant", async () => {
+    await request(app).post("/api/dashboards").set("Authorization", `Bearer ${token}`).send({ name: "D1" });
+    await request(app).post("/api/dashboards").set("Authorization", `Bearer ${token}`).send({ name: "D2" });
+    const res = await request(app).get("/api/dashboards").set("Authorization", `Bearer ${token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.dashboards.length).toBe(2);
+  });
+
+  it("gets dashboard by id", async () => {
+    const create = await request(app).post("/api/dashboards").set("Authorization", `Bearer ${token}`).send({ name: "D1" });
+    const res = await request(app).get(`/api/dashboards/${create.body.dashboard.id}`).set("Authorization", `Bearer ${token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.dashboard.name).toBe("D1");
+  });
+
+  it("updates a dashboard", async () => {
+    const create = await request(app).post("/api/dashboards").set("Authorization", `Bearer ${token}`).send({ name: "D1" });
+    const res = await request(app)
+      .put(`/api/dashboards/${create.body.dashboard.id}`)
+      .set("Authorization", `Bearer ${token}`)
+      .send({ name: "Updated" });
+    expect(res.status).toBe(200);
+    expect(res.body.dashboard.name).toBe("Updated");
+  });
+
+  it("deletes a dashboard", async () => {
+    const create = await request(app).post("/api/dashboards").set("Authorization", `Bearer ${token}`).send({ name: "D1" });
+    const res = await request(app).delete(`/api/dashboards/${create.body.dashboard.id}`).set("Authorization", `Bearer ${token}`);
+    expect(res.status).toBe(200);
+    const get = await request(app).get(`/api/dashboards/${create.body.dashboard.id}`).set("Authorization", `Bearer ${token}`);
