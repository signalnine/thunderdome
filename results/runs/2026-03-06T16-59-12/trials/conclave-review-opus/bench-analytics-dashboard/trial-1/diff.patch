@@ -0,0 +1,166 @@
+import { Router, Response } from "express";
+import type Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+function escapeCsvField(value: string): string {
+  if (/[",\n\r]/.test(value)) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = "id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) => {
+    return [
+      escapeCsvField(e.id),
+      escapeCsvField(e.name),
+      escapeCsvField(e.properties),
+      escapeCsvField(e.timestamp),
+      escapeCsvField(e.user_id || ""),
+      escapeCsvField(e.session_id || ""),
+    ].join(",");
+  });
+  return [headers, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenant_id = req.user!.tenant_id;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenant_id = req.user!.tenant_id;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenant_id];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboard data as JSON
+  router.get("/dashboards/:id/json", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenant_id = req.user!.tenant_id;
+
+    const dashboard = db.prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?").get(req.params.id, tenant_id) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare("SELECT * FROM widgets WHERE dashboard_id = ?").all(req.params.id) as Array<Record<string, unknown>>;
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${req.params.id}.json`);
+    res.json({
+      dashboard: { ...dashboard, config: JSON.parse(dashboard.config as string) },
+      widgets: widgets.map((w) => ({ ...w, config: JSON.parse(w.config as string) })),
+    });
+  });
+
+  // Export dashboard data as CSV
+  router.get("/dashboards/:id/csv", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenant_id = req.user!.tenant_id;
+
+    const dashboard = db.prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?").get(req.params.id, tenant_id) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare("SELECT * FROM widgets WHERE dashboard_id = ?").all(req.params.id) as Array<Record<string, unknown>>;
+
+    const headers = "widget_id,type,config,position_x,position_y,width,height";
+    const rows = widgets.map((w) => {
+      return [
+        escapeCsvField(String(w.id)),
+        escapeCsvField(String(w.type)),
+        escapeCsvField(String(w.config)),
+        String(w.position_x),
+        String(w.position_y),
+        String(w.width),
+        String(w.height),
+      ].join(",");
+    });
+
+    const dashRow = [
+      escapeCsvField(String(dashboard.id)),
+      escapeCsvField(String(dashboard.name)),
+      escapeCsvField(String(dashboard.config)),
+    ].join(",");
+
+    const csv = `dashboard_id,name,config\n${dashRow}\n\n${headers}\n${rows.join("\n")}`;
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${req.params.id}.csv`);
+    res.send(csv);
+  });
+
+  return router;
+}
