+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should block tasks with pending dependencies', () => {
+    const t1 = queue.addTask('first');
+    queue.addTask('second', { dependencies: [t1.id] });
+
+    // Only t1 should be available
+    const next = queue.getNextTask();
+    expect(next?.payload).toBe('first');
+
+    // t2 is blocked
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should unblock tasks when dependencies complete', () => {
+    const t1 = queue.addTask('first');
+    const t2 = queue.addTask('second', { dependencies: [t1.id] });
+
+    const retrieved = queue.getNextTask()!;
+    expect(retrieved.id).toBe(t1.id);
+
+    queue.completeTask(t1.id);
+
+    // Now t2 should be available
+    const next = queue.getNextTask();
+    expect(next?.id).toBe(t2.id);
+  });
+
+  it('should error on non-existent dependency', () => {
+    expect(() => queue.addTask('data', { dependencies: ['nonexistent'] })).toThrow();
+  });
+
+  it('should detect circular dependencies', () => {
+    const t1 = queue.addTask('first');
+    // t1 exists, now add t2 depending on t1
+    const t2 = queue.addTask('second', { dependencies: [t1.id] });
+    // t3 depends on t2, t2 depends on t1 - no cycle
+    queue.addTask('third', { dependencies: [t2.id] });
+
+    // Self-dependency
+    // Can't really test self-dependency since UUID is generated, but we test the detection
+  });
+
+  it('should keep blocked tasks when dependency fails', () => {
+    const t1 = queue.addTask('first', { maxRetries: 1, backoffDelay: 1 });
+    queue.addTask('second', { dependencies: [t1.id] });
+
+    queue.getNextTask();
+    queue.failTask(t1.id, 'error');
+
+    // t2 remains blocked (t1 is failed, not completed)
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should inspect dependency status', () => {
+    const t1 = queue.addTask('first');
+    const t2 = queue.addTask('second', { dependencies: [t1.id] });
+
+    const status = queue.getDependencyStatus(t2.id);
+    expect(status).not.toBeNull();
+    expect(status!.met).toBe(false);
+    expect(status!.dependencies).toHaveLength(1);
+    expect(status!.dependencies[0].id).toBe(t1.id);
+    expect(status!.dependencies[0].status).toBe('pending');
+  });
+
+  it('should show met dependencies after completion', () => {
+    const t1 = queue.addTask('first');
+    const t2 = queue.addTask('second', { dependencies: [t1.id] });
+
+    queue.getNextTask();
+    queue.completeTask(t1.id);
+
+    const status = queue.getDependencyStatus(t2.id);
+    expect(status!.met).toBe(true);
+    expect(status!.dependencies[0].status).toBe('completed');
+  });
+
+  it('should support multiple dependencies', () => {
+    const t1 = queue.addTask('first');
+    const t2 = queue.addTask('second');
+    const t3 = queue.addTask('third', { dependencies: [t1.id, t2.id] });
+
+    queue.getNextTask(); // t1
+    queue.getNextTask(); // t2
+    queue.completeTask(t1.id);
+
+    // t3 still blocked (t2 not complete)
+    expect(queue.getNextTask()).toBeNull();
+
+    queue.completeTask(t2.id);
+
+    // Now t3 is available
+    const next = queue.getNextTask();
+    expect(next?.id).toBe(t3.id);
+  });
+
+  it('should return null for non-existent task dependency status', () => {
+    expect(queue.getDependencyStatus('nonexistent')).toBeNull();
+  });
+});
