+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012GHK2UdWFUkz4YCUXBWQKC","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 9: Progress Tracking and Cancellation', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  describe('Progress Tracking', () => {\n    12→    it('should update and query progress', () => {\n    13→      queue.addTask('data');\n    14→      const task = queue.getNextTask()!;\n    15→\n    16→      queue.updateProgress(task.id, 50, 'halfway');\n    17→      const progress = queue.getProgress(task.id);\n    18→      expect(progress?.progress).toBe(50);\n    19→      expect(progress?.message).toBe('halfway');\n    20→    });\n    21→\n    22→    it('should reject invalid progress values', () => {\n    23→      queue.addTask('data');\n    24→      const task = queue.getNextTask()!;\n    25→\n    26→      expect(() => queue.updateProgress(task.id, -1)).toThrow();\n    27→      expect(() => queue.updateProgress(task.id, 101)).toThrow();\n    28→    });\n    29→\n    30→    it('should only update progress on processing tasks', () => {\n    31→      const task = queue.addTask('data');\n    32→      expect(() => queue.updateProgress(task.id, 50)).toThrow();\n    33→    });\n    34→\n    35→    it('should notify progress listeners', () => {\n    36→      queue.addTask('data');\n    37→      const task = queue.getNextTask()!;\n    38→\n    39→      const updates: Array<{ progress: number; message?: string }> = [];\n    40→      queue.onProgress(task.id, (progress, message) => {\n    41→        updates.push({ progress, message });\n    42→      });\n    43→\n    44→      queue.updateProgress(task.id, 25, 'quarter');\n    45→      queue.updateProgress(task.id, 75, 'three quarters');\n    46→\n    47→      expect(updates).toHaveLength(2);\n    48→      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n    49→      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n    50→    });\n    51→\n    52→    it('should support unsubscribe', () => {\n    53→      queue.addTask('data');\n    54→      const task = queue.getNextTask()!;\n    55→\n    56→      const updates: number[] = [];\n    57→      const unsubscribe = queue.onProgress(task.id, (progress) => {\n    58→        updates.push(progress);\n    59→      });\n    60→\n    61→      queue.updateProgress(task.id, 25);\n    62→      unsubscribe();\n    63→      queue.updateProgress(task.id, 75);\n    64→\n    65→      expect(updates).toEqual([25]);\n    66→    });\n    67→\n    68→    it('should return null for non-existent task progress', () => {\n    69→      expect(queue.getProgress('nonexistent')).toBeNull();\n    70→    });\n    71→  });\n    72→\n    73→  describe('Cancellation', () => {\n    74→    it('should cancel pending tasks', () => {\n    75→      const task = queue.addTask('data');\n    76→      const result = queue.cancelTask(task.id);\n    77→      expect(result).toBe(true);\n    78→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    79→      expect(queue.getNextTask()).toBeNull();\n    80→    });\n    81→\n    82→    it('should cancel processing tasks', () => {\n    83→      queue.addTask('data');\n    84→      const task = queue.getNextTask()!;\n    85→\n    86→      const result = queue.cancelTask(task.id);\n    87→      expect(result).toBe(true);\n    88→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    89→    });\n    90→\n    91→    it('should not cancel completed tasks', () => {\n    92→      queue.addTask('data');\n    93→      const task = queue.getNextTask()!;\n    94→      queue.completeTask(task.id);\n    95→\n    96→      const result = queue.cancelTask(task.id);\n    97→      expect(result).toBe(false);\n    98→    });\n    99→\n   100→    it('should not cancel failed tasks', () => {\n   101→      queue.addTask('data', { maxRetries: 0 });\n   102→      const task = queue.getNextTask()!;\n   103→      queue.failTask(task.id, 'error');\n   104→\n   105→      const result = queue.cancelTask(task.id);\n   106→      expect(result).toBe(false);\n   107→    });\n   108→\n   109→    it('should not retry cancelled tasks', () => {\n   110→      queue.addTask('data', { maxRetries: 3 });\n   111→      const task = queue.getNextTask()!;\n   112→      queue.cancelTask(task.id);\n   113→\n   114→      // Task is cancelled, should not be available for retry\n   115→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   116→    });\n   117→\n   118→    it('should return false for non-existent task', () => {\n   119→      expect(queue.cancelTask('nonexistent')).toBe(false);\n   120→    });\n   121→  });\n   122→});\n   123→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"2d49ab94-beac-4b97-84c6-ed1ace24fbde"}
