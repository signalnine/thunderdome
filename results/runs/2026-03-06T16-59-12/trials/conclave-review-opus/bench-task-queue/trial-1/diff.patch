index 0000000..7464e3e
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,627 @@
+import { randomUUID } from 'node:crypto';
+import {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  DeadLetteredTask,
+  Schedule,
+  Middleware,
+  TaskHandler,
+  ProgressListener,
+  ShutdownResult,
+  createTask,
+} from './types.js';
+import { parseCron, shouldRun } from './cron.js';
+
+interface QueueState {
+  tasks: Map<string, Task>;
+  deadLetterQueue: DeadLetteredTask[];
+  concurrencyLimit: number;
+  middlewares: Middleware[];
+  handler?: TaskHandler;
+}
+
+export class TaskQueue {
+  private queues: Map<string, QueueState> = new Map();
+  private allTasks: Map<string, Task> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // ---- Phase 1 & 2: Basic FIFO + Named Queues ----
+
+  private getOrCreateQueue(name: string): QueueState {
+    let queue = this.queues.get(name);
+    if (!queue) {
+      queue = {
+        tasks: new Map(),
+        deadLetterQueue: [],
+        concurrencyLimit: 0, // 0 = unlimited
+        middlewares: [],
+      };
+      this.queues.set(name, queue);
+    }
+    return queue;
+  }
+
+  addTask<T>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Queue system is shut down. Cannot add new tasks.');
+    }
+
+    // Phase 3: Validate priority
+    if (options.priority !== undefined) {
+      if (!Number.isInteger(options.priority) || options.priority < 1 || options.priority > 10) {
+        throw new Error(`Invalid priority: ${options.priority}. Must be an integer between 1 and 10.`);
+      }
+    }
+
+    // Phase 7: Validate dependencies
+    if (options.dependencies && options.dependencies.length > 0) {
+      for (const depId of options.dependencies) {
+        const depTask = this.allTasks.get(depId);
+        if (!depTask) {
+          throw new Error(`Dependency task "${depId}" does not exist.`);
+        }
+      }
+    }
+
+    const task = createTask(payload, options);
+
+    // Phase 7: Circular dependency detection
+    if (task.dependencies.length > 0) {
+      this.detectCircularDependencies(task);
+    }
+
+    const queue = this.getOrCreateQueue(task.queue);
+    queue.tasks.set(task.id, task);
+    this.allTasks.set(task.id, task);
+    return task;
+  }
+
+  getNextTask(queueName: string = 'default'): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+
+    // Phase 8: Check concurrency limit
+    if (queue.concurrencyLimit > 0) {
+      const activeCount = this.getActiveCount(queueName);
+      if (activeCount >= queue.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+
+    // Get all pending tasks that are available
+    const candidates: Task[] = [];
+    for (const task of queue.tasks.values()) {
+      if (task.status !== 'pending') continue;
+
+      // Phase 4: Skip delayed tasks not yet available
+      if (task.availableAt > now) continue;
+
+      // Phase 7: Skip tasks with unresolved dependencies
+      if (task.dependencies.length > 0) {
+        if (!this.areDependenciesMet(task)) continue;
+      }
+
+      candidates.push(task);
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Phase 3: Sort by priority (lower = higher priority), then by availableAt, then FIFO (createdAt)
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();
+      if (availDiff !== 0) return availDiff;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempt += 1;
+    task.updatedAt = new Date();
+    return task;
+  }
+
+  getWaitingCount(queueName: string = 'default'): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+
+    let count = 0;
+    for (const task of queue.tasks.values()) {
+      if (task.status === 'pending') count++;
+    }
+    return count;
+  }
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  // ---- Phase 5: Retry with Backoff ----
+
+  completeTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found.`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state (current: ${task.status}).`);
+    }
+
+    task.status = 'completed';
+    task.updatedAt = new Date();
+
+    // Phase 7: Unblock dependent tasks (no action needed, checked at retrieval time)
+    // Dependencies are checked dynamically when getting next task
+  }
+
+  failTask(taskId: string, error?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found.`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state (current: ${task.status}).`);
+    }
+
+    task.error = error;
+    task.updatedAt = new Date();
+
+    if (task.attempt <= task.maxRetries) {
+      // Re-add with exponential backoff delay
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+      task.progressMessage = undefined;
+      task.error = undefined;
+    } else {
+      // Exhausted retries
+      task.status = 'failed';
+
+      // Phase 6: Move to DLQ
+      const queue = this.getOrCreateQueue(task.queue);
+      const dlqTask: DeadLetteredTask = {
+        ...task,
+        failedAt: new Date(),
+        failCount: task.attempt,
+        lastError: error,
+      };
+      queue.deadLetterQueue.push(dlqTask);
+    }
+  }
+
+  // ---- Phase 6: Dead Letter Queue ----
+
+  getDeadLetterTasks(queueName: string = 'default'): DeadLetteredTask[] {
+    const queue = this.queues.get(queueName);
+    if (!queue) return [];
+    return [...queue.deadLetterQueue];
+  }
+
+  reprocessDeadLetteredTask(taskId: string): Task | null {
+    for (const [_queueName, queue] of this.queues) {
+      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);
+      if (index !== -1) {
+        const dlqTask = queue.deadLetterQueue[index];
+        queue.deadLetterQueue.splice(index, 1);
+
+        // Get original task and reset it
+        const task = this.allTasks.get(taskId);
+        if (task) {
+          task.status = 'pending';
+          task.attempt = 0;
+          task.error = undefined;
+          task.progress = 0;
+          task.progressMessage = undefined;
+          task.availableAt = new Date();
+          task.updatedAt = new Date();
+          return task;
+        }
+
+        // If task not in allTasks (shouldn't happen), recreate from DLQ
+        const restored: Task = {
+          id: dlqTask.id,
+          payload: dlqTask.payload,
+          status: 'pending',
+          priority: dlqTask.priority,
+          queue: dlqTask.queue,
+          createdAt: dlqTask.createdAt,
+          updatedAt: new Date(),
+          availableAt: new Date(),
+          attempt: 0,
+          maxRetries: dlqTask.maxRetries,
+          backoffDelay: dlqTask.backoffDelay,
+          dependencies: dlqTask.dependencies,
+          progress: 0,
+        };
+        this.allTasks.set(restored.id, restored);
+        queue.tasks.set(restored.id, restored);
+        return restored;
+      }
+    }
+    return null;
+  }
+
+  clearDeadLetterQueue(queueName: string = 'default'): void {
+    const queue = this.queues.get(queueName);
+    if (queue) {
+      queue.deadLetterQueue = [];
+    }
+  }
+
+  // ---- Phase 7: Task Dependencies ----
+
+  private areDependenciesMet(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (!dep || dep.status !== 'completed') {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  private detectCircularDependencies(newTask: Task): void {
+    const visited = new Set<string>();
+
+    const visit = (taskId: string): void => {
+      if (taskId === newTask.id) {
+        throw new Error('Circular dependency detected.');
+      }
+      if (visited.has(taskId)) return;
+      visited.add(taskId);
+
+      const task = this.allTasks.get(taskId);
+      if (task) {
+        for (const depId of task.dependencies) {
+          visit(depId);
+        }
+      }
+    };
+
+    // Check if any of the new task's dependencies (transitively) depend on the new task
+    // Since the new task is just being created, we need to check if any dependency
+    // eventually leads back to a task that depends on newTask
+    // Actually: newTask depends on its dependencies. We need to check if any dependency
+    // chain from newTask's dependencies leads back to newTask.
+    // Since newTask isn't in allTasks yet, we just need to check if any dependency
+    // is newTask itself (direct cycle with self), or if any dependency's transitive
+    // deps include newTask.
+    // But newTask just got created with a fresh UUID, so the only way to get a cycle
+    // is if somehow a dependency of newTask depends on newTask - which can't happen
+    // since newTask is brand new.
+    //
+    // However, we should still check for existing circular chains among the specified dependencies.
+    // The real scenario is: task A depends on B, task B depends on C, now if C depends on A -> cycle.
+    // Since we're adding newTask which depends on some existing tasks, cycles can only
+    // form if newTask's deps transitively depend on each other in a cycle - but those
+    // would have been caught when they were added.
+    //
+    // Actually the real danger: newTask depends on X, and X has newTask as dependency.
+    // But since newTask is brand new with a new UUID, X can't already depend on it.
+    // So circular deps can't happen with brand new tasks. But we still validate the
+    // dependencies exist (done in addTask).
+
+    // Still, let's be thorough and check for self-references and existing cycles
+    for (const depId of newTask.dependencies) {
+      if (depId === newTask.id) {
+        throw new Error('Circular dependency detected.');
+      }
+      visit(depId);
+    }
+  }
+
+  getDependencyStatus(taskId: string): { met: boolean; dependencies: Array<{ id: string; status: TaskStatus | 'unknown' }> } | null {
+    const task = this.allTasks.get(taskId);
+    if (!task) return null;
+
+    const dependencies = task.dependencies.map(depId => {
+      const dep = this.allTasks.get(depId);
+      return {
+        id: depId,
+        status: (dep?.status ?? 'unknown') as TaskStatus | 'unknown',
+      };
+    });
+
+    return {
+      met: this.areDependenciesMet(task),
+      dependencies,
+    };
+  }
+
+  // ---- Phase 8: Concurrency Control ----
+
+  setConcurrency(queueName: string, limit: number): void {
+    if (!Number.isInteger(limit) || limit < 0) {
+      throw new Error(`Invalid concurrency limit: ${limit}. Must be a non-negative integer.`);
+    }
+    const queue = this.getOrCreateQueue(queueName);
+    queue.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string = 'default'): number {
+    const queue = this.queues.get(queueName);
+    return queue?.concurrencyLimit ?? 0;
+  }
+
+  getActiveCount(queueName: string = 'default'): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+
+    let count = 0;
+    for (const task of queue.tasks.values()) {
+      if (task.status === 'processing') count++;
+    }
+    return count;
+  }
+
+  // ---- Phase 9: Progress Tracking and Cancellation ----
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found.`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state.`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Progress must be between 0 and 100, got ${progress}.`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+    task.updatedAt = new Date();
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } | null {
+    const task = this.allTasks.get(taskId);
+    if (!task) return null;
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    let listeners = this.progressListeners.get(taskId);
+    if (!listeners) {
+      listeners = new Set();
+      this.progressListeners.set(taskId, listeners);
+    }
+    listeners.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      listeners!.delete(listener);
+      if (listeners!.size === 0) {
+        this.progressListeners.delete(taskId);
+      }
+    };
+  }
+
+  cancelTask(taskId: string): boolean {
+    const task = this.allTasks.get(taskId);
+    if (!task) return false;
+
+    if (task.status === 'pending') {
+      task.status = 'cancelled';
+      task.updatedAt = new Date();
+      // Remove cancelled pending tasks from the queue
+      const queue = this.queues.get(task.queue);
+      if (queue) {
+        queue.tasks.delete(task.id);
+      }
+      return true;
+    }
+
+    if (task.status === 'processing') {
+      task.status = 'cancelled';
+      task.updatedAt = new Date();
+      return true;
+    }
+
+    return false;
+  }
+
+  // ---- Phase 10: Recurring Tasks ----
+
+  addSchedule(
+    cronExpression: string,
+    queueName: string,
+    taskTemplate: unknown,
+    taskOptions?: Omit<TaskOptions, 'queue' | 'dependencies'>
+  ): Schedule {
+    // Validate cron expression by parsing it
+    parseCron(cronExpression);
+
+    const schedule: Schedule = {
+      id: randomUUID(),
+      cronExpression,
+      queue: queueName,
+      taskTemplate,
+      taskOptions,
+      active: true,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): boolean {
+    const schedule = this.schedules.get(scheduleId);
+    if (!schedule) return false;
+    schedule.active = false;
+    this.schedules.delete(scheduleId);
+    return true;
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values()).filter(s => s.active);
+  }
+
+  tick(now: Date = new Date()): Task[] {
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (!schedule.active) continue;
+
+      const cron = parseCron(schedule.cronExpression);
+      if (shouldRun(cron, now, schedule.lastRun)) {
+        schedule.lastRun = now;
+        const task = this.addTask(schedule.taskTemplate, {
+          ...schedule.taskOptions,
+          queue: schedule.queue,
+        });
+        created.push(task);
+      }
+    }
+
+    return created;
+  }
+
+  // ---- Phase 11: Middleware Pipeline ----
+
+  use(queueName: string, middleware: Middleware): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.middlewares.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: TaskHandler): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.handler = handler;
+  }
+
+  async processTask(queueName: string = 'default'): Promise<Task | null> {
+    const task = this.getNextTask(queueName);
+    if (!task) return null;
+
+    const queue = this.queues.get(queueName);
+    if (!queue) return task;
+
+    const middlewares = [...queue.middlewares];
+    const handler = queue.handler;
+
+    try {
+      let index = 0;
+      const executeNext = async (): Promise<void> => {
+        if (index < middlewares.length) {
+          const mw = middlewares[index++];
+          await mw(task, executeNext);
+        } else if (handler) {
+          await handler(task);
+        }
+      };
+
+      await executeNext();
+
+      // If still in processing state (middleware/handler didn't change it), mark completed
+      if (task.status === 'processing') {
+        this.completeTask(task.id);
+      }
+    } catch (error) {
+      if (task.status === 'processing') {
+        const errorMessage = error instanceof Error ? error.message : String(error);
+        this.failTask(task.id, errorMessage);
+      }
+    }
+
+    return task;
+  }
+
+  // ---- Phase 12: Graceful Shutdown ----
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.performShutdown(timeout);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(timeout: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+    let completed = 0;
+    let cancelled = 0;
+
+    // Run shutdown callbacks
+    for (const callback of this.shutdownCallbacks) {
+      try {
+        await callback();
+      } catch {
+        // Ignore callback errors during shutdown
+      }
+    }
+
+    // Collect all processing tasks
+    const processingTasks: Task[] = [];
+    for (const queue of this.queues.values()) {
+      for (const task of queue.tasks.values()) {
+        if (task.status === 'processing') {
+          processingTasks.push(task);
+        }
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        cancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks with timeout
+    const waitStart = Date.now();
+    const checkInterval = 10; // ms
+
+    while (Date.now() - waitStart < timeout) {
+      let allDone = true;
+      for (const task of processingTasks) {
+        if (task.status === 'processing') {
+          allDone = false;
+          break;
+        }
+      }
+      if (allDone) break;
+      await new Promise(resolve => setTimeout(resolve, checkInterval));
+    }
+
+    // Count completed and force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        task.updatedAt = new Date();
+        cancelled++;
+      } else if (task.status === 'completed') {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      cancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  get isShuttingDown(): boolean {
+    return this.isShutdown;
+  }
+}
