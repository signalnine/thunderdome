+    expect(queue.getWaitingCount('q2')).toBe(1);
+
+    queue.getNextTask('q1');
+    expect(queue.getWaitingCount('q1')).toBe(0);
+    expect(queue.getWaitingCount('q2')).toBe(1);
+  });
+
+  it('should return null for empty or non-existent queue', () => {
+    expect(queue.getNextTask('nonexistent')).toBeNull();
+  });
+
+  it('should list all queue names', () => {
+    queue.addTask('a', { queue: 'emails' });
+    queue.addTask('b', { queue: 'sms' });
