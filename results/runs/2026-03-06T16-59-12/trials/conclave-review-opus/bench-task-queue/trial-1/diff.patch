+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should create a schedule', () => {
+    const schedule = queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+    expect(schedule.id).toBeDefined();
+    expect(schedule.cronExpression).toBe('*/5 * * * *');
+    expect(schedule.queue).toBe('default');
+    expect(schedule.active).toBe(true);
+  });
+
+  it('should list active schedules', () => {
+    queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+    queue.addSchedule('0 * * * *', 'default', { type: 'hourly' });
+
+    expect(queue.getSchedules()).toHaveLength(2);
+  });
+
+  it('should remove a schedule', () => {
+    const schedule = queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+    expect(queue.removeSchedule(schedule.id)).toBe(true);
+    expect(queue.getSchedules()).toHaveLength(0);
+  });
+
+  it('should enqueue tasks when tick matches cron', () => {
+    queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    // Tick at a minute divisible by 5
+    const matchTime = new Date(2024, 0, 1, 12, 0, 0); // 12:00
+    const tasks = queue.tick(matchTime);
+    expect(tasks).toHaveLength(1);
+    expect(tasks[0].payload).toEqual({ type: 'cleanup' });
+  });
+
+  it('should not enqueue when cron does not match', () => {
+    queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    // Tick at minute 3 (not divisible by 5)
+    const noMatchTime = new Date(2024, 0, 1, 12, 3, 0);
+    const tasks = queue.tick(noMatchTime);
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should not double-fire in same minute', () => {
+    queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    queue.tick(time);
+    const secondTick = queue.tick(time);
+    expect(secondTick).toHaveLength(0);
+  });
+
+  it('should not create tasks for removed schedules', () => {
+    const schedule = queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+    queue.removeSchedule(schedule.id);
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    const tasks = queue.tick(time);
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('recurring tasks are subject to queue rules', () => {
+    queue.addSchedule('*/5 * * * *', 'emails', { type: 'digest' }, { priority: 1 });
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    const tasks = queue.tick(time);
+    expect(tasks[0].queue).toBe('emails');
+    expect(tasks[0].priority).toBe(1);
+  });
+
+  it('should support hourly cron', () => {
+    queue.addSchedule('0 * * * *', 'default', { type: 'hourly' });
+
+    // Match at minute 0
+    const match = new Date(2024, 0, 1, 13, 0, 0);
+    expect(queue.tick(match)).toHaveLength(1);
+
+    // No match at minute 30
+    const noMatch = new Date(2024, 0, 1, 13, 30, 0);
+    expect(queue.tick(noMatch)).toHaveLength(0);
+  });
+
+  it('should support daily cron', () => {
+    queue.addSchedule('0 0 * * *', 'default', { type: 'daily' });
+
+    // Match at midnight
+    const match = new Date(2024, 0, 2, 0, 0, 0);
+    expect(queue.tick(match)).toHaveLength(1);
+
+    // No match at noon
+    const noMatch = new Date(2024, 0, 2, 12, 0, 0);
+    expect(queue.tick(noMatch)).toHaveLength(0);
+  });
+
+  it('should reject invalid cron expressions', () => {
+    expect(() => queue.addSchedule('invalid', 'default', {})).toThrow();
+  });
+});
