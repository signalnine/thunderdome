+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should complete a task', () => {
+    queue.addTask('data');
+    const task = queue.getNextTask()!;
+    queue.completeTask(task.id);
+    expect(queue.getTask(task.id)?.status).toBe('completed');
+  });
+
+  it('should fail a task with error message', () => {
+    queue.addTask('data', { maxRetries: 0 });
+    const task = queue.getNextTask()!;
+    queue.failTask(task.id, 'something broke');
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.status).toBe('failed');
+    expect(updated.error).toBe('something broke');
+  });
+
+  it('should retry failed task with backoff delay', () => {
+    queue.addTask('data', { maxRetries: 3, backoffDelay: 100 });
+    const task = queue.getNextTask()!;
+    queue.failTask(task.id, 'fail');
+
+    // Task should be pending again but delayed
+    const updated = queue.getTask(task.id)!;
+    expect(updated.status).toBe('pending');
+    expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should exponentially increase backoff delay', () => {
+    const task = queue.addTask('data', { maxRetries: 3, backoffDelay: 1000 });
+
+    // First attempt
+    queue.getNextTask();
+    const beforeFail1 = Date.now();
+    queue.failTask(task.id, 'fail');
+    const delay1 = queue.getTask(task.id)!.availableAt.getTime() - beforeFail1;
+    // First retry: 1000 * 2^0 = 1000ms
+    expect(delay1).toBeGreaterThanOrEqual(900);
+    expect(delay1).toBeLessThan(1200);
+  });
+
+  it('should track attempt count', () => {
+    const task = queue.addTask('data', { maxRetries: 3, backoffDelay: 10 });
+    expect(task.attempt).toBe(0);
+
+    const t1 = queue.getNextTask()!;
+    expect(t1.attempt).toBe(1);
+  });
+
+  it('should default to 3 max retries', () => {
+    const task = queue.addTask('data');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should default to 1000ms base delay', () => {
+    const task = queue.addTask('data');
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    const task = queue.addTask('data', { queue: 'special', priority: 2, maxRetries: 3, backoffDelay: 10 });
+    queue.getNextTask('special');
+    queue.failTask(task.id, 'fail');
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.queue).toBe('special');
+    expect(updated.priority).toBe(2);
+  });
+
+  it('should remain failed after exhausting retries', () => {
+    // maxRetries: 0 means no retries - fail immediately after first attempt
+    const task = queue.addTask('data', { maxRetries: 0, backoffDelay: 1 });
+
+    // Attempt 1 - should go directly to failed
+    queue.getNextTask();
+    queue.failTask(task.id, 'fail');
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.status).toBe('failed');
+  });
+
+  it('should allow configured number of retries before failing', async () => {
+    // maxRetries: 1 means 1 retry allowed (2 total attempts)
+    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 1 });
+
+    // Attempt 1 - should retry
+    queue.getNextTask();
+    queue.failTask(task.id, 'fail1');
+    expect(queue.getTask(task.id)!.status).toBe('pending');
+
+    // Wait for backoff
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    // Attempt 2 - should fail permanently
+    queue.getNextTask();
+    queue.failTask(task.id, 'fail2');
+    expect(queue.getTask(task.id)!.status).toBe('failed');
+  });
+
+  it('should error when completing non-processing task', () => {
+    const task = queue.addTask('data');
+    expect(() => queue.completeTask(task.id)).toThrow();
+  });
+
+  it('should error when failing non-processing task', () => {
+    const task = queue.addTask('data');
+    expect(() => queue.failTask(task.id)).toThrow();
+  });
+});
