+    expect(queue.getQueueNames()).toEqual([]);
+    queue.addTask('data', { queue: 'new-queue' });
+    expect(queue.getQueueNames()).toContain('new-queue');
+  });
+
+  it('should be backward compatible with Phase 1', () => {
+    queue.addTask('no-queue-specified');
+    const task = queue.getNextTask();
+    expect(task?.payload).toBe('no-queue-specified');
+    expect(task?.queue).toBe('default');
+  });
+});
