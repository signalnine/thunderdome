tring[] = [];\n\n    queue.use('default', async (_task, _next) => {\n      log.push('blocking middleware');\n      // Intentionally not calling next\n    });\n\n    queue.setHandler('default', async () => {\n      log.push('handler');\n    });\n\n    queue.addTask('data');\n    const task = await queue.processTask();\n\n    expect(log).toEqual(['blocking middleware']);\n    // Task should still be completed since processTask auto-completes\n    expect(task?.status).toBe('completed');\n  });\n\n  it('should allow middleware to modify task', async () => {\n    queue.use('default', async (task, next) => {\n      (task as any).payload = { ...(task.payload as any), enriched: true };\n      await next();\n    });\n\n    let receivedPayload: unknown;\n    queue.setHandler('default', async (task) => {\n      receivedPayload = task.payload;\n    });\n\n    queue.addTask({ original: true });\n    await queue.processTask();\n\n    expect(receivedPayload).toEqual({ original: true, enriched: true });\n  });\n\n  it('should mark task as failed when middleware throws', async () => {\n    queue.use('default', async () => {\n      throw new Error('middleware error');\n    });\n\n    queue.addTask('data', { maxRetries: 0 });\n    const task = await queue.processTask();\n\n    expect(task?.status).toBe('failed');\n    expect(queue.getTask(task!.id)?.error).toBe('middleware error');\n  });\n\n  it('should mark task as failed when handler throws', async () => {\n    queue.setHandler('default', async () => {\n      throw new Error('handler error');\n    });\n\n    queue.addTask('data', { maxRetries: 0 });\n    const task = await queue.processTask();\n\n    expect(task?.status).toBe('failed');\n  });\n\n  it('should have independent middleware per queue', async () => {\n    const log: string[] = [];\n\n    queue.use('q1', async (_task, next) => {\n      log.push('q1-middleware');\n      await next();\n    });\n\n    queue.use('q2', async (_task, next) => {\n      log.push('q2-middleware');\n      await next();\n    });\n\n    queue.addTask('a', { queue: 'q1' });\n    queue.addTask('b', { queue: 'q2' });\n\n    await queue.processTask('q1');\n    expect(log).toEqual(['q1-middleware']);\n\n    await queue.processTask('q2');\n    expect(log).toEqual(['q1-middleware', 'q2-middleware']);\n  });\n\n  it('should return null when no task available for processing', async () => {\n    const result = await queue.processTask();\n    expect(result).toBeNull();\n  });\n\n  it('should auto-complete task without handler', async () => {\n    queue.addTask('data');\n    const task = await queue.processTask();\n    expect(task?.status).toBe('completed');\n  });\n});\n","structuredPatch":[{"oldStart":71,"oldLines":7,"newStart":71,"newLines":8,"lines":[" ","   it('should allow middleware to modify task', async () => {","     queue.use('default', async (task, next) => {","-      (task as any).payload = { ...(task.payload as any), enriched: true };","+      // eslint-disable-next-line @typescript-eslint/no-explicit-any","+      (task as Record<string, unknown>).payload = { ...(task.payload as Record<string, unknown>), enriched: true };","       await next();","     });"," "]}],"userModified":false,"replaceAll":false}}
