+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should delay task by milliseconds', () => {
+    queue.addTask('delayed', { delay: 5000 });
+    // Task exists but is not available yet
+    expect(queue.getWaitingCount()).toBe(1);
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should make delayed task available after delay', async () => {
+    queue.addTask('delayed', { delay: 50 });
+    expect(queue.getNextTask()).toBeNull();
+
+    await new Promise(resolve => setTimeout(resolve, 60));
+    const task = queue.getNextTask();
+    expect(task?.payload).toBe('delayed');
+  });
+
+  it('should schedule task for a specific time', () => {
+    const futureTime = new Date(Date.now() + 10000);
+    const task = queue.addTask('scheduled', { processAt: futureTime });
+    expect(task.availableAt.getTime()).toBe(futureTime.getTime());
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should prefer non-delayed tasks over delayed ones', () => {
+    queue.addTask('delayed', { delay: 5000 });
+    queue.addTask('immediate');
+
+    const task = queue.getNextTask();
+    expect(task?.payload).toBe('immediate');
+  });
+
+  it('should expose availability time on task', () => {
+    const task = queue.addTask('delayed', { delay: 1000 });
+    expect(task.availableAt).toBeInstanceOf(Date);
+    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());
+  });
+
+  it('should order by availability time, then priority, then FIFO when multiple become available', async () => {
+    const now = Date.now();
+    queue.addTask('later', { processAt: new Date(now - 100), priority: 5 });
+    queue.addTask('earlier', { processAt: new Date(now - 200), priority: 5 });
+
+    const first = queue.getNextTask();
+    const second = queue.getNextTask();
+    expect(first?.payload).toBe('earlier');
+    expect(second?.payload).toBe('later');
+  });
+
+  it('should work with named queues', () => {
+    queue.addTask('delayed', { queue: 'emails', delay: 5000 });
+    queue.addTask('immediate', { queue: 'emails' });
+
+    expect(queue.getNextTask('emails')?.payload).toBe('immediate');
+  });
+});
