+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XtKMQzSAGsjNByuaU8cMhB","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 1: Basic FIFO Queue', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should add a task and return a task object', () => {\n    12→    const task = queue.addTask({ message: 'hello' });\n    13→    expect(task).toBeDefined();\n    14→    expect(task.id).toBeDefined();\n    15→    expect(typeof task.id).toBe('string');\n    16→    expect(task.payload).toEqual({ message: 'hello' });\n    17→    expect(task.status).toBe('pending');\n    18→    expect(task.createdAt).toBeInstanceOf(Date);\n    19→  });\n    20→\n    21→  it('should assign unique IDs to each task', () => {\n    22→    const t1 = queue.addTask('task1');\n    23→    const t2 = queue.addTask('task2');\n    24→    expect(t1.id).not.toBe(t2.id);\n    25→  });\n    26→\n    27→  it('should retrieve tasks in FIFO order', () => {\n    28→    queue.addTask('first');\n    29→    queue.addTask('second');\n    30→    queue.addTask('third');\n    31→\n    32→    const t1 = queue.getNextTask();\n    33→    expect(t1?.payload).toBe('first');\n    34→\n    35→    const t2 = queue.getNextTask();\n    36→    expect(t2?.payload).toBe('second');\n    37→\n    38→    const t3 = queue.getNextTask();\n    39→    expect(t3?.payload).toBe('third');\n    40→  });\n    41→\n    42→  it('should transition task to processing state on retrieval', () => {\n    43→    queue.addTask('data');\n    44→    const task = queue.getNextTask();\n    45→    expect(task?.status).toBe('processing');\n    46→  });\n    47→\n    48→  it('should return null when no tasks are available', () => {\n    49→    expect(queue.getNextTask()).toBeNull();\n    50→  });\n    51→\n    52→  it('should return null after all tasks are retrieved', () => {\n    53→    queue.addTask('only');\n    54→    queue.getNextTask();\n    55→    expect(queue.getNextTask()).toBeNull();\n    56→  });\n    57→\n    58→  it('should track waiting count', () => {\n    59→    expect(queue.getWaitingCount()).toBe(0);\n    60→    queue.addTask('a');\n    61→    queue.addTask('b');\n    62→    expect(queue.getWaitingCount()).toBe(2);\n    63→    queue.getNextTask();\n    64→    expect(queue.getWaitingCount()).toBe(1);\n    65→    queue.getNextTask();\n    66→    expect(queue.getWaitingCount()).toBe(0);\n    67→  });\n    68→\n    69→  it('should set attempt to 1 when retrieved', () => {\n    70→    queue.addTask('data');\n    71→    const task = queue.getNextTask();\n    72→    expect(task?.attempt).toBe(1);\n    73→  });\n    74→});\n    75→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"641f851f-fb0e-44b6-8359-3760f0260aba"}
