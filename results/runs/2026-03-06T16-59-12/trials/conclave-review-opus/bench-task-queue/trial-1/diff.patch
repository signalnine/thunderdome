+import { randomUUID } from 'node:crypto';
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  queue: string;
+  createdAt: Date;
+  updatedAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface DeadLetteredTask<T = unknown> extends Task<T> {
+  failedAt: Date;
+  failCount: number;
+  lastError?: string;
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  taskTemplate: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue' | 'dependencies'>;
+  lastRun?: Date;
+  active: boolean;
+}
+
+export type Middleware = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type TaskHandler = (task: Task) => Promise<void>;
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export interface ShutdownResult {
+  completed: number;
+  cancelled: number;
+  duration: number;
+}
+
+export function createTask<T>(payload: T, options: TaskOptions = {}): Task<T> {
+  const now = new Date();
+  const priority = options.priority ?? 5;
+
+  let availableAt = now;
+  if (options.delay != null && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  } else if (options.processAt != null) {
+    availableAt = options.processAt;
+  }
+
+  return {
+    id: randomUUID(),
+    payload,
+    status: 'pending',
+    priority,
+    queue: options.queue ?? 'default',
+    createdAt: now,
+    updatedAt: now,
+    availableAt,
+    attempt: 0,
+    maxRetries: options.maxRetries ?? 3,
+    backoffDelay: options.backoffDelay ?? 1000,
+    dependencies: options.dependencies ?? [],
+    progress: 0,
+  };
+}
