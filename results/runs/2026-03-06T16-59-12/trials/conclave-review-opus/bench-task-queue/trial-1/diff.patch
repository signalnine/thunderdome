+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  describe('Progress Tracking', () => {
+    it('should update and query progress', () => {
+      queue.addTask('data');
+      const task = queue.getNextTask()!;
+
+      queue.updateProgress(task.id, 50, 'halfway');
+      const progress = queue.getProgress(task.id);
+      expect(progress?.progress).toBe(50);
+      expect(progress?.message).toBe('halfway');
+    });
+
+    it('should reject invalid progress values', () => {
+      queue.addTask('data');
+      const task = queue.getNextTask()!;
+
+      expect(() => queue.updateProgress(task.id, -1)).toThrow();
+      expect(() => queue.updateProgress(task.id, 101)).toThrow();
+    });
+
+    it('should only update progress on processing tasks', () => {
+      const task = queue.addTask('data');
+      expect(() => queue.updateProgress(task.id, 50)).toThrow();
+    });
+
+    it('should notify progress listeners', () => {
+      queue.addTask('data');
+      const task = queue.getNextTask()!;
+
+      const updates: Array<{ progress: number; message?: string }> = [];
+      queue.onProgress(task.id, (progress, message) => {
+        updates.push({ progress, message });
+      });
+
+      queue.updateProgress(task.id, 25, 'quarter');
+      queue.updateProgress(task.id, 75, 'three quarters');
+
+      expect(updates).toHaveLength(2);
+      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });
+      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });
+    });
+
+    it('should support unsubscribe', () => {
+      queue.addTask('data');
+      const task = queue.getNextTask()!;
+
+      const updates: number[] = [];
+      const unsubscribe = queue.onProgress(task.id, (progress) => {
+        updates.push(progress);
+      });
+
+      queue.updateProgress(task.id, 25);
+      unsubscribe();
+      queue.updateProgress(task.id, 75);
+
+      expect(updates).toEqual([25]);
+    });
+
+    it('should return null for non-existent task progress', () => {
+      expect(queue.getProgress('nonexistent')).toBeNull();
+    });
+  });
+
+  describe('Cancellation', () => {
+    it('should cancel pending tasks', () => {
+      const task = queue.addTask('data');
+      const result = queue.cancelTask(task.id);
+      expect(result).toBe(true);
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+      expect(queue.getNextTask()).toBeNull();
+    });
+
+    it('should cancel processing tasks', () => {
+      queue.addTask('data');
+      const task = queue.getNextTask()!;
+
+      const result = queue.cancelTask(task.id);
+      expect(result).toBe(true);
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+    });
+
+    it('should not cancel completed tasks', () => {
+      queue.addTask('data');
+      const task = queue.getNextTask()!;
+      queue.completeTask(task.id);
+
+      const result = queue.cancelTask(task.id);
+      expect(result).toBe(false);
+    });
+
+    it('should not cancel failed tasks', () => {
+      queue.addTask('data', { maxRetries: 0 });
+      const task = queue.getNextTask()!;
+      queue.failTask(task.id, 'error');
+
+      const result = queue.cancelTask(task.id);
+      expect(result).toBe(false);
+    });
+
+    it('should not retry cancelled tasks', () => {
+      queue.addTask('data', { maxRetries: 3 });
+      const task = queue.getNextTask()!;
+      queue.cancelTask(task.id);
+
+      // Task is cancelled, should not be available for retry
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+    });
+
+    it('should return false for non-existent task', () => {
+      expect(queue.cancelTask('nonexistent')).toBe(false);
+    });
+  });
+});
