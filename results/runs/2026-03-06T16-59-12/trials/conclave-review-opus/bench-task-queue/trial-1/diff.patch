+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019NvoQtRtZiCKRLhFJCVHGJ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 8: Concurrency Control', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should default to unlimited concurrency', () => {\n    12→    expect(queue.getConcurrency()).toBe(0);\n    13→  });\n    14→\n    15→  it('should set and query concurrency limit', () => {\n    16→    queue.setConcurrency('default', 2);\n    17→    expect(queue.getConcurrency('default')).toBe(2);\n    18→  });\n    19→\n    20→  it('should limit concurrent processing', () => {\n    21→    queue.setConcurrency('default', 2);\n    22→    queue.addTask('a');\n    23→    queue.addTask('b');\n    24→    queue.addTask('c');\n    25→\n    26→    const t1 = queue.getNextTask();\n    27→    const t2 = queue.getNextTask();\n    28→    expect(t1).not.toBeNull();\n    29→    expect(t2).not.toBeNull();\n    30→\n    31→    // At limit, should return null\n    32→    expect(queue.getNextTask()).toBeNull();\n    33→  });\n    34→\n    35→  it('should free slot when task completes', () => {\n    36→    queue.setConcurrency('default', 1);\n    37→    queue.addTask('a');\n    38→    queue.addTask('b');\n    39→\n    40→    const t1 = queue.getNextTask()!;\n    41→    expect(queue.getNextTask()).toBeNull();\n    42→\n    43→    queue.completeTask(t1.id);\n    44→    const t2 = queue.getNextTask();\n    45→    expect(t2).not.toBeNull();\n    46→  });\n    47→\n    48→  it('should free slot when task fails', () => {\n    49→    queue.setConcurrency('default', 1);\n    50→    queue.addTask('a', { maxRetries: 0 });\n    51→    queue.addTask('b');\n    52→\n    53→    const t1 = queue.getNextTask()!;\n    54→    expect(queue.getNextTask()).toBeNull();\n    55→\n    56→    queue.failTask(t1.id, 'error');\n    57→    // t1 failed and went to DLQ. Slot freed.\n    58→    const t2 = queue.getNextTask();\n    59→    expect(t2).not.toBeNull();\n    60→  });\n    61→\n    62→  it('should track active count', () => {\n    63→    queue.addTask('a');\n    64→    queue.addTask('b');\n    65→\n    66→    expect(queue.getActiveCount()).toBe(0);\n    67→    queue.getNextTask();\n    68→    expect(queue.getActiveCount()).toBe(1);\n    69→    queue.getNextTask();\n    70→    expect(queue.getActiveCount()).toBe(2);\n    71→  });\n    72→\n    73→  it('should respect priority with concurrency limit', () => {\n    74→    queue.setConcurrency('default', 1);\n    75→    queue.addTask('low', { priority: 10 });\n    76→    queue.addTask('high', { priority: 1 });\n    77→\n    78→    const task = queue.getNextTask();\n    79→    expect(task?.payload).toBe('high');\n    80→  });\n    81→\n    82→  it('should have independent concurrency per queue', () => {\n    83→    queue.setConcurrency('q1', 1);\n    84→    queue.setConcurrency('q2', 1);\n    85→\n    86→    queue.addTask('a', { queue: 'q1' });\n    87→    queue.addTask('b', { queue: 'q1' });\n    88→    queue.addTask('c', { queue: 'q2' });\n    89→    queue.addTask('d', { queue: 'q2' });\n    90→\n    91→    expect(queue.getNextTask('q1')).not.toBeNull();\n    92→    expect(queue.getNextTask('q1')).toBeNull(); // at limit\n    93→\n    94→    expect(queue.getNextTask('q2')).not.toBeNull();\n    95→    expect(queue.getNextTask('q2')).toBeNull(); // at limit\n    96→  });\n    97→});\n    98→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"6c6a8bfc-bf79-4771-b34e-dada16dc1bdf"}
