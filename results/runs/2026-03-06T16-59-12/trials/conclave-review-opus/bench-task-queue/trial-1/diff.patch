+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0197Sw2nv4cnNNh2tp922j1c","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import {\n     3→  Task,\n     4→  TaskOptions,\n     5→  TaskStatus,\n     6→  DeadLetteredTask,\n     7→  Schedule,\n     8→  Middleware,\n     9→  TaskHandler,\n    10→  ProgressListener,\n    11→  ShutdownResult,\n    12→  createTask,\n    13→} from './types.js';\n    14→import { parseCron, shouldRun } from './cron.js';\n    15→\n    16→interface QueueState {\n    17→  tasks: Map<string, Task>;\n    18→  deadLetterQueue: DeadLetteredTask[];\n    19→  concurrencyLimit: number;\n    20→  middlewares: Middleware[];\n    21→  handler?: TaskHandler;\n    22→}\n    23→\n    24→export class TaskQueue {\n    25→  private queues: Map<string, QueueState> = new Map();\n    26→  private allTasks: Map<string, Task> = new Map();\n    27→  private schedules: Map<string, Schedule> = new Map();\n    28→  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n    29→  private isShutdown = false;\n    30→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    31→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    32→\n    33→  // ---- Phase 1 & 2: Basic FIFO + Named Queues ----\n    34→\n    35→  private getOrCreateQueue(name: string): QueueState {\n    36→    let queue = this.queues.get(name);\n    37→    if (!queue) {\n    38→      queue = {\n    39→        tasks: new Map(),\n    40→        deadLetterQueue: [],\n    41→        concurrencyLimit: 0, // 0 = unlimited\n    42→        middlewares: [],\n    43→      };\n    44→      this.queues.set(name, queue);\n    45→    }\n    46→    return queue;\n    47→  }\n    48→\n    49→  addTask<T>(payload: T, options: TaskOptions = {}): Task<T> {\n    50→    if (this.isShutdown) {\n    51→      throw new Error('Queue system is shut down. Cannot add new tasks.');\n    52→    }\n    53→\n    54→    // Phase 3: Validate priority\n    55→    if (options.priority !== undefined) {\n    56→      if (!Number.isInteger(options.priority) || options.priority < 1 || options.priority > 10) {\n    57→        throw new Error(`Invalid priority: ${options.priority}. Must be an integer between 1 and 10.`);\n    58→      }\n    59→    }\n    60→\n    61→    // Phase 7: Validate dependencies\n    62→    if (options.dependencies && options.dependencies.length > 0) {\n    63→      for (const depId of options.dependencies) {\n    64→        const depTask = this.allTasks.get(depId);\n    65→        if (!depTask) {\n    66→          throw new Error(`Dependency task \"${depId}\" does not exist.`);\n    67→        }\n    68→      }\n    69→    }\n    70→\n    71→    const task = createTask(payload, options);\n    72→\n    73→    // Phase 7: Circular dependency detection\n    74→    if (task.dependencies.length > 0) {\n    75→      this.detectCircularDependencies(task);\n    76→    }\n    77→\n    78→    const queue = this.getOrCreateQueue(task.queue);\n    79→    queue.tasks.set(task.id, task);\n    80→    this.allTasks.set(task.id, task);\n    81→    return task;\n    82→  }\n    83→\n    84→  getNextTask(queueName: string = 'default'): Task | null {\n    85→    const queue = this.queues.get(queueName);\n    86→    if (!queue) return null;\n    87→\n    88→    // Phase 8: Check concurrency limit\n    89→    if (queue.concurrencyLimit > 0) {\n    90→      const activeCount = this.getActiveCount(queueName);\n    91→      if (activeCount >= queue.concurrencyLimit) {\n    92→        return null;\n    93→      }\n    94→    }\n    95→\n    96→    const now = new Date();\n    97→\n    98→    // Get all pending tasks that are available\n    99→    const candidates: Task[] = [];\n   100→    for (const task of queue.tasks.values()) {\n   101→      if (task.status !== 'pending') continue;\n   102→\n   103→      // Phase 4: Skip delayed tasks not yet available\n   104→      if (task.availableAt > now) continue;\n   105→\n   106→      // Phase 7: Skip tasks with unresolved dependencies\n   107→      if (task.dependencies.length > 0) {\n   108→        if (!this.areDependenciesMet(task)) continue;\n   109→      }\n   110→\n   111→      candidates.push(task);\n   112→    }\n   113→\n   114→    if (candidates.length === 0) return null;\n   115→\n   116→    // Phase 3: Sort by priority (lower = higher priority), then by availableAt, then FIFO (createdAt)\n   117→    candidates.sort((a, b) => {\n   118→      if (a.priority !== b.priority) return a.priority - b.priority;\n   119→      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n   120→      if (availDiff !== 0) return availDiff;\n   121→      return a.createdAt.getTime() - b.createdAt.getTime();\n   122→    });\n   123→\n   124→    const task = candidates[0];\n   125→    task.status = 'processing';\n   126→    task.attempt += 1;\n   127→    task.updatedAt = new Date();\n   128→    return task;\n   129→  }\n   130→\n   131→  getWaitingCount(queueName: string = 'default'): number {\n   132→    const queue = this.queues.get(queueName);\n   133→    if (!queue) return 0;\n   134→\n   135→    let count = 0;\n   136→    for (const task of queue.tasks.values()) {\n   137→      if (task.status === 'pending') count++;\n   138→    }\n   139→    return count;\n   140→  }\n   141→\n   142→  getQueueNames(): string[] {\n   143→    return Array.from(this.queues.keys());\n   144→  }\n   145→\n   146→  getTask(taskId: string): Task | undefined {\n   147→    return this.allTasks.get(taskId);\n   148→  }\n   149→\n   150→  // ---- Phase 5: Retry with Backoff ----\n   151→\n   152→  completeTask(taskId: string): void {\n   153→    const task = this.allTasks.get(taskId);\n   154→    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n   155→    if (task.status !== 'processing') {\n   156→      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status}).`);\n   157→    }\n   158→\n   159→    task.status = 'completed';\n   160→    task.updatedAt = new Date();\n   161→\n   162→    // Phase 7: Unblock dependent tasks (no action needed, checked at retrieval time)\n   163→    // Dependencies are checked dynamically when getting next task\n   164→  }\n   165→\n   166→  failTask(taskId: string, error?: string): void {\n   167→    const task = this.allTasks.get(taskId);\n   168→    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n   169→    if (task.status !== 'processing') {\n   170→      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status}).`);\n   171→    }\n   172→\n   173→    task.error = error;\n   174→    task.updatedAt = new Date();\n   175→\n   176→    if (task.attempt < task.maxRetries) {\n   177→      // Re-add with exponential backoff delay\n   178→      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n   179→      task.status = 'pending';\n   180→      task.availableAt = new Date(Date.now() + delay);\n   181→      task.progress = 0;\n   182→      task.progressMessage = undefined;\n   183→    } else {\n   184→      // Exhausted retries\n   185→      task.status = 'failed';\n   186→\n   187→      // Phase 6: Move to DLQ\n   188→      const queue = this.getOrCreateQueue(task.queue);\n   189→      const dlqTask: DeadLetteredTask = {\n   190→        ...task,\n   191→        failedAt: new Date(),\n   192→        failCount: task.attempt,\n   193→        lastError: error,\n   194→      };\n   195→      queue.deadLetterQueue.push(dlqTask);\n   196→    }\n   197→  }\n   198→\n   199→  // ---- Phase 6: Dead Letter Queue ----\n   200→\n   201→  getDeadLetterTasks(queueName: string = 'default'): DeadLetteredTask[] {\n   202→    const queue = this.queues.get(queueName);\n   203→    if (!queue) return [];\n   204→    return [...queue.deadLetterQueue];\n   205→  }\n   206→\n   207→  reprocessDeadLetteredTask(taskId: string): Task | null {\n   208→    for (const [_queueName, queue] of this.queues) {\n   209→      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);\n   210→      if (index !== -1) {\n   211→        const dlqTask = queue.deadLetterQueue[index];\n   212→        queue.deadLetterQueue.splice(index, 1);\n   213→\n   214→        // Get original task and reset it\n   215→        const task = this.allTasks.get(taskId);\n   216→        if (task) {\n   217→          task.status = 'pending';\n   218→          task.attempt = 0;\n   219→          task.error = undefined;\n   220→          task.progress = 0;\n   221→          task.progressMessage = undefined;\n   222→          task.availableAt = new Date();\n   223→          task.updatedAt = new Date();\n   224→          return task;\n   225→        }\n   226→\n   227→        // If task not in allTasks (shouldn't happen), recreate from DLQ\n   228→        const restored: Task = {\n   229→          id: dlqTask.id,\n   230→          payload: dlqTask.payload,\n   231→          status: 'pending',\n   232→          priority: dlqTask.priority,\n   233→          queue: dlqTask.queue,\n   234→          createdAt: dlqTask.createdAt,\n   235→          updatedAt: new Date(),\n   236→          availableAt: new Date(),\n   237→          attempt: 0,\n   238→          maxRetries: dlqTask.maxRetries,\n   239→          backoffDelay: dlqTask.backoffDelay,\n   240→          dependencies: dlqTask.dependencies,\n   241→          progress: 0,\n   242→        };\n   243→        this.allTasks.set(restored.id, restored);\n   244→        queue.tasks.set(restored.id, restored);\n   245→        return restored;\n   246→      }\n   247→    }\n   248→    return null;\n   249→  }\n   250→\n   251→  clearDeadLetterQueue(queueName: string = 'default'): void {\n   252→    const queue = this.queues.get(queueName);\n   253→    if (queue) {\n   254→      queue.deadLetterQueue = [];\n   255→    }\n   256→  }\n   257→\n   258→  // ---- Phase 7: Task Dependencies ----\n   259→\n   260→  private areDependenciesMet(task: Task): boolean {\n   261→    for (const depId of task.dependencies) {\n   262→      const dep = this.allTasks.get(depId);\n   263→      if (!dep || dep.status !== 'completed') {\n   264→        return false;\n   265→      }\n   266→    }\n   267→    return true;\n   268→  }\n   269→\n   270→  private detectCircularDependencies(newTask: Task): void {\n   271→    const visited = new Set<string>();\n   272→\n   273→    const visit = (taskId: string): void => {\n   274→      if (taskId === newTask.id) {\n   275→        throw new Error('Circular dependency detected.');\n   276→      }\n   277→      if (visited.has(taskId)) return;\n   278→      visited.add(taskId);\n   279→\n   280→      const task = this.allTasks.get(taskId);\n   281→      if (task) {\n   282→        for (const depId of task.dependencies) {\n   283→          visit(depId);\n   284→        }\n   285→      }\n   286→    };\n   287→\n   288→    // Check if any of the new task's dependencies (transitively) depend on the new task\n   289→    // Since the new task is just being created, we need to check if any dependency\n   290→    // eventually leads back to a task that depends on newTask\n   291→    // Actually: newTask depends on its dependencies. We need to check if any dependency\n   292→    // chain from newTask's dependencies leads back to newTask.\n   293→    // Since newTask isn't in allTasks yet, we just need to check if any dependency\n   294→    // is newTask itself (direct cycle with self), or if any dependency's transitive\n   295→    // deps include newTask.\n   296→    // But newTask just got created with a fresh UUID, so the only way to get a cycle\n   297→    // is if somehow a dependency of newTask depends on newTask - which can't happen\n   298→    // since newTask is brand new.\n   299→    //\n   300→    // However, we should still check for existing circular chains among the specified dependencies.\n   301→    // The real scenario is: task A depends on B, task B depends on C, now if C depends on A -> cycle.\n   302→    // Since we're adding newTask which depends on some existing tasks, cycles can only\n   303→    // form if newTask's deps transitively depend on each other in a cycle - but those\n   304→    // would have been caught when they were added.\n   305→    //\n   306→    // Actually the real danger: newTask depends on X, and X has newTask as dependency.\n   307→    // But since newTask is brand new with a new UUID, X can't already depend on it.\n   308→    // So circular deps can't happen with brand new tasks. But we still validate the\n   309→    // dependencies exist (done in addTask).\n   310→\n   311→    // Still, let's be thorough and check for self-references and existing cycles\n   312→    for (const depId of newTask.dependencies) {\n   313→      if (depId === newTask.id) {\n   314→        throw new Error('Circular dependency detected.');\n   315→      }\n   316→      visit(depId);\n   317→    }\n   318→  }\n   319→\n   320→  getDependencyStatus(taskId: string): { met: boolean; dependencies: Array<{ id: string; status: TaskStatus }> } | null {\n   321→    const task = this.allTasks.get(taskId);\n   322→    if (!task) return null;\n   323→\n   324→    const dependencies = task.dependencies.map(depId => {\n   325→      const dep = this.allTasks.get(depId);\n   326→      return {\n   327→        id: depId,\n   328→        status: dep?.status ?? ('unknown' as TaskStatus),\n   329→      };\n   330→    });\n   331→\n   332→    return {\n   333→      met: this.areDependenciesMet(task),\n   334→      dependencies,\n   335→    };\n   336→  }\n   337→\n   338→  // ---- Phase 8: Concurrency Control ----\n   339→\n   340→  setConcurrency(queueName: string, limit: number): void {\n   341→    const queue = this.getOrCreateQueue(queueName);\n   342→    queue.concurrencyLimit = limit;\n   343→  }\n   344→\n   345→  getConcurrency(queueName: string = 'default'): number {\n   346→    const queue = this.queues.get(queueName);\n   347→    return queue?.concurrencyLimit ?? 0;\n   348→  }\n   349→\n   350→  getActiveCount(queueName: string = 'default'): number {\n   351→    const queue = this.queues.get(queueName);\n   352→    if (!queue) return 0;\n   353→\n   354→    let count = 0;\n   355→    for (const task of queue.tasks.values()) {\n   356→      if (task.status === 'processing') count++;\n   357→    }\n   358→    return count;\n   359→  }\n   360→\n   361→  // ---- Phase 9: Progress Tracking and Cancellation ----\n   362→\n   363→  updateProgress(taskId: string, progress: number, message?: string): void {\n   364→    const task = this.allTasks.get(taskId);\n   365→    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n   366→    if (task.status !== 'processing') {\n   367→      throw new Error(`Task \"${taskId}\" is not in processing state.`);\n   368→    }\n   369→    if (progress < 0 || progress > 100) {\n   370→      throw new Error(`Progress must be between 0 and 100, got ${progress}.`);\n   371→    }\n   372→\n   373→    task.progress = progress;\n   374→    task.progressMessage = message;\n   375→    task.updatedAt = new Date();\n   376→\n   377→    // Notify listeners\n   378→    const listeners = this.progressListeners.get(taskId);\n   379→    if (listeners) {\n   380→      for (const listener of listeners) {\n   381→        listener(progress, message);\n   382→      }\n   383→    }\n   384→  }\n   385→\n   386→  getProgress(taskId: string): { progress: number; message?: string } | null {\n   387→    const task = this.allTasks.get(taskId);\n   388→    if (!task) return null;\n   389→    return { progress: task.progress, message: task.progressMessage };\n   390→  }\n   391→\n   392→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   393→    let listeners = this.progressListeners.get(taskId);\n   394→    if (!listeners) {\n   395→      listeners = new Set();\n   396→      this.progressListeners.set(taskId, listeners);\n   397→    }\n   398→    listeners.add(listener);\n   399→\n   400→    // Return unsubscribe function\n   401→    return () => {\n   402→      listeners!.delete(listener);\n   403→      if (listeners!.size === 0) {\n   404→        this.progressListeners.delete(taskId);\n   405→      }\n   406→    };\n   407→  }\n   408→\n   409→  cancelTask(taskId: string): boolean {\n   410→    const task = this.allTasks.get(taskId);\n   411→    if (!task) return false;\n   412→\n   413→    if (task.status === 'pending' || task.status === 'processing') {\n   414→      task.status = 'cancelled';\n   415→      task.updatedAt = new Date();\n   416→      return true;\n   417→    }\n   418→\n   419→    return false;\n   420→  }\n   421→\n   422→  // ---- Phase 10: Recurring Tasks ----\n   423→\n   424→  addSchedule(\n   425→    cronExpression: string,\n   426→    queueName: string,\n   427→    taskTemplate: unknown,\n   428→    taskOptions?: Omit<TaskOptions, 'queue' | 'dependencies'>\n   429→  ): Schedule {\n   430→    // Validate cron expression by parsing it\n   431→    parseCron(cronExpression);\n   432→\n   433→    const schedule: Schedule = {\n   434→      id: randomUUID(),\n   435→      cronExpression,\n   436→      queue: queueName,\n   437→      taskTemplate,\n   438→      taskOptions,\n   439→      active: true,\n   440→    };\n   441→\n   442→    this.schedules.set(schedule.id, schedule);\n   443→    return schedule;\n   444→  }\n   445→\n   446→  removeSchedule(scheduleId: string): boolean {\n   447→    const schedule = this.schedules.get(scheduleId);\n   448→    if (!schedule) return false;\n   449→    schedule.active = false;\n   450→    this.schedules.delete(scheduleId);\n   451→    return true;\n   452→  }\n   453→\n   454→  getSchedules(): Schedule[] {\n   455→    return Array.from(this.schedules.values()).filter(s => s.active);\n   456→  }\n   457→\n   458→  tick(now: Date = new Date()): Task[] {\n   459→    const created: Task[] = [];\n   460→\n   461→    for (const schedule of this.schedules.values()) {\n   462→      if (!schedule.active) continue;\n   463→\n   464→      const cron = parseCron(schedule.cronExpression);\n   465→      if (shouldRun(cron, now, schedule.lastRun)) {\n   466→        schedule.lastRun = now;\n   467→        const task = this.addTask(schedule.taskTemplate, {\n   468→          ...schedule.taskOptions,\n   469→          queue: schedule.queue,\n   470→        });\n   471→        created.push(task);\n   472→      }\n   473→    }\n   474→\n   475→    return created;\n   476→  }\n   477→\n   478→  // ---- Phase 11: Middleware Pipeline ----\n   479→\n   480→  use(queueName: string, middleware: Middleware): void {\n   481→    const queue = this.getOrCreateQueue(queueName);\n   482→    queue.middlewares.push(middleware);\n   483→  }\n   484→\n   485→  setHandler(queueName: string, handler: TaskHandler): void {\n   486→    const queue = this.getOrCreateQueue(queueName);\n   487→    queue.handler = handler;\n   488→  }\n   489→\n   490→  async processTask(queueName: string = 'default'): Promise<Task | null> {\n   491→    const task = this.getNextTask(queueName);\n   492→    if (!task) return null;\n   493→\n   494→    const queue = this.queues.get(queueName);\n   495→    if (!queue) return task;\n   496→\n   497→    const middlewares = [...queue.middlewares];\n   498→    const handler = queue.handler;\n   499→\n   500→    try {\n   501→      let index = 0;\n   502→      const executeNext = async (): Promise<void> => {\n   503→        if (index < middlewares.length) {\n   504→          const mw = middlewares[index++];\n   505→          await mw(task, executeNext);\n   506→        } else if (handler) {\n   507→          await handler(task);\n   508→        }\n   509→      };\n   510→\n   511→      await executeNext();\n   512→\n   513→      // If still in processing state (middleware/handler didn't change it), mark completed\n   514→      if (task.status === 'processing') {\n   515→        this.completeTask(task.id);\n   516→      }\n   517→    } catch (error