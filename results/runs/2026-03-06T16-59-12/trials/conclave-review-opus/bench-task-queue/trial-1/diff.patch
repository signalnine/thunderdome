;\n\n  it('should track attempt count', () => {\n    const task = queue.addTask('data', { maxRetries: 3, backoffDelay: 10 });\n    expect(task.attempt).toBe(0);\n\n    const t1 = queue.getNextTask()!;\n    expect(t1.attempt).toBe(1);\n  });\n\n  it('should default to 3 max retries', () => {\n    const task = queue.addTask('data');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default to 1000ms base delay', () => {\n    const task = queue.addTask('data');\n    expect(task.backoffDelay).toBe(1000);\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    const task = queue.addTask('data', { queue: 'special', priority: 2, maxRetries: 3, backoffDelay: 10 });\n    queue.getNextTask('special');\n    queue.failTask(task.id, 'fail');\n\n    const updated = queue.getTask(task.id)!;\n    expect(updated.queue).toBe('special');\n    expect(updated.priority).toBe(2);\n  });\n\n  it('should remain failed after exhausting retries', () => {\n    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 1 });\n\n    // Attempt 1\n    queue.getNextTask();\n    queue.failTask(task.id, 'fail');\n\n    const updated = queue.getTask(task.id)!;\n    expect(updated.status).toBe('failed');\n  });\n\n  it('should error when completing non-processing task', () => {\n    const task = queue.addTask('data');\n    expect(() => queue.completeTask(task.id)).toThrow();\n  });\n\n  it('should error when failing non-processing task', () => {\n    const task = queue.addTask('data');\n    expect(() => queue.failTask(task.id)).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":818,"cache_read_input_tokens":36649,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":818},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a4530823-757f-4daf-bdef-7f