+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YJpC2Bo5LAfej1RavRAnro","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 4: Delayed and Scheduled Tasks', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should delay task by milliseconds', () => {\n    12→    queue.addTask('delayed', { delay: 5000 });\n    13→    // Task exists but is not available yet\n    14→    expect(queue.getWaitingCount()).toBe(1);\n    15→    expect(queue.getNextTask()).toBeNull();\n    16→  });\n    17→\n    18→  it('should make delayed task available after delay', async () => {\n    19→    queue.addTask('delayed', { delay: 50 });\n    20→    expect(queue.getNextTask()).toBeNull();\n    21→\n    22→    await new Promise(resolve => setTimeout(resolve, 60));\n    23→    const task = queue.getNextTask();\n    24→    expect(task?.payload).toBe('delayed');\n    25→  });\n    26→\n    27→  it('should schedule task for a specific time', () => {\n    28→    const futureTime = new Date(Date.now() + 10000);\n    29→    const task = queue.addTask('scheduled', { processAt: futureTime });\n    30→    expect(task.availableAt.getTime()).toBe(futureTime.getTime());\n    31→    expect(queue.getNextTask()).toBeNull();\n    32→  });\n    33→\n    34→  it('should prefer non-delayed tasks over delayed ones', () => {\n    35→    queue.addTask('delayed', { delay: 5000 });\n    36→    queue.addTask('immediate');\n    37→\n    38→    const task = queue.getNextTask();\n    39→    expect(task?.payload).toBe('immediate');\n    40→  });\n    41→\n    42→  it('should expose availability time on task', () => {\n    43→    const task = queue.addTask('delayed', { delay: 1000 });\n    44→    expect(task.availableAt).toBeInstanceOf(Date);\n    45→    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());\n    46→  });\n    47→\n    48→  it('should order by availability time, then priority, then FIFO when multiple become available', async () => {\n    49→    const now = Date.now();\n    50→    queue.addTask('later', { processAt: new Date(now - 100), priority: 5 });\n    51→    queue.addTask('earlier', { processAt: new Date(now - 200), priority: 5 });\n    52→\n    53→    const first = queue.getNextTask();\n    54→    const second = queue.getNextTask();\n    55→    expect(first?.payload).toBe('earlier');\n    56→    expect(second?.payload).toBe('later');\n    57→  });\n    58→\n    59→  it('should work with named queues', () => {\n    60→    queue.addTask('delayed', { queue: 'emails', delay: 5000 });\n    61→    queue.addTask('immediate', { queue: 'emails' });\n    62→\n    63→    expect(queue.getNextTask('emails')?.payload).toBe('immediate');\n    64→  });\n    65→});\n    66→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"d3fbb237-7bd1-42fc-827b-da38322e0200"}
