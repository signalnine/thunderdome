n\n    // Phase 3: Validate priority\n    if (options.priority !== undefined) {\n      if (!Number.isInteger(options.priority) || options.priority < 1 || options.priority > 10) {\n        throw new Error(`Invalid priority: ${options.priority}. Must be an integer between 1 and 10.`);\n      }\n    }\n\n    // Phase 7: Validate dependencies\n    if (options.dependencies && options.dependencies.length > 0) {\n      for (const depId of options.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (!depTask) {\n          throw new Error(`Dependency task \"${depId}\" does not exist.`);\n        }\n      }\n    }\n\n    const task = createTask(payload, options);\n\n    // Phase 7: Circular dependency detection\n    if (task.dependencies.length > 0) {\n      this.detectCircularDependencies(task);\n    }\n\n    const queue = this.getOrCreateQueue(task.queue);\n    queue.tasks.set(task.id, task);\n    this.allTasks.set(task.id, task);\n    return task;\n  }\n\n  getNextTask(queueName: string = 'default'): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n\n    // Phase 8: Check concurrency limit\n    if (queue.concurrencyLimit > 0) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= queue.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n\n    // Get all pending tasks that are available\n    const candidates: Task[] = [];\n    for (const task of queue.tasks.values()) {\n      if (task.status !== 'pending') continue;\n\n      // Phase 4: Skip delayed tasks not yet available\n      if (task.availableAt > now) continue;\n\n      // Phase 7: Skip tasks with unresolved dependencies\n      if (task.dependencies.length > 0) {\n        if (!this.areDependenciesMet(task)) continue;\n      }\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Phase 3: Sort by priority (lower = higher priority), then by availableAt, then FIFO (createdAt)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt += 1;\n    task.updatedAt = new Date();\n    return task;\n  }\n\n  getWaitingCount(queueName: string = 'default'): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const task of queue.tasks.values()) {\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.allTasks.get(taskId);\n  }\n\n  // ---- Phase 5: Retry with Backoff ----\n\n  completeTask(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status}).`);\n    }\n\n    task.status = 'completed';\n    task.updatedAt = new Date();\n\n    // Phase 7: Unblock dependent tasks (no action needed, checked at retrieval time)\n    // Dependencies are checked dynamically when getting next task\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status}).`);\n    }\n\n    task.error = error;\n    task.updatedAt = new Date();\n\n    if (task.attempt < task.maxRetries) {\n      // Re-add with exponential backoff delay\n      const del