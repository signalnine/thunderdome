+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should stop accepting tasks after shutdown', async () => {
+    await queue.shutdown();
+    expect(() => queue.addTask('data')).toThrow(/shut down/i);
+  });
+
+  it('should complete immediately with no processing tasks', async () => {
+    const result = await queue.shutdown();
+    expect(result.completed).toBe(0);
+    expect(result.cancelled).toBe(0);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should wait for processing tasks', async () => {
+    queue.addTask('data');
+    const task = queue.getNextTask()!;
+
+    // Complete the task asynchronously
+    setTimeout(() => {
+      queue.completeTask(task.id);
+    }, 50);
+
+    const result = await queue.shutdown(5000);
+    expect(result.completed).toBe(1);
+    expect(result.cancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks exceeding timeout', async () => {
+    queue.addTask('slow-data');
+    queue.getNextTask(); // Start processing but don't complete
+
+    const result = await queue.shutdown(50);
+    expect(result.cancelled).toBe(1);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let callbackRan = false;
+    queue.onShutdown(() => {
+      callbackRan = true;
+    });
+
+    await queue.shutdown();
+    expect(callbackRan).toBe(true);
+  });
+
+  it('should be safe to call shutdown multiple times', async () => {
+    const result1 = await queue.shutdown();
+    const result2 = await queue.shutdown();
+    expect(result1).toEqual(result2);
+  });
+
+  it('should report shutdown duration', async () => {
+    const result = await queue.shutdown();
+    expect(typeof result.duration).toBe('number');
+  });
+
+  it('should indicate system is shutting down', async () => {
+    expect(queue.isShuttingDown).toBe(false);
+    await queue.shutdown();
+    expect(queue.isShuttingDown).toBe(true);
+  });
+
+  it('should return summary with correct counts', async () => {
+    queue.addTask('a');
+    queue.addTask('b');
+    const t1 = queue.getNextTask()!;
+    queue.getNextTask()!; // t2 processing
+
+    // Complete t1 during shutdown
+    setTimeout(() => queue.completeTask(t1.id), 20);
+
+    // t2 will timeout
+    const result = await queue.shutdown(100);
+    expect(result.completed).toBe(1);
+    expect(result.cancelled).toBe(1);
+  });
+});
