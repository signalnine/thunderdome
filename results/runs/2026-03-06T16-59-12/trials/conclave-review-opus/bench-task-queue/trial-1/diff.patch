+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should move failed task to DLQ after exhausting retries', () => {
+    const task = queue.addTask('data', { maxRetries: 0 });
+
+    queue.getNextTask();
+    queue.failTask(task.id, 'permanent error');
+
+    const dlq = queue.getDeadLetterTasks();
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].id).toBe(task.id);
+    expect(dlq[0].lastError).toBe('permanent error');
+    expect(dlq[0].failCount).toBe(1);
+  });
+
+  it('should retain error info in DLQ', () => {
+    const task = queue.addTask('data', { maxRetries: 0 });
+    queue.getNextTask();
+    queue.failTask(task.id, 'specific error message');
+
+    const dlq = queue.getDeadLetterTasks();
+    expect(dlq[0].lastError).toBe('specific error message');
+  });
+
+  it('should reprocess dead-lettered task', () => {
+    const task = queue.addTask('data', { maxRetries: 0 });
+    queue.getNextTask();
+    queue.failTask(task.id, 'error');
+
+    expect(queue.getDeadLetterTasks()).toHaveLength(1);
+
+    const restored = queue.reprocessDeadLetteredTask(task.id);
+    expect(restored).not.toBeNull();
+    expect(restored!.status).toBe('pending');
+    expect(restored!.attempt).toBe(0);
+
+    expect(queue.getDeadLetterTasks()).toHaveLength(0);
+
+    // Can retrieve again
+    const retrieved = queue.getNextTask();
+    expect(retrieved?.id).toBe(task.id);
+  });
+
+  it('should clear dead letter queue', () => {
+    const task = queue.addTask('data', { maxRetries: 0 });
+    queue.getNextTask();
+    queue.failTask(task.id, 'error');
+
+    expect(queue.getDeadLetterTasks()).toHaveLength(1);
+    queue.clearDeadLetterQueue();
+    expect(queue.getDeadLetterTasks()).toHaveLength(0);
+  });
+
+  it('should have independent DLQs per queue', () => {
+    const t1 = queue.addTask('data1', { queue: 'q1', maxRetries: 0 });
+    const t2 = queue.addTask('data2', { queue: 'q2', maxRetries: 0 });
+
+    queue.getNextTask('q1');
+    queue.failTask(t1.id, 'error');
+    queue.getNextTask('q2');
+    queue.failTask(t2.id, 'error');
+
+    expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);
+    expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);
+
+    queue.clearDeadLetterQueue('q1');
+    expect(queue.getDeadLetterTasks('q1')).toHaveLength(0);
+    expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);
+  });
+
+  it('should return null when reprocessing non-existent DLQ task', () => {
+    expect(queue.reprocessDeadLetteredTask('nonexistent')).toBeNull();
+  });
+});
