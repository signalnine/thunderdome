+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U3XJHb4Y2Uxgq69svhnUPM","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 7: Task Dependencies', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should block tasks with pending dependencies', () => {\n    12→    const t1 = queue.addTask('first');\n    13→    queue.addTask('second', { dependencies: [t1.id] });\n    14→\n    15→    // Only t1 should be available\n    16→    const next = queue.getNextTask();\n    17→    expect(next?.payload).toBe('first');\n    18→\n    19→    // t2 is blocked\n    20→    expect(queue.getNextTask()).toBeNull();\n    21→  });\n    22→\n    23→  it('should unblock tasks when dependencies complete', () => {\n    24→    const t1 = queue.addTask('first');\n    25→    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n    26→\n    27→    const retrieved = queue.getNextTask()!;\n    28→    expect(retrieved.id).toBe(t1.id);\n    29→\n    30→    queue.completeTask(t1.id);\n    31→\n    32→    // Now t2 should be available\n    33→    const next = queue.getNextTask();\n    34→    expect(next?.id).toBe(t2.id);\n    35→  });\n    36→\n    37→  it('should error on non-existent dependency', () => {\n    38→    expect(() => queue.addTask('data', { dependencies: ['nonexistent'] })).toThrow();\n    39→  });\n    40→\n    41→  it('should detect circular dependencies', () => {\n    42→    const t1 = queue.addTask('first');\n    43→    // t1 exists, now add t2 depending on t1\n    44→    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n    45→    // t3 depends on t2, t2 depends on t1 - no cycle\n    46→    queue.addTask('third', { dependencies: [t2.id] });\n    47→\n    48→    // Self-dependency\n    49→    // Can't really test self-dependency since UUID is generated, but we test the detection\n    50→  });\n    51→\n    52→  it('should keep blocked tasks when dependency fails', () => {\n    53→    const t1 = queue.addTask('first', { maxRetries: 1, backoffDelay: 1 });\n    54→    queue.addTask('second', { dependencies: [t1.id] });\n    55→\n    56→    queue.getNextTask();\n    57→    queue.failTask(t1.id, 'error');\n    58→\n    59→    // t2 remains blocked (t1 is failed, not completed)\n    60→    expect(queue.getNextTask()).toBeNull();\n    61→  });\n    62→\n    63→  it('should inspect dependency status', () => {\n    64→    const t1 = queue.addTask('first');\n    65→    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n    66→\n    67→    const status = queue.getDependencyStatus(t2.id);\n    68→    expect(status).not.toBeNull();\n    69→    expect(status!.met).toBe(false);\n    70→    expect(status!.dependencies).toHaveLength(1);\n    71→    expect(status!.dependencies[0].id).toBe(t1.id);\n    72→    expect(status!.dependencies[0].status).toBe('pending');\n    73→  });\n    74→\n    75→  it('should show met dependencies after completion', () => {\n    76→    const t1 = queue.addTask('first');\n    77→    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n    78→\n    79→    queue.getNextTask();\n    80→    queue.completeTask(t1.id);\n    81→\n    82→    const status = queue.getDependencyStatus(t2.id);\n    83→    expect(status!.met).toBe(true);\n    84→    expect(status!.dependencies[0].status).toBe('completed');\n    85→  });\n    86→\n    87→  it('should support multiple dependencies', () => {\n    88→    const t1 = queue.addTask('first');\n    89→    const t2 = queue.addTask('second');\n    90→    const t3 = queue.addTask('third', { dependencies: [t1.id, t2.id] });\n    91→\n    92→    queue.getNextTask(); // t1\n    93→    queue.getNextTask(); // t2\n    94→    queue.completeTask(t1.id);\n    95→\n    96→    // t3 still blocked (t2 not complete)\n    97→    expect(queue.getNextTask()).toBeNull();\n    98→\n    99→    queue.completeTask(t2.id);\n   100→\n   101→    // Now t3 is available\n   102→    const next = queue.getNextTask();\n   103→    expect(next?.id).toBe(t3.id);\n   104→  });\n   105→\n   106→  it('should return null for non-existent task dependency status', () => {\n   107→    expect(queue.getDependencyStatus('nonexistent')).toBeNull();\n   108→  });\n   109→});\n   110→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"ce904703-e655-432f-aa43-acf218f040d6"}
