+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QwHtT77pUAAWa9X21VzW9E","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 6: Dead Letter Queue', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should move failed task to DLQ after exhausting retries', () => {\n    12→    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 1 });\n    13→\n    14→    queue.getNextTask();\n    15→    queue.failTask(task.id, 'permanent error');\n    16→\n    17→    const dlq = queue.getDeadLetterTasks();\n    18→    expect(dlq).toHaveLength(1);\n    19→    expect(dlq[0].id).toBe(task.id);\n    20→    expect(dlq[0].lastError).toBe('permanent error');\n    21→    expect(dlq[0].failCount).toBe(1);\n    22→  });\n    23→\n    24→  it('should retain error info in DLQ', () => {\n    25→    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 1 });\n    26→    queue.getNextTask();\n    27→    queue.failTask(task.id, 'specific error message');\n    28→\n    29→    const dlq = queue.getDeadLetterTasks();\n    30→    expect(dlq[0].lastError).toBe('specific error message');\n    31→  });\n    32→\n    33→  it('should reprocess dead-lettered task', () => {\n    34→    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 1 });\n    35→    queue.getNextTask();\n    36→    queue.failTask(task.id, 'error');\n    37→\n    38→    expect(queue.getDeadLetterTasks()).toHaveLength(1);\n    39→\n    40→    const restored = queue.reprocessDeadLetteredTask(task.id);\n    41→    expect(restored).not.toBeNull();\n    42→    expect(restored!.status).toBe('pending');\n    43→    expect(restored!.attempt).toBe(0);\n    44→\n    45→    expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    46→\n    47→    // Can retrieve again\n    48→    const retrieved = queue.getNextTask();\n    49→    expect(retrieved?.id).toBe(task.id);\n    50→  });\n    51→\n    52→  it('should clear dead letter queue', () => {\n    53→    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 1 });\n    54→    queue.getNextTask();\n    55→    queue.failTask(task.id, 'error');\n    56→\n    57→    expect(queue.getDeadLetterTasks()).toHaveLength(1);\n    58→    queue.clearDeadLetterQueue();\n    59→    expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    60→  });\n    61→\n    62→  it('should have independent DLQs per queue', () => {\n    63→    const t1 = queue.addTask('data1', { queue: 'q1', maxRetries: 1, backoffDelay: 1 });\n    64→    const t2 = queue.addTask('data2', { queue: 'q2', maxRetries: 1, backoffDelay: 1 });\n    65→\n    66→    queue.getNextTask('q1');\n    67→    queue.failTask(t1.id, 'error');\n    68→    queue.getNextTask('q2');\n    69→    queue.failTask(t2.id, 'error');\n    70→\n    71→    expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n    72→    expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    73→\n    74→    queue.clearDeadLetterQueue('q1');\n    75→    expect(queue.getDeadLetterTasks('q1')).toHaveLength(0);\n    76→    expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    77→  });\n    78→\n    79→  it('should return null when reprocessing non-existent DLQ task', () => {\n    80→    expect(queue.reprocessDeadLetteredTask('nonexistent')).toBeNull();\n    81→  });\n    82→});\n    83→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"4a660dee-a4fa-46cb-93e9-6aeed8eb0c60"}
