+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015EfBhGsuBeXy52XC2ryBYa","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→\n     3→export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';\n     4→\n     5→export interface TaskOptions {\n     6→  queue?: string;\n     7→  priority?: number;\n     8→  delay?: number;\n     9→  processAt?: Date;\n    10→  maxRetries?: number;\n    11→  backoffDelay?: number;\n    12→  dependencies?: string[];\n    13→}\n    14→\n    15→export interface Task<T = unknown> {\n    16→  id: string;\n    17→  payload: T;\n    18→  status: TaskStatus;\n    19→  priority: number;\n    20→  queue: string;\n    21→  createdAt: Date;\n    22→  updatedAt: Date;\n    23→  availableAt: Date;\n    24→  attempt: number;\n    25→  maxRetries: number;\n    26→  backoffDelay: number;\n    27→  error?: string;\n    28→  dependencies: string[];\n    29→  progress: number;\n    30→  progressMessage?: string;\n    31→}\n    32→\n    33→export interface DeadLetteredTask<T = unknown> extends Task<T> {\n    34→  failedAt: Date;\n    35→  failCount: number;\n    36→  lastError?: string;\n    37→}\n    38→\n    39→export interface Schedule {\n    40→  id: string;\n    41→  cronExpression: string;\n    42→  queue: string;\n    43→  taskTemplate: unknown;\n    44→  taskOptions?: Omit<TaskOptions, 'queue' | 'dependencies'>;\n    45→  lastRun?: Date;\n    46→  active: boolean;\n    47→}\n    48→\n    49→export type Middleware = (task: Task, next: () => Promise<void>) => Promise<void>;\n    50→export type TaskHandler = (task: Task) => Promise<void>;\n    51→export type ProgressListener = (progress: number, message?: string) => void;\n    52→\n    53→export interface ShutdownResult {\n    54→  completed: number;\n    55→  cancelled: number;\n    56→  duration: number;\n    57→}\n    58→\n    59→export function createTask<T>(payload: T, options: TaskOptions = {}): Task<T> {\n    60→  const now = new Date();\n    61→  const priority = options.priority ?? 5;\n    62→\n    63→  let availableAt = now;\n    64→  if (options.delay != null && options.delay > 0) {\n    65→    availableAt = new Date(now.getTime() + options.delay);\n    66→  } else if (options.processAt != null) {\n    67→    availableAt = options.processAt;\n    68→  }\n    69→\n    70→  return {\n    71→    id: randomUUID(),\n    72→    payload,\n    73→    status: 'pending',\n    74→    priority,\n    75→    queue: options.queue ?? 'default',\n    76→    createdAt: now,\n    77→    updatedAt: now,\n    78→    availableAt,\n    79→    attempt: 0,\n    80→    maxRetries: options.maxRetries ?? 3,\n    81→    backoffDelay: options.backoffDelay ?? 1000,\n    82→    dependencies: options.dependencies ?? [],\n    83→    progress: 0,\n    84→  };\n    85→}\n    86→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"7f093d7e-e154-4e18-ab40-4b25e930c40a"}
