+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xfb271bkMLJYA7kwSPyjJJ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../TaskQueue.js';\n     3→\n     4→describe('Phase 2: Named Queues', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should use default queue when no name given', () => {\n    12→    queue.addTask('data');\n    13→    const task = queue.getNextTask();\n    14→    expect(task?.queue).toBe('default');\n    15→  });\n    16→\n    17→  it('should support named queues', () => {\n    18→    queue.addTask('email', { queue: 'emails' });\n    19→    queue.addTask('sms', { queue: 'sms' });\n    20→\n    21→    const email = queue.getNextTask('emails');\n    22→    expect(email?.payload).toBe('email');\n    23→\n    24→    const sms = queue.getNextTask('sms');\n    25→    expect(sms?.payload).toBe('sms');\n    26→  });\n    27→\n    28→  it('should keep queues independent', () => {\n    29→    queue.addTask('a', { queue: 'q1' });\n    30→    queue.addTask('b', { queue: 'q2' });\n    31→\n    32→    expect(queue.getWaitingCount('q1')).toBe(1);\n    33→    expect(queue.getWaitingCount('q2')).toBe(1);\n    34→\n    35→    queue.getNextTask('q1');\n    36→    expect(queue.getWaitingCount('q1')).toBe(0);\n    37→    expect(queue.getWaitingCount('q2')).toBe(1);\n    38→  });\n    39→\n    40→  it('should return null for empty or non-existent queue', () => {\n    41→    expect(queue.getNextTask('nonexistent')).toBeNull();\n    42→  });\n    43→\n    44→  it('should list all queue names', () => {\n    45→    queue.addTask('a', { queue: 'emails' });\n    46→    queue.addTask('b', { queue: 'sms' });\n    47→    const names = queue.getQueueNames();\n    48→    expect(names).toContain('emails');\n    49→    expect(names).toContain('sms');\n    50→  });\n    51→\n    52→  it('should create queues implicitly', () => {\n    53→    expect(queue.getQueueNames()).toEqual([]);\n    54→    queue.addTask('data', { queue: 'new-queue' });\n    55→    expect(queue.getQueueNames()).toContain('new-queue');\n    56→  });\n    57→\n    58→  it('should be backward compatible with Phase 1', () => {\n    59→    queue.addTask('no-queue-specified');\n    60→    const task = queue.getNextTask();\n    61→    expect(task?.payload).toBe('no-queue-specified');\n    62→    expect(task?.queue).toBe('default');\n    63→  });\n    64→});\n    65→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"83ad1a02-f2c9-435e-b75e-d1b40b94c63e"}
