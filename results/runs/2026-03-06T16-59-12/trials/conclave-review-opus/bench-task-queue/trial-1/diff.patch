bleAt.getTime() - beforeFail1;\n    47→    // First retry: 1000 * 2^0 = 1000ms\n    48→    expect(delay1).toBeGreaterThanOrEqual(900);\n    49→    expect(delay1).toBeLessThan(1200);\n    50→  });\n    51→\n    52→  it('should track attempt count', () => {\n    53→    const task = queue.addTask('data', { maxRetries: 3, backoffDelay: 10 });\n    54→    expect(task.attempt).toBe(0);\n    55→\n    56→    const t1 = queue.getNextTask()!;\n    57→    expect(t1.attempt).toBe(1);\n    58→  });\n    59→\n    60→  it('should default to 3 max retries', () => {\n    61→    const task = queue.addTask('data');\n    62→    expect(task.maxRetries).toBe(3);\n    63→  });\n    64→\n    65→  it('should default to 1000ms base delay', () => {\n    66→    const task = queue.addTask('data');\n    67→    expect(task.backoffDelay).toBe(1000);\n    68→  });\n    69→\n    70→  it('should keep original queue and priority on retry', () => {\n    71→    const task = queue.addTask('data', { queue: 'special', priority: 2, maxRetries: 3, backoffDelay: 10 });\n    72→    queue.getNextTask('special');\n    73→    queue.failTask(task.id, 'fail');\n    74→\n    75→    const updated = queue.getTask(task.id)!;\n    76→    expect(updated.queue).toBe('special');\n    77→    expect(updated.priority).toBe(2);\n    78→  });\n    79→\n    80→  it('should remain failed after exhausting retries', () => {\n    81→    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 1 });\n    82→\n    83→    // Attempt 1\n    84→    queue.getNextTask();\n    85→    queue.failTask(task.id, 'fail');\n    86→\n    87→    const updated = queue.getTask(task.id)!;\n    88→    expect(updated.status).toBe('failed');\n    89→  });\n    90→\n    91→  it('should error when completing non-processing task', () => {\n    92→    const task = queue.addTask('data');\n    93→    expect(() => queue.completeTask(task.id)).toThrow();\n    94→  });\n    95→\n    96→  it('should error when failing non-processing task', () => {\n    97→    const task = queue.addTask('data');\n    98→    expect(() => queue.failTask(task.id)).toThrow();\n    99→  });\n   100→});\n   101→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"44741dfb-eb10-4cc0-8aa9-eb3f8865c5b8"}
