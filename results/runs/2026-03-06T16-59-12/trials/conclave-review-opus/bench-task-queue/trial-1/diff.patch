eckInterval = 10; // ms\n   578→\n   579→    while (Date.now() - waitStart < timeout) {\n   580→      let allDone = true;\n   581→      for (const task of processingTasks) {\n   582→        if (task.status === 'processing') {\n   583→          allDone = false;\n   584→          break;\n   585→        }\n   586→      }\n   587→      if (allDone) break;\n   588→      await new Promise(resolve => setTimeout(resolve, checkInterval));\n   589→    }\n   590→\n   591→    // Count completed and force-cancel remaining\n   592→    for (const task of processingTasks) {\n   593→      if (task.status === 'processing') {\n   594→        task.status = 'cancelled';\n   595→        task.updatedAt = new Date();\n   596→        cancelled++;\n   597→      } else if (task.status === 'completed') {\n   598→        completed++;\n   599→      }\n   600→    }\n   601→\n   602→    return {\n   603→      completed,\n   604→      cancelled,\n   605→      duration: Date.now() - startTime,\n   606→    };\n   607→  }\n   608→\n   609→  get isShuttingDown(): boolean {\n   610→    return this.isShutdown;\n   611→  }\n   612→}\n   613→"}]},"parent_tool_use_id":"toolu_01151BgFhXJBL59kF6yioaZo","session_id":"a4530823-757f-4daf-bdef-7f93fba6cecb","uuid":"4a4d9de1-a91c-4471-b8d5-2033307b6b32"}
