+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should default to unlimited concurrency', () => {
+    expect(queue.getConcurrency()).toBe(0);
+  });
+
+  it('should set and query concurrency limit', () => {
+    queue.setConcurrency('default', 2);
+    expect(queue.getConcurrency('default')).toBe(2);
+  });
+
+  it('should limit concurrent processing', () => {
+    queue.setConcurrency('default', 2);
+    queue.addTask('a');
+    queue.addTask('b');
+    queue.addTask('c');
+
+    const t1 = queue.getNextTask();
+    const t2 = queue.getNextTask();
+    expect(t1).not.toBeNull();
+    expect(t2).not.toBeNull();
+
+    // At limit, should return null
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should free slot when task completes', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('a');
+    queue.addTask('b');
+
+    const t1 = queue.getNextTask()!;
+    expect(queue.getNextTask()).toBeNull();
+
+    queue.completeTask(t1.id);
+    const t2 = queue.getNextTask();
+    expect(t2).not.toBeNull();
+  });
+
+  it('should free slot when task fails', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('a', { maxRetries: 0 });
+    queue.addTask('b');
+
+    const t1 = queue.getNextTask()!;
+    expect(queue.getNextTask()).toBeNull();
+
+    queue.failTask(t1.id, 'error');
+    // t1 failed and went to DLQ. Slot freed.
+    const t2 = queue.getNextTask();
+    expect(t2).not.toBeNull();
+  });
+
+  it('should track active count', () => {
+    queue.addTask('a');
+    queue.addTask('b');
+
+    expect(queue.getActiveCount()).toBe(0);
+    queue.getNextTask();
+    expect(queue.getActiveCount()).toBe(1);
+    queue.getNextTask();
+    expect(queue.getActiveCount()).toBe(2);
+  });
+
+  it('should respect priority with concurrency limit', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('low', { priority: 10 });
+    queue.addTask('high', { priority: 1 });
+
+    const task = queue.getNextTask();
+    expect(task?.payload).toBe('high');
+  });
+
+  it('should have independent concurrency per queue', () => {
+    queue.setConcurrency('q1', 1);
+    queue.setConcurrency('q2', 1);
+
+    queue.addTask('a', { queue: 'q1' });
+    queue.addTask('b', { queue: 'q1' });
+    queue.addTask('c', { queue: 'q2' });
+    queue.addTask('d', { queue: 'q2' });
+
+    expect(queue.getNextTask('q1')).not.toBeNull();
+    expect(queue.getNextTask('q1')).toBeNull(); // at limit
+
+    expect(queue.getNextTask('q2')).not.toBeNull();
+    expect(queue.getNextTask('q2')).toBeNull(); // at limit
+  });
+});
