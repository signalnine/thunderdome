+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WKVLuiYaVkdF9r7FNG3Pgh","type":"tool_result","content":"     1→import { Router, Request, Response, NextFunction } from 'express';\n     2→import Database from 'better-sqlite3';\n     3→import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\n     4→import { NotFoundError, ValidationError } from './errors.js';\n     5→\n     6→function sanitizeFtsQuery(query: string): string {\n     7→  // Remove FTS5 special characters that could cause syntax errors\n     8→  // Keep quoted phrases intact, strip other special chars\n     9→  // FTS5 special operators: AND, OR, NOT, NEAR, *, ^, +, -\n    10→  // We need to handle quotes for phrase matching\n    11→  const trimmed = query.trim();\n    12→\n    13→  // If the query is a quoted phrase, pass it through as-is\n    14→  if (trimmed.startsWith('\"') && trimmed.endsWith('\"') && trimmed.length > 2) {\n    15→    // Ensure the inner content doesn't have unbalanced quotes\n    16→    const inner = trimmed.slice(1, -1).replace(/\"/g, '');\n    17→    return `\"${inner}\"`;\n    18→  }\n    19→\n    20→  // Strip special FTS5 characters: ( ) { } : ^ * +\n    21→  // Replace them with spaces, then collapse multiple spaces\n    22→  const cleaned = trimmed\n    23→    .replace(/[(){}:^*+\\-/\\\\<>&']/g, ' ')\n    24→    .replace(/\\s+/g, ' ')\n    25→    .trim();\n    26→\n    27→  return cleaned;\n    28→}\n    29→\n    30→export function createRoutes(db: Database.Database): Router {\n    31→  const router = Router();\n    32→\n    33→  // GET /notes/search - Full-text search\n    34→  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    35→    try {\n    36→      const q = req.query.q as string | undefined;\n    37→      if (!q || q.trim() === '') {\n    38→        throw new ValidationError('Search query parameter \"q\" is required');\n    39→      }\n    40→\n    41→      const page = Math.max(1, parseInt(req.query.page as string) || 1);\n    42→      const perPage = 20;\n    43→      const offset = (page - 1) * perPage;\n    44→\n    45→      const sanitized = sanitizeFtsQuery(q);\n    46→      if (!sanitized) {\n    47→        // After sanitization the query is empty — return empty results\n    48→        res.json({ results: [], total: 0, page, perPage });\n    49→        return;\n    50→      }\n    51→\n    52→      // Count total matching results\n    53→      const countStmt = db.prepare(`\n    54→        SELECT COUNT(*) as cnt FROM notes_fts WHERE notes_fts MATCH ?\n    55→      `);\n    56→      const { cnt: total } = countStmt.get(sanitized) as { cnt: number };\n    57→\n    58→      // Fetch paginated results with BM25 ranking and snippet highlighting\n    59→      const searchStmt = db.prepare(`\n    60→        SELECT\n    61→          notes.id,\n    62→          notes.title,\n    63→          snippet(notes_fts, 1, '<mark>', '</mark>', '...', 32) as snippet,\n    64→          bm25(notes_fts) as rank\n    65→        FROM notes_fts\n    66→        JOIN notes ON notes.id = notes_fts.rowid\n    67→        WHERE notes_fts MATCH ?\n    68→        ORDER BY bm25(notes_fts)\n    69→        LIMIT ? OFFSET ?\n    70→      `);\n    71→      const results = searchStmt.all(sanitized, perPage, offset) as SearchResult[];\n    72→\n    73→      res.json({ results, total, page, perPage });\n    74→    } catch (err) {\n    75→      next(err);\n    76→    }\n    77→  });\n    78→\n    79→  // GET /notes/search/suggest - Autocomplete suggestions\n    80→  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n    81→    try {\n    82→      const q = req.query.q as string | undefined;\n    83→      if (!q || q.trim() === '') {\n    84→        throw new ValidationError('Search query parameter \"q\" is required');\n    85→      }\n    86→\n    87→      // Use prefix matching for autocomplete\n    88→      const sanitized = sanitizeFtsQuery(q);\n    89→      if (!sanitized) {\n    90→        res.json({ results: [] });\n    91→        return;\n    92→      }\n    93→\n    94→      // Add * for prefix matching if not a quoted phrase\n    95→      const ftsQuery = sanitized.startsWith('\"') ? sanitized : `${sanitized}*`;\n    96→\n    97→      const suggestStmt = db.prepare(`\n    98→        SELECT notes.id, notes.title\n    99→        FROM notes_fts\n   100→        JOIN notes ON notes.id = notes_fts.rowid\n   101→        WHERE notes_fts MATCH ?\n   102→        ORDER BY bm25(notes_fts)\n   103→        LIMIT 5\n   104→      `);\n   105→      const results = suggestStmt.all(ftsQuery) as SuggestResult[];\n   106→\n   107→      res.json({ results });\n   108→    } catch (err) {\n   109→      next(err);\n   110→    }\n   111→  });\n   112→\n   113→  // GET /notes - List all notes (with optional tag filter)\n   114→  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n   115→    try {\n   116→      const tag = req.query.tag as string | undefined;\n   117→\n   118→      let notes: Note[];\n   119→      if (tag) {\n   120→        // Use a join with json_each for tag filtering\n   121→        const tagStmt = db.prepare(`\n   122→          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n   123→          WHERE json_each.value = ?\n   124→          ORDER BY created_at DESC\n   125→        `);\n   126→        notes = tagStmt.all(tag) as Note[];\n   127→      } else {\n   128→        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n   129→        notes = stmt.all() as Note[];\n   130→      }\n   131→\n   132→      res.json({ notes });\n   133→    } catch (err) {\n   134→      next(err);\n   135→    }\n   136→  });\n   137→\n   138→  // GET /notes/:id - Get single note\n   139→  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   140→    try {\n   141→      const id = parseInt(req.params.id);\n   142→      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n   143→      const note = stmt.get(id) as Note | undefined;\n   144→\n   145→      if (!note) {\n   146→        throw new NotFoundError('Note not found');\n   147→      }\n   148→\n   149→      res.json({ note });\n   150→    } catch (err) {\n   151→      next(err);\n   152→    }\n   153→  });\n   154→\n   155→  // POST /notes - Create note\n   156→  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n   157→    try {\n   158→      const input = req.body as NoteInput;\n   159→\n   160→      if (!input.title || input.title.trim() === '') {\n   161→        throw new ValidationError('Title is required');\n   162→      }\n   163→      if (!input.body || input.body.trim() === '') {\n   164→        throw new ValidationError('Body is required');\n   165→      }\n   166→\n   167→      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n   168→      const stmt = db.prepare(`\n   169→        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n   170→      `);\n   171→      const result = stmt.run(input.title, input.body, tags);\n   172→\n   173→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n   174→      res.status(201).json({ note });\n   175→    } catch (err) {\n   176→      next(err);\n   177→    }\n   178→  });\n   179→\n   180→  // PUT /notes/:id - Update note\n   181→  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   182→    try {\n   183→      const id = parseInt(req.params.id);\n   184→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   185→\n   186→      if (!existing) {\n   187→        throw new NotFoundError('Note not found');\n   188→      }\n   189→\n   190→      const input = req.body as Partial<NoteInput>;\n   191→      const title = input.title ?? existing.title;\n   192→      const body = input.body ?? existing.body;\n   193→      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n   194→\n   195→      const stmt = db.prepare(`\n   196→        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n   197→        WHERE id = ?\n   198→      `);\n   199→      stmt.run(title, body, tags, id);\n   200→\n   201→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n   202→      res.json({ note });\n   203→    } catch (err) {\n   204→      next(err);\n   205→    }\n   206→  });\n   207→\n   208→  // DELETE /notes/:id - Delete note\n   209→  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   210→    try {\n   211→      const id = parseInt(req.params.id);\n   212→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   213→\n   214→      if (!existing) {\n   215→        throw new NotFoundError('Note not found');\n   216→      }\n   217→\n   218→      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n   219→      res.status(204).send();\n   220→    } catch (err) {\n   221→      next(err);\n   222→    }\n   223→  });\n   224→\n   225→  return router;\n   226→}\n   227→"}]},"parent_tool_use_id":"toolu_013FBtpsLp2yikaM3469qLFt","session_id":"1c18d800-2cdb-489d-a728-8a60b4072b0f","uuid":"43955c0e-a717-42a7-a721-670c4386e5e9"}
