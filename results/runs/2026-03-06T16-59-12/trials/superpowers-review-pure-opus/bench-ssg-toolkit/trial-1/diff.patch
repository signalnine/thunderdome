n    49→    expect(index[0].title).toBe('My Post');\n    50→    expect(index[0].content).toBe('Some text here');\n    51→  });\n    52→\n    53→  it('HTML tags stripped from indexed content', async () => {\n    54→    const files = [\n    55→      makeFile({\n    56→        slug: 'post',\n    57→        title: 'Post',\n    58→        content: '<h1>Title</h1><p>This is <strong>bold</strong> text.</p>',\n    59→      }),\n    60→    ];\n    61→    const ctx = makeCtx(files);\n    62→    await plugin.hooks.afterBuild!(ctx);\n    63→    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    64→    expect(index[0].content).not.toContain('<');\n    65→    expect(index[0].content).not.toContain('>');\n    66→    expect(index[0].content).toContain('bold');\n    67→    expect(index[0].content).toContain('text');\n    68→  });\n    69→\n    70→  it('code blocks included in searchable text', async () => {\n    71→    const files = [\n    72→      makeFile({\n    73→        slug: 'post',\n    74→        title: 'Code Post',\n    75→        content: '<p>Example:</p><pre><code class=\"language-js\">const x = 1;</code></pre>',\n    76→      }),\n    77→    ];\n    78→    const ctx = makeCtx(files);\n    79→    await plugin.hooks.afterBuild!(ctx);\n    80→    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    81→    expect(index[0].content).toContain('const x = 1;');\n    82→  });\n    83→\n    84→  it('handles empty file list', async () => {\n    85→    const ctx = makeCtx([]);\n    86→    await plugin.hooks.afterBuild!(ctx);\n    87→    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    88→    expect(index).toEqual([]);\n    89→  });\n    90→\n    91→  it('search index is valid JSON', async () => {\n    92→    const files = [\n    93→      makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Content</p>' }),\n    94→      makeFile({ slug: 'post-2', title: 'Post 2', content: '<p>More</p>' }),\n    95→    ];\n    96→    const ctx