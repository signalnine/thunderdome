private async performShutdown(options?: ShutdownOptions): Promise<ShutdownSummary> {\n    const timeout = options?.timeout ?? 30000;\n    const startTime = Date.now();\n    let completedCount = 0;\n    let cancelledCount = 0;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Collect all processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        cancelled: 0,\n        elapsed: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to complete, up to timeout\n    const waitForCompletion = (): Promise<void> => {\n      return new Promise<void>(resolve => {\n        let timeoutId: ReturnType<typeof setTimeout>;\n\n        const checkInterval = setInterval(() => {\n          const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n          if (stillProcessing.length === 0) {\n            clearInterval(checkInterval);\n            clearTimeout(timeoutId);\n            resolve();\n          }\n        }, 10);\n\n        timeoutId = setTimeout(() => {\n          clearInterval(checkInterval);\n          resolve();\n        }, timeout);\n      });\n    };\n\n    await waitForCompletion();\n\n    // Count completed vs force-cancel remaining\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        task.status = 'cancelled';\n        cancelledCount++;\n      } else if (task.status === 'completed') {\n        completedCount++;\n      } else if (task.status === 'failed') {\n        completedCount++;\n      }\n    }\n\n    return {\n      completed: completedCount,\n      cancelled: cancelledCount,\n      elapsed: Date.now() - startTime,\n    };\n  }\n}\n","structuredPatch":[{"oldStart":689,"oldLines":21