adTask);\n\n    // Update the task in the main map too\n    (this.tasks.get(task.id) as DeadLetteredTask).deadLetteredAt = new Date();\n  }\n\n  private validateCron(expression: string): void {\n    const parts = expression.split(' ');\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${expression}. Must have 5 fields.`);\n    }\n\n    // Validate supported patterns\n    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Check for supported patterns\n    const isEveryNMinutes = /^\\*\\/\\d+$/.test(minute) && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n    const isEveryHour = minute === '0' && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n    const isEveryDay = minute === '0' && hour === '0' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n\n    if (!isEveryNMinutes && !isEveryHour && !isEveryDay) {\n      throw new Error(`Unsupported cron expression: ${expression}. Supported: */N * * * *, 0 * * * *, 0 0 * * *`);\n    }\n\n    if (isEveryNMinutes) {\n      const n = parseInt(minute.split('/')[1], 10);\n      if (n <= 0 || n > 59) {\n        throw new Error(`Invalid interval in cron expression: ${n}`);\n      }\n    }\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cronExpression.split(' ');\n    const [minutePart, hourPart] = parts;\n\n    if (minutePart.startsWith('*/')) {\n      // Every N minutes\n      const interval = parseInt(minutePart.split('/')[1], 10);\n      const currentMinute = now.getMinutes();\n\n      if (currentMinute % interval !== 0) return false;\n\n      // Check if we already ran at this minute\n      if (schedule.lastRun) {\n        const lastRunMinute = schedule.lastRun.getMinutes();\n        const lastRunHour = schedule.lastRun.getHours();\n        const lastRunDate = schedule.lastRun.toDateString();\n        if (\n          lastRunMinute === currentMinute &&\n          lastRunHour === now.getHours() &&\n          lastRunDate === now.toDateString()\n        ) {\n          return false;\n        }\n      }\n      return true;\n    }\n\n    if (minutePart === '0' && hourPart === '*') {\n      // Every hour on the hour\n      if (now.getMinutes() !== 0) return false;\n\n      if (schedule.lastRun) {\n        const lastRunHour = schedule.lastRun.getHours();\n        const lastRunDate = schedule.lastRun.toDateString();\n        if (lastRunHour === now.getHours() && lastRunDate === now.toDateString()) {\n          return false;\n        }\n      }\n      return true;\n    }\n\n    if (minutePart === '0' && hourPart === '0') {\n      // Every day at midnight\n      if (now.getMinutes() !== 0 || now.getHours() !== 0) return false;\n\n      if (schedule.lastRun) {\n        if (schedule.lastRun.toDateString() === now.toDateString()) {\n          return false;\n        }\n      }\n      return true;\n    }\n\n    return false;\n  }\n\n  private async executeMiddlewarePipeline(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    handler?: HandlerFn\n  ): Promise<void> {\n    let index = 0;\n    let nextCalled = false;\n\n    const executeNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const middleware = middlewares[index++];\n        nextCalled = false;\n        await middleware(task, async () => {\n          nextCalled = true;\n          await executeNext();\n        });\n        // If middleware didn't call next, stop pipeline\n        if (!nextCalled && index <= middlewares.length) {\n          return;\n        }\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    await executeNext();\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownSummary> {\n    const timeout = options?.timeout ?? 30000;\n    const startTime = Date.now();\n    let completedCount = 0;\n    let cancelledCount = 0;\n\n    // Run shutdown callbacks\n    for (const