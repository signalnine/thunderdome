dlewareStacks.get(name) ?? [];\n    const handler = this.handlers.get(name);\n\n    try {\n      await this.executeMiddlewarePipeline(task, middlewares, handler);\n    } catch (err) {\n      const errorMsg = err instanceof Error ? err.message : String(err);\n      // Only fail if still processing (middleware may have changed status)\n      if (task.status === 'processing') {\n        this.fail(task.id, errorMsg);\n      }\n    }\n\n    return task;\n  }\n\n  // ─── Phase 12: Graceful Shutdown ────────────────────────────────\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownSummary> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(options);\n    return this.shutdownPromise;\n  }\n\n  // ─── Task Lookup ────────────────────────────────────────────────\n\n  getTask(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  // ─── Private Helpers ────────────────────────────────────────────\n\n  private ensureQueue(name: string): void {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, new Set());\n    }\n  }\n\n  private compareTasks(\n    a: { priority: number; availableAt: number; createdAt: number },\n    b: { priority: number; availableAt: number; createdAt: number }\n  ): number {\n    // Lower priority number = higher priority (1 is highest)\n    if (a.priority !== b.priority) return a.priority - b.priority;\n    // Earlier availability time first\n    if (a.availableAt !== b.availableAt) return a.availableAt - b.availableAt;\n    // FIFO: earlier creation time first\n    return a.createdAt - b.createdAt;\n  }\n\n  private hasUnresolvedDependencies(task: Task): boolean {\n    if (task.dependencies.length === 0) return false;\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') return true;\n    }\n    return false;\n  }\n\n  private detectCircularDeps(newTaskId: string, deps: string[]): void {\n    // BFS/DFS to check if any dependency transitively depends on the new task\n    // Since the new task hasn't been added yet, we check if any dependency\n    // has a chain that leads back to any of the deps being added\n    // Actually, since the task is new and not yet in the map, we can't have cycles\n    // unless a dependency depends on another task that depends on... itself\n    // The real check: does adding these dependencies create a cycle?\n\n    // We need to check: can any dependency reach back to newTaskId through its own dependencies?\n    // Since newTaskId is new, this isn't possible directly.\n    // But we should check for cycles among existing tasks when they reference each other.\n\n    // Actually the check is: among existing deps, is there a cycle?\n    // For a newly added task with deps [A, B], we check if A or B transitively depend on each other\n    // in a way that would create a cycle. But since the new task isn't anyone's dependency yet,\n    // the only cycle possible would be if we introduced a dependency on a task that somehow\n    // already depends on this new task. Since this task is new, that's impossible.\n\n    // However, the spec says \"circular dependencies (direct or indirect) must be detected and rejected\".\n    // This means: if task A depends on B, and then we try to add task C that depends on A,\n    // and later A tries to depend on C - that should be caught.\n    // Since we're creating a new task, the cycle can't exist yet.\n    // But let's be safe and do a proper check anyway.\n\n    // Actually the real scenario is:\n    // 1. Task A exists (no deps)\n    // 2. Task B is added with dep on A\n    // 3. Now we try to add a dep from A to B - but A already exists, we'd need to modify it\n    // Since deps are set at creation tim