FO\n      const first = queue.next();\n      expect(first?.payload).toBe('delayed-high');\n    });\n\n    it('should handle dependencies + priority', () => {\n      const dep = queue.add('dep', { priority: 10 });\n      queue.add('dependent', { priority: 1, dependencies: [dep.id] });\n\n      // Even though dependent has higher priority, it's blocked\n      const task = queue.next();\n      expect(task?.payload).toBe('dep');\n    });\n\n    it('should handle concurrency + retry', () => {\n      queue.setConcurrency('default', 1);\n      const t = queue.add('task', { maxRetries: 2, backoffDelay: 0 });\n\n      const task = queue.next()!;\n      queue.fail(task.id, 'err');\n\n      // After fail, concurrency slot is freed, task is pending with delay\n      queue.getTask(t.id)!.availableAt = new Date(0);\n      const retry = queue.next();\n      expect(retry?.id).toBe(t.id);\n    });\n\n    it('should handle cancel + progress', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      queue.reportProgress(task.id, 50);\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":522,"cache_read_input_tokens":36062,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":522},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2107b12e-f12a-4d0c-bc47-bb3ab39302b3","uuid":"7f402232-3575-46ec-b7f7-8b5b49660bb6"}
