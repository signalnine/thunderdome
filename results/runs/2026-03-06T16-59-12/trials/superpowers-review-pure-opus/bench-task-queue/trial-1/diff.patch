+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FQXyRHsfzcfVBtwoDaAmNZ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('TaskQueue', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  // ─── Phase 1: Basic FIFO Queue ───────────────────────────────────\n    12→\n    13→  describe('Phase 1: Basic FIFO Queue', () => {\n    14→    it('should add a task and return a task object', () => {\n    15→      const task = queue.add({ message: 'hello' });\n    16→      expect(task).toBeDefined();\n    17→      expect(task.id).toBeDefined();\n    18→      expect(task.payload).toEqual({ message: 'hello' });\n    19→      expect(task.status).toBe('pending');\n    20→      expect(task.createdAt).toBeInstanceOf(Date);\n    21→    });\n    22→\n    23→    it('should assign unique IDs to tasks', () => {\n    24→      const t1 = queue.add('task1');\n    25→      const t2 = queue.add('task2');\n    26→      expect(t1.id).not.toBe(t2.id);\n    27→    });\n    28→\n    29→    it('should retrieve tasks in FIFO order', () => {\n    30→      queue.add('first');\n    31→      queue.add('second');\n    32→      queue.add('third');\n    33→\n    34→      const t1 = queue.next();\n    35→      expect(t1?.payload).toBe('first');\n    36→      expect(t1?.status).toBe('processing');\n    37→\n    38→      const t2 = queue.next();\n    39→      expect(t2?.payload).toBe('second');\n    40→\n    41→      const t3 = queue.next();\n    42→      expect(t3?.payload).toBe('third');\n    43→    });\n    44→\n    45→    it('should return null when no tasks are available', () => {\n    46→      expect(queue.next()).toBeNull();\n    47→    });\n    48→\n    49→    it('should return null after all tasks are consumed', () => {\n    50→      queue.add('only');\n    51→      queue.next();\n    52→      expect(queue.next()).toBeNull();\n    53→    });\n    54→\n    55→    it('should transition task to processing on next()', () => {\n    56→      queue.add('task');\n    57→      const task = queue.next();\n    58→      expect(task?.status).toBe('processing');\n    59→    });\n    60→\n    61→    it('should track queue size', () => {\n    62→      expect(queue.size()).toBe(0);\n    63→      queue.add('a');\n    64→      queue.add('b');\n    65→      expect(queue.size()).toBe(2);\n    66→      queue.next();\n    67→      expect(queue.size()).toBe(1);\n    68→    });\n    69→  });\n    70→\n    71→  // ─── Phase 2: Named Queues ──────────────────────────────────────\n    72→\n    73→  describe('Phase 2: Named Queues', () => {\n    74→    it('should use default queue when no name specified', () => {\n    75→      queue.add('task');\n    76→      expect(queue.getQueues()).toContain('default');\n    77→    });\n    78→\n    79→    it('should support named queues', () => {\n    80→      queue.add('email-task', { queue: 'emails' });\n    81→      queue.add('report-task', { queue: 'reports' });\n    82→\n    83→      expect(queue.getQueues()).toContain('emails');\n    84→      expect(queue.getQueues()).toContain('reports');\n    85→    });\n    86→\n    87→    it('should keep named queues independent', () => {\n    88→      queue.add('email-1', { queue: 'emails' });\n    89→      queue.add('report-1', { queue: 'reports' });\n    90→\n    91→      const emailTask = queue.next('emails');\n    92→      expect(emailTask?.payload).toBe('email-1');\n    93→      expect(queue.size('emails')).toBe(0);\n    94→      expect(queue.size('reports')).toBe(1);\n    95→    });\n    96→\n    97→    it('should return null for non-existent queue', () => {\n    98→      expect(queue.next('nonexistent')).toBeNull();\n    99→    });\n   100→\n   101→    it('should return null for empty queue', () => {\n   102→      queue.add('task', { queue: 'myqueue' });\n   103→      queue.next('myqueue');\n   104→      expect(queue.next('myqueue')).toBeNull();\n   105→    });\n   106→\n   107→    it('should list all queue names', () => {\n   108→      queue.add('a', { queue: 'q1' });\n   109→      queue.add('b', { queue: 'q2' });\n   110→      queue.add('c', { queue: 'q3' });\n   111→      const names = queue.getQueues();\n   112→      expect(names).toContain('q1');\n   113→      expect(names).toContain('q2');\n   114→      expect(names).toContain('q3');\n   115→      expect(names).toHaveLength(3);\n   116→    });\n   117→\n   118→    it('should be backward compatible (default queue)', () => {\n   119→      queue.add('task');\n   120→      const task = queue.next();\n   121→      expect(task?.payload).toBe('task');\n   122→    });\n   123→  });\n   124→\n   125→  // ─── Phase 3: Priority ─────────────────────────────────────────\n   126→\n   127→  describe('Phase 3: Priority', () => {\n   128→    it('should default to priority 5', () => {\n   129→      const task = queue.add('task');\n   130→      expect(task.priority).toBe(5);\n   131→    });\n   132→\n   133→    it('should return higher priority tasks first', () => {\n   134→      queue.add('low', { priority: 10 });\n   135→      queue.add('high', { priority: 1 });\n   136→      queue.add('medium', { priority: 5 });\n   137→\n   138→      expect(queue.next()?.payload).toBe('high');\n   139→      expect(queue.next()?.payload).toBe('medium');\n   140→      expect(queue.next()?.payload).toBe('low');\n   141→    });\n   142→\n   143→    it('should maintain FIFO within same priority', () => {\n   144→      queue.add('first', { priority: 3 });\n   145→      queue.add('second', { priority: 3 });\n   146→      queue.add('third', { priority: 3 });\n   147→\n   148→      expect(queue.next()?.payload).toBe('first');\n   149→      expect(queue.next()?.payload).toBe('second');\n   150→      expect(queue.next()?.payload).toBe('third');\n   151→    });\n   152→\n   153→    it('should reject invalid priority (too low)', () => {\n   154→      expect(() => queue.add('task', { priority: 0 })).toThrow();\n   155→    });\n   156→\n   157→    it('should reject invalid priority (too high)', () => {\n   158→      expect(() => queue.add('task', { priority: 11 })).toThrow();\n   159→    });\n   160→\n   161→    it('should reject non-integer priority', () => {\n   162→      expect(() => queue.add('task', { priority: 2.5 })).toThrow();\n   163→    });\n   164→\n   165→    it('should expose priority on task object', () => {\n   166→      const task = queue.add('task', { priority: 3 });\n   167→      expect(task.priority).toBe(3);\n   168→    });\n   169→\n   170→    it('should handle priority per queue', () => {\n   171→      queue.add('q1-low', { queue: 'q1', priority: 10 });\n   172→      queue.add('q1-high', { queue: 'q1', priority: 1 });\n   173→      queue.add('q2-low', { queue: 'q2', priority: 10 });\n   174→\n   175→      expect(queue.next('q1')?.payload).toBe('q1-high');\n   176→      expect(queue.next('q2')?.payload).toBe('q2-low');\n   177→    });\n   178→  });\n   179→\n   180→  // ─── Phase 4: Delayed Tasks ─────────────────────────────────────\n   181→\n   182→  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n   183→    it('should accept a delay in milliseconds', () => {\n   184→      const task = queue.add('delayed', { delay: 5000 });\n   185→      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n   186→    });\n   187→\n   188→    it('should not return delayed tasks before their time', () => {\n   189→      queue.add('delayed', { delay: 60000 });\n   190→      expect(queue.next()).toBeNull();\n   191→    });\n   192→\n   193→    it('should return non-delayed tasks before delayed ones', () => {\n   194→      queue.add('delayed', { delay: 60000 });\n   195→      queue.add('immediate');\n   196→\n   197→      const task = queue.next();\n   198→      expect(task?.payload).toBe('immediate');\n   199→    });\n   200→\n   201→    it('should accept processAt date', () => {\n   202→      const futureDate = new Date(Date.now() + 60000);\n   203→      const task = queue.add('scheduled', { processAt: futureDate });\n   204→      expect(task.availableAt).toEqual(futureDate);\n   205→    });\n   206→\n   207→    it('should return delayed tasks that are now available', () => {\n   208→      // Use a delay of 0 or past time\n   209→      const pastDate = new Date(Date.now() - 1000);\n   210→      queue.add('available', { processAt: pastDate });\n   211→\n   212→      const task = queue.next();\n   213→      expect(task?.payload).toBe('available');\n   214→    });\n   215→\n   216→    it('should order delayed tasks by availability then priority then FIFO', () => {\n   217→      const past1 = new Date(Date.now() - 2000);\n   218→      const past2 = new Date(Date.now() - 1000);\n   219→\n   220→      // Same priority - availability time is the tiebreaker\n   221→      queue.add('later', { processAt: past2, priority: 5 });\n   222→      queue.add('earlier', { processAt: past1, priority: 5 });\n   223→\n   224→      // Earlier availability time comes first when priority is the same\n   225→      expect(queue.next()?.payload).toBe('earlier');\n   226→      expect(queue.next()?.payload).toBe('later');\n   227→    });\n   228→\n   229→    it('should prefer higher priority over earlier availability when priorities differ', () => {\n   230→      const past1 = new Date(Date.now() - 2000);\n   231→      const past2 = new Date(Date.now() - 1000);\n   232→\n   233→      queue.add('earlier-low-prio', { processAt: past1, priority: 10 });\n   234→      queue.add('later-high-prio', { processAt: past2, priority: 1 });\n   235→\n   236→      // Higher priority wins even if available later\n   237→      expect(queue.next()?.payload).toBe('later-high-prio');\n   238→      expect(queue.next()?.payload).toBe('earlier-low-prio');\n   239→    });\n   240→\n   241→    it('should work with named queues', () => {\n   242→      queue.add('delayed-email', { queue: 'emails', delay: 60000 });\n   243→      queue.add('immediate-email', { queue: 'emails' });\n   244→\n   245→      expect(queue.next('emails')?.payload).toBe('immediate-email');\n   246→      expect(queue.next('emails')).toBeNull();\n   247→    });\n   248→  });\n   249→\n   250→  // ─── Phase 5: Retry with Backoff ────────────────────────────────\n   251→\n   252→  describe('Phase 5: Retry with Backoff', () => {\n   253→    it('should complete a processing task', () => {\n   254→      queue.add('task');\n   255→      const task = queue.next()!;\n   256→      queue.complete(task.id);\n   257→      expect(queue.getTask(task.id)?.status).toBe('completed');\n   258→    });\n   259→\n   260→    it('should fail a processing task and retry', () => {\n   261→      queue.add('task', { maxRetries: 3, backoffDelay: 100 });\n   262→      const task = queue.next()!;\n   263→      expect(task.attempts).toBe(1);\n   264→\n   265→      queue.fail(task.id, 'error');\n   266→\n   267→      // Task should be pending again with a delay\n   268→      const updated = queue.getTask(task.id)!;\n   269→      expect(updated.status).toBe('pending');\n   270→      expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now());\n   271→    });\n   272→\n   273→    it('should use exponential backoff', () => {\n   274→      const t = queue.add('task', { maxRetries: 3, backoffDelay: 1000 });\n   275→\n   276→      // First attempt\n   277→      queue.next();\n   278→      const beforeFail1 = Date.now();\n   279→      queue.fail(t.id, 'err');\n   280→      const task1 = queue.getTask(t.id)!;\n   281→      // First retry delay: 1000 * 2^0 = 1000ms\n   282→      expect(task1.availableAt.getTime() - beforeFail1).toBeGreaterThanOrEqual(900);\n   283→      expect(task1.availableAt.getTime() - beforeFail1).toBeLessThan(2000);\n   284→    });\n   285→\n   286→    it('should track attempt count', () => {\n   287→      const t = queue.add('task', { maxRetries: 3, backoffDelay: 0 });\n   288→\n   289→      queue.next();\n   290→      expect(queue.getTask(t.id)!.attempts).toBe(1);\n   291→\n   292→      queue.fail(t.id, 'err');\n   293→      // Manually set available so we can get it again\n   294→      queue.getTask(t.id)!.availableAt = new Date(0);\n   295→\n   296→      queue.next();\n   297→      expect(queue.getTask(t.id)!.attempts).toBe(2);\n   298→    });\n   299→\n   300→    it('should mark as failed after exhausting retries', () => {\n   301→      const t = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n   302→\n   303→      // First and only attempt\n   304→      queue.next();\n   305→      queue.fail(t.id, 'final error');\n   306→\n   307→      expect(queue.getTask(t.id)!.status).toBe('failed');\n   308→    });\n   309→\n   310→    it('should keep original queue and priority on retry', () => {\n   311→      const t = queue.add('task', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n   312→\n   313→      queue.next('myq');\n   314→      queue.fail(t.id, 'err');\n   315→\n   316→      const updated = queue.getTask(t.id)!;\n   317→      expect(updated.queue).toBe('myq');\n   318→      expect(updated.priority).toBe(2);\n   319→    });\n   320→\n   321→    it('should throw when completing non-processing task', () => {\n   322→      const t = queue.add('task');\n   323→      expect(() => queue.complete(t.id)).toThrow();\n   324→    });\n   325→\n   326→    it('should throw when failing non-processing task', () => {\n   327→      const t = queue.add('task');\n   328→      expect(() => queue.fail(t.id)).toThrow();\n   329→    });\n   330→\n   331→    it('should set default maxRetries to 3', () => {\n   332→      const t = queue.add('task');\n   333→      expect(t.maxRetries).toBe(3);\n   334→    });\n   335→\n   336→    it('should set default backoffDelay to 1000', () => {\n   337→      const t = queue.add('task');\n   338→      expect(t.backoffDelay).toBe(1000);\n   339→    });\n   340→  });\n   341→\n   342→  // ─── Phase 6: Dead Letter Queue ─────────────────────────────────\n   343→\n   344→  describe('Phase 6: Dead Letter Queue', () => {\n   345→    it('should move task to DLQ after exhausting retries', () => {\n   346→      const t = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n   347→\n   348→      queue.next();\n   349→      queue.fail(t.id, 'permanent failure');\n   350→\n   351→      const dlq = queue.getDeadLetterTasks();\n   352→      expect(dlq).toHaveLength(1);\n   353→      expect(dlq[0].id).toBe(t.id);\n   354→      expect(dlq[0].lastError).toBe('permanent failure');\n   355→    });\n   356→\n   357→    it('should retain error info on dead-lettered tasks', () => {\n   358→      const t = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n   359→      queue.next();\n   360→      queue.fail(t.id, 'some error');\n   361→\n   362→      const dlq = queue.getDeadLetterTasks();\n   363→      expect(dlq[0].lastError).toBe('some error');\n   364→      expect(dlq[0].failureCount).toBe(1);\n   365→    });\n   366→\n   367→    it('should requeue a dead-lettered task', () => {\n   368→      const t = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n   369→      queue.next();\n   370→      queue.fail(t.id, 'err');\n   371→\n   372→      expect(queue.getDeadLetterTasks()).toHaveLength(1);\n   373→\n   374→      const requeued = queue.requeue(t.id);\n   375→      expect(requeued).toBeDefined();\n   376→      expect(requeued!.status).toBe('pending');\n   377→      expect(requeued!.attempts).toBe(0);\n   378→      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n   379→    });\n   380→\n   381→    it('should clear dead letter queue', () => {\n   382→      const t1 = queue.add('task1', { maxRetries: 1, backoffDelay: 0 });\n   383→      const t2 = queue.add('task2', { maxRetries: 1, backoffDelay: 0 });\n   384→\n   385→      queue.next(); queue.fail(t1.id, 'err');\n   386→      queue.next(); queue.fail(t2.id, 'err');\n   387→\n   388→      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n   389→      queue.clearDeadLetterQueue();\n   390→      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n   391→    });\n   392→\n   393→    it('should have independent DLQ per named queue', () => {\n   394→      const t1 = queue.add('task1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n   395→      const t2 = queue.add('task2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n   396→\n   397→      queue.next('q1'); queue.fail(t1.id, 'err');\n   398→      queue.next('q2'); queue.fail(t2.id, 'err');\n   399→\n   400→      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n   401→      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n   402→\n   403→      queue.clearDeadLetterQueue('q1');\n   404→      expect(queue.getDeadLetterTasks('q1')).toHaveLength(0);\n   405→      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n   406→    });\n   407→\n   408→    it('should throw when requeuing non-DLQ task', () => {\n   409→      expect(() => queue.requeue('nonexistent')).toThrow();\n   410→    });\n   411→  });\n   412→\n   413→  // ─── Phase 7: Task Dependencies ─────────────────────────────────\n   414→\n   415→  describe('Phase 7: Task Dependencies', () => {\n   416→    it('should block tasks with unresolved dependencies', () => {\n   417→      const dep = queue.add('dependency');\n   418→      queue.add('dependent', { dependencies: [dep.id] });\n   419→\n   420→      // Dependent should not be returned\n   421→      const task = queue.next();\n   422→      expect(task?.payload).toBe('dependency');\n   423→\n   424→      // After taking dep, dependent is still blocked\n   425→      expect(queue.next()).toBeNull();\n   426→    });\n   427→\n   428→    it('should unblock task when dependency completes', () => {\n   429→      const dep = queue.add('dependency');\n   430→      queue.add('dependent', { dependencies: [dep.id] });\n   431→\n   432→      const depTask = queue.next()!;\n   433→      queue.complete(depTask.id);\n   434→\n   435→      const dependentTask = queue.next();\n   436→      expect(dependentTask?.payload).toBe('dependent');\n   437→    });\n   438→\n   439→    it('should reject circular dependencies', () => {\n   440→      const a = queue.add('A');\n   441→      const b = queue.add('B', { dependencies: [a.id] });\n   442→      expect(() =>\n   443→        queue.add('C', { dependencies: [b.id] })\n   444→      ).not.toThrow();\n   445→\n   446→      // This would create a cycle only if A depended on C, but A has no deps\n   447→      // So let's test actual cycle detection:\n   448→      // We can't create a cycle with creation-time deps easily since tasks are new\n   449→      // But let's test the non-existent dependency error\n   450→    });\n   451→\n   452→    it('should reject dependency on non-existent task', () => {\n   453→      expect(() => queue.add('task', { dependencies: ['nonexistent'] })).toThrow();\n   454→    });\n   455→\n   456→    it('should keep dependents blocked when dependency fails', () => {\n   457→      const dep = queue.add('dependency', { maxRetries: 1, backoffDelay: 0 });\n   458→      queue.add('dependent', { dependencies: [dep.id] });\n   459→\n   460→      const depTask = queue.next()!;\n   461→      queue.fail(depTask.id, 'err');\n   462→\n   463→      // Dependent should still be blocked\n   464→      expect(queue.next()).toBeNull();\n   465→    });\n   466→\n   467→    it('should inspect dependency status', () => {\n   468→      const a = queue.add('A');\n   469→      const b = queue.add('B');\n   470→      const c = queue.add('C', { dependencies: [a.id, b.id] });\n   471→\n   472→      const status = queue.getDependencyStatus(c.id);\n   473→      expect(status.taskId).toBe(c.id);\n   474→      expect(status.pending).toContain(a.id);\n   475→      expect(status.pending).toContain(b.id);\n   476→      expect(status.resolved).toHaveLength(0);\n   477→      expect(status.blocked).toBe(true);\n   478→\n   479→      // Complete one dependency\n   480→      const taskA = queue.next()!;\n   481→      queue.complete(taskA.id);\n   482→\n   483→      const status2 = queue.getDependencyStatus(c.id);\n   484→      expect(status2.resolved).toContain(a.id);\n   485→      expect(status2.pending).toContain(b.id);\n   486→      expect(status2.blocked).toBe(true);\n   487→    });\n   488→\n   489→    it('should handle multiple dependencies all resolved', () => {\n   490→      const a = queue.add('A');\n   491→      const b = queue.add('B');\n   492→      const c = queue.add('C', { dependencies: [a.id, b.id] });\n   493→\n   494→      // Complete both\n   495→      const taskA = queue.next()!;\n   496→      queue.complete(taskA.id);\n   497→      const taskB = queue.next()!;\n   498→      queue.complete(taskB.id);\n   499→\n   500→      const taskC = queue.next();\n   501→      expect(taskC?.id).toBe(c.id);\n   502→    });\n   503→  });\n   504→\n   505→  // ─── Phase 8: Concurrency Control ──────────────────────────────\n   506→\n   507→  describe('Phase 8: Concurrency Control', () => {\n   508→    it('should limit concurrent processing', () => {\n   509→      queue.setConcurrency('default', 2);\n   510→      queue.add('task1');\n   511→      queue.add('task2');\n   512→      queue.add('task3');\n   513→\n   514→      const t1 = queue.next();\n   515→      const t2 = queue.next();\n   516→      const t3 = queue.next();\n   517→\n   518→      expect(t1).not.toBeNull();\n   519→      expect(t2).not.toBeNull();\n   520→      expect(t3).toBeNull(); // Limit reached\n   521→    });\n   522→\n   523→    it('should free slot on completion', () => {\n   524→      queue.setConcurrency('default', 1);\n   525→      queue.add('task1');\n   526→      queue.add('task2');\n   527→\n   528→      const t1 = queue.next()!;\n   529→      expect(queue.next()).toBeNull(); // Limit reached\n   530→\n   531→      queue.complete(t1.id);\n   532→      const t2 = queue.next();\n   533→      expect(t2?.payload).toBe('task2');\n   534→    });\n   535→\n   536→    it('should free slot on failure', () => {\n   537→      queue.setConcurrency('default', 1);\n   538→      queue.add('task1', { maxRetries: 1, backoffDelay: 0 });\n   539→      queue.add('task2');\n   540→\n   541→      const t1 = queue.next()!;\n   542→      expect(queue.next()).toBeNull();\n   543→\n   544→      queue.fail(t1.id, 'err'); // Task exhausts retries -> failed\n   545→      const t2 = queue.next();\n   546→      expect(t2?.payload).toBe('task2');\n   547→    });\n   548→\n   549→    it('should default to unlimited concurrency', () => {\n   550→      expect(queue.getConcurrency()).toBeUndefined();\n   551→    });\n   552→\n   553→    it('should query active count', () => {\n   554→      queue.add('task1');\n   555→      queue.add('task2');\n   556→\n   557→      expect(queue.getActiveCount()).toBe(0);\n   558→      queue.next();\n   559→      expect(queue.getActiveCount()).toBe(1);\n   560→      queue.next();\n   561→      expect(queue.getActiveCount()).toBe(2);\n   562→    });\n   563→\n   564→    it('should respect priority within concurrency limit', () => {\n   565→      queue.setConcurrency('default', 1);\n   566→      queue.add('low', { priority: 10 });\n   567→      queue.add('high', { priority: 1 });\n   568→\n   569→      const task = queue.next();\n   570→      expect(task?.payload).toBe('high');\n   571→    });\n   572→  });\n   573→\n   574→  // ─── Phase 9: Progress Tracking and Cancellation ────────────────\n   575→\n   576→  describe('Phase 9: Progress Tracking and Cancellation', () => {\n   577→    it('should report and query progress', () => {\n   578→      queue.add('task');\n   579→      const task = queue.next()!;\n   580→\n   581→      queue.reportProgress(task.id, 50, 'halfway there');\n   582→      const progress = queue.getProgress(task.id);\n   583→      expect(progress.progress).toBe(50);\n   584→      expect(progress.message).toBe('halfway there');\n   585→    });\n   586→\n   587→    it('should notify progress listeners', () => {\n   588→      queue.add('task');\n   589→      const task = queue.next()!;\n   590→\n   591→      const updates: Array<{ progress: number; message?: string }> = [];\n   592→      queue.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n   593→\n   594→      queue.reportProgress(task.id, 25, 'quarter');\n   595→      queue.reportProgress(task.id, 75, 'three quarters');\n   596→\n   597→      expect(updates).toHaveLength(2);\n   598→      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n   599→      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n   600→    });\n   601→\n   602→    it('should support unsubscribe from progress', () => {\n   603→      queue.add('task');\n   604→      const task = queue.next()!;\n   605→\n   606→      const updates: number[] = [];\n   607→      const unsub = queue.onProgress(task.id, (p) => updates.push(p));\n   608→\n   609→      queue.reportProgress(task.id, 25);\n   610→      unsub();\n   611→      queue.reportProgress(task.id, 75);\n   612→\n   613→      expect(updates).toHaveLength(1);\n   614→      expect(updates[0]).toBe(25);\n   615→    });\n   616→\n   617→    it('should cancel a pending task', () => {\n   618→      const t = queue.add('task');\n   619→      queue.cancel(t.id);\n   620→\n   621→      expect(queue.getTask(t.id)?.status).toBe('cancelled');\n   622→      expect(queue.next()).toBeNull();\n   623→      expect(queue.size()).toBe(0);\n   624→    });\n   625→\n   626→    it('should cancel a processing task', () => {\n   627→      queue.add('task');\n   628→      const task = queue.next()!;\n   629→      queue.cancel(task.id);\n   630→\n   631→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   632→    });\n   633→\n   634→    it('should not retry cancelled tasks', () => {\n   635→      const t = queue.add('task', { maxRetries: 3 });\n   636→      queue.next();\n   637→      queue.cancel(t.id);\n   638→\n   639→      // Task should remain cancelled, not retried\n   640→      expect(queue.getTask(t.id)?.status).toBe('cancelled');\n   641→      expect(queue.next()).toBeNull();\n   642→    });\n   643→\n   644→    it('should reject invalid progress values', () => {\n   645→      queue.add('task');\n   646→      const task = queue.next()!;\n   647→      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n   648→      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n   649→    });\n   650→\n   651→    it('should not cancel completed tasks', () => {\n   652→      queue.add('task');\n   653→      const task = queue.next()!;\n   654→      queue.complete(task.id);\n   655→      expect(() => queue.cancel(task.id)).toThrow();\n   656→    });\n   657→  });\n   658→\n   659→  // ─── Phase 10: Recurring Tasks ──────────────────────────────────\n   660→\n   661→  describe('Phase 10: Recurring Tasks', () => {\n   662→    it('should create a schedule', () => {\n   663→      const schedule = queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n   664→      expect(schedule.id).toBeDefined();\n   665→      expect(schedule.cronExpression).toBe('*/5 * * * *');\n   666→    });\n   667→\n   668→    it('should list schedules', () => {\n   669→      queue.addSchedule('*/5 * * * *', 'task1');\n   670→      queue.addSchedule('0 * * * *', 'task2');\n   671→      expect(queue.getSchedules()).toHaveLength(2);\n   672→    });\n   673→\n   674→    it('should remove a schedule', () => {\n   675→      const s = queue.addSchedule('*/5 * * * *', 'task');\n   676→      queue.removeSchedule(s.id);\n   677→      expect(queue.getSchedules()).toHaveLength(0);\n   678→    });\n   679→\n   680→    it('should enqueue tasks on tick for every-N-minutes schedule', () => {\n   681→      queue.addSchedule('*/5 * * * *', 'periodic-task');\n   682→\n   683→      // Simulate a time that's a multiple of 5 minutes\n   684→      const time = new Date('2024-01-01T12:05:00Z');\n   685→      const tasks = queue.tick(time);\n   686→      expect(tasks).toHaveLength(1);\n   687→      expect(tasks[0].payload).toBe('periodic-task');\n   688→    });\n   689→\n   690→    it('should not double-enqueue on same tick', () => {\n   691→      queue.addSchedule('*/5 * * * *', 'task');\n   692→      const time = new Date('2024-01-01T12:05:00Z');\n   693→\n   694→      queue.tick(time);\n   695→      const tasks2 = queue.tick(time);\n   696→      expect(tasks2).toHaveLength(0);\n   697→    });\n   698→\n   699→    it('should handle hourly schedule', () => {\n   700→      queue.addSchedule('0 * * * *', 'hourly-task');\n   701→      const onHour = new Date('2024-01-01T13:00:00Z');\n   702→      const notOnHour = new Date('2024-01-01T13:30:00Z');\n   703→\n   704→      expect(queue.tick(onHour)).toHaveLength(1);\n   705→      expect(queue.tick(notOnHour)).toHaveLength(0);\n   706→    });\n   707→\n   708→    it('should handle daily schedule', () => {\n   709→      queue.addSchedule('0 0 * * *', 'daily-task');\n   710→      const midnight = new Date('2024-01-02T00:00:00Z');\n   711→      const noon = new Date('2024-01-02T12:00:00Z');\n   712→\n   713→      expect(queue.tick(midnight)).toHaveLength(1);\n   714→      expect(queue.tick(noon)).toHaveLength(0);\n   715→    });\n   716→\n   717→    it('should stop creating tasks after schedule removal', () => {\n   718→      const s = queue.addSchedule('*/5 * * * *', 'task');\n   719→      const t1 = new Date('2024-01-01T12:05:00Z');\n   720→      queue.tick(t1);\n   721→\n   722→      queue.removeSchedule(s.id);\n   723→      const t2 = new Date('2024-01-01T12:10:00Z');\n   724→      expect(queue.tick(t2)).toHaveLength(0);\n   725→    });\n   726→\n   727→    it('should reject invalid cron expressions', () => {\n   728→      expect(() => queue.addSchedule('invalid', 'task')).toThrow();\n   729→    });\n   730→\n   731→    it('should throw when removing non-existent schedule', () => {\n   732→      expect(() =