+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FJP1EkU28qwMcDWDMwYq7Y","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BY7YThaUfetvhAoNiwbiAk","name":"Write","input":{"file_path":"/workspace/tests/task-queue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ─── Phase 1: Basic FIFO Queue ───────────────────────────────────\n\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = queue.add({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const t1 = queue.next();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = queue.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return null after all tasks are consumed', () => {\n      queue.add('only');\n      queue.next();\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should transition task to processing on next()', () => {\n      queue.add('task');\n      const task = queue.next();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should track queue size', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n  });\n\n  // ─── Phase 2: Named Queues ──────────────────────────────────────\n\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name specified', () => {\n      queue.add('task');\n      expect(queue.getQueues()).toContain('default');\n    });\n\n    it('should support named queues', () => {\n      queue.add('email-task', { queue: 'emails' });\n      queue.add('report-task', { queue: 'reports' });\n\n      expect(queue.getQueues()).toContain('emails');\n      expect(queue.getQueues()).toContain('reports');\n    });\n\n    it('should keep named queues independent', () => {\n      queue.add('email-1', { queue: 'emails' });\n      queue.add('report-1', { queue: 'reports' });\n\n      const emailTask = queue.next('emails');\n      expect(emailTask?.payload).toBe('email-1');\n      expect(queue.size('emails')).toBe(0);\n      expect(queue.size('reports')).toBe(1);\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should return null for empty queue', () => {\n      queue.add('task', { queue: 'myqueue' });\n      queue.next('myqueue');\n      expect(queue.next('myqueue')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queue: 'q1' });\n      queue.add('b', { queue: 'q2' });\n      queue.add('c', { queue: 'q3' });\n      const names = queue.getQueues();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n      expect(names).toContain('q3');\n      expect(names).toHaveLength(3);\n    });\n\n    it('should be backward compatible (default queue)', () => {\n      queue.add('task');\n      const task = queue.next();\n      expect(task?.payload).toBe('task');\n    });\n  });\n\n  // ─── Phase 3: Priority ─────────────────────────────────────────\n\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = queue.add('task');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 3 });\n      queue.add('second', { priority: 3 });\n      queue.add('third', { priority: 3 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority (too low)', () => {\n      expect(() => queue.add('task', { priority: 0 })).toThrow();\n    });\n\n    it('should reject invalid priority (too high)', () => {\n      expect(() => queue.add('task', { priority: 11 })).toThrow();\n    });\n\n    it('should reject non-integer priority', () => {\n      expect(() => queue.add('task', { priority: 2.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.add('task', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n\n    it('should handle priority per queue', () => {\n      queue.add('q1-low', { queue: 'q1', priority: 10 });\n      queue.add('q1-high', { queue: 'q1', priority: 1 });\n      queue.add('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.next('q1')?.payload).toBe('q1-high');\n      expect(queue.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ─── Phase 4: Delayed Tasks ─────────────────────────────────────\n\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should accept a delay in milliseconds', () => {\n      const task = queue.add('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should not return delayed tasks before their time', () => {\n      queue.add('delayed', { delay: 60000 });\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return non-delayed tasks before delayed ones', () => {\n      queue.add('delayed', { delay: 60000 });\n      queue.add('immediate');\n\n      const task = queue.next();\n      expect(task?.payload).toBe('immediate');\n    });\n\n    it('should accept processAt date', () => {\n      const futureDate = new Date(Date.now() + 60000);\n      const task = queue.add('scheduled', { processAt: futureDate });\n      expect(task.availableAt).toEqual(futureDate);\n    });\n\n    it('should return delayed tasks that are now available', () => {\n      // Use a delay of 0 or past time\n      const pastDate = new Date(Date.now() - 1000);\n      queue.add('available', { processAt: pastDate });\n\n      const task = queue.next();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should order delayed tasks by availability then priority then FIFO', () => {\n      const past1 = new Date(Date.now() - 2000);\n      const past2 = new Date(Date.now() - 1000);\n\n      queue.add('later', { processAt: past2, priority: 1 });\n      queue.add('earlier', { processAt: past1, priority: 5 });\n\n      // Earlier availability time comes first\n      expect(queue.next()?.payload).toBe('earlier');\n      expect(queue.next()?.payload).toBe('later');\n    });\n\n    it('should work with named queues', () => {\n      queue.add('delayed-email', { queue: 'emails', delay: 60000 });\n      queue.add('immediate-email', { queue: 'emails' });\n\n      expect(queue.next('emails')?.payload).toBe('immediate-email');\n      expect(queue.next('emails')).toBeNull();\n    });\n  });\n\n  // ─── Phase 5: Retry with Backoff ────────────────────────────────\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should fail a processing task and retry', () => {\n      queue.add('task', { maxRetries: 3, backoffDelay: 100 });\n      const task = queue.next()!;\n      expect(task.attempts).toBe(1);\n\n      queue.fail(task.id, 'error');\n\n      // Task should be pending again with a delay\n      const updated = queue.getTask(task.id)!;\n      expect(updated.status).toBe('pending');\n      expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should use exponential backoff', () => {\n      const t = queue.add('task', { maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt\n      queue.next();\n      const beforeFail1 = Date.now();\n      queue.fail(t.id, 'err');\n      const task1 = queue.getTask(t.id)!;\n      // First retry delay: 1000 * 2^0 = 1000ms\n      expect(task1.availableAt.getTime() - beforeFail1).toBeGreaterThanOrEqual(900);\n      expect(task1.availableAt.getTime() - beforeFail1).toBeLessThan(2000);\n    });\n\n    it('should track attempt count', () => {\n      const t = queue.add('task', { maxRetries: 3, backoffDelay: 0 });\n\n      queue.next();\n      expect(queue.getTask(t.id)!.attempts).toBe(1);\n\n      queue.fail(t.id, 'err');\n      // Manually set available so we can get it again\n      queue.getTask(t.id)!.availableAt = new Date(0);\n\n      queue.next();\n      expect(queue.getTask(t.id)!.attempts).toBe(2);\n    });\n\n    it('should mark as failed after exhausting retries', () => {\n      const t = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n\n      // First and only attempt\n      queue.next();\n      queue.fail(t.id, 'final error');\n\n      expect(queue.getTask(t.id)!.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const t = queue.add('task', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n\n      queue.next('myq');\n      queue.fail(t.id, 'err');\n\n      const updated = queue.getTask(t.id)!;\n      expect(updated.queue).toBe('myq');\n      expect(updated.priority).toBe(2);\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const t = queue.add('task');\n      expect(() => queue.complete(t.id)).toThrow();\n    });\n\n    it('should throw when failing non-processing task', () => {\n      const t = queue.add('task');\n      expect(() => queue.fail(t.id)).toThrow();\n    });\n\n    it('should set default maxRetries to 3', () => {\n      const t = queue.add('task');\n      expect(t.maxRetries).toBe(3);\n    });\n\n    it('should set default backoffDelay to 1000', () => {\n      const t = queue.add('task');\n      expect(t.backoffDelay).toBe(1000);\n    });\n  });\n\n  // ─── Phase 6: Dead Letter Queue ─────────────────────────────────\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ after exhausting retries', () => {\n      const t = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n\n      queue.next();\n      queue.fail(t.id, 'permanent failure');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(t.id);\n      expect(dlq[0].lastError).toBe('permanent failure');\n    });\n\n    it('should retain error info on dead-lettered tasks', () => {\n      const t = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n      queue.next();\n      queue.fail(t.id, 'some error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].lastError).toBe('some error');\n      expect(dlq[0].failureCount).toBe(1);\n    });\n\n    it('should requeue a dead-lettered task', () => {\n      const t = queue.add('task', { maxRetries: 1, backoffDelay: 0 });\n      queue.next();\n      queue.fail(t.id, 'err');\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(1);\n\n      const requeued = queue.requeue(t.id);\n      expect(requeued).toBeDefined();\n      expect(requeued!.status).toBe('pending');\n      expect(requeued!.attempts).toBe(0);\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      const t1 = queue.add('task1', { maxRetries: 1, backoffDelay: 0 });\n      const t2 = queue.add('task2', { maxRetries: 1, backoffDelay: 0 });\n\n      queue.next(); queue.fail(t1.id, 'err');\n      queue.next(); queue.fail(t2.id, 'err');\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should have independent DLQ per named queue', () => {\n      const t1 = queue.add('task1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      const t2 = queue.add('task2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n      queue.next('q1'); queue.fail(t1.id, 'err');\n      queue.next('q2'); queue.fail(t2.id, 'err');\n\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n\n      queue.clearDeadLetterQueue('q1');\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(0);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n\n    it('should throw when requeuing non-DLQ task', () => {\n      expect(() => queue.requeue('nonexistent')).toThrow();\n    });\n  });\n\n  // ─── Phase 7: Task Dependencies ─────────────────────────────────\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = queue.add('dependency');\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      // Dependent should not be returned\n      const task = queue.next();\n      expect(task?.payload).toBe('dependency');\n\n      // After taking dep, dependent is still blocked\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should unblock task when dependency completes', () => {\n      const dep = queue.add('dependency');\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      const depTask = queue.next()!;\n      queue.complete(depTask.id);\n\n      const dependentTask = queue.next();\n      expect(dependentTask?.payload).toBe('dependent');\n    });\n\n    it('should reject circular dependencies', () => {\n      const a = queue.add('A');\n      const b = queue.add('B', { dependencies: [a.id] });\n      expect(() =>\n        queue.add('C', { dependencies: [b.id] })\n      ).not.toThrow();\n\n      // This would create a cycle only if A depended on C, but A has no deps\n      // So let's test actual cycle detection:\n      // We can't create a cycle with creation-time deps easily since tasks are new\n      // But let's test the non-existent dependency error\n    });\n\n    it('should reject dependency on non-existent task', () => {\n      expect(() => queue.add('task', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = queue.add('dependency', { maxRetries: 1, backoffDelay: 0 });\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      const depTask = queue.next()!;\n      queue.fail(depTask.id, 'err');\n\n      // Dependent should still be blocked\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const a = queue.add('A');\n      const b = queue.add('B');\n      const c = queue.add('C', { dependencies: [a.id, b.id] });\n\n      const status = queue.getDependencyStatus(c.id);\n      expect(status.taskId).toBe(c.id);\n      expect(status.pending).toContain(a.id);\n      expect(status.pending).toContain(b.id);\n      expect(status.resolved).toHaveLength(0);\n      expect(status.blocked).toBe(true);\n\n      // Complete one dependency\n      const taskA = queue.next()!;\n      queue.complete(taskA.id);\n\n      const status2 = queue.getDependencyStatus(c.id);\n      expect(status2.resolved).toContain(a.id);\n      expect(status2.pending).toContain(b.id);\n      expect(status2.blocked).toBe(true);\n    });\n\n    it('should handle multiple dependencies all resolved', () => {\n      const a = queue.add('A');\n      const b = queue.add('B');\n      const c = queue.add('C', { dependencies: [a.id, b.id] });\n\n      // Complete both\n      const taskA = queue.next()!;\n      queue.complete(taskA.id);\n      const taskB = queue.next()!;\n      queue.complete(taskB.id);\n\n      const taskC = queue.next();\n      expect(taskC?.id).toBe(c.id);\n    });\n  });\n\n  // ─── Phase 8: Concurrency Control ──────────────────────────────\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('task1');\n      queue.add('task2');\n      queue.add('task3');\n\n      const t1 = queue.next();\n      const t2 = queue.next();\n      const t3 = queue.next();\n\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n      expect(t3).toBeNull(); // Limit reached\n    });\n\n    it('should free slot on completion', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('task1');\n      queue.add('task2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull(); // Limit reached\n\n      queue.complete(t1.id);\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('task2');\n    });\n\n    it('should free slot on failure', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('task1', { maxRetries: 1, backoffDelay: 0 });\n      queue.add('task2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.fail(t1.id, 'err'); // Task exhausts retries -> failed\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('task2');\n    });\n\n    it('should default to unlimited concurrency', () => {\n      expect(queue.getConcurrency()).toBeUndefined();\n    });\n\n    it('should query active count', () => {\n      queue.add('task1');\n      queue.add('task2');\n\n      expect(queue.getActiveCount()).toBe(0);\n      queue.next();\n      expect(queue.getActiveCount()).toBe(1);\n      queue.next();\n      expect(queue.getActiveCount()).toBe(2);\n    });\n\n    it('should respect priority within concurrency limit', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const task = queue.next();\n      expect(task?.payload).toBe('high');\n    });\n  });\n\n  // ─── Phase 9: Progress Tracking and Cancellation ────────────────\n\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should report and query progress', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      queue.reportProgress(task.id, 50, 'halfway there');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway there');\n    });\n\n    it('should notify progress listeners', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      queue.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      queue.reportProgress(task.id, 25, 'quarter');\n      queue.reportProgress(task.id, 75, 'three quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n    });\n\n    it('should support unsubscribe from progress', () => {\n      queue.add('task');\n      const task = queue.next()!;\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(task.id, (p) => updates.push(p));\n\n      queue.reportProgress(task.id, 25);\n      unsub();\n      queue.reportProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n      expect(updates[0]).toBe(25);\n    });\n\n    it('should cancel a pending task', () => {\n      const t = queue.add('task');\n      queue.cancel(t.id);\n\n      expect(queue.getTask(t.id)?.status).toBe('cancelled');\n      expect(queue.next()).toBeNull();\n      expect(queue.size()).toBe(0);\n    });\n\n    it('should cancel a processing task', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const t = queue.add('task', { maxRetries: 3 });\n      queue.next();\n      queue.cancel(t.id);\n\n      // Task should remain cancelled, not retried\n      expect(queue.getTask(t.id)?.status).toBe('cancelled');\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should not cancel completed tasks', () => {\n      queue.add('task');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ─── Phase 10: Recurring Tasks ──────────────────────────────────\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n      expect(schedule.id