ffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      progress: 0,\n      failureCount: 0,\n      dependencies,\n    };\n\n    // Detect circular dependencies\n    if (dependencies.length > 0) {\n      this.detectCircularDeps(task.id, dependencies);\n    }\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.add(task.id);\n\n    return task;\n  }\n\n  next(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(name);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = new Date();\n    let bestTask: Task | null = null;\n    let bestScore: { priority: number; availableAt: number; createdAt: number } | null = null;\n\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status !== 'pending') continue;\n\n      // Check availability time\n      if (task.availableAt > now) continue;\n\n      // Check dependencies\n      if (this.hasUnresolvedDependencies(task)) continue;\n\n      const score = {\n        priority: task.priority,\n        availableAt: task.availableAt.getTime(),\n        createdAt: task.createdAt.getTime(),\n      };\n\n      if (!bestScore || this.compareTasks(score, bestScore) < 0) {\n        bestTask = task;\n        bestScore = score;\n      }\n    }\n\n    if (bestTask) {\n      bestTask.status = 'processing';\n      bestTask.attempts += 1;\n    }\n\n    return bestTask;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return 0;\n\n    let count = 0;\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // ─── Phase 2: Named Queues ──────────────────────────────────────\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Phase 5: Retry with Backoff ────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks are now unblocked (phase 7)\n    // No action needed -- unblocking is checked at retrieval time\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.lastError = error;\n    task.failureCount += 1;\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n    } else {\n      // No retries left\n      task.status = 'failed';\n      // Move to dead letter queue\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // ─── Phase 6: Dead Letter Queue ─────────────────────────────────\n\n  getDeadLetterTasks(queueName?: string): DeadLetteredTask[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return [...(this.deadLetterQueues.get(name) ?? [])];\n  }\n\n  requeue(taskId: string): Task | null {\n    // Find and remove from DLQ\n    for (const [queueName, dlqTasks] of this.deadLetterQueues) {\n      const idx = dlqTasks.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n        dlqTasks.splice(idx, 1);\n\n        // Reset the task for fresh retries\n        const task = this.tasks.get(taskId)!;\n        task.status = 'pending';\n        task.attempts = 0;\n        task.progress = 0;\n        task.failureCount = 0;\n        task.lastError = undefined;\n        task.availableAt = new Date();\n\n        // Re-add to original queue\n        this.ensureQueue(queueName);\n        this.queues.get(queueName)!.add(taskId);\n\n        return task;\n      }\n    }\n    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlqTasks = this.deadLetterQueues.get(name);\n    if (dlqTasks) {\n      for (const task of dlqTasks) {\n        this.tasks.delete(task.id);\n      }\n      dlqTasks.length = 0;\n    }\n  }\n\n  // ─── Phase 7: Task Dependencies ─────────────────────────────────\n\n  getDependencyStatus(taskId: string): DependencyStatus {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved: string[] = [];\n    const pending: string[] = [];\n\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        resolved.push(depId);\n      } else {\n        pending.push(depId);\n      }\n    }\n\n    return {\n      taskId,\n      resolved,\n      pending,\n      blocked: pending.length > 0,\n    };\n  }\n\n  // ─── Phase 8: Concurrency Control ──────────────────────────────\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName?: string): number | undefined {\n    return this.concurrencyLimits.get(queueName ?? DEFAULT_QUEUE);\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return 0;\n\n    let count = 0;\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // ─── Phase 9: Progress Tracking and Cancellation ────────────────\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progre