+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XpZfBt2tsAa6AiJezU9PYN","type":"tool_result","content":"     1→# Phase 12: Graceful Shutdown\n     2→\n     3→Add the ability to shut down the task queue system in an orderly fashion.\n     4→\n     5→## Requirements\n     6→\n     7→- A shutdown operation should signal the system to stop accepting new tasks.\n     8→- After shutdown is initiated, attempting to add new tasks should produce an error.\n     9→- The shutdown should wait for all currently-processing tasks to finish, up to a configurable timeout.\n    10→- If processing tasks do not complete within the timeout, they should be force-cancelled.\n    11→- Callbacks can be registered to run during the shutdown process.\n    12→- The shutdown should produce a summary indicating how many tasks completed, how many were force-cancelled, and how long the shutdown took.\n    13→- Calling shutdown multiple times should be safe and return the same result.\n    14→- If no tasks are processing, shutdown should complete immediately.\n    15→"}]},"parent_tool_use_id":"toolu_01TEaLEUZ6Ly2a5bS8TxJwtK","session_id":"2107b12e-f12a-4d0c-bc47-bb3ab39302b3","uuid":"f8cd0b1a-8c6d-4bc0-9447-8dabf6e18bea"}
+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01HzBEFWBc61VDxnnnn7QDNz","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0139LqZh1oyc95PmEbez2LKY","name":"Read","input":{"file_path":"/workspace/src/TaskQueue.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4529,"cache_read_input_tokens":13724,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4529},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01TEaLEUZ6Ly2a5bS8TxJwtK","session_id":"2107b12e-f12a-4d0c-bc47-bb3ab39302b3","uuid":"9ab84f4d-0dd5-4c34-ac15-4c24c19f0c06"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0139LqZh1oyc95PmEbez2LKY","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import type {\n     3→  Task,\n     4→  TaskOptions,\n     5→  DeadLetteredTask,\n     6→  Schedule,\n     7→  MiddlewareFn,\n     8→  HandlerFn,\n     9→  ProgressListener,\n    10→  ShutdownOptions,\n    11→  ShutdownSummary,\n    12→  DependencyStatus,\n    13→} from './types.js';\n    14→\n    15→const DEFAULT_QUEUE = 'default';\n    16→const DEFAULT_PRIORITY = 5;\n    17→const DEFAULT_MAX_RETRIES = 3;\n    18→const DEFAULT_BACKOFF_DELAY = 1000;\n    19→\n    20→export class TaskQueue {\n    21→  // Monotonic sequence counter for FIFO ordering\n    22→  private seqCounter = 0;\n    23→\n    24→  // Task storage: taskId -> Task\n    25→  private tasks = new Map<string, Task>();\n    26→\n    27→  // Per-queue task lists: queueName -> Set<taskId>\n    28→  private queues = new Map<string, Set<string>>();\n    29→\n    30→  // Dead letter queues: queueName -> taskId[]\n    31→  private deadLetterQueues = new Map<string, DeadLetteredTask[]>();\n    32→\n    33→  // Concurrency limits: queueName -> maxConcurrency\n    34→  private concurrencyLimits = new Map<string, number>();\n    35→\n    36→  // Progress listeners: taskId -> Set<ProgressListener>\n    37→  private progressListeners = new Map<string, Set<ProgressListener>>();\n    38→\n    39→  // Schedules: scheduleId -> Schedule\n    40→  private schedules = new Map<string, Schedule>();\n    41→\n    42→  // Middleware stacks: queueName -> MiddlewareFn[]\n    43→  private middlewareStacks = new Map<string, MiddlewareFn[]>();\n    44→\n    45→  // Handlers: queueName -> HandlerFn\n    46→  private handlers = new Map<string, HandlerFn>();\n    47→\n    48→  // Shutdown state\n    49→  private isShuttingDown = false;\n    50→  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n    51→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    52→\n    53→  // ─── Phase 1: Basic FIFO Queue ───────────────────────────────────\n    54→\n    55→  add<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    56→    if (this.isShuttingDown) {\n    57→      throw new Error('Cannot add tasks: system is shutting down');\n    58→    }\n    59→\n    60→    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    61→    const priority = options?.priority ?? DEFAULT_PRIORITY;\n    62→\n    63→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    64→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    65→    }\n    66→\n    67→    // Calculate availability time\n    68→    const now = new Date();\n    69→    let availableAt = new Date(0); // Non-delayed tasks are immediately available (epoch 0 for stable sorting)\n    70→    if (options?.processAt) {\n    71→      availableAt = options.processAt;\n    72→    } else if (options?.delay != null && options.delay > 0) {\n    73→      availableAt = new Date(now.getTime() + options.delay);\n    74→    }\n    75→\n    76→    // Validate dependencies\n    77→    const dependencies = options?.dependencies ?? [];\n    78→    if (dependencies.length > 0) {\n    79→      for (const depId of dependencies) {\n    80→        if (!this.tasks.has(depId)) {\n    81→          throw new Error(`Dependency task not found: ${depId}`);\n    82→        }\n    83→      }\n    84→    }\n    85→\n    86→    const task: Task<T> = {\n    87→      id: randomUUID(),\n    88→      payload,\n    89→      status: 'pending',\n    90→      queue: queueName,\n    91→      priority,\n    92→      createdAt: now,\n    93→      availableAt,\n    94→      seq: this.seqCounter++,\n    95→      attempts: 0,\n    96→      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n    97→      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n    98→      progress: 0,\n    99→      failureCount: 0,\n   100→      dependencies,\n   101→    };\n   102→\n   103→    // Detect circular dependencies\n   104→    if (dependencies.length > 0) {\n   105→      this.detectCircularDeps(task.id, dependencies);\n   106→    }\n   107→\n   108→    this.tasks.set(task.id, task as Task);\n   109→    this.ensureQueue(queueName);\n   110→    this.queues.get(queueName)!.add(task.id);\n   111→\n   112→    return task;\n   113→  }\n   114→\n   115→  next(queueName?: string): Task | null {\n   116→    const name = queueName ?? DEFAULT_QUEUE;\n   117→    const queueTaskIds = this.queues.get(name);\n   118→    if (!queueTaskIds) return null;\n   119→\n   120→    // Check concurrency limit\n   121→    const limit = this.concurrencyLimits.get(name);\n   122→    if (limit !== undefined) {\n   123→      const activeCount = this.getActiveCount(name);\n   124→      if (activeCount >= limit) return null;\n   125→    }\n   126→\n   127→    const now = new Date();\n   128→    let bestTask: Task | null = null;\n   129→    let bestScore: { priority: number; availableAt: number; seq: number } | null = null;\n   130→\n   131→    for (const taskId of queueTaskIds) {\n   132→      const task = this.tasks.get(taskId)!;\n   133→      if (task.status !== 'pending') continue;\n   134→\n   135→      // Check availability time\n   136→      if (task.availableAt > now) continue;\n   137→\n   138→      // Check dependencies\n   139→      if (this.hasUnresolvedDependencies(task)) continue;\n   140→\n   141→      const score = {\n   142→        priority: task.priority,\n   143→        availableAt: task.availableAt.getTime(),\n   144→        seq: task.seq,\n   145→      };\n   146→\n   147→      if (!bestScore || this.compareTasks(score, bestScore) < 0) {\n   148→        bestTask = task;\n   149→        bestScore = score;\n   150→      }\n   151→    }\n   152→\n   153→    if (bestTask) {\n   154→      bestTask.status = 'processing';\n   155→      bestTask.attempts += 1;\n   156→    }\n   157→\n   158→    return bestTask;\n   159→  }\n   160→\n   161→  size(queueName?: string): number {\n   162→    const name = queueName ?? DEFAULT_QUEUE;\n   163→    const queueTaskIds = this.queues.get(name);\n   164→    if (!queueTaskIds) return 0;\n   165→\n   166→    let count = 0;\n   167→    for (const taskId of queueTaskIds) {\n   168→      const task = this.tasks.get(taskId)!;\n   169→      if (task.status === 'pending') count++;\n   170→    }\n   171→    return count;\n   172→  }\n   173→\n   174→  // ─── Phase 2: Named Queues ──────────────────────────────────────\n   175→\n   176→  getQueues(): string[] {\n   177→    return Array.from(this.queues.keys());\n   178→  }\n   179→\n   180→  // ─── Phase 5: Retry with Backoff ────────────────────────────────\n   181→\n   182→  complete(taskId: string): void {\n   183→    const task = this.tasks.get(taskId);\n   184→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   185→    if (task.status !== 'processing') {\n   186→      throw new Error(`Cannot complete task in status: ${task.status}`);\n   187→    }\n   188→\n   189→    task.status = 'completed';\n   190→    task.progress = 100;\n   191→\n   192→    // Check if any blocked tasks are now unblocked (phase 7)\n   193→    // No action needed -- unblocking is checked at retrieval time\n   194→  }\n   195→\n   196→  fail(taskId: string, error?: string): void {\n   197→    const task = this.tasks.get(taskId);\n   198→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   199→    if (task.status !== 'processing') {\n   200→      throw new Error(`Cannot fail task in status: ${task.status}`);\n   201→    }\n   202→\n   203→    task.lastError = error;\n   204→    task.failureCount += 1;\n   205→\n   206→    if (task.attempts < task.maxRetries) {\n   207→      // Retry with exponential backoff\n   208→      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n   209→      task.availableAt = new Date(Date.now() + delay);\n   210→      task.status = 'pending';\n   211→      task.progress = 0;\n   212→    } else {\n   213→      // No retries left\n   214→      task.status = 'failed';\n   215→      // Move to dead letter queue\n   216→      this.moveToDeadLetterQueue(task);\n   217→    }\n   218→  }\n   219→\n   220→  // ─── Phase 6: Dead Letter Queue ─────────────────────────────────\n   221→\n   222→  getDeadLetterTasks(queueName?: string): DeadLetteredTask[] {\n   223→    const name = queueName ?? DEFAULT_QUEUE;\n   224→    return [...(this.deadLetterQueues.get(name) ?? [])];\n   225→  }\n   226→\n   227→  requeue(taskId: string): Task | null {\n   228→    // Find and remove from DLQ\n   229→    for (const [queueName, dlqTasks] of this.deadLetterQueues) {\n   230→      const idx = dlqTasks.findIndex(t => t.id === taskId);\n   231→      if (idx !== -1) {\n   232→        dlqTasks.splice(idx, 1);\n   233→\n   234→        // Reset the task for fresh retries\n   235→        const task = this.tasks.get(taskId)!;\n   236→        task.status = 'pending';\n   237→        task.attempts = 0;\n   238→        task.progress = 0;\n   239→        task.failureCount = 0;\n   240→        task.lastError = undefined;\n   241→        task.availableAt = new Date();\n   242→\n   243→        // Re-add to original queue\n   244→        this.ensureQueue(queueName);\n   245→        this.queues.get(queueName)!.add(taskId);\n   246→\n   247→        return task;\n   248→      }\n   249→    }\n   250→    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n   251→  }\n   252→\n   253→  clearDeadLetterQueue(queueName?: string): void {\n   254→    const name = queueName ?? DEFAULT_QUEUE;\n   255→    const dlqTasks = this.deadLetterQueues.get(name);\n   256→    if (dlqTasks) {\n   257→      for (const task of dlqTasks) {\n   258→        this.tasks.delete(task.id);\n   259→      }\n   260→      dlqTasks.length = 0;\n   261→    }\n   262→  }\n   263→\n   264→  // ─── Phase 7: Task Dependencies ─────────────────────────────────\n   265→\n   266→  getDependencyStatus(taskId: string): DependencyStatus {\n   267→    const task = this.tasks.get(taskId);\n   268→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   269→\n   270→    const resolved: string[] = [];\n   271→    const pending: string[] = [];\n   272→\n   273→    for (const depId of task.dependencies) {\n   274→      const dep = this.tasks.get(depId);\n   275→      if (dep && dep.status === 'completed') {\n   276→        resolved.push(depId);\n   277→      } else {\n   278→        pending.push(depId);\n   279→      }\n   280→    }\n   281→\n   282→    return {\n   283→      taskId,\n   284→      resolved,\n   285→      pending,\n   286→      blocked: pending.length > 0,\n   287→    };\n   288→  }\n   289→\n   290→  // ─── Phase 8: Concurrency Control ──────────────────────────────\n   291→\n   292→  setConcurrency(queueName: string, limit: number): void {\n   293→    if (limit < 1 || !Number.isInteger(limit)) {\n   294→      throw new Error(`Invalid concurrency limit: ${limit}`);\n   295→    }\n   296→    this.concurrencyLimits.set(queueName, limit);\n   297→  }\n   298→\n   299→  getConcurrency(queueName?: string): number | undefined {\n   300→    return this.concurrencyLimits.get(queueName ?? DEFAULT_QUEUE);\n   301→  }\n   302→\n   303→  getActiveCount(queueName?: string): number {\n   304→    const name = queueName ?? DEFAULT_QUEUE;\n   305→    const queueTaskIds = this.queues.get(name);\n   306→    if (!queueTaskIds) return 0;\n   307→\n   308→    let count = 0;\n   309→    for (const taskId of queueTaskIds) {\n   310→      const task = this.tasks.get(taskId)!;\n   311→      if (task.status === 'processing') count++;\n   312→    }\n   313→    return count;\n   314→  }\n   315→\n   316→  // ─── Phase 9: Progress Tracking and Cancellation ────────────────\n   317→\n   318→  reportProgress(taskId: string, progress: number, message?: string): void {\n   319→    const task = this.tasks.get(taskId);\n   320→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   321→    if (task.status !== 'processing') {\n   322→      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n   323→    }\n   324→    if (progress < 0 || progress > 100) {\n   325→      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n   326→    }\n   327→\n   328→    task.progress = progress;\n   329→    task.progressMessage = message;\n   330→\n   331→    // Notify listeners\n   332→    const listeners = this.progressListeners.get(taskId);\n   333→    if (listeners) {\n   334→      for (const listener of listeners) {\n   335→        listener(progress, message);\n   336→      }\n   337→    }\n   338→  }\n   339→\n   340→  getProgress(taskId: string): { progress: number; message?: string } {\n   341→    const task = this.tasks.get(taskId);\n   342→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   343→    return { progress: task.progress, message: task.progressMessage };\n   344→  }\n   345→\n   346→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   347→    const task = this.tasks.get(taskId);\n   348→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   349→\n   350→    if (!this.progressListeners.has(taskId)) {\n   351→      this.progressListeners.set(taskId, new Set());\n   352→    }\n   353→    this.progressListeners.get(taskId)!.add(listener);\n   354→\n   355→    // Return unsubscribe function\n   356→    return () => {\n   357→      const listeners = this.progressListeners.get(taskId);\n   358→      if (listeners) {\n   359→        listeners.delete(listener);\n   360→        if (listeners.size === 0) {\n   361→          this.progressListeners.delete(taskId);\n   362→        }\n   363→      }\n   364→    };\n   365→  }\n   366→\n   367→  cancel(taskId: string): void {\n   368→    const task = this.tasks.get(taskId);\n   369→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   370→\n   371→    if (task.status !== 'pending' && task.status !== 'processing') {\n   372→      throw new Error(`Cannot cancel task in status: ${task.status}`);\n   373→    }\n   374→\n   375→    task.status = 'cancelled';\n   376→\n   377→    // Remove from queue if pending\n   378→    const queueTaskIds = this.queues.get(task.queue);\n   379→    if (queueTaskIds) {\n   380→      queueTaskIds.delete(taskId);\n   381→    }\n   382→  }\n   383→\n   384→  // ─── Phase 10: Recurring Tasks ──────────────────────────────────\n   385→\n   386→  addSchedule(\n   387→    cronExpression: string,\n   388→    payload: unknown,\n   389→    options?: { queue?: string; priority?: number; maxRetries?: number; backoffDelay?: number }\n   390→  ): Schedule {\n   391→    this.validateCron(cronExpression);\n   392→\n   393→    const schedule: Schedule = {\n   394→      id: randomUUID(),\n   395→      cronExpression,\n   396→      queue: options?.queue ?? DEFAULT_QUEUE,\n   397→      payload,\n   398→      taskOptions: options ? { priority: options.priority, maxRetries: options.maxRetries, backoffDelay: options.backoffDelay } : undefined,\n   399→      createdAt: new Date(),\n   400→    };\n   401→\n   402→    this.schedules.set(schedule.id, schedule);\n   403→    return schedule;\n   404→  }\n   405→\n   406→  removeSchedule(scheduleId: string): void {\n   407→    if (!this.schedules.has(scheduleId)) {\n   408→      throw new Error(`Schedule not found: ${scheduleId}`);\n   409→    }\n   410→    this.schedules.delete(scheduleId);\n   411→  }\n   412→\n   413→  getSchedules(): Schedule[] {\n   414→    return Array.from(this.schedules.values());\n   415→  }\n   416→\n   417→  tick(now?: Date): Task[] {\n   418→    const currentTime = now ?? new Date();\n   419→    const createdTasks: Task[] = [];\n   420→\n   421→    for (const schedule of this.schedules.values()) {\n   422→      if (this.shouldRunSchedule(schedule, currentTime)) {\n   423→        const task = this.add(schedule.payload, {\n   424→          queue: schedule.queue,\n   425→          ...schedule.taskOptions,\n   426→        });\n   427→        createdTasks.push(task as Task);\n   428→        schedule.lastRun = currentTime;\n   429→      }\n   430→    }\n   431→\n   432→    return createdTasks;\n   433→  }\n   434→\n   435→  // ─── Phase 11: Middleware Pipeline ──────────────────────────────\n   436→\n   437→  use(queueName: string, middleware: MiddlewareFn): void {\n   438→    if (!this.middlewareStacks.has(queueName)) {\n   439→      this.middlewareStacks.set(queueName, []);\n   440→    }\n   441→    this.middlewareStacks.get(queueName)!.push(middleware);\n   442→  }\n   443→\n   444→  setHandler(queueName: string, handler: HandlerFn): void {\n   445→    this.handlers.set(queueName, handler);\n   446→  }\n   447→\n   448→  async process(queueName?: string): Promise<Task | null> {\n   449→    const name = queueName ?? DEFAULT_QUEUE;\n   450→    const task = this.next(name);\n   451→    if (!task) return null;\n   452→\n   453→    const middlewares = this.middlewareStacks.get(name) ?? [];\n   454→    const handler = this.handlers.get(name);\n   455→\n   456→    try {\n   457→      await this.executeMiddlewarePipeline(task, middlewares, handler);\n   458→    } catch (err) {\n   459→      const errorMsg = err instanceof Error ? err.message : String(err);\n   460→      // Only fail if still processing (middleware may have changed status)\n   461→      if (task.status === 'processing') {\n   462→        this.fail(task.id, errorMsg);\n   463→      }\n   464→    }\n   465→\n   466→    return task;\n   467→  }\n   468→\n   469→  // ─── Phase 12: Graceful Shutdown ────────────────────────────────\n   470→\n   471→  onShutdown(callback: () => void | Promise<void>): void {\n   472→    this.shutdownCallbacks.push(callback);\n   473→  }\n   474→\n   475→  async shutdown(options?: ShutdownOptions): Promise<ShutdownSummary> {\n   476→    if (this.shutdownPromise) {\n   477→      return this.shutdownPromise;\n   478→    }\n   479→\n   480→    this.isShuttingDown = true;\n   481→    this.shutdownPromise = this.performShutdown(options);\n   482→    return this.shutdownPromise;\n   483→  }\n   484→\n   485→  // ─── Task Lookup ────────────────────────────────────────────────\n   486→\n   487→  getTask(taskId: string): Task | null {\n   488→    return this.tasks.get(taskId) ?? null;\n   489→  }\n   490→\n   491→  // ─── Private Helpers ────────────────────────────────────────────\n   492→\n   493→  private ensureQueue(name: string): void {\n   494→    if (!this.queues.has(name)) {\n   495→      this.queues.set(name, new Set());\n   496→    }\n   497→  }\n   498→\n   499→  private compareTasks(\n   500→    a: { priority: number; availableAt: number; seq: number },\n   501→    b: { priority: number; availableAt: number; seq: number }\n   502→  ): number {\n   503→    // Phase 3: lower priority number = higher priority (1 is highest)\n   504→    if (a.priority !== b.priority) return a.priority - b.priority;\n   505→    // Phase 4: earlier availability time first among same priority\n   506→    if (a.availableAt !== b.availableAt) return a.availableAt - b.availableAt;\n   507→    // FIFO: lower sequence number first\n   508→    return a.seq - b.seq;\n   509→  }\n   510→\n   511→  private hasUnresolvedDependencies(task: Task): boolean {\n   512→    if (task.dependencies.length === 0) return false;\n   513→    for (const depId of task.dependencies) {\n   514→      const dep = this.tasks.get(depId);\n   515→      if (!dep || dep.status !== 'completed') return true;\n   516→    }\n   517→    return false;\n   518→  }\n   519→\n   520→  private detectCircularDeps(newTaskId: string, deps: string[]): void {\n   521→    // BFS/DFS to check if any dependency transitively depends on the new task\n   522→    // Since the new task hasn't been added yet, we check if any dependency\n   523→    // has a chain that leads back to any of the deps being added\n   524→    // Actually, since the task is new and not yet in the map, we can't have cycles\n   525→    // unless a dependency depends on another task that depends on... itself\n   526→    // The real check: does adding these dependencies create a cycle?\n   527→\n   528→    // We need to check: can any dependency reach back to newTaskId through its own dependencies?\n   529→    // Since newTaskId is new, this isn't possible directly.\n   530→    // But we should check for cycles among existing tasks when they reference each other.\n   531→\n   532→    // Actually the check is: among existing deps, is there a cycle?\n   533→    // For a newly added task with deps [A, B], we check if A or B transitively depend on each other\n   534→    // in a way that would create a cycle. But since the new task isn't anyone's dependency yet,\n   535→    // the only cycle possible would be if we introduced a dependency on a task that somehow\n   536→    // already depends on this new task. Since this task is new, that's impossible.\n   537→\n   538→    // However, the spec says \"circular dependencies (direct or indirect) must be detected and rejected\".\n   539→    // This means: if task A depends on B, and then we try to add task C that depends on A,\n   540→    // and later A tries to depend on C - that should be caught.\n   541→    // Since we're creating a new task, the cycle can't exist yet.\n   542→    // But let's be safe and do a proper check anyway.\n   543→\n   544→    // Actually the real scenario is:\n   545→    // 1. Task A exists (no deps)\n   546→    // 2. Task B is added with dep on A\n   547→    // 3. Now we try to add a dep from A to B - but A already exists, we'd need to modify it\n   548→    // Since deps are set at creation time, actual cycles between brand new tasks are impossible.\n   549→    // But we should still validate, e.g., someone passes [A, B] where B depends on A's completion\n   550→    // which depends on a task that depends on... etc.\n   551→\n   552→    // For correctness, let's just ensure no dep chain creates a cycle:\n   553→    const visited = new Set<string>();\n   554→    visited.add(newTaskId);\n   555→\n   556→    const stack = [...deps];\n   557→    while (stack.length > 0) {\n   558→      const current = stack.pop()!;\n   559→      if (current === newTaskId) {\n   560→        throw new Error('Circular dependency detected');\n   561→      }\n   562→      if (visited.has(current)) continue;\n   563→      visited.add(current);\n   564→      const task = this.tasks.get(current);\n   565→      if (task) {\n   566→        stack.push(...task.dependencies);\n   567→      }\n   568→    }\n   569→  }\n   570→\n   571→  private moveToDeadLetterQueue(task: Task): void {\n   572→    const queueName = task.queue;\n   573→\n   574→    // Remove from active queue\n   575→    const queueTaskIds = this.queues.get(queueName);\n   576→    if (queueTaskIds) {\n   577→      queueTaskIds.delete(task.id);\n   578→    }\n   579→\n   580→    // Add to DLQ\n   581→    if (!this.deadLetterQueues.has(queueName)) {\n   582→      this.deadLetterQueues.set(queueName, []);\n   583→    }\n   584→\n   585→    const deadTask: DeadLetteredTask = {\n   586→      ...task,\n   587→      deadLetteredAt: new Date(),\n   588→    };\n   589→\n   590→    this.deadLetterQueues.get(queueName)!.push(deadTask);\n   591→\n   592→    // Update the task in the main map too\n   593→    (this.tasks.get(task.id) as DeadLetteredTask).deadLetteredAt = new Date();\n   594→  }\n   595→\n   596→  private validateCron(expression: string): void {\n   597→    const parts = expression.split(' ');\n   598→    if (parts.length !== 5) {\n   599→      throw new Error(`Invalid cron expression: ${expression}. Must have 5 fields.`);\n   600→    }\n   601→\n   602→    // Validate supported patterns\n   603→    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n   604→\n   605→    // Check for supported patterns\n   606→    const isEveryNMinutes = /^\\*\\/\\d+$/.test(minute) && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n   607→    const isEveryHour = minute === '0' && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n   608→    const isEveryDay = minute === '0' && hour === '0' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n   609→\n   610→    if (!isEveryNMinutes && !isEveryHour && !isEveryDay) {\n   611→      throw new Error(`Unsupported cron expression: ${expression}. Supported: */N * * * *, 0 * * * *, 0 0 * * *`);\n   612→    }\n   613→\n   614→    if (isEveryNMinutes) {\n   615→      const n = parseInt(minute.split('/')[1], 10);\n   616→      if (n <= 0 || n > 59) {\n   617→        throw new Error(`Invalid interval in cron expression: ${n}`);\n   618→      }\n   619→    }\n   620→  }\n   621→\n   622→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   623→    const parts = schedule.cronExpression.split(' ');\n   624→    const [minutePart, hourPart] = parts;\n   625→\n   626→    if (minutePart.startsWith('*/')) {\n   627→      // Every N minutes\n   628→      const interval = parseInt(minutePart.split('/')[1], 10);\n   629→      const currentMinute = now.getMinutes();\n   630→\n   631→      if (currentMinute % interval !== 0) return false;\n   632→\n   633→      // Check if we already ran at this minute\n   634→      if (schedule.lastRun) {\n   635→        const lastRunMinute = schedule.lastRun.getMinutes();\n   636→        const lastRunHour = schedule.lastRun.getHours();\n   637→        const lastRunDate = schedule.lastRun.toDateString();\n   638→        if (\n   639→          lastRunMinute === currentMinute &&\n   640→          lastRunHour === now.getHours() &&\n   641→          lastRunDate === now.toDateString()\n   642→        ) {\n   643→          return false;\n   644→        }\n   645→      }\n   646→      return true;\n   647→    }\n   648→\n   649→    if (minutePart === '0' && hourPart === '*') {\n   650→      // Every hour on the hour\n   651→      if (now.getMinutes() !== 0) return false;\n   652→\n   653→      if (schedule.lastRun) {\n   654→        const lastRunHour = schedule.lastRun.getHours();\n   655→        const lastRunDate = schedule.lastRun.toDateString();\n   656→        if (lastRunHour === now.getHours() && lastRunDate === now.toDateString()) {\n   657→          return false;\n   658→        }\n   659→      }\n   660→      return true;\n   661→    }\n   662→\n   663→    if (minutePart === '0' && hourPart === '0') {\n   664→      // Every day at midnight\n   665→      if (now.getMinutes() !== 0 || now.getHours() !== 0) return false;\n   666→\n   667→      if (schedule.lastRun) {\n   668→        if (schedule.lastRun.toDateString() === now.toDateString()) {\n   669→          return false;\n   670→        }\n   671→      }\n   672→      return true;\n   673→    }\n   674→\n   675→    return false;\n   676→  }\n   677→\n   678→  private async executeMiddlewarePipeline(\n   679→    task: Task,\n   680→    middlewares: MiddlewareFn[],\n   681→    handler?: HandlerFn\n   682→  ): Promise<void> {\n   683→    let index = 0;\n   684→    let nextCalled = false;\n   685→\n   686→    const executeNext = async (): Promise<void> => {\n   687→      if (index < middlewares.length) {\n   688→        const middleware = middlewares[index++];\n   689→        nextCalled = false;\n   690→        await middleware(task, async () => {\n   691→          nextCalled = true;\n   692→          await executeNext();\n   693→        });\n   694→        // If middleware didn't call next, stop pipeline\n   695→        if (!nextCalled && index <= middlewares.length) {\n   696→          return;\n   697→        }\n   698→      } else if (handler) {\n   699→        await handler(task);\n   700→      }\n   701→    };\n   702→\n   703→    await executeNext();\n   704→  }\n   705→\n   706→  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownSummary> {\n   707→    const timeout = options?.timeout ?? 30000;\n   708→    const startTime = Date.now();\n   709→    let completedCount = 0;\n   710→    let cancelledCount = 0;\n   711→\n   712→    // Run shutdown callbacks\n   713→    for (const cb of this.shutdownCallbacks) {\n   714→      await cb();\n   715→    }\n   716→\n   717→    // Collect all processing tasks\n   718→    const processingTasks: Task[] = [];\n   719→    for (const task of this.tasks.values()) {\n   720→      if (task.status === 'processing') {\n   721→        processingTasks.push(task);\n   722→      }\n   723→    }\n   724→\n   725→    if (processingTasks.length === 0) {\n   726→      return {\n   727→        completed: 0,\n   728→        cancelled: 0,\n   729→        elapsed: Date.now() - startTime,\n   730→      };\n   731→    }\n   732→\n   733→    // Wait for processing tasks to complete, up to timeout\n   734→    const waitForCompletion = (): Promise<void> => {\n   735→      return new Promise<void>(resolve => {\n   736→        const checkInterval = setInterval(() => {\n   737→          const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n   738→          if (stillProcessing.length === 0) {\n   739→            clearInterval(checkInterval);\n   740→            resolve();\n   741→          }\n   742→        }, 10);\n   743→\n   744→        setTimeout(() => {\n   745→          clearInterval(checkInterval);\n   746→          resolve();\n   747→        }, timeout);\n   748→      });\n   749→    };\n   750→\n   751→    await waitForCompletion();\n   752→\n   753→    // Count completed vs force-cancel remaining\n   754→    for (const task of processingTasks) {\n   755→      if (task.status === 'processing') {\n   756→        task.status = 'cancelled';\n   757→        cancelledCount++;\n   758→      } else if (task.status === 'completed') {\n   759→        completedCount++;\n   760→      } else if (task.status === 'failed') {\n   761→        completedCount++;\n   762→      }\n   763→    }\n   764→\n   765→    return {\n   766→      completed: completedCou