 -> Set<taskId>\n  private queues = new Map<string, Set<string>>();\n\n  // Dead letter queues: queueName -> taskId[]\n  private deadLetterQueues = new Map<string, DeadLetteredTask[]>();\n\n  // Concurrency limits: queueName -> maxConcurrency\n  private concurrencyLimits = new Map<string, number>();\n\n  // Progress listeners: taskId -> Set<ProgressListener>\n  private progressListeners = new Map<string, Set<ProgressListener>>();\n\n  // Schedules: scheduleId -> Schedule\n  private schedules = new Map<string, Schedule>();\n\n  // Middleware stacks: queueName -> MiddlewareFn[]\n  private middlewareStacks = new Map<string, MiddlewareFn[]>();\n\n  // Handlers: queueName -> HandlerFn\n  private handlers = new Map<string, HandlerFn>();\n\n  // Shutdown state\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // ─── Phase 1: Basic FIFO Queue ───────────────────────────────────\n\n  add<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: system is shutting down');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Calculate availability time\n    const now = new Date();\n    let availableAt = new Date(0); // Non-delayed tasks are immediately available (epoch 0 for stable sorting)\n    if (options?.processAt) {\n      availableAt = options.processAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Validate dependencies\n    const dependencies = options?.dependencies ?? [];\n    if (dependencies.length > 0) {\n      for (const depId of dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      seq: this.seqCounter++,\n      attempts: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      progress: 0,\n      failureCount: 0,\n      dependencies,\n    };\n\n    // Detect circular dependencies\n    if (dependencies.length > 0) {\n      this.detectCircularDeps(task.id, dependencies);\n    }\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.add(task.id);\n\n    return task;\n  }\n\n  next(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(name);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = new Date();\n    let bestTask: Task | null = null;\n    let bestScore: { priority: number; availableAt: number; seq: number } | null = null;\n\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status !== 'pending') continue;\n\n      // Check availability time\n      if (task.availableAt > now) continue;\n\n      // Check dependencies\n      if (this.hasUnresolvedDependencies(task)) continue;\n\n      const score = {\n        priority: task.priority,\n        availableAt: task.availableAt.getTime(),\n        seq: task.seq,\n      };\n\n      if (!bestScore || this.compareTasks(score, bestScore) < 0) {\n        bestTask = task;\n        bestScore = score;\n      }\n    }\n\n    if (bestTask) {\n      bestTask.status = 'processing';\n      bestTask.attempts += 1;\n    }\n\n    return bestTask;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return 0;\n\n    let count = 0;\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // ─── Phase 2: Named Queues ──────────────────────────────────────\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Phase 5: Retry with Backoff ────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks are now unblocked (phase 7)\n    // No action needed -- unblocking is checked at retrieval time\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.lastError = error;\n    task.failureCount += 1;\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n    } else {\n      // No retries left\n      task.status = 'failed';\n      // Move to dead letter queue\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // ─── Phase 6: Dead Letter Queue ─────────────────────────────────\n\n  getDeadLetterTasks(queueName?: string): DeadLetteredTask[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return [...(this.deadLetterQueues.get(name) ?? [])];\n  }\n\n  requeue(taskId: string): Task | null {\n    // Find and remove from DLQ\n    for (const [queueName, dlqTasks] of this.deadLetterQueues) {\n      const idx = dlqTasks.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n        dlqTasks.splice(idx, 1);\n\n        // Reset the task for fresh retries\n        const task = this.tasks.get(taskId)!;\n        task.status = 'pending';\n        task.attempts = 0;\n        task.progress = 0;\n        task.failureCount = 0;\n        task.lastError = undefined;\n        task.availableAt = new Date(0);\n        task.seq = this.seqCounter++;\n\n        // Re-add to original queue\n        this.ensureQueue(queueName);\n        this.queues.get(queueName)!.add(taskId);\n\n        return task;\n      }\n    }\n    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlqTasks = this.deadLetterQueues.get(name);\n    if (dlqTasks) {\n      dlqTasks.length = 0;\n    }\n  }\n\n  // ─── Phase 7: Task Dependencies ─────────────────────────────────\n\n  getDependencyStatus(taskId: string): DependencyStatus {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved: string[] = [];\n    const pending: string[] = [];\n\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        resolved.push(depId);\n      } else {\n        pending.push(depId);\n      }\n    }\n\n    return {\n      taskId,\n      resolved,\n      pending,\n      blocked: pending.length > 0,\n    };\n  }\n\n  // ─── Phase 8: Concurrency Control ──────────────────────────────\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName?: string): number | undefined {\n    return this.concurrencyLimits.get(queueName ?? DEFAULT_QUEUE);\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueTaskIds = this.queues.get(name);\n    if (!queueTaskIds) return 0;\n\n    let count = 0;\n    for (const taskId of queueTaskIds) {\n      const task = this.tasks.get(taskId)!;\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // ─── Phase 9: Progress Tracking and Cancellation ────────────────\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancel(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Cannot cancel task in status: ${task.status}`);\n    }\n\n    task.status = 'cancelled';\n\n    // Remove from queue if pending\n    const queueTaskIds = this.queues.get(task.queue);\n    if (queueTaskIds) {\n      queueTaskIds.delete(taskId);\n    }\n  }\n\n  // ─── Phase 10: Recurring Tasks ──────────────────────────────────\n\n  addSchedule(\n    cronExpression: string,\n    payload: unknown,\n    options?: { queue?: string; priority?: number; maxRetries?: number; backoffDelay?: number }\n  ): Schedule {\n    this.validateCron(cronExpression);\n\n    const schedule: Schedule = {\n      id: randomUUID(),\n      cronExpression,\n      queue: options?.queue ?? DEFAULT_QUEUE,\n      payload,\n      taskOptions: options ? { priority: options.priority, maxRetries: options.maxRetries, backoffDelay: options.backoffDelay } : undefined,\n      createdAt: new Date(),\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule not found: ${scheduleId}`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const createdTasks: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.add(schedule.payload, {\n          queue: schedule.queue,\n          ...schedule.taskOptions,\n        });\n        createdTasks.push(task as Task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  // ─── Phase 11: Middleware Pipeline ──────────────────────────────\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    if (!this.middlewareStacks.has(queueName)) {\n      this.middlewareStacks.set(queueName, []);\n    }\n    this.middlewareStacks.get(queueName)!.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: HandlerFn): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  async process(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const task = this.next(name);\n    if (!task) return null;\n\n    const middlewares = this.middlewareStacks.get(name) ?? [];\n    const handler = this.handlers.get(name);\n\n    try {\n      await this.executeMiddlewarePipeline(task, middlewares, handler);\n    } catch (err) {\n      const errorMsg = err instanceof Error ? err.message : String(err);\n      // Only fail if still processing (middleware may have changed status)\n      if (task.status === 'processing') {\n        this.fail(task.id, errorMsg);\n      }\n    }\n\n    return task;\n  }\n\n  // ─── Phase 12: Graceful Shutdown ────────────────────────────────\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownSummary> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(options);\n    return this.shutdownPromise;\n  }\n\n  // ─── Task Lookup ────────────────────────────────────────────────\n\n  getTask(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  // ─── Private Helpers ────────────────────────────────────────────\n\n  private ensureQueue(name: string): void {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, new Set());\n    }\n  }\n\n  private compareTasks(\n    a: { priority: number; availableAt: number; seq: number },\n    b: { priority: number; availableAt: number; seq: number }\n  ): number {\n    // Phase 3: lower priority number = higher priority (1 is highest)\n    if (a.priority !== b.priority) return a.priority - b.priority;\n    // Phase 4: earlier availability time first among same priority\n    if (a.availableAt !== b.availableAt) return a.availableAt - b.availableAt;\n    // FIFO: lower sequence number first\n    return a.seq - b.seq;\n  }\n\n  private hasUnresolvedDependencies(task: Task): boolean {\n    if (task.dependencies.length === 0) return false;\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') return true;\n    }\n    return false;\n  }\n\n  private detectCircularDeps(newTaskId: string, deps: string[]): void {\n    // DFS from the new task's dependencies through their transitive deps.\n    // If we encounter newTaskId, a cycle exists.\n    const visited = new Set<string>();\n    visited.add(newTaskId);\n\n    const stack = [...deps];\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === newTaskId) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n      const task = this.tasks.get(current);\n      if (task) {\n        stack.push(...task.dependencies);\n      }\n    }\n  }\n\n  private moveToDeadLetterQueue(task: Task): void {\n    const queueName = task.queue;\n\n    // Remove from active queue\n    const queueTaskIds = this.queues.get(queueName);\n    if (queueTaskIds) {\n      queueTaskIds.delete(task.id);\n    }\n\n    // Add to DLQ\n    if (!this.deadLetterQueues.has(queueName)) {\n      this.deadLetterQueues.set(queueName, []);\n    }\n\n    const now = new Date();\n    (task as DeadLetteredTask).deadLetteredAt = now;\n\n    this.deadLetterQueues.get(queueName)!.push(task as DeadLetteredTask);\n  }\n\n  private validateCron(expression: string): void {\n    const parts = expression.split(' ');\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${expression}. Must have 5 fields.`);\n    }\n\n    // Validate supported patterns\n    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Check for supported patterns\n    const isEveryNMinutes = /^\\*\\/\\d+$/.test(minute) && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n    const isEveryHour = minute === '0' && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n    const isEveryDay = minute === '0' && hour === '0' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n\n    if (!isEveryNMinutes && !isEveryHour && !isEveryDay) {\n      throw new Error(`Unsupported cron expression: ${expression}. Supported: */N * * * *, 0 * * * *, 0 0 * * *`);\n    }\n\n    if (isEveryNMinutes) {\n      const n = parseInt(minute.split('/')[1], 10);\n      if (n <= 0 || n > 59) {\n        throw new Error(`Invalid interval in cron expression: ${n}`);\n      }\n    }\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cronExpression.split(' ');\n    const [minutePart, hourPart] = parts;\n\n    if (minutePart.startsWith('*/')) {\n      // Every N minutes\n      const interval = parseInt(minutePart.split('/')[1], 10);\n      const currentMinute = now.getMinutes();\n\n      if (currentMinute % interval !== 0) return false;\n\n      // Check if we already ran at this minute\n      if (schedule.lastRun) {\n        const lastRunMinute = schedule.lastRun.getMinutes();\n        const lastRunHour = schedule.lastRun.getHours();\n        const lastRunDate = schedule.lastRun.toDateString();\n        if (\n          lastRunMinute === currentMinute &&\n          lastRunHour === now.getHours() &&\n          lastRunDate === now.toDateString()\n        ) {\n          return false;\n        }\n      }\n      return true;\n    }\n\n    if (minutePart === '0' && hourPart === '*') {\n      // Every hour on the hour\n      if (now.getMinutes() !== 0) return false;\n\n      if (schedule.lastRun) {\n        const lastRunHour = schedule.lastRun.getHours();\n        const lastRunDate = schedule.lastRun.toDateString();\n        if (lastRunHour === now.getHours() && lastRunDate === now.toDateString()) {\n          return false;\n        }\n      }\n      return true;\n    }\n\n    if (minutePart === '0' && hourPart === '0') {\n      // Every day at midnight\n      if (now.getMinutes() !== 0 || now.getHours() !== 0) return false;\n\n      if (schedule.lastRun) {\n        if (schedule.lastRun.toDateString() === now.toDateString()) {\n          return false;\n        }\n      }\n      return true;\n    }\n\n    return false;\n  }\n\n  private async executeMiddlewarePipeline(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    handler?: HandlerFn\n  ): Promise<void> {\n    let index = 0;\n    let nextCalled = false;\n\n    const executeNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const middleware = middlewares[index++];\n        nextCalled = false;\n        await middleware(task, async () => {\n          nextCalled = true;\n          await executeNext();\n        });\n        // If middleware didn't call next, stop pipeline\n        if (!nextCalled && index <= middlewares.length) {\n          return;\n        }\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    await executeNext();\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownSummary> {\n    const timeout = options?.timeout ?? 30000;\n    const startTime = Date.now();\n    let completedCount = 0;\n    let cancelledCount = 0;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Collect all processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        cancelled: 0,\n        elapsed: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to complete, up to timeout\n    const waitForCompletion = (): Promise<void> => {\n      return new Promise<void>(resolve => {\n        let timeoutId: ReturnType<typeof setTimeout>;\n\n        const checkInterval = setInterval(() => {\n          const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n          if (stillProcessing.length === 0) {\n            clearInterval(checkInterval);\n            clearTimeout(timeoutId);\n            resolve();\n          }\n        }, 10);\n\n        timeoutId = setTimeout(() => {\n          clearInterval(checkInterval);\n          resolve();\n        }, timeout);\n      });\n    };\n\n    await waitForCompletion();\n\n    // Count completed vs force-cancel remaining\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        task.status = 'cancelled';\n        cancelledCount++;\n      } else if (task.status === 'completed') {\n        completedCount++;\n      } else if (task.status === 'failed') {\n        completedCount++;\n      }\n    }\n\n    return {\n      completed: completedCount,\n      cancelled: cancelledCount,\n      elapsed: Date.now() - startTime,\n    };\n  }\n}\n","structuredPatch":[{"oldStart":644,"oldLines"