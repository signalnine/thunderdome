+export { TaskQueue } from './TaskQueue.js';
+export type {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  DeadLetteredTask,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressListener,
+  ShutdownOptions,
+  ShutdownSummary,
+  DependencyStatus,
+} from './types.js';
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..cb7b3ec
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,65 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  seq: number;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  progress: number;
+  progressMessage?: string;
+  lastError?: string;
+  failureCount: number;
+  dependencies: string[];
+}
+
+export interface DeadLetteredTask<T = unknown> extends Task<T> {
+  deadLetteredAt: Date;
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'processAt' | 'dependencies'>;
+  lastRun?: Date;
+  createdAt: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void>;
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownSummary {
+  completed: number;
+  cancelled: number;
+  elapsed: number;
+}
+
+export interface DependencyStatus {
+  taskId: string;
+  resolved: string[];
+  pending: string[];
+  blocked: boolean;
+}
