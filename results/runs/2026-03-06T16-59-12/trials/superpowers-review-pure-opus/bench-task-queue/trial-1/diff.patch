RIORITY = 5;\nconst DEFAULT_MAX_RETRIES = 3;\nconst DEFAULT_BACKOFF_DELAY = 1000;\n\nexport class TaskQueue {\n  // Monotonic sequence counter for FIFO ordering\n  private seqCounter = 0;\n\n  // Task storage: taskId -> Task\n  private tasks = new Map<string, Task>();\n\n  // Per-queue task lists: queueName -> Set<taskId>\n  private queues = new Map<string, Set<string>>();\n\n  // Dead letter queues: queueName -> taskId[]\n  private deadLetterQueues = new Map<string, DeadLetteredTask[]>();\n\n  // Concurrency limits: queueName -> maxConcurrency\n  private concurrencyLimits = new Map<string, number>();\n\n  // Progress listeners: taskId -> Set<ProgressListener>\n  private progressListeners = new Map<string, Set<ProgressListener>>();\n\n  // Schedules: scheduleId -> Schedule\n  private schedules = new Map<string, Schedule>();\n\n  // Middleware stacks: queueName -> MiddlewareFn[]\n  private middlewareStacks = new Map<string, MiddlewareFn[]>();\n\n  // Handlers: queueName -> HandlerFn\n  private handlers = new Map<string, HandlerFn>();\n\n  // Shutdown state\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // ─── Phase 1: Basic FIFO Queue ───────────────────────────────────\n\n  add<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: system is shutting down');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Calculate availability time\n    const now = new Date();\n    let availableAt = new Date(0); // Non-delayed tasks are immediately available (epoch 0 for stable sorting)\n    if (options?.processAt) {