+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BvwpyqJRZWD844zQ4iujF4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AmzK7qXdRY4rsYip3KJHD6","name":"Write","input":{"file_path":"/workspace/tests/registry.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { createRegistry } from '../src/registry/index.js';\nimport type { PluginManifest, RegistryService } from '../src/types.js';\n\nfunction makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {\n  return {\n    name: 'test-plugin',\n    version: '1.0.0',\n    description: 'A test plugin',\n    author: 'tester',\n    dependencies: {},\n    entryPoint: 'console.log(\"hello\")',\n    permissions: [],\n    ...overrides,\n  };\n}\n\ndescribe('Plugin Registry', () => {\n  let registry: RegistryService;\n\n  beforeEach(() => {\n    registry = createRegistry();\n  });\n\n  it('should register and retrieve a plugin', () => {\n    const manifest = makeManifest();\n    registry.register(manifest);\n\n    const result = registry.get('test-plugin');\n    expect(result).not.toBeNull();\n    expect(result!.name).toBe('test-plugin');\n    expect(result!.version).toBe('1.0.0');\n  });\n\n  it('should return null for non-existent plugin', () => {\n    expect(registry.get('nonexistent')).toBeNull();\n  });\n\n  it('should support multiple versions of the same plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toContain('1.0.0');\n    expect(versions).toContain('2.0.0');\n    expect(versions).toHaveLength(2);\n  });\n\n  it('should get a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    const v1 = registry.getVersion('test-plugin', '1.0.0');\n    expect(v1).not.toBeNull();\n    expect(v1!.version).toBe('1.0.0');\n\n    const v2 = registry.getVersion('test-plugin', '2.0.0');\n    expect(v2).not.toBeNull();\n    expect(v2!.version).toBe('2.0.0');\n  });\n\n  it('should return null for non-existent version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();\n    expect(registry.getVersion('nonexistent', '1.0.0')).toBeNull();\n  });\n\n  it('should list all plugins', () => {\n    registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'plugin-b', version: '1.0.0' }));\n\n    const all = registry.list();\n    expect(all).toHaveLength(2);\n    const names = all.map((p) => p.name);\n    expect(names).toContain('plugin-a');\n    expect(names).toContain('plugin-b');\n  });\n\n  it('should search plugins by name', () => {\n    registry.register(makeManifest({ name: 'auth-plugin', description: 'Authentication' }));\n    registry.register(makeManifest({ name: 'db-plugin', description: 'Database' }));\n\n    const results = registry.search('auth');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('auth-plugin');\n  });\n\n  it('should search plugins by description', () => {\n    registry.register(makeManifest({ name: 'plugin-a', description: 'Handles authentication' }));\n    registry.register(makeManifest({ name: 'plugin-b', description: 'Handles logging' }));\n\n    const results = registry.search('logging');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('plugin-b');\n  });\n\n  it('should search plugins by author', () => {\n    registry.register(makeManifest({ name: 'plugin-a', author: 'alice' }));\n    registry.register(makeManifest({ name: 'plugin-b', author: 'bob' }));\n\n    const results = registry.search('alice');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('plugin-a');\n  });\n\n  it('should search case-insensitively', () => {\n    registry.register(makeManifest({ name: 'MyPlugin' }));\n    const results = registry.search('myplugin');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should remove a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    const removed = registry.remove('test-plugin', '1.0.0');\n    expect(removed).toBe(true);\n\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toEqual(['2.0.0']);\n  });\n\n  it('should return false when removing non-existent version', () => {\n    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n  });\n\n  it('should update a plugin manifest', () => {\n    registry.register(makeManifest());\n\n    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n\n    const updated = registry.getVersion('test-plugin', '1.0.0');\n    expect(updated!.description).toBe('Updated description');\n  });\n\n  it('should throw when updating non-existent plugin', () => {\n    expect(() => registry.update('nonexistent', '1.0.0', {})).toThrow();\n  });\n\n  it('should return empty versions array for non-existent plugin', () => {\n    expect(registry.listVersions('nonexistent')).toEqual([]);\n  });\n\n  it('should return empty list when no plugins registered', () => {\n    expect(registry.list()).toEqual([]);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":130,"cache_read_input_tokens":28145,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":130},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5c98f04d-a8b8-4236-b9a2-f2af16c7b435","uuid":"c1aa039a-125d-4499-8adc-fd96f27e5fbd"}
