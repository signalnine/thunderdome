sult = await marketplace.installPlugin(manifest);\n\n    expect(result.resolvedDependencies).toHaveLength(1);\n    expect(result.resolvedDependencies[0].name).toBe('dep-plugin');\n    expect(result.resolvedDependencies[0].version).toBe('1.1.0');\n  });\n\n  it('should reject plugin with missing name', async () => {\n    const manifest = makeManifest({ name: '' });\n    await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/name/);\n  });\n\n  it('should reject plugin with missing version', async () => {\n    const manifest = makeManifest({ version: '' });\n    await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/version/);\n  });\n\n  it('should reject plugin with missing entryPoint', async () => {\n    const manifest = makeManifest({ entryPoint: '' });\n    await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/entryPoint/);\n  });\n\n  it('should reject plugin with circular dependencies', async () => {\n    // Set up circular: a -> b -> a\n    marketplace.registry.register(\n      makeManifest({ name: 'plugin-b', dependencies: { 'plugin-a': '^1.0.0' } })\n    );\n\n    const manifest = makeManifest({\n      name: 'plugin-a',\n      dependencies: { 'plugin-b': '^1.0.0' },\n    });\n\n    await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/Circular/);\n\n    // Plugin should be removed from registry after circular dep rejection\n    expect(marketplace.registry.get('plugin-a')).toBeNull();\n  });\n\n  it('should handle plugin with failing code', async () => {\n    const manifest = makeManifest({\n      entryPoint: 'throw new Error(\"init failed\")',\n    });\n\n    const result = await marketplace.installPlugin(manifest);\n    expect(result.sandboxResult.success).toBe(false);\n    expect(result.sandboxResult.error).toBe('init failed');\n  });\n\n  it('should expose all services', () => {\n    expect(marketplace.registry).toBeDefined();\n    expect(marketplace.resolver).toBeDefined();\n    expect(marketplace.runner).toBeDefined();\n    expect(marketplace.reviews).toBeDefined();\n    expect(marketplace.deps).toBeDefined();\n  });\n\n  it('full workflow: install, review, query', async () => {\n    const manifest = makeManifest({\n      entryPoint: 'console.log(\"initialized\")',\n    });\n\n    const installResult = await marketplace.installPlugin(manifest);\n    expect(installResult.sandboxResult.success).toBe(true);\n\n    // Leave some reviews\n    marketplace.reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Excellent!',\n    });\n    marketplace.reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 4,\n      comment: 'Pretty good',\n    });\n\n    const avg = marketplace.reviews.getAverageRating('test-plugin');\n    expect(avg).toBe(4.5);\n\n    const count = marketplace.reviews.getReviewCount('test-plugin');\n    expect(count).toBe(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1633,"cache_read_input_tokens":33777,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1633},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5c98f04d-a8b8-4236-b9a2-f2af16c7b435","uuid":"d88a45f7-ba10-47c3-a26a-57e8900af5d2"}
