uginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 3,\n      comment: 'OK',\n    });\n\n    const avg = reviews.getAverageRating('test-plugin');\n    expect(avg).toBe(4);\n  });\n\n  it('should exclude flagged reviews from average', () => {\n    const r1 = reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Great!',\n    });\n    reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 1,\n      comment: 'Terrible spam',\n    });\n\n    reviews.flagReview(r1.id + 1); // flag the second review\n\n    const avg = reviews.getAverageRating('test-plugin');\n    expect(avg).toBe(5); // only the first review counts\n  });\n\n  it('should return 0 for plugin with no reviews', () => {\n    expect(reviews.getAverageRating('nonexistent')).toBe(0);\n  });\n\n  it('should flag a review', () => {\n    const review = reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 1,\n      comment: 'Spam',\n    });\n\n    reviews.flagReview(review.id);\n\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged).toHaveLength(1);\n    expect(flagged[0].id).toBe(review.id);\n    expect(flagged[0].flagged).toBe(true);\n  });\n\n  it('should remove a review', () => {\n    const review = reviews.addReview({\n      pluginName: 'test-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Great!',\n    });\n\n    const removed = reviews.removeReview(review.id);\n    expect(removed).toBe(true);\n\n    const pluginReviews = reviews.getReviews('test-plugin');\n    expect(pluginReviews).toHaveLength(0);\n  });\n\n  it('should return false when removing non-existent review', () => {\n    expect(reviews.removeReview(999)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({\n  