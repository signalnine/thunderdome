+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EMQ285eQnMDDzE2oKTWrNm","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createResolver } from '../src/resolver/index.js';\n     3→import type { ResolverService } from '../src/types.js';\n     4→\n     5→describe('Version Resolver', () => {\n     6→  let resolver: ResolverService;\n     7→\n     8→  beforeEach(() => {\n     9→    resolver = createResolver();\n    10→  });\n    11→\n    12→  it('should resolve a simple constraint', () => {\n    13→    const results = resolver.resolve(\n    14→      [{ name: 'foo', range: '^1.0.0' }],\n    15→      { foo: ['1.0.0', '1.1.0', '1.2.0', '2.0.0'] }\n    16→    );\n    17→\n    18→    expect(results).toHaveLength(1);\n    19→    expect(results[0].name).toBe('foo');\n    20→    expect(results[0].version).toBe('1.2.0');\n    21→    expect(results[0].satisfies).toBe('^1.0.0');\n    22→  });\n    23→\n    24→  it('should resolve multiple constraints', () => {\n    25→    const results = resolver.resolve(\n    26→      [\n    27→        { name: 'foo', range: '^1.0.0' },\n    28→        { name: 'bar', range: '~2.1.0' },\n    29→      ],\n    30→      {\n    31→        foo: ['1.0.0', '1.5.0', '2.0.0'],\n    32→        bar: ['2.0.0', '2.1.0', '2.1.5', '2.2.0'],\n    33→      }\n    34→    );\n    35→\n    36→    expect(results).toHaveLength(2);\n    37→    expect(results[0].version).toBe('1.5.0');\n    38→    expect(results[1].version).toBe('2.1.5');\n    39→  });\n    40→\n    41→  it('should throw when no versions available', () => {\n    42→    expect(() =>\n    43→      resolver.resolve([{ name: 'foo', range: '^1.0.0' }], {})\n    44→    ).toThrow(/No versions available/);\n    45→  });\n    46→\n    47→  it('should throw when no version satisfies range', () => {\n    48→    expect(() =>\n    49→      resolver.resolve(\n    50→        [{ name: 'foo', range: '^3.0.0' }],\n    51→        { foo: ['1.0.0', '2.0.0'] }\n    52→      )\n    53→    ).toThrow(/No version of \"foo\" satisfies/);\n    54→  });\n    55→\n    56→  it('should check if version satisfies range', () => {\n    57→    expect(resolver.satisfies('1.5.0', '^1.0.0')).toBe(true);\n    58→    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    59→    expect(resolver.satisfies('1.0.0', '>=1.0.0 <2.0.0')).toBe(true);\n    60→  });\n    61→\n    62→  it('should find max satisfying version', () => {\n    63→    const versions = ['1.0.0', '1.1.0', '1.2.0', '2.0.0'];\n    64→    expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.2.0');\n    65→    expect(resolver.maxSatisfying(versions, '^2.0.0')).toBe('2.0.0');\n    66→    expect(resolver.maxSatisfying(versions, '^3.0.0')).toBeNull();\n    67→  });\n    68→\n    69→  it('should validate ranges', () => {\n    70→    expect(resolver.validRange('^1.0.0')).toBe(true);\n    71→    expect(resolver.validRange('~2.0.0')).toBe(true);\n    72→    expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n    73→    expect(resolver.validRange('not-a-range')).toBe(false);\n    74→  });\n    75→\n    76→  it('should handle exact version constraints', () => {\n    77→    const results = resolver.resolve(\n    78→      [{ name: 'foo', range: '1.0.0' }],\n    79→      { foo: ['1.0.0', '2.0.0'] }\n    80→    );\n    81→    expect(results[0].version).toBe('1.0.0');\n    82→  });\n    83→});\n    84→"}]},"parent_tool_use_id":"toolu_0156Ay6dZaRYXXpR96AHTX51","session_id":"5c98f04d-a8b8-4236-b9a2-f2af16c7b435","uuid":"6210e4b3-4edb-44df-8531-501930e72be6"}
