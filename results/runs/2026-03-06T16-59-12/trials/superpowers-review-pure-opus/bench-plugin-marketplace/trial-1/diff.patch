+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pu3G2Fqu4Bu8v65Quw6K8R","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { createRegistry } from '../src/registry/index.js';\n     3→import type { PluginManifest, RegistryService } from '../src/types.js';\n     4→\n     5→function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {\n     6→  return {\n     7→    name: 'test-plugin',\n     8→    version: '1.0.0',\n     9→    description: 'A test plugin',\n    10→    author: 'tester',\n    11→    dependencies: {},\n    12→    entryPoint: 'console.log(\"hello\")',\n    13→    permissions: [],\n    14→    ...overrides,\n    15→  };\n    16→}\n    17→\n    18→describe('Plugin Registry', () => {\n    19→  let registry: RegistryService;\n    20→\n    21→  beforeEach(() => {\n    22→    registry = createRegistry();\n    23→  });\n    24→\n    25→  it('should register and retrieve a plugin', () => {\n    26→    const manifest = makeManifest();\n    27→    registry.register(manifest);\n    28→\n    29→    const result = registry.get('test-plugin');\n    30→    expect(result).not.toBeNull();\n    31→    expect(result!.name).toBe('test-plugin');\n    32→    expect(result!.version).toBe('1.0.0');\n    33→  });\n    34→\n    35→  it('should return null for non-existent plugin', () => {\n    36→    expect(registry.get('nonexistent')).toBeNull();\n    37→  });\n    38→\n    39→  it('should support multiple versions of the same plugin', () => {\n    40→    registry.register(makeManifest({ version: '1.0.0' }));\n    41→    registry.register(makeManifest({ version: '2.0.0' }));\n    42→\n    43→    const versions = registry.listVersions('test-plugin');\n    44→    expect(versions).toContain('1.0.0');\n    45→    expect(versions).toContain('2.0.0');\n    46→    expect(versions).toHaveLength(2);\n    47→  });\n    48→\n    49→  it('should get a specific version', () => {\n    50→    registry.register(makeManifest({ version: '1.0.0' }));\n    51→    registry.register(makeManifest({ version: '2.0.0' }));\n    52→\n    53→    const v1 = registry.getVersion('test-plugin', '1.0.0');\n    54→    expect(v1).not.toBeNull();\n    55→    expect(v1!.version).toBe('1.0.0');\n    56→\n    57→    const v2 = registry.getVersion('test-plugin', '2.0.0');\n    58→    expect(v2).not.toBeNull();\n    59→    expect(v2!.version).toBe('2.0.0');\n    60→  });\n    61→\n    62→  it('should return null for non-existent version', () => {\n    63→    registry.register(makeManifest({ version: '1.0.0' }));\n    64→    expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();\n    65→    expect(registry.getVersion('nonexistent', '1.0.0')).toBeNull();\n    66→  });\n    67→\n    68→  it('should list all plugins', () => {\n    69→    registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0' }));\n    70→    registry.register(makeManifest({ name: 'plugin-b', version: '1.0.0' }));\n    71→\n    72→    const all = registry.list();\n    73→    expect(all).toHaveLength(2);\n    74→    const names = all.map((p) => p.name);\n    75→    expect(names).toContain('plugin-a');\n    76→    expect(names).toContain('plugin-b');\n    77→  });\n    78→\n    79→  it('should search plugins by name', () => {\n    80→    registry.register(makeManifest({ name: 'auth-plugin', description: 'Authentication' }));\n    81→    registry.register(makeManifest({ name: 'db-plugin', description: 'Database' }));\n    82→\n    83→    const results = registry.search('auth');\n    84→    expect(results).toHaveLength(1);\n    85→    expect(results[0].name).toBe('auth-plugin');\n    86→  });\n    87→\n    88→  it('should search plugins by description', () => {\n    89→    registry.register(makeManifest({ name: 'plugin-a', description: 'Handles authentication' }));\n    90→    registry.register(makeManifest({ name: 'plugin-b', description: 'Handles logging' }));\n    91→\n    92→    const results = registry.search('logging');\n    93→    expect(results).toHaveLength(1);\n    94→    expect(results[0].name).toBe('plugin-b');\n    95→  });\n    96→\n    97→  it('should search plugins by author', () => {\n    98→    registry.register(makeManifest({ name: 'plugin-a', author: 'alice' }));\n    99→    registry.register(makeManifest({ name: 'plugin-b', author: 'bob' }));\n   100→\n   101→    const results = registry.search('alice');\n   102→    expect(results).toHaveLength(1);\n   103→    expect(results[0].name).toBe('plugin-a');\n   104→  });\n   105→\n   106→  it('should search case-insensitively', () => {\n   107→    registry.register(makeManifest({ name: 'MyPlugin' }));\n   108→    const results = registry.search('myplugin');\n   109→    expect(results).toHaveLength(1);\n   110→  });\n   111→\n   112→  it('should remove a specific version', () => {\n   113→    registry.register(makeManifest({ version: '1.0.0' }));\n   114→    registry.register(makeManifest({ version: '2.0.0' }));\n   115→\n   116→    const removed = registry.remove('test-plugin', '1.0.0');\n   117→    expect(removed).toBe(true);\n   118→\n   119→    const versions = registry.listVersions('test-plugin');\n   120→    expect(versions).toEqual(['2.0.0']);\n   121→  });\n   122→\n   123→  it('should return false when removing non-existent version', () => {\n   124→    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n   125→  });\n   126→\n   127→  it('should update a plugin manifest', () => {\n   128→    registry.register(makeManifest());\n   129→\n   130→    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n   131→\n   132→    const updated = registry.getVersion('test-plugin', '1.0.0');\n   133→    expect(updated!.description).toBe('Updated description');\n   134→  });\n   135→\n   136→  it('should throw when updating non-existent plugin', () => {\n   137→    expect(() => registry.update('nonexistent', '1.0.0', {})).toThrow();\n   138→  });\n   139→\n   140→  it('should return empty versions array for non-existent plugin', () => {\n   141→    expect(registry.listVersions('nonexistent')).toEqual([]);\n   142→  });\n   143→\n   144→  it('should return empty list when no plugins registered', () => {\n   145→    expect(registry.list()).toEqual([]);\n   146→  });\n   147→});\n   148→"}]},"parent_tool_use_id":"toolu_0156Ay6dZaRYXXpR96AHTX51","session_id":"5c98f04d-a8b8-4236-b9a2-f2af16c7b435","uuid":"a303e457-ba65-444b-92f5-2f716980a062"}
