+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VRnJ9vR1vrkuQhujPRf4Hs","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import type { Review, ReviewService } from '../types.js';\n     3→\n     4→export function createReviewService(dbPath?: string): ReviewService {\n     5→  const db = new Database(dbPath ?? ':memory:');\n     6→\n     7→  db.exec(`\n     8→    CREATE TABLE IF NOT EXISTS reviews (\n     9→      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    10→      pluginName TEXT NOT NULL,\n    11→      pluginVersion TEXT NOT NULL,\n    12→      userId TEXT NOT NULL,\n    13→      rating INTEGER NOT NULL CHECK(rating >= 1 AND rating <= 5),\n    14→      comment TEXT NOT NULL,\n    15→      flagged INTEGER NOT NULL DEFAULT 0,\n    16→      createdAt TEXT NOT NULL\n    17→    )\n    18→  `);\n    19→\n    20→  const insertStmt = db.prepare(`\n    21→    INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt)\n    22→    VALUES (?, ?, ?, ?, ?, 0, ?)\n    23→  `);\n    24→\n    25→  const getByPluginStmt = db.prepare(`\n    26→    SELECT * FROM reviews WHERE pluginName = ? ORDER BY createdAt DESC\n    27→  `);\n    28→\n    29→  const avgRatingStmt = db.prepare(`\n    30→    SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0\n    31→  `);\n    32→\n    33→  const flagStmt = db.prepare(`\n    34→    UPDATE reviews SET flagged = 1 WHERE id = ?\n    35→  `);\n    36→\n    37→  const getFlaggedStmt = db.prepare(`\n    38→    SELECT * FROM reviews WHERE flagged = 1 ORDER BY createdAt DESC\n    39→  `);\n    40→\n    41→  const removeStmt = db.prepare(`\n    42→    DELETE FROM reviews WHERE id = ?\n    43→  `);\n    44→\n    45→  const getByUserStmt = db.prepare(`\n    46→    SELECT * FROM reviews WHERE userId = ? ORDER BY createdAt DESC\n    47→  `);\n    48→\n    49→  const countStmt = db.prepare(`\n    50→    SELECT COUNT(*) as count FROM reviews WHERE pluginName = ?\n    51→  `);\n    52→\n    53→  function rowToReview(row: Record<string, unknown>): Review {\n    54→    return {\n    55→      id: row.id as number,\n    56→      pluginName: row.pluginName as string,\n    57→      pluginVersion: row.pluginVersion as string,\n    58→      userId: row.userId as string,\n    59→      rating: row.rating as number,\n    60→      comment: row.comment as string,\n    61→      flagged: (row.flagged as number) === 1,\n    62→      createdAt: row.createdAt as string,\n    63→    };\n    64→  }\n    65→\n    66→  return {\n    67→    addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {\n    68→      const createdAt = new Date().toISOString();\n    69→      const result = insertStmt.run(\n    70→        review.pluginName,\n    71→        review.pluginVersion,\n    72→        review.userId,\n    73→        review.rating,\n    74→        review.comment,\n    75→        createdAt\n    76→      );\n    77→\n    78→      return {\n    79→        id: Number(result.lastInsertRowid),\n    80→        ...review,\n    81→        flagged: false,\n    82→        createdAt,\n    83→      };\n    84→    },\n    85→\n    86→    getReviews(pluginName: string): Review[] {\n    87→      const rows = getByPluginStmt.all(pluginName) as Record<string, unknown>[];\n    88→      return rows.map(rowToReview);\n    89→    },\n    90→\n    91→    getAverageRating(pluginName: string): number {\n    92→      const row = avgRatingStmt.get(pluginName) as { avg: number | null };\n    93→      return row.avg ?? 0;\n    94→    },\n    95→\n    96→    flagReview(reviewId: number): void {\n    97→      flagStmt.run(reviewId);\n    98→    },\n    99→\n   100→    getFlaggedReviews(): Review[] {\n   101→      const rows = getFlaggedStmt.all() as Record<string, unknown>[];\n   102→      return rows.map(rowToReview);\n   103→    },\n   104→\n   105→    removeReview(reviewId: number): boolean {\n   106→      const result = removeStmt.run(reviewId);\n   107→      return result.changes > 0;\n   108→    },\n   109→\n   110→    getReviewsByUser(userId: string): Review[] {\n   111→      const rows = getByUserStmt.all(userId) as Record<string, unknown>[];\n   112→      return rows.map(rowToReview);\n   113→    },\n   114→\n   115→    getReviewCount(pluginName: string): number {\n   116→      const row = countStmt.get(pluginName) as { count: number };\n   117→      return row.count;\n   118→    },\n   119→  };\n   120→}\n   121→"}]},"parent_tool_use_id":"toolu_0156Ay6dZaRYXXpR96AHTX51","session_id":"5c98f04d-a8b8-4236-b9a2-f2af16c7b435","uuid":"c20e8239-43d1-4de6-af74-44485d28aaa5"}
