+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011hHy4XN35uKowYHKFTZdCe","type":"tool_result","content":"     1→import type { PluginManifest, RegistryService } from '../types.js';\n     2→\n     3→export function createRegistry(): RegistryService {\n     4→  // Map of name -> Map of version -> manifest\n     5→  const plugins = new Map<string, Map<string, PluginManifest>>();\n     6→\n     7→  return {\n     8→    register(manifest: PluginManifest): void {\n     9→      if (!plugins.has(manifest.name)) {\n    10→        plugins.set(manifest.name, new Map());\n    11→      }\n    12→      plugins.get(manifest.name)!.set(manifest.version, { ...manifest });\n    13→    },\n    14→\n    15→    get(name: string): PluginManifest | null {\n    16→      const versions = plugins.get(name);\n    17→      if (!versions || versions.size === 0) return null;\n    18→      // Return the latest registered version (last inserted)\n    19→      let latest: PluginManifest | null = null;\n    20→      for (const manifest of versions.values()) {\n    21→        latest = manifest;\n    22→      }\n    23→      return latest ? { ...latest } : null;\n    24→    },\n    25→\n    26→    getVersion(name: string, version: string): PluginManifest | null {\n    27→      const versions = plugins.get(name);\n    28→      if (!versions) return null;\n    29→      const manifest = versions.get(version);\n    30→      return manifest ? { ...manifest } : null;\n    31→    },\n    32→\n    33→    list(): PluginManifest[] {\n    34→      const result: PluginManifest[] = [];\n    35→      for (const versions of plugins.values()) {\n    36→        for (const manifest of versions.values()) {\n    37→          result.push({ ...manifest });\n    38→        }\n    39→      }\n    40→      return result;\n    41→    },\n    42→\n    43→    search(query: string): PluginManifest[] {\n    44→      const lower = query.toLowerCase();\n    45→      const result: PluginManifest[] = [];\n    46→      for (const versions of plugins.values()) {\n    47→        for (const manifest of versions.values()) {\n    48→          if (\n    49→            manifest.name.toLowerCase().includes(lower) ||\n    50→            manifest.description.toLowerCase().includes(lower) ||\n    51→            manifest.author.toLowerCase().includes(lower)\n    52→          ) {\n    53→            result.push({ ...manifest });\n    54→          }\n    55→        }\n    56→      }\n    57→      return result;\n    58→    },\n    59→\n    60→    remove(name: string, version: string): boolean {\n    61→      const versions = plugins.get(name);\n    62→      if (!versions) return false;\n    63→      const deleted = versions.delete(version);\n    64→      if (versions.size === 0) {\n    65→        plugins.delete(name);\n    66→      }\n    67→      return deleted;\n    68→    },\n    69→\n    70→    listVersions(name: string): string[] {\n    71→      const versions = plugins.get(name);\n    72→      if (!versions) return [];\n    73→      return Array.from(versions.keys());\n    74→    },\n    75→\n    76→    update(name: string, version: string, updates: Partial<PluginManifest>): void {\n    77→      const versions = plugins.get(name);\n    78→      if (!versions) throw new Error(`Plugin ${name} not found`);\n    79→      const manifest = versions.get(version);\n    80→      if (!manifest) throw new Error(`Plugin ${name}@${version} not found`);\n    81→      Object.assign(manifest, updates);\n    82→    },\n    83→  };\n    84→}\n    85→"}]},"parent_tool_use_id":"toolu_0156Ay6dZaRYXXpR96AHTX51","session_id":"5c98f04d-a8b8-4236-b9a2-f2af16c7b435","uuid":"1e67f9bb-1613-42c1-9db4-613207289a7e"}
