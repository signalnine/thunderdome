+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JxadMbTM6DCCP8mMhhGwZq","type":"tool_result","content":"     1→import { Router, Request, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { v4 as uuidv4 } from \"uuid\";\n     4→import { authMiddleware } from \"../auth.js\";\n     5→\n     6→interface DashboardRow {\n     7→  id: string;\n     8→  tenant_id: string;\n     9→  name: string;\n    10→  owner_id: string;\n    11→  config: string;\n    12→  created_at: string;\n    13→  updated_at: string;\n    14→}\n    15→\n    16→export function createDashboardRouter(db: Database.Database): Router {\n    17→  const router = Router();\n    18→\n    19→  router.use(authMiddleware);\n    20→\n    21→  // Create dashboard\n    22→  router.post(\"/\", (req: Request, res: Response) => {\n    23→    const { name, config } = req.body;\n    24→\n    25→    if (!name) {\n    26→      res.status(400).json({ error: \"Dashboard name is required\" });\n    27→      return;\n    28→    }\n    29→\n    30→    const id = uuidv4();\n    31→    const tenantId = req.user!.tenantId;\n    32→    const ownerId = req.user!.userId;\n    33→    const now = new Date().toISOString();\n    34→    const dashConfig = JSON.stringify(config || {});\n    35→\n    36→    db.prepare(\n    37→      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    38→    ).run(id, tenantId, name, ownerId, dashConfig, now, now);\n    39→\n    40→    res.status(201).json({\n    41→      id,\n    42→      tenantId,\n    43→      name,\n    44→      ownerId,\n    45→      config: config || {},\n    46→      createdAt: now,\n    47→      updatedAt: now,\n    48→    });\n    49→  });\n    50→\n    51→  // List dashboards for tenant\n    52→  router.get(\"/\", (req: Request, res: Response) => {\n    53→    const tenantId = req.user!.tenantId;\n    54→\n    55→    const dashboards = db\n    56→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n    57→      .all(tenantId) as DashboardRow[];\n    58→\n    59→    res.json(\n    60→      dashboards.map((d) => ({\n    61→        id: d.id,\n    62→        tenantId: d.tenant_id,\n    63→        name: d.name,\n    64→        ownerId: d.owner_id,\n    65→        config: JSON.parse(d.config),\n    66→        createdAt: d.created_at,\n    67→        updatedAt: d.updated_at,\n    68→      }))\n    69→    );\n    70→  });\n    71→\n    72→  // Get single dashboard\n    73→  router.get(\"/:id\", (req: Request, res: Response) => {\n    74→    const tenantId = req.user!.tenantId;\n    75→\n    76→    const dashboard = db\n    77→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    78→      .get(req.params.id, tenantId) as DashboardRow | undefined;\n    79→\n    80→    if (!dashboard) {\n    81→      res.status(404).json({ error: \"Dashboard not found\" });\n    82→      return;\n    83→    }\n    84→\n    85→    res.json({\n    86→      id: dashboard.id,\n    87→      tenantId: dashboard.tenant_id,\n    88→      name: dashboard.name,\n    89→      ownerId: dashboard.owner_id,\n    90→      config: JSON.parse(dashboard.config),\n    91→      createdAt: dashboard.created_at,\n    92→      updatedAt: dashboard.updated_at,\n    93→    });\n    94→  });\n    95→\n    96→  // Update dashboard\n    97→  router.put(\"/:id\", (req: Request, res: Response) => {\n    98→    const tenantId = req.user!.tenantId;\n    99→    const { name, config } = req.body;\n   100→\n   101→    const existing = db\n   102→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   103→      .get(req.params.id, tenantId) as DashboardRow | undefined;\n   104→\n   105→    if (!existing) {\n   106→      res.status(404).json({ error: \"Dashboard not found\" });\n   107→      return;\n   108→    }\n   109→\n   110→    const updatedName = name || existing.name;\n   111→    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;\n   112→    const now = new Date().toISOString();\n   113→\n   114→    db.prepare(\n   115→      \"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\"\n   116→    ).run(updatedName, updatedConfig, now, req.params.id);\n   117→\n   118→    res.json({\n   119→      id: existing.id,\n   120→      tenantId: existing.tenant_id,\n   121→      name: updatedName,\n   122→      ownerId: existing.owner_id,\n   123→      config: JSON.parse(updatedConfig),\n   124→      createdAt: existing.created_at,\n   125→      updatedAt: now,\n   126→    });\n   127→  });\n   128→\n   129→  // Delete dashboard\n   130→  router.delete(\"/:id\", (req: Request, res: Response) => {\n   131→    const tenantId = req.user!.tenantId;\n   132→\n   133→    const existing = db\n   134→      .prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   135→      .get(req.params.id, tenantId);\n   136→\n   137→    if (!existing) {\n   138→      res.status(404).json({ error: \"Dashboard not found\" });\n   139→      return;\n   140→    }\n   141→\n   142→    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n   143→\n   144→    res.status(204).send();\n   145→  });\n   146→\n   147→  return router;\n   148→}\n   149→"}]},"parent_tool_use_id":"toolu_01FWdwZszs7opk9MocezgZVD","session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"e5bd02a5-c134-4d2d-a401-fc9f88f5343a"}
