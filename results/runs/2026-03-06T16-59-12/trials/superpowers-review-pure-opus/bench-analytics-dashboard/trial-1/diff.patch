+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014su7HVBHpf9TMYVJs1Xn78","type":"tool_result","content":"     1→import { Router, Request, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { authMiddleware } from \"../auth.js\";\n     4→\n     5→interface EventRow {\n     6→  id: string;\n     7→  tenant_id: string;\n     8→  name: string;\n     9→  properties: string;\n    10→  timestamp: string;\n    11→  user_id: string | null;\n    12→  session_id: string | null;\n    13→}\n    14→\n    15→interface DashboardRow {\n    16→  id: string;\n    17→  tenant_id: string;\n    18→  name: string;\n    19→  owner_id: string;\n    20→  config: string;\n    21→  created_at: string;\n    22→  updated_at: string;\n    23→}\n    24→\n    25→function escapeCsvField(value: string): string {\n    26→  if (value.includes(\",\") || value.includes('\"') || value.includes(\"\\n\")) {\n    27→    return `\"${value.replace(/\"/g, '\"\"')}\"`;\n    28→  }\n    29→  return value;\n    30→}\n    31→\n    32→function eventsToCsv(events: EventRow[]): string {\n    33→  const headers = [\"id\", \"name\", \"properties\", \"timestamp\", \"user_id\", \"session_id\"];\n    34→  const lines = [headers.join(\",\")];\n    35→\n    36→  for (const event of events) {\n    37→    const row = [\n    38→      escapeCsvField(event.id),\n    39→      escapeCsvField(event.name),\n    40→      escapeCsvField(event.properties),\n    41→      escapeCsvField(event.timestamp),\n    42→      escapeCsvField(event.user_id || \"\"),\n    43→      escapeCsvField(event.session_id || \"\"),\n    44→    ];\n    45→    lines.push(row.join(\",\"));\n    46→  }\n    47→\n    48→  return lines.join(\"\\n\");\n    49→}\n    50→\n    51→function dashboardsToCsv(dashboards: DashboardRow[]): string {\n    52→  const headers = [\"id\", \"name\", \"owner_id\", \"config\", \"created_at\", \"updated_at\"];\n    53→  const lines = [headers.join(\",\")];\n    54→\n    55→  for (const d of dashboards) {\n    56→    const row = [\n    57→      escapeCsvField(d.id),\n    58→      escapeCsvField(d.name),\n    59→      escapeCsvField(d.owner_id),\n    60→      escapeCsvField(d.config),\n    61→      escapeCsvField(d.created_at),\n    62→      escapeCsvField(d.updated_at),\n    63→    ];\n    64→    lines.push(row.join(\",\"));\n    65→  }\n    66→\n    67→  return lines.join(\"\\n\");\n    68→}\n    69→\n    70→export function createExportRouter(db: Database.Database): Router {\n    71→  const router = Router();\n    72→\n    73→  router.use(authMiddleware);\n    74→\n    75→  // Export events as JSON\n    76→  router.get(\"/events/json\", (req: Request, res: Response) => {\n    77→    const tenantId = req.user!.tenantId;\n    78→    const { eventName, startDate, endDate } = req.query;\n    79→\n    80→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    81→    const params: unknown[] = [tenantId];\n    82→\n    83→    if (eventName) {\n    84→      sql += \" AND name = ?\";\n    85→      params.push(eventName);\n    86→    }\n    87→\n    88→    if (startDate) {\n    89→      sql += \" AND timestamp >= ?\";\n    90→      params.push(startDate);\n    91→    }\n    92→\n    93→    if (endDate) {\n    94→      sql += \" AND timestamp <= ?\";\n    95→      params.push(endDate);\n    96→    }\n    97→\n    98→    sql += \" ORDER BY timestamp DESC\";\n    99→\n   100→    const events = db.prepare(sql).all(...params) as EventRow[];\n   101→\n   102→    const mapped = events.map((e) => ({\n   103→      id: e.id,\n   104→      name: e.name,\n   105→      properties: JSON.parse(e.properties),\n   106→      timestamp: e.timestamp,\n   107→      userId: e.user_id,\n   108→      sessionId: e.session_id,\n   109→    }));\n   110→\n   111→    res.json(mapped);\n   112→  });\n   113→\n   114→  // Export events as CSV\n   115→  router.get(\"/events/csv\", (req: Request, res: Response) => {\n   116→    const tenantId = req.user!.tenantId;\n   117→    const { eventName, startDate, endDate } = req.query;\n   118→\n   119→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n   120→    const params: unknown[] = [tenantId];\n   121→\n   122→    if (eventName) {\n   123→      sql += \" AND name = ?\";\n   124→      params.push(eventName);\n   125→    }\n   126→\n   127→    if (startDate) {\n   128→      sql += \" AND timestamp >= ?\";\n   129→      params.push(startDate);\n   130→    }\n   131→\n   132→    if (endDate) {\n   133→      sql += \" AND timestamp <= ?\";\n   134→      params.push(endDate);\n   135→    }\n   136→\n   137→    sql += \" ORDER BY timestamp DESC\";\n   138→\n   139→    const events = db.prepare(sql).all(...params) as EventRow[];\n   140→\n   141→    res.setHeader(\"Content-Type\", \"text/csv\");\n   142→    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n   143→    res.send(eventsToCsv(events));\n   144→  });\n   145→\n   146→  // Export dashboards as JSON\n   147→  router.get(\"/dashboards/json\", (req: Request, res: Response) => {\n   148→    const tenantId = req.user!.tenantId;\n   149→\n   150→    const dashboards = db\n   151→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   152→      .all(tenantId) as DashboardRow[];\n   153→\n   154→    const mapped = dashboards.map((d) => ({\n   155→      id: d.id,\n   156→      name: d.name,\n   157→      ownerId: d.owner_id,\n   158→      config: JSON.parse(d.config),\n   159→      createdAt: d.created_at,\n   160→      updatedAt: d.updated_at,\n   161→    }));\n   162→\n   163→    res.json(mapped);\n   164→  });\n   165→\n   166→  // Export dashboards as CSV\n   167→  router.get(\"/dashboards/csv\", (req: Request, res: Response) => {\n   168→    const tenantId = req.user!.tenantId;\n   169→\n   170→    const dashboards = db\n   171→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   172→      .all(tenantId) as DashboardRow[];\n   173→\n   174→    res.setHeader(\"Content-Type\", \"text/csv\");\n   175→    res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n   176→    res.send(dashboardsToCsv(dashboards));\n   177→  });\n   178→\n   179→  return router;\n   180→}\n   181→"}]},"parent_tool_use_id":"toolu_01FWdwZszs7opk9MocezgZVD","session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"0824fa03-c764-4bd2-a7fc-fae00eeadd21"}
