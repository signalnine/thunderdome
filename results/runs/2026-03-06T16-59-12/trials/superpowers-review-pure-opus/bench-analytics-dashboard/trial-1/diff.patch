    46→      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    47→    );\n    48→\n    49→    const insertMany = db.transaction((evts: typeof events) => {\n    50→      const results: { id: string; name: string }[] = [];\n    51→      for (const evt of evts) {\n    52→        if (!evt.name) continue;\n    53→        const id = uuidv4();\n    54→        const eventTimestamp = evt.timestamp || new Date().toISOString();\n    55→        const eventProperties = JSON.stringify(evt.properties || {});\n    56→        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId, evt.sessionId || null);\n    57→        results.push({ id, name: evt.name });\n    58→      }\n    59→      return results;\n    60→    });\n    61→\n    62→    const results = insertMany(events);\n    63→\n    64→    res.status(201).json({ inserted: results.length, events: results });\n    65→  });\n    66→\n    67→  return router;\n    68→}\n    69→"}]},"parent_tool_use_id":null,"session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"2b5ad250-1686-475e-aab4-4046ac8a585a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/routes/events.ts","content":"import { Router, Request, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport { authMiddleware } from \"../auth.js\";\n\nexport function createEventRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(authMiddleware);\n\n  // Ingest single event\n  router.post(\"/\", (req: Request, res: Response) => {\n    const { name, properties, timestamp, sessionId } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: \"Event name is required\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const tenantId = req.user!.tenantId;\n    const userId = req.user!.userId;\n    const eventTimestamp = timestamp || new Date().toISOString();\n    const eventProperties = JSON.stringify(properties || {});\n\n    db.prepare(\n      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, sessionId || null);\n\n    res.status(201).json({ id, name, tenantId, timestamp: eventTimestamp });\n  });\n\n  // Ingest batch events\n  router.post(\"/batch\", (req: Request, res: Response) => {\n    const { events } = req.body;\n\n    if (!Array.isArray(events) || events.length === 0) {\n      res.status(400).json({ error: \"events array is required and must not be empty\" });\n      return;\n    }\n\n    const tenantId = req.user!.tenantId;\n    const userId = req.user!.userId;\n\n    const insert = db.prepare(\n      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    );\n\n    const insertMany = db.transaction((evts: typeof events) => {\n      const results: { id: string; name: string }[] = [];\n      for (const evt of evts) {\n        if (!evt.name) continue;\n        const id = uuidv4();\n        const eventTimestamp = evt.timestamp || new Date().toISOString();\n        const eventProperties = JSON.stringify(evt.properties || {});\n        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId, evt.sessionId || null);\n        results.push({ id, name: evt.name });\n      }\n      return results;\n    });\n\n    const results = insertMany(events);\n\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  return router;\n}\n","numLines":69,"startLine":1,"totalLines":69}}}
