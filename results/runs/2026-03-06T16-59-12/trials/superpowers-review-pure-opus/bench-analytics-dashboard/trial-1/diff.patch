te);\n    }\n\n    if (filters && typeof filters === \"object\") {\n      for (const [key, value] of Object.entries(filters)) {\n        sql += \" AND json_extract(properties, ?) = ?\";\n        params.push(`$.${key}`, value);\n      }\n    }\n\n    const result = db.prepare(sql).get(...params) as { count: number };\n\n    res.json({ count: result.count });\n  });\n\n  // Timeseries query\n  router.post(\"/timeseries\", (req: Request, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { eventName, startDate, endDate, interval, filters } = req.body;\n\n    if (!eventName) {\n      res.status(400).json({ error: \"eventName is required\" });\n      return;\n    }\n\n    const bucket = interval || \"day\";\n    let dateFormat: string;\n\n    switch (bucket) {\n      case \"hour\":\n        dateFormat = \"%Y-%m-%dT%H:00:00\";\n        break;\n      case \"day\":\n        dateFormat = \"%Y-%m-%d\";\n        break;\n      case \"week\":\n        dateFormat = \"%Y-W%W\";\n        break;\n      case \"month\":\n        dateFormat = \"%Y-%m\";\n        break;\n      default:\n        dateFormat = \"%Y-%m-%d\";\n    }\n\n    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;\n    const params: unknown[] = [tenantId, eventName];\n\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(startDate);\n    }\n\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    if (filters && typeof filters === \"object\") {\n      for (const [key, value] of Object.entries(filters)) {\n        sql += \" AND json_extract(properties, ?) = ?\";\n        params.push(`$.${key}`, value);\n      }\n    }\n\n    sql += \" GROUP BY bucket ORDER BY bucket ASC\";\n\n    const results = db.prepare(sql).all(...params) as { bucket: string; count: number }[];\n\n    res.json({ eventName, interval: bucket, data: results });\n  });\n\n  // Breakdown query\n  router.post(\"/breakdown\", (req: Request, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { eventName, property, startDate, endDate, filters } = req.body;\n\n    if (!eventName || !property) {\n      res.status(400).json({ error: \"eventName and property are required\" });\n      return;\n    }\n\n    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;\n    const params: unknown[] = [`$.${property}`, tenantId, eventName];\n\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(startDate);\n    }\n\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    if (filters && typeof filters === \"object\") {\n      for (const [key, value] of Object.entries(filters)) {\n        sql += \" AND json_extract(properties, ?) = ?\";\n        params.push(`$.${key}`, value);\n      }\n    }\n\n    sql += \" AND json_extract(properties, ?) IS NOT NULL GROUP BY value ORDER BY count DESC\";\n    params.push(`$.${property}`);\n\n    const results = db.prepare(sql).all(...params) as { value: string; count: number }[];\n\n    res.json({ eventName, property, data: results });\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":2,"oldLines":6,"newStart":2,"newLines":25,"lines":[" import Database from \"better-sqlite3\";"," import { authMiddleware } from \"../auth.js\";"," ","+const VALID_PROPERTY_KEY = /^[a-zA-Z0-9_.-]+$/;","+","+function applyFilters(","+  sql: string,","+  params: unknown[],","+  filters: Record<string, unknown> | undefined","+): { sql: string; error?: string } {","+  if (filters && typeof filters === \"object\") {","+    for (const [key, value] of Object.entries(filters)) {","+      if (!VALID_PROPERTY_KEY.test(key)) {","+        return { sql, error: `Invalid filter key: ${key}` };","+      }","+      sql += \" AND json_extract(properties, ?) = ?\";","+      params.push(`$.${key}`