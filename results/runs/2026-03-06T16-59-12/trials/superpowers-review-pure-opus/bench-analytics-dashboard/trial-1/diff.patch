+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U5r6RsyRxvN4KQXcApCVaT","type":"tool_result","content":"     1→import { Router, Request, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { v4 as uuidv4 } from \"uuid\";\n     4→import { authMiddleware } from \"../auth.js\";\n     5→\n     6→export function createEventRouter(db: Database.Database): Router {\n     7→  const router = Router();\n     8→\n     9→  router.use(authMiddleware);\n    10→\n    11→  // Ingest single event\n    12→  router.post(\"/\", (req: Request, res: Response) => {\n    13→    const { name, properties, timestamp, sessionId } = req.body;\n    14→\n    15→    if (!name) {\n    16→      res.status(400).json({ error: \"Event name is required\" });\n    17→      return;\n    18→    }\n    19→\n    20→    const id = uuidv4();\n    21→    const tenantId = req.user!.tenantId;\n    22→    const userId = req.user!.userId;\n    23→    const eventTimestamp = timestamp || new Date().toISOString();\n    24→    const eventProperties = JSON.stringify(properties || {});\n    25→\n    26→    db.prepare(\n    27→      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    28→    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, sessionId || null);\n    29→\n    30→    res.status(201).json({ id, name, tenantId, timestamp: eventTimestamp });\n    31→  });\n    32→\n    33→  // Ingest batch events\n    34→  router.post(\"/batch\", (req: Request, res: Response) => {\n    35→    const { events } = req.body;\n    36→\n    37→    if (!Array.isArray(events) || events.length === 0) {\n    38→      res.status(400).json({ error: \"events array is required and must not be empty\" });\n    39→      return;\n    40→    }\n    41→\n    42→    const tenantId = req.user!.tenantId;\n    43→    const userId = req.user!.userId;\n    44→\n    45→    const insert = db.prepare(\n    46→      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    47→    );\n    48→\n    49→    const insertMany = db.transaction((evts: typeof events) => {\n    50→      const results: { id: string; name: string }[] = [];\n    51→      for (const evt of evts) {\n    52→        if (!evt.name) continue;\n    53→        const id = uuidv4();\n    54→        const eventTimestamp = evt.timestamp || new Date().toISOString();\n    55→        const eventProperties = JSON.stringify(evt.properties || {});\n    56→        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId, evt.sessionId || null);\n    57→        results.push({ id, name: evt.name });\n    58→      }\n    59→      return results;\n    60→    });\n    61→\n    62→    const results = insertMany(events);\n    63→\n    64→    res.status(201).json({ inserted: results.length, events: results });\n    65→  });\n    66→\n    67→  return router;\n    68→}\n    69→"}]},"parent_tool_use_id":"toolu_01FWdwZszs7opk9MocezgZVD","session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"d476e367-a16e-4654-8798-3954f64008d4"}
