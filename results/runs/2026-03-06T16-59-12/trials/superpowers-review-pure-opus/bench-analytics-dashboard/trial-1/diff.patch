+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C4amxHhhY3u7q8wHCCF9k1","type":"tool_result","content":"     1→import { Router, Request, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { authMiddleware } from \"../auth.js\";\n     4→\n     5→export function createQueryRouter(db: Database.Database): Router {\n     6→  const router = Router();\n     7→\n     8→  router.use(authMiddleware);\n     9→\n    10→  // Count query\n    11→  router.post(\"/count\", (req: Request, res: Response) => {\n    12→    const tenantId = req.user!.tenantId;\n    13→    const { eventName, startDate, endDate, filters } = req.body;\n    14→\n    15→    let sql = \"SELECT COUNT(*) as count FROM events WHERE tenant_id = ?\";\n    16→    const params: unknown[] = [tenantId];\n    17→\n    18→    if (eventName) {\n    19→      sql += \" AND name = ?\";\n    20→      params.push(eventName);\n    21→    }\n    22→\n    23→    if (startDate) {\n    24→      sql += \" AND timestamp >= ?\";\n    25→      params.push(startDate);\n    26→    }\n    27→\n    28→    if (endDate) {\n    29→      sql += \" AND timestamp <= ?\";\n    30→      params.push(endDate);\n    31→    }\n    32→\n    33→    if (filters && typeof filters === \"object\") {\n    34→      for (const [key, value] of Object.entries(filters)) {\n    35→        sql += \" AND json_extract(properties, ?) = ?\";\n    36→        params.push(`$.${key}`, value);\n    37→      }\n    38→    }\n    39→\n    40→    const result = db.prepare(sql).get(...params) as { count: number };\n    41→\n    42→    res.json({ count: result.count });\n    43→  });\n    44→\n    45→  // Timeseries query\n    46→  router.post(\"/timeseries\", (req: Request, res: Response) => {\n    47→    const tenantId = req.user!.tenantId;\n    48→    const { eventName, startDate, endDate, interval, filters } = req.body;\n    49→\n    50→    if (!eventName) {\n    51→      res.status(400).json({ error: \"eventName is required\" });\n    52→      return;\n    53→    }\n    54→\n    55→    const bucket = interval || \"day\";\n    56→    let dateFormat: string;\n    57→\n    58→    switch (bucket) {\n    59→      case \"hour\":\n    60→        dateFormat = \"%Y-%m-%dT%H:00:00\";\n    61→        break;\n    62→      case \"day\":\n    63→        dateFormat = \"%Y-%m-%d\";\n    64→        break;\n    65→      case \"week\":\n    66→        dateFormat = \"%Y-W%W\";\n    67→        break;\n    68→      case \"month\":\n    69→        dateFormat = \"%Y-%m\";\n    70→        break;\n    71→      default:\n    72→        dateFormat = \"%Y-%m-%d\";\n    73→    }\n    74→\n    75→    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;\n    76→    const params: unknown[] = [tenantId, eventName];\n    77→\n    78→    if (startDate) {\n    79→      sql += \" AND timestamp >= ?\";\n    80→      params.push(startDate);\n    81→    }\n    82→\n    83→    if (endDate) {\n    84→      sql += \" AND timestamp <= ?\";\n    85→      params.push(endDate);\n    86→    }\n    87→\n    88→    if (filters && typeof filters === \"object\") {\n    89→      for (const [key, value] of Object.entries(filters)) {\n    90→        sql += \" AND json_extract(properties, ?) = ?\";\n    91→        params.push(`$.${key}`, value);\n    92→      }\n    93→    }\n    94→\n    95→    sql += \" GROUP BY bucket ORDER BY bucket ASC\";\n    96→\n    97→    const results = db.prepare(sql).all(...params) as { bucket: string; count: number }[];\n    98→\n    99→    res.json({ eventName, interval: bucket, data: results });\n   100→  });\n   101→\n   102→  // Breakdown query\n   103→  router.post(\"/breakdown\", (req: Request, res: Response) => {\n   104→    const tenantId = req.user!.tenantId;\n   105→    const { eventName, property, startDate, endDate, filters } = req.body;\n   106→\n   107→    if (!eventName || !property) {\n   108→      res.status(400).json({ error: \"eventName and property are required\" });\n   109→      return;\n   110→    }\n   111→\n   112→    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;\n   113→    const params: unknown[] = [`$.${property}`, tenantId, eventName];\n   114→\n   115→    if (startDate) {\n   116→      sql += \" AND timestamp >= ?\";\n   117→      params.push(startDate);\n   118→    }\n   119→\n   120→    if (endDate) {\n   121→      sql += \" AND timestamp <= ?\";\n   122→      params.push(endDate);\n   123→    }\n   124→\n   125→    if (filters && typeof filters === \"object\") {\n   126→      for (const [key, value] of Object.entries(filters)) {\n   127→        sql += \" AND json_extract(properties, ?) = ?\";\n   128→        params.push(`$.${key}`, value);\n   129→      }\n   130→    }\n   131→\n   132→    sql += \" AND json_extract(properties, ?) IS NOT NULL GROUP BY value ORDER BY count DESC\";\n   133→    params.push(`$.${property}`);\n   134→\n   135→    const results = db.prepare(sql).all(...params) as { value: string; count: number }[];\n   136→\n   137→    res.json({ eventName, property, data: results });\n   138→  });\n   139→\n   140→  return router;\n   141→}\n   142→"}]},"parent_tool_use_id":"toolu_01FWdwZszs7opk9MocezgZVD","session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"06248bfe-aa03-4c62-b5d4-9498f23ead1a"}
