")];\n\n  for (const d of dashboards) {\n    const row = [\n      escapeCsvField(d.id),\n      escapeCsvField(d.name),\n      escapeCsvField(d.owner_id),\n      escapeCsvField(d.config),\n      escapeCsvField(d.created_at),\n      escapeCsvField(d.updated_at),\n    ];\n    lines.push(row.join(\",\"));\n  }\n\n  return lines.join(\"\\n\");\n}\n\nexport function createExportRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(authMiddleware);\n\n  // Export events as JSON\n  router.get(\"/events/json\", (req: Request, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { eventName, startDate, endDate } = req.query;\n\n    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    const params: unknown[] = [tenantId];\n\n    if (eventName) {\n      sql += \" AND name = ?\";\n      params.push(eventName);\n    }\n\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(startDate);\n    }\n\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    sql += \" ORDER BY timestamp DESC\";\n\n    const events = db.prepare(sql).all(...params) as EventRow[];\n\n    const mapped = events.map((e) => ({\n      id: e.id,\n      name: e.name,\n      properties: JSON.parse(e.properties),\n      timestamp: e.timestamp,\n      userId: e.user_id,\n      sessionId: e.session_id,\n    }));\n\n    res.json(mapped);\n  });\n\n  // Export events as CSV\n  router.get(\"/events/csv\", (req: Request, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { eventName, startDate, endDate } = req.query;\n\n    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    const params: unknown[] = [tenantId];\n\n    if (eventName) {\n      sql += \" AND name = ?\";\n      params.push(eventName);\n    }\n\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(startDate);\n    }\n\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    sql += \" ORDER BY timestamp DESC\";\n\n    const events = db.prepare(sql).all(...params) as EventRow[];\n\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    res.send(eventsToCsv(events));\n  });\n\n  // Export dashboards as JSON\n  router.get(\"/dashboards/json\", (req: Request, res: Response) => {\n    const tenantId = req.user!.tenantId;\n\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n      .all(tenantId) as DashboardRow[];\n\n    const mapped = dashboards.map((d) => ({\n      id: d.id,\n      name: d.name,\n      ownerId: d.owner_id,\n      config: JSON.parse(d.config),\n      createdAt: d.created_at,\n      updatedAt: d.updated_at,\n    }));\n\n    res.json(mapped);\n  });\n\n  // Export dashboards as CSV\n  router.get(\"/dashboards/csv\", (req: Request, res: Response) => {\n    const tenantId = req.user!.tenantId;\n\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n      .all(tenantId) as DashboardRow[];\n\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n    res.send(dashboardsToCsv(dashboards));\n  });\n\n  return router;\n}\n","numLines":181,"startLine":1,"totalLines":181}}}
