+import express from "express";
+import { createDb } from "./db.js";
+import { createUserRouter } from "./routes/users.js";
+import { createEventRouter } from "./routes/events.js";
+import { createQueryRouter } from "./routes/queries.js";
+import { createDashboardRouter } from "./routes/dashboards.js";
+import { createExportRouter } from "./routes/export.js";
+
+export function createApp(dbPath?: string): express.Application {
+  const app = express();
+  const db = createDb(dbPath);
+
+  app.use(express.json({ limit: "1mb" }));
+
+  app.get("/health", (_req, res) => {
+    res.json({ status: "ok" });
+  });
+
+  app.use("/api/users", createUserRouter(db));
+  app.use("/api/events", createEventRouter(db));
+  app.use("/api/queries", createQueryRouter(db));
+  app.use("/api/dashboards", createDashboardRouter(db));
+  app.use("/api/export", createExportRouter(db));
+
+  return app;
+}
