+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BKRQjzMB7zoRKBn6uZR95X","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016Tp7kYVNV8WXacXysRCtHA","name":"Write","input":{"file_path":"/workspace/src/routes/export.ts","content":"import { Router, Request, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { authMiddleware } from \"../auth.js\";\n\ninterface EventRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  properties: string;\n  timestamp: string;\n  user_id: string | null;\n  session_id: string | null;\n}\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\nconst DEFAULT_LIMIT = 10000;\nconst MAX_LIMIT = 50000;\n\nfunction escapeCsvField(value: string): string {\n  if (value.includes(\",\") || value.includes('\"') || value.includes(\"\\n\")) {\n    return `\"${value.replace(/\"/g, '\"\"')}\"`;\n  }\n  return value;\n}\n\nfunction eventsToCsv(events: EventRow[]): string {\n  const headers = [\"id\", \"name\", \"properties\", \"timestamp\", \"user_id\", \"session_id\"];\n  const lines = [headers.join(\",\")];\n\n  for (const event of events) {\n    const row = [\n      escapeCsvField(event.id),\n      escapeCsvField(event.name),\n      escapeCsvField(event.properties),\n      escapeCsvField(event.timestamp),\n      escapeCsvField(event.user_id || \"\"),\n      escapeCsvField(event.session_id || \"\"),\n    ];\n    lines.push(row.join(\",\"));\n  }\n\n  return lines.join(\"\\n\");\n}\n\nfunction dashboardsToCsv(dashboards: DashboardRow[]): string {\n  const headers = [\"id\", \"name\", \"owner_id\", \"config\", \"created_at\", \"updated_at\"];\n  const lines = [headers.join(\",\")];\n\n  for (const d of dashboards) {\n    const row = [\n      escapeCsvField(d.id),\n      escapeCsvField(d.name),\n      escapeCsvField(d.owner_id),\n      escapeCsvField(d.config),\n      escapeCsvField(d.created_at),\n      escapeCsvField(d.updated_at),\n    ];\n    lines.push(row.join(\",\"));\n  }\n\n  return lines.join(\"\\n\");\n}\n\nfunction queryEvents(db: Database.Database, req: Request): EventRow[] {\n  const tenantId = req.user!.tenantId;\n  const { eventName, startDate, endDate } = req.query;\n\n  let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n  const params: unknown[] = [tenantId];\n\n  if (eventName) {\n    sql += \" AND name = ?\";\n    params.push(eventName);\n  }\n\n  if (startDate) {\n    sql += \" AND timestamp >= ?\";\n    params.push(startDate);\n  }\n\n  if (endDate) {\n    sql += \" AND timestamp <= ?\";\n    params.push(endDate);\n  }\n\n  sql += \" ORDER BY timestamp DESC\";\n\n  const limit = Math.min(\n    Number(req.query.limit) || DEFAULT_LIMIT,\n    MAX_LIMIT\n  );\n  const offset = Number(req.query.offset) || 0;\n  sql += \" LIMIT ? OFFSET ?\";\n  params.push(limit, offset);\n\n  return db.prepare(sql).all(...params) as EventRow[];\n}\n\nexport function createExportRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(authMiddleware);\n\n  // Export events as JSON\n  router.get(\"/events/json\", (req: Request, res: Response) => {\n    const events = queryEvents(db, req);\n\n    const mapped = events.map((e) => ({\n      id: e.id,\n      name: e.name,\n      properties: JSON.parse(e.properties),\n      timestamp: e.timestamp,\n      userId: e.user_id,\n      sessionId: e.session_id,\n    }));\n\n    res.json(mapped);\n  });\n\n  // Export events as CSV\n  router.get(\"/events/csv\", (req: Request, res: Response) => {\n    const events = queryEvents(db, req);\n\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    res.send(eventsToCsv(events));\n  });\n\n  // Export dashboards as JSON\n  router.get(\"/dashboards/json\", (req: Request, res: Response) => {\n    const tenantId = req.user!.tenantId;\n\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n      .all(tenantId) as DashboardRow[];\n\n    const mapped = dashboards.map((d) => ({\n      id: d.id,\n      name: d.name,\n      ownerId: d.owner_id,\n      config: JSON.parse(d.config),\n      createdAt: d.created_at,\n      updatedAt: d.updated_at,\n    }));\n\n    res.json(mapped);\n  });\n\n  // Export dashboards as CSV\n  router.get(\"/dashboards/csv\", (req: Request, res: Response) => {\n    const tenantId = req.user!.tenantId;\n\n    const dashboards = db\n      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n      .all(tenantId) as DashboardRow[];\n\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n    res.send(dashboardsToCsv(dashboards));\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2524,"cache_read_input_tokens":51070,"cache_creation":{"ephemeral_5m_input_tokens":2524,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"3913f168-34f3-445c-ba27-f0ec3ee9a339"}
