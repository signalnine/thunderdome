tion((evts: typeof events) => {\n      const results: { id: string; name: string }[] = [];\n      for (const evt of evts) {\n        if (!evt.name) continue;\n        const id = uuidv4();\n        const eventTimestamp = evt.timestamp || new Date().toISOString();\n        const eventProperties = JSON.stringify(evt.properties || {});\n        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId, evt.sessionId || null);\n        results.push({ id, name: evt.name });\n      }\n      return results;\n    });\n\n    const results = insertMany(events);\n\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":794,"cache_read_input_tokens":20724,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":794},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"b027df7f-7ec4-435f-b564-3937ab9b0a31"}
