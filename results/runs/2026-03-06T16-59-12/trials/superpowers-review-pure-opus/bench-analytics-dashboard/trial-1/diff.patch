+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013SBURRNCy1mSRvbi1YD5fV","type":"tool_result","content":"     1→import { Request, Response, NextFunction } from \"express\";\n     2→import jwt from \"jsonwebtoken\";\n     3→\n     4→const JWT_SECRET = process.env.JWT_SECRET || \"analytics-dashboard-secret\";\n     5→\n     6→export interface JwtPayload {\n     7→  userId: string;\n     8→  email: string;\n     9→  tenantId: string;\n    10→  role: string;\n    11→}\n    12→\n    13→declare module \"express-serve-static-core\" {\n    14→  interface Request {\n    15→    user?: JwtPayload;\n    16→  }\n    17→}\n    18→\n    19→export function signToken(payload: JwtPayload): string {\n    20→  return jwt.sign(payload, JWT_SECRET, { expiresIn: \"24h\" });\n    21→}\n    22→\n    23→export function verifyToken(token: string): JwtPayload {\n    24→  return jwt.verify(token, JWT_SECRET) as JwtPayload;\n    25→}\n    26→\n    27→export function authMiddleware(\n    28→  req: Request,\n    29→  res: Response,\n    30→  next: NextFunction\n    31→): void {\n    32→  const header = req.headers.authorization;\n    33→  if (!header || !header.startsWith(\"Bearer \")) {\n    34→    res.status(401).json({ error: \"Authentication required\" });\n    35→    return;\n    36→  }\n    37→\n    38→  const token = header.slice(7);\n    39→  try {\n    40→    const payload = verifyToken(token);\n    41→    req.user = payload;\n    42→    next();\n    43→  } catch {\n    44→    res.status(401).json({ error: \"Invalid or expired token\" });\n    45→  }\n    46→}\n    47→"}]},"parent_tool_use_id":"toolu_01FWdwZszs7opk9MocezgZVD","session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"c5e657ce-955b-468e-b3b7-6d0a2abccbf1"}
