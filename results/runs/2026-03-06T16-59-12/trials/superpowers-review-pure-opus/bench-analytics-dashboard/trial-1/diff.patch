@@ -0,0 +1,89 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { authMiddleware } from "../auth.js";
+
+export function createEventRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // Ingest single event
+  router.post("/", (req: Request, res: Response) => {
+    const { name, properties, timestamp, sessionId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = JSON.stringify(properties || {});
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, sessionId || null);
+
+    res.status(201).json({ id, name, tenantId, timestamp: eventTimestamp });
+  });
+
+  // Ingest batch events
+  router.post("/batch", (req: Request, res: Response) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const MAX_BATCH_SIZE = 1000;
+    if (events.length > MAX_BATCH_SIZE) {
+      res.status(400).json({ error: `Batch size exceeds maximum of ${MAX_BATCH_SIZE}` });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const skipped: { index: number; reason: string }[] = [];
+
+    const insertMany = db.transaction((evts: typeof events) => {
+      const results: { id: string; name: string }[] = [];
+      for (let i = 0; i < evts.length; i++) {
+        const evt = evts[i];
+        if (!evt.name) {
+          skipped.push({ index: i, reason: "missing event name" });
+          continue;
+        }
+        const id = uuidv4();
+        const eventTimestamp = evt.timestamp || new Date().toISOString();
+        const eventProperties = JSON.stringify(evt.properties || {});
+        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId, evt.sessionId || null);
+        results.push({ id, name: evt.name });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+
+    const response: { inserted: number; events: { id: string; name: string }[]; skipped?: { index: number; reason: string }[] } = {
+      inserted: results.length,
+      events: results,
+    };
+
+    if (skipped.length > 0) {
+      response.skipped = skipped;
+    }
+
+    res.status(201).json(response);
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
new file mode 100644
index 0000000..1b76a25
--- /dev/null
+++ b/src/routes/export.ts
@@ -0,0 +1,172 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { authMiddleware } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+const DEFAULT_LIMIT = 10000;
+const MAX_LIMIT = 50000;
+
+function escapeCsvField(value: string): string {
+  if (value.includes(",") || value.includes('"') || value.includes("\n")) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const lines = [headers.join(",")];
+
+  for (const event of events) {
+    const row = [
+      escapeCsvField(event.id),
+      escapeCsvField(event.name),
+      escapeCsvField(event.properties),
+      escapeCsvField(event.timestamp),
+      escapeCsvField(event.user_id || ""),
+      escapeCsvField(event.session_id || ""),
+    ];
+    lines.push(row.join(","));
+  }
+
+  return lines.join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const headers = ["id", "name", "owner_id", "config", "created_at", "updated_at"];
+  const lines = [headers.join(",")];
+
+  for (const d of dashboards) {
+    const row = [
+      escapeCsvField(d.id),
+      escapeCsvField(d.name),
+      escapeCsvField(d.owner_id),
+      escapeCsvField(d.config),
+      escapeCsvField(d.created_at),
+      escapeCsvField(d.updated_at),
+    ];
+    lines.push(row.join(","));
+  }
+
+  return lines.join("\n");
+}
+
+function queryEvents(db: Database.Database, req: Request): EventRow[] {
+  const tenantId = req.user!.tenantId;
+  const { eventName, startDate, endDate } = req.query;
+
+  let sql = "SELECT * FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [tenantId];
+
+  if (eventName) {
+    sql += " AND name = ?";
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  sql += " ORDER BY timestamp DESC";
+
+  const limit = Math.min(
+    Number(req.query.limit) || DEFAULT_LIMIT,
+    MAX_LIMIT
+  );
+  const offset = Number(req.query.offset) || 0;
+  sql += " LIMIT ? OFFSET ?";
+  params.push(limit, offset);
+
+  return db.prepare(sql).all(...params) as EventRow[];
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // Export events as JSON
+  router.get("/events/json", (req: Request, res: Response) => {
+    const events = queryEvents(db, req);
+
+    const mapped = events.map((e) => ({
+      id: e.id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.json(mapped);
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", (req: Request, res: Response) => {
+    const events = queryEvents(db, req);
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    const mapped = dashboards.map((d) => ({
+      id: d.id,
+      name: d.name,
+      ownerId: d.owner_id,
+      config: JSON.parse(d.config),
+      createdAt: d.created_at,
+      updatedAt: d.updated_at,
+    }));
+
+    res.json(mapped);
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(dashboardsToCsv(dashboards));
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..a66dae8
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,165 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { authMiddleware } from "../auth.js";
+
+const VALID_PROPERTY_KEY = /^[a-zA-Z0-9_.-]+$/;
+
+function applyFilters(
+  sql: string,
+  params: unknown[],
+  filters: Record<string, unknown> | undefined
+): { sql: string; error?: string } {
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      if (!VALID_PROPERTY_KEY.test(key)) {
+        return { sql, error: `Invalid filter key: ${key}` };
+      }
+      sql += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, value);
+    }
+  }
+  return { sql };
+}
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // Count query
+  router.post("/count", (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    const filterResult = applyFilters(sql, params, filters);
+    if (filterResult.error) {
+      res.status(400).json({ error: filterResult.error });
+      return;
+    }
+    sql = filterResult.sql;
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    if (!eventName) {
+      res.status(400).json({ error: "eventName is required" });
+      return;
+    }
+
+    const bucket = interval || "day";
+    let dateFormat: string;
+
+    switch (bucket) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "day":
+        dateFormat = "%Y-%m-%d";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "month":
+        dateFormat = "%Y-%m";
+        break;
+      default:
+        dateFormat = "%Y-%m-%d";
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+    const params: unknown[] = [tenantId, eventName];
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    const filterResult = applyFilters(sql, params, filters);
+    if (filterResult.error) {
+      res.status(400).json({ error: filterResult.error });
+      return;
+    }
+    sql = filterResult.sql;
+
+    sql += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const results = db.prepare(sql).all(...params) as { bucket: string; count: number }[];
+
+    res.json({ eventName, interval: bucket, data: results });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, property, startDate, endDate, filters } = req.body;
+
+    if (!eventName || !property) {
+      res.status(400).json({ error: "eventName and property are required" });
+      return;
+    }
+
+    if (!VALID_PROPERTY_KEY.test(property)) {
+      res.status(400).json({ error: `Invalid property key: ${property}` });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId, eventName];
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    const filterResult = applyFilters(sql, params, filters);
+    if (filterResult.error) {
+      res.status(400).json({ error: filterResult.error });
+      return;
+    }
+    sql = filterResult.sql;
+
+    sql += " AND json_extract(properties, ?) IS NOT NULL GROUP BY value ORDER BY count DESC";
+    params.push(`$.${property}`);
+
+    const results = db.prepare(sql).all(...params) as { value: string; count: number }[];
+
+    res.json({ eventName, property, data: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..89d3a85
--- /dev/null
+++ b/src/routes/users.ts
@@ -0,0 +1,146 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { randomBytes, scryptSync } from "crypto";
+import { v4 as uuidv4 } from "uuid";
+import { signToken, authMiddleware } from "../auth.js";
+
+function hashPassword(password: string, salt?: string): string {
+  const useSalt = salt || randomBytes(16).toString("hex");
+  const hash = scryptSync(password, useSalt, 64).toString("hex");
+  return `${useSalt}:${hash}`;
+}
+
+function verifyPassword(password: string, stored: string): boolean {
+  const [salt, hash] = stored.split(":");
+  if (!salt || !hash) return false;
+  const derived = scryptSync(password, salt, 64).toString("hex");
+  return derived === hash;
+}
+
+export function createUserRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Register
+  router.post("/register", (req: Request, res: Response) => {
+    const { email, password, tenantId, role } = req.body;
+
+    if (!email || !password || !tenantId) {
+      res.status(400).json({ error: "email, password, and tenantId are required" });
+      return;
+    }
+
+    const existing = db.prepare("SELECT id FROM users WHERE email = ?").get(email);
+    if (existing) {
+      res.status(409).json({ error: "Email already registered" });
+      return;
+    }
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+    const userRole = role && ["admin", "viewer", "editor"].includes(role) ? role : "viewer";
+
+    db.prepare(
+      "INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, email, passwordHash, tenantId, userRole);
+
+    const token = signToken({ userId: id, email, tenantId, role: userRole });
+
+    res.status(201).json({
+      id,
+      email,
+      tenantId,
+      role: userRole,
+      token,
+    });
+  });
+
+  // Login
+  router.post("/login", (req: Request, res: Response) => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: "email and password are required" });
+      return;
+    }
+
+    const user = db
+      .prepare("SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?")
+      .get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;
+
+    if (!user || !verifyPassword(password, user.password_hash)) {
+      res.status(401).json({ error: "Invalid credentials" });
+      return;
+    }
+
+    const token = signToken({
+      userId: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+    });
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      token,
+    });
+  });
+
+  // Get profile
+  router.get("/me", authMiddleware, (req: Request, res: Response) => {
+    const user = db
+      .prepare("SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?")
+      .get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: "User not found" });
+      return;
+    }
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      createdAt: user.created_at,
+    });
+  });
+
+  // Update user role (admin only)
+  router.patch("/:userId/role", authMiddleware, (req: Request, res: Response) => {
+    if (req.user!.role !== "admin") {
+      res.status(403).json({ error: "Only admins can change roles" });
+      return;
+    }
+
+    const { role } = req.body;
+    const { userId } = req.params;
+
+    if (!role || !["admin", "viewer", "editor"].includes(role)) {
+      res.status(400).json({ error: "Valid role is required (admin, viewer, editor)" });
+      return;
+    }
+
+    const target = db
+      .prepare("SELECT id, tenant_id FROM users WHERE id = ?")
+      .get(userId) as { id: string; tenant_id: string } | undefined;
+
+    if (!target) {
+      res.status(404).json({ error: "User not found" });
+      return;
+    }
+
+    if (target.tenant_id !== req.user!.tenantId) {
+      res.status(403).json({ error: "Cannot modify users in other tenants" });
+      return;
+    }
+
+    db.prepare("UPDATE users SET role = ? WHERE id = ?").run(role, userId);
+
+    res.json({ id: userId, role });
+  });
+
+  return router;
+}
