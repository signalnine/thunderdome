+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jbx4xRb5Ew1k9AxkH7FMdF","type":"tool_result","content":"File created successfully at: /workspace/tests/api.test.ts"}]},"parent_tool_use_id":null,"session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"f8ddbaf2-81a0-49bf-9986-783807d6e167","tool_use_result":{"type":"create","filePath":"/workspace/tests/api.test.ts","content":"import { describe, it, expect, beforeEach } from \"vitest\";\nimport request from \"supertest\";\nimport { createApp } from \"../src/app.js\";\nimport type { Application } from \"express\";\n\nlet app: Application;\n\nbeforeEach(() => {\n  app = createApp(\":memory:\");\n});\n\nasync function registerUser(\n  overrides: Record<string, string> = {}\n): Promise<request.Response> {\n  return request(app)\n    .post(\"/api/users/register\")\n    .send({\n      email: overrides.email || \"test@example.com\",\n      password: \"password123\",\n      tenantId: overrides.tenantId || \"tenant-1\",\n      role: overrides.role || \"admin\",\n    });\n}\n\nasync function getToken(overrides: Record<string, string> = {}): Promise<string> {\n  const res = await registerUser(overrides);\n  return res.body.token;\n}\n\ndescribe(\"User Management\", () => {\n  it(\"should register a user\", async () => {\n    const res = await registerUser();\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty(\"id\");\n    expect(res.body).toHaveProperty(\"token\");\n    expect(res.body.email).toBe(\"test@example.com\");\n    expect(res.body.tenantId).toBe(\"tenant-1\");\n    expect(res.body.role).toBe(\"admin\");\n  });\n\n  it(\"should reject duplicate email\", async () => {\n    await registerUser();\n    const res = await registerUser();\n    expect(res.status).toBe(409);\n  });\n\n  it(\"should login\", async () => {\n    await registerUser();\n    const res = await request(app)\n      .post(\"/api/users/login\")\n      .send({ email: \"test@example.com\", password: \"password123\" });\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty(\"token\");\n  });\n\n  it(\"should reject bad credentials\", async () => {\n    await registerUser();\n    const res = await request(app)\n      .post(\"/api/users/login\")\n      .send({ email: \"test@example.com\", password: \"wrong\" });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"should get profile\", async () => {\n    const token = await getToken();\n    const res = await request(app)\n      .get(\"/api/users/me\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.email).toBe(\"test@example.com\");\n  });\n\n  it(\"should require auth for profile\", async () => {\n    const res = await request(app).get(\"/api/users/me\");\n    expect(res.status).toBe(401);\n  });\n\n  it(\"should allow admin to change roles\", async () => {\n    const adminToken = await getToken();\n    const viewerRes = await registerUser({ email: \"viewer@example.com\", role: \"viewer\" });\n    const viewerId = viewerRes.body.id;\n\n    const res = await request(app)\n      .patch(`/api/users/${viewerId}/role`)\n      .set(\"Authorization\", `Bearer ${adminToken}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe(\"editor\");\n  });\n\n  it(\"should not allow non-admin to change roles\", async () => {\n    const adminRes = await registerUser();\n    const viewerToken = (await registerUser({ email: \"viewer@example.com\", role: \"viewer\" })).body.token;\n\n    const res = await request(app)\n      .patch(`/api/users/${adminRes.body.id}/role`)\n      .set(\"Authorization\", `Bearer ${viewerToken}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(403);\n  });\n\n  it(\"should not allow cross-tenant role changes\", async () => {\n    const adminToken = await getToken();\n    const otherUser = await registerUser({ email: \"other@example.com\", tenantId: \"tenant-2\" });\n\n    const res = await request(app)\n      .patch(`/api/users/${otherUser.body.id}/role`)\n      .set(\"Authorization\", `Bearer ${adminToken}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(403);\n  });\n});\n\ndescribe(\"Event Ingestion\", () => {\n  it(\"should ingest a single event\", async () => {\n    const token = await getToken();\n    const res = await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\", properties: { url: \"/home\" } });\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty(\"id\");\n    expect(res.body.name).toBe(\"page_view\");\n  });\n\n  it(\"should ingest batch events\", async () => {\n    const token = await getToken();\n    const res = await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"click\", properties: { button: \"signup\" } },\n          { name: \"page_view\", properties: { url: \"/about\" } },\n        ],\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.inserted).toBe(3);\n  });\n\n  it(\"should require auth for events\", async () => {\n    const res = await request(app)\n      .post(\"/api/events\")\n      .send({ name: \"page_view\" });\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe(\"Query Engine\", () => {\n  async function seedEvents(token: string) {\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-01T14:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-02T10:00:00Z\" },\n          { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-01T12:00:00Z\" },\n        ],\n      });\n  }\n\n  it(\"should count events\", async () => {\n    const token = await getToken();\n    await seedEvents(token);\n\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\" });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(3);\n  });\n\n  it(\"should count events with date range\", async () => {\n    const token = await getToken();\n    await seedEvents(token);\n\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", startDate: \"2024-01-01\", endDate: \"2024-01-01T23:59:59Z\" });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(2);\n  });\n\n  it(\"should return timeseries\", async () => {\n    const token = await getToken();\n    await seedEvents(token);\n\n    const res = await request(app)\n      .post(\"/api/queries/timeseries\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", interval: \"day\" });\n    expect(res.status).toBe(200);\n    expect(res.body.data).toHaveLength(2);\n    expect(res.body.data[0].count).toBe(2);\n    expect(res.body.data[1].count).toBe(1);\n  });\n\n  it(\"should return breakdown\", async () => {\n    const token = await getToken();\n    await seedEvents(token);\n\n    const res = await request(app)\n      .post(\"/api/queries/breakdown\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", property: \"url\" });\n    expect(res.status).toBe(200);\n    expect(res.body.data).toHaveLength(2);\n    expect(res.body.data[0].value).toBe(\"/home\");\n    expect(res.body.data[0].count).toBe(2);\n  });\n\n  it(\"should enforce tenant isolation on queries\", async () => {\n    const token1 = await getToken();\n    const token2 = await getToken({ email: \"other@example.com\", tenantId: \"tenant-2\" });\n\n    await seedEvents(token1);\n\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token2}`)\n      .send({});\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(0);\n  });\n});\n\ndescribe(\"Dashboard CRUD\", () => {\n  it(\"should create a dashboard\", async () => {\n    const token = await getToken();\n    const res = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Main Dashboard\", config: { widgets: [] } });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"Main Dashboard\");\n  });\n\n  it(\"should list dashboards\", async () => {\n    const token = await getToken();\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 2\" });\n\n    const res = await request(app)\n      .get(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveLength(2);\n  });\n\n  it(\"should get a single dashboard\", async () => {\n    const token = await getToken();\n    const createRes = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n\n    const res = await request(app)\n      .get(`/api/dashboards/${createRes.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"Dashboard 1\");\n  });\n\n  it(\"should update a dashboard\", async () => {\n    const token = await getToken();\n    const createRes = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n\n    const res = await request(app)\n      .put(`/api/dashboards/${createRes.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Updated Dashboard\" });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"Updated Dashboard\");\n  });\n\n  it(\"should delete a dashboard\", async () => {\n    const token = await getToken();\n    const createRes = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n\n    const res = await request(app)\n      .delete(`/api/dashboards/${createRes.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/api/dashboards/${createRes.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it(\"should enforce tenant isolation on dashboards\", async () => {\n    const token1 = await getToken();\n    const token2 = await getToken({ email: \"other@example.com\", tenantId: \"tenant-2\" });\n\n    const createRes = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token1}`)\n      .send({ name: \"Tenant 1 Dashboard\" });\n\n    const res = await request(app)\n      .get(`/api/dashboards/${createRes.body.id}`)\n      .set(\"Authorization\", `Bearer ${token2}`);\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe(\"Data Export\", () => {\n  it(\"should export events as JSON\", async () => {\n    const token = await getToken();\n    await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\", properties: { url: \"/home\" } });\n\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.body)).toBe(true);\n    expect(res.body).toHaveLength(1);\n    expect(res.body[0].name).toBe(\"page_view\");\n  });\n\n  it(\"should export events as CSV\", async () => {\n    const token = await getToken();\n    await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\", properties: { url: \"/home\" } });\n\n    const res = await request(app)\n      .get(\"/api/export/events/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,name,properties,timestamp\");\n    expect(res.text).toContain(\"page_view\");\n  });\n\n  it(\"should export dashboards as JSON\", async () => {\n    const token = await getToken();\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n\n    const res = await request(app)\n      .get(\"/api/export/dashboards/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveLength(1);\n    expect(res.body[0].name).toBe(\"My Dashboard\");\n  });\n\n  it(\"should export dashboards as CSV\", async () => {\n    const token = await getToken();\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n\n    const res = await request(app)\n      .get(\"/api/export/dashboards/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"My Dashboard\");\n  });\n\n  it(\"should enforce tenant isolation on exports\", async () => {\n    const token1 = await getToken();\n    const token2 = await getToken({ email: \"other@example.com\", tenantId: \"tenant-2\" });\n\n    await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token1}`)\n      .send({ name: \"page_view\" });\n\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token2}`);\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveLength(0);\n  });\n\n  it(\"should require auth for exports\", async () => {\n    const res = await request(app).get(\"/api/export/events/json\");\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
