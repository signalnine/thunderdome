+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0124jqLNdfC5NppNj5xoWk6P","type":"tool_result","content":"     1→import { Router, Request, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { createHash } from \"crypto\";\n     4→import { v4 as uuidv4 } from \"uuid\";\n     5→import { signToken, authMiddleware } from \"../auth.js\";\n     6→\n     7→function hashPassword(password: string): string {\n     8→  return createHash(\"sha256\").update(password).digest(\"hex\");\n     9→}\n    10→\n    11→export function createUserRouter(db: Database.Database): Router {\n    12→  const router = Router();\n    13→\n    14→  // Register\n    15→  router.post(\"/register\", (req: Request, res: Response) => {\n    16→    const { email, password, tenantId, role } = req.body;\n    17→\n    18→    if (!email || !password || !tenantId) {\n    19→      res.status(400).json({ error: \"email, password, and tenantId are required\" });\n    20→      return;\n    21→    }\n    22→\n    23→    const existing = db.prepare(\"SELECT id FROM users WHERE email = ?\").get(email);\n    24→    if (existing) {\n    25→      res.status(409).json({ error: \"Email already registered\" });\n    26→      return;\n    27→    }\n    28→\n    29→    const id = uuidv4();\n    30→    const passwordHash = hashPassword(password);\n    31→    const userRole = role && [\"admin\", \"viewer\", \"editor\"].includes(role) ? role : \"viewer\";\n    32→\n    33→    db.prepare(\n    34→      \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n    35→    ).run(id, email, passwordHash, tenantId, userRole);\n    36→\n    37→    const token = signToken({ userId: id, email, tenantId, role: userRole });\n    38→\n    39→    res.status(201).json({\n    40→      id,\n    41→      email,\n    42→      tenantId,\n    43→      role: userRole,\n    44→      token,\n    45→    });\n    46→  });\n    47→\n    48→  // Login\n    49→  router.post(\"/login\", (req: Request, res: Response) => {\n    50→    const { email, password } = req.body;\n    51→\n    52→    if (!email || !password) {\n    53→      res.status(400).json({ error: \"email and password are required\" });\n    54→      return;\n    55→    }\n    56→\n    57→    const user = db\n    58→      .prepare(\"SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?\")\n    59→      .get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;\n    60→\n    61→    if (!user || user.password_hash !== hashPassword(password)) {\n    62→      res.status(401).json({ error: \"Invalid credentials\" });\n    63→      return;\n    64→    }\n    65→\n    66→    const token = signToken({\n    67→      userId: user.id,\n    68→      email: user.email,\n    69→      tenantId: user.tenant_id,\n    70→      role: user.role,\n    71→    });\n    72→\n    73→    res.json({\n    74→      id: user.id,\n    75→      email: user.email,\n    76→      tenantId: user.tenant_id,\n    77→      role: user.role,\n    78→      token,\n    79→    });\n    80→  });\n    81→\n    82→  // Get profile\n    83→  router.get(\"/me\", authMiddleware, (req: Request, res: Response) => {\n    84→    const user = db\n    85→      .prepare(\"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\")\n    86→      .get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;\n    87→\n    88→    if (!user) {\n    89→      res.status(404).json({ error: \"User not found\" });\n    90→      return;\n    91→    }\n    92→\n    93→    res.json({\n    94→      id: user.id,\n    95→      email: user.email,\n    96→      tenantId: user.tenant_id,\n    97→      role: user.role,\n    98→      createdAt: user.created_at,\n    99→    });\n   100→  });\n   101→\n   102→  // Update user role (admin only)\n   103→  router.patch(\"/:userId/role\", authMiddleware, (req: Request, res: Response) => {\n   104→    if (req.user!.role !== \"admin\") {\n   105→      res.status(403).json({ error: \"Only admins can change roles\" });\n   106→      return;\n   107→    }\n   108→\n   109→    const { role } = req.body;\n   110→    const { userId } = req.params;\n   111→\n   112→    if (!role || ![\"admin\", \"viewer\", \"editor\"].includes(role)) {\n   113→      res.status(400).json({ error: \"Valid role is required (admin, viewer, editor)\" });\n   114→      return;\n   115→    }\n   116→\n   117→    const target = db\n   118→      .prepare(\"SELECT id, tenant_id FROM users WHERE id = ?\")\n   119→      .get(userId) as { id: string; tenant_id: string } | undefined;\n   120→\n   121→    if (!target) {\n   122→      res.status(404).json({ error: \"User not found\" });\n   123→      return;\n   124→    }\n   125→\n   126→    if (target.tenant_id !== req.user!.tenantId) {\n   127→      res.status(403).json({ error: \"Cannot modify users in other tenants\" });\n   128→      return;\n   129→    }\n   130→\n   131→    db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, userId);\n   132→\n   133→    res.json({ id: userId, role });\n   134→  });\n   135→\n   136→  return router;\n   137→}\n   138→"}]},"parent_tool_use_id":"toolu_01FWdwZszs7opk9MocezgZVD","session_id":"26144cbc-5dd3-4b02-8ce7-89a4f2d20a8c","uuid":"9abc7e77-fc42-406e-af67-cac1cbac548b"}
