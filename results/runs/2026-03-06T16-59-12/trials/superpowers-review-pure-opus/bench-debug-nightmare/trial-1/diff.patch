lculateOrderTotal(items, discountPercent, taxRate);\n    47‚Üí\n    48‚Üí    const record: PaymentRecord = {\n    49‚Üí      orderId,\n    50‚Üí      amount: breakdown.total,\n    51‚Üí      method: paymentMethod,\n    52‚Üí      status: 'charged',\n    53‚Üí      processedAt: Date.now(),\n    54‚Üí    };\n    55‚Üí\n    56‚Üí    this.payments.set(orderId, record);\n    57‚Üí    this.notificationService.sendConfirmation(orderId, breakdown.total);\n    58‚Üí    return record;\n    59‚Üí  }\n    60‚Üí\n    61‚Üí  private async handleRefund(data: unknown): Promise<void> {\n    62‚Üí    const event = data as { orderId: string; amount: number };\n    63‚Üí    const payment = this.payments.get(event.orderId);\n    64‚Üí    if (payment) {\n    65‚Üí      payment.status = 'refunded';\n    66‚Üí      this.notificationService.sendRefundNotice(event.orderId, event.amount);\n    67‚Üí    }\n    68‚Üí  }\n    69‚Üí\n    70‚Üí  async issueRefund(orderId: string, amount: number): Promise<PaymentRecord | undefined> {\n    71‚Üí    const payment = this.payments.get(orderId);\n    72‚Üí    if (!payment) return undefined;\n    73‚Üí\n    74‚Üí    payment.status = 'refunded';\n    75‚Üí\n    76‚Üí    await this.eventBus.emit(ORDER_EVENTS.REFUNDED, {\n    77‚Üí      orderId,\n    78‚Üí      amount,\n    79‚Üí      timestamp: Date.now(),\n    80‚Üí    });\n    81‚Üí\n    82‚Üí    return { ...payment };\n    83‚Üí  }\n    84‚Üí\n    85‚Üí  getPayment(orderId: string): PaymentRecord | undefined {\n    86‚Üí    const p = this.payments.get(orderId);\n    87‚Üí    return p ? { ...p } : undefined;\n    88‚Üí  }\n    89‚Üí\n    90‚Üí  clear(): void {\n    91‚Üí    this.payments.clear();\n    92‚Üí  }\n    93‚Üí}\n    94‚Üí"}]},"parent_tool_use_id":null,"session_id":"733e2a01-32f2-4a6b-a7bf-4e1327aa4a91","uuid":"32c15d26-d4ea-47bc-b213-e4629d2a9cc9","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/billing/service.ts","content":"import { EventBus } from '../events/bus.js';\nimport { ORDER_EVENTS } from '../events/types.js';\nimport { NotificationService } from '../notifications/service.js';\nimport { calculateOrderTotal } from './calculator.js';\nimport { OrderItem } from '../orders/repository.js';\n\nexport interface PaymentRecord {\n  orderId: string;\n  amount: number;\n  method: string;\n  status: 'charged' | 'refunded';\n  processedAt: number;\n}\n\nexport class BillingService {\n  private payments: Map<string, PaymentRecord> = new Map();\n\n  constructor(\n    private eventBus: EventBus,\n    private notificationService: NotificationService\n  ) {}\n\n  registerHandlers(): void {\n    this.eventBus.on(ORDER_EVENTS.STOCK_RESERVED, this.handleStockReserved.bind(this));\n    this.eventBus.on(ORDER_EVENTS.REFUNDED, this.handleRefund);\n  }\n\n  private async handleStockReserved(data: unknown): Promise<void> {\n    const event = data as { orderId: string; items: OrderItem[] };\n    // Payment would be charged here in a real system\n    await this.eventBus.emit(ORDER_EVENTS.PAYMENT_CHARGED, {\n      orderId: event.orderId,\n      amount: 0, // Actual amount set by order service\n      paymentMethod: 'card',\n      timestamp: Date.now(),\n    });\n  }\n\n  async chargePayment(\n    orderId: string,\n    items: OrderItem[],\n    discountPercent: number,\n    taxRate: number,\n    paymentMethod: string\n  ): Promise<PaymentRecord> {\n    const breakdown = calculateOrderTotal(items, discountPercent, taxRate);\n\n    const record: PaymentRecord = {\n      orderId,\n      amount: breakdown.total,\n      method: paymentMethod,\n      status: 'charged',\n      processedAt: Date.now(),\n    };\n\n    this.payments.set(orderId, record);\n    this.notificationService.sendConfirmation(orderId, breakdown.total);\n    return record;\n  }\n\n  private async handleRefund(data: unknown): Promise<void> {\n    const event = data as { orderId: string; amount: number };\n    const payment = this.payments.get(event.orderId);\n    if (payment) {\n      payment.status = 'refunded';\n      this.notificationService.sendRefundNotice(event.orderId, event.amount);\n    }\n  }\n\n  async issueRefund(orderId: string, amount: number): Promise<PaymentRecord | undefined> {\n    const payment = this.payments.get(orderId);\n    if (!payment) return undefined;\n\n    payment.status = 'refunded';\n\n    await this.eventBus.emit(ORDER_EVENTS.REFUNDED, {\n      orderId,\n      amount,\n      timestamp: Date.now(),\n    });\n\n    return { ...payment };\n  }\n\n  getPayment(orderId: string): PaymentRecord | undefined {\n    const p = this.payments.get(orderId);\n    return p ? { ...p } : undefined;\n  }\n\n  clear(): void {\n    this.payments.clear();\n  }\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
