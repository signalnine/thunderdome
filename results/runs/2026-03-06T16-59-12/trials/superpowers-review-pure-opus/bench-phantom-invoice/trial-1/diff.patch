to correct month', () => {\n    43→    // Invoice on March 1 should be in month 3, not month 2\n    44→    createInvoice(db, {\n    45→      customer_id: 'cust-1',\n    46→      date: '2024-03-01',\n    47→      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n    48→    });\n    49→    const report = getMonthlyReport(db, 2024);\n    50→    const march = report.find(r => r.month === 3);\n    51→    const feb = report.find(r => r.month === 2);\n    52→\n    53→    expect(march).toBeDefined();\n    54→    expect(march!.count).toBe(1);\n    55→    expect(march!.total_revenue).toBe(200);\n    56→    expect(feb).toBeUndefined();\n    57→  });\n    58→\n    59→  it('multiple months reporting shows correct distribution', () => {\n    60→    createInvoice(db, {\n    61→      customer_id: 'cust-1', date: '2024-04-15',\n    62→      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n    63→    });\n    64→    createInvoice(db, {\n    65→      customer_id: 'cust-1', date: '2024-05-15',\n    66→      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n    67→    });\n    68→    createInvoice(db, {\n    69→      customer_id: 'cust-1', date: '2024-06-15',\n    70→      subtotal: 300, discount_rate: 0, tax_rate: 0, total: 300, status: 'paid',\n    71→    });\n    72→\n    73→    const report = getMonthlyReport(db, 2024);\n    74→    expect(report).toHaveLength(3);\n    75→    expect(report[0].month).toBe(4);\n    76→    expect(report[1].month).toBe(5);\n    77→    expect(report[2].month).toBe(6);\n    78→    expect(report[0].total_revenue).toBe(100);\n    79→    expect(report[1].total_revenue).toBe(200);\n    80→    expect(report[2].total_revenue).toBe(300);\n    81→  });\n    82→\n    83→  it('zero discount rate still calculates correctly', () => {\n    84→    // subtotal=1000, 0% discount => 1000, 7% tax => 1070\n    85→    const total = calculateInvoiceTotal(1000, 0, 0.07);\n    86→    expect(total).toBe(1070);\n    87→  });\n    88→\n    89→  it('100% discount rate results in zero total', () => {\n    90→    const total = calculateInvoiceTotal(500, 1.0, 0.1);\n    91→    expect(total).toBe(0);\n    92→  });\n    93→\n    94→  it('formatDate produces correct ISO string', () => {\n    95→    const date = new Date(Date.UTC(2024, 5, 15)); // June 15, 2024\n    96→    expect(formatDate(date)).toBe('2024-06-15');\n    97→  });\n    98→\n    99→  it('large invoice totals maintain precision', () => {\n   100→    // subtotal=99999.99, 5% discount => 94999.9905, 10% tax => 104499.98955 => 104499.99\n   101→    const total = calculateInvoiceTotal(99999.99, 0.05, 0.1);\n   102→    expect(total).toBe(104499.99);\n   103→  });\n   104→\n   105→  it('date range with single day span returns matching invoices', () => {\n   106→    createInvoice(db, {\n   107→      customer_id: 'cust-1',\n   108→      date: '2024-09-15',\n   109→      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n   110→    });\n   111→    createInvoice(db, {\n   112→      customer_id: 'cust-1',\n   113→      date: '2024-09-16',\n   114→      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n   115→    });\n   116→\n   117→    // Single day range should only include the one on that day\n   118→    const invoices = getInvoicesByDateRange(db, '2024-09-15', '2024-09-15');\n   119→    expect(invoices).toHaveLength(1);\n   120→    expect(invoices[0].date).toBe('2024-09-15');\n   121→  });\n   122→});\n   123→"}]},"parent_tool_use_id":"toolu_01C755pGaPZtdS7HUo7GUEkA","session_id":"2c74f393-3c08-4792-a5cf-9e718f2c9579","uuid":"0d947524-52d7-4fd0-af58-605b95d1d847"}
