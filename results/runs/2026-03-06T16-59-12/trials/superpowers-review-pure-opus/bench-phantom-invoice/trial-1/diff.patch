+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AZXDJjidp6usSZJ5gisbFn","type":"tool_result","content":"import type Database from 'better-sqlite3';\nimport type { Invoice, LineItem } from '../models/invoice.js';\n\n/**\n * Retrieve invoices within a date range (inclusive on both ends).\n */\nexport function getInvoicesByDateRange(\n  db: Database.Database,\n  startDate: string,\n  endDate: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE date >= ? AND date < ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(startDate, endDate) as Invoice[];\n}\n\n/**","is_error":false}]},"parent_tool_use_id":"toolu_01C755pGaPZtdS7HUo7GUEkA","session_id":"2c74f393-3c08-4792-a5cf-9e718f2c9579","uuid":"802a613b-a8d8-4fb9-b588-415e04610a6a"}
