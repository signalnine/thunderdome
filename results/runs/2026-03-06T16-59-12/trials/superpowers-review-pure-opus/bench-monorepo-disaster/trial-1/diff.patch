expect(canDelete('user')).toBe(false);\n    48→  });\n    49→\n    50→  it('requirePermission throws when permission is missing', () => {\n    51→    expect(() => requirePermission('viewer', 'write')).toThrow(\n    52→      \"Role 'viewer' does not have permission 'write'\"\n    53→    );\n    54→  });\n    55→});\n    56→"}]},"parent_tool_use_id":"toolu_01DyfVEMZUVAHgx2yQxLbECm","session_id":"eaa994b6-2159-4285-87fd-06ff0333b73b","uuid":"807f8531-f928-4f17-8ff8-9cb6865746c2"}
