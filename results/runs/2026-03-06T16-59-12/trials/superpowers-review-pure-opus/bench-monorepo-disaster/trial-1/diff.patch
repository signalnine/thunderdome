+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AJJRTddq7kBD52pbb9uS5A","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import request from 'supertest';\n     3→import { createApp } from '../src/index.js';\n     4→import { resetDefaultConnection } from '@monorepo/core';\n     5→\n     6→describe('User Routes', () => {\n     7→  let app: ReturnType<typeof createApp>;\n     8→\n     9→  beforeEach(() => {\n    10→    resetDefaultConnection();\n    11→    app = createApp();\n    12→  });\n    13→\n    14→  it('creates user with valid data', async () => {\n    15→    const res = await request(app)\n    16→      .post('/users')\n    17→      .set('x-user-role', 'admin')\n    18→      .send({ name: 'Test', email: 'test@test.com', role: 'user' });\n    19→    expect(res.status).toBe(201);\n    20→    expect(res.body.user.name).toBe('Test');\n    21→  });\n    22→\n    23→  it('rejects user creation without admin role', async () => {\n    24→    const res = await request(app)\n    25→      .post('/users')\n    26→      .set('x-user-role', 'viewer')\n    27→      .send({ name: 'Test', email: 'test@test.com', role: 'user' });\n    28→    expect(res.status).toBe(403);\n    29→  });\n    30→\n    31→  it('returns 400 for invalid user data', async () => {\n    32→    const res = await request(app)\n    33→      .post('/users')\n    34→      .set('x-user-role', 'admin')\n    35→      .send({ name: '', email: 'not-email', role: 'user' });\n    36→    expect(res.status).toBe(400);\n    37→  });\n    38→\n    39→  it('lists all users', async () => {\n    40→    // Create a user first\n    41→    await request(app)\n    42→      .post('/users')\n    43→      .set('x-user-role', 'admin')\n    44→      .send({ name: 'Alice', email: 'alice@test.com', role: 'user' });\n    45→\n    46→    const res = await request(app)\n    47→      .get('/users')\n    48→      .set('x-user-role', 'admin');\n    49→    expect(res.status).toBe(200);\n    50→    expect(res.body.users).toHaveLength(1);\n    51→  });\n    52→\n    53→  it('gets user by id', async () => {\n    54→    const createRes = await request(app)\n    55→      .post('/users')\n    56→      .set('x-user-role', 'admin')\n    57→      .send({ name: 'Bob', email: 'bob@test.com', role: 'user' });\n    58→\n    59→    const res = await request(app)\n    60→      .get(`/users/${createRes.body.user.id}`)\n    61→      .set('x-user-role', 'admin');\n    62→    expect(res.status).toBe(200);\n    63→    expect(res.body.user.name).toBe('Bob');\n    64→  });\n    65→\n    66→  it('returns 404 for nonexistent user', async () => {\n    67→    const res = await request(app)\n    68→      .get('/users/999')\n    69→      .set('x-user-role', 'admin');\n    70→    expect(res.status).toBe(404);\n    71→  });\n    72→\n    73→  it('returns 400 for invalid user id', async () => {\n    74→    const res = await request(app)\n    75→      .get('/users/abc')\n    76→      .set('x-user-role', 'admin');\n    77→    expect(res.status).toBe(400);\n    78→  });\n    79→\n    80→  it('returns 409 for duplicate email', async () => {\n    81→    await request(app)\n    82→      .post('/users')\n    83→      .set('x-user-role', 'admin')\n    84→      .send({ name: 'First', email: 'dup@test.com', role: 'user' });\n    85→\n    86→    const res = await request(app)\n    87→      .post('/users')\n    88→      .set('x-user-role', 'admin')\n    89→      .send({ name: 'Second', email: 'dup@test.com', role: 'user' });\n    90→    expect(res.status).toBe(409);\n    91→  });\n    92→});\n    93→"}]},"parent_tool_use_id":"toolu_01CMRwmpfCz6N7W6t4ac3UMu","session_id":"eaa994b6-2159-4285-87fd-06ff0333b73b","uuid":"c7c37e7c-bc6f-4294-ba1d-19605b6ca524"}
