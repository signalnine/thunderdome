Log[0] corresponds to logStartVersion. */\n  operationLog: Operation[];\n  clients: Map<string, ClientConnection>;\n}\n\n// Message types from client\ninterface ClientOperationMessage {\n  type: \"operation\";\n  version: number;\n  operation: Operation;\n}\n\n// Message types to client\ninterface ServerSyncMessage {\n  type: \"sync\";\n  content: string;\n  version: number;\n  documentId: string;\n}\n\ninterface ServerOperationMessage {\n  type: \"operation\";\n  operation: Operation;\n  version: number;\n  clientId: string;\n}\n\ninterface ServerAckMessage {\n  type: \"ack\";\n  version: number;\n}\n\ninterface ServerErrorMessage {\n  type: \"error\";\n  message: string;\n}\n\ntype ServerMessage =\n  | ServerSyncMessage\n  | ServerOperationMessage\n  | ServerAckMessage\n  | ServerErrorMessage;\n\nexport function createWebSocketServer(\n  server: Server,\n  repo: DocumentRepo\n): { wss: WebSocketServer; sessions: Map<string, DocumentSession>; closeAll: () => void } {\n  const wss = new WebSocketServer({ server, maxPayload: MAX_WS_PAYLOAD });\n  const sessions = new Map<string, DocumentSession>();\n\n  function getOrCreateSession(documentId: string): DocumentSession | null {\n    let session = sessions.get(documentId);\n    if (session) return session;\n\n    const doc = repo.getById(documentId);\n    if (!doc) return null;\n\n    const latestVersion = repo.getLatestVersion(documentId);\n    const serverVersion = latestVersion ? latestVersion.version : 0;\n\n    // Rehydrate operation log from database\n    const versions = repo.getVersions(documentId);\n    const operationLog: Operation[] = [];\n    let logStartVersion = 1; // operations start at version 1\n\n    for (const v of versions) {\n      if (v.operation) {\n        try {\n          operationLog.push(JSON.parse(v.operation) as Operation);\n        } catch {\n          // Skip malformed operations\n        }\n      }\n    }\n\n    // If log is too large, trim from the beginning\n    if (operationLog.length > MAX_OP_LOG_SIZE) {\n      const trimCount = operationLog.length - MAX_OP_LOG_SIZE;\n      operationLog.splice(0, trimCount);\n      logStartVersion += trimCount;\n    }\n\n    session = {\n      documentId,\n      serverVersion,\n      logStartVersion,\n      operationLog,\n      clients: new Map(),\n    };\n    sessions.set(documentId, session);\n    return session;\n  }\n\n  function sendMessage(ws: WebSocket, msg: ServerMessage) {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  function broadcastOperation(\n    session: DocumentSession,\n    operation: Operation,\n    version: number,\n    senderId: string\n  ) {\n    for (const [clientId, client] of session.clients) {\n      if (clientId === senderId) {\n        sendMessage(client.ws, { type: \"ack\", version });\n      } else {\n        sendMessage(client.ws, {\n          type: \"operation\",\n          operation,\n          version,\n          clientId: senderId,\n        });\n      }\n    }\n  }\n\n  wss.on(\"connection\", (ws: WebSocket, req: IncomingMessage) => {\n    const url = new URL(req.url || \"/\", `http://${req.headers.host || \"localhost\"}`);\n    const pathParts = url.pathname.split(\"/\").filter(Boolean);\n\n    let documentId: string | null = null;\n\n    if (pathParts.length >= 3 && pathParts[0] === \"ws\" && pathParts[1] === \"documents\") {\n      documentId = pathParts[2];\n    } else if (\n      pathParts.length >= 3 &&\n      pathParts[0] === \"documents\" &&\n      pathParts[2] === \"ws\"\n    ) {\n      documentId = pathParts[1];\n    } else if (pathParts.length >= 2 && pathParts[0] === \"documents\") {\n      documentId = pathParts[1];\n    }\n\n    if (!documentId) {\n      sendMessage(ws, {\n        type: \"error\",\n        message: \"Invalid WebSocket path. Use /ws/documents/:id\",\n      });\n      ws.close(1008, \"Invalid path\");\n      return;\n    }\n\n    const session = getOrCreateSession(documentId);\n    if (!session) {\n      sendMessage(ws, {\n        type: \"error\",\n        message: \"Document not found\",\n      });\n      ws.close(1008, \"Document not found\");\n      return;\n    }\n\n    const clientId = randomUUID();\n    const client: ClientConnection = { id: clientId, ws, documentId };\n    session.clients.set(clientId, client);\n\n    // Send current document state\n    const doc = repo.getById(documentId);\n    if (doc) {\n      sendMessage(ws, {\n        type: \"sync\",\n        content: doc.content,\n        version: session.serverVersion,\n        documentId,\n      });\n    }\n\n    ws.on(\"message\", (data) => {\n      let msg: { type: string };\n      try {\n        msg = JSON.parse(data.toString());\n      } catch {\n        sendMessage(ws, { type: \"error\", message: \"Invalid JSON\" });\n        return;\n      }\n\n      if (msg.type === \"operation\") {\n        handleOperation(session, client, msg as ClientOperationMessage);\n      } else {\n        sendMessage(ws, {\n          type: \"error\",\n          message: `Unknown message type: ${msg.type}`,\n        });\n      }\n    });\n\n    ws.on(\"close\", () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        sessions.delete(documentId!);\n      }\n    });\n\n    ws.on(\"error\", () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        sessions.delete(documentId!);\n      }\n    });\n  });\n\n  function handleOperation(\n    session: DocumentSession,\n    client: ClientConnection,\n    msg: ClientOperationMessage\n  ) {\n    const { version, operation } = msg;\n\n    if (\n      typeof version !== \"number\" ||\n      !Number.isInteger(version) ||\n      version < 0\n    ) {\n      sendMessage(client.ws, {\n        type: \"error\",\n        message: \"Invalid version number\",\n      });\n      return;\n    }\n\n    if (version > session.serverVersion) {\n      sendMessage(client.ws, {\n        type: \"error\",\n        message: `Version ${version} is ahead of server version ${session.serverVersion}`,\n      });\n      return;\n    }\n\n    // If client is too far behind, resync them\n    if (version < session.logStartVersion) {\n      const doc = repo.getById(session.documentId);\n      if (doc) {\n        sendMessage(client.ws, {\n          type: \"sync\",\n          content: doc.content,\n          version: session.serverVersion,\n          documentId: session.documentId,\n        });\n      }\n      sendMessage(client.ws, {\n        type: \"error\",\n        message: \"Client version too old, please resync\",\n      });\n      return;\n    }\n\n    if (!operation || !Array.isArray(operation.ops)) {\n      sendMessage(client.ws, {\n        type: \"error\",\n        message: \"Invalid operation structure\",\n      });\n      return;\n    }\n\n    const doc = repo.getById(session.documentId);\n    if (!doc) {\n      sendMessage(client.ws, { type: \"error\", message: \"Document not found\" });\n      return;\n    }\n\n    // Transform against all operations since the client's version\n    let transformedOp = operation;\n    try {\n      for (let i = version; i < session.serverVersion; i++) {\n        const logIdx = i - session.logStartVersion;\n        const serverOp = session.operationLog[logIdx];\n        if (!serverOp) {\n          // Resync the client\n          sendMessage(client.ws, {\n            type: \"sync\",\n            content: doc.content,\n            version: session.serverVersion,\n            documentId: session.documentId,\n          });\n          sendMessage(client.ws, {\n            type: \"error\",\n            message: \"Cannot transform: missing operation history, resynced\",\n          });\n          return;\n        }\n        const [clientPrime] = transform(transformedOp, serverOp);\n        transformedOp = clientPrime;\n      }\n    } catch (e) {\n      sendMessage(client.ws, {\n        type: \"error\",\n        message: `Transform error: ${e instanceof Error ? e.message : String(e)}`,\n      });\n      return;\n    }\n\n    const validationError = validateOperation(transformedOp, doc.content.length);\n    if (validationError) {\n      sendMessage(client.ws, {\n        type: \"error\",\n        message: `Invalid operation: ${validationError}`,\n      });\n      return;\n    }\n\n    let newContent: string;\n    try {\n      newContent = apply(doc.content, transformedOp);\n    } catch (e) {\n      sendMessage(client.ws, {\n        type: \"error\",\n        message: `Apply error: ${e instanceof Error ? e.message : String(e)}`,\n      });\n      return;\n    }\n\n    // Persist the change\n    session.serverVersion++;\n    session.operationLog.push(transformedOp);\n    repo.updateContent(session.documentId, newContent, transformedOp);\n\n    // Trim operation log if it exceeds the cap\n    if (session.operationLog.length > MAX_OP_LOG_SIZE) {\n      const trimCount = session.operationLog.length - MAX_OP_LOG_SIZE;\n      session.operationLog.splice(0, trimCount);\n      session.logStartVersion += trimCount;\n    }\n\n    broadcastOperation(session, transformedOp, session.serverVersion, client.id);\n  }\n\n  function closeAll() {\n    for (const session of sessions.values()) {\n      for (const client of session.clients.values()) {\n        client.ws.close(1001, \"Server shutting down\");\n      }\n    }\n    sessions.clear();\n    wss.close();\n  }\n\n  return { wss, sessions, closeAll };\n}\n","structuredPatch":[{"oldStart":6,"oldLines":6,"newStart":6,"newLines":9,"lines":[" import { randomUUID } from \"crypto\";"," import { URL } from \"url\";"," ","+const MAX_OP_LOG_SIZE = 1000;","+const MAX_WS_PAYLOAD = 1024 * 1024; // 1MB","+"," interface ClientConnection {","   id: string;","   ws: WebSocket;"]},{"oldStart":16,"oldLines":7,"newStart":19,"newLines":9,"lines":["   documentId: string;","   /** Current server version number for this session */","   serverVersion: number;","-  /** Log of operations applied, indexed by ve