ge>();","     expect(msg.type).toBe(\"error\");","   });"," ","   it(\"should handle version history growing with operations\", async () => {","     const doc = await createDoc(\"Test\", \"hello\");","     const ws = await connect(doc.id);","-    await waitForMessage<SyncMessage>(ws);","+    await ws.nextMessage<SyncMessage>();"," ","     const ops = [","       createInsertOp(5, 5, \" world\"),"]},{"oldStart":291,"oldLines":7,"newStart":315,"newLines":7,"lines":["       ws.send(","         JSON.stringify({ type: \"operation\", version: i + 1, operation: ops[i] })","       );","-      await waitForMessage<AckMessage>(ws);","+      await ws.nextMessage<AckMessage>();","     }"," ","     const versions = await getVersions(doc.id);"]},{"oldStart":301,"oldLines":11,"newStart":325,"newLines":11,"lines":[" ","   it(\"should handle 10 concurrent clients\", async () => {","     const doc = await createDoc(\"Test\", \"\");","-    const websockets: WebSocket[] = [];","+    const websockets: BufferedWs[] = [];"," ","     for (let i = 0; i < 10; i++) {","       const ws = await connect(doc.id);","-      await waitForMessage<SyncMessage>(ws);","+      await ws.nextMessage<SyncMessage>();","       websockets.push(ws);","     }"," "]},{"oldStart":318,"oldLines":24,"newStart":342,"newLines":14,"lines":["         JSON.stringify({ type: \"operation\", version: currentVersion, operation: op })","       );"," ","-      const ack = await waitForMessage<AckMessage>(websockets[i]);","+      const ack = await websockets[i].nextMessage<AckMessage>();","       expect(ack.type).toBe(\"ack\");","       currentVersion = ack.version;"," ","-      // Drain broadcast messages from other clients","-      await new Promise((r) => setTimeout(r, 30));","+      // Drain broadcast messages from all other clients","       for (let j = 0; j < websockets.length; j++) {","         if (j !== i) {","-          // Drain by reading any pending message","-          const drainPromise = new Promise<void>((resolve) => {","-            const handler = () => { /* drain */ };","-            websockets[j].on(\"message\", handler);","-            setTimeout(() => {","-              websockets[j].off(\"message\", handler);","-              resolve();","-            }, 10);","-          });","-          await drainPromise;","+          await websockets[j].drain(20);","         }","       }","     }"]},{"oldStart":347,"oldLines":12,"newStart":361,"newLines":12,"lines":["   it(\"should handle delete operations\", async () => {","     const doc = await createDoc(\"Test\", \"hello world\");","     const ws = await connect(doc.id);","-    await waitForMessage<SyncMessage>(ws);","+    await ws.nextMessage<SyncMessage>();"," ","     const op = createDeleteOp(11, 5, 6);","     ws.send(JSON.stringify({ type: \"operation\", version: 1, operation: op }));"," ","-    const ack = await waitForMessage<AckMessage>(ws);","+    const ack = await ws.nextMessage<AckMessage>();","     expect(ack.type).toBe(\"ack\");"," ","     const updated = await getDoc(doc.id);"]}],"originalFile":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport { createApp } from \"../src/server.js\";\nimport type { AppInstance } from \"../src/server.js\";\nimport { createInsertOp, createDeleteOp } from \"../src/ot.js\";\nimport WebSocket from \"ws\";\nimport http from \"http\";\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", (err) => reject(err));\n  });\n}\n\nfunction waitForMessage<T = unknown>(ws: WebSocket, timeoutMs = 5000): Promise<T> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(\n      () => reject(new Error(\"Timed out waiting for WS message\")),\n      timeoutMs\n    );\n    ws.once(\"message\", (data) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(data.toString()) as T);\n    });\n  });\n}\n\nfunction collectMessages(ws: WebSocket, count: number, timeoutMs = 5000): Promise<unknown[]> {\n  return new Promise((resolve, reject) => {\n    const messages: unknown[] = [];\n    const timer = setTimeout(\n      () => reject(new Error(`Timed out collecting messages (got ${messages.length}/${count})`)),\n      timeoutMs\n    );\n    const handler = (data: WebSocket.RawData) => {\n      messages.push(JSON.parse(data.toString()));\n      if (messages.length >= count) {\n        clearTimeout(timer);\n        ws.off(\"message\", handler);\n        resolve(messages);\n      }\n    };\n    ws.on(\"message\", handler);\n  });\n}\n\nfunction httpRequest(\n  port: number,\n  method: string,\n  path: string,\n  body?: unknown\n): Promise<{ status: number; body: unknown }> {\n  return new Promise((resolve, reject) => {\n    const data = body ? JSON.stringify(body) : undefined;\n    const headers: Record<string, string> = {};\n    if (data) {\n      headers[\"Content-Type\"] = \"application/json\";\n      headers[\"Content-Length\"] = String(Buffer.byteLength(data));\n    }\n\n    const req = http.request(\n      { hostname: \"localhost\", port, path, method, headers },\n      (res) => {\n        let responseBody = \"\";\n        res.on(\"data\", (chunk: string) => (responseBody += chunk));\n        res.on(\"end\", () => {\n          try {\n            resolve({\n              status: res.statusCode || 0,\n              body: responseBody ? JSON.parse(responseBody) : null,\n            });\n          } catch {\n            resolve({ status: res.statusCode || 0, body: responseBody });\n          }\n        });\n      }\n    );\n    req.on(\"error\", reject);\n    if (data) req.write(data);\n    req.end();\n  });\n}\n\ninterface SyncMessage {\n  type: \"sync\";\n  content: string;\n  version: number;\n  documentId: string;\n}\n\ninterface AckMessage {\n  type: \"ack\";\n  version: number;\n}\n\ninterface OpMessage {\n  type: \"operation\";\n  operation: unknown;\n  version: number;\n  clientId: string;\n}\n\ninterface ErrorMessage {\n  type: \"error\";\n  message: string;\n}\n\ndescribe(\"WebSocket Collaboration\", () => {\n  let instance: AppInstance;\n  let port: number;\n  const clients: WebSocket[] = [];\n\n  beforeEach(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    for (const ws of clients) {\n      if (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING) {\n        ws.close();\n      }\n    }\n    clients.length = 0;\n    await instance.stop();\n  });\n\n  async function createDoc(title: string, content = \"\"): Promise<{ id: string }> {\n    const res = await httpRequest(port, \"POST\", \"/api/documents\", { title, content });\n    return res.body as { id: string };\n  }\n\n  async function getDoc(id: string): Promise<{ id: string; content: string; title: string }> {\n    const res = await httpRequest(port, \"GET\", `/api/documents/${id}`);\n    return res.body as { id: string; content: string; title: string };\n  }\n\n  async function getVersions(id: string): Promise<Array<{ version: number; content: string }>> {\n    const res = await httpRequest(port, \"GET\", `/api/documents/${id}/versions`);\n    return res.body as Array<{ version: number; content: string }>;\n  }\n\n  async function connect(docId: string): Promise<WebSocket> {\n    const ws = await connectWs(port, docId);\n    clients.push(ws);\n    return ws;\n  }\n\n  it(\"should send sync message on connect\", async () => {\n    const doc = await createDoc(\"Test\", \"Hello\");\n    const ws = await connect(doc.id);\n    const msg = await waitForMessage<SyncMessage>(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Hello\");\n    expect(msg.version).toBe(1);\n    expect(msg.documentId).toBe(doc.id);\n  });\n\n  it(\"should reject connection for nonexistent document\", async () => {\n    return new Promise<void>((resolve) => {\n      const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n      clients.push(ws);\n      ws.on(\"message\", (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === \"error\") {\n          expect(msg.message).toContain(\"not found\");\n          resolve();\n        }\n      });\n      ws.on(\"close\", () => resolve());\n    });\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n\n    const ws1 = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws1);\n\n    const ws2 = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws2);\n\n    const op = createInsertOp(5, 5, \" world\");\n    const msgPromise = waitForMessage<OpMessage>(ws2);\n    const ackPromise = waitForMessage<AckMessage>(ws1);\n\n    ws1.send(JSON.stringify({ type: \"operation\", version: 1, operation: op }));\n\n    const ack = await ackPromise;\n    expect(ack.type).toBe(\"ack\");\n    expect(ack.version).toBe(2);\n\n    const broadcast = await msgPromise;\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(2);\n  });\n\n  it(\"should persist changes from WebSocket operations\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    const op = createInsertOp(5, 5, \" world\");\n    ws.send(JSON.stringify({ type: \"operation\", version: 1, operation: op }));\n\n    await waitForMessage<AckMessage>(ws);\n\n    const updated = await getDoc(doc.id);\n    expect(updated.content).toBe(\"hello world\");\n  });\n\n  it(\"should handle concurrent edits with OT\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n\n    const ws1 = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws1);\n\n    const ws2 = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws2);\n\n    const op1 = createInsertOp(5, 0, \"X\");\n    const op2 = createInsertOp(5, 5, \"Y\");\n\n    const ws1Messages = collectMessages(ws1, 2);\n    const ws2Messages = collectMessages(ws2, 2);\n\n    ws1.send(JSON.stringify({ type: \"operation\", version: 1, operation: op1 }));\n    await new Promise((r) => setTimeout(r, 50));\n    ws2.send(JSON.stringify({ type: \"operation\", version: 1, operation: op2 }));\n\n    const ws1Msgs = await ws1Messages;\n    const ws2Msgs = await ws2Messages;\n\n    const ws1Types = ws1Msgs.map((m) => (m as { type: string }).type);\n    expect(ws1Types).toContain(\"ack\");\n    expect(ws1Types).toContain(\"operation\");\n\n    const ws2Types = ws2Msgs.map((m) => (m as { type: string }).type);\n    expect(ws2Types).toContain(\"ack\");\n    expect(ws2Types).toContain(\"operation\");\n\n    const updated = await getDoc(doc.id);\n    expect(updated.content).toContain(\"X\");\n    expect(updated.content).toContain(\"Y\");\n    expect(updated.content).toBe(\"XhelloY\");\n  });\n\n  it(\"should handle error for invalid JSON\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    ws.send(\"not json\");\n\n    const msg = await waitForMessage<ErrorMessage>(ws);\n    expect(msg.type).toBe(\"error\");\n    expect(msg.message).toContain(\"Invalid JSON\");\n  });\n\n  it(\"should handle error for invalid operation\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: { baseLength: 999, targetLength: 999, ops: [] },\n      })\n    );\n\n    const msg = await waitForMessage<ErrorMessage>(ws);\n    expect(msg.type).toBe(\"error\");\n  });\n\n  it(\"should handle version history growing with operations\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    const ops = [\n      createInsertOp(5, 5, \" world\"),\n      createInsertOp(11, 11, \"!\"),\n      createInsertOp(12, 0, \"A \"),\n    ];\n\n    for (let i = 0; i < ops.length; i++) {\n      ws.send(\n        JSON.stringify({ type: \"operation\", version: i + 1, operation: ops[i] })\n      );\n      await waitForMessage<AckMessage>(ws);\n    }\n\n    const versions = await getVersions(doc.id);\n    expect(versions.length).toBe(4);\n    expect(versions[versions.length - 1].content).toBe(\"A hello world!\");\n  });\n\n  it(\"should handle 10 concurrent clients\", async () => {\n    const doc = await createDoc(\"Test\", \"\");\n    const websockets: WebSocket[] = [];\n\n    for (let i = 0; i < 10; i++) {\n      const ws = await connect(doc.id);\n      await waitForMessage<SyncMessage>(ws);\n      websockets.push(ws);\n    }\n\n    let currentVersion = 1;\n    for (let i = 0; i < 10; i++) {\n      const docLen = i;\n      const op = createInsertOp(docLen, docLen, String(i));\n\n      websockets[i].send(\n        JSON.stringify({ type: \"operation\", version: currentVersion, operation: op })\n      );\n\n      const ack = await waitForMessage<AckMessage>(websockets[i]);\n      expect(ack.type).toBe(\"ack\");\n      currentVersion = ack.version;\n\n      // Drain broadcast messages from other clients\n      await new Promise((r) => setTimeout(r, 30));\n      for (let j = 0; j < websockets.length; j++) {\n        if (j !== i) {\n          // Drain by reading any pending message\n          const drainPromise = new Promise<void>((resolve) => {\n            const handler = () => { /* drain */ };\n            websockets[j].on(\"message\", handler);\n            setTimeout(() => {\n              websockets[j].off(\"message\", handler);\n              resolve();\n            }, 10);\n          });\n          await drainPromise;\n        }\n      }\n    }\n\n    const updated = await getDoc(doc.id);\n    expect(updated.content).toBe(\"0123456789\");\n  });\n\n  it(\"should handle delete operations\", async () => {\n    const doc = await createDoc(\"Test\", \"hello world\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    const op = createDeleteOp(11, 5, 6);\n    ws.send(JSON.stringify({ type: \"operation\", version: 1, operation: op }));\n\n    const ack = await waitForMessage<AckMessage>(ws);\n    expect(ack.type).toBe(\"ack\");\n\n    const updated = await getDoc(doc.id);\n    expect(updated.content).toBe(\"hello\");\n  });\n});\n"}}
