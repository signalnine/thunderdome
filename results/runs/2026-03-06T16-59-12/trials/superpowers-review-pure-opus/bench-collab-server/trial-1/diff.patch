+describe("REST API", () => {
+  let instance: AppInstance;
+  let port: number;
+
+  beforeEach(async () => {
+    instance = createApp();
+    port = await instance.start(0);
+  });
+
+  afterEach(async () => {
+    await instance.stop();
+  });
+
+  describe("POST /api/documents", () => {
+    it("should create a document", async () => {
+      const res = await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "Test Doc", content: "Hello" })
+        .expect(201);
+
+      expect(res.body.title).toBe("Test Doc");
+      expect(res.body.content).toBe("Hello");
+      expect(res.body.id).toBeDefined();
+    });
+
+    it("should create a document with empty content", async () => {
+      const res = await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "Empty Doc" })
+        .expect(201);
+
+      expect(res.body.content).toBe("");
+    });
+
+    it("should reject missing title", async () => {
+      await request(instance.app)
+        .post("/api/documents")
+        .send({ content: "Hello" })
+        .expect(400);
+    });
+  });
+
+  describe("GET /api/documents", () => {
+    it("should list all documents", async () => {
+      await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "Doc 1" });
+      await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "Doc 2" });
+
+      const res = await request(instance.app).get("/api/documents").expect(200);
+
+      expect(res.body).toHaveLength(2);
+    });
+
+    it("should return empty array when no documents", async () => {
+      const res = await request(instance.app).get("/api/documents").expect(200);
+      expect(res.body).toHaveLength(0);
+    });
+  });
+
+  describe("GET /api/documents/:id", () => {
+    it("should get a document by id", async () => {
+      const createRes = await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "Test", content: "Hello" });
+
+      const res = await request(instance.app)
+        .get(`/api/documents/${createRes.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe("Test");
+      expect(res.body.content).toBe("Hello");
+    });
+
+    it("should return 404 for unknown document", async () => {
+      await request(instance.app)
+        .get("/api/documents/nonexistent")
+        .expect(404);
+    });
+  });
+
+  describe("PUT /api/documents/:id", () => {
+    it("should update a document", async () => {
+      const createRes = await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "Original" });
+
+      const res = await request(instance.app)
+        .put(`/api/documents/${createRes.body.id}`)
+        .send({ title: "Updated", content: "New content" })
+        .expect(200);
+
+      expect(res.body.title).toBe("Updated");
+      expect(res.body.content).toBe("New content");
+    });
+
+    it("should return 404 for unknown document", async () => {
+      await request(instance.app)
+        .put("/api/documents/nonexistent")
+        .send({ title: "Updated" })
+        .expect(404);
+    });
+  });
+
+  describe("PATCH /api/documents/:id", () => {
+    it("should partially update a document", async () => {
+      const createRes = await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "Original", content: "Content" });
+
+      const res = await request(instance.app)
+        .patch(`/api/documents/${createRes.body.id}`)
+        .send({ title: "Updated" })
+        .expect(200);
+
+      expect(res.body.title).toBe("Updated");
+      expect(res.body.content).toBe("Content"); // content unchanged
+    });
+  });
+
+  describe("DELETE /api/documents/:id", () => {
+    it("should delete a document", async () => {
+      const createRes = await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "To Delete" });
+
+      await request(instance.app)
+        .delete(`/api/documents/${createRes.body.id}`)
+        .expect(204);
+
+      await request(instance.app)
+        .get(`/api/documents/${createRes.body.id}`)
+        .expect(404);
+    });
+
+    it("should return 404 for unknown document", async () => {
+      await request(instance.app)
+        .delete("/api/documents/nonexistent")
+        .expect(404);
+    });
+  });
+
+  describe("GET /api/documents/:id/versions", () => {
+    it("should return version history", async () => {
+      const createRes = await request(instance.app)
+        .post("/api/documents")
+        .send({ title: "Versioned", content: "v1" });
+
+      const res = await request(instance.app)
+        .get(`/api/documents/${createRes.body.id}/versions`)
+        .expect(200);
+
+      expect(res.body).toHaveLength(1);
+      expect(res.body[0].version).toBe(1);
+      expect(res.body[0].content).toBe("v1");
+    });
+
+    it("should return 404 for unknown document", async () => {
+      await request(instance.app)
+        .get("/api/documents/nonexistent/versions")
+        .expect(404);
+    });
+  });
+});
