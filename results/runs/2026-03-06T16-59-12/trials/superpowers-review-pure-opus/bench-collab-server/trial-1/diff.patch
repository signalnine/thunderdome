export interface Version {\n  id: number;\n  document_id: string;\n  version: number;\n  content: string;\n  operation: string | null;\n  created_at: string;\n}\n\nexport function createDatabase(dbPath: string = \":memory:\"): Database.Database {\n  const db = new Database(dbPath);\n  db.pragma(\"journal_mode = WAL\");\n  db.pragma(\"foreign_keys = ON\");\n\n  const __dirname = dirname(fileURLToPath(import.meta.url));\n  const schemaPath = resolve(__dirname, \"..\", \"schema.sql\");\n  const schema = readFileSync(schemaPath, \"utf-8\");\n  db.exec(schema);\n\n  return db;\n}\n\nexport function createDocumentRepo(db: Database.Database) {\n  const insertDoc = db.prepare(\n    \"INSERT INTO documents (id, title, content, created_at, updated_at) VALUES (?, ?, ?, datetime('now'), datetime('now'))\"\n  );\n  const selectDoc = db.prepare(\"SELECT * FROM documents WHERE id = ?\");\n  const selectAllDocs = db.prepare(\n    \"SELECT * FROM documents ORDER BY updated_at DESC\"\n  );\n  const updateDocContent = db.prepare(\n    \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n  );\n  const updateDocTitle = db.prepare(\n    \"UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?\"\n  );\n  const updateDocTitleAndContent = db.prepare(\n    \"UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?\"\n  );\n  const deleteDoc = db.prepare(\"DELETE FROM documents WHERE id = ?\");\n\n  const insertVersion = db.prepare(\n    \"INSERT INTO versions (document_id, version, content, operation, created_at) VALUES (?, ?, ?, ?, datetime('now'))\"\n  );\n  const selectVersions = db.prepare(\n    \"SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC\"\n  );\n  const selectLatestVersion = db.prepare(\n    \"SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1\"\n  );\n\n  return {\n    create(title: string, content: string = \"\"): Document {\n      const id = randomUUID();\n      insertDoc.run(id, title, content);\n      // Create initial version\n      insertVersion.run(id, 1, content, null);\n      return selectDoc.get(id) as Document;\n    },\n\n    getById(id: string): Document | undefined {\n      return selectDoc.get(id) as Document | undefined;\n    },\n\n    getAll(): Document[] {\n      return selectAllDocs.all() as Document[];\n    },\n\n    update(\n      id: string,\n      updates: { title?: string; content?: string }\n    ): Document | undefined {\n      const existing = selectDoc.get(id) as Document | undefined;\n      if (!existing) return undefined;\n\n      if (updates.title !== undefined && updates.content !== undefined) {\n        updateDocTitleAndContent.run(updates.title, updates.content, id);\n      } else if (updates.title !== undefined) {\n        updateDocTitle.run(updates.title, id);\n      } else if (updates.content !== undefined) {\n        updateDocContent.run(updates.content, id);\n      }\n\n      return selectDoc.get(id) as Document;\n    },\n\n    updateContent(id: string, content: string, operation?: object): Document | undefined {\n      const existing = selectDoc.get(id) as Document | undefined;\n      if (!existing) return undefined;\n\n      updateDocContent.run(content, id);\n\n      const latest = selectLatestVersion.get(id) as Version | undefined;\n      const nextVersion = latest ? latest.version + 1 : 1;\n      insertVersion.run(\n        id,\n        nextVersion,\n        content,\n        operation ? JSON.stringify(operation) : null\n      );\n\n      return selectDoc.get(id) as Document;\n    },\n\n    delete(id: string): boolean {\n      const result = deleteDoc.run(id);\n      return result.changes > 0;\n    },\n\n    getVersions(id: string): Version[] {\n      return selectVersions.all(id) as Version[];\n    },\n\n    getLatestVersion(id: string): Version | undefined {\n      return selectLatestVersion.get(id) as Version | undefined;\n    },\n  };\n}\n\nexport type DocumentRepo = ReturnType<typeof createDocumentRepo>;\n","numLines":135,"startLine":1,"totalLines":135}}}
