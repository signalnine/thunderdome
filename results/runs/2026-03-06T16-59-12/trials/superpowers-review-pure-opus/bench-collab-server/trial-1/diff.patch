 JSON.stringify({","-          type: \"operation\",","-          version: i + 1,","-          operation: ops[i],","-        })","+        JSON.stringify({ type: \"operation\", version: i + 1, operation: ops[i] })","       );","       await waitForMessage<AckMessage>(ws);","     }"," ","-    // Check versions","-    const versions = await getVersionsViaRest(doc.id);","-    expect(versions.length).toBe(4); // initial + 3 operations","+    const versions = await getVersions(doc.id);","+    expect(versions.length).toBe(4);","     expect(versions[versions.length - 1].content).toBe(\"A hello world!\");","   });"," ","   it(\"should handle 10 concurrent clients\", async () => {","-    const doc = await createDocViaRest(\"Test\", \"\");","+    const doc = await createDoc(\"Test\", \"\");","     const websockets: WebSocket[] = [];"," ","-    // Connect 10 clients","     for (let i = 0; i < 10; i++) {","       const ws = await connect(doc.id);","       await waitForMessage<SyncMessage>(ws);","       websockets.push(ws);","     }"," ","-    // Each client inserts a character sequentially","     let currentVersion = 1;","     for (let i = 0; i < 10; i++) {","-      const docLen = i; // Document grows by 1 each time","+      const docLen = i;","       const op = createInsertOp(docLen, docLen, String(i));"," ","-      // Drain any pending broadcast messages first","-      const drainPromise = (idx: number) => {","-        return new Promise<void>((resolve) => {","-          const handler = (data: WebSocket.RawData) => {","-            const msg = JSON.parse(data.toString());","-            if (msg.type === \"operation\") {","-              // keep draining","-            }","-          };","-          websockets[idx].on(\"message\", handler);","-          setTimeout(() => {","-            websockets[idx].off(\"message\", handler);","-            resolve();","-          }, 10);","-        });","-      };","-","       websockets[i].send(","-        JSON.stringify({","-          type: \"operation\",","-          version: currentVersion,","-          operation: op,","-        })","+        JSON.stringify({ type: \"operation\", version: currentVersion, operation: op })","       );"," ","-      // Wait for ack to this client","       const ack = await waitForMessage<AckMessage>(websockets[i]);","       expect(ack.type).toBe(\"ack\");","       currentVersion = ack.version;"," ","-      // Wait for broadcasts to propagate","-      await new Promise((r) => setTimeout(r, 20));","-","-      // Drain broadcast messages from all other clients","-      for (let j = 0; j < 10; j++) {","+      // Drain broadcast messages from other clients","+      await new Promise((r) => setTimeout(r, 30));","+      for (let j = 0; j < websockets.length; j++) {","         if (j !== i) {","-          await drainPromise(j);","+          // Drain by reading any pending message","+          const drainPromise = new Promise<void>((resolve) => {","+            const handler = () => { /* drain */ };","+            websockets[j].on(\"message\", handler);","+            setTimeout(() => {","+              websockets[j].off(\"message\", handler);","+              resolve();","+            }, 10);","+          });","+          await drainPromise;","         }","       }","     }"," ","-    // Verify final document","-    const updated = await getDocViaRest(doc.id);","+    const updated = await getDoc(doc.id);","     expect(updated.content).toBe(\"0123456789\");","   });"," ","   it(\"should handle delete operations\", async () => {","-    const doc = await createDocViaRest(\"Test\", \"hello world\");","+    const doc = await createDoc(\"Test\", \"hello world\");","     const ws = await connect(doc.id);","     await waitForMessage<SyncMessage>(ws);"," ","-    const op = createDeleteOp(11, 5, 6); // delete \" world\"","-    ws.send(","-      JSON.stringify({","-        type: \"operation\",","-        version: 1,","-        operation: op,","-      })","-    );","+    const op = createDeleteOp(11, 5, 6);","+    ws.send(JSON.stringify({ type: \"operation\", version: 1, operation: op }));"," ","     const ack = await waitForMessage<AckMessage>(ws);","     expect(ack.type).toBe(\"ack\");"," ","-    const updated = await getDocViaRest(doc.id);","+    const updated = await getDoc(doc.id);","     expect(updated.content).toBe(\"hello\");","   });"," });"]}],"originalFile":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport { createApp } from \"../src/server.js\";\nimport type { AppInstance } from \"../src/server.js\";\nimport { createInsertOp, createDeleteOp } from \"../src/ot.js\";\nimport WebSocket from \"ws\";\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", (err) => reject(err));\n  });\n}\n\nfunction waitForMessage<T = unknown>(ws: WebSocket, timeoutMs = 5000): Promise<T> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(\n      () => reject(new Error(\"Timed out waiting for WS message\")),\n      timeoutMs\n    );\n    ws.once(\"message\", (data) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(data.toString()) as T);\n    });\n  });\n}\n\nfunction collectMessages(ws: WebSocket, count: number, timeoutMs = 5000): Promise<unknown[]> {\n  return new Promise((resolve, reject) => {\n    const messages: unknown[] = [];\n    const timer = setTimeout(\n      () => reject(new Error(`Timed out collecting messages (got ${messages.length}/${count})`)),\n      timeoutMs\n    );\n    const handler = (data: WebSocket.RawData) => {\n      messages.push(JSON.parse(data.toString()));\n      if (messages.length >= count) {\n        clearTimeout(timer);\n        ws.off(\"message\", handler);\n        resolve(messages);\n      }\n    };\n    ws.on(\"message\", handler);\n  });\n}\n\ninterface SyncMessage {\n  type: \"sync\";\n  content: string;\n  version: number;\n  documentId: string;\n}\n\ninterface AckMessage {\n  type: \"ack\";\n  version: number;\n}\n\ninterface OpMessage {\n  type: \"operation\";\n  operation: unknown;\n  version: number;\n  clientId: string;\n}\n\ninterface ErrorMessage {\n  type: \"error\";\n  message: string;\n}\n\ndescribe(\"WebSocket Collaboration\", () => {\n  let instance: AppInstance;\n  let port: number;\n  const clients: WebSocket[] = [];\n\n  beforeEach(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    for (const ws of clients) {\n      if (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING) {\n        ws.close();\n      }\n    }\n    clients.length = 0;\n    await instance.stop();\n  });\n\n  async function createDocViaRest(title: string, content: string = \"\"): Promise<{ id: string }> {\n    // Use native http to avoid supertest dependency issues\n    return new Promise((resolve, reject) => {\n      const data = JSON.stringify({ title, content });\n      const http = await import(\"http\");\n      const req = http.request(\n        {\n          hostname: \"localhost\",\n          port,\n          path: \"/api/documents\",\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Content-Length\": Buffer.byteLength(data),\n          },\n        },\n        (res) => {\n          let body = \"\";\n          res.on(\"data\", (chunk: string) => (body += chunk));\n          res.on(\"end\", () => {\n            try {\n              resolve(JSON.parse(body));\n            } catch (e) {\n              reject(e);\n            }\n          });\n        }\n      );\n      req.on(\"error\", reject);\n      req.write(data);\n      req.end();\n    });\n  }\n\n  async function getDocViaRest(id: string): Promise<{ id: string; content: string; title: string }> {\n    return new Promise((resolve, reject) => {\n      const http = await import(\"http\");\n      const req = http.request(\n        {\n          hostname: \"localhost\",\n          port,\n          path: `/api/documents/${id}`,\n          method: \"GET\",\n        },\n        (res) => {\n          let body = \"\";\n          res.on(\"data\", (chunk: string) => (body += chunk));\n          res.on(\"end\", () => {\n            try {\n              resolve(JSON.parse(body));\n            } catch (e) {\n              reject(e);\n            }\n          });\n        }\n      );\n      req.on(\"error\", reject);\n      req.end();\n    });\n  }\n\n  async function getVersionsViaRest(id: string): Promise<Array<{ version: number; content: string }>> {\n    return new Promise((resolve, reject) => {\n      const http = await import(\"http\");\n      const req = http.request(\n        {\n          hostname: \"localhost\",\n          port,\n          path: `/api/documents/${id}/versions`,\n          method: \"GET\",\n        },\n        (res) => {\n          let body = \"\";\n          res.on(\"data\", (chunk: string) => (body += chunk));\n          res.on(\"end\", () => {\n            try {\n              resolve(JSON.parse(body));\n            } catch (e) {\n              reject(e);\n            }\n          });\n        }\n      );\n      req.on(\"error\", reject);\n      req.end();\n    });\n  }\n\n  async function connect(docId: string): Promise<WebSocket> {\n    const ws = await connectWs(port, docId);\n    clients.push(ws);\n    return ws;\n  }\n\n  it(\"should send sync message on connect\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"Hello\");\n    const ws = await connect(doc.id);\n\n    const msg = await waitForMessage<SyncMessage>(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Hello\");\n    expect(msg.version).toBe(1);\n    expect(msg.documentId).toBe(doc.id);\n  });\n\n  it(\"should reject connection for nonexistent document\", async () => {\n    return new Promise<void>((resolve) => {\n      const ws = new WebSocket(\n        `ws://localhost:${port}/ws/documents/nonexistent`\n      );\n      clients.push(ws);\n      ws.on(\"message\", (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === \"error\") {\n          expect(msg.message).toContain(\"not found\");\n          resolve();\n        }\n      });\n      ws.on(\"close\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"hello\");\n\n    const ws1 = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws1);\n\n    const ws2 = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws2);\n\n    // Client 1 sends an insert operation\n    const op = createInsertOp(5, 5, \" world\");\n    const msgPromise = waitForMessage<OpMessage>(ws2);\n    const ackPromise = waitForMessage<AckMessage>(ws1);\n\n    ws1.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: op,\n      })\n    );\n\n    const ack = await ackPromise;\n    expect(ack.type).toBe(\"ack\");\n    expect(ack.version).toBe(2);\n\n    const broadcast = await msgPromise;\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(2);\n  });\n\n  it(\"should persist changes from WebSocket operations\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    const op = createInsertOp(5, 5, \" world\");\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: op,\n      })\n    );\n\n    await waitForMessage<AckMessage>(ws);\n\n    // Verify via REST\n    const updated = await getDocViaRest(doc.id);\n    expect(updated.content).toBe(\"hello world\");\n  });\n\n  it(\"should handle concurrent edits with OT\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"hello\");\n\n    const ws1 = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws1);\n\n    const ws2 = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws2);\n\n    // Both clients have version 1 of \"hello\"\n    // Client 1: insert \"X\" at position 0 -> \"Xhello\"\n    const op1 = createInsertOp(5, 0, \"X\");\n    // Client 2: insert \"Y\" at position 5 -> \"helloY\"\n    const op2 = createInsertOp(5, 5, \"Y\");\n\n    // Set up message listeners before sending\n    const ws1Messages = collectMessages(ws1, 2);\n    const ws2Messages = collectMessages(ws2, 2);\n\n    // Send both operations (both based on version 1)\n    ws1.send(JSON.stringify({ type: \"operation\", version: 1, operation: op1 }));\n\n    // Wait a tiny bit so op1 is processed first\n    await new Promise((r) => setTimeout(r, 50));\n\n    ws2.send(JSON.stringify({ type: \"operation\", version: 1, operation: op2 }));\n\n    const ws1Msgs = await ws1Messages;\n    const ws2Msgs = await ws2Messages;\n\n    // ws1 should get ack then broadcast of op2\n    const ws1Types = ws1Msgs.map((m) => (m as { type: string }).type);\n    expect(ws1Types).toContain(\"ack\");\n    expect(ws1Types).toContain(\"operation\");\n\n    // ws2 should get broadcast of op1 then ack\n    const ws2Types = ws2Msgs.map((m) => (m as { type: string }).type);\n    expect(ws2Types).toContain(\"ack\");\n    expect(ws2Types).toContain(\"operation\");\n\n    // Verify the document content via REST\n    const updated = await getDocViaRest(doc.id);\n\n    // Both inserts should be preserved\n    expect(updated.content).toContain(\"X\");\n    expect(updated.content).toContain(\"Y\");\n    expect(updated.content).toBe(\"XhelloY\");\n  });\n\n  it(\"should handle error for invalid JSON\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    ws.send(\"not json\");\n\n    const msg = await waitForMessage<ErrorMessage>(ws);\n    expect(msg.type).toBe(\"error\");\n    expect(msg.message).toContain(\"Invalid JSON\");\n  });\n\n  it(\"should handle error for invalid operation\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: { baseLength: 999, targetLength: 999, ops: [] },\n      })\n    );\n\n    const msg = await waitForMessage<ErrorMessage>(ws);\n    expect(msg.type).toBe(\"error\");\n  });\n\n  it(\"should handle version history growing with operations\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    // Apply 3 operations sequentially\n    const ops = [\n      createInsertOp(5, 5, \" world\"),\n      createInsertOp(11, 11, \"!\"),\n      createInsertOp(12, 0, \"A \"),\n    ];\n\n    for (let i = 0; i < ops.length; i++) {\n      ws.send(\n        JSON.stringify({\n          type: \"operation\",\n          version: i + 1,\n          operation: ops[i],\n        })\n      );\n      await waitForMessage<AckMessage>(ws);\n    }\n\n    // Check versions\n    const versions = await getVersionsViaRest(doc.id);\n    expect(versions.length).toBe(4); // initial + 3 operations\n    expect(versions[versions.length - 1].content).toBe(\"A hello world!\");\n  });\n\n  it(\"should handle 10 concurrent clients\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"\");\n    const websockets: WebSocket[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connect(doc.id);\n      await waitForMessage<SyncMessage>(ws);\n      websockets.push(ws);\n    }\n\n    // Each client inserts a character sequentially\n    let currentVersion = 1;\n    for (let i = 0; i < 10; i++) {\n      const docLen = i; // Document grows by 1 each time\n      const op = createInsertOp(docLen, docLen, String(i));\n\n      // Drain any pending broadcast messages first\n      const drainPromise = (idx: number) => {\n        return new Promise<void>((resolve) => {\n          const handler = (data: WebSocket.RawData) => {\n            const msg = JSON.parse(data.toString());\n            if (msg.type === \"operation\") {\n              // keep draining\n            }\n          };\n          websockets[idx].on(\"message\", handler);\n          setTimeout(() => {\n            websockets[idx].off(\"message\", handler);\n            resolve();\n          }, 10);\n        });\n      };\n\n      websockets[i].send(\n        JSON.stringify({\n          type: \"operation\",\n          version: currentVersion,\n          operation: op,\n        })\n      );\n\n      // Wait for ack to this client\n      const ack = await waitForMessage<AckMessage>(websockets[i]);\n      expect(ack.type).toBe(\"ack\");\n      currentVersion = ack.version;\n\n      // Wait for broadcasts to propagate\n      await new Promise((r) => setTimeout(r, 20));\n\n      // Drain broadcast messages from all other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          await drainPromise(j);\n        }\n      }\n    }\n\n    // Verify final document\n    const updated = await getDocViaRest(doc.id);\n    expect(updated.content).toBe(\"0123456789\");\n  });\n\n  it(\"should handle delete operations\", async () => {\n    const doc = await createDocViaRest(\"Test\", \"hello world\");\n    const ws = await connect(doc.id);\n    await waitForMessage<SyncMessage>(ws);\n\n    const op = createDeleteOp(11, 5, 6); // delete \" world\"\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: op,\n      })\n    );\n\n    const ack = await waitForMessage<AckMessage>(ws);\n    expect(ack.type).toBe(\"ack\");\n\n    const updated = await getDocViaRest(doc.id);\n    expect(updated.content).toBe(\"hello\");\n  });\n});\n"}}
