diff --git a/tests/ot.test.ts b/tests/ot.test.ts
new file mode 100644
index 0000000..9699fad
--- /dev/null
+++ b/tests/ot.test.ts
@@ -0,0 +1,174 @@
+import { describe, it, expect } from "vitest";
+import {
+  apply,
+  transform,
+  validateOperation,
+  createInsertOp,
+  createDeleteOp,
+  Operation,
+} from "../src/ot.js";
+
+describe("OT Engine", () => {
+  describe("apply", () => {
+    it("should apply an insert operation", () => {
+      const doc = "hello";
+      const op = createInsertOp(5, 5, " world");
+      const result = apply(doc, op);
+      expect(result).toBe("hello world");
+    });
+
+    it("should apply an insert at the beginning", () => {
+      const doc = "world";
+      const op = createInsertOp(5, 0, "hello ");
+      const result = apply(doc, op);
+      expect(result).toBe("hello world");
+    });
+
+    it("should apply a delete operation", () => {
+      const doc = "hello world";
+      const op = createDeleteOp(11, 5, 6);
+      const result = apply(doc, op);
+      expect(result).toBe("hello");
+    });
+
+    it("should apply to an empty document", () => {
+      const doc = "";
+      const op = createInsertOp(0, 0, "hello");
+      const result = apply(doc, op);
+      expect(result).toBe("hello");
+    });
+
+    it("should reject operation with wrong baseLength", () => {
+      const doc = "hello";
+      const op: Operation = {
+        baseLength: 10,
+        targetLength: 15,
+        ops: [
+          { type: "retain", count: 10 },
+          { type: "insert", text: "world" },
+        ],
+      };
+      expect(() => apply(doc, op)).toThrow();
+    });
+  });
+
+  describe("validateOperation", () => {
+    it("should validate a correct operation", () => {
+      const op = createInsertOp(5, 3, "xyz");
+      expect(validateOperation(op, 5)).toBeNull();
+    });
+
+    it("should reject mismatched baseLength", () => {
+      const op = createInsertOp(5, 3, "xyz");
+      expect(validateOperation(op, 10)).not.toBeNull();
+    });
+
+    it("should reject invalid retain count", () => {
+      const op: Operation = {
+        baseLength: 5,
+        targetLength: 5,
+        ops: [{ type: "retain", count: -1 }],
+      };
+      expect(validateOperation(op, 5)).not.toBeNull();
+    });
+  });
+
+  describe("transform", () => {
+    it("should handle two inserts at different positions", () => {
+      const doc = "hello";
+      const a = createInsertOp(5, 0, "A"); // Insert A at beginning
+      const b = createInsertOp(5, 5, "B"); // Insert B at end
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      // Apply a then b'
+      const result1 = apply(apply(doc, a), bPrime);
+      // Apply b then a'
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toContain("A");
+      expect(result1).toContain("B");
+    });
+
+    it("should handle two inserts at the same position", () => {
+      const doc = "hello";
+      const a = createInsertOp(5, 2, "X");
+      const b = createInsertOp(5, 2, "Y");
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+      // Both insertions should be preserved
+      expect(result1).toContain("X");
+      expect(result1).toContain("Y");
+    });
+
+    it("should handle insert vs delete", () => {
+      const doc = "hello world";
+      const a = createInsertOp(11, 5, "!"); // Insert ! after "hello"
+      const b = createDeleteOp(11, 6, 5); // Delete "world"
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toContain("!");
+      expect(result1).not.toContain("world");
+    });
+
+    it("should handle delete vs delete (same region)", () => {
+      const doc = "hello world";
+      const a = createDeleteOp(11, 6, 5); // Delete "world"
+      const b = createDeleteOp(11, 6, 5); // Delete "world"
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toBe("hello ");
+    });
+
+    it("should handle overlapping deletes", () => {
+      const doc = "abcdefgh";
+      const a = createDeleteOp(8, 2, 3); // Delete "cde"
+      const b = createDeleteOp(8, 4, 3); // Delete "efg"
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+    });
+
+    it("should converge with multiple concurrent inserts", () => {
+      const doc = "abcd";
+      const a = createInsertOp(4, 1, "X"); // aXbcd
+      const b = createInsertOp(4, 3, "Y"); // abcYd
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toContain("X");
+      expect(result1).toContain("Y");
+    });
+
+    it("should throw for operations with different baseLengths", () => {
+      const a = createInsertOp(5, 0, "A");
+      const b = createInsertOp(10, 0, "B");
+
+      expect(() => transform(a, b)).toThrow();
+    });
+  });
+});
