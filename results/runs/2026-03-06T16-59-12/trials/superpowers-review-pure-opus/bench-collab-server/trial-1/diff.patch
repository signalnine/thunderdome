@@ -0,0 +1,349 @@
+/**
+ * Operational Transformation (OT) engine for collaborative editing.
+ *
+ * Operations are represented as a sequence of components:
+ * - { type: "retain", count: n } -- skip n characters
+ * - { type: "insert", text: s }  -- insert string s at current position
+ * - { type: "delete", count: n } -- delete n characters at current position
+ *
+ * An operation also carries a base length (the length of the document it applies to)
+ * and a target length (the length of the document after applying it).
+ */
+
+export interface RetainOp {
+  type: "retain";
+  count: number;
+}
+
+export interface InsertOp {
+  type: "insert";
+  text: string;
+}
+
+export interface DeleteOp {
+  type: "delete";
+  count: number;
+}
+
+export type OpComponent = RetainOp | InsertOp | DeleteOp;
+
+export interface Operation {
+  baseLength: number;
+  targetLength: number;
+  ops: OpComponent[];
+}
+
+/** Validate that an operation is well-formed for a document of the given length. */
+export function validateOperation(
+  op: Operation,
+  docLength: number
+): string | null {
+  if (op.baseLength !== docLength) {
+    return `Operation baseLength (${op.baseLength}) does not match document length (${docLength})`;
+  }
+
+  let consumedInput = 0;
+  let producedOutput = 0;
+
+  for (const component of op.ops) {
+    switch (component.type) {
+      case "retain":
+        if (component.count <= 0 || !Number.isInteger(component.count)) {
+          return `Invalid retain count: ${component.count}`;
+        }
+        consumedInput += component.count;
+        producedOutput += component.count;
+        break;
+      case "insert":
+        if (typeof component.text !== "string" || component.text.length === 0) {
+          return `Invalid insert text`;
+        }
+        producedOutput += component.text.length;
+        break;
+      case "delete":
+        if (component.count <= 0 || !Number.isInteger(component.count)) {
+          return `Invalid delete count: ${component.count}`;
+        }
+        consumedInput += component.count;
+        break;
+      default:
+        return `Unknown operation type: ${(component as OpComponent).type}`;
+    }
+  }
+
+  if (consumedInput !== op.baseLength) {
+    return `Operations consume ${consumedInput} chars but baseLength is ${op.baseLength}`;
+  }
+
+  if (producedOutput !== op.targetLength) {
+    return `Operations produce ${producedOutput} chars but targetLength is ${op.targetLength}`;
+  }
+
+  return null;
+}
+
+/** Apply an operation to a document string, returning the new document. */
+export function apply(doc: string, op: Operation): string {
+  const error = validateOperation(op, doc.length);
+  if (error) {
+    throw new Error(`Cannot apply operation: ${error}`);
+  }
+
+  let pos = 0;
+  let result = "";
+
+  for (const component of op.ops) {
+    switch (component.type) {
+      case "retain":
+        result += doc.slice(pos, pos + component.count);
+        pos += component.count;
+        break;
+      case "insert":
+        result += component.text;
+        break;
+      case "delete":
+        pos += component.count;
+        break;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations (a and b) that were both applied to the same
+ * base document. Returns [a', b'] such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * This is the core OT algorithm that ensures convergence.
+ */
+export function transform(
+  a: Operation,
+  b: Operation
+): [Operation, Operation] {
+  if (a.baseLength !== b.baseLength) {
+    throw new Error(
+      `Transform requires operations with the same baseLength: ${a.baseLength} vs ${b.baseLength}`
+    );
+  }
+
+  const aPrime: OpComponent[] = [];
+  const bPrime: OpComponent[] = [];
+
+  // Flatten operations into a stream of unit-sized components for easier processing
+  // We iterate both ops simultaneously, consuming from each as needed.
+  // We track position in each operation's component list and partial offset.
+  let aIdx = 0;
+  let aOff = 0; // offset within current a component (for retain/delete)
+  let bIdx = 0;
+  let bOff = 0;
+
+  function aType(): OpComponent["type"] | null {
+    if (aIdx >= a.ops.length) return null;
+    return a.ops[aIdx].type;
+  }
+
+  function bType(): OpComponent["type"] | null {
+    if (bIdx >= b.ops.length) return null;
+    return b.ops[bIdx].type;
+  }
+
+  function aRemaining(): number {
+    if (aIdx >= a.ops.length) return 0;
+    const op = a.ops[aIdx];
+    if (op.type === "insert") return op.text.length - aOff;
+    return op.count - aOff;
+  }
+
+  function bRemaining(): number {
+    if (bIdx >= b.ops.length) return 0;
+    const op = b.ops[bIdx];
+    if (op.type === "insert") return op.text.length - bOff;
+    return op.count - bOff;
+  }
+
+  function consumeA(n: number) {
+    aOff += n;
+    const op = a.ops[aIdx];
+    const total = op.type === "insert" ? op.text.length : op.count;
+    if (aOff >= total) {
+      aIdx++;
+      aOff = 0;
+    }
+  }
+
+  function consumeB(n: number) {
+    bOff += n;
+    const op = b.ops[bIdx];
+    const total = op.type === "insert" ? op.text.length : op.count;
+    if (bOff >= total) {
+      bIdx++;
+      bOff = 0;
+    }
+  }
+
+  function takeAInsert(): InsertOp {
+    const op = a.ops[aIdx] as InsertOp;
+    const text = op.text.slice(aOff);
+    aIdx++;
+    aOff = 0;
+    return { type: "insert", text };
+  }
+
+  function takeBInsert(): InsertOp {
+    const op = b.ops[bIdx] as InsertOp;
+    const text = op.text.slice(bOff);
+    bIdx++;
+    bOff = 0;
+    return { type: "insert", text };
+  }
+
+  while (aIdx < a.ops.length || bIdx < b.ops.length) {
+    const at = aType();
+    const bt = bType();
+
+    // a inserts: goes into a', b' retains over it
+    if (at === "insert") {
+      const ins = takeAInsert();
+      aPrime.push(ins);
+      bPrime.push({ type: "retain", count: ins.text.length });
+      continue;
+    }
+
+    // b inserts: goes into b', a' retains over it
+    if (bt === "insert") {
+      const ins = takeBInsert();
+      bPrime.push(ins);
+      aPrime.push({ type: "retain", count: ins.text.length });
+      continue;
+    }
+
+    if (at === null || bt === null) {
+      throw new Error("Transform ran out of operations unexpectedly");
+    }
+
+    const ar = aRemaining();
+    const br = bRemaining();
+    const min = Math.min(ar, br);
+
+    if (at === "retain" && bt === "retain") {
+      consumeA(min);
+      consumeB(min);
+      aPrime.push({ type: "retain", count: min });
+      bPrime.push({ type: "retain", count: min });
+    } else if (at === "delete" && bt === "delete") {
+      // Both delete same chars, cancel out
+      consumeA(min);
+      consumeB(min);
+    } else if (at === "delete" && bt === "retain") {
+      consumeA(min);
+      consumeB(min);
+      aPrime.push({ type: "delete", count: min });
+    } else if (at === "retain" && bt === "delete") {
+      consumeA(min);
+      consumeB(min);
+      bPrime.push({ type: "delete", count: min });
+    }
+  }
+
+  // a' applies after b, so a'.baseLength = b.targetLength
+  const aPrimeOp = buildOperation(aPrime, b.targetLength);
+  // b' applies after a, so b'.baseLength = a.targetLength
+  const bPrimeOp = buildOperation(bPrime, a.targetLength);
+
+  return [aPrimeOp, bPrimeOp];
+}
+
+function buildOperation(ops: OpComponent[], baseLength: number): Operation {
+  // Merge adjacent same-type components
+  const merged: OpComponent[] = [];
+  for (const op of ops) {
+    if (merged.length > 0) {
+      const last = merged[merged.length - 1];
+      if (last.type === "retain" && op.type === "retain") {
+        merged[merged.length - 1] = {
+          type: "retain",
+          count: last.count + op.count,
+        };
+        continue;
+      }
+      if (last.type === "delete" && op.type === "delete") {
+        merged[merged.length - 1] = {
+          type: "delete",
+          count: last.count + op.count,
+        };
+        continue;
+      }
+      if (last.type === "insert" && op.type === "insert") {
+        merged[merged.length - 1] = {
+          type: "insert",
+          text: last.text + op.text,
+        };
+        continue;
+      }
+    }
+    merged.push(op);
+  }
+
+  let produced = 0;
+  for (const op of merged) {
+    switch (op.type) {
+      case "retain":
+        produced += op.count;
+        break;
+      case "insert":
+        produced += op.text.length;
+        break;
+      case "delete":
+        break;
+    }
+  }
+
+  return {
+    baseLength,
+    targetLength: produced,
+    ops: merged,
+  };
+}
+
+/**
+ * Create a simple insert operation at a given position in a document.
+ */
+export function createInsertOp(
+  docLength: number,
+  position: number,
+  text: string
+): Operation {
+  const ops: OpComponent[] = [];
+  if (position > 0) ops.push({ type: "retain", count: position });
+  ops.push({ type: "insert", text });
+  if (position < docLength)
+    ops.push({ type: "retain", count: docLength - position });
+
+  return {
+    baseLength: docLength,
+    targetLength: docLength + text.length,
+    ops,
+  };
+}
+
+/**
+ * Create a simple delete operation at a given position in a document.
+ */
+export function createDeleteOp(
+  docLength: number,
+  position: number,
+  count: number
+): Operation {
+  const ops: OpComponent[] = [];
+  if (position > 0) ops.push({ type: "retain", count: position });
+  ops.push({ type: "delete", count });
+  if (position + count < docLength)
+    ops.push({ type: "retain", count: docLength - position - count });
+
+  return {
+    baseLength: docLength,
+    targetLength: docLength - count,
+    ops,
+  };
+}
