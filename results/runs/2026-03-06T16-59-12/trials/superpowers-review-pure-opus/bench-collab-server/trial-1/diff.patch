+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014iJgneUUtvUFVpA2tGjhmv","type":"tool_result","content":"     1→import Database from \"better-sqlite3\";\n     2→import { randomUUID } from \"crypto\";\n     3→import { readFileSync } from \"fs\";\n     4→import { resolve, dirname } from \"path\";\n     5→import { fileURLToPath } from \"url\";\n     6→\n     7→export interface Document {\n     8→  id: string;\n     9→  title: string;\n    10→  content: string;\n    11→  created_at: string;\n    12→  updated_at: string;\n    13→}\n    14→\n    15→export interface Version {\n    16→  id: number;\n    17→  document_id: string;\n    18→  version: number;\n    19→  content: string;\n    20→  operation: string | null;\n    21→  created_at: string;\n    22→}\n    23→\n    24→export function createDatabase(dbPath: string = \":memory:\"): Database.Database {\n    25→  const db = new Database(dbPath);\n    26→  db.pragma(\"journal_mode = WAL\");\n    27→  db.pragma(\"foreign_keys = ON\");\n    28→\n    29→  const __dirname = dirname(fileURLToPath(import.meta.url));\n    30→  const schemaPath = resolve(__dirname, \"..\", \"schema.sql\");\n    31→  const schema = readFileSync(schemaPath, \"utf-8\");\n    32→  db.exec(schema);\n    33→\n    34→  return db;\n    35→}\n    36→\n    37→export function createDocumentRepo(db: Database.Database) {\n    38→  const insertDoc = db.prepare(\n    39→    \"INSERT INTO documents (id, title, content, created_at, updated_at) VALUES (?, ?, ?, datetime('now'), datetime('now'))\"\n    40→  );\n    41→  const selectDoc = db.prepare(\"SELECT * FROM documents WHERE id = ?\");\n    42→  const selectAllDocs = db.prepare(\n    43→    \"SELECT * FROM documents ORDER BY updated_at DESC\"\n    44→  );\n    45→  const updateDocContent = db.prepare(\n    46→    \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n    47→  );\n    48→  const updateDocTitle = db.prepare(\n    49→    \"UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?\"\n    50→  );\n    51→  const updateDocTitleAndContent = db.prepare(\n    52→    \"UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?\"\n    53→  );\n    54→  const deleteDoc = db.prepare(\"DELETE FROM documents WHERE id = ?\");\n    55→\n    56→  const insertVersion = db.prepare(\n    57→    \"INSERT INTO versions (document_id, version, content, operation, created_at) VALUES (?, ?, ?, ?, datetime('now'))\"\n    58→  );\n    59→  const selectVersions = db.prepare(\n    60→    \"SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC\"\n    61→  );\n    62→  const selectLatestVersion = db.prepare(\n    63→    \"SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1\"\n    64→  );\n    65→\n    66→  return {\n    67→    create(title: string, content: string = \"\"): Document {\n    68→      const id = randomUUID();\n    69→      insertDoc.run(id, title, content);\n    70→      // Create initial version\n    71→      insertVersion.run(id, 1, content, null);\n    72→      return selectDoc.get(id) as Document;\n    73→    },\n    74→\n    75→    getById(id: string): Document | undefined {\n    76→      return selectDoc.get(id) as Document | undefined;\n    77→    },\n    78→\n    79→    getAll(): Document[] {\n    80→      return selectAllDocs.all() as Document[];\n    81→    },\n    82→\n    83→    update(\n    84→      id: string,\n    85→      updates: { title?: string; content?: string }\n    86→    ): Document | undefined {\n    87→      const existing = selectDoc.get(id) as Document | undefined;\n    88→      if (!existing) return undefined;\n    89→\n    90→      if (updates.title !== undefined && updates.content !== undefined) {\n    91→        updateDocTitleAndContent.run(updates.title, updates.content, id);\n    92→      } else if (updates.title !== undefined) {\n    93→        updateDocTitle.run(updates.title, id);\n    94→      } else if (updates.content !== undefined) {\n    95→        updateDocContent.run(updates.content, id);\n    96→      }\n    97→\n    98→      return selectDoc.get(id) as Document;\n    99→    },\n   100→\n   101→    updateContent(id: string, content: string, operation?: object): Document | undefined {\n   102→      const existing = selectDoc.get(id) as Document | undefined;\n   103→      if (!existing) return undefined;\n   104→\n   105→      updateDocContent.run(content, id);\n   106→\n   107→      const latest = selectLatestVersion.get(id) as Version | undefined;\n   108→      const nextVersion = latest ? latest.version + 1 : 1;\n   109→      insertVersion.run(\n   110→        id,\n   111→        nextVersion,\n   112→        content,\n   113→        operation ? JSON.stringify(operation) : null\n   114→      );\n   115→\n   116→      return selectDoc.get(id) as Document;\n   117→    },\n   118→\n   119→    delete(id: string): boolean {\n   120→      const result = deleteDoc.run(id);\n   121→      return result.changes > 0;\n   122→    },\n   123→\n   124→    getVersions(id: string): Version[] {\n   125→      return selectVersions.all(id) as Version[];\n   126→    },\n   127→\n   128→    getLatestVersion(id: string): Version | undefined {\n   129→      return selectLatestVersion.get(id) as Version | undefined;\n   130→    },\n   131→  };\n   132→}\n   133→\n   134→export type DocumentRepo = ReturnType<typeof createDocumentRepo>;\n   135→"}]},"parent_tool_use_id":"toolu_01Kftm1Yi94wZ75JVYuC6FGM","session_id":"a3069b4b-a5ce-43d4-9247-c633b9aacc8f","uuid":"6655e45d-741a-4c8f-b9e5-794c95b2d524"}
