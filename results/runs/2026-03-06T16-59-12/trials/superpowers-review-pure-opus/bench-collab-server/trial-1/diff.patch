{docId}`);\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<unknown> {\n  return new Promise((resolve) => {\n    ws.once(\"message\", (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction waitForMessages(ws: WebSocket, count: number): Promise<unknown[]> {\n  return new Promise((resolve) => {\n    const messages: unknown[] = [];\n    const handler = (data: WebSocket.RawData) => {\n      messages.push(JSON.parse(data.toString()));\n      if (messages.length >= count) {\n        ws.off(\"message\", handler);\n        resolve(messages);\n      }\n    };\n    ws.on(\"message\", handler);\n  });\n}\n\ndescribe(\"WebSocket Collaboration\", () => {\n  let instance: AppInstance;\n  let port: number;\n  const clients: WebSocket[] = [];\n\n  beforeEach(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    for (const ws of clients) {\n      if (ws.readyState === WebSocket.OPEN) {\n        ws.close();\n      }\n    }\n    clients.length = 0;\n    await instance.stop();\n  });\n\n  async function createDoc(title: string, content: string = \"\") {\n    const res = await request(instance.app)\n      .post(\"/api/documents\")\n      .send({ title, content });\n    return res.body;\n  }\n\n  async function connect(docId: string): Promise<WebSocket> {\n    const ws = await connectWs(port, docId);\n    clients.push(ws);\n    return ws;\n  }\n\n  it(\"should send sync message on connect\", async () => {\n    const doc = await createDoc(\"Test\", \"Hello\");\n    const ws = await connect(doc.id);\n\n    const msg = (await waitForMessage(ws)) as {\n      type: string;\n      content: string;\n      version: number;\n      documentId: string;\n    };\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Hello\");\n    expect(msg.version).toBe(1); // Initial version\n    expect(msg.documentId).toBe(doc.id);\n  });\n\n  it(\"should reject connection for nonexistent document\", async () => {\n    return new Promise<void>((resolve) => {\n      const ws = new WebSocket(\n        `ws://localhost:${port}/ws/documents/nonexistent`\n      );\n      clients.push(ws);\n      ws.on(\"message\", (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === \"error\") {\n          expect(msg.message).toContain(\"not found\");\n          resolve();\n        }\n      });\n      ws.on(\"close\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n\n    const ws1 = await connect(doc.id);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connect(doc.id);\n    const sync2 = await waitForMessage(ws2);\n\n    expect((sync1 as { type: string }).type).toBe(\"sync\");\n    expect((sync2 as { type: string }).type).toBe(\"sync\");\n\n    // Client 1 sends an insert operation\n    const op = createInsertOp(5, 5, \" world\");\n    const msgPromise = waitForMessage(ws2);\n    const ackPromise = waitForMessage(ws1);\n\n    ws1.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: op,\n      })\n    );\n\n    const ack = (await ackPromise) as { type: string; version: number };\n    expect(ack.type).toBe(\"ack\");\n    expect(ack.version).toBe(2);\n\n    const broadcast = (await msgPromise) as {\n      type: string;\n      operation: unknown;\n      version: number;\n    };\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(2);\n  });\n\n  it(\"should persist changes from WebSocket operations\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage(ws); // sync\n\n    const op = createInsertOp(5, 5, \" world\");\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: op,\n      })\n    );\n\n    await waitForMessage(ws); // ack\n\n    // Verify via REST\n    const res = await request(instance.app)\n      .get(`/api/documents/${doc.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"hello world\");\n  });\n\n  it(\"should handle concurrent edits with OT\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n\n    const ws1 = await connect(doc.id);\n    await waitForMessage(ws1); // sync\n\n    const ws2 = await connect(doc.id);\n    await waitForMessage(ws2); // sync\n\n    // Both clients have version 1 of \"hello\"\n    // Client 1: insert \"X\" at position 0 -> \"Xhello\"\n    const op1 = createInsertOp(5, 0, \"X\");\n    // Client 2: insert \"Y\" at position 5 -> \"helloY\"\n    const op2 = createInsertOp(5, 5, \"Y\");\n\n    // Set up message listeners before sending\n    const ws2Messages = waitForMessages(ws2, 2); // Will receive: ack for op2, broadcast of op1\n    const ws1Messages = waitForMessages(ws1, 2); // Will receive: ack for op1, broadcast of op2\n\n    // Send both operations (both based on version 1)\n    ws1.send(JSON.stringify({ type: \"operation\", version: 1, operation: op1 }));\n\n    // Wait a tiny bit so op1 is processed first\n    await new Promise((r) => setTimeout(r, 50));\n\n    ws2.send(JSON.stringify({ type: \"operation\", version: 1, operation: op2 }));\n\n    const [ws1Msg1, ws1Msg2] = await ws1Messages;\n    const [ws2Msg1, ws2Msg2] = await ws2Messages;\n\n    // ws1 should get ack then broadcast of op2\n    expect((ws1Msg1 as { type: string }).type).toBe(\"ack\");\n    expect((ws1Msg2 as { type: string }).type).toBe(\"operation\");\n\n    // ws2 should get broadcast of op1 then ack\n    // (order may vary, but both should be present)\n    const ws2Types = [ws2Msg1, ws2Msg2].map(\n      (m) => (m as { type: string }).type\n    );\n    expect(ws2Types).toContain(\"ack\");\n    expect(ws2Types).toContain(\"operation\");\n\n    // Verify the document content via REST\n    const res = await request(instance.app)\n      .get(`/api/documents/${doc.id}`)\n      .expect(200);\n\n    // Both inserts should be preserved\n    expect(res.body.content).toContain(\"X\");\n    expect(res.body.content).toContain(\"Y\");\n    expect(res.body.content).toBe(\"XhelloY\");\n  });\n\n  it(\"should handle error for invalid JSON\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send(\"not json\");\n\n    const msg = (await waitForMessage(ws)) as {\n      type: string;\n      message: string;\n    };\n    expect(msg.type).toBe(\"error\");\n    expect(msg.message).toContain(\"Invalid JSON\");\n  });\n\n  it(\"should handle error for invalid operation\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: { baseLength: 999, targetLength: 999, ops: [] },\n      })\n    );\n\n    const msg = (await waitForMessage(ws)) as {\n      type: string;\n      message: string;\n    };\n    expect(msg.type).toBe(\"error\");\n  });\n\n  it(\"should handle version history growing with operations\", async () => {\n    const doc = await createDoc(\"Test\", \"hello\");\n    const ws = await connect(doc.id);\n    await waitForMessage(ws); // sync\n\n    // Apply 3 operations\n    const ops = [\n      createInsertOp(5, 5, \" world\"),\n      createInsertOp(11, 11, \"!\"),\n      createInsertOp(12, 0, \"A \"),\n    ];\n\n    for (let i = 0; i < ops.length; i++) {\n      ws.send(\n        JSON.stringify({\n          type: \"operation\",\n          version: i + 1,\n          operation: ops[i],\n        })\n      );\n      await waitForMessage(ws); // ack\n    }\n\n    // Check versions\n    const res = await request(instance.app)\n      .get(`/api/documents/${doc.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBe(4); // initial + 3 operations\n    expect(res.body[res.body.length - 1].content).toBe(\"A hello world!\");\n  });\n\n  it(\"should handle 10 concurrent clients\", async () => {\n    const doc = await createDoc(\"Test\", \"\");\n    const websockets: WebSocket[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connect(doc.id);\n      await waitForMessage(ws); // sync\n      websockets.push(ws);\n    }\n\n    // Each client inserts a character sequentially\n    let currentVersion = 1;\n    for (let i = 0; i < 10; i++) {\n      const docLen = i; // Document grows by 1 each time\n      const op = createInsertOp(docLen, docLen, String(i));\n\n      websockets[i].send(\n        JSON.stringify({\n          type: \"operation\",\n          version: currentVersion,\n          operation: op,\n        })\n      );\n\n      // Wait for ack to this client\n      const ack = (await waitForMessage(websockets[i])) as {\n        type: string;\n        version: number;\n      };\n      expect(ack.type).toBe(\"ack\");\n      currentVersion = ack.version;\n\n      // Drain broadcast messages from other clients\n      await new Promise((r) => setTimeout(r, 20));\n    }\n\n    // Verify final document\n    const res = await request(instance.app)\n      .get(`/api/documents/${doc.id}`)\n      .expect(200);\n\n    expect(res.body.content).toBe(\"0123456789\");\n  });\n\n  it(\"should handle delete operations\", async () => {\n    const doc = await createDoc(\"Test\", \"hello world\");\n    const ws = await connect(doc.id);\n    await waitForMessage(ws); // sync\n\n    const op = createDeleteOp(11, 5, 6); // delete \" world\"\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        version: 1,\n        operation: op,\n      })\n    );\n\n    const ack = (await waitForMessage(ws)) as { type: string };\n    expect(ack.type).toBe(\"ack\");\n\n    const res = await request(instance.app)\n      .get(`/api/documents/${doc.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"hello\");\n  });\n});\n"}}
