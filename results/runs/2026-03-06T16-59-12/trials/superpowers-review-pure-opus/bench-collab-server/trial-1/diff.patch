+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JhZwhvwXJYSx1s4ePXqVEt","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from \"ws\";\n     2→import { IncomingMessage } from \"http\";\n     3→import { Server } from \"http\";\n     4→import { DocumentRepo } from \"./db.js\";\n     5→import { Operation, apply, transform, validateOperation } from \"./ot.js\";\n     6→import { randomUUID } from \"crypto\";\n     7→import { URL } from \"url\";\n     8→\n     9→interface ClientConnection {\n    10→  id: string;\n    11→  ws: WebSocket;\n    12→  documentId: string;\n    13→}\n    14→\n    15→interface DocumentSession {\n    16→  documentId: string;\n    17→  /** Current server version number for this session */\n    18→  serverVersion: number;\n    19→  /** Log of operations applied, indexed by version (version n was produced by log[n-1]) */\n    20→  operationLog: Operation[];\n    21→  clients: Map<string, ClientConnection>;\n    22→}\n    23→\n    24→// Message types from client\n    25→interface ClientOperationMessage {\n    26→  type: \"operation\";\n    27→  version: number; // The server version the client's operation is based on\n    28→  operation: Operation;\n    29→}\n    30→\n    31→interface ClientCursorMessage {\n    32→  type: \"cursor\";\n    33→  position: number;\n    34→}\n    35→\n    36→type ClientMessage = ClientOperationMessage | ClientCursorMessage;\n    37→\n    38→// Message types to client\n    39→interface ServerSyncMessage {\n    40→  type: \"sync\";\n    41→  content: string;\n    42→  version: number;\n    43→  documentId: string;\n    44→}\n    45→\n    46→interface ServerOperationMessage {\n    47→  type: \"operation\";\n    48→  operation: Operation;\n    49→  version: number;\n    50→  clientId: string;\n    51→}\n    52→\n    53→interface ServerAckMessage {\n    54→  type: \"ack\";\n    55→  version: number;\n    56→}\n    57→\n    58→interface ServerErrorMessage {\n    59→  type: \"error\";\n    60→  message: string;\n    61→}\n    62→\n    63→type ServerMessage =\n    64→  | ServerSyncMessage\n    65→  | ServerOperationMessage\n    66→  | ServerAckMessage\n    67→  | ServerErrorMessage;\n    68→\n    69→export function createWebSocketServer(\n    70→  server: Server,\n    71→  repo: DocumentRepo\n    72→): { wss: WebSocketServer; sessions: Map<string, DocumentSession>; closeAll: () => void } {\n    73→  const wss = new WebSocketServer({ server });\n    74→  const sessions = new Map<string, DocumentSession>();\n    75→\n    76→  function getOrCreateSession(documentId: string): DocumentSession | null {\n    77→    let session = sessions.get(documentId);\n    78→    if (session) return session;\n    79→\n    80→    const doc = repo.getById(documentId);\n    81→    if (!doc) return null;\n    82→\n    83→    const latestVersion = repo.getLatestVersion(documentId);\n    84→    const serverVersion = latestVersion ? latestVersion.version : 0;\n    85→\n    86→    session = {\n    87→      documentId,\n    88→      serverVersion,\n    89→      operationLog: [],\n    90→      clients: new Map(),\n    91→    };\n    92→    sessions.set(documentId, session);\n    93→    return session;\n    94→  }\n    95→\n    96→  function sendMessage(ws: WebSocket, msg: ServerMessage) {\n    97→    if (ws.readyState === WebSocket.OPEN) {\n    98→      ws.send(JSON.stringify(msg));\n    99→    }\n   100→  }\n   101→\n   102→  function broadcastOperation(\n   103→    session: DocumentSession,\n   104→    operation: Operation,\n   105→    version: number,\n   106→    senderId: string\n   107→  ) {\n   108→    for (const [clientId, client] of session.clients) {\n   109→      if (clientId === senderId) {\n   110→        // Send ack to sender\n   111→        sendMessage(client.ws, { type: \"ack\", version });\n   112→      } else {\n   113→        // Broadcast operation to others\n   114→        sendMessage(client.ws, {\n   115→          type: \"operation\",\n   116→          operation,\n   117→          version,\n   118→          clientId: senderId,\n   119→        });\n   120→      }\n   121→    }\n   122→  }\n   123→\n   124→  wss.on(\"connection\", (ws: WebSocket, req: IncomingMessage) => {\n   125→    // Extract document ID from URL path: /ws/documents/:id\n   126→    const url = new URL(req.url || \"/\", `http://${req.headers.host || \"localhost\"}`);\n   127→    const pathParts = url.pathname.split(\"/\").filter(Boolean);\n   128→\n   129→    // Support paths like /ws/documents/:id or /documents/:id/ws\n   130→    let documentId: string | null = null;\n   131→\n   132→    if (pathParts.length >= 3 && pathParts[0] === \"ws\" && pathParts[1] === \"documents\") {\n   133→      documentId = pathParts[2];\n   134→    } else if (\n   135→      pathParts.length >= 3 &&\n   136→      pathParts[0] === \"documents\" &&\n   137→      pathParts[2] === \"ws\"\n   138→    ) {\n   139→      documentId = pathParts[1];\n   140→    } else if (pathParts.length >= 2 && pathParts[0] === \"documents\") {\n   141→      documentId = pathParts[1];\n   142→    }\n   143→\n   144→    if (!documentId) {\n   145→      sendMessage(ws, {\n   146→        type: \"error\",\n   147→        message: \"Invalid WebSocket path. Use /ws/documents/:id\",\n   148→      });\n   149→      ws.close(1008, \"Invalid path\");\n   150→      return;\n   151→    }\n   152→\n   153→    const session = getOrCreateSession(documentId);\n   154→    if (!session) {\n   155→      sendMessage(ws, {\n   156→        type: \"error\",\n   157→        message: \"Document not found\",\n   158→      });\n   159→      ws.close(1008, \"Document not found\");\n   160→      return;\n   161→    }\n   162→\n   163→    const clientId = randomUUID();\n   164→    const client: ClientConnection = { id: clientId, ws, documentId };\n   165→    session.clients.set(clientId, client);\n   166→\n   167→    // Send current document state\n   168→    const doc = repo.getById(documentId);\n   169→    if (doc) {\n   170→      sendMessage(ws, {\n   171→        type: \"sync\",\n   172→        content: doc.content,\n   173→        version: session.serverVersion,\n   174→        documentId,\n   175→      });\n   176→    }\n   177→\n   178→    ws.on(\"message\", (data) => {\n   179→      let msg: ClientMessage;\n   180→      try {\n   181→        msg = JSON.parse(data.toString());\n   182→      } catch {\n   183→        sendMessage(ws, { type: \"error\", message: \"Invalid JSON\" });\n   184→        return;\n   185→      }\n   186→\n   187→      if (msg.type === \"operation\") {\n   188→        handleOperation(session, client, msg);\n   189→      } else if (msg.type === \"cursor\") {\n   190→        // Cursor tracking -- could broadcast to other clients\n   191→        // For now, we acknowledge but don't broadcast\n   192→      } else {\n   193→        sendMessage(ws, {\n   194→          type: \"error\",\n   195→          message: `Unknown message type: ${(msg as { type: string }).type}`,\n   196→        });\n   197→      }\n   198→    });\n   199→\n   200→    ws.on(\"close\", () => {\n   201→      session.clients.delete(clientId);\n   202→      // Clean up empty sessions\n   203→      if (session.clients.size === 0) {\n   204→        sessions.delete(documentId!);\n   205→      }\n   206→    });\n   207→\n   208→    ws.on(\"error\", () => {\n   209→      session.clients.delete(clientId);\n   210→      if (session.clients.size === 0) {\n   211→        sessions.delete(documentId!);\n   212→      }\n   213→    });\n   214→  });\n   215→\n   216→  function handleOperation(\n   217→    session: DocumentSession,\n   218→    client: ClientConnection,\n   219→    msg: ClientOperationMessage\n   220→  ) {\n   221→    const { version, operation } = msg;\n   222→\n   223→    // Validate version\n   224→    if (\n   225→      typeof version !== \"number\" ||\n   226→      !Number.isInteger(version) ||\n   227→      version < 0\n   228→    ) {\n   229→      sendMessage(client.ws, {\n   230→        type: \"error\",\n   231→        message: \"Invalid version number\",\n   232→      });\n   233→      return;\n   234→    }\n   235→\n   236→    if (version > session.serverVersion) {\n   237→      sendMessage(client.ws, {\n   238→        type: \"error\",\n   239→        message: `Version ${version} is ahead of server version ${session.serverVersion}`,\n   240→      });\n   241→      return;\n   242→    }\n   243→\n   244→    // Validate operation structure\n   245→    if (!operation || !Array.isArray(operation.ops)) {\n   246→      sendMessage(client.ws, {\n   247→        type: \"error\",\n   248→        message: \"Invalid operation structure\",\n   249→      });\n   250→      return;\n   251→    }\n   252→\n   253→    // Get current document content\n   254→    const doc = repo.getById(session.documentId);\n   255→    if (!doc) {\n   256→      sendMessage(client.ws, { type: \"error\", message: \"Document not found\" });\n   257→      return;\n   258→    }\n   259→\n   260→    // Transform the operation against all operations that happened since the client's version\n   261→    let transformedOp = operation;\n   262→    try {\n   263→      for (let i = version; i < session.serverVersion; i++) {\n   264→        const serverOp = session.operationLog[i - (session.serverVersion - session.operationLog.length)];\n   265→        if (!serverOp) {\n   266→          sendMessage(client.ws, {\n   267→            type: \"error\",\n   268→            message: \"Cannot transform: missing operation history\",\n   269→          });\n   270→          return;\n   271→        }\n   272→        const [clientPrime] = transform(transformedOp, serverOp);\n   273→        transformedOp = clientPrime;\n   274→      }\n   275→    } catch (e) {\n   276→      sendMessage(client.ws, {\n   277→        type: \"error\",\n   278→        message: `Transform error: ${e instanceof Error ? e.message : String(e)}`,\n   279→      });\n   280→      return;\n   281→    }\n   282→\n   283→    // Validate the transformed operation against the current document\n   284→    const validationError = validateOperation(transformedOp, doc.content.length);\n   285→    if (validationError) {\n   286→      sendMessage(client.ws, {\n   287→        type: \"error\",\n   288→        message: `Invalid operation: ${validationError}`,\n   289→      });\n   290→      return;\n   291→    }\n   292→\n   293→    // Apply the operation\n   294→    let newContent: string;\n   295→    try {\n   296→      newContent = apply(doc.content, transformedOp);\n   297→    } catch (e) {\n   298→      sendMessage(client.ws, {\n   299→        type: \"error\",\n   300→        message: `Apply error: ${e instanceof Error ? e.message : String(e)}`,\n   301→      });\n   302→      return;\n   303→    }\n   304→\n   305→    // Persist the change\n   306→    session.serverVersion++;\n   307→    session.operationLog.push(transformedOp);\n   308→    repo.updateContent(session.documentId, newContent, transformedOp);\n   309→\n   310→    // Broadcast to all clients\n   311→    broadcastOperation(session, transformedOp, session.serverVersion, client.id);\n   312→  }\n   313→\n   314→  function closeAll() {\n   315→    for (const session of sessions.values()) {\n   316→      for (const client of session.clients.values()) {\n   317→        client.ws.close(1001, \"Server shutting down\");\n   318→      }\n   319→    }\n   320→    sessions.clear();\n   321→    wss.close();\n   322→  }\n   323→\n   324→  return { wss, sessions, closeAll };\n   325→}\n   326→"}]},"parent_tool_use_id":"toolu_01Kftm1Yi94wZ75JVYuC6FGM","session_id":"a3069b4b-a5ce-43d4-9247-c633b9aacc8f","uuid":"8711cb70-6e89-4019-93b0-27ea76d90710"}
