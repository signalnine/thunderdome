+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LqH59PjZgEGQjvGLJwTVUA","type":"tool_result","content":"     1→/**\n     2→ * Operational Transformation (OT) engine for collaborative editing.\n     3→ *\n     4→ * Operations are represented as a sequence of components:\n     5→ * - { type: \"retain\", count: n } -- skip n characters\n     6→ * - { type: \"insert\", text: s }  -- insert string s at current position\n     7→ * - { type: \"delete\", count: n } -- delete n characters at current position\n     8→ *\n     9→ * An operation also carries a base length (the length of the document it applies to)\n    10→ * and a target length (the length of the document after applying it).\n    11→ */\n    12→\n    13→export interface RetainOp {\n    14→  type: \"retain\";\n    15→  count: number;\n    16→}\n    17→\n    18→export interface InsertOp {\n    19→  type: \"insert\";\n    20→  text: string;\n    21→}\n    22→\n    23→export interface DeleteOp {\n    24→  type: \"delete\";\n    25→  count: number;\n    26→}\n    27→\n    28→export type OpComponent = RetainOp | InsertOp | DeleteOp;\n    29→\n    30→export interface Operation {\n    31→  baseLength: number;\n    32→  targetLength: number;\n    33→  ops: OpComponent[];\n    34→}\n    35→\n    36→/** Validate that an operation is well-formed for a document of the given length. */\n    37→export function validateOperation(\n    38→  op: Operation,\n    39→  docLength: number\n    40→): string | null {\n    41→  if (op.baseLength !== docLength) {\n    42→    return `Operation baseLength (${op.baseLength}) does not match document length (${docLength})`;\n    43→  }\n    44→\n    45→  let consumedInput = 0;\n    46→  let producedOutput = 0;\n    47→\n    48→  for (const component of op.ops) {\n    49→    switch (component.type) {\n    50→      case \"retain\":\n    51→        if (component.count <= 0 || !Number.isInteger(component.count)) {\n    52→          return `Invalid retain count: ${component.count}`;\n    53→        }\n    54→        consumedInput += component.count;\n    55→        producedOutput += component.count;\n    56→        break;\n    57→      case \"insert\":\n    58→        if (typeof component.text !== \"string\" || component.text.length === 0) {\n    59→          return `Invalid insert text`;\n    60→        }\n    61→        producedOutput += component.text.length;\n    62→        break;\n    63→      case \"delete\":\n    64→        if (component.count <= 0 || !Number.isInteger(component.count)) {\n    65→          return `Invalid delete count: ${component.count}`;\n    66→        }\n    67→        consumedInput += component.count;\n    68→        break;\n    69→      default:\n    70→        return `Unknown operation type: ${(component as OpComponent).type}`;\n    71→    }\n    72→  }\n    73→\n    74→  if (consumedInput !== op.baseLength) {\n    75→    return `Operations consume ${consumedInput} chars but baseLength is ${op.baseLength}`;\n    76→  }\n    77→\n    78→  if (producedOutput !== op.targetLength) {\n    79→    return `Operations produce ${producedOutput} chars but targetLength is ${op.targetLength}`;\n    80→  }\n    81→\n    82→  return null;\n    83→}\n    84→\n    85→/** Apply an operation to a document string, returning the new document. */\n    86→export function apply(doc: string, op: Operation): string {\n    87→  const error = validateOperation(op, doc.length);\n    88→  if (error) {\n    89→    throw new Error(`Cannot apply operation: ${error}`);\n    90→  }\n    91→\n    92→  let pos = 0;\n    93→  let result = \"\";\n    94→\n    95→  for (const component of op.ops) {\n    96→    switch (component.type) {\n    97→      case \"retain\":\n    98→        result += doc.slice(pos, pos + component.count);\n    99→        pos += component.count;\n   100→        break;\n   101→      case \"insert\":\n   102→        result += component.text;\n   103→        break;\n   104→      case \"delete\":\n   105→        pos += component.count;\n   106→        break;\n   107→    }\n   108→  }\n   109→\n   110→  return result;\n   111→}\n   112→\n   113→/**\n   114→ * Transform two concurrent operations (a and b) that were both applied to the same\n   115→ * base document. Returns [a', b'] such that:\n   116→ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')\n   117→ *\n   118→ * This is the core OT algorithm that ensures convergence.\n   119→ */\n   120→export function transform(\n   121→  a: Operation,\n   122→  b: Operation\n   123→): [Operation, Operation] {\n   124→  if (a.baseLength !== b.baseLength) {\n   125→    throw new Error(\n   126→      `Transform requires operations with the same baseLength: ${a.baseLength} vs ${b.baseLength}`\n   127→    );\n   128→  }\n   129→\n   130→  const aPrime: OpComponent[] = [];\n   131→  const bPrime: OpComponent[] = [];\n   132→\n   133→  // Flatten operations into a stream of unit-sized components for easier processing\n   134→  // We iterate both ops simultaneously, consuming from each as needed.\n   135→  // We track position in each operation's component list and partial offset.\n   136→  let aIdx = 0;\n   137→  let aOff = 0; // offset within current a component (for retain/delete)\n   138→  let bIdx = 0;\n   139→  let bOff = 0;\n   140→\n   141→  function aType(): OpComponent[\"type\"] | null {\n   142→    if (aIdx >= a.ops.length) return null;\n   143→    return a.ops[aIdx].type;\n   144→  }\n   145→\n   146→  function bType(): OpComponent[\"type\"] | null {\n   147→    if (bIdx >= b.ops.length) return null;\n   148→    return b.ops[bIdx].type;\n   149→  }\n   150→\n   151→  function aRemaining(): number {\n   152→    if (aIdx >= a.ops.length) return 0;\n   153→    const op = a.ops[aIdx];\n   154→    if (op.type === \"insert\") return op.text.length - aOff;\n   155→    return op.count - aOff;\n   156→  }\n   157→\n   158→  function bRemaining(): number {\n   159→    if (bIdx >= b.ops.length) return 0;\n   160→    const op = b.ops[bIdx];\n   161→    if (op.type === \"insert\") return op.text.length - bOff;\n   162→    return op.count - bOff;\n   163→  }\n   164→\n   165→  function consumeA(n: number) {\n   166→    aOff += n;\n   167→    const op = a.ops[aIdx];\n   168→    const total = op.type === \"insert\" ? op.text.length : op.count;\n   169→    if (aOff >= total) {\n   170→      aIdx++;\n   171→      aOff = 0;\n   172→    }\n   173→  }\n   174→\n   175→  function consumeB(n: number) {\n   176→    bOff += n;\n   177→    const op = b.ops[bIdx];\n   178→    const total = op.type === \"insert\" ? op.text.length : op.count;\n   179→    if (bOff >= total) {\n   180→      bIdx++;\n   181→      bOff = 0;\n   182→    }\n   183→  }\n   184→\n   185→  function takeAInsert(): InsertOp {\n   186→    const op = a.ops[aIdx] as InsertOp;\n   187→    const text = op.text.slice(aOff);\n   188→    aIdx++;\n   189→    aOff = 0;\n   190→    return { type: \"insert\", text };\n   191→  }\n   192→\n   193→  function takeBInsert(): InsertOp {\n   194→    const op = b.ops[bIdx] as InsertOp;\n   195→    const text = op.text.slice(bOff);\n   196→    bIdx++;\n   197→    bOff = 0;\n   198→    return { type: \"insert\", text };\n   199→  }\n   200→\n   201→  while (aIdx < a.ops.length || bIdx < b.ops.length) {\n   202→    const at = aType();\n   203→    const bt = bType();\n   204→\n   205→    // a inserts: goes into a', b' retains over it\n   206→    if (at === \"insert\") {\n   207→      const ins = takeAInsert();\n   208→      aPrime.push(ins);\n   209→      bPrime.push({ type: \"retain\", count: ins.text.length });\n   210→      continue;\n   211→    }\n   212→\n   213→    // b inserts: goes into b', a' retains over it\n   214→    if (bt === \"insert\") {\n   215→      const ins = takeBInsert();\n   216→      bPrime.push(ins);\n   217→      aPrime.push({ type: \"retain\", count: ins.text.length });\n   218→      continue;\n   219→    }\n   220→\n   221→    if (at === null || bt === null) {\n   222→      throw new Error(\"Transform ran out of operations unexpectedly\");\n   223→    }\n   224→\n   225→    const ar = aRemaining();\n   226→    const br = bRemaining();\n   227→    const min = Math.min(ar, br);\n   228→\n   229→    if (at === \"retain\" && bt === \"retain\") {\n   230→      consumeA(min);\n   231→      consumeB(min);\n   232→      aPrime.push({ type: \"retain\", count: min });\n   233→      bPrime.push({ type: \"retain\", count: min });\n   234→    } else if (at === \"delete\" && bt === \"delete\") {\n   235→      // Both delete same chars, cancel out\n   236→      consumeA(min);\n   237→      consumeB(min);\n   238→    } else if (at === \"delete\" && bt === \"retain\") {\n   239→      consumeA(min);\n   240→      consumeB(min);\n   241→      aPrime.push({ type: \"delete\", count: min });\n   242→    } else if (at === \"retain\" && bt === \"delete\") {\n   243→      consumeA(min);\n   244→      consumeB(min);\n   245→      bPrime.push({ type: \"delete\", count: min });\n   246→    }\n   247→  }\n   248→\n   249→  // a' applies after b, so a'.baseLength = b.targetLength\n   250→  const aPrimeOp = buildOperation(aPrime, b.targetLength);\n   251→  // b' applies after a, so b'.baseLength = a.targetLength\n   252→  const bPrimeOp = buildOperation(bPrime, a.targetLength);\n   253→\n   254→  return [aPrimeOp, bPrimeOp];\n   255→}\n   256→\n   257→function buildOperation(ops: OpComponent[], baseLength: number): Operation {\n   258→  // Merge adjacent same-type components\n   259→  const merged: OpComponent[] = [];\n   260→  for (const op of ops) {\n   261→    if (merged.length > 0) {\n   262→      const last = merged[merged.length - 1];\n   263→      if (last.type === \"retain\" && op.type === \"retain\") {\n   264→        merged[merged.length - 1] = {\n   265→          type: \"retain\",\n   266→          count: last.count + op.count,\n   267→        };\n   268→        continue;\n   269→      }\n   270→      if (last.type === \"delete\" && op.type === \"delete\") {\n   271→        merged[merged.length - 1] = {\n   272→          type: \"delete\",\n   273→          count: last.count + op.count,\n   274→        };\n   275→        continue;\n   276→      }\n   277→      if (last.type === \"insert\" && op.type === \"insert\") {\n   278→        merged[merged.length - 1] = {\n   279→          type: \"insert\",\n   280→          text: last.text + op.text,\n   281→        };\n   282→        continue;\n   283→      }\n   284→    }\n   285→    merged.push(op);\n   286→  }\n   287→\n   288→  let produced = 0;\n   289→  for (const op of merged) {\n   290→    switch (op.type) {\n   291→      case \"retain\":\n   292→        produced += op.count;\n   293→        break;\n   294→      case \"insert\":\n   295→        produced += op.text.length;\n   296→        break;\n   297→      case \"delete\":\n   298→        break;\n   299→    }\n   300→  }\n   301→\n   302→  return {\n   303→    baseLength,\n   304→    targetLength: produced,\n   305→    ops: merged,\n   306→  };\n   307→}\n   308→\n   309→/**\n   310→ * Create a simple insert operation at a given position in a document.\n   311→ */\n   312→export function createInsertOp(\n   313→  docLength: number,\n   314→  position: number,\n   315→  text: string\n   316→): Operation {\n   317→  const ops: OpComponent[] = [];\n   318→  if (position > 0) ops.push({ type: \"retain\", count: position });\n   319→  ops.push({ type: \"insert\", text });\n   320→  if (position < docLength)\n   321→    ops.push({ type: \"retain\", count: docLength - position });\n   322→\n   323→  return {\n   324→    baseLength: docLength,\n   325→    targetLength: docLength + text.length,\n   326→    ops,\n   327→  };\n   328→}\n   329→\n   330→/**\n   331→ * Create a simple delete operation at a given position in a document.\n   332→ */\n   333→export function createDeleteOp(\n   334→  docLength: number,\n   335→  position: number,\n   336→  count: number\n   337→): Operation {\n   338→  const ops: OpComponent[] = [];\n   339→  if (position > 0) ops.push({ type: \"retain\", count: position });\n   340→  ops.push({ type: \"delete\", count });\n   341→  if (position + count < docLength)\n   342→    ops.push({ type: \"retain\", count: docLength - position - count });\n   343→\n   344→  return {\n   345→    baseLength: docLength,\n   346→    targetLength: docLength - count,\n   347→    ops,\n   348→  };\n   349→}\n   350→"}]},"parent_tool_use_id":"toolu_01Kftm1Yi94wZ75JVYuC6FGM","session_id":"a3069b4b-a5ce-43d4-9247-c633b9aacc8f","uuid":"cc51c2cf-6490-41d7-a548-4e9e71f59a98"}
