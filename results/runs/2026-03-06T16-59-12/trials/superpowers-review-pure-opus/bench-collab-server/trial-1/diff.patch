th: computeTargetLength(aPrime, b.targetLength),\n    ops: aPrime,\n  };\n\n  const bPrimeOp: Operation = {\n    baseLength: a.targetLength,\n    targetLength: computeTargetLength(bPrime, a.targetLength),\n    ops: bPrime,\n  };\n\n  return [aPrimeOp, bPrimeOp];\n}\n\nfunction computeTargetLength(ops: OpComponent[], baseLength: number): number {\n  let consumed = 0;\n  let produced = 0;\n  for (const op of ops) {\n    switch (op.type) {\n      case \"retain\":\n        consumed += op.count;\n        produced += op.count;\n        break;\n      case \"insert\":\n        produced += op.text.length;\n        break;\n      case \"delete\":\n        consumed += op.count;\n        break;\n    }\n  }\n  // Sanity check\n  if (consumed !== baseLength) {\n    // If there's remaining base, add implicit retain\n    // This shouldn't happen with correct transform, but be safe\n  }\n  return produced;\n}\n\n/**\n * Create a simple insert operation at a given position in a document.\n */\nexport function createInsertOp(\n  docLength: number,\n  position: number,\n  text: string\n): Operation {\n  const ops: OpComponent[] = [];\n  if (position > 0) ops.push({ type: \"retain\", count: position });\n  ops.push({ type: \"insert\", text });\n  if (position < docLength)\n    ops.push({ type: \"retain\", count: docLength - position });\n\n  return {\n    baseLength: docLength,\n    targetLength: docLength + text.length,\n    ops,\n  };\n}\n\n/**\n * Create a simple delete operation at a given position in a document.\n */\nexport function createDeleteOp(\n  docLength: number,\n  position: number,\n  count: number\n): Operation {\n  const ops: OpComponent[] = [];\n  if (position > 0) ops.push({ type: \"retain\", count: position });\n  ops.push({ type: \"delete\", count });\n  if (position + count < docLength)\n    ops.push({ type: \"retain\", count: docLength - position - count });\n\n  return {\n    baseLength: docLength,\n    targetLength: docLength - count,\n    ops,\n  };\n}\n"},"call