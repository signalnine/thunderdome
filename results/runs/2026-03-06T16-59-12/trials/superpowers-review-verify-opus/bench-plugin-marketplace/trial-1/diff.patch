be('addReview', () => {\n    it('should add a review with auto-generated fields', () => {\n      const review = reviews.addReview({\n        pluginName: 'test-plugin',\n        pluginVersion: '1.0.0',\n        userId: 'user1',\n        rating: 5,\n        comment: 'Great plugin!',\n      });\n      expect(review.id).toBe(1);\n      expect(review.flagged).toBe(false);\n      expect(review.createdAt).toBeDefined();\n      expect(review.pluginName).toBe('test-plugin');\n      expect(review.rating).toBe(5);\n    });\n\n    it('should auto-increment IDs', () => {\n      const r1 = reviews.addReview({\n        pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'ok',\n      });\n      const r2 = reviews.addReview({\n        pluginName: 'p2', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: 'good',\n      });\n      expect(r2.id).toBe(r1.id + 1);\n    });\n\n    it('should reject invalid ratings', () => {\n      expect(() =>\n        reviews.addReview({\n          pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 0, comment: 'bad',\n        })\n      ).toThrow();\n      expect(() =>\n        reviews.addReview({\n          pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 6, comment: 'bad',\n        })\n      ).toThrow();\n    });\n  });\n\n  describe('getReviews', () => {\n    it('should return reviews for a specific plugin', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'great' });\n      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'ok' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u3', rating: 4, comment: 'good' });\n\n      const p1Reviews = reviews.getReviews('p1');\n      expect(p1Reviews).toHaveLength(2);\n      expect(p1Reviews.every(r => r.pluginName === 'p1')).toBe(true);\n    });\n\n    it('should return empty array for plugin with no reviews', () => {\n      expect(reviews.getReviews('nonexistent')).toEqual([]);\n    });\n  });\n\n  describe('getAverageRating', () => {\n    it('should calculate average rating', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n      expect(reviews.getAverageRating('p1')).toBe(4);\n    });\n\n    it('should exclude flagged reviews from average', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'spam' });\n      reviews.flagReview(r1.id);\n      // unflagged: 3 and 1, average = 2\n      expect(reviews.getAverageRating('p1')).toBe(2);\n    });\n\n    it('should return 0 for plugin with no reviews', () => {\n      expect(reviews.getAverageRating('nonexistent')).toBe(0);\n    });\n\n    it('should return 0 when all reviews are flagged', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.flagReview(r1.id);\n      expect(reviews.getAverageRating('p1')).toBe(0);\n    });\n  });\n\n  describe('flagReview', () => {\n    it('should flag a review', () => {\n      const review = reviews.addReview({\n        pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'great',\n      });\n      reviews.flagReview(review.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].id).toBe(review.id);\n    });\n\n    it('should throw when flagging non-existent review', () => {\n      expect(() => reviews.flagReview(999)).toThrow();\n    });\n  });\n\n  describe('getFlaggedReviews', () => {\n    it('should return only flagged reviews', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n      reviews.flagReview(r1.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].flagged).toBe(true);\n    });\n  });\n\n  describe('removeReview', () => {\n    it('should remove a review', () => {\n      const review = reviews.addReview({\n        pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '',\n      });\n      expect(reviews.removeReview(review.id)).toBe(true);\n      expect(reviews.getReviews('p1')).toHaveLength(0);\n    });\n\n    it('should return false for non-existent review', () => {\n      expect(reviews.removeReview(999)).toBe(false);\n    });\n  });\n\n  describe('getReviewsByUser', () => {\n    it('should return reviews by a specific user', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: '' });\n      reviews.addReview({ pluginName: 'p3', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: '' });\n\n      const aliceReviews = reviews.getReviewsByUser('alice');\n      expect(aliceReviews).toHaveLength(2);\n      expect(aliceReviews.every(r => r.userId === 'alice')).toBe(true);\n    });\n  });\n\n  describe('getReviewCount', () => {\n    it('should return count of reviews for a plugin', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n      reviews.addReview({ pluginName: 'p2', pluginVersion: