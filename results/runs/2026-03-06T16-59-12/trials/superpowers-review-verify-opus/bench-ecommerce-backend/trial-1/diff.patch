4→\n    85→  it('should emit product:created event', async () => {\n    86→    const catalog = createCatalogService(bus);\n    87→    catalog.createProduct('Test', 5, 'cat');\n    88→    const log = bus.getLog();\n    89→    const event = log.find(e => e.event === Events.PRODUCT_CREATED);\n    90→    expect(event).toBeDefined();\n    91→    expect((event?.payload as { name: string }).name).toBe('Test');\n    92→  });\n    93→});\n    94→\n    95→describe('Inventory Service', () => {\n    96→  let bus: EventBus;\n    97→\n    98→  beforeEach(() => {\n    99→    bus = new EventBus();\n   100→  });\n   101→\n   102→  it('should set and get stock', () => {\n   103→    const inventory = createInventoryService(bus);\n   104→    inventory.setStock('p1', 100);\n   105→    expect(inventory.getStock('p1')).toBe(100);\n   106→  });\n   107→\n   108→  it('should return 0 for unknown product', () => {\n   109→    const inventory = createInventoryService(bus);\n   110→    expect(inventory.getStock('unknown')).toBe(0);\n   111→  });\n   112→\n   113→  it('should reserve stock successfully', () => {\n   114→    const inventory = createInventoryService(bus);\n   115→    inventory.setStock('p1', 10);\n   116→    expect(inventory.reserve('p1', 5)).toBe(true);\n   117→    expect(inventory.getStock('p1')).toBe(5);\n   118→  });\n   119→\n   120→  it('should fail to reserve insufficient stock', () => {\n   121→    const inventory = createInventoryService(bus);\n   122→    inventory.setStock('p1', 3);\n   123→    expect(inventory.reserve('p1', 5)).toBe(false);\n   124→    expect(inventory.getStock('p1')).toBe(3);\n   125→  });\n   126→\n   127→  it('should release reserved stock', () => {\n   128→    const inventory = createInventoryService(bus);\n   129→    inventory.setStock('p1', 10);\n   130→    inventory.reserve('p1', 5);\n   131→    inventory.release('p1', 3);\n   132→    expect(inventory.getStock('p1')).toBe(8);\n   133→  });\n   134→\n   135→  it('should emit low stock alert', () => {\n   136→    const inventory = createInventoryService(bus);\n   137→    inventory.setStock('p1', 10);\n   138→    inventory.setLowStockThreshold('p1', 5);\n   139→    inventory.setStock('p1', 3);\n   140→    const log = bus.getLog();\n   141→    const alert = log.find(e => e.event === Events.LOW_STOCK_ALERT);\n   142→    expect(alert).toBeDefined();\n   143→  });\n   144→});\n   145→\n   146→describe('Cart Service', () => {\n   147→  let bus: EventBus;\n   148→\n   149→  beforeEach(() => {\n   150→    bus = new EventBus();\n   151→  });\n   152→\n   153→  it('should create a cart', () => {\n   154→    const cart = createCartService(bus);\n   155→    const id = cart.createCart('user1');\n   156→    expect(id).toBeDefined();\n   157→    const c = cart.getCart(id);\n   158→    expect(c?.userId).toBe('user1');\n   159→    expect(c?.items).toEqual([]);\n   160→  });\n   161→\n   162→  it('should add items to cart', () => {\n   163→    const cart = createCartService(bus);\n   164→    const id = cart.createCart('user1');\n   165→    cart.addItem(id, 'p1', 2);\n   166→    const c = cart.getCart(id);\n   167→    expect(c?.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n   168→  });\n   169→\n   170→  it('should consolidate duplicate items', () => {\n   171→    const cart = createCartService(bus);\n   172→    const id = cart.createCart('user1');\n   173→    cart.addItem(id, 'p1', 2);\n   174→    cart.addItem(id, 'p1', 3);\n   175→    const c = cart.getCart(id);\n   176→    expect(c?.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n   177→  });\n   178→\n   179→  it('should remove items from cart', () => {\n   180→    const cart = createCartService(bus);\n   181→    const id = cart.createCart('user1');\n   182→    cart.addItem(id, 'p1', 2);\n   183→    cart.addItem(id, 'p2', 1);\n   184→    cart.removeItem(id, 'p1');\n   185→    const c = cart.getCart(id);\n   186→    expect(c?.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n   187→  });\n   188→\n   189→  it