+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01E6evZFUEGoocKX2FRKrxFk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EoEhPxLZsGhdT56Pcbyc6C","name":"Write","input":{"file_path":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\n\ndescribe('Catalog Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create and retrieve a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for non-existent product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Gizmo', 2, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('should search products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Item', 1, 'electronics');\n    const results = catalog.searchProducts('electron');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Old', 5, 'cat');\n    catalog.updateProduct(id, { name: 'New', price: 10 });\n    const product = catalog.getProduct(id);\n    expect(product?.name).toBe('New');\n    expect(product?.price).toBe(10);\n    expect(product?.category).toBe('cat');\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('A', 1, 'cat');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n  });\n\n  it('should return false when removing nonexistent product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.removeProduct('nope')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Test', 5, 'cat');\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.PRODUCT_CREATED);\n    expect(event).toBeDefined();\n    expect((event?.payload as { name: string }).name).toBe('Test');\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    const log = bus.getLog();\n    const alert = log.find(e => e.event === Events.LOW_STOCK_ALERT);\n    expect(alert).toBeDefined();\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeDefined();\n    const c = cart.getCart(id);\n    expect(c?.userId).toBe('user1');\n    expect(c?.items).toEqual([]);\n  });\n\n  it('should add items to cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n  });\n\n  it('should consolidate duplicate items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove items from cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id);\n    expect(c?.items[0].quantity).toBe(10);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([]);\n  });\n\n  it('should return null for nonexistent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nope')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n      { productId: 'p2', quantity: 1, price: 20 },\n    ]);\n    expect(result.subtotal).toBe(40);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(4);\n    expect(result.total).toBe(44);\n  });\n\n  it('should apply discount code before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product:created events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 25, category: 'cat' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n\n  it('should ignore invalid discount code', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in pending status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order?.status).toBe(OrderStatus.PENDING);\n    expect(order?.userId).toBe('user1');\n    expect(order?.total).toBe(50);\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order:created event', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n  });\n\n  it('should emit order:status_changed with previous status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    const payload = event?.payload as { previousStatus: string; status: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user2', 'cart2', 30);\n    orders.createOrder('user1', 'cart3', 20);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for nonexistent order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nope')).toBeNull();\n  });\n\n  it('should cancel an order', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund nonexistent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('fake-tx');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should deliver notifications to subscribed users on order creation', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(1);\n    expect(notifs.some(n => n.type === 'order_created')).toBe(true);\n  });\n\n  it('should deliver notifications on order status change', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should deliver notifications on payment processed', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not deliver to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'A', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'B', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue for failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p1', quantity: 1 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 3 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(2);\n    expect(top[0]).toEqual({ productId: 'p1', count: 5 });\n    expect(top[1]).toEqual({ productId: 'p2', count: 3 });\n  });\n});\n\ndescribe('End-to-end integration', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should handle full order lifecycle', async () => {\n    // Create all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'electronics');\n\n    // Check pricing gets product prices via event\n    expect(pricing.getPrice(p1)).toBe(999);\n    expect(pricing.getPrice(p2)).toBe(29);\n\n    // Set inventory\n    inventory.setStock(p1, 50);\n    inventory.setStock(p2, 200);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n\n    // Calculate total\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1057);\n    expect(totals.tax).toBeCloseTo(105.7);\n    expect(totals.total).toBeCloseTo(1162.7);\n\n    // Reserve inventory\n    for (const item of cart.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, totals.total);\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(4); // order created + status changes + payment\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBeCloseTo(1162.7);\n    expect(analytics.getConversionRate()).toBe(1);\n\n    const topProducts = analytics.getTopProducts(2);\n    expect(topProducts).toHaveLength(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":440,"cache_read_input_tokens":28666,"cache_creation":{"ephemeral_5m_input_tokens":440,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"14b9b72f-ead1-4a0c-a5b7-8f08b523350e","uuid":"260662b2-73f1-42d5-8383-1cd95d934ffe"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EoEhPxLZsGhdT56Pcbyc6C","type":"tool_result","content":"File created successfully at: /workspace/tests/services.test.ts"}]},"parent_tool_use_id":null,"session_id":"14b9b72f-ead1-4a0c-a5b7-8f08b523350e","uuid":"153ebf6b-bb8b-41d4-a0a0-7371e7489c52","tool_use_result":{"type":"create","filePath":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\n\ndescribe('Catalog Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create and retrieve a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for non-existent product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Gizmo', 2, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('should search products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Item', 1, 'electronics');\n    const results = catalog.searchProducts('electron');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Old', 5, 'cat');\n    catalog.updateProduct(id, { name: 'New', price: 10 });\n    const product = catalog.getProduct(id);\n    expect(product?.name).toBe('New');\n    expect(product?.price).toBe(10);\n    expect(product?.category).toBe('cat');\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('A', 1, 'cat');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n  });\n\n  it('should return false when removing nonexistent product', () => {\n    const catalog = createCatalogService(bus);\n    expect(catalog.removeProduct('nope')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Test', 5, 'cat');\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.PRODUCT_CREATED);\n    expect(event).toBeDefined();\n    expect((event?.payload as { name: string }).name).toBe('Test');\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    const log = bus.getLog();\n    const alert = log.find(e => e.event === Events.LOW_STOCK_ALERT);\n    expect(alert).toBeDefined();\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeDefined();\n    const c = cart.getCart(id);\n    expect(c?.userId).toBe('user1');\n    expect(c?.items).toEqual([]);\n  });\n\n  it('should add items to cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n  });\n\n  it('should consolidate duplicate items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove items from cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id);\n    expect(c?.items[0].quantity).toBe(10);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([]);\n  });\n\n  it('should return null for nonexistent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nope')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n      { productId: 'p2', quantity: 1, price: 20 },\n    ]);\n    expect(result.subtotal).toBe(40);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(4);\n    expect(result.total).toBe(44);\n  });\n\n  it('should apply discount code before tax', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product:created events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 25, category: 'cat' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n\n  it('should ignore invalid discount code', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order in pending status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order?.status).toBe(OrderStatus.PENDING);\n    expect(order?.userId).toBe('user1');\n    expect(order?.total).toBe(50);\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order:created event', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n  });\n\n  it('should emit order:status_changed with previous status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    const payload = event?.payload as { previousStatus: string; status: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user2', 'cart2', 30);\n    orders.createOrder('user1', 'cart3', 20);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for nonexistent order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nope')).toBeNull();\n  });\n\n  it('should cancel an order', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund nonexistent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('fake-tx');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should deliver notifications to subscribed users on order creation', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(1);\n    expect(notifs.some(n => n.type === 'order_created')).toBe(true);\n  });\n\n  it('should deliver notifications on order status change', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should deliver notifications on payment processed', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not deliver to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'A', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'B', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue for failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p1', quantity: 1 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 3 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(2);\n    expect(top[0]).toEqual({ productId: 'p1', count: 5 });\n    expect(top[1]).toEqual({ productId: 'p2', count: 3 });\n  });\n});\n\ndescribe('End-to-end integration', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should handle full order lifecycle', async () => {\n    // Create all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'electronics');\n\n    // Check pricing gets product prices via event\n    expect(pricing.getPrice(p1)).toBe(999);\n    expect(pricing.getPrice(p2)).toBe(29);\n\n    // Set inventory\n    inventory.setStock(p1, 50);\n    inventory.setStock(p2, 200);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n\n    // Calculate total\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1057);\n    expect(totals.tax).toBeCloseTo(105.7);\n    expect(totals.total).toBeCloseTo(1162.7);\n\n    // Reserve inventory\n    for (const item of cart.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, totals.total);\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(4); // order created + status changes + payment\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBeCloseTo(1162.7);\n    expect(analytics.getConversionRate()).toBe(1);\n\n    const topProducts = analytics.getTopProducts(2);\n    expect(topProducts).toHaveLength(2);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
