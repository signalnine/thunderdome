e(99);\n   243→  });\n   244→\n   245→  it('should track prices from product:created events', async () => {\n   246→    const pricing = createPricingService(bus);\n   247→    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 25, category: 'cat' });\n   248→    expect(pricing.getPrice('p1')).toBe(25);\n   249→  });\n   250→\n   251→  it('should return 0 for unknown product price', () => {\n   252→    const pricing = createPricingService(bus);\n   253→    expect(pricing.getPrice('unknown')).toBe(0);\n   254→  });\n   255→\n   256→  it('should ignore invalid discount code', () => {\n   257→    const pricing = createPricingService(bus);\n   258→    const result = pricing.calculateTotal(\n   259→      [{ productId: 'p1', quantity: 1, price: 100 }],\n   260→      'INVALID'\n   261→    );\n   262→    expect(result.discount).toBe(0);\n   263→    expect(result.total).toBe(110);\n   264→  });\n   265→});\n   266→\n   267→describe('Order Service', () => {\n   268→  let bus: EventBus;\n   269→\n   270→  beforeEach(() => {\n   271→    bus = new EventBus();\n   272→  });\n   273→\n   274→  it('should create an order in pending status', () => {\n   275→    const orders = createOrderService(bus);\n   276→    const id = orders.createOrder('user1', 'cart1', 50);\n   277→    const order = orders.getOrder(id);\n   278→    expect(order?.status).toBe(OrderStatus.PENDING);\n   279→    expect(order?.userId).toBe('user1');\n   280→    expect(order?.total).toBe(50);\n   281→  });\n   282→\n   283→  it('should update order status', () => {\n   284→    const orders = createOrderService(bus);\n   285→    const id = orders.createOrder('user1', 'cart1', 50);\n   286→    orders.updateStatus(id, OrderStatus.CONFIRMED);\n   287→    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n   288→  });\n   289→\n   290→  it('should emit order:created event', () => {\n   291→    const orders = createOrderService(bus);\n   292→    orders.createOrder('user1', 'cart1'