tries[1].endTime).toBeNull();\n      expect(entries[1].task).toBe(\"task2\");\n    });\n\n    it(\"should throw when starting with empty name\", () => {\n      expect(() => tracker.start(\"\")).toThrow();\n      expect(() => tracker.start(\"   \")).toThrow();\n    });\n\n    it(\"should throw when stopping with no running timer\", () => {\n      expect(() => tracker.stop()).toThrow();\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should persist data to file\", () => {\n      tracker.start(\"work\");\n      tracker.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"work\");\n    });\n\n    it(\"should create parent directories if they don't exist\", () => {\n      const nested = path.join(os.tmpdir(), `tt-${Date.now()}`, \"a\", \"b\", \"data.json\");\n      const t = new TimeTracker(nested);\n      t.start(\"test\");\n      t.stop();\n      expect(fs.existsSync(nested)).toBe(true);\n      fs.rmSync(path.join(os.tmpdir(), `tt-${Date.now()}`), { recursive: true, force: true });\n    });\n  });\n\n  describe(\"querying\", () => {\n    it(\"should return all entries without filters\", () => {\n      tracker.start(\"a\");\n      tracker.stop();\n      tracker.start(\"b\");\n      tracker.stop();\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it(\"should filter entries by date range\", () => {\n      tracker.start(\"old\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      const entryTime = new Date(entries[0].startTime);\n\n      const before = new Date(entryTime.getTime() - 1000);\n      const after = new Date(entryTime.getTime() + 1000);\n\n      expect(tracker.getEntries(before, after)).toHaveLength(1);\n      expect(tracker.getEntries(after)).toHaveLength(0);\n    });\n  });\n\n  describe(\"summary\", () => {\n    it(\"should summarize time per task\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"review\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n      expect(summary[\"review\"]).toBeGreaterThanOrEqual(0);\n      expect(Object.keys(summary)).toHaveLength(2);\n    });\n\n    it(\"should include running tasks using current time\", () => {\n      tracker.start(\"running\");\n      const summary = tracker.getSummary();\n      expect(summary[\"running\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle unicode task names\", () => {\n      tracker.start(\"日本語タスク\");\n      tracker.stop();\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"日本語タスク\");\n    });\n\n    it(\"should handle emoji task names\", () => {\n      tracker.start(\"🚀 Deploy\");\n      tracker.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"🚀 Deploy\");\n    });\n\n    it(\"should handle mixed unicode and emoji\", () => {\n      tracker.start(\"café ☕ résumé\");\n      tracker.stop();\n      const summary = tracker.getSummary();\n      expect(summary[\"café ☕ résumé\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
