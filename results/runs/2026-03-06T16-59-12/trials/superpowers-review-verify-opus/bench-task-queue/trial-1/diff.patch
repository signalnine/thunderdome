+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RLv6ziM9jdMFXRqapSTs2Q","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FkgmB3Y6aLJ3kiUnrhAHLR","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskStatus,\n  AddTaskOptions,\n  ProgressListener,\n  Middleware,\n  NextFunction,\n  TaskHandler,\n  ScheduleOptions,\n  Schedule,\n  ShutdownResult,\n  ShutdownOptions,\n} from './types.js';\nimport { parseCron, shouldRun } from './cron.js';\n\nconst DEFAULT_QUEUE = 'default';\n\nexport class TaskQueue {\n  // All tasks by ID\n  private tasks: Map<string, Task> = new Map();\n\n  // Per-queue: list of task IDs in insertion order\n  private queues: Map<string, string[]> = new Map();\n\n  // Per-queue dead letter queues\n  private deadLetterQueues: Map<string, string[]> = new Map();\n\n  // Concurrency limits per queue\n  private concurrencyLimits: Map<string, number> = new Map();\n\n  // Progress listeners per task\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n\n  // Middleware per queue\n  private middlewareStacks: Map<string, Middleware[]> = new Map();\n\n  // Handlers per queue\n  private handlers: Map<string, TaskHandler> = new Map();\n\n  // Schedules\n  private schedules: Map<string, Schedule> = new Map();\n\n  // Shutdown state\n  private _isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: Array<() => Promise<void> | void> = [];\n\n  // --- Phase 1: Basic FIFO Queue ---\n\n  add<T = unknown>(payload: T, options?: AddTaskOptions): Task<T> {\n    if (this._isShuttingDown) {\n      throw new Error('Queue system is shutting down; cannot add new tasks');\n    }\n\n    const queueName = options?.queueName ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? 5;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Calculate availability time\n    let availableAt = new Date();\n    if (options?.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    // Validate dependencies\n    const dependencies = options?.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Detect circular dependencies\n    if (dependencies.length > 0) {\n      const taskId = randomUUID(); // pre-generate ID for cycle detection\n      this.detectCircularDeps(taskId, dependencies);\n\n      const task: Task<T> = {\n        id: taskId,\n        payload,\n        status: 'pending',\n        queueName,\n        priority,\n        createdAt: new Date(),\n        availableAt,\n        attempts: 0,\n        maxRetries: options?.maxRetries ?? 3,\n        backoffDelay: options?.backoffDelay ?? 1000,\n        dependencies: [...dependencies],\n        progress: 0,\n      };\n\n      this.tasks.set(task.id, task as Task);\n      this.ensureQueue(queueName);\n      this.queues.get(queueName)!.push(task.id);\n\n      return task;\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queueName,\n      priority,\n      createdAt: new Date(),\n      availableAt,\n      attempts: 0,\n      maxRetries: options?.maxRetries ?? 3,\n      backoffDelay: options?.backoffDelay ?? 1000,\n      dependencies: [],\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.push(task.id);\n\n    return task;\n  }\n\n  get<T = unknown>(queueName?: string): Task<T> | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return null;\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(name);\n    if (limit != null) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = Date.now();\n\n    // Find the best candidate: highest priority (lowest number), then FIFO\n    // Only consider tasks that are pending, available (not delayed), and unblocked\n    let bestIndex = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < queue.length; i++) {\n      const task = this.tasks.get(queue[i]);\n      if (!task || task.status !== 'pending') continue;\n\n      // Check availability time\n      if (task.availableAt.getTime() > now) continue;\n\n      // Check dependencies\n      if (!this.areDependenciesMet(task)) continue;\n\n      if (\n        bestTask === null ||\n        task.priority < bestTask.priority ||\n        (task.priority === bestTask.priority &&\n          task.availableAt.getTime() < bestTask.availableAt.getTime()) ||\n        (task.priority === bestTask.priority &&\n          task.availableAt.getTime() === bestTask.availableAt.getTime() &&\n          bestIndex > i)\n      ) {\n        bestIndex = i;\n        bestTask = task;\n      }\n    }\n\n    if (bestTask === null) return null;\n\n    bestTask.status = 'processing';\n    bestTask.attempts++;\n\n    return bestTask as Task<T>;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const id of queue) {\n      const task = this.tasks.get(id);\n      if (task && task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // --- Phase 2: Named Queues ---\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // --- Phase 5: Retry with Backoff ---\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks are now unblocked (phase 7)\n    // (unblocking happens naturally during get() checks)\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    if (task.attempts < task.maxRetries) {\n      // Re-queue with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.error = error;\n      task.progress = 0;\n    } else {\n      // No more retries\n      task.status = 'failed';\n      task.error = error;\n\n      // Move to dead letter queue (phase 6)\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // --- Phase 6: Dead Letter Queue ---\n\n  private moveToDeadLetterQueue(task: Task): void {\n    const dlqName = task.queueName;\n    if (!this.deadLetterQueues.has(dlqName)) {\n      this.deadLetterQueues.set(dlqName, []);\n    }\n    this.deadLetterQueues.get(dlqName)!.push(task.id);\n\n    // Remove from regular queue\n    const queue = this.queues.get(task.queueName);\n    if (queue) {\n      const idx = queue.indexOf(task.id);\n      if (idx !== -1) queue.splice(idx, 1);\n    }\n  }\n\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(name);\n    if (!dlq) return [];\n    return dlq\n      .map((id) => this.tasks.get(id))\n      .filter((t): t is Task => t != null);\n  }\n\n  retryDeadLetterTask(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'failed') {\n      throw new Error(`Task is not in failed state: ${task.status}`);\n    }\n\n    // Remove from DLQ\n    const dlq = this.deadLetterQueues.get(task.queueName);\n    if (dlq) {\n      const idx = dlq.indexOf(taskId);\n      if (idx !== -1) dlq.splice(idx, 1);\n    }\n\n    // Reset task for fresh retries\n    task.status = 'pending';\n    task.attempts = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n    task.progress = 0;\n\n    // Add back to queue\n    this.ensureQueue(task.queueName);\n    this.queues.get(task.queueName)!.push(task.id);\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(name);\n    if (dlq) {\n      for (const id of dlq) {\n        this.tasks.delete(id);\n      }\n      dlq.length = 0;\n    }\n  }\n\n  // --- Phase 7: Task Dependencies ---\n\n  private areDependenciesMet(task: Task): boolean {\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') return false;\n    }\n    return true;\n  }\n\n  private detectCircularDeps(taskId: string, dependencies: string[]): void {\n    // BFS/DFS from each dependency to see if we can reach taskId\n    // Also check if any dependency depends (transitively) on any other dependency\n    // creating a cycle\n    const visited = new Set<string>();\n\n    const visit = (currentId: string, path: Set<string>): void => {\n      if (path.has(currentId)) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(currentId)) return;\n      visited.add(currentId);\n      path.add(currentId);\n\n      const current = this.tasks.get(currentId);\n      if (current) {\n        for (const depId of current.dependencies) {\n          visit(depId, new Set(path));\n        }\n      }\n    };\n\n    // Check that no dependency can reach back to form a cycle\n    // We simulate: taskId depends on all `dependencies`\n    // So we walk from each dependency and check for cycles\n    for (const depId of dependencies) {\n      const reachable = new Set<string>();\n      const stack = [depId];\n      while (stack.length > 0) {\n        const id = stack.pop()!;\n        if (reachable.has(id)) continue;\n        reachable.add(id);\n        const t = this.tasks.get(id);\n        if (t) {\n          for (const d of t.dependencies) {\n            stack.push(d);\n          }\n        }\n      }\n      // If we can reach taskId from any dependency, that's a cycle\n      // taskId is new, so this shouldn't happen unless deps reference each other circularly\n    }\n\n    // Also check: no dependency in the list creates a cycle with another dep\n    // Build the dependency graph including the new task\n    // Check for cycles with a proper topological approach\n    const allDeps = new Map<string, string[]>();\n    allDeps.set(taskId, [...dependencies]);\n\n    for (const [id, t] of this.tasks) {\n      allDeps.set(id, [...t.dependencies]);\n    }\n\n    // Detect cycle using DFS\n    const WHITE = 0, GRAY = 1, BLACK = 2;\n    const colors = new Map<string, number>();\n\n    const dfs = (node: string): boolean => {\n      colors.set(node, GRAY);\n      const deps = allDeps.get(node) ?? [];\n      for (const dep of deps) {\n        const color = colors.get(dep) ?? WHITE;\n        if (color === GRAY) return true; // cycle\n        if (color === WHITE && dfs(dep)) return true;\n      }\n      colors.set(node, BLACK);\n      return false;\n    };\n\n    // Only need to check from the new task\n    if (dfs(taskId)) {\n      throw new Error('Circular dependency detected');\n    }\n  }\n\n  getDependencyStatus(taskId: string): { dependency: string; status: TaskStatus }[] {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    return task.dependencies.map((depId) => {\n      const dep = this.tasks.get(depId);\n      return {\n        dependency: depId,\n        status: dep ? dep.status : ('unknown' as TaskStatus),\n      };\n    });\n  }\n\n  // --- Phase 8: Concurrency Control ---\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error('Concurrency limit must be a positive integer');\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName?: string): number | undefined {\n    return this.concurrencyLimits.get(queueName ?? DEFAULT_QUEUE);\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const id of queue) {\n      const task = this.tasks.get(id);\n      if (task && task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // --- Phase 9: Progress Tracking and Cancellation ---\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error('Progress must be between 0 and 100');\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n 