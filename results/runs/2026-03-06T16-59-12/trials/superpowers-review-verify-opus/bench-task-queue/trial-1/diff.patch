+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RRtNAqhS9GNS5z6bnvztd5","type":"tool_result","content":"     1→export type TaskStatus =\n     2→  | 'pending'\n     3→  | 'processing'\n     4→  | 'completed'\n     5→  | 'failed'\n     6→  | 'cancelled';\n     7→\n     8→export interface Task<T = unknown> {\n     9→  id: string;\n    10→  payload: T;\n    11→  status: TaskStatus;\n    12→  queueName: string;\n    13→  priority: number;\n    14→  createdAt: Date;\n    15→  availableAt: Date;\n    16→  attempts: number;\n    17→  maxRetries: number;\n    18→  backoffDelay: number;\n    19→  error?: string;\n    20→  dependencies: string[];\n    21→  progress: number;\n    22→  progressMessage?: string;\n    23→  failCount: number;\n    24→  sequence: number;\n    25→}\n    26→\n    27→export interface AddTaskOptions {\n    28→  queueName?: string;\n    29→  priority?: number;\n    30→  delay?: number;\n    31→  availableAt?: Date;\n    32→  maxRetries?: number;\n    33→  backoffDelay?: number;\n    34→  dependencies?: string[];\n    35→}\n    36→\n    37→export interface ProgressListener {\n    38→  (progress: number, message?: string): void;\n    39→}\n    40→\n    41→export interface MiddlewareContext<T = unknown> {\n    42→  task: Task<T>;\n    43→}\n    44→\n    45→export type NextFunction = () => Promise<void> | void;\n    46→\n    47→export type Middleware<T = unknown> = (\n    48→  ctx: MiddlewareContext<T>,\n    49→  next: NextFunction\n    50→) => Promise<void> | void;\n    51→\n    52→export type TaskHandler<T = unknown> = (task: Task<T>) => Promise<void> | void;\n    53→\n    54→export interface ScheduleOptions {\n    55→  cronExpression: string;\n    56→  queueName?: string;\n    57→  payload: unknown;\n    58→  priority?: number;\n    59→  maxRetries?: number;\n    60→  backoffDelay?: number;\n    61→}\n    62→\n    63→export interface Schedule {\n    64→  id: string;\n    65→  cronExpression: string;\n    66→  queueName: string;\n    67→  payload: unknown;\n    68→  priority: number;\n    69→  maxRetries: number;\n    70→  backoffDelay: number;\n    71→  lastRun?: Date;\n    72→  createdAt: Date;\n    73→}\n    74→\n    75→export interface ShutdownResult {\n    76→  completed: number;\n    77→  forceCancelled: number;\n    78→  durationMs: number;\n    79→}\n    80→\n    81→export interface ShutdownOptions {\n    82→  timeout?: number;\n    83→}\n    84→"}]},"parent_tool_use_id":"toolu_018nFx3xJFLPrF7Lr6vHXofY","session_id":"c224e1c2-6e95-4036-80b3-e4b2caf2cba3","uuid":"23f923e8-4373-4aea-86aa-12903ed06461"}
