+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AWR9FxPKFRiMUAnUja9qaj","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import type {\n     3→  Task,\n     4→  TaskStatus,\n     5→  AddTaskOptions,\n     6→  ProgressListener,\n     7→  Middleware,\n     8→  NextFunction,\n     9→  TaskHandler,\n    10→  ScheduleOptions,\n    11→  Schedule,\n    12→  ShutdownResult,\n    13→  ShutdownOptions,\n    14→} from './types.js';\n    15→import { parseCron, shouldRun, type CronFields } from './cron.js';\n    16→\n    17→const DEFAULT_QUEUE = 'default';\n    18→\n    19→interface InternalSchedule extends Schedule {\n    20→  parsedCron: CronFields;\n    21→}\n    22→\n    23→export class TaskQueue {\n    24→  private tasks: Map<string, Task> = new Map();\n    25→  private queues: Map<string, string[]> = new Map();\n    26→  private deadLetterQueues: Map<string, string[]> = new Map();\n    27→  private concurrencyLimits: Map<string, number> = new Map();\n    28→  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n    29→  private middlewareStacks: Map<string, Middleware[]> = new Map();\n    30→  private handlers: Map<string, TaskHandler> = new Map();\n    31→  private schedules: Map<string, InternalSchedule> = new Map();\n    32→  private _isShuttingDown = false;\n    33→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    34→  private shutdownCallbacks: Array<() => Promise<void> | void> = [];\n    35→  private sequenceCounter = 0;\n    36→\n    37→  // --- Phase 1: Basic FIFO Queue ---\n    38→\n    39→  add<T = unknown>(payload: T, options?: AddTaskOptions): Task<T> {\n    40→    if (this._isShuttingDown) {\n    41→      throw new Error('Queue system is shutting down; cannot add new tasks');\n    42→    }\n    43→\n    44→    const queueName = options?.queueName ?? DEFAULT_QUEUE;\n    45→    const priority = options?.priority ?? 5;\n    46→\n    47→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    48→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    49→    }\n    50→\n    51→    let availableAt = new Date();\n    52→    if (options?.availableAt) {\n    53→      availableAt = options.availableAt;\n    54→    } else if (options?.delay != null && options.delay > 0) {\n    55→      availableAt = new Date(Date.now() + options.delay);\n    56→    }\n    57→\n    58→    const dependencies = options?.dependencies ?? [];\n    59→    for (const depId of dependencies) {\n    60→      if (!this.tasks.has(depId)) {\n    61→        throw new Error(`Dependency task not found: ${depId}`);\n    62→      }\n    63→    }\n    64→\n    65→    // Fix M1: Single task construction path\n    66→    const taskId = randomUUID();\n    67→\n    68→    if (dependencies.length > 0) {\n    69→      this.detectCircularDeps(taskId, dependencies);\n    70→    }\n    71→\n    72→    const task: Task<T> = {\n    73→      id: taskId,\n    74→      payload,\n    75→      status: 'pending',\n    76→      queueName,\n    77→      priority,\n    78→      createdAt: new Date(),\n    79→      availableAt,\n    80→      attempts: 0,\n    81→      maxRetries: options?.maxRetries ?? 3,\n    82→      backoffDelay: options?.backoffDelay ?? 1000,\n    83→      dependencies: [...dependencies],\n    84→      progress: 0,\n    85→      failCount: 0,\n    86→      sequence: this.sequenceCounter++,\n    87→    };\n    88→\n    89→    this.tasks.set(task.id, task as Task);\n    90→    this.ensureQueue(queueName);\n    91→    this.queues.get(queueName)!.push(task.id);\n    92→\n    93→    return task;\n    94→  }\n    95→\n    96→  get<T = unknown>(queueName?: string): Task<T> | null {\n    97→    const name = queueName ?? DEFAULT_QUEUE;\n    98→    const queue = this.queues.get(name);\n    99→    if (!queue) return null;\n   100→\n   101→    const limit = this.concurrencyLimits.get(name);\n   102→    if (limit != null) {\n   103→      const activeCount = this.getActiveCount(name);\n   104→      if (activeCount >= limit) return null;\n   105→    }\n   106→\n   107→    const now = Date.now();\n   108→\n   109→    // Fix H1: Use sequence number for FIFO ordering instead of availableAt\n   110→    // Ordering: priority (lower = higher), then availableAt, then sequence (insertion order)\n   111→    let bestTask: Task | null = null;\n   112→\n   113→    for (let i = 0; i < queue.length; i++) {\n   114→      const task = this.tasks.get(queue[i]);\n   115→      if (!task || task.status !== 'pending') continue;\n   116→      if (task.availableAt.getTime() > now) continue;\n   117→      if (!this.areDependenciesMet(task)) continue;\n   118→\n   119→      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {\n   120→        bestTask = task;\n   121→      }\n   122→    }\n   123→\n   124→    if (bestTask === null) return null;\n   125→\n   126→    bestTask.status = 'processing';\n   127→    bestTask.attempts++;\n   128→\n   129→    return bestTask as Task<T>;\n   130→  }\n   131→\n   132→  private compareTasks(a: Task, b: Task): number {\n   133→    if (a.priority !== b.priority) return a.priority - b.priority;\n   134→    const aTime = a.availableAt.getTime();\n   135→    const bTime = b.availableAt.getTime();\n   136→    if (aTime !== bTime) return aTime - bTime;\n   137→    return a.sequence - b.sequence;\n   138→  }\n   139→\n   140→  size(queueName?: string): number {\n   141→    const name = queueName ?? DEFAULT_QUEUE;\n   142→    const queue = this.queues.get(name);\n   143→    if (!queue) return 0;\n   144→\n   145→    let count = 0;\n   146→    for (const id of queue) {\n   147→      const task = this.tasks.get(id);\n   148→      if (task && task.status === 'pending') count++;\n   149→    }\n   150→    return count;\n   151→  }\n   152→\n   153→  // --- Phase 2: Named Queues ---\n   154→\n   155→  getQueueNames(): string[] {\n   156→    return Array.from(this.queues.keys());\n   157→  }\n   158→\n   159→  // --- Phase 5: Retry with Backoff ---\n   160→\n   161→  complete(taskId: string): void {\n   162→    const task = this.tasks.get(taskId);\n   163→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   164→    if (task.status !== 'processing') {\n   165→      throw new Error(`Cannot complete task in status: ${task.status}`);\n   166→    }\n   167→\n   168→    task.status = 'completed';\n   169→    task.progress = 100;\n   170→\n   171→    // Fix M3: Remove from queue array\n   172→    this.removeFromQueue(task);\n   173→\n   174→    // Clean up progress listeners\n   175→    this.progressListeners.delete(taskId);\n   176→  }\n   177→\n   178→  fail(taskId: string, error?: string): void {\n   179→    const task = this.tasks.get(taskId);\n   180→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   181→    if (task.status !== 'processing') {\n   182→      throw new Error(`Cannot fail task in status: ${task.status}`);\n   183→    }\n   184→\n   185→    // Fix H6: Track total failure count\n   186→    task.failCount++;\n   187→\n   188→    if (task.attempts < task.maxRetries) {\n   189→      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n   190→      task.status = 'pending';\n   191→      task.availableAt = new Date(Date.now() + delay);\n   192→      task.error = error;\n   193→      task.progress = 0;\n   194→    } else {\n   195→      task.status = 'failed';\n   196→      task.error = error;\n   197→      this.moveToDeadLetterQueue(task);\n   198→    }\n   199→  }\n   200→\n   201→  // --- Phase 6: Dead Letter Queue ---\n   202→\n   203→  private moveToDeadLetterQueue(task: Task): void {\n   204→    const dlqName = task.queueName;\n   205→    if (!this.deadLetterQueues.has(dlqName)) {\n   206→      this.deadLetterQueues.set(dlqName, []);\n   207→    }\n   208→    this.deadLetterQueues.get(dlqName)!.push(task.id);\n   209→    this.removeFromQueue(task);\n   210→  }\n   211→\n   212→  getDeadLetterTasks(queueName?: string): Task[] {\n   213→    const name = queueName ?? DEFAULT_QUEUE;\n   214→    const dlq = this.deadLetterQueues.get(name);\n   215→    if (!dlq) return [];\n   216→    return dlq\n   217→      .map((id) => this.tasks.get(id))\n   218→      .filter((t): t is Task => t != null);\n   219→  }\n   220→\n   221→  retryDeadLetterTask(taskId: string): Task {\n   222→    const task = this.tasks.get(taskId);\n   223→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   224→    if (task.status !== 'failed') {\n   225→      throw new Error(`Task is not in failed state: ${task.status}`);\n   226→    }\n   227→\n   228→    const dlq = this.deadLetterQueues.get(task.queueName);\n   229→    if (dlq) {\n   230→      const idx = dlq.indexOf(taskId);\n   231→      if (idx !== -1) dlq.splice(idx, 1);\n   232→    }\n   233→\n   234→    // Reset for fresh retries but preserve failCount\n   235→    task.status = 'pending';\n   236→    task.attempts = 0;\n   237→    task.error = undefined;\n   238→    task.availableAt = new Date();\n   239→    task.progress = 0;\n   240→    task.sequence = this.sequenceCounter++;\n   241→\n   242→    this.ensureQueue(task.queueName);\n   243→    this.queues.get(task.queueName)!.push(task.id);\n   244→\n   245→    return task;\n   246→  }\n   247→\n   248→  clearDeadLetterQueue(queueName?: string): void {\n   249→    const name = queueName ?? DEFAULT_QUEUE;\n   250→    const dlq = this.deadLetterQueues.get(name);\n   251→    if (dlq) {\n   252→      for (const id of dlq) {\n   253→        this.tasks.delete(id);\n   254→      }\n   255→      dlq.length = 0;\n   256→    }\n   257→  }\n   258→\n   259→  // --- Phase 7: Task Dependencies ---\n   260→\n   261→  private areDependenciesMet(task: Task): boolean {\n   262→    for (const depId of task.dependencies) {\n   263→      const dep = this.tasks.get(depId);\n   264→      if (!dep || dep.status !== 'completed') return false;\n   265→    }\n   266→    return true;\n   267→  }\n   268→\n   269→  private detectCircularDeps(taskId: string, dependencies: string[]): void {\n   270→    const allDeps = new Map<string, string[]>();\n   271→    allDeps.set(taskId, [...dependencies]);\n   272→\n   273→    for (const [id, t] of this.tasks) {\n   274→      allDeps.set(id, [...t.dependencies]);\n   275→    }\n   276→\n   277→    const WHITE = 0, GRAY = 1, BLACK = 2;\n   278→    const colors = new Map<string, number>();\n   279→\n   280→    const dfs = (node: string): boolean => {\n   281→      colors.set(node, GRAY);\n   282→      const deps = allDeps.get(node) ?? [];\n   283→      for (const dep of deps) {\n   284→        const color = colors.get(dep) ?? WHITE;\n   285→        if (color === GRAY) return true;\n   286→        if (color === WHITE && dfs(dep)) return true;\n   287→      }\n   288→      colors.set(node, BLACK);\n   289→      return false;\n   290→    };\n   291→\n   292→    if (dfs(taskId)) {\n   293→      throw new Error('Circular dependency detected');\n   294→    }\n   295→  }\n   296→\n   297→  // Fix M4: Return proper type without unsafe cast\n   298→  getDependencyStatus(taskId: string): { dependency: string; status: TaskStatus | 'unknown' }[] {\n   299→    const task = this.tasks.get(taskId);\n   300→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   301→\n   302→    return task.dependencies.map((depId) => {\n   303→      const dep = this.tasks.get(depId);\n   304→      return {\n   305→        dependency: depId,\n   306→        status: dep ? dep.status : 'unknown' as const,\n   307→      };\n   308→    });\n   309→  }\n   310→\n   311→  // --- Phase 8: Concurrency Control ---\n   312→\n   313→  setConcurrency(queueName: string, limit: number): void {\n   314→    if (limit < 1 || !Number.isInteger(limit)) {\n   315→      throw new Error('Concurrency limit must be a positive integer');\n   316→    }\n   317→    this.concurrencyLimits.set(queueName, limit);\n   318→  }\n   319→\n   320→  getConcurrency(queueName?: string): number | undefined {\n   321→    return this.concurrencyLimits.get(queueName ?? DEFAULT_QUEUE);\n   322→  }\n   323→\n   324→  getActiveCount(queueName?: string): number {\n   325→    const name = queueName ?? DEFAULT_QUEUE;\n   326→    let count = 0;\n   327→    for (const task of this.tasks.values()) {\n   328→      if (task.queueName === name && task.status === 'processing') count++;\n   329→    }\n   330→    return count;\n   331→  }\n   332→\n   333→  // --- Phase 9: Progress Tracking and Cancellation ---\n   334→\n   335→  reportProgress(taskId: string, progress: number, message?: string): void {\n   336→    const task = this.tasks.get(taskId);\n   337→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   338→    if (task.status !== 'processing') {\n   339→      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n   340→    }\n   341→    if (progress < 0 || progress > 100) {\n   342→      throw new Error('Progress must be between 0 and 100');\n   343→    }\n   344→\n   345→    task.progress = progress;\n   346→    task.progressMessage = message;\n   347→\n   348→    const listeners = this.progressListeners.get(taskId);\n   349→    if (listeners) {\n   350→      for (const listener of listeners) {\n   351→        listener(progress, message);\n   352→      }\n   353→    }\n   354→  }\n   355→\n   356→  getProgress(taskId: string): { progress: number; message?: string } {\n   357→    const task = this.tasks.get(taskId);\n   358→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   359→    return { progress: task.progress, message: task.progressMessage };\n   360→  }\n   361→\n   362→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   363→    if (!this.progressListeners.has(taskId)) {\n   364→      this.progressListeners.set(taskId, new Set());\n   365→    }\n   366→    this.progressListeners.get(taskId)!.add(listener);\n   367→\n   368→    return () => {\n   369→      const listeners = this.progressListeners.get(taskId);\n   370→      if (listeners) {\n   371→        listeners.delete(listener);\n   372→      }\n   373→    };\n   374→  }\n   375→\n   376→  cancel(taskId: string): void {\n   377→    const task = this.tasks.get(taskId);\n   378→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   379→    if (task.status !== 'pending' && task.status !== 'processing') {\n   380→      throw new Error(`Cannot cancel task in status: ${task.status}`);\n   381→    }\n   382→\n   383→    task.status = 'cancelled';\n   384→    this.removeFromQueue(task);\n   385→    this.progressListeners.delete(taskId);\n   386→  }\n   387→\n   388→  // --- Phase 10: Recurring Tasks ---\n   389→\n   390→  addSchedule(options: ScheduleOptions): Schedule {\n   391→    // Fix M6: Parse and cache cron fields\n   392→    const parsedCron = parseCron(options.cronExpression);\n   393→\n   394→    const schedule: InternalSchedule = {\n   395→      id: randomUUID(),\n   396→      cronExpression: options.cronExpression,\n   397→      queueName: options.queueName ?? DEFAULT_QUEUE,\n   398→      payload: options.payload,\n   399→      priority: options.priority ?? 5,\n   400→      maxRetries: options.maxRetries ?? 3,\n   401→      backoffDelay: options.backoffDelay ?? 1000,\n   402→      createdAt: new Date(),\n   403→      parsedCron,\n   404→    };\n   405→\n   406→    this.schedules.set(schedule.id, schedule);\n   407→    return schedule;\n   408→  }\n   409→\n   410→  removeSchedule(scheduleId: string): void {\n   411→    if (!this.schedules.has(scheduleId)) {\n   412→      throw new Error(`Schedule not found: ${scheduleId}`);\n   413→    }\n   414→    this.schedules.delete(scheduleId);\n   415→  }\n   416→\n   417→  getSchedules(): Schedule[] {\n   418→    return Array.from(this.schedules.values());\n   419→  }\n   420→\n   421→  tick(now?: Date): Task[] {\n   422→    // Fix C6: Return empty during shutdown instead of throwing\n   423→    if (this._isSh