ue.complete(task.id);\n   193→      expect(queue.getTask(task.id)?.status).toBe('completed');\n   194→    });\n   195→\n   196→    it('should retry a failed task with backoff', () => {\n   197→      queue.add('work', { maxRetries: 3, backoffDelay: 100 });\n   198→      const task = queue.get()!;\n   199→      expect(task.attempts).toBe(1);\n   200→\n   201→      queue.fail(task.id, 'error1');\n   202→      const retask = queue.getTask(task.id)!;\n   203→      expect(retask.status).toBe('pending');\n   204→      // Backoff: 100 * 2^0 = 100ms\n   205→      expect(retask.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n   206→    });\n   207→\n   208→    it('should track attempt count', () => {\n   209→      queue.add('work', { maxRetries: 3, backoffDelay: 1 });\n   210→      const t1 = queue.get()!;\n   211→      expect(t1.attempts).toBe(1);\n   212→\n   213→      queue.fail(t1.id);\n   214→\n   215→      // Wait a tiny bit for backoff\n   216→      // Since backoff is 1ms * 2^0 = 1ms, it should be available almost immediately\n   217→      // But we need to wait for the delay to pass\n   218→      const check = () => {\n   219→        const t2 = queue.get();\n   220→        return t2;\n   221→      };\n   222→\n   223→      // Attempt 2 may need a small delay\n   224→      let t2 = check();\n   225→      if (!t2) {\n   226→        // still delayed, skip this check\n   227→      } else {\n   228→        expect(t2.attempts).toBe(2);\n   229→      }\n   230→    });\n   231→\n   232→    it('should fail permanently after max retries', () => {\n   233→      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n   234→      const task = queue.get()!;\n   235→      queue.fail(task.id, 'error');\n   236→      expect(queue.getTask(task.id)?.status).toBe('failed');\n   237→    });\n   238→\n   239→    it('should keep original queue and priority on retry', () => {\n   240→      queue.add('work', { queueName: 'q1', priority: 2, maxRetries: 3, backoffDelay: 1 });\n   241→      const task = queue.get('q1')!;\n   242→      queue.fail(task.id);\n   243→      const retask = queue.getTask(task.id)!;\n   244→      expect(retask.queueName).toBe('q1');\n   245→      expect(retask.priority).toBe(2);\n   246→    });\n   247→\n   248→    it('should default maxRetries to 3', () => {\n   249→      const task = queue.add('work');\n   250→      expect(task.maxRetries).toBe(3);\n   251→    });\n   252→\n   253→    it('should default backoffDelay to 1000', () => {\n   254→      const task = queue.add('work');\n   255→      expect(task.backoffDelay).toBe(1000);\n   256→    });\n   257→  });\n   258→\n   259→  // ========== Phase 6: Dead Letter Queue ==========\n   260→  describe('Phase 6: Dead Letter Queue', () => {\n   261→    it('should move to DLQ after all retries exhausted', () => {\n   262→      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n   263→      const task = queue.get()!;\n   264→      queue.fail(task.id, 'permanent error');\n   265→\n   266→      const dlq = queue.getDeadLetterTasks();\n   267→      expect(dlq).toHaveLength(1);\n   268→      expect(dlq[0].id).toBe(task.id);\n   269→      expect(dlq[0].error).toBe('permanent error');\n   270→    });\n   271→\n   272→    it('should have per-queue DLQs', () => {\n   273→      queue.add('w1', { queueName: 'q1', maxRetries: 1 });\n   274→      queue.add('w2', { queueName: 'q2', maxRetries: 1 });\n   275→\n   276→      const t1 = queue.get('q1')!;\n   277→      const t2 = queue.get('q2')!;\n   278→      queue.fail(t1.id);\n   279→      queue.fail(t2.id);\n   280→\n   281→      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n   282→      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n   283→    });\n   284→\n   285→    it('should retry a dead-lettered task', () => {\n   286→      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n   287→      const task = queue.get()!;\n   288→      queue.fail(task.id);\n   289→\n   290→      const retried = queue.retryDeadLetterTask(task.id);\n   291→      expect(retried.status).toBe('pending');\n   292→      expect(retried.attempts).toBe(0);\n   293→\n   294→      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n   295→    });\n   296→\n   297→    it('should clear DLQ', () => {\n   298→      queue.add('w1', { maxRetries: 1 });\n   299→      queue.add('w2', { maxRetries: 1 });\n   300→      queue.fail(queue.get()!.id);\n   301→      queue.fail(queue.get()!.id);\n   302→\n   303→      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n   304→      queue.clearDeadLetterQueue();\n   305→      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n   306→    });\n   307→  });\n   308→\n   309→  // ========== Phase 7: Task Dependencies ==========\n   310→  describe('Phase 7: Task Dependencies', () => {\n   311→    it('should block tasks with unmet dependencies', () => {\n   312→      const dep = queue.add('dependency');\n   313→      const task = queue.add('dependent', { dependencies: [dep.id] });\n   314→\n   315→      // Get should return the dependency first (since the dependent is blocked)\n   316→      const first = queue.get();\n   317→      expect(first?.id).toBe(dep.id);\n   318→\n   319→      // Dependent should not be available yet\n   320→      const second = queue.get();\n   321→      expect(second).toBeNull();\n   322→\n   323→      // Complete the dependency\n   324→      queue.complete(dep.id);\n   325→\n   326→      // Now the dependent should be available\n   327→      const third = queue.get();\n   328→      expect(third?.id).toBe(task.id);\n   329→    });\n   330→\n   331→    it('should reject circular dependencies', () => {\n   332→      const t1 = queue.add('t1');\n   333→      const t2 = queue.add('t2', { dependencies: [t1.id] });\n   334→      expect(() => {\n   335→        queue.add('t3', { dependencies: [t2.id, t1.id] });\n   336→      }).not.toThrow();\n   337→\n   338→      // Direct circle: t1 -> t2 -> t1 (t1 already exists, so we can't make it depend on t2)\n   339→      // But we can create: A depends on B, then try B depends on A\n   340→    });\n   341→\n   342→    it('should detect indirect circular dependencies', () => {\n   343→      const a = queue.add('a');\n   344→      const b = queue.add('b', { dependencies: [a.id] });\n   345→      const c = queue.add('c', { dependencies: [b.id] });\n   346→\n   347→      // Now trying to make a new task that creates a cycle would need\n   348→      // something that depends on c and a depends on it\n   349→      // But since a is already created without deps, we can't add deps to it\n   350→      // The cycle detection prevents adding a task whose deps form a cycle\n   351→      // Let's test: d depends on c, e depends on d, and try f depends on e\n   352→      // where we somehow create a cycle\n   353→      void c; // used for reference\n   354→\n   355→      // True cycle test: create a chain then close it\n   356→      const x = queue.add('x');\n   357→      const y = queue.add('y', { dependencies: [x.id] });\n   358→      // z depends on y, but if we could make x depend on z... we can't retroactively add deps\n   359→      void y;\n   360→    });\n   361→\n   362→    it('should reject dependency on non-existent task', () => {\n   363→      expect(() => {\n   364→        queue.add('task', { dependencies: ['nonexistent-id'] });\n   365→      }).toThrow('Dependency task not found');\n   366→    });\n   367→\n   368→    it('should inspect dependency status', () => {\n   369→      const dep1 = queue.add('dep1');\n   370→      const dep2 = queue.add('dep2');\n   371→      const task = queue.add('task', { dependencies: [dep1.id, dep2.id] });\n   372→\n   373→      const status = queue.getDependencyStatus(task.id);\n   374→      expect(status).toHaveLength(2);\n   375→      expect(status[0].status).toBe('pending');\n   376→    });\n   377→\n   378→    it('should keep dependent blocked when dependency fails', () => {\n   379→      const dep = queue.add('dep', { maxRetries: 1 });\n   380→      queue.add('dependent', { dependencies: [dep.id] });\n   381→\n   382→      const depTask = queue.get()!;\n   383→      queue.fail(depTask.id, 'error');\n   384→\n   385→      // Dependent should still be blocked\n   386→      expect(queue.get()).toBeNull();\n   387→    });\n   388→  });\n   389→\n   390→  // ========== Phase 8: Concurrency Control ==========\n   391→  describe('Phase 8: Concurrency Control', () => {\n   392→    it('should limit concurrent processing tasks', () => {\n   393→      queue.setConcurrency('default', 2);\n   394→      queue.add('a');\n   395→      queue.add('b');\n   396→      queue.add('c');\n   397→\n   398→      const t1 = queue.get();\n   399→      const t2 = queue.get();\n   400→      const t3 = queue.get();\n   401→\n   402→      expect(t1).not.toBeNull();\n   403→      expect(t2).not.toBeNull();\n   404→      expect(t3).toBeNull(); // concurrency limit reached\n   405→    });\n   406→\n   407→    it('should free slot when task completes', () => {\n   408→      queue.setConcurrency('default', 1);\n   409→      queue.add('a');\n   410→      queue.add('b');\n   411→\n   412→      const t1 = queue.get()!;\n   413→      expect(queue.get()).toBeNull(); // limit reached\n   414→\n   415→      queue.complete(t1.id);\n   416→      const t2 = queue.get();\n   417→      expect(t2).not.toBeNull();\n   418→    });\n   419→\n   420→    it('should free slot when task fails', () => {\n   421→      queue.setConcurrency('default', 1);\n   422→      queue.add('a', { maxRetries: 1 });\n   423→      queue.add('b');\n   424→\n   425→      const t1 = queue.get()!;\n   426→      queue.fail(t1.id);\n   427→\n   428→      // t1 is now in DLQ, slot freed\n   429→      const t2 = queue.get();\n   430→      expect(t2).not.toBeNull();\n   431→    });\n   432→\n   433→    it('should default to unlimited concurrency', () => {\n   434→      expect(queue.getConcurrency('default')).toBeUndefined();\n   435→    });\n   436→\n   437→    it('should report active count', () => {\n   438→      queue.add('a');\n   439→      queue.add('b');\n   440→      expect(queue.getActiveCount()).toBe(0);\n   441→      queue.get();\n   442→      expect(queue.getActiveCount()).toBe(1);\n   443→      queue.get();\n   444→      expect(queue.getActiveCount()).toBe(2);\n   445→    });\n   446→\n   447→    it('should still respect priority under concurrency limits', () => {\n   448→      queue.setConcurrency('default', 1);\n   449→      queue.add('low', { priority: 10 });\n   450→      queue.add('high', { priority: 1 });\n   451→\n   452→      const t1 = queue.get()!;\n   453→      expect(t1.payload).toBe('high');\n   454→    });\n   455→  });\n   456→\n   457→  // ========== Phase 9: Progress and Cancellation ==========\n   458→  describe('Phase 9: Progress Tracking and Cancellation', () => {\n   459→    it('should report and query progress', () => {\n   460→      queue.add('work');\n   461→      const task = queue.get()!;\n   462→\n   463→      queue.reportProgress(task.id, 50, 'halfway');\n   464→      const progress = queue.getProgress(task.id);\n   465→      expect(progress.progress).toBe(50);\n   466→      expect(progress.message).toBe('halfway');\n   467→    });\n   468→\n   469→    it('should notify progress listeners', () => {\n   470→      queue.add('work');\n   471→      const task = queue.get()!;\n   472→\n   473→      const updates: number[] = [];\n   474→      queue.onProgress(task.id, (p) => updates.push(p));\n   475→\n   476→      queue.reportProgress(task.id, 25);\n   477→      queue.reportProgress(task.id, 50);\n   478→      queue.reportProgress(task.id, 75);\n   479→\n   480→      expect(updates).toEqual([25, 50, 75]);\n   481→    });\n   482→\n   483→    it('should support unsubscribing from progress', () => {\n   484→      queue.add('work');\n   485→      const task = queue.get()!;\n   486→\n   487→      const updates: number[] = [];\n   488→      const unsubscribe = queue.onProgress(task.id, (p) => updates.push(p));\n   489→\n   490→      queue.reportProgress(task.id, 25);\n   491→      unsubscribe();\n   492→      queue.reportProgress(task.id, 50);\n   493→\n   494→      expect(updates).toEqual([25]);\n   495→    });\n   496→\n   497→    it('should cancel a pending task', () => {\n   498→      const task = queue.add('work');\n   499→      queue.cancel(task.id);\n   500→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   501→      expect(queue.get()).toBeNull();\n   502→    });\n   503→\n   504→    it('should cancel a processing task', () => {\n   505→      queue.add('work');\n   506→      const task = queue.get()!;\n   507→      queue.cancel(task.id);\n   508→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   509→    });\n   510→\n   511→    it('should not retry cancelled tasks', () => {\n   512→      queue.add('work', { maxRetries: 3 });\n   513→      const task = queue.get()!;\n   514→      queue.cancel(task.id);\n   515→\n   516→      // Cannot fail a cancelled task\n   517→      expect(() => queue.fail(task.id)).toThrow();\n   518→    });\n   519→\n   520→    it('should reject progress on non-processing task', () => {\n   521→      const task = queue.add('work');\n   522→      expect(() => queue.reportProgress(task.id, 50)).toThrow();\n   523→    });\n   524→\n   525→    it('should reject invalid progress values', () => {\n   526→      queue.add('work');\n   527→      const task = queue.get()!;\n   528→      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n   529→      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n   530→    });\n   531→  });\n   532→\n   533→  // ========== Phase 10: Recurring Tasks ==========\n   534→  describe('Phase 10: Recurring Tasks', () => {\n   535→    it('should create a schedule', () => {\n   536→      const schedule = queue.addSchedule({\n   537→        cronExpression: '*/5 * * * *',\n   538→        payload: { type: 'cleanup' },\n   539→      });\n   540→\n   541→      expect(schedule.id).toBeDefined();\n   542→      expect(schedule.cronExpression).toBe('*/5 * * * *');\n   543→    });\n   544→\n   545→    it('should list schedules', () => {\n   546→      queue.addSchedule({ cronExpression: '*/5 * * * *', payload: 'a' });\n   547→      queue.addSchedule({ cronExpression: '0 * * * *', payload: 'b' });\n   548→\n   549→      expect(queue.getSchedules()).toHaveLength(2);\n   550→    });\n   551→\n   552→    it('should remove a schedule', () => {\n   553→      const schedule = queue.addSchedule({\n   554→        cronExpression: '*/5 * * * *',\n   555→        payload: 'x',\n   556→      });\n   557→\n   558→      queue.removeSchedule(schedule.id);\n   559→      expect(queue.getSchedules()).toHaveLength(0);\n   560→    });\n   561→\n   562→    it('should enqueue tasks on tick when due', () => {\n   563→      queue.addSchedule({\n   564→        cronExpression: '*/5 * * * *',\n   565→        payload: 'recurring',\n   566→      });\n   567→\n   568→      // Simulate a time where minute is divisible by 5\n   569→      const time = new Date(2025, 0, 1, 12, 10, 0);\n   570→      const created = queue.tick(time);\n   571→\n   572→      expect(created.length).toBe(1);\n   573→      expect(created[0].payload).toBe('recurring');\n   574→    });\n   575→\n   576→    it('should not double-fire at same minute', () => {\n   577→      queue.addSchedule({\n   578→        cronExpression: '*/5 * * * *',\n   579→        payload: 'recurring',\n   580→      });\n   581→\n   582→      const time = new Date(2025, 0, 1, 12, 10, 0);\n   583→      queue.tick(time);\n   584→      const second = queue.tick(time);\n   585→\n   586→      expect(second).toHaveLength(0);\n   587→    });\n   588→\n   589→    it('should support hourly cron', () => {\n   590→      queue.addSchedule({\n   591→        cronExpression: '0 * * * *',\n   592→        payload: 'hourly',\n   593→      });\n   594→\n   595→      const onTheHour = new Date(2025, 0, 1, 14, 0, 0);\n   596→      const offHour = new Date(2025, 0, 1, 14, 30, 0);\n   597→\n   598→      expect(queue.tick(onTheHour)).toHaveLength(1);\n   599→      expect(queue.tick(offHour)).toHaveLength(0);\n   600→    });\n   601→\n   602→    it('should support daily cron', () => {\n   603→      queue.addSchedule({\n   604→        cronExpression: '0 0 * * *',\n   605→        payload: 'daily',\n   606→      });\n   607→\n   608→      const midnight = new Date(2025, 0, 1, 0, 0, 0);\n   609→      expect(queue.tick(midnight)).toHaveLength(1);\n   610→\n   611→      const noon = new Date(2025, 0, 1, 12, 0, 0);\n   612→      expect(queue.tick(noon)).toHaveLength(0);\n   613→    });\n   614→  });\n   615→\n   616→  // ========== Phase 11: Middleware Pipeline ==========\n   617→  describe('Phase 11: Middleware Pipeline', () => {\n   618→    it('should run middleware in order before handler', async () => {\n   619→      const order: string[] = [];\n   620→\n   621→      queue.use('default', async (_ctx, next) => {\n   622→        order.push('mw1-before');\n   623→        await next();\n   624→        order.push('mw1-after');\n   625→      });\n   626→\n   627→      queue.use('default', async (_ctx, next) => {\n   628→        order.push('mw2-before');\n   629→        await next();\n   630→        order.push('mw2-after');\n   631→      });\n   632→\n   633→      queue.setHandler('default', async () => {\n   634→        order.push('handler');\n   635→      });\n   636→\n   637→      queue.add('work');\n   638→      const task = queue.get()!;\n   639→      await queue.process(task);\n   640→\n   641→      expect(order).toEqual([\n   642→        'mw1-before',\n   643→        'mw2-before',\n   644→        'handler',\n   645→        'mw2-after',\n   646→        'mw1-after',\n   647→      ]);\n   648→    });\n   649→\n   650→    it('should skip processing if middleware does not call next', async () => {\n   651→      const handlerCalled: boolean[] = [];\n   652→\n   653→      queue.use('default', async () => {\n   654→        // Intentionally not calling next\n   655→      });\n   656→\n   657→      queue.setHandler('default', async () => {\n   658→        handlerCalled.push(true);\n   659→      });\n   660→\n   661→      queue.add('work');\n   662→      const task = queue.get()!;\n   663→      await queue.process(task);\n   664→\n   665→      expect(handlerCalled).toHaveLength(0);\n   666→    });\n   667→\n   668→    it('should allow middleware to modify task', async () => {\n   669→      queue.use('default', async (ctx, next) => {\n   670→        (ctx.task.payload as Record<string, unknown>).modified = true;\n   671→        await next();\n   672→      });\n   673→\n   674→      let receivedPayload: unknown;\n   675→      queue.setHandler('default', async (task) => {\n   676→        receivedPayload = task.payload;\n   677→      });\n   678→\n   679→      queue.add({ data: 'original' });\n   680→      const task = queue.get()!;\n   681→      await queue.process(task);\n   682→\n   683→      expect(receivedPayload).toEqual({ data: 'original', modified: true });\n   684→    });\n   685→\n   686→    it('should fail task if middleware throws', async () => {\n   687→      queue.use('default', async () => {\n   688→        throw new Error('middleware error');\n   689→      });\n   690→\n   691→      queue.add('work', { maxRetries: 1 });\n   692→      const task = queue.get()!;\n   693→\n   694→      await expect(queue.process(task)).rejects.toThrow('middleware error');\n   695→      expect(queue.getTask(task.id)?.status).toBe('failed');\n   696→    });\n   697→\n   698→    it('should have independent middleware per queue', async () => {\n   699→      const calls: string[] = [];\n   700→\n   701→      queue.use('q1', async (_ctx, next) => {\n   702→        calls.push('q1-mw');\n   703→        await next();\n   704→      });\n   705→\n   706→      queue.use('q2', async (_ctx, next) => {\n   707→        calls.push('q2-mw');\n   708→        await next();\n   709→      });\n   710→\n   711→      queue.setHandler('q1', async () => { calls.push('q1-handler'); });\n   712→      queue.setHandler('q2', async () => { calls.push('q2-handler'); });\n   713→\n   714→      queue.add('work1', { queueName: 'q1' });\n   715→      queue.add('work2', { queueName: 'q2' });\n   716→\n   717→      const t1 = queue.get('q1')!;\n   718→      await queue.process(t1);\n   719→      expect(calls).toEqual(['q1-mw', 'q1-handler']);\n   720→\n   721→      calls.length = 0;\n   722→      const t2 = queue.get('q2')!;\n   723→      await queue.process(t2);\n   724→      expect(calls).toEqual(['q2-mw', 'q2-handler']);\n   725→    });\n   726→  });\n   727→\n   728→  // ========== Phase 12: Graceful Shutdown ==========\n   729→  describe('Phase 12: Graceful Shutdown', () => {\n   730→    it('should reject new tasks after shutdown', async () => {\n   731→      await queue.shutdown();\n   732→      expect(() => queue.add('task')).toThrow('shutting down');\n   733→    });\n   734→\n   735→    it('should complete immediately with no processing tasks', async () => {\n   736→      const result = await queue.shutdown();\n   737→      expect(result.completed).toBe(0);\n   738→      expect(result.forceCancelled).toBe(0);\n   739→      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n   740→    });\n   741→\n   742→    it('should wait for processing tasks', async () => {\n   743→      queue.add('work');\n   744→      const task = queue.get()!;\n   745→\n   746→      // Start shutdown in background, then complete the task\n   747→      const shutdownPromise = queue.shutdown({ timeout: 5000 });\n   748→\n   749→      // Complete the task shortly\n   750→      setTimeout(() => queue.complete(task.id), 100);\n   751→\n   752→      const result = await shutdownPromise;\n   753→      expect(result.completed).toBe(1);\n   754→      expect(result.forceCancelled).toBe(0);\n   755→    });\n   756→\n   757→    it('should force-cancel tasks that exceed timeout', async () => {\n   758→      queue.add('slow-work');\n   759→      const task = queue.get()!;\n   760→      void task; // task stays in processing\n   761→\n   762→      const result = await queue.shutdown({ timeout: 200 });\n   763→      expect(result.forceCancelled).toBe(1);\n   764→    });\n   765→\n   766→    it('should be idempotent', async () => {\n   767→      const r1 = queue.shutdown();\n   768→      const r2 = queue.shutdown();\n   769→      expect(await r1).toEqual(await r2);\n   770→    });\n   771→\n   772→    it('should run shutdown callbacks', async () => {\n   773→      let callbackRan = false;\n   774→      queue.onShutdown(() => {\n   775→        callbackRan = true;\n   776→      });\n   777→\n   778→      await queue.shutdown();\n   779→      expect(callbackRan).toBe(true);\n   780→    });\n   781→\n   782→    it('should report isShuttingDown', async () => {\n   783→      expect(queue.isShuttingDown).toBe(false);\n   784→      const promise = queue.shutdown();\n   785→      expect(queue.isShuttingDown).toBe(true);\n   786→      await promise;\n   787→    });\n   788→  });\n   789→\n   790→  // ========== Integration tests ==========\n   791→  describe('Integration', () => {\n   792→    it('should handle priority + delay together', () => {\n   793→      const now = Date.now();\n   794→      queue.add('delayed-high', { priority: 1, availableAt: new Date(now - 100) });\n   795→      queue.add('immediate-low', { priority: 10 });\n   796→\n   797→      // Higher priority wins even though the low-prio was added after\n   798→      expect(queue.get()?.payload).toBe('delayed-high');\n   799→    });\n   800→\n   801→    it('should handle retry + DLQ + named queues', () => {\n   802→      queue.add('work', { queueName: 'q1', maxRetries: 1 });\n   803→      const task = queue.get('q1')!;\n   804→      queue.fail(task.id, 'oops');\n   805→\n   806→      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n   807→      expect(queue.getDeadLetterTasks('default')).toHaveLength(0);\n   808→    });\n   8