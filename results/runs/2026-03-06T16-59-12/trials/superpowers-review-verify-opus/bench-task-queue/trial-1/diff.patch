diff --git a/src/TaskQueue.ts b/src/TaskQueue.ts
new file mode 100644
index 0000000..38ca459
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,600 @@
+import { randomUUID } from 'node:crypto';
+import type {
+  Task,
+  TaskStatus,
+  AddTaskOptions,
+  ProgressListener,
+  Middleware,
+  NextFunction,
+  TaskHandler,
+  ScheduleOptions,
+  Schedule,
+  ShutdownResult,
+  ShutdownOptions,
+} from './types.js';
+import { parseCron, shouldRun, type CronFields } from './cron.js';
+
+const DEFAULT_QUEUE = 'default';
+
+interface InternalSchedule extends Schedule {
+  parsedCron: CronFields;
+}
+
+export class TaskQueue {
+  private tasks: Map<string, Task> = new Map();
+  private queues: Map<string, string[]> = new Map();
+  private deadLetterQueues: Map<string, string[]> = new Map();
+  private concurrencyLimits: Map<string, number> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private middlewareStacks: Map<string, Middleware[]> = new Map();
+  private handlers: Map<string, TaskHandler> = new Map();
+  private schedules: Map<string, InternalSchedule> = new Map();
+  private _isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => Promise<void> | void> = [];
+  private sequenceCounter = 0;
+
+  // --- Phase 1: Basic FIFO Queue ---
+
+  add<T = unknown>(payload: T, options?: AddTaskOptions): Task<T> {
+    if (this._isShuttingDown) {
+      throw new Error('Queue system is shutting down; cannot add new tasks');
+    }
+
+    const queueName = options?.queueName ?? DEFAULT_QUEUE;
+    const priority = options?.priority ?? 5;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    let availableAt = new Date();
+    if (options?.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options?.delay != null && options.delay > 0) {
+      availableAt = new Date(Date.now() + options.delay);
+    }
+
+    const dependencies = options?.dependencies ?? [];
+    for (const depId of dependencies) {
+      if (!this.tasks.has(depId)) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    // Fix M1: Single task construction path
+    const taskId = randomUUID();
+
+    if (dependencies.length > 0) {
+      this.detectCircularDeps(taskId, dependencies);
+    }
+
+    const task: Task<T> = {
+      id: taskId,
+      payload,
+      status: 'pending',
+      queueName,
+      priority,
+      createdAt: new Date(),
+      availableAt,
+      attempts: 0,
+      maxRetries: options?.maxRetries ?? 3,
+      backoffDelay: options?.backoffDelay ?? 1000,
+      dependencies: [...dependencies],
+      progress: 0,
+      failCount: 0,
+      sequence: this.sequenceCounter++,
+    };
+
+    this.tasks.set(task.id, task as Task);
+    this.ensureQueue(queueName);
+    this.queues.get(queueName)!.push(task.id);
+
+    return task;
+  }
+
+  get<T = unknown>(queueName?: string): Task<T> | null {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queue = this.queues.get(name);
+    if (!queue) return null;
+
+    const limit = this.concurrencyLimits.get(name);
+    if (limit != null) {
+      const activeCount = this.getActiveCount(name);
+      if (activeCount >= limit) return null;
+    }
+
+    const now = Date.now();
+
+    // Fix H1: Use sequence number for FIFO ordering instead of availableAt
+    // Ordering: priority (lower = higher), then availableAt, then sequence (insertion order)
+    let bestTask: Task | null = null;
+
+    for (let i = 0; i < queue.length; i++) {
+      const task = this.tasks.get(queue[i]);
+      if (!task || task.status !== 'pending') continue;
+      if (task.availableAt.getTime() > now) continue;
+      if (!this.areDependenciesMet(task)) continue;
+
+      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {
+        bestTask = task;
+      }
+    }
+
+    if (bestTask === null) return null;
+
+    bestTask.status = 'processing';
+    bestTask.attempts++;
+
+    return bestTask as Task<T>;
+  }
+
+  private compareTasks(a: Task, b: Task): number {
+    if (a.priority !== b.priority) return a.priority - b.priority;
+    const aTime = a.availableAt.getTime();
+    const bTime = b.availableAt.getTime();
+    if (aTime !== bTime) return aTime - bTime;
+    return a.sequence - b.sequence;
+  }
+
+  size(queueName?: string): number {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queue = this.queues.get(name);
+    if (!queue) return 0;
+
+    let count = 0;
+    for (const id of queue) {
+      const task = this.tasks.get(id);
+      if (task && task.status === 'pending') count++;
+    }
+    return count;
+  }
+
+  // --- Phase 2: Named Queues ---
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // --- Phase 5: Retry with Backoff ---
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in status: ${task.status}`);
+    }
+
+    task.status = 'completed';
+    task.progress = 100;
+
+    // Fix M3: Remove from queue array
+    this.removeFromQueue(task);
+
+    // Clean up progress listeners
+    this.progressListeners.delete(taskId);
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in status: ${task.status}`);
+    }
+
+    // Fix H6: Track total failure count
+    task.failCount++;
+
+    if (task.attempts < task.maxRetries) {
+      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.error = error;
+      task.progress = 0;
+    } else {
+      task.status = 'failed';
+      task.error = error;
+      this.moveToDeadLetterQueue(task);
+    }
+  }
+
+  // --- Phase 6: Dead Letter Queue ---
+
+  private moveToDeadLetterQueue(task: Task): void {
+    const dlqName = task.queueName;
+    if (!this.deadLetterQueues.has(dlqName)) {
+      this.deadLetterQueues.set(dlqName, []);
+    }
+    this.deadLetterQueues.get(dlqName)!.push(task.id);
+    this.removeFromQueue(task);
+  }
+
+  getDeadLetterTasks(queueName?: string): Task[] {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const dlq = this.deadLetterQueues.get(name);
+    if (!dlq) return [];
+    return dlq
+      .map((id) => this.tasks.get(id))
+      .filter((t): t is Task => t != null);
+  }
+
+  retryDeadLetterTask(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'failed') {
+      throw new Error(`Task is not in failed state: ${task.status}`);
+    }
+
+    const dlq = this.deadLetterQueues.get(task.queueName);
+    if (dlq) {
+      const idx = dlq.indexOf(taskId);
+      if (idx !== -1) dlq.splice(idx, 1);
+    }
+
+    // Reset for fresh retries but preserve failCount
+    task.status = 'pending';
+    task.attempts = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.progress = 0;
+    task.sequence = this.sequenceCounter++;
+
+    this.ensureQueue(task.queueName);
+    this.queues.get(task.queueName)!.push(task.id);
+
+    return task;
+  }
+
+  clearDeadLetterQueue(queueName?: string): void {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const dlq = this.deadLetterQueues.get(name);
+    if (dlq) {
+      for (const id of dlq) {
+        this.tasks.delete(id);
+      }
+      dlq.length = 0;
+    }
+  }
+
+  // --- Phase 7: Task Dependencies ---
+
+  private areDependenciesMet(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (!dep || dep.status !== 'completed') return false;
+    }
+    return true;
+  }
+
+  private detectCircularDeps(taskId: string, dependencies: string[]): void {
+    const allDeps = new Map<string, string[]>();
+    allDeps.set(taskId, [...dependencies]);
+
+    for (const [id, t] of this.tasks) {
+      allDeps.set(id, [...t.dependencies]);
+    }
+
+    const WHITE = 0, GRAY = 1, BLACK = 2;
+    const colors = new Map<string, number>();
+
+    const dfs = (node: string): boolean => {
+      colors.set(node, GRAY);
+      const deps = allDeps.get(node) ?? [];
+      for (const dep of deps) {
+        const color = colors.get(dep) ?? WHITE;
+        if (color === GRAY) return true;
+        if (color === WHITE && dfs(dep)) return true;
+      }
+      colors.set(node, BLACK);
+      return false;
+    };
+
+    if (dfs(taskId)) {
+      throw new Error('Circular dependency detected');
+    }
+  }
+
+  // Fix M4: Return proper type without unsafe cast
+  getDependencyStatus(taskId: string): { dependency: string; status: TaskStatus | 'unknown' }[] {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    return task.dependencies.map((depId) => {
+      const dep = this.tasks.get(depId);
+      return {
+        dependency: depId,
+        status: dep ? dep.status : 'unknown' as const,
+      };
+    });
+  }
+
+  // --- Phase 8: Concurrency Control ---
+
+  setConcurrency(queueName: string, limit: number): void {
+    if (limit < 1 || !Number.isInteger(limit)) {
+      throw new Error('Concurrency limit must be a positive integer');
+    }
+    this.concurrencyLimits.set(queueName, limit);
+  }
+
+  getConcurrency(queueName?: string): number | undefined {
+    return this.concurrencyLimits.get(queueName ?? DEFAULT_QUEUE);
+  }
+
+  getActiveCount(queueName?: string): number {
+    const name = queueName ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queueName === name && task.status === 'processing') count++;
+    }
+    return count;
+  }
+
+  // --- Phase 9: Progress Tracking and Cancellation ---
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot report progress for task in status: ${task.status}`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error('Progress must be between 0 and 100');
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    task.status = 'cancelled';
+    this.removeFromQueue(task);
+    this.progressListeners.delete(taskId);
+  }
+
+  // --- Phase 10: Recurring Tasks ---
+
+  addSchedule(options: ScheduleOptions): Schedule {
+    // Fix M6: Parse and cache cron fields
+    const parsedCron = parseCron(options.cronExpression);
+
+    const schedule: InternalSchedule = {
+      id: randomUUID(),
+      cronExpression: options.cronExpression,
+      queueName: options.queueName ?? DEFAULT_QUEUE,
+      payload: options.payload,
+      priority: options.priority ?? 5,
+      maxRetries: options.maxRetries ?? 3,
+      backoffDelay: options.backoffDelay ?? 1000,
+      createdAt: new Date(),
+      parsedCron,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule not found: ${scheduleId}`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    // Fix C6: Return empty during shutdown instead of throwing
+    if (this._isShuttingDown) {
+      return [];
+    }
+
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (shouldRun(schedule.parsedCron, currentTime, schedule.lastRun)) {
+        const task = this.add(schedule.payload, {
+          queueName: schedule.queueName,
+          priority: schedule.priority,
+          maxRetries: schedule.maxRetries,
+          backoffDelay: schedule.backoffDelay,
+        });
+        schedule.lastRun = currentTime;
+        created.push(task);
+      }
+    }
+
+    return created;
+  }
+
+  // --- Phase 11: Middleware Pipeline ---
+
+  use(queueName: string, middleware: Middleware): void;
+  use(middleware: Middleware): void;
+  use(queueNameOrMiddleware: string | Middleware, middleware?: Middleware): void {
+    let name: string;
+    let mw: Middleware;
+
+    if (typeof queueNameOrMiddleware === 'string') {
+      name = queueNameOrMiddleware;
+      mw = middleware!;
+    } else {
+      name = DEFAULT_QUEUE;
+      mw = queueNameOrMiddleware;
+    }
+
+    if (!this.middlewareStacks.has(name)) {
+      this.middlewareStacks.set(name, []);
+    }
+    this.middlewareStacks.get(name)!.push(mw);
+  }
+
+  setHandler(queueName: string, handler: TaskHandler): void;
+  setHandler(handler: TaskHandler): void;
+  setHandler(queueNameOrHandler: string | TaskHandler, handler?: TaskHandler): void {
+    if (typeof queueNameOrHandler === 'string') {
+      this.handlers.set(queueNameOrHandler, handler!);
+    } else {
+      this.handlers.set(DEFAULT_QUEUE, queueNameOrHandler);
+    }
+  }
+
+  // Fix H4 & H5: Auto-complete on success, don't re-throw after fail
+  async process<T = unknown>(task: Task<T>): Promise<void> {
+    const middlewares = this.middlewareStacks.get(task.queueName) ?? [];
+    const handler = this.handlers.get(task.queueName);
+
+    let index = 0;
+    const next: NextFunction = async () => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw({ task: task as Task }, next);
+      } else if (handler) {
+        await handler(task as Task);
+      }
+    };
+
+    try {
+      await next();
+      // Auto-complete on success if still processing
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      const message = err instanceof Error ? err.message : String(err);
+      // Only fail if still in processing status (not already handled)
+      if (task.status === 'processing') {
+        this.fail(task.id, message);
+      }
+      throw err;
+    }
+  }
+
+  // --- Phase 12: Graceful Shutdown ---
+
+  get isShuttingDown(): boolean {
+    return this._isShuttingDown;
+  }
+
+  onShutdown(callback: () => Promise<void> | void): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this._isShuttingDown = true;
+    this.shutdownPromise = this.performShutdown(options);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {
+    const startTime = Date.now();
+    const timeout = options?.timeout ?? 30000;
+
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    const processingTasks = this.getProcessingTasks();
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    const deadline = startTime + timeout;
+    while (Date.now() < deadline) {
+      const stillProcessing = this.getProcessingTasks();
+      if (stillProcessing.length === 0) break;
+      await new Promise((resolve) => setTimeout(resolve, 50));
+    }
+
+    const remaining = this.getProcessingTasks();
+    for (const task of remaining) {
+      task.status = 'cancelled';
+      forceCancelled++;
+    }
+
+    for (const task of processingTasks) {
+      if (task.status === 'completed') completed++;
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+
+  private getProcessingTasks(): Task[] {
+    const result: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') result.push(task);
+    }
+    return result;
+  }
+
+  // --- Utility ---
+
+  getTask<T = unknown>(taskId: string): Task<T> | undefined {
+    return this.tasks.get(taskId) as Task<T> | undefined;
+  }
+
+  private ensureQueue(name: string): void {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, []);
+    }
+  }
+
+  private removeFromQueue(task: Task): void {
+    const queue = this.queues.get(task.queueName);
+    if (queue) {
+      const idx = queue.indexOf(task.id);
+      if (idx !== -1) queue.splice(idx, 1);
+    }
+  }
+}
