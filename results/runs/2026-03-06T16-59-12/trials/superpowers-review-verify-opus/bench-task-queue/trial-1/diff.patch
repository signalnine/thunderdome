);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.get();\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should transition to processing on get', () => {\n      const added = queue.add('work');\n      expect(added.status).toBe('pending');\n      const retrieved = queue.get();\n      expect(retrieved?.status).toBe('processing');\n      expect(retrieved?.id).toBe(added.id);\n    });\n\n    it('should have a sequence number for FIFO ordering', () => {\n      const t1 = queue.add('first');\n      const t2 = queue.add('second');\n      expect(t2.sequence).toBeGreaterThan(t1.sequence);\n    });\n  });\n\n  // ========== Phase 2: Named Queues ==========\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      queue.add('task');\n      const names = queue.getQueueNames();\n      expect(names).toContain('default');\n    });\n\n    it('should support multiple independent queues', () => {\n      queue.add('email-task', { queueName: 'emails' });\n      queue.add('sms-task', { queueName: 'sms' });\n\n      expect(queue.size('emails')).toBe(1);\n      expect(queue.size('sms')).toBe(1);\n\n      const emailTask = queue.get('emails');\n      expect(emailTask?.payload).toBe('email-task');\n      expect(queue.get('sms')?.payload).toBe('sms-task');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.get('nonexistent')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queueName: 'q1' });\n      queue.add('b', { queueName: 'q2' });\n      queue.add('c', { queueName: 'q3' });\n      expect(queue.getQueueNames().sort()).toEqual(['q1', 'q2', 'q3']);\n    });\n\n    it('should be backward compatible with Phase 1', () => {\n      queue.add('default-task');\n      expect(queue.get()?.payload).toBe('default-task');\n    });\n  });\n\n  // ========== Phase 3: Priority ==========\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = queue.add('task');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.get()?.payload).toBe('high');\n      expect(queue.get()?.payload).toBe('medium');\n      expect(queue.get()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 3 });\n      queue.add('second', { priority: 3 });\n      queue.add('third', { priority: 3 });\n\n      expect(queue.get()?.payload).toBe('first');\n      expect(queue.get()?.payload).toBe('second');\n      expect(queue.get()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority', () => {\n      expect(() => queue.add('x', { priority: 0 })).toThrow();\n      expect(() => queue.add('x', { priority: 11 })).toThrow();\n      expect(() => queue.add('x', { priority: 3.5 })).toThrow();\n    });\n\n    it('should apply priority per queue', () => {\n      queue.add('q1-low', { queueName: 'q1', priority: 10 });\n      queue.add('q1-high', { queueName: 'q1', priority: 1 });\n      queue.add('q2-low', { queueName: 'q2', priority: 10 });\n\n      expect(queue.get('q1')?.payload).toBe('q1-high');\n      expect(queue.get('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ========== Phase 4: Delayed Tasks ==========\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their time', () => {\n      queue.add('delayed', { delay: 60000 });\n      expect(queue.get()).toBeNull();\n    });\n\n    it('should return delayed tasks after their time', () => {\n      queue.add('delayed', { availableAt: new Date(Date.now() - 1000) });\n      const task = queue.get();\n      expect(task?.payload).toBe('delayed');\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      queue.add('delayed', { delay: 60000 });\n      queue.add('immediate');\n      expect(queue.get()?.payload).toBe('immediate');\n    });\n\n    it('should indicate availability time', () => {\n      const future = new Date(Date.now() + 5000);\n      const task = queue.add('later', { availableAt: future });\n      expect(task.availableAt.getTime()).toBe(future.getTime());\n    });\n\n    it('should work with named queues', () => {\n      queue.add('delayed', { queueName: 'q1', delay: 60000 });\n      queue.add('immediate', { queueName: 'q1' });\n      expect(queue.get('q1')?.payload).toBe('immediate');\n    });\n\n    it('should order delayed tasks by availability time when ready', () => {\n      const now = Date.now();\n      queue.add('second', { availableAt: new Date(now - 500) });\n      queue.add('first', { availableAt: new Date(now - 1000) });\n\n      expect(queue.get()?.payload).toBe('first');\n      expect(queue.get()?.payload).toBe('second');\n    });\n  });\n\n  // ========== Phase 5: Retry with Backoff ==========\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      queue.add('work');\n      const task = queue.get()!;\n      queue.complete(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should retry a failed task with backoff', () => {\n      queue.add('work', { maxRetries: 3, backoffDelay: 100 });\n      const task = queue.get()!;\n      expect(task.attempts).toBe(1);\n\n      queue.fail(task.id, 'error1');\n      const retask = queue.getTask(task.id)!;\n      expect(retask.status).toBe('pending');\n      expect(retask.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should track attempt count deterministically', () => {\n      // Fix C2: Use backoffDelay:0 and availableAt manipulation for determinism\n      queue.add('work', { maxRetries: 3, backoffDelay: 0 });\n      const t1 = queue.get()!;\n      expect(t1.attempts).toBe(1);\n\n      queue.fail(t1.id);\n      // backoffDelay: 0 means 0 * 2^0 = 0ms delay, task is immediately available\n      const t2 = queue.get();\n      expect(t2).not.toBeNull();\n      expect(t2!.attempts).toBe(2);\n      expect(t2!.id).toBe(t1.id);\n    });\n\n    it('should fail permanently after max retries', () => {\n      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n      const task = queue.get()!;\n      queue.fail(task.id, 'error');\n      expect(queue.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      queue.add('work', { queueName: 'q1', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const task = queue.get('q1')!;\n      queue.fail(task.id);\n      const retask = queue.getTask(task.id)!;\n      expect(retask.queueName).toBe('q1');\n      expect(retask.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = queue.add('work');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default backoffDelay to 1000', () => {\n      const task = queue.add('work');\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should track failCount across retries', () => {\n      queue.add('work', { maxRetries: 3, backoffDelay: 0 });\n\n      const t1 = queue.get()!;\n      expect(t1.failCount).toBe(0);\n      queue.fail(t1.id, 'err1');\n      expect(queue.getTask(t1.id)!.failCount).toBe(1);\n\n      const t2 = queue.get()!;\n      queue.fail(t2.id, 'err2');\n      expect(queue.getTask(t1.id)!.failCount).toBe(2);\n    });\n  });\n\n  // ========== Phase 6: Dead Letter Queue ==========\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move to DLQ after all retries exhausted', () => {\n      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n      const task = queue.get()!;\n      queue.fail(task.id, 'permanent error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error).toBe('permanent error');\n    });\n\n    it('should retain failCount in DLQ', () => {\n      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n      const task = queue.get()!;\n      queue.fail(task.id, 'error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].failCount).toBe(1);\n      expect(dlq[0].attempts).toBe(1);\n    });\n\n    it('should have per-queue DLQs', () => {\n      queue.add('w1', { queueName: 'q1', maxRetries: 1 });\n      queue.add('w2', { queueName: 'q2', maxRetries: 1 });\n\n      const t1 = queue.get('q1')!;\n      const t2 = queue.get('q2')!;\n      queue.fail(t1.id);\n      queue.fail(t2.id);\n\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n\n    it('should retry a dead-lettered task', () => {\n      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n      const task = queue.get()!;\n      queue.fail(task.id);\n\n      const retried = queue.retryDeadLetterTask(task.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempts).toBe(0);\n      // failCount should be preserved\n      expect(retried.failCount).toBe(1);\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear DLQ', () => {\n      queue.add('w1', { maxRetries: 1 });\n      queue.add('w2', { maxRetries: 1 });\n      queue.fail(queue.get()!.id);\n      queue.fail(queue.get()!.id);\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n  });\n\n  // ========== Phase 7: Task Dependencies ==========\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unmet dependencies', () => {\n      const dep = queue.add('dependency');\n      const task = queue.add('dependent', { dependencies: [dep.id] });\n\n      const first = queue.get();\n      expect(first?.id).toBe(dep.id);\n\n      const second = queue.get();\n      expect(second).toBeNull();\n\n      queue.complete(dep.id);\n\n      const third = queue.get();\n      expect(third?.id).toBe(task.id);\n    });\n\n    it('should allow valid dependency chains', () => {\n      const t1 = queue.add('t1');\n      const t2 = queue.add('t2', { dependencies: [t1.id] });\n      // t3 depends on both t1 and t2 - this should work\n      expect(() => {\n        queue.add('t3', { dependencies: [t2.id, t1.id] });\n      }).not.toThrow();\n    });\n\n    it('should reject dependency on non-existent task', () => {\n      expect(() => {\n        queue.add('task', { dependencies: ['nonexistent-id'] });\n      }).toThrow('Dependency task not found');\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const task = queue.add('task', { dependencies: [dep1.id, dep2.id] });\n\n      const status = queue.getDependencyStatus(task.id);\n      expect(status).toHaveLength(2);\n      expect(status[0].status).toBe('pending');\n    });\n\n    it('should keep dependent blocked when dependency fails', () => {\n      const dep = queue.add('dep', { maxRetries: 1 });\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      const depTask = queue.get()!;\n      queue.fail(depTask.id, 'error');\n\n      expect(queue.get()).toBeNull();\n    });\n\n    it('should support chain of dependencies', () => {\n      const a = queue.add('a');\n      const b = queue.add('b', { dependencies: [a.id] });\n      const c = queue.add('c', { dependencies: [b.id] });\n\n      // Only a is available\n      expect(queue.get()!.id).toBe(a.id);\n      expect(queue.get()).toBeNull();\n\n      queue.complete(a.id);\n      // Now b is available\n      expect(queue.get()!.id).toBe(b.id);\n      expect(queue.get()).toBeNull();\n\n      queue.complete(b.id);\n      // Now c is available\n      expect(queue.get()!.id).toBe(c.id);\n    });\n  });\n\n  // ========== Phase 8: Concurrency Control ==========\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('a');\n      queue.add('b');\n      queue.add('c');\n\n      const t1 = queue.get();\n      const t2 = queue.get();\n      const t3 = queue.get();\n\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n      expect(t3).toBeNull();\n    });\n\n    it('should free slot when task completes', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('a');\n      queue.add('b');\n\n      const t1 = queue.get()!;\n      expect(queue.get()).toBeNull();\n\n      queue.complete(t1.id);\n      const t2 = queue.get();\n      expect(t2).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('a', { maxRetries: 1 });\n      queue.add('b');\n\n      const t1 = queue.get()!;\n      queue.fail(t1.id);\n\n      const t2 = queue.get();\n      expect(t2).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      expect(queue.getConcurrency('default')).toBeUndefined();\n    });\n\n    it('should report active count', () => {\n      queue.add('a');\n      queue.add('b');\n      expect(queue.getActiveCount()).toBe(0);\n      queue.get();\n      expect(queue.getActiveCount()).toBe(1);\n      queue.get();\n      expect(queue.getActiveCount()).toBe(2);\n    });\n\n    it('should still respect priority under concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const t1 = queue.get()!;\n      expect(t1.payload).toBe('high');\n    });\n  });\n\n  // ========== Phase 9: Progress and Cancellation ==========\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should report and query progress', () => {\n      queue.add('work');\n      const task = queue.get()!;\n\n      queue.reportProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      queue.add('work');\n      const task = queue.get()!;\n\n      const updates: number[] = [];\n      queue.onProgress(task.id, (p) => updates.push(p));\n\n      queue.reportProgress(task.id, 25);\n      queue.reportProgress(task.id, 50);\n      queue.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25, 50, 75]);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      queue.add('work');\n      const task = queue.get()!;\n\n      const updates: number[] = [];\n      const unsubscribe = queue.onProgress(task.id, (p) => updates.push(p));\n\n      queue.reportProgress(task.id, 25);\n      unsubscribe();\n      queue.reportProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = queue.add('work');\n      queue.cancel(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.get()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      queue.add('work');\n      const task = queue.get()!;\n      queue.cancel(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.add('work', { maxRetries: 3 });\n      const task = queue.get()!;\n      queue.cancel(task.id);\n\n      expect(() => queue.fail(task.id)).toThrow();\n    });\n\n    it('should reject progress on non-processing task', () => {\n      const task = queue.add('work');\n      expect(() => queue.reportProgress(task.id, 50)).toThrow();\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add('work');\n      const task = queue.get()!;\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ========== Phase 10: Recurring Tasks ==========\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        payload: { type: 'cleanup' },\n      });\n\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n    });\n\n    it('should list schedules', () => {\n      queue.addSchedule({ cronExpression: '*/5 * * * *', payload: 'a' });\n      queue.addSchedule({ cronExpression: '0 * * * *', payload: 'b' });\n\n      expect(queue.getSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        payload: 'x',\n      });\n\n      queue.removeSchedule(schedule.id);\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when due', () => {\n      queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        payload: 'recurring',\n      });\n\n      const time = new Date(2025, 0, 1, 12, 10, 0);\n      const created = queue.tick(time);\n\n      expect(created.length).toBe(1);\n      expect(created[0].payload).toBe('recurring');\n    });\n\n    it('should not double-fire at same minute', () => {\n      queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        payload: 'recurring',\n      });\n\n      const time = new Date(2025, 0, 1, 12, 10, 0);\n      queue.tick(time);\n      const second = queue.tick(time);\n\n      expect(second).toHaveLength(0);\n    });\n\n    it('should support hourly cron', () => {\n      queue.addSchedule({\n        cronExpression: '0 * * * *',\n        payload: 'hourly',\n      });\n\n      const onTheHour = new Date(2025, 0, 1, 14, 0, 0);\n      const offHour = new Date(2025, 0, 1, 14, 30, 0);\n\n      expect(queue.tick(onTheHour)).toHaveLength(1);\n      expect(queue.tick(offHour)).toHaveLength(0);\n    });\n\n    it('should support daily cron', () => {\n      queue.addSchedule({\n        cronExpression: '0 0 * * *',\n        payload: 'daily',\n      });\n\n      const midnight = new Date(2025, 0, 1, 0, 0, 0);\n      expect(queue.tick(midnight)).toHaveLength(1);\n\n      const noon = new Date(2025, 0, 1, 12, 0, 0);\n      expect(queue.tick(noon)).toHaveLength(0);\n    });\n\n    it('should handle month boundaries correctly', () => {\n      queue.addSchedule({\n        cronExpression: '0 0 * * *',\n        payload: 'daily',\n      });\n\n      // Jan 15 midnight\n      const jan15 = new Date(2025, 0, 15, 0, 0, 0);\n      expect(queue.tick(jan15)).toHaveLength(1);\n\n      // Feb 15 midnight - should fire even though same day-of-month\n      const feb15 = new Date(2025, 1, 15, 0, 0, 0);\n      expect(queue.tick(feb15)).toHaveLength(1);\n    });\n\n    it('should return empty during shutdown', async () => {\n      queue.addSchedule({\n        cronExpression: '*/5 * * * *',\n        payload: 'recurring',\n      });\n\n      await queue.shutdown();\n      const time = new Date(2025, 0, 1, 12, 10, 0);\n      const created = queue.tick(time);\n      expect(created).toHaveLength(0);\n    });\n  });\n\n  // ========== Phase 11: Middleware Pipeline ==========\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order before handler', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_ctx, next) => {\n        order.push('mw1-before');\n        await next();\n        order.push('mw1-after');\n      });\n\n      queue.use('default', async (_ctx, next) => {\n        order.push('mw2-before'