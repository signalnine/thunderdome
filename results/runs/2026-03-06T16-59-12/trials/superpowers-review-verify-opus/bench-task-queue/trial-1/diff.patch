@@ -0,0 +1,98 @@
+// Minimal cron expression parser supporting:
+// - star/N * * * *  (every N minutes)
+// - 0 * * * *       (every hour)
+// - 0 0 * * *       (every day at midnight)
+
+export interface CronFields {
+  minute: number | { every: number };
+  hour: number | '*';
+}
+
+export function parseCron(expression: string): CronFields {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}"`);
+  }
+
+  const [minutePart, hourPart, dayOfMonth, month, dayOfWeek] = parts;
+
+  if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {
+    throw new Error(
+      `Unsupported cron expression: only *, minute, and hour fields are supported`
+    );
+  }
+
+  let minute: number | { every: number };
+  if (minutePart.startsWith('*/')) {
+    const n = parseInt(minutePart.slice(2), 10);
+    if (isNaN(n) || n <= 0 || n > 59) {
+      throw new Error(`Invalid cron interval: ${minutePart}`);
+    }
+    minute = { every: n };
+  } else if (minutePart === '*') {
+    minute = { every: 1 };
+  } else {
+    const n = parseInt(minutePart, 10);
+    if (isNaN(n) || n < 0 || n > 59) {
+      throw new Error(`Invalid cron minute: ${minutePart}`);
+    }
+    minute = n;
+  }
+
+  let hour: number | '*';
+  if (hourPart === '*') {
+    hour = '*';
+  } else {
+    const n = parseInt(hourPart, 10);
+    if (isNaN(n) || n < 0 || n > 23) {
+      throw new Error(`Invalid cron hour: ${hourPart}`);
+    }
+    hour = n;
+  }
+
+  return { minute, hour };
+}
+
+// Fix M5: Compare full date for lastRun deduplication (including year, month, day)
+function sameSlot(a: Date, b: Date): boolean {
+  return (
+    a.getFullYear() === b.getFullYear() &&
+    a.getMonth() === b.getMonth() &&
+    a.getDate() === b.getDate() &&
+    a.getHours() === b.getHours() &&
+    a.getMinutes() === b.getMinutes()
+  );
+}
+
+export function shouldRun(fields: CronFields, now: Date, lastRun?: Date): boolean {
+  const currentMinute = now.getMinutes();
+  const currentHour = now.getHours();
+
+  if (typeof fields.minute === 'object') {
+    const interval = fields.minute.every;
+
+    if (fields.hour !== '*') {
+      if (currentHour !== fields.hour) return false;
+    }
+
+    if (currentMinute % interval !== 0) return false;
+
+    if (lastRun && sameSlot(lastRun, now)) {
+      return false;
+    }
+
+    return true;
+  }
+
+  if (currentMinute !== fields.minute) return false;
+
+  if (fields.hour !== '*') {
+    if (currentHour !== fields.hour) return false;
+  }
+
+  if (lastRun && sameSlot(lastRun, now)) {
+    return false;
+  }
+
+  return true;
+}
