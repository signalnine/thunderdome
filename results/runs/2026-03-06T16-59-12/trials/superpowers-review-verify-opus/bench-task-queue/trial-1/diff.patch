+export type TaskStatus =
+  | 'pending'
+  | 'processing'
+  | 'completed'
+  | 'failed'
+  | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queueName: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+  failCount: number;
+  sequence: number;
+}
+
+export interface AddTaskOptions {
+  queueName?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface ProgressListener {
+  (progress: number, message?: string): void;
+}
+
+export interface MiddlewareContext<T = unknown> {
+  task: Task<T>;
+}
+
+export type NextFunction = () => Promise<void> | void;
+
+export type Middleware<T = unknown> = (
+  ctx: MiddlewareContext<T>,
+  next: NextFunction
+) => Promise<void> | void;
+
+export type TaskHandler<T = unknown> = (task: Task<T>) => Promise<void> | void;
+
+export interface ScheduleOptions {
+  cronExpression: string;
+  queueName?: string;
+  payload: unknown;
+  priority?: number;
+  maxRetries?: number;
+  backoffDelay?: number;
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queueName: string;
+  payload: unknown;
+  priority: number;
+  maxRetries: number;
+  backoffDelay: number;
+  lastRun?: Date;
+  createdAt: Date;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
