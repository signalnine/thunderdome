ad).toBe('first');\n   189→      expect(queue.get()?.payload).toBe('second');\n   190→    });\n   191→  });\n   192→\n   193→  // ========== Phase 5: Retry with Backoff ==========\n   194→  describe('Phase 5: Retry with Backoff', () => {\n   195→    it('should complete a processing task', () => {\n   196→      queue.add('work');\n   197→      const task = queue.get()!;\n   198→      queue.complete(task.id);\n   199→      expect(queue.getTask(task.id)?.status).toBe('completed');\n   200→    });\n   201→\n   202→    it('should retry a failed task with backoff', () => {\n   203→      queue.add('work', { maxRetries: 3, backoffDelay: 100 });\n   204→      const task = queue.get()!;\n   205→      expect(task.attempts).toBe(1);\n   206→\n   207→      queue.fail(task.id, 'error1');\n   208→      const retask = queue.getTask(task.id)!;\n   209→      expect(retask.status).toBe('pending');\n   210→      expect(retask.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n   211→    });\n   212→\n   213→    it('should track attempt count deterministically', () => {\n   214→      // Fix C2: Use backoffDelay:0 and availableAt manipulation for determinism\n   215→      queue.add('work', { maxRetries: 3, backoffDelay: 0 });\n   216→      const t1 = queue.get()!;\n   217→      expect(t1.attempts).toBe(1);\n   218→\n   219→      queue.fail(t1.id);\n   220→      // backoffDelay: 0 means 0 * 2^0 = 0ms delay, task is immediately available\n   221→      const t2 = queue.get();\n   222→      expect(t2).not.toBeNull();\n   223→      expect(t2!.attempts).toBe(2);\n   224→      expect(t2!.id).toBe(t1.id);\n   225→    });\n   226→\n   227→    it('should fail permanently after max retries', () => {\n   228→      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n   229→      const task = queue.get()!;\n   230→      queue.fail(task.id, 'error');\n   231→      expect(queue.getTask(task.id)?.status).toBe('failed');\n   232→    });\n   233→\n   234→    it('should keep original queue and p