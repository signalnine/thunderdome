n   478→  // Fix H4 & H5: Auto-complete on success, don't re-throw after fail\n   479→  async process<T = unknown>(task: Task<T>): Promise<void> {\n   480→    const middlewares = this.middlewareStacks.get(task.queueName) ?? [];\n   481→    const handler = this.handlers.get(task.queueName);\n   482→\n   483→    let index = 0;\n   484→    const next: NextFunction = async () => {\n   485→      if (index < middlewares.length) {\n   486→        const mw = middlewares[index++];\n   487→        await mw({ task: task as Task }, next);\n   488→      } else if (handler) {\n   489→        await handler(task as Task);\n   490→      }\n   491→    };\n   492→\n   493→    try {\n   494→      await next();\n   495→      // Auto-complete on success if still processing\n   496→      if (task.status === 'processing') {\n   497→        this.complete(task.id);\n   498→      }\n   499→    } catch (err) {\n   500→      const message = err instanceof Error ? err.message : String(err);\n   501→      // Only fail if still in processing status (not already handled)\n   502→      if (task.status === 'processing') {\n   503→        this.fail(task.id, message);\n   504→      }\n   505→      throw err;\n   506→    }\n   507→  }\n   508→\n   509→  // --- Phase 12: Graceful Shutdown ---\n   510→\n   511→  get isShuttingDown(): boolean {\n   512→    return this._isShuttingDown;\n   513→  }\n   514→\n   515→  onShutdown(callback: () => Promise<void> | void): void {\n   516→    this.shutdownCallbacks.push(callback);\n   517→  }\n   518→\n   519→  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   520→    if (this.shutdownPromise) {\n   521→      return this.shutdownPromise;\n   522→    }\n   523→\n   524→    this._isShuttingDown = true;\n   525→    this.shutdownPromise = this.performShutdown(options);\n   526→    return this.shutdownPromise;\n   527→  }\n   528→\n   529→  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   530→    const startTime = Date.now();\n   531→    const timeout = options?.timeout ?? 30000;\n   532→\n   533→    for (const cb of this.shutdownCallbacks) {\n   534→      await cb();\n   535→    }\n   536→\n   537→    const processingTasks = this.getProcessingTasks();\n   538→    let completed = 0;\n   539→    let forceCancelled = 0;\n   540→\n   541→    if (processingTasks.length === 0) {\n   542→      return {\n   543→        completed: 0,\n   544→        forceCancelled: 0,\n   545→        durationMs: Date.now() - startTime,\n   546→      };\n   547→    }\n   548→\n   549→    const deadline = startTime + timeout;\n   550→    while (Date.now() < deadline) {\n   551→      const stillProcessing = this.getProcessingTasks();\n   552→      if (stillProcessing.length === 0) break;\n   553→      await new Promise((resolve) => setTimeout(resolve, 50));\n   554→    }\n   555→\n   556→    const remaining = this.getProcessingTasks();\n   557→    for (const task of remaining) {\n   558→      task.status = 'cancelled';\n   559→      forceCancelled++;\n   560→    }\n   561→\n   562→    for (const task of processingTasks) {\n   563→      if (task.status === 'completed') completed++;\n   564→    }\n   565→\n   566→    return {\n   567→      completed,\n   568→      forceCancelled,\n   569→      durationMs: Date.now() - startTime,\n   570→    };\n   571→  }\n   572→\n   573→  private getProcessingTasks(): Task[] {\n   574→    const result: Task[] = [];\n   575→    for (const task of this.tasks.values()) {\n   576→      if (task.status === 'processing') result.push(task);\n   577→    }\n   578→    return result;\n   579→  }\n   580→\n   581→  // --- Utility ---\n   582→\n   583→  getTask<T = unknown>(taskId: string): Task<T> | undefined {\n   584→    return this.tasks.get(taskId) as Task<T> | undefined;\n   585→  }\n   586→\n   587→  private ensureQueue(name: string): void {\n   588→    if (!this.queues.has(name)) {\n   589→      this.queues.set(name, []);\n   590→    }\n   591→  }\n   592→\n   593→  pr