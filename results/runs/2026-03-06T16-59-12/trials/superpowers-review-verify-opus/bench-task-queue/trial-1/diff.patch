ssingTasks(): Task[] {\n    const result: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') result.push(task);\n    }\n    return result;\n  }\n\n  // --- Utility ---\n\n  getTask<T = unknown>(taskId: string): Task<T> | undefined {\n    return this.tasks.get(taskId) as Task<T> | undefined;\n  }\n\n  private ensureQueue(name: string): void {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, []);\n    }\n  }\n}\n","structuredPatch":[{"oldStart":312,"oldLines":51,"newStart":312,"newLines":7,"lines":["   }"," ","   private detectCircularDeps(taskId: string, dependencies: string[]): void {","-    // BFS/DFS from each dependency to see if we can reach taskId","-    // Also check if any dependency depends (transitively) on any other dependency","-    // creating a cycle","-    const visited = new Set<string>();","-","-    const visit = (currentId: string, path: Set<string>): void => {","-      if (path.has(currentId)) {","-        throw new Error('Circular dependency detected');","-      }","-      if (visited.has(currentId)) return;","-      visited.add(currentId);","-      path.add(currentId);","-","-      const current = this.tasks.get(currentId);","-      if (current) {","-        for (const depId of current.dependencies) {","-          visit(depId, new Set(path));","-        }","-      }","-    };","-","-    // Check that no dependency can reach back to form a cycle","-    // We simulate: taskId depends on all `dependencies`","-    // So we walk from each dependency and check for cycles","-    for (const depId of dependencies) {","-      const reachable = new Set<string>();","-      const stack = [depId];","-      while (stack.length > 0) {","-        const id = stack.pop()!;","-        if (reachable.has(id)) continue;","-        reachable.add(id);","-        const t = this.tasks.get(id);","-        if (t) {","-          for (const d of t.dependencies) {","-            stack.push(d);","-          }","-  