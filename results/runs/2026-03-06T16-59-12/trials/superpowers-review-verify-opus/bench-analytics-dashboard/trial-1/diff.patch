@@ -0,0 +1,216 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { AuthenticatedRequest } from '../types.js';
+import { authenticate } from '../middleware/auth.js';
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function safeJsonParse(str: string, fallback: unknown = {}): unknown {
+  try {
+    return JSON.parse(str);
+  } catch {
+    return fallback;
+  }
+}
+
+function escapeCsvField(field: string): string {
+  if (field.includes(',') || field.includes('"') || field.includes('\n')) {
+    return `"${field.replace(/"/g, '""')}"`;
+  }
+  return field;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ['id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+  const lines = [headers.join(',')];
+
+  for (const event of events) {
+    const row = [
+      escapeCsvField(event.id),
+      escapeCsvField(event.name),
+      escapeCsvField(event.properties),
+      escapeCsvField(event.timestamp),
+      escapeCsvField(event.user_id || ''),
+      escapeCsvField(event.session_id || ''),
+    ];
+    lines.push(row.join(','));
+  }
+
+  return lines.join('\n');
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get('/events/json', authenticate, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    sql += ' ORDER BY timestamp ASC';
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const result = events.map((e) => ({
+      ...e,
+      properties: safeJsonParse(e.properties),
+    }));
+
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.json"');
+    res.json(result);
+  });
+
+  // Export events as CSV
+  router.get('/events/csv', authenticate, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    sql += ' ORDER BY timestamp ASC';
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const csv = eventsToCsv(events);
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(csv);
+  });
+
+  // Export dashboard as JSON
+  router.get('/dashboards/:id/json', authenticate, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { id } = req.params;
+
+    const dashboard = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const widgets = db
+      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')
+      .all(id) as Array<{ id: string; dashboard_id: string; type: string; config: string; position_x: number; position_y: number; width: number; height: number }>;
+
+    const result = {
+      ...dashboard,
+      config: safeJsonParse(dashboard.config),
+      widgets: widgets.map((w) => ({
+        ...w,
+        config: safeJsonParse(w.config),
+      })),
+    };
+
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${id}.json"`);
+    res.json(result);
+  });
+
+  // Export dashboard as CSV
+  router.get('/dashboards/:id/csv', authenticate, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { id } = req.params;
+
+    const dashboard = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const widgets = db
+      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')
+      .all(id) as Array<{ id: string; dashboard_id: string; type: string; config: string; position_x: number; position_y: number; width: number; height: number }>;
+
+    const headers = ['id', 'name', 'owner_id', 'config', 'created_at', 'updated_at', 'widget_count'];
+    const row = [
+      escapeCsvField(dashboard.id),
+      escapeCsvField(dashboard.name),
+      escapeCsvField(dashboard.owner_id),
+      escapeCsvField(dashboard.config),
+      escapeCsvField(dashboard.created_at),
+      escapeCsvField(dashboard.updated_at),
+      String(widgets.length),
+    ];
+
+    let csv = headers.join(',') + '\n' + row.join(',');
+
+    if (widgets.length > 0) {
+      csv += '\n\nwidget_id,type,config,position_x,position_y,width,height';
+      for (const w of widgets) {
+        csv += '\n' + [
+          escapeCsvField(w.id),
+          escapeCsvField(w.type),
+          escapeCsvField(w.config),
+          String(w.position_x),
+          String(w.position_y),
+          String(w.width),
+          String(w.height),
+        ].join(',');
+      }
+    }
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${id}.csv"`);
+    res.send(csv);
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..375a7f5
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,96 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { AuthenticatedRequest } from '../types.js';
+import { authenticate } from '../middleware/auth.js';
+
+const INTERVAL_FORMATS: Record<string, string> = {
+  hour: '%Y-%m-%dT%H:00:00',
+  day: '%Y-%m-%d',
+  month: '%Y-%m-01',
+};
+
+function buildFilterClause(params: unknown[], event_name?: string, start_date?: string, end_date?: string, filters?: Record<string, unknown>): string {
+  let sql = '';
+
+  if (event_name) {
+    sql += ' AND name = ?';
+    params.push(event_name);
+  }
+
+  if (start_date) {
+    sql += ' AND timestamp >= ?';
+    params.push(start_date);
+  }
+
+  if (end_date) {
+    sql += ' AND timestamp <= ?';
+    params.push(end_date);
+  }
+
+  if (filters && typeof filters === 'object') {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += ' AND json_extract(properties, ?) = ?';
+      params.push(`$.${key}`, value);
+    }
+  }
+
+  return sql;
+}
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post('/count', authenticate, (req: AuthenticatedRequest, res: Response) => {
+    const { event_name, start_date, end_date, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    const params: unknown[] = [tenantId];
+    const filterSql = buildFilterClause(params, event_name, start_date, end_date, filters);
+    const sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?' + filterSql;
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post('/timeseries', authenticate, (req: AuthenticatedRequest, res: Response) => {
+    const { event_name, start_date, end_date, interval, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    const bucketInterval = interval || 'day';
+    const dateFormat = INTERVAL_FORMATS[bucketInterval];
+
+    if (!dateFormat) {
+      res.status(400).json({ error: 'Invalid interval. Must be hour, day, or month.' });
+      return;
+    }
+
+    const params: unknown[] = [tenantId];
+    const filterSql = buildFilterClause(params, event_name, start_date, end_date, filters);
+    const sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?` + filterSql + ' GROUP BY bucket ORDER BY bucket ASC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ interval: bucketInterval, data: results });
+  });
+
+  // Breakdown query
+  router.post('/breakdown', authenticate, (req: AuthenticatedRequest, res: Response) => {
+    const { event_name, property, start_date, end_date, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: 'property is required for breakdown queries' });
+      return;
+    }
+
+    const params: unknown[] = [`$.${property}`, tenantId];
+    const filterSql = buildFilterClause(params, event_name, start_date, end_date, filters);
+    const sql = 'SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?' + filterSql + ' GROUP BY value ORDER BY count DESC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;
+    res.json({ property, data: results });
+  });
+
+  return router;
+}
