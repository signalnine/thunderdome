+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SZE5kivPsxbG7bMJjVB42d","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import Database from 'better-sqlite3';\n     3→import { createHash } from 'crypto';\n     4→import { v4 as uuidv4 } from 'uuid';\n     5→import { AuthenticatedRequest } from '../types.js';\n     6→import { authenticate, generateToken, requireRole } from '../middleware/auth.js';\n     7→\n     8→function hashPassword(password: string): string {\n     9→  return createHash('sha256').update(password).digest('hex');\n    10→}\n    11→\n    12→export function createUserRoutes(db: Database.Database): Router {\n    13→  const router = Router();\n    14→\n    15→  // Register\n    16→  router.post('/register', (req: AuthenticatedRequest, res: Response) => {\n    17→    const { email, password, tenant_id, role } = req.body;\n    18→\n    19→    if (!email || !password || !tenant_id) {\n    20→      res.status(400).json({ error: 'email, password, and tenant_id are required' });\n    21→      return;\n    22→    }\n    23→\n    24→    const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);\n    25→    if (existing) {\n    26→      res.status(409).json({ error: 'Email already registered' });\n    27→      return;\n    28→    }\n    29→\n    30→    const id = uuidv4();\n    31→    const password_hash = hashPassword(password);\n    32→    const userRole = role && ['admin', 'viewer', 'editor'].includes(role) ? role : 'viewer';\n    33→\n    34→    db.prepare(\n    35→      'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'\n    36→    ).run(id, email, password_hash, tenant_id, userRole);\n    37→\n    38→    const token = generateToken({ userId: id, tenantId: tenant_id, role: userRole });\n    39→\n    40→    res.status(201).json({\n    41→      id,\n    42→      email,\n    43→      tenant_id,\n    44→      role: userRole,\n    45→      token,\n    46→    });\n    47→  });\n    48→\n    49→  // Login\n    50→  router.post('/login', (req: AuthenticatedRequest, res: Response) => {\n    51→    const { email, password } = req.body;\n    52→\n    53→    if (!email || !password) {\n    54→      res.status(400).json({ error: 'email and password are required' });\n    55→      return;\n    56→    }\n    57→\n    58→    const user = db\n    59→      .prepare('SELECT * FROM users WHERE email = ?')\n    60→      .get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;\n    61→\n    62→    if (!user || user.password_hash !== hashPassword(password)) {\n    63→      res.status(401).json({ error: 'Invalid credentials' });\n    64→      return;\n    65→    }\n    66→\n    67→    const token = generateToken({\n    68→      userId: user.id,\n    69→      tenantId: user.tenant_id,\n    70→      role: user.role,\n    71→    });\n    72→\n    73→    res.json({\n    74→      id: user.id,\n    75→      email: user.email,\n    76→      tenant_id: user.tenant_id,\n    77→      role: user.role,\n    78→      token,\n    79→    });\n    80→  });\n    81→\n    82→  // Get profile\n    83→  router.get('/me', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    84→    const user = db\n    85→      .prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?')\n    86→      .get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;\n    87→\n    88→    if (!user) {\n    89→      res.status(404).json({ error: 'User not found' });\n    90→      return;\n    91→    }\n    92→\n    93→    res.json(user);\n    94→  });\n    95→\n    96→  // Update role (admin only)\n    97→  router.patch(\n    98→    '/:userId/role',\n    99→    authenticate,\n   100→    requireRole('admin'),\n   101→    (req: AuthenticatedRequest, res: Response) => {\n   102→      const { userId } = req.params;\n   103→      const { role } = req.body;\n   104→\n   105→      if (!role || !['admin', 'viewer', 'editor'].includes(role)) {\n   106→        res.status(400).json({ error: 'Valid role is required (admin, viewer, editor)' });\n   107→        return;\n   108→      }\n   109→\n   110→      const targetUser = db\n   111→        .prepare('SELECT id, tenant_id FROM users WHERE id = ?')\n   112→        .get(userId) as { id: string; tenant_id: string } | undefined;\n   113→\n   114→      if (!targetUser) {\n   115→        res.status(404).json({ error: 'User not found' });\n   116→        return;\n   117→      }\n   118→\n   119→      if (targetUser.tenant_id !== req.user!.tenantId) {\n   120→        res.status(403).json({ error: 'Cannot modify users in another tenant' });\n   121→        return;\n   122→      }\n   123→\n   124→      db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, userId);\n   125→\n   126→      res.json({ id: userId, role });\n   127→    }\n   128→  );\n   129→\n   130→  return router;\n   131→}\n   132→"}]},"parent_tool_use_id":"toolu_01XcmruFniZx6SQXgHqqgeUD","session_id":"3fcfc893-9347-401b-94f4-88670bcb5079","uuid":"cb008cee-af08-4182-b71a-9418bbe19a9d"}
