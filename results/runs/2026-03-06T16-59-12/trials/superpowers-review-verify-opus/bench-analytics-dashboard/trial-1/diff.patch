quest(app)\n        .post('/api/users/register')\n        .send({ email: 'test@example.com', password: 'pass123', tenant_id: 'tenant1' });\n      expect(res.status).toBe(201);\n      expect(res.body.email).toBe('test@example.com');\n      expect(res.body.tenant_id).toBe('tenant1');\n      expect(res.body.token).toBeDefined();\n      expect(res.body.role).toBe('admin');\n    });\n\n    it('should register subsequent users as viewer by default', async () => {\n      await request(app)\n        .post('/api/users/register')\n        .send({ email: 'first@example.com', password: 'pass123', tenant_id: 'tenant1' });\n      const res = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'second@example.com', password: 'pass123', tenant_id: 'tenant1' });\n      expect(res.status).toBe(201);\n      expect(res.body.role).toBe('viewer');\n    });\n\n    it('should reject duplicate email', async () => {\n      await request(app)\n        .post('/api/users/register')\n        .send({ email: 'dup@example.com', password: 'pass123', tenant_id: 'tenant1' });\n      const res = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'dup@example.com', password: 'pass456', tenant_id: 'tenant1' });\n      expect(res.status).toBe(409);\n    });\n\n    it('should login and return token', async () => {\n      await request(app)\n        .post('/api/users/register')\n        .send({ email: 'user@example.com', password: 'pass123', tenant_id: 'tenant1' });\n      const res = await request(app)\n        .post('/api/users/login')\n        .send({ email: 'user@example.com', password: 'pass123' });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it('should reject wrong password', async () => {\n      await request(app)\n        .post('/api/users/register')\n        .send({ email: 'user2@example.com', password: 'pass123', tenant_id: 'tenant1' });\n      const res = await request(app)\n        .post('/api/users/login')\n        .send({ email: 'user2@example.com', password: 'wrong' });\n      expect(res.status).toBe(401);\n    });\n\n    it('should get user profile', async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'me@example.com', password: 'pass123', tenant_id: 'tenant1' });\n      const res = await request(app)\n        .get('/api/users/me')\n        .set('Authorization', `Bearer ${reg.body.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe('me@example.com');\n    });\n\n    it('should return 401 for unauthenticated profile request', async () => {\n      const res = await request(app).get('/api/users/me');\n      expect(res.status).toBe(401);\n    });\n\n    it('should allow admin to change role', async () => {\n      const admin = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'adm@example.com', password: 'pass', tenant_id: 't1', role: 'admin' });\n      const user = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'usr@example.com', password: 'pass', tenant_id: 't1' });\n\n      const res = await request(app)\n        .patch(`/api/users/${user.body.id}/role`)\n        .set('Authorization', `Bearer ${admin.body.token}`)\n        .send({ role: 'editor' });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe('editor');\n    });\n\n    it('should reject non-admin role change', async () => {\n      const viewer = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'v@example.com', password: 'pass', tenant_id: 't1' });\n      const user = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'u@example.com', password: 'pass', tenant_id: 't1' });\n\n      const res = await request(app)\n        .patch(`/api/users/${user.body.id}/role`)\n        .set('Authorization', `Bearer ${viewer.body.token}`)\n        .send({ role: 'editor' });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('Event Ingestion', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'ev@example.com', password: 'pass', tenant_id: 't1' });\n      token = reg.body.token;\n    });\n\n    it('should ingest a single event', async () => {\n      const res = await request(app)\n        .post('/api/events')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'page_view', properties: { url: '/home' } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('page_view');\n      expect(res.body.properties.url).toBe('/home');\n    });\n\n    it('should reject unauthenticated event', async () => {\n      const res = await request(app)\n        .post('/api/events')\n        .send({ name: 'page_view' });\n      expect(res.status).toBe(401);\n    });\n\n    it('should ingest batch events', async () => {\n      const res = await request(app)\n        .post('/api/events/batch')\n        .set('Authorization', `Bearer ${token}`)\n        .send({\n          events: [\n            { name: 'page_view', properties: { url: '/home' } },\n            { name: 'click', properties: { button: 'cta' } },\n            { name: 'page_view', properties: { url: '/about' } },\n          ],\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n  });\n\n  describe('Query Engine', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'q@example.com', password: 'pass', tenant_id: 't1' });\n      token = reg.body.token;\n\n      // Insert test events\n      await request(app)\n        .post('/api/events/batch')\n        .set('Authorization', `Bearer ${token}`)\n        .send({\n          events: [\n            { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-01T10:00:00Z' },\n            { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-01T14:00:00Z' },\n            { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-02T10:00:00Z' },\n            { name: 'click', properties: { button: 'cta' }, timestamp: '2024-01-02T11:00:00Z' },\n          ],\n        });\n    });\n\n    it('should count all events', async () => {\n      const res = await request(app)\n        .post('/api/queries/count')\n        .set('Authorization', `Bearer ${token}`)\n        .send({});\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(4);\n    });\n\n    it('should count filtered events', async () => {\n      const res = await request(app)\n        .post('/api/queries/count')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ event_name: 'page_view' });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it('should return timeseries data', async () => {\n      const res = await request(app)\n        .post('/api/queries/timeseries')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ event_name: 'page_view', interval: 'day' });\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBe(2);\n    });\n\n    it('should return breakdown data', async () => {\n      const res = await request(app)\n        .post('/api/queries/breakdown')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ event_name: 'page_view', property: 'url' });\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBe(2);\n      expect(res.body.data[0].count).toBe(2); // /home has 2\n    });\n  });\n\n  describe('Tenant Isolation', () => {\n    it('should not allow one tenant to see another tenant events', async () => {\n      const t1 = await request(app)\n        .post('/api/users/register')\n        .send({ email: 't1@example.com', password: 'pass', tenant_id: 'tenant1' });\n      const t2 = await request(app)\n        .post('/api/users/register')\n        .send({ email: 't2@example.com', password: 'pass', tenant_id: 'tenant2' });\n\n      await request(app)\n        .post('/api/events')\n        .set('Authorization', `Bearer ${t1.body.token}`)\n        .send({ name: 'secret_event', properties: { data: 'private' } });\n\n      const res = await request(app)\n        .post('/api/queries/count')\n        .set('Authorization', `Bearer ${t2.body.token}`)\n        .send({ event_name: 'secret_event' });\n      expect(res.body.count).toBe(0);\n    });\n  });\n\n  describe('Dashboard CRUD', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'd@example.com', password: 'pass', tenant_id: 't1' });\n      token = reg.body.token;\n    });\n\n    it('should create a dashboard', async () => {\n      const res = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'My Dashboard', config: { theme: 'dark' } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('My Dashboard');\n      expect(res.body.config.theme).toBe('dark');\n    });\n\n    it('should list dashboards', async () => {\n      await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Dashboard 1' });\n      await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Dashboard 2' });\n\n      const res = await request(app)\n        .get('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.length).toBe(2);\n    });\n\n    it('should get a single dashboard', async () => {\n      const created = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Test Dashboard' });\n\n      const res = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Test Dashboard');\n    });\n\n    it('should update a dashboard', async () => {\n      const created = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Old Name' });\n\n      const res = await request(app)\n        .put(`/api/dashboards/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'New Name' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('New Name');\n    });\n\n    it('should delete a dashboard', async () => {\n      const created = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'To Delete' });\n\n      const res = await request(app)\n        .delete(`/api/dashboards/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(204);\n\n      const check = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(check.status).toBe(404);\n    });\n  });\n\n  describe('Data Export', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'exp@example.com', password: 'pass', tenant_id: 't1' });\n      token = reg.body.token;\n\n      await request(app)\n        .post('/api/events/batch')\n        .set('Authorization', `Bearer ${token}`)\n        .send({\n          events: [\n            { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-01T10:00:00Z' },\n            { name: 'click', properties: { button: 'cta' }, timestamp: '2024-01-02T10:00:00Z' },\n          ],\n        });\n    });\n\n    it('should export events as JSON', async () => {\n      const res = await request(app)\n        .get('/api/export/events/json')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toContain('application/json');\n      expect(Array.isArray(res.body)).toBe(true);\n      expect(res.body.length).toBe(2);\n    });\n\n    it('should export events as CSV', async () => {\n      const res = await request(app)\n        .get('/api/export/events/csv')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toContain('text/csv');\n      const lines = res.text.split('\\n');\n      expect(lines[0]).toBe('id,name,properties,timestamp,user_id,session_id');\n      expect(lines.length).toBe(3); // header + 2 events\n    });\n\n    it('should export dashboard as JSON', async () => {\n      const dash = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Export Test' });\n\n      const res = await request(app)\n        .get(`/api/export/dashboards/${dash.body.id}/json`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Export Test');\n    });\n\n    it('should export dashboard as CSV', async () => {\n      const dash = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'CSV Export' });\n\n      const res = await request(app)\n        .get(`/api/export/dashboards/${dash.body.id}/csv`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toContain('text/csv');\n    });\n\n    it('should reject unauthenticated export', async () => {\n      const res = await req