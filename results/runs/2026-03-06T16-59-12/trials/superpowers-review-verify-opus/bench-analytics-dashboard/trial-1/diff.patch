}\n\n    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [tenantId];\n\n    if (event_name) {\n      sql += ' AND name = ?';\n      params.push(event_name);\n    }\n\n    if (start_date) {\n      sql += ' AND timestamp >= ?';\n      params.push(start_date);\n    }\n\n    if (end_date) {\n      sql += ' AND timestamp <= ?';\n      params.push(end_date);\n    }\n\n    if (filters && typeof filters === 'object') {\n      for (const [key, value] of Object.entries(filters)) {\n        sql += ` AND json_extract(properties, ?) = ?`;\n        params.push(`$.${key}`, value);\n      }\n    }\n\n    sql += ' GROUP BY bucket ORDER BY bucket ASC';\n\n    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;\n    res.json({ interval: bucketInterval, data: results });\n  });\n\n  // Breakdown query\n  router.post('/breakdown', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const { event_name, property, start_date, end_date, filters } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    if (!property) {\n      res.status(400).json({ error: 'property is required for breakdown queries' });\n      return;\n    }\n\n    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [`$.${property}`, tenantId];\n\n    if (event_name) {\n      sql += ' AND name = ?';\n      params.push(event_name);\n    }\n\n    if (start_date) {\n      sql += ' AND timestamp >= ?';\n      params.push(start_date);\n    }\n\n    if (end_date) {\n      sql += ' AND timestamp <= ?';\n      params.push(end_date);\n    }\n\n    if (filters && typeof filters === 'object') {\n      for (const [key, value] of Object.entries(filters)) {\n        sql += ` AND json_extract(properties, ?) = ?`;\n        params.push(`$.${key}`, value);\n      }\n    }\n\n    sql += ' GROUP BY value ORDER BY count DESC';\n\n    const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;\n    res.json({ property, data: results });\n  });","new_string":"const INTERVAL_FORMATS: Record<string, string> = {\n  hour: '%Y-%m-%dT%H:00:00',\n  day: '%Y-%m-%d',\n  month: '%Y-%m-01',\n};\n\nfunction buildFilterClause(params: unknown[], event_name?: string, start_date?: string, end_date?: string, filters?: Record<string, unknown>): string {\n  let sql = '';\n\n  if (event_name) {\n    sql += ' AND name = ?';\n    params.push(event_name);\n  }\n\n  if (start_date) {\n    sql += ' AND timestamp >= ?';\n    params.push(start_date);\n  }\n\n  if (end_date) {\n    sql += ' AND timestamp <= ?';\n    params.push(end_date);\n  }\n\n  if (filters && typeof filters === 'object') {\n    for (const [key, value] of Object.entries(filters)) {\n      sql += ' AND json_extract(properties, ?) = ?';\n      params.push(`$.${key}`, value);\n    }\n  }\n\n  return sql;\n}\n\nexport function createQueryRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Count query\n  router.post('/count', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const { event_name, start_date, end_date, filters } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    const params: unknown[] = [tenantId];\n    const filterSql = buildFilterClause(params, event_name, start_date, end_date, filters);\n    const sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?' + filterSql;\n\n    const result = db.prepare(sql).get(...params) as { count: number };\n    res.json({ count: result.count });\n  });\n\n  // Timeseries query\n  router.post('/timeseries', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const { event_name, start_date, end_date, interval, filters } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    const bucketInterval = interval || 'day';\n    const dateFormat = INTERVAL_FORMATS[bucketInterval];\n\n    if (!dateFormat) {\n      res.status(400).json({ error: 'Invalid interval. Must be hour, day, or month.' });\n      return;\n    }\n\n    const params: unknown[] = [tenantId];\n    const filterSql = buildFilterClause(params, event_name, start_date, end_date, filters);\n    const sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?` + filterSql + ' GROUP BY bucket ORDER BY bucket ASC';\n\n    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;\n    res.json({ interval: bucketInterval, data: results });\n  });\n\n  // Breakdown query\n  router.post('/breakdown', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const { event_name, property, start_date, end_date, filters } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    if (!property) {\n      res.status(400).json({ error: 'property is required for breakdown queries' });\n      return;\n    }\n\n    const params: unknown[] = [`$.${property}`, tenantId];\n    const filterSql = buildFilterClause(params, event_name, start_date, end_date, filters);\n    const sql = 'SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?' + filterSql + ' GROUP BY value ORDER BY count DESC';\n\n    const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;\n    res.json({ property, data: results });\n  });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1768,"cache_read_input_tokens":52626,"cache_creation":{"ephemeral_5m_input_tokens":1768,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3fcfc893-9347-401b-94f4-88670bcb5079","uuid":"7f8561a0-5af4-4fdd-95f8-4dbc8fe3c1ca"}
