+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P4kz2av9TYJ3BMZoepCMBn","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import Database from 'better-sqlite3';\n     3→import { AuthenticatedRequest } from '../types.js';\n     4→import { authenticate } from '../middleware/auth.js';\n     5→\n     6→interface EventRow {\n     7→  id: string;\n     8→  tenant_id: string;\n     9→  name: string;\n    10→  properties: string;\n    11→  timestamp: string;\n    12→  user_id: string | null;\n    13→  session_id: string | null;\n    14→}\n    15→\n    16→interface DashboardRow {\n    17→  id: string;\n    18→  tenant_id: string;\n    19→  name: string;\n    20→  owner_id: string;\n    21→  config: string;\n    22→  created_at: string;\n    23→  updated_at: string;\n    24→}\n    25→\n    26→function escapeCsvField(field: string): string {\n    27→  if (field.includes(',') || field.includes('\"') || field.includes('\\n')) {\n    28→    return `\"${field.replace(/\"/g, '\"\"')}\"`;\n    29→  }\n    30→  return field;\n    31→}\n    32→\n    33→function eventsToCsv(events: EventRow[]): string {\n    34→  const headers = ['id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];\n    35→  const lines = [headers.join(',')];\n    36→\n    37→  for (const event of events) {\n    38→    const row = [\n    39→      escapeCsvField(event.id),\n    40→      escapeCsvField(event.name),\n    41→      escapeCsvField(event.properties),\n    42→      escapeCsvField(event.timestamp),\n    43→      escapeCsvField(event.user_id || ''),\n    44→      escapeCsvField(event.session_id || ''),\n    45→    ];\n    46→    lines.push(row.join(','));\n    47→  }\n    48→\n    49→  return lines.join('\\n');\n    50→}\n    51→\n    52→export function createExportRoutes(db: Database.Database): Router {\n    53→  const router = Router();\n    54→\n    55→  // Export events as JSON\n    56→  router.get('/events/json', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    57→    const tenantId = req.user!.tenantId;\n    58→    const { event_name, start_date, end_date } = req.query;\n    59→\n    60→    let sql = 'SELECT * FROM events WHERE tenant_id = ?';\n    61→    const params: unknown[] = [tenantId];\n    62→\n    63→    if (event_name) {\n    64→      sql += ' AND name = ?';\n    65→      params.push(event_name);\n    66→    }\n    67→\n    68→    if (start_date) {\n    69→      sql += ' AND timestamp >= ?';\n    70→      params.push(start_date);\n    71→    }\n    72→\n    73→    if (end_date) {\n    74→      sql += ' AND timestamp <= ?';\n    75→      params.push(end_date);\n    76→    }\n    77→\n    78→    sql += ' ORDER BY timestamp ASC';\n    79→\n    80→    const events = db.prepare(sql).all(...params) as EventRow[];\n    81→    const result = events.map((e) => ({\n    82→      ...e,\n    83→      properties: JSON.parse(e.properties),\n    84→    }));\n    85→\n    86→    res.setHeader('Content-Type', 'application/json');\n    87→    res.setHeader('Content-Disposition', 'attachment; filename=\"events.json\"');\n    88→    res.json(result);\n    89→  });\n    90→\n    91→  // Export events as CSV\n    92→  router.get('/events/csv', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    93→    const tenantId = req.user!.tenantId;\n    94→    const { event_name, start_date, end_date } = req.query;\n    95→\n    96→    let sql = 'SELECT * FROM events WHERE tenant_id = ?';\n    97→    const params: unknown[] = [tenantId];\n    98→\n    99→    if (event_name) {\n   100→      sql += ' AND name = ?';\n   101→      params.push(event_name);\n   102→    }\n   103→\n   104→    if (start_date) {\n   105→      sql += ' AND timestamp >= ?';\n   106→      params.push(start_date);\n   107→    }\n   108→\n   109→    if (end_date) {\n   110→      sql += ' AND timestamp <= ?';\n   111→      params.push(end_date);\n   112→    }\n   113→\n   114→    sql += ' ORDER BY timestamp ASC';\n   115→\n   116→    const events = db.prepare(sql).all(...params) as EventRow[];\n   117→    const csv = eventsToCsv(events);\n   118→\n   119→    res.setHeader('Content-Type', 'text/csv');\n   120→    res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n   121→    res.send(csv);\n   122→  });\n   123→\n   124→  // Export dashboard as JSON\n   125→  router.get('/dashboards/:id/json', authenticate, (req: AuthenticatedRequest, res: Response) => {\n   126→    const tenantId = req.user!.tenantId;\n   127→    const { id } = req.params;\n   128→\n   129→    const dashboard = db\n   130→      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n   131→      .get(id, tenantId) as DashboardRow | undefined;\n   132→\n   133→    if (!dashboard) {\n   134→      res.status(404).json({ error: 'Dashboard not found' });\n   135→      return;\n   136→    }\n   137→\n   138→    const widgets = db\n   139→      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')\n   140→      .all(id) as Array<{ id: string; dashboard_id: string; type: string; config: string; position_x: number; position_y: number; width: number; height: number }>;\n   141→\n   142→    const result = {\n   143→      ...dashboard,\n   144→      config: JSON.parse(dashboard.config),\n   145→      widgets: widgets.map((w) => ({\n   146→        ...w,\n   147→        config: JSON.parse(w.config),\n   148→      })),\n   149→    };\n   150→\n   151→    res.setHeader('Content-Type', 'application/json');\n   152→    res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${id}.json\"`);\n   153→    res.json(result);\n   154→  });\n   155→\n   156→  // Export dashboard as CSV\n   157→  router.get('/dashboards/:id/csv', authenticate, (req: AuthenticatedRequest, res: Response) => {\n   158→    const tenantId = req.user!.tenantId;\n   159→    const { id } = req.params;\n   160→\n   161→    const dashboard = db\n   162→      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n   163→      .get(id, tenantId) as DashboardRow | undefined;\n   164→\n   165→    if (!dashboard) {\n   166→      res.status(404).json({ error: 'Dashboard not found' });\n   167→      return;\n   168→    }\n   169→\n   170→    const widgets = db\n   171→      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')\n   172→      .all(id) as Array<{ id: string; dashboard_id: string; type: string; config: string; position_x: number; position_y: number; width: number; height: number }>;\n   173→\n   174→    const headers = ['id', 'name', 'owner_id', 'config', 'created_at', 'updated_at', 'widget_count'];\n   175→    const row = [\n   176→      escapeCsvField(dashboard.id),\n   177→      escapeCsvField(dashboard.name),\n   178→      escapeCsvField(dashboard.owner_id),\n   179→      escapeCsvField(dashboard.config),\n   180→      escapeCsvField(dashboard.created_at),\n   181→      escapeCsvField(dashboard.updated_at),\n   182→      String(widgets.length),\n   183→    ];\n   184→\n   185→    let csv = headers.join(',') + '\\n' + row.join(',');\n   186→\n   187→    if (widgets.length > 0) {\n   188→      csv += '\\n\\nwidget_id,type,config,position_x,position_y,width,height';\n   189→      for (const w of widgets) {\n   190→        csv += '\\n' + [\n   191→          escapeCsvField(w.id),\n   192→          escapeCsvField(w.type),\n   193→          escapeCsvField(w.config),\n   194→          String(w.position_x),\n   195→          String(w.position_y),\n   196→          String(w.width),\n   197→          String(w.height),\n   198→        ].join(',');\n   199→      }\n   200→    }\n   201→\n   202→    res.setHeader('Content-Type', 'text/csv');\n   203→    res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${id}.csv\"`);\n   204→    res.send(csv);\n   205→  });\n   206→\n   207→  return router;\n   208→}\n   209→"}]},"parent_tool_use_id":"toolu_01XcmruFniZx6SQXgHqqgeUD","session_id":"3fcfc893-9347-401b-94f4-88670bcb5079","uuid":"a