+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HHZQhnG69zUBjn8wx3eDxo","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import Database from 'better-sqlite3';\n     3→import { v4 as uuidv4 } from 'uuid';\n     4→import { AuthenticatedRequest } from '../types.js';\n     5→import { authenticate } from '../middleware/auth.js';\n     6→\n     7→export function createDashboardRoutes(db: Database.Database): Router {\n     8→  const router = Router();\n     9→\n    10→  // Create dashboard\n    11→  router.post('/', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    12→    const { name, config } = req.body;\n    13→\n    14→    if (!name) {\n    15→      res.status(400).json({ error: 'Dashboard name is required' });\n    16→      return;\n    17→    }\n    18→\n    19→    const id = uuidv4();\n    20→    const tenantId = req.user!.tenantId;\n    21→    const ownerId = req.user!.userId;\n    22→    const dashConfig = config ? JSON.stringify(config) : '{}';\n    23→    const now = new Date().toISOString();\n    24→\n    25→    db.prepare(\n    26→      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'\n    27→    ).run(id, tenantId, name, ownerId, dashConfig, now, now);\n    28→\n    29→    res.status(201).json({\n    30→      id,\n    31→      tenant_id: tenantId,\n    32→      name,\n    33→      owner_id: ownerId,\n    34→      config: JSON.parse(dashConfig),\n    35→      created_at: now,\n    36→      updated_at: now,\n    37→    });\n    38→  });\n    39→\n    40→  // List dashboards for tenant\n    41→  router.get('/', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    42→    const tenantId = req.user!.tenantId;\n    43→\n    44→    const dashboards = db\n    45→      .prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC')\n    46→      .all(tenantId) as Array<{ id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string }>;\n    47→\n    48→    const result = dashboards.map((d) => ({\n    49→      ...d,\n    50→      config: JSON.parse(d.config),\n    51→    }));\n    52→\n    53→    res.json(result);\n    54→  });\n    55→\n    56→  // Get single dashboard\n    57→  router.get('/:id', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    58→    const tenantId = req.user!.tenantId;\n    59→    const { id } = req.params;\n    60→\n    61→    const dashboard = db\n    62→      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n    63→      .get(id, tenantId) as { id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string } | undefined;\n    64→\n    65→    if (!dashboard) {\n    66→      res.status(404).json({ error: 'Dashboard not found' });\n    67→      return;\n    68→    }\n    69→\n    70→    const widgets = db\n    71→      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')\n    72→      .all(id) as Array<{ id: string; dashboard_id: string; type: string; config: string; position_x: number; position_y: number; width: number; height: number }>;\n    73→\n    74→    res.json({\n    75→      ...dashboard,\n    76→      config: JSON.parse(dashboard.config),\n    77→      widgets: widgets.map((w) => ({\n    78→        ...w,\n    79→        config: JSON.parse(w.config),\n    80→      })),\n    81→    });\n    82→  });\n    83→\n    84→  // Update dashboard\n    85→  router.put('/:id', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    86→    const tenantId = req.user!.tenantId;\n    87→    const { id } = req.params;\n    88→    const { name, config } = req.body;\n    89→\n    90→    const existing = db\n    91→      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n    92→      .get(id, tenantId) as { id: string; name: string; config: string } | undefined;\n    93→\n    94→    if (!existing) {\n    95→      res.status(404).json({ error: 'Dashboard not found' });\n    96→      return;\n    97→    }\n    98→\n    99→    const updatedName = name || existing.name;\n   100→    const updatedConfig = config ? JSON.stringify(config) : existing.config;\n   101→    const now = new Date().toISOString();\n   102→\n   103→    db.prepare(\n   104→      'UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?'\n   105→    ).run(updatedName, updatedConfig, now, id);\n   106→\n   107→    res.json({\n   108→      id,\n   109→      tenant_id: tenantId,\n   110→      name: updatedName,\n   111→      config: JSON.parse(updatedConfig),\n   112→      updated_at: now,\n   113→    });\n   114→  });\n   115→\n   116→  // Delete dashboard\n   117→  router.delete('/:id', authenticate, (req: AuthenticatedRequest, res: Response) => {\n   118→    const tenantId = req.user!.tenantId;\n   119→    const { id } = req.params;\n   120→\n   121→    const existing = db\n   122→      .prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?')\n   123→      .get(id, tenantId);\n   124→\n   125→    if (!existing) {\n   126→      res.status(404).json({ error: 'Dashboard not found' });\n   127→      return;\n   128→    }\n   129→\n   130→    db.prepare('DELETE FROM dashboards WHERE id = ?').run(id);\n   131→\n   132→    res.status(204).send();\n   133→  });\n   134→\n   135→  return router;\n   136→}\n   137→"}]},"parent_tool_use_id":"toolu_01XcmruFniZx6SQXgHqqgeUD","session_id":"3fcfc893-9347-401b-94f4-88670bcb5079","uuid":"c62351d7-62f6-40e7-a428-d92cb681a8e6"}
