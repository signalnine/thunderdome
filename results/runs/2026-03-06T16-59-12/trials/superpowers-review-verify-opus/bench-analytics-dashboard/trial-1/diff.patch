().toISOString();\n\n    db.prepare(\n      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'\n    ).run(id, tenantId, name, ownerId, dashConfig, now, now);\n\n    res.status(201).json({\n      id,\n      tenant_id: tenantId,\n      name,\n      owner_id: ownerId,\n      config: JSON.parse(dashConfig),\n      created_at: now,\n      updated_at: now,\n    });\n  });\n\n  // List dashboards for tenant\n  router.get('/', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n\n    const dashboards = db\n      .prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC')\n      .all(tenantId) as Array<{ id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string }>;\n\n    const result = dashboards.map((d) => ({\n      ...d,\n      config: JSON.parse(d.config),\n    }));\n\n    res.json(result);\n  });\n\n  // Get single dashboard\n  router.get('/:id', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { id } = req.params;\n\n    const dashboard = db\n      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n      .get(id, tenantId) as { id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string } | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    const widgets = db\n      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')\n      .all(id) as Array<{ id: string; dashboard_id: string; type: string; config: string; position_x: number; position_y: number; width: number; height: number }>;\n\n    res.json({\n      ...dashboard,\n      config: JSON.parse(dashboard.config),\n      widgets: widgets.map((w) => ({\n        ...w,\n        config: JSON.parse(w.config),\n      })),\n    });\n  });\n\n  // Update dashboard\n  router.put('/:id', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { id } = req.params;\n    const { name, config } = req.body;\n\n    const existing = db\n      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n      .get(id, tenantId) as { id: string; name: string; config: string } | undefined;\n\n    if (!existing) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    const updatedName = name || existing.name;\n    const updatedConfig = config ? JSON.stringify(config) : existing.config;\n    const now = new Date().toISOString();\n\n    db.prepare(\n      'UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?'\n    ).run(updatedName, updatedConfig, now, id);\n\n    res.json({\n      id,\n      tenant_id: tenantId,\n      name: updatedName,\n      config: JSON.parse(updatedConfig),\n      updated_at: now,\n    });\n  });\n\n  // Delete dashboard\n  router.delete('/:id', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const tenantId = req.user!.tenantId;\n    const { id } = req.params;\n\n    const existing = db\n      .prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?')\n      .get(id, tenantId);\n\n    if (!existing) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    db.prepare('DELETE FROM dashboards WHERE id = ?').run(id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":4,"oldLines":6,"newStart":4,"newLines":14,"lines":[" import { AuthenticatedRequest } from '../types.js';"," import { authenticate } from '../middleware/auth.js';"," ","+function safeJsonParse(str: string, fallback: unknown = {}): unknown {","+  try {","+    return JSON.parse(str);","+  } catch {","+    return fallback;","+  }","+}","+"," export function createDashboardRoutes(d