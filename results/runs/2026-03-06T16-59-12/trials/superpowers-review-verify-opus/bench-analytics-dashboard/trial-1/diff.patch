+    app = createApp(':memory:');
+  });
+
+  describe('Health check', () => {
+    it('should return ok', async () => {
+      const res = await request(app).get('/api/health');
+      expect(res.status).toBe(200);
+      expect(res.body).toEqual({ status: 'ok' });
+    });
+  });
+
+  describe('User Management', () => {
+    it('should register first user in tenant as admin', async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'test@example.com', password: 'pass123', tenant_id: 'tenant1' });
+      expect(res.status).toBe(201);
+      expect(res.body.email).toBe('test@example.com');
+      expect(res.body.tenant_id).toBe('tenant1');
+      expect(res.body.token).toBeDefined();
+      expect(res.body.role).toBe('admin');
+    });
+
+    it('should register subsequent users as viewer by default', async () => {
+      await request(app)
+        .post('/api/users/register')
+        .send({ email: 'first@example.com', password: 'pass123', tenant_id: 'tenant1' });
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'second@example.com', password: 'pass123', tenant_id: 'tenant1' });
+      expect(res.status).toBe(201);
+      expect(res.body.role).toBe('viewer');
+    });
+
+    it('should reject duplicate email', async () => {
+      await request(app)
+        .post('/api/users/register')
+        .send({ email: 'dup@example.com', password: 'pass123', tenant_id: 'tenant1' });
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'dup@example.com', password: 'pass456', tenant_id: 'tenant1' });
+      expect(res.status).toBe(409);
+    });
+
+    it('should login and return token', async () => {
+      await request(app)
+        .post('/api/users/register')
+        .send({ email: 'user@example.com', password: 'pass123', tenant_id: 'tenant1' });
+      const res = await request(app)
+        .post('/api/users/login')
+        .send({ email: 'user@example.com', password: 'pass123' });
+      expect(res.status).toBe(200);
+      expect(res.body.token).toBeDefined();
+    });
+
+    it('should reject wrong password', async () => {
+      await request(app)
+        .post('/api/users/register')
+        .send({ email: 'user2@example.com', password: 'pass123', tenant_id: 'tenant1' });
+      const res = await request(app)
+        .post('/api/users/login')
+        .send({ email: 'user2@example.com', password: 'wrong' });
+      expect(res.status).toBe(401);
+    });
+
+    it('should get user profile', async () => {
+      const reg = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'me@example.com', password: 'pass123', tenant_id: 'tenant1' });
+      const res = await request(app)
+        .get('/api/users/me')
+        .set('Authorization', `Bearer ${reg.body.token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.email).toBe('me@example.com');
+    });
+
+    it('should return 401 for unauthenticated profile request', async () => {
+      const res = await request(app).get('/api/users/me');
+      expect(res.status).toBe(401);
+    });
+
+    it('should allow admin to change role', async () => {
