tenant_id = ?';\n    const params: unknown[] = [tenantId];\n\n    if (event_name) {\n      sql += ' AND name = ?';\n      params.push(event_name);\n    }\n\n    if (start_date) {\n      sql += ' AND timestamp >= ?';\n      params.push(start_date);\n    }\n\n    if (end_date) {\n      sql += ' AND timestamp <= ?';\n      params.push(end_date);\n    }\n\n    if (filters && typeof filters === 'object') {\n      for (const [key, value] of Object.entries(filters)) {\n        sql += ` AND json_extract(properties, ?) = ?`;\n        params.push(`$.${key}`, value);\n      }\n    }\n\n    const result = db.prepare(sql).get(...params) as { count: number };\n    res.json({ count: result.count });\n  });\n\n  // Timeseries query\n  router.post('/timeseries', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const { event_name, start_date, end_date, interval, filters } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    // Default interval is 'day'\n    const bucketInterval = interval || 'day';\n\n    let dateFormat: string;\n    switch (bucketInterval) {\n      case 'hour':\n        dateFormat = '%Y-%m-%dT%H:00:00';\n        break;\n      case 'month':\n        dateFormat = '%Y-%m-01';\n        break;\n      case 'day':\n      default:\n        dateFormat = '%Y-%m-%d';\n        break;\n    }\n\n    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [tenantId];\n\n    if (event_name) {\n      sql += ' AND name = ?';\n      params.push(event_name);\n    }\n\n    if (start_date) {\n      sql += ' AND timestamp >= ?';\n      params.push(start_date);\n    }\n\n    if (end_date) {\n      sql += ' AND timestamp <= ?';\n      params.push(end_date);\n    }\n\n    if (filters && typeof filters === 'object') {\n      for (const [key, value] of Object.entries(filters)) {\n        sql += ` AND json_extract(properties, ?) = ?`;\n        params.push(`$.${key}`, value);\n      }\n    }\n\n    sql += ' GROUP BY bucket ORDER BY bucket ASC';\n\n    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;\n    res.json({ interval: bucketInterval, data: results });\n  });\n\n  // Breakdown query\n  router.post('/breakdown', authenticate, (req: AuthenticatedRequest, res: Response) => {\n    const { event_name, property, start_date, end_date, filters } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    if (!property) {\n      res.status(400).json({ error: 'property is required for breakdown queries' });\n      return;\n    }\n\n    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: unknown[] = [`$.${property}`, tenantId];\n\n    if (event_name) {\n      sql += ' AND name = ?';\n      params.push(event_name);\n    }\n\n    if (start_date) {\n      sql += ' AND timestamp >= ?';\n      params.push(start_date);\n    }\n\n    if (end_date) {\n      sql += ' AND timestamp <= ?';\n      params.push(end_date);\n    }\n\n    if (filters && typeof filters === 'object') {\n      for (const [key, value] of Object.entries(filters)) {\n        sql += ` AND json_extract(properties, ?) = ?`;\n        params.push(`$.${key}`, value);\n      }\n    }\n\n    sql += ' GROUP BY value ORDER BY count DESC';\n\n    const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;\n    res.json({ property, data: results });\n  });\n\n  return router;\n}\n","numLines":139,"startLine":1,"totalLines":139}}}
