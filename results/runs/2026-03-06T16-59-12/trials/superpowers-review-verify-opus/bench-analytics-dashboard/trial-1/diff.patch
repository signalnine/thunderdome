 });\n    87→\n    88→    it('should allow admin to change role', async () => {\n    89→      const admin = await request(app)\n    90→        .post('/api/users/register')\n    91→        .send({ email: 'adm@example.com', password: 'pass', tenant_id: 't1', role: 'admin' });\n    92→      const user = await request(app)\n    93→        .post('/api/users/register')\n    94→        .send({ email: 'usr@example.com', password: 'pass', tenant_id: 't1' });\n    95→\n    96→      const res = await request(app)\n    97→        .patch(`/api/users/${user.body.id}/role`)\n    98→        .set('Authorization', `Bearer ${admin.body.token}`)\n    99→        .send({ role: 'editor' });\n   100→      expect(res.status).toBe(200);\n   101→      expect(res.body.role).toBe('editor');\n   102→    });\n   103→\n   104→    it('should reject non-admin role change', async () => {\n   105→      const viewer = await request(app)\n   106→        .post('/api/users/register')\n   107→        .send({ email: 'v@example.com', password: 'pass', tenant_id: 't1' });\n   108→      const user = await request(app)\n   109→        .post('/api/users/register')\n   110→        .send({ email: 'u@example.com', password: 'pass', tenant_id: 't1' });\n   111→\n   112→      const res = await request(app)\n   113→        .patch(`/api/users/${user.body.id}/role`)\n   114→        .set('Authorization', `Bearer ${viewer.body.token}`)\n   115→        .send({ role: 'editor' });\n   116→      expect(res.status).toBe(403);\n   117→    });\n   118→  });\n   119→\n   120→  describe('Event Ingestion', () => {\n   121→    let token: string;\n   122→\n   123→    beforeEach(async () => {\n   124→      const reg = await request(app)\n   125→        .post('/api/users/register')\n   126→        .send({ email: 'ev@example.com', password: 'pass', tenant_id: 't1' });\n   127→      token = reg.body.token;\n   128→    });\n   129→\n   130→    it('should ingest a single event', async () => {\n   131→      const res = await request(app)\n 