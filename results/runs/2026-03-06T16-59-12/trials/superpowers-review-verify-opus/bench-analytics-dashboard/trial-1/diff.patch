+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GrtJjw6hqeZHqyoKzCxuAm","type":"tool_result","content":"     1→import { Response, NextFunction } from 'express';\n     2→import jwt from 'jsonwebtoken';\n     3→import { AuthenticatedRequest, AuthPayload } from '../types.js';\n     4→\n     5→const JWT_SECRET = process.env.JWT_SECRET || 'analytics-dashboard-secret';\n     6→\n     7→export function generateToken(payload: AuthPayload): string {\n     8→  return jwt.sign(payload, JWT_SECRET, { expiresIn: '24h' });\n     9→}\n    10→\n    11→export function authenticate(\n    12→  req: AuthenticatedRequest,\n    13→  res: Response,\n    14→  next: NextFunction\n    15→): void {\n    16→  const authHeader = req.headers.authorization;\n    17→  if (!authHeader || !authHeader.startsWith('Bearer ')) {\n    18→    res.status(401).json({ error: 'Authentication required' });\n    19→    return;\n    20→  }\n    21→\n    22→  const token = authHeader.slice(7);\n    23→  try {\n    24→    const decoded = jwt.verify(token, JWT_SECRET) as AuthPayload;\n    25→    req.user = decoded;\n    26→    next();\n    27→  } catch {\n    28→    res.status(401).json({ error: 'Invalid or expired token' });\n    29→  }\n    30→}\n    31→\n    32→export function requireRole(...roles: string[]) {\n    33→  return (req: AuthenticatedRequest, res: Response, next: NextFunction): void => {\n    34→    if (!req.user) {\n    35→      res.status(401).json({ error: 'Authentication required' });\n    36→      return;\n    37→    }\n    38→    if (!roles.includes(req.user.role)) {\n    39→      res.status(403).json({ error: 'Insufficient permissions' });\n    40→      return;\n    41→    }\n    42→    next();\n    43→  };\n    44→}\n    45→"}]},"parent_tool_use_id":"toolu_01XcmruFniZx6SQXgHqqgeUD","session_id":"3fcfc893-9347-401b-94f4-88670bcb5079","uuid":"65997d0d-36ef-48a3-826a-a3cbed1498fd"}
