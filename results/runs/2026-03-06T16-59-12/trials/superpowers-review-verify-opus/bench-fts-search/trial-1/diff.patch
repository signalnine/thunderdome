+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MxTPxvxDEtUyinx5pr7gT7","type":"tool_result","content":"     1→import { Router, Request, Response, NextFunction } from 'express';\n     2→import Database from 'better-sqlite3';\n     3→import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\n     4→import { NotFoundError, ValidationError } from './errors.js';\n     5→\n     6→function sanitizeFtsQuery(query: string): string {\n     7→  // If the query contains a quoted phrase, preserve it\n     8→  if (query.includes('\"')) {\n     9→    // Extract quoted parts and non-quoted parts\n    10→    const parts: string[] = [];\n    11→    const remaining = query;\n    12→    const quoteRegex = /\"([^\"]*)\"/g;\n    13→    let match;\n    14→    let lastIndex = 0;\n    15→\n    16→    while ((match = quoteRegex.exec(remaining)) !== null) {\n    17→      // Process text before the quote\n    18→      const before = remaining.substring(lastIndex, match.index).trim();\n    19→      if (before) {\n    20→        parts.push(sanitizePlainTerms(before));\n    21→      }\n    22→      // Add the quoted phrase as-is\n    23→      parts.push(`\"${match[1]}\"`);\n    24→      lastIndex = match.index + match[0].length;\n    25→    }\n    26→\n    27→    // Process remaining text after last quote\n    28→    const after = remaining.substring(lastIndex).trim();\n    29→    if (after) {\n    30→      parts.push(sanitizePlainTerms(after));\n    31→    }\n    32→\n    33→    return parts.join(' ');\n    34→  }\n    35→\n    36→  return sanitizePlainTerms(query);\n    37→}\n    38→\n    39→function sanitizePlainTerms(text: string): string {\n    40→  // Remove FTS5 special characters and operators\n    41→  // Keep alphanumeric, spaces, and basic punctuation\n    42→  return text\n    43→    .replace(/[*+\\-<>(){}[\\]^~:@!/\\\\]/g, ' ')\n    44→    .replace(/\\s+/g, ' ')\n    45→    .trim();\n    46→}\n    47→\n    48→export function createRoutes(db: Database.Database): Router {\n    49→  const router = Router();\n    50→\n    51→  // GET /notes/search - Full-text search\n    52→  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    53→    try {\n    54→      const q = req.query.q as string | undefined;\n    55→      if (!q || q.trim() === '') {\n    56→        throw new ValidationError('Search query is required');\n    57→      }\n    58→\n    59→      const page = Math.max(1, parseInt(req.query.page as string) || 1);\n    60→      const perPage = 20;\n    61→      const offset = (page - 1) * perPage;\n    62→\n    63→      // Sanitize query for FTS5: remove characters that are FTS5 operators\n    64→      // but preserve quoted phrases\n    65→      const sanitized = sanitizeFtsQuery(q);\n    66→\n    67→      // Count total results\n    68→      const countStmt = db.prepare(`\n    69→        SELECT COUNT(*) as total\n    70→        FROM notes_fts\n    71→        WHERE notes_fts MATCH ?\n    72→      `);\n    73→\n    74→      let total = 0;\n    75→      let results: SearchResult[] = [];\n    76→\n    77→      try {\n    78→        total = (countStmt.get(sanitized) as { total: number }).total;\n    79→\n    80→        // Search with BM25 ranking and snippet highlighting\n    81→        const searchStmt = db.prepare(`\n    82→          SELECT\n    83→            notes.id,\n    84→            notes.title,\n    85→            snippet(notes_fts, 1, '<mark>', '</mark>', '...', 32) as snippet,\n    86→            bm25(notes_fts) as rank\n    87→          FROM notes_fts\n    88→          JOIN notes ON notes.id = notes_fts.rowid\n    89→          WHERE notes_fts MATCH ?\n    90→          ORDER BY bm25(notes_fts)\n    91→          LIMIT ? OFFSET ?\n    92→        `);\n    93→\n    94→        results = searchStmt.all(sanitized, perPage, offset) as SearchResult[];\n    95→      } catch {\n    96→        // If the FTS query is invalid, return empty results\n    97→        total = 0;\n    98→        results = [];\n    99→      }\n   100→\n   101→      res.json({ results, total, page, perPage });\n   102→    } catch (err) {\n   103→      next(err);\n   104→    }\n   105→  });\n   106→\n   107→  // GET /notes/search/suggest - Autocomplete suggestions\n   108→  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n   109→    try {\n   110→      const q = req.query.q as string | undefined;\n   111→      if (!q || q.trim() === '') {\n   112→        throw new ValidationError('Search query is required');\n   113→      }\n   114→\n   115→      // Use prefix query for autocomplete\n   116→      const sanitized = sanitizeFtsQuery(q.trim());\n   117→      const prefixQuery = sanitized + '*';\n   118→\n   119→      let results: SuggestResult[] = [];\n   120→      try {\n   121→        const suggestStmt = db.prepare(`\n   122→          SELECT notes.id, notes.title\n   123→          FROM notes_fts\n   124→          JOIN notes ON notes.id = notes_fts.rowid\n   125→          WHERE notes_fts MATCH ?\n   126→          ORDER BY bm25(notes_fts)\n   127→          LIMIT 5\n   128→        `);\n   129→        results = suggestStmt.all(prefixQuery) as SuggestResult[];\n   130→      } catch {\n   131→        results = [];\n   132→      }\n   133→\n   134→      res.json({ results });\n   135→    } catch (err) {\n   136→      next(err);\n   137→    }\n   138→  });\n   139→\n   140→  // GET /notes - List all notes (with optional tag filter)\n   141→  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n   142→    try {\n   143→      const tag = req.query.tag as string | undefined;\n   144→\n   145→      let notes: Note[];\n   146→      if (tag) {\n   147→        // Use a join with json_each for tag filtering\n   148→        const tagStmt = db.prepare(`\n   149→          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n   150→          WHERE json_each.value = ?\n   151→          ORDER BY created_at DESC\n   152→        `);\n   153→        notes = tagStmt.all(tag) as Note[];\n   154→      } else {\n   155→        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n   156→        notes = stmt.all() as Note[];\n   157→      }\n   158→\n   159→      res.json({ notes });\n   160→    } catch (err) {\n   161→      next(err);\n   162→    }\n   163→  });\n   164→\n   165→  // GET /notes/:id - Get single note\n   166→  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   167→    try {\n   168→      const id = parseInt(req.params.id);\n   169→      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n   170→      const note = stmt.get(id) as Note | undefined;\n   171→\n   172→      if (!note) {\n   173→        throw new NotFoundError('Note not found');\n   174→      }\n   175→\n   176→      res.json({ note });\n   177→    } catch (err) {\n   178→      next(err);\n   179→    }\n   180→  });\n   181→\n   182→  // POST /notes - Create note\n   183→  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n   184→    try {\n   185→      const input = req.body as NoteInput;\n   186→\n   187→      if (!input.title || input.title.trim() === '') {\n   188→        throw new ValidationError('Title is required');\n   189→      }\n   190→      if (!input.body || input.body.trim() === '') {\n   191→        throw new ValidationError('Body is required');\n   192→      }\n   193→\n   194→      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n   195→      const stmt = db.prepare(`\n   196→        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n   197→      `);\n   198→      const result = stmt.run(input.title, input.body, tags);\n   199→\n   200→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n   201→      res.status(201).json({ note });\n   202→    } catch (err) {\n   203→      next(err);\n   204→    }\n   205→  });\n   206→\n   207→  // PUT /notes/:id - Update note\n   208→  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   209→    try {\n   210→      const id = parseInt(req.params.id);\n   211→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   212→\n   213→      if (!existing) {\n   214→        throw new NotFoundError('Note not found');\n   215→      }\n   216→\n   217→      const input = req.body as Partial<NoteInput>;\n   218→      const title = input.title ?? existing.title;\n   219→      const body = input.body ?? existing.body;\n   220→      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n   221→\n   222→      const stmt = db.prepare(`\n   223→        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n   224→        WHERE id = ?\n   225→      `);\n   226→      stmt.run(title, body, tags, id);\n   227→\n   228→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n   229→      res.json({ note });\n   230→    } catch (err) {\n   231→      next(err);\n   232→    }\n   233→  });\n   234→\n   235→  // DELETE /notes/:id - Delete note\n   236→  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   237→    try {\n   238→      const id = parseInt(req.params.id);\n   239→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   240→\n   241→      if (!existing) {\n   242→        throw new NotFoundError('Note not found');\n   243→      }\n   244→\n   245→      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n   246→      res.status(204).send();\n   247→    } catch (err) {\n   248→      next(err);\n   249→    }\n   250→  });\n   251→\n   252→  return router;\n   253→}\n   254→"}]},"parent_tool_use_id":"toolu_018XL6WPfPMhVktYEhZaQccd","session_id":"dd759fa8-2b0a-48dd-b8de-444b3369a0bd","uuid":"5604a94b-a6e5-47f1-a553-8c8304e6c8b3"}
