  expect(res.status).toBe(200);\n    50→    expect(res.body.users).toHaveLength(1);\n    51→  });\n    52→\n    53→  it('gets user by id', async () => {\n    54→    const createRes = await request(app)\n    55→      .post('/users')\n    56→      .set('x-user-role', 'admin')\n    57→      .send({ name: 'Bob', email: 'bob@test.com', role: 'user' });\n    58→\n    59→    const res = await request(app)\n    60→      .get(`/users/${createRes.body.user.id}`)\n    61→      .set('x-user-role', 'admin');\n    62→    expect(res.status).toBe(200);\n    63→    expect(res.body.user.name).toBe('Bob');\n    64→  });\n    65→\n    66→  it('returns 404 for nonexistent user', async () => {\n    67→    const res = await request(app)\n    68→      .get('/users/999')\n    69→      .set('x-user-role', 'admin');\n    70→    expect(res.status).toBe(404);\n    71→  });\n    72→\n    73→  it('returns 400 for invalid user id', async () => {\n    74→    const res = await request(app)\n    75→      .get('/users/abc')\n    76→      .set('x-user-role', 'admin');\n    77→    expect(res.status).toBe(400);\n    78→  });\n    79→\n    80→  it('returns 409 for duplicate email', async () => {\n    81→    await request(app)\n    82→      .post('/users')\n    83→      .set('x-user-role', 'admin')\n    84→      .send({ name: 'First', email: 'dup@test.com', role: 'user' });\n    85→\n    86→    const res = await request(app)\n    87→      .post('/users')\n    88→      .set('x-user-role', 'admin')\n    89→      .send({ name: 'Second', email: 'dup@test.com', role: 'user' });\n    90→    expect(res.status).toBe(409);\n    91→  });\n    92→});\n    93→"}]},"parent_tool_use_id":"toolu_01QSwWK3ZN5t78H7jvuwthnQ","session_id":"e1a17e76-b4a0-403e-bbcf-50b1d69db88d","uuid":"08402423-2347-4692-8ee3-9f720e5c33fc"}
