ue);\n    51→  });\n    52→\n    53→  it('rejects invalid token', async () => {\n    54→    const res = await request(app)\n    55→      .get('/auth/verify')\n    56→      .set('Authorization', 'Bearer bad-token');\n    57→    expect(res.status).toBe(401);\n    58→  });\n    59→\n    60→  it('rejects request without token', async () => {\n    61→    const res = await request(app).get('/auth/verify');\n    62→    expect(res.status).toBe(401);\n    63→  });\n    64→});\n    65→"}]},"parent_tool_use_id":"toolu_01AS9M4FmgoEF2QxPxaupaXu","session_id":"e1a17e76-b4a0-403e-bbcf-50b1d69db88d","uuid":"acc6d9d0-9c03-4abe-a2e5-a12515c02b97"}
