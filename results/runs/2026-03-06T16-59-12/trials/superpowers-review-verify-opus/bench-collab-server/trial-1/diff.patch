+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, validate, inputLength, outputLength, Operation } from '../src/ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply a retain operation', () => {
+      expect(apply('hello', [{ retain: 5 }])).toBe('hello');
+    });
+
+    it('should apply an insert operation', () => {
+      expect(apply('', [{ insert: 'hello' }])).toBe('hello');
+    });
+
+    it('should apply a delete operation', () => {
+      expect(apply('hello', [{ delete: 5 }])).toBe('');
+    });
+
+    it('should apply a combined operation', () => {
+      // Insert "X" at position 2 in "hello"
+      const op: Operation = [{ retain: 2 }, { insert: 'X' }, { retain: 3 }];
+      expect(apply('hello', op)).toBe('heXllo');
+    });
+
+    it('should delete characters in the middle', () => {
+      const op: Operation = [{ retain: 1 }, { delete: 3 }, { retain: 1 }];
+      expect(apply('hello', op)).toBe('ho');
+    });
+
+    it('should throw if input length does not match document', () => {
+      expect(() => apply('hello', [{ retain: 3 }])).toThrow();
+    });
+  });
+
+  describe('inputLength / outputLength', () => {
+    it('should compute input length', () => {
+      const op: Operation = [{ retain: 3 }, { insert: 'abc' }, { delete: 2 }];
+      expect(inputLength(op)).toBe(5); // 3 retain + 2 delete
+    });
+
+    it('should compute output length', () => {
+      const op: Operation = [{ retain: 3 }, { insert: 'abc' }, { delete: 2 }];
+      expect(outputLength(op)).toBe(6); // 3 retain + 3 insert
+    });
+  });
+
+  describe('transform', () => {
+    it('should transform two inserts at different positions', () => {
+      const doc = 'abc';
+      // op1: insert X at position 1 => "aXbc"
+      const op1: Operation = [{ retain: 1 }, { insert: 'X' }, { retain: 2 }];
+      // op2: insert Y at position 2 => "abYc"
+      const op2: Operation = [{ retain: 2 }, { insert: 'Y' }, { retain: 1 }];
+
+      const [op1p, op2p] = transform(op1, op2);
+
+      // Apply op1 then op2' should equal apply op2 then op1'
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+      expect(result1).toBe('aXbYc');
+    });
+
+    it('should transform two inserts at the same position (op1 wins)', () => {
+      const doc = 'abc';
+      const op1: Operation = [{ retain: 1 }, { insert: 'X' }, { retain: 2 }];
+      const op2: Operation = [{ retain: 1 }, { insert: 'Y' }, { retain: 2 }];
+
+      const [op1p, op2p] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+      // op1 has priority, so X comes before Y
+      expect(result1).toBe('aXYbc');
+    });
+
+    it('should transform insert vs delete', () => {
+      const doc = 'abcde';
+      // op1: insert X at position 2
+      const op1: Operation = [{ retain: 2 }, { insert: 'X' }, { retain: 3 }];
+      // op2: delete char at position 1 (delete 'b')
+      const op2: Operation = [{ retain: 1 }, { delete: 1 }, { retain: 3 }];
+
+      const [op1p, op2p] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+      expect(result1).toBe('aXcde');
+    });
+
+    it('should transform two deletes at the same position', () => {
+      const doc = 'abcde';
+      const op1: Operation = [{ retain: 1 }, { delete: 1 }, { retain: 3 }];
+      const op2: Operation = [{ retain: 1 }, { delete: 1 }, { retain: 3 }];
+
+      const [op1p, op2p] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2p);
+      const result2 = apply(apply(doc, op2), op1p);
+      expect(result1).toBe(result2);
+      expect(result1).toBe('acde');
+    });
+
+    it('should handle empty operations on empty document', () => {
+      const [op1p, op2p] = transform([], []);
+      expect(op1p).toEqual([]);
+      expect(op2p).toEqual([]);
+    });
+
+    it('should throw for mismatched input lengths', () => {
+      const op1: Operation = [{ retain: 3 }];
+      const op2: Operation = [{ retain: 5 }];
+      expect(() => transform(op1, op2)).toThrow();
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two sequential operations', () => {
+      const doc = 'hello';
+      const op1: Operation = [{ retain: 5 }, { insert: ' world' }];
+      const op2: Operation = [{ retain: 11 }, { insert: '!' }];
+
+      const composed = compose(op1, op2);
+      expect(apply(doc, composed)).toBe('hello world!');
+      expect(apply(apply(doc, op1), op2)).toBe('hello world!');
+    });
+  });
+
+  describe('validate', () => {
+    it('should accept valid operations', () => {
+      expect(validate([{ retain: 5 }])).toBeNull();
+      expect(validate([{ insert: 'hello' }])).toBeNull();
+      expect(validate([{ delete: 3 }])).toBeNull();
+      expect(validate([{ retain: 2 }, { insert: 'x' }, { delete: 1 }])).toBeNull();
+    });
+
+    it('should reject non-array input', () => {
+      expect(validate('hello' as unknown as Operation)).toBe('Operation must be an array');
+    });
+
+    it('should reject retain with non-positive value', () => {
+      expect(validate([{ retain: 0 }])).toContain('positive integer');
+      expect(validate([{ retain: -1 }])).toContain('positive integer');
+    });
+
+    it('should reject empty insert', () => {
+      expect(validate([{ insert: '' }])).toContain('non-empty string');
+    });
+
+    it('should reject delete with non-positive value', () => {
+      expect(validate([{ delete: 0 }])).toContain('positive integer');
+    });
+  });
+});
