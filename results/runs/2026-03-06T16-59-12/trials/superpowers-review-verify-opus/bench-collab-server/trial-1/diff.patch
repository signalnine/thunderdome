ocument(id: string): boolean {\n    const result = this.stmts.delete.run(id);\n    return result.changes > 0;\n  }\n\n  getVersionHistory(documentId: string): VersionRow[] {\n    return this.stmts.getVersions.all(documentId) as VersionRow[];\n  }\n\n  getVersion(documentId: string, version: number): VersionRow | undefined {\n    return this.stmts.getVersion.get(documentId, version) as VersionRow | undefined;\n  }\n\n  getOperationsFrom(documentId: string, fromVersion: number): { operations: string; version: number }[] {\n    return this.stmts.getOpsFrom.all(documentId, fromVersion) as { operations: string; version: number }[];\n  }\n\n  close(): void {\n    this.db.close();\n  }\n}\n","structuredPatch":[{"oldStart":40,"oldLines":7,"newStart":40,"newLines":8,"lines":["       content TEXT NOT NULL,","       operations TEXT NOT NULL DEFAULT '[]',","       created_at TEXT NOT NULL DEFAULT (datetime('now')),","-      FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE","+      FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE,","+      UNIQUE(document_id, version)","     );"," ","     CREATE INDEX IF NOT EXISTS idx_versions_doc_version"]},{"oldStart":62,"oldLines":8,"newStart":63,"newLines":17,"lines":["     insertVersion: Database.Statement;","     getVersions: Database.Statement;","     getVersion: Database.Statement;","+    getOpsFrom: Database.Statement;","   };"," ","+  private createDocumentTxn: Database.Transaction<","+    (id: string, title: string, content: string) => DocumentRow","+  >;","+","+  private updateContentTxn: Database.Transaction<","+    (id: string, content: string, version: number, operations: string) => DocumentRow","+  >;","+","   constructor(db: Database.Database) {","     this.db = db;","     this.stmts = {"]},{"oldStart":88,"oldLines":14,"newStart":98,"newLines":30,"lines":["       getVersion: db.prepare(","         `SELECT * FROM versions WHERE document_id = ? AND version = ?`","       ),","+      getOpsFr