@@ -0,0 +1,73 @@
+import express from 'express';
+import http from 'http';
+import { WebSocketServer } from 'ws';
+import { createDatabase, DocumentStore } from './database.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath || ':memory:');
+  const store = new DocumentStore(db);
+  const app = express();
+
+  app.use(express.json());
+
+  const server = http.createServer(app);
+  const wss = new WebSocketServer({ server });
+  const collab = new CollaborationServer(wss, store);
+
+  // Pass collab to router so DELETE can evict WebSocket sessions
+  app.use('/api', createRouter(store, collab));
+
+  let started = false;
+
+  return {
+    app,
+    async start(port?: number): Promise<number> {
+      if (started) {
+        const addr = server.address();
+        if (addr && typeof addr === 'object') return addr.port;
+        return 0;
+      }
+      return new Promise((resolve, reject) => {
+        server.listen(port ?? 0, () => {
+          started = true;
+          const addr = server.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Failed to get server address'));
+          }
+        });
+        server.on('error', reject);
+      });
+    },
+    async stop(): Promise<void> {
+      // Close WebSocket connections first
+      collab.closeAll();
+      wss.close();
+
+      // Then close HTTP server so in-flight requests complete
+      await new Promise<void>((resolve, reject) => {
+        if (!started) {
+          resolve();
+          return;
+        }
+        server.close((err) => {
+          started = false;
+          if (err) reject(err);
+          else resolve();
+        });
+      });
+
+      // Close DB last, after all connections are shut down
+      store.close();
+    },
+  };
+}
