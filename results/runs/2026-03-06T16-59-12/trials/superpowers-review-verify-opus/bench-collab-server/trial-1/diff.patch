+++ b/src/ot.ts
@@ -0,0 +1,285 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are represented as a sequence of components:
+ * - { retain: n }  -- skip n characters
+ * - { insert: s }  -- insert string s at current position
+ * - { delete: n }  -- delete n characters at current position
+ *
+ * The key function is `transform(op1, op2)` which takes two concurrent
+ * operations (both based on the same document state) and returns
+ * [op1', op2'] such that applying op1 then op2' yields the same
+ * document as applying op2 then op1'.
+ */
+
+export type OpComponent =
+  | { retain: number }
+  | { insert: string }
+  | { delete: number };
+
+export type Operation = OpComponent[];
+
+function isRetain(c: OpComponent): c is { retain: number } {
+  return 'retain' in c;
+}
+
+function isInsert(c: OpComponent): c is { insert: string } {
+  return 'insert' in c;
+}
+
+function isDelete(c: OpComponent): c is { delete: number } {
+  return 'delete' in c;
+}
+
+/** Compute the input length an operation expects. */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (isRetain(c)) len += c.retain;
+    else if (isDelete(c)) len += c.delete;
+  }
+  return len;
+}
+
+/** Compute the output length after applying an operation. */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (isRetain(c)) len += c.retain;
+    else if (isInsert(c)) len += c.insert.length;
+  }
+  return len;
+}
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, op: Operation): string {
+  const inLen = inputLength(op);
+  if (inLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${inLen}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (isRetain(c)) {
+      result += doc.slice(pos, pos + c.retain);
+      pos += c.retain;
+    } else if (isInsert(c)) {
+      result += c.insert;
+    } else if (isDelete(c)) {
+      pos += c.delete;
+    }
+  }
+
+  return result;
+}
+
+/** Compose two consecutive operations into one. */
+export function compose(op1: Operation, op2: Operation): Operation {
+  if (outputLength(op1) !== inputLength(op2)) {
+    throw new Error('Compose: op1 output length must equal op2 input length');
+  }
+
+  const result: Operation = [];
+  let i1 = 0;
+  let i2 = 0;
+  let c1: OpComponent | undefined = op1[i1];
+  let c2: OpComponent | undefined = op2[i2];
+
+  function push(c: OpComponent) {
+    if (isRetain(c) && c.retain === 0) return;
+    if (isDelete(c) && c.delete === 0) return;
+    if (isInsert(c) && c.insert === '') return;
+
+    const last = result[result.length - 1];
+    if (last) {
+      if (isRetain(last) && isRetain(c)) {
+        result[result.length - 1] = { retain: last.retain + c.retain };
+        return;
+      }
+      if (isInsert(last) && isInsert(c)) {
+        result[result.length - 1] = { insert: last.insert + c.insert };
+        return;
+      }
+      if (isDelete(last) && isDelete(c)) {
+        result[result.length - 1] = { delete: last.delete + c.delete };
+        return;
+      }
+    }
+    result.push(c);
+  }
+
+  while (c1 !== undefined || c2 !== undefined) {
+    if (c1 !== undefined && isDelete(c1)) {
+      push(c1);
+      i1++;
+      c1 = op1[i1];
+      continue;
+    }
+    if (c2 !== undefined && isInsert(c2)) {
+      push(c2);
+      i2++;
+      c2 = op2[i2];
+      continue;
+    }
+
+    if (c1 === undefined || c2 === undefined) {
+      throw new Error('Compose: unexpected end of operation');
+    }
+
+    if (isRetain(c1) && isRetain(c2)) {
+      const min = Math.min(c1.retain, c2.retain);
+      push({ retain: min });
+      if (c1.retain === min) { i1++; c1 = op1[i1]; } else { c1 = { retain: c1.retain - min }; }
+      if (c2.retain === min) { i2++; c2 = op2[i2]; } else { c2 = { retain: c2.retain - min }; }
+    } else if (isInsert(c1) && isDelete(c2)) {
+      const min = Math.min(c1.insert.length, c2.delete);
+      if (c1.insert.length === min) { i1++; c1 = op1[i1]; } else { c1 = { insert: c1.insert.slice(min) }; }
+      if (c2.delete === min) { i2++; c2 = op2[i2]; } else { c2 = { delete: c2.delete - min }; }
+    } else if (isInsert(c1) && isRetain(c2)) {
+      const min = Math.min(c1.insert.length, c2.retain);
+      push({ insert: c1.insert.slice(0, min) });
+      if (c1.insert.length === min) { i1++; c1 = op1[i1]; } else { c1 = { insert: c1.insert.slice(min) }; }
+      if (c2.retain === min) { i2++; c2 = op2[i2]; } else { c2 = { retain: c2.retain - min }; }
+    } else if (isRetain(c1) && isDelete(c2)) {
+      const min = Math.min(c1.retain, c2.delete);
+      push({ delete: min });
+      if (c1.retain === min) { i1++; c1 = op1[i1]; } else { c1 = { retain: c1.retain - min }; }
+      if (c2.delete === min) { i2++; c2 = op2[i2]; } else { c2 = { delete: c2.delete - min }; }
+    } else {
+      throw new Error('Compose: unexpected component combination');
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations.
+ *
+ * Given op1 and op2 both based on the same document state, returns [op1', op2']
+ * such that: apply(apply(doc, op1), op2') === apply(apply(doc, op2), op1')
+ *
+ * op1 is given priority for tie-breaking (e.g., simultaneous inserts at the
+ * same position: op1's insert comes first).
+ */
+export function transform(
+  op1: Operation,
+  op2: Operation
+): [Operation, Operation] {
+  if (inputLength(op1) !== inputLength(op2)) {
+    throw new Error(
+      `Transform: operations have different input lengths (${inputLength(op1)} vs ${inputLength(op2)})`
+    );
+  }
+
+  const op1p: Operation = [];
+  const op2p: Operation = [];
+  let i1 = 0;
+  let i2 = 0;
+  let c1: OpComponent | undefined = op1[i1];
+  let c2: OpComponent | undefined = op2[i2];
+
+  function push1(c: OpComponent) {
+    if (isRetain(c) && c.retain === 0) return;
+    if (isDelete(c) && c.delete === 0) return;
+    if (isInsert(c) && c.insert === '') return;
+    const last = op1p[op1p.length - 1];
+    if (last) {
+      if (isRetain(last) && isRetain(c)) { op1p[op1p.length - 1] = { retain: last.retain + c.retain }; return; }
+      if (isInsert(last) && isInsert(c)) { op1p[op1p.length - 1] = { insert: last.insert + c.insert }; return; }
+      if (isDelete(last) && isDelete(c)) { op1p[op1p.length - 1] = { delete: last.delete + c.delete }; return; }
+    }
+    op1p.push(c);
+  }
+
+  function push2(c: OpComponent) {
+    if (isRetain(c) && c.retain === 0) return;
+    if (isDelete(c) && c.delete === 0) return;
+    if (isInsert(c) && c.insert === '') return;
+    const last = op2p[op2p.length - 1];
+    if (last) {
+      if (isRetain(last) && isRetain(c)) { op2p[op2p.length - 1] = { retain: last.retain + c.retain }; return; }
+      if (isInsert(last) && isInsert(c)) { op2p[op2p.length - 1] = { insert: last.insert + c.insert }; return; }
+      if (isDelete(last) && isDelete(c)) { op2p[op2p.length - 1] = { delete: last.delete + c.delete }; return; }
+    }
+    op2p.push(c);
+  }
+
+  while (c1 !== undefined || c2 !== undefined) {
+    // Insert in op1 goes first (op1 has priority)
+    if (c1 !== undefined && isInsert(c1)) {
+      push1({ insert: c1.insert });
+      push2({ retain: c1.insert.length });
+      i1++;
+      c1 = op1[i1];
+      continue;
+    }
+    // Insert in op2
+    if (c2 !== undefined && isInsert(c2)) {
+      push1({ retain: c2.insert.length });
+      push2({ insert: c2.insert });
+      i2++;
+      c2 = op2[i2];
+      continue;
+    }
+
+    if (c1 === undefined || c2 === undefined) {
+      throw new Error('Transform: unexpected end of operation');
+    }
+
+    if (isRetain(c1) && isRetain(c2)) {
+      const min = Math.min(c1.retain, c2.retain);
+      push1({ retain: min });
+      push2({ retain: min });
+      if (c1.retain === min) { i1++; c1 = op1[i1]; } else { c1 = { retain: c1.retain - min }; }
+      if (c2.retain === min) { i2++; c2 = op2[i2]; } else { c2 = { retain: c2.retain - min }; }
+    } else if (isDelete(c1) && isDelete(c2)) {
+      const min = Math.min(c1.delete, c2.delete);
+      // Both delete the same chars — neither needs to include them
+      if (c1.delete === min) { i1++; c1 = op1[i1]; } else { c1 = { delete: c1.delete - min }; }
+      if (c2.delete === min) { i2++; c2 = op2[i2]; } else { c2 = { delete: c2.delete - min }; }
+    } else if (isDelete(c1) && isRetain(c2)) {
+      const min = Math.min(c1.delete, c2.retain);
+      push1({ delete: min });
+      // op2' doesn't need to retain chars that were deleted
+      if (c1.delete === min) { i1++; c1 = op1[i1]; } else { c1 = { delete: c1.delete - min }; }
+      if (c2.retain === min) { i2++; c2 = op2[i2]; } else { c2 = { retain: c2.retain - min }; }
+    } else if (isRetain(c1) && isDelete(c2)) {
+      const min = Math.min(c1.retain, c2.delete);
+      // op1' doesn't need to retain chars that were deleted
+      push2({ delete: min });
+      if (c1.retain === min) { i1++; c1 = op1[i1]; } else { c1 = { retain: c1.retain - min }; }
+      if (c2.delete === min) { i2++; c2 = op2[i2]; } else { c2 = { delete: c2.delete - min }; }
+    } else {
+      throw new Error('Transform: unexpected component combination');
+    }
+  }
+
+  return [op1p, op2p];
+}
+
+/** Validate that an operation is well-formed. */
+export function validate(op: Operation): string | null {
+  if (!Array.isArray(op)) return 'Operation must be an array';
+  for (let i = 0; i < op.length; i++) {
+    const c = op[i];
+    if (typeof c !== 'object' || c === null) return `Component ${i} is not an object`;
+    if (isRetain(c)) {
+      if (typeof c.retain !== 'number' || c.retain <= 0 || !Number.isInteger(c.retain))
+        return `Component ${i}: retain must be a positive integer`;
+    } else if (isInsert(c)) {
+      if (typeof c.insert !== 'string' || c.insert.length === 0)
+        return `Component ${i}: insert must be a non-empty string`;
+    } else if (isDelete(c)) {
+      if (typeof c.delete !== 'number' || c.delete <= 0 || !Number.isInteger(c.delete))
+        return `Component ${i}: delete must be a positive integer`;
+    } else {
+      return `Component ${i}: unknown operation type`;
+    }
+  }
+  return null;
+}
diff --git a/src/routes.ts b/src/routes.ts
new file mode 100644
index 0000000..d374c34
--- /dev/null
+++ b/src/routes.ts
@@ -0,0 +1,98 @@
+import { Router, Request, Response } from 'express';
+import { randomUUID } from 'crypto';
+import { DocumentStore } from './database.js';
+import { CollaborationServer } from './collaboration.js';
+
+export function createRouter(store: DocumentStore, collab?: CollaborationServer): Router {
+  const router = Router();
+
+  // Create a document
+  router.post('/documents', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'title is required and must be a string' });
+      return;
+    }
+    const id = randomUUID();
+    const doc = store.createDocument(id, title, typeof content === 'string' ? content : '');
+    res.status(201).json(doc);
+  });
+
+  // List all documents
+  router.get('/documents', (_req: Request, res: Response) => {
+    const docs = store.getAllDocuments();
+    res.json(docs);
+  });
+
+  // Get a single document
+  router.get('/documents/:id', (req: Request, res: Response) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document (title only via REST — content changes via WebSocket/OT)
+  router.put('/documents/:id', (req: Request, res: Response) => {
+    const { title } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'title is required and must be a string' });
+      return;
+    }
+    const doc = store.updateDocumentTitle(req.params.id, title);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req: Request, res: Response) => {
+    const deleted = store.deleteDocument(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    // Evict any active WebSocket sessions for this document
+    if (collab) {
+      collab.evictDocument(req.params.id);
+    }
+    res.status(204).send();
+  });
+
+  // Get version history
+  router.get('/documents/:id/versions', (req: Request, res: Response) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = store.getVersionHistory(req.params.id);
+    res.json(versions);
+  });
+
+  // Get a specific version
+  router.get('/documents/:id/versions/:version', (req: Request, res: Response) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versionNum = parseInt(req.params.version, 10);
+    if (isNaN(versionNum)) {
+      res.status(400).json({ error: 'version must be a number' });
+      return;
+    }
+    const version = store.getVersion(req.params.id, versionNum);
+    if (!version) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+    res.json(version);
+  });
+
+  return router;
+}
