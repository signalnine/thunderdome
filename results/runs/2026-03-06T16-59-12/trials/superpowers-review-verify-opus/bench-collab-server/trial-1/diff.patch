+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KHrUktbU4GM6MraG7qwgaj","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→\n     3→export interface DocumentRow {\n     4→  id: string;\n     5→  title: string;\n     6→  content: string;\n     7→  version: number;\n     8→  created_at: string;\n     9→  updated_at: string;\n    10→}\n    11→\n    12→export interface VersionRow {\n    13→  id: number;\n    14→  document_id: string;\n    15→  version: number;\n    16→  content: string;\n    17→  operations: string;\n    18→  created_at: string;\n    19→}\n    20→\n    21→export function createDatabase(dbPath: string = ':memory:'): Database.Database {\n    22→  const db = Database(dbPath);\n    23→  db.pragma('journal_mode = WAL');\n    24→  db.pragma('foreign_keys = ON');\n    25→\n    26→  db.exec(`\n    27→    CREATE TABLE IF NOT EXISTS documents (\n    28→      id TEXT PRIMARY KEY,\n    29→      title TEXT NOT NULL,\n    30→      content TEXT NOT NULL DEFAULT '',\n    31→      version INTEGER NOT NULL DEFAULT 0,\n    32→      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    33→      updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n    34→    );\n    35→\n    36→    CREATE TABLE IF NOT EXISTS versions (\n    37→      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    38→      document_id TEXT NOT NULL,\n    39→      version INTEGER NOT NULL,\n    40→      content TEXT NOT NULL,\n    41→      operations TEXT NOT NULL DEFAULT '[]',\n    42→      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    43→      FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE\n    44→    );\n    45→\n    46→    CREATE INDEX IF NOT EXISTS idx_versions_doc_version\n    47→      ON versions(document_id, version);\n    48→  `);\n    49→\n    50→  return db;\n    51→}\n    52→\n    53→export class DocumentStore {\n    54→  private db: Database.Database;\n    55→  private stmts: {\n    56→    insert: Database.Statement;\n    57→    getById: Database.Statement;\n    58→    getAll: Database.Statement;\n    59→    update: Database.Statement;\n    60→    updateContent: Database.Statement;\n    61→    delete: Database.Statement;\n    62→    insertVersion: Database.Statement;\n    63→    getVersions: Database.Statement;\n    64→    getVersion: Database.Statement;\n    65→  };\n    66→\n    67→  constructor(db: Database.Database) {\n    68→    this.db = db;\n    69→    this.stmts = {\n    70→      insert: db.prepare(\n    71→        `INSERT INTO documents (id, title, content, version) VALUES (?, ?, ?, 0)`\n    72→      ),\n    73→      getById: db.prepare(`SELECT * FROM documents WHERE id = ?`),\n    74→      getAll: db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`),\n    75→      update: db.prepare(\n    76→        `UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?`\n    77→      ),\n    78→      updateContent: db.prepare(\n    79→        `UPDATE documents SET content = ?, version = ?, updated_at = datetime('now') WHERE id = ?`\n    80→      ),\n    81→      delete: db.prepare(`DELETE FROM documents WHERE id = ?`),\n    82→      insertVersion: db.prepare(\n    83→        `INSERT INTO versions (document_id, version, content, operations) VALUES (?, ?, ?, ?)`\n    84→      ),\n    85→      getVersions: db.prepare(\n    86→        `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`\n    87→      ),\n    88→      getVersion: db.prepare(\n    89→        `SELECT * FROM versions WHERE document_id = ? AND version = ?`\n    90→      ),\n    91→    };\n    92→  }\n    93→\n    94→  createDocument(id: string, title: string, content: string = ''): DocumentRow {\n    95→    this.stmts.insert.run(id, title, content);\n    96→    // Save initial version\n    97→    this.stmts.insertVersion.run(id, 0, content, '[]');\n    98→    return this.stmts.getById.get(id) as DocumentRow;\n    99→  }\n   100→\n   101→  getDocument(id: string): DocumentRow | undefined {\n   102→    return this.stmts.getById.get(id) as DocumentRow | undefined;\n   103→  }\n   104→\n   105→  getAllDocuments(): DocumentRow[] {\n   106→    return this.stmts.getAll.all() as DocumentRow[];\n   107→  }\n   108→\n   109→  updateDocumentTitle(id: string, title: string): DocumentRow | undefined {\n   110→    const result = this.stmts.update.run(title, id);\n   111→    if (result.changes === 0) return undefined;\n   112→    return this.stmts.getById.get(id) as DocumentRow;\n   113→  }\n   114→\n   115→  updateDocumentContent(\n   116→    id: string,\n   117→    content: string,\n   118→    version: number,\n   119→    operations: string\n   120→  ): DocumentRow | undefined {\n   121→    this.stmts.updateContent.run(content, version, id);\n   122→    this.stmts.insertVersion.run(id, version, content, operations);\n   123→    return this.stmts.getById.get(id) as DocumentRow;\n   124→  }\n   125→\n   126→  deleteDocument(id: string): boolean {\n   127→    const result = this.stmts.delete.run(id);\n   128→    return result.changes > 0;\n   129→  }\n   130→\n   131→  getVersionHistory(documentId: string): VersionRow[] {\n   132→    return this.stmts.getVersions.all(documentId) as VersionRow[];\n   133→  }\n   134→\n   135→  getVersion(documentId: string, version: number): VersionRow | undefined {\n   136→    return this.stmts.getVersion.get(documentId, version) as VersionRow | undefined;\n   137→  }\n   138→\n   139→  close(): void {\n   140→    this.db.close();\n   141→  }\n   142→}\n   143→"}]},"parent_tool_use_id":"toolu_01SSunhwmgSoxP95nQLziiYo","session_id":"a785380d-83fd-49c7-bf44-139e6dae5c7d","uuid":"8271d249-7659-44da-ab85-31ed6e0dd8c7"}
