e('WebSocket Collaboration', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterAll(async () => {\n    await instance.stop();\n  });\n\n  it('should send sync message on connection', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Test', content: 'hello' });\n\n    const client = await connectWs(port, created.body.id);\n    const msg = await client.waitForMessage();\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n\n    client.ws.close();\n  });\n\n  it('should reject connection for non-existent document', async () => {\n    const ws = new WebSocket(\n      `ws://127.0.0.1:${port}/documents/nonexistent`\n    );\n    const closePromise = new Promise<number>((resolve) => {\n      ws.on('close', (code) => resolve(code));\n    });\n    const code = await closePromise;\n    expect(code).toBe(1008);\n  });\n\n  it('should apply an operation and send ack', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Op Test', content: 'abc' });\n\n    const client = await connectWs(port, created.body.id);\n    const sync = await client.waitForMessage();\n    expect(sync.type).toBe('sync');\n\n    // Insert 'X' at position 1 => \"aXbc\"\n    sendOp(\n      client.ws,\n      [{ retain: 1 }, { insert: 'X' }, { retain: 2 }],\n      0\n    );\n    const ack = await client.waitForMessage();\n\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const res = await request(instance.app).get(\n      `/api/documents/${created.body.id}`\n    );\n    expect(res.body.content).toBe('aXbc');\n    expect(res.body.version).toBe(1);\n\n    client.ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Broadcast Test', content: 'abc' });\n\n    const c1 = await connectWs(port, created.body.id);\n    const sync1 = await c1.waitForMessage();\n    expect(sync1.type).toBe('sync');\n\n    const c2 = await connectWs(port, created.body.id);\n    const sync2 = await c2.waitForMessage();\n    expect(sync2.type).toBe('sync');\n\n    // c1 sends an operation\n    sendOp(c1.ws, [{ retain: 3 }, { insert: 'd' }], 0);\n\n    // c1 gets ack\n    const ack = await c1.waitForMessage();\n    expect(ack.type).toBe('ack');\n\n    // c2 gets the broadcast\n    const broadcast = await c2.waitForMessage();\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(1);\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent Test', content: 'abc' });\n\n    const c1 = await connectWs(port, created.body.id);\n    await c1.waitForMessage(); // sync\n\n    const c2 = await connectWs(port, created.body.id);\n    await c2.waitForMessage(); // sync\n\n    // Both clients send operations based on version 0\n    // c1: insert 'X' at position 0 => \"Xabc\"\n    sendOp(c1.ws, [{ insert: 'X' }, { retain: 3 }], 0);\n    // c2: insert 'Y' at position 3 => \"abcY\"\n    sendOp(c2.ws, [{ retain: 3 }, { insert: 'Y' }], 0);\n\n    // c1 gets ack for its operation\n    const ack1 = await c1.waitForMessage();\n    expect(ack1.type).toBe('ack');\n\n    // c1 gets broadcast of c2's (transformed) operation\n    const broadcast1 = await c1.waitForMessage();\n    expect(broadcast1.type).toBe('operation');\n\n    // c2 gets broadcast of c1's operation and ack for its own\n    const msg2a = await c2.waitForMessage();\n    const msg2b = await c2.waitForMessage();\n\n    // One should be operation, one should be ack\n    const types = [msg2a.type, msg2b.type].sort();\n    expect(types).toEqual(['ack', 'operation']);\n\n    // Verify final state via REST — both X and Y should be present\n    const res = await request(instance.app).get(\n      `/api/documents/${created.body.id}`\n    );\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('Y');\n    expect(res.body.content).toContain('abc');\n    expect(res.body.content).toBe('XabcY');\n\n    c1.ws.close();\n    c2.ws.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Invalid Op Test', content: 'abc' });\n\n    const client = await connectWs(port, created.body.id);\n    await client.waitForMessage(); // sync\n\n    // Send invalid operation (retain 0)\n    client.ws.send(\n      JSON.stringify({\n        type: 'operation',\n        operation: [{ retain: 0 }],\n        version: 0,\n      })\n    );\n\n    const msg = await client.waitForMessage();\n    expect(msg.type).toBe('error');\n\n    client.ws.close();\n  });\n\n  it('should reject invalid message types', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Bad Type Test', content: '' });\n\n    const client = await connectWs(port, created.body.id);\n    await client.waitForMessage(); // sync\n\n    client.ws.send(JSON.stringify({ type: 'unknown' }));\n    const msg = await client.waitForMessage();\n    expect(msg.type).toBe('error');\n\n    client.ws.close();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Stress Test', content: '' });\n\n    const docId = created.body.id;\n    const numClients = 10;\n    const clients: ConnectedClient[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < numClients; i++) {\n      const client = await connectWs(port, docId);\n      await client.waitForMessage(); // sync\n      clients.push(client);\n    }\n\n    // Each client sends one insert sequentially\n    for (let i = 0; i < numClients; i++) {\n      const client = clients[i];\n      const char = String.fromCharCode(65 + i); // A, B, C, ...\n\n      // Get current state\n      const res = await request(instance.app).get(\n        `/api/documents/${docId}`\n      );\n      const currentLen = res.body.content.length;\n      const version = res.body.version;\n\n      const op =\n        currentLen > 0\n          ? [{ retain: currentLen }, { insert: char }]\n          : [{ insert: char }];\n\n      sendOp(client.ws, op, version);\n\n      // Wait for ack\n      const ack = await client.waitForMessage();\n      expect(ack.type).toBe('ack');\n\n      // Drain broadcast messages from other clients\n      for (let j = 0; j < numClients; j++) {\n        if (j !== i) {\n          const bcast = await clients[j].waitForMessage();\n          expect(bcast.type).toBe('operation');\n        }\n      }\n    }\n\n    // Verify final state\n    const finalRes = await request(instance.app).get(\n      `/api/documents/${docId}`\n    );\n    expect(finalRes.body.content.length).toBe(10);\n    expect(finalRes.body.content).toBe('ABCDEFGHIJ');\n\n    // Close all\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });\n\n  it('should persist document state across server instances', async () => {\n    const fs = await import('fs');\n    const os = await import('os');\n    const path = await import('path');\n\n    const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'collab-'));\n    const dbFile = path.join(tmpDir, 'test.db');\n\n    // First instance\n    const instance1 = createApp(dbFile);\n    const port1 = await instance1.start(0);\n\n    const created = await request(instance1.app)\n      .post('/api/documents')\n      .send({ title: 'Persist Test', content: 'initial' });\n\n    const docId = created.body.id;\n\n    // Make an edit via WebSocket\n    const client = await connectWs(port1, docId);\n    await client.waitForMessage(); // sync\n\n    sendOp(client.ws, [{ retain: 7 }, { insert: ' data' }], 0);\n    await client.waitForMessage(); // ack\n\n    client.ws.close();\n    await instance1.stop();\n\n    // Second instance with same DB\n    const instance2 = createApp(dbFile);\n    await instance2.start(0);\n\n    const res = await request(instance2.app).get(\n      `/api/documents/${docId}`\n    );\n    expect(res.body.content).toBe('initial data');\n    expect(res.body.version).toBe(1);\n\n    // Check version history\n    const versions = await request(instance2.app).get(\n      `/api/documents/${docId}/versions`\n    );\n    expect(versions.body.length).toBe(2); // version 0 and version 1\n\n    await instance2.stop();\n\n    // Cleanup\n    fs.rmSync(tmpDir, { recursive: true });\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":58,"newStart":1,"newLines":70,"lines":["-import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';","+import { describe, it, expect, beforeAll, afterAll } from 'vitest';"," import WebSocket from 'ws';"," import request from 'supertest';"," import { createApp, AppInstance } from '../src/server.js';"," "," interface ConnectedClient {","   ws: WebSocket;","-  messages: Record<string, unknown>[];","   waitForMessage(): Promise<Record<string, unknown>>;"," }"," "," function connectWs(port: number, docId: string): Promise<ConnectedClient> {","   return new Promise((resolve, reject) => {","     const ws = new WebSocket(`ws://127.0.0.1:${port}/documents/${docId}`);","-    const messages: Record<string, unknown>[] = [];","-    let waiting: { resolve: (msg: Record<string, unknown>) => void; reject: (err: Error) => void } | null = null;","+    const pendingMessages: Record<string, unknown>[] = [];","+    let waiter: {","+      resolve: (msg: Record<string, unknown>) => void;","+      reject: (err: