ance2.app).get(`/api/documents/${docId}/versions`);","+    const versions = await request(instance2.app).get(","+      `/api/documents/${docId}/versions`","+    );","     expect(versions.body.length).toBe(2); // version 0 and version 1"," ","     await instance2.stop();"]}],"originalFile":"import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';\nimport WebSocket from 'ws';\nimport request from 'supertest';\nimport { createApp, AppInstance } from '../src/server.js';\n\ninterface ConnectedClient {\n  ws: WebSocket;\n  messages: Record<string, unknown>[];\n  waitForMessage(): Promise<Record<string, unknown>>;\n}\n\nfunction connectWs(port: number, docId: string): Promise<ConnectedClient> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://127.0.0.1:${port}/documents/${docId}`);\n    const messages: Record<string, unknown>[] = [];\n    let waiting: { resolve: (msg: Record<string, unknown>) => void; reject: (err: Error) => void } | null = null;\n\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString()) as Record<string, unknown>;\n      if (waiting) {\n        const w = waiting;\n        waiting = null;\n        w.resolve(msg);\n      } else {\n        messages.push(msg);\n      }\n    });\n\n    ws.on('open', () => {\n      resolve({\n        ws,\n        messages,\n        waitForMessage(): Promise<Record<string, unknown>> {\n          if (messages.length > 0) {\n            return Promise.resolve(messages.shift()!);\n          }\n          return new Promise((res, rej) => {\n            const timeout = setTimeout(() => {\n              waiting = null;\n              rej(new Error('Timeout waiting for message'));\n            }, 5000);\n            waiting = {\n              resolve: (msg) => { clearTimeout(timeout); res(msg); },\n              reject: (err) => { clearTimeout(timeout); rej(err); },\n            };\n          });\n        },\n      });\n    });\n\n    ws.on('error', reject);\n  });\n}\n\nfunction sendOp(ws: WebSocket, operation: unknown[], version: number): void {\n  ws.send(JSON.stringify({ type: 'operation', operation, version }));\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterAll(async () => {\n    await instance.stop();\n  });\n\n  it('should send sync message on connection', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Test', content: 'hello' });\n\n    const ws = await connectWs(port, created.body.id);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n\n    ws.close();\n  });\n\n  it('should reject connection for non-existent document', async () => {\n    const ws = new WebSocket(`ws://127.0.0.1:${port}/documents/nonexistent`);\n    const closePromise = new Promise<number>((resolve) => {\n      ws.on('close', (code) => resolve(code));\n    });\n    const code = await closePromise;\n    expect(code).toBe(1008);\n  });\n\n  it('should apply an operation and send ack', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Op Test', content: 'abc' });\n\n    const ws = await connectWs(port, created.body.id);\n    const sync = await waitForMessage(ws);\n    expect(sync.type).toBe('sync');\n\n    // Insert 'X' at position 1 => \"aXbc\"\n    sendOp(ws, [{ retain: 1 }, { insert: 'X' }, { retain: 2 }], 0);\n    const ack = await waitForMessage(ws);\n\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const res = await request(instance.app).get(`/api/documents/${created.body.id}`);\n    expect(res.body.content).toBe('aXbc');\n    expect(res.body.version).toBe(1);\n\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Broadcast Test', content: 'abc' });\n\n    const ws1 = await connectWs(port, created.body.id);\n    const sync1 = await waitForMessage(ws1);\n    expect(sync1.type).toBe('sync');\n\n    const ws2 = await connectWs(port, created.body.id);\n    const sync2 = await waitForMessage(ws2);\n    expect(sync2.type).toBe('sync');\n\n    // ws1 sends an operation\n    sendOp(ws1, [{ retain: 3 }, { insert: 'd' }], 0);\n\n    // ws1 gets ack\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe('ack');\n\n    // ws2 gets the broadcast\n    const broadcast = await waitForMessage(ws2);\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(1);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent Test', content: 'abc' });\n\n    const ws1 = await connectWs(port, created.body.id);\n    await waitForMessage(ws1); // sync\n\n    const ws2 = await connectWs(port, created.body.id);\n    await waitForMessage(ws2); // sync\n\n    // Both clients send operations based on version 0\n    // ws1: insert 'X' at position 0 => \"Xabc\"\n    sendOp(ws1, [{ insert: 'X' }, { retain: 3 }], 0);\n    // ws2: insert 'Y' at position 3 => \"abcY\"\n    sendOp(ws2, [{ retain: 3 }, { insert: 'Y' }], 0);\n\n    // ws1 gets ack for its operation\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe('ack');\n\n    // ws1 gets broadcast of ws2's (transformed) operation\n    const broadcast1 = await waitForMessage(ws1);\n    expect(broadcast1.type).toBe('operation');\n\n    // ws2 gets broadcast of ws1's operation\n    const msg2a = await waitForMessage(ws2);\n    // ws2 gets ack for its own operation\n    const msg2b = await waitForMessage(ws2);\n\n    // One should be operation, one should be ack\n    const types = [msg2a.type, msg2b.type].sort();\n    expect(types).toEqual(['ack', 'operation']);\n\n    // Verify final state via REST — both X and Y should be present\n    const res = await request(instance.app).get(`/api/documents/${created.body.id}`);\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('Y');\n    expect(res.body.content).toContain('abc');\n    expect(res.body.content).toBe('XabcY');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Invalid Op Test', content: 'abc' });\n\n    const ws = await connectWs(port, created.body.id);\n    await waitForMessage(ws); // sync\n\n    // Send invalid operation (retain 0)\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 0 }],\n      version: 0,\n    }));\n\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject invalid message types', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Bad Type Test', content: '' });\n\n    const ws = await connectWs(port, created.body.id);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: 'unknown' }));\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Stress Test', content: '' });\n\n    const docId = created.body.id;\n    const numClients = 10;\n    const clients: WebSocket[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < numClients; i++) {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client sends one insert sequentially, each based on the current version\n    for (let i = 0; i < numClients; i++) {\n      const ws = clients[i];\n      // Insert character at the end\n      const char = String.fromCharCode(65 + i); // A, B, C, ...\n\n      // Get current state\n      const res = await request(instance.app).get(`/api/documents/${docId}`);\n      const currentLen = res.body.content.length;\n      const version = res.body.version;\n\n      const op = currentLen > 0\n        ? [{ retain: currentLen }, { insert: char }]\n        : [{ insert: char }];\n\n      sendOp(ws, op, version);\n\n      // Wait for ack\n      const ack = await waitForMessage(ws);\n      expect(ack.type).toBe('ack');\n\n      // Drain broadcast messages from other clients\n      for (let j = 0; j < numClients; j++) {\n        if (j !== i) {\n          // Other clients receive broadcast\n          const bcast = await waitForMessage(clients[j]);\n          expect(bcast.type).toBe('operation');\n        }\n      }\n    }\n\n    // Verify final state\n    const final = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(final.body.content.length).toBe(10);\n    expect(final.body.content).toBe('ABCDEFGHIJ');\n\n    // Close all\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it('should persist document state across server instances', async () => {\n    const fs = await import('fs');\n    const os = await import('os');\n    const path = await import('path');\n\n    const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'collab-'));\n    const dbFile = path.join(tmpDir, 'test.db');\n\n    // First instance\n    const instance1 = createApp(dbFile);\n    const port1 = await instance1.start(0);\n\n    const created = await request(instance1.app)\n      .post('/api/documents')\n      .send({ title: 'Persist Test', content: 'initial' });\n\n    const docId = created.body.id;\n\n    // Make an edit via WebSocket\n    const ws = await connectWs(port1, docId);\n    await waitForMessage(ws); // sync\n\n    sendOp(ws, [{ retain: 7 }, { insert: ' data' }], 0);\n    await waitForMessage(ws); // ack\n\n    ws.close();\n    await instance1.stop();\n\n    // Second instance with same DB\n    const instance2 = createApp(dbFile);\n    await instance2.start(0);\n\n    const res = await request(instance2.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('initial data');\n    expect(res.body.version).toBe(1);\n\n    // Check version history\n    const versions = await request(instance2.app).get(`/api/documents/${docId}/versions`);\n    expect(versions.body.length).toBe(2); // version 0 and version 1\n\n    await instance2.stop();\n\n    // Cleanup\n    fs.rmSync(tmpDir, { recursive: true });\n  });\n});\n"}}
