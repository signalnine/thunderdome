+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0177BWQd5YXXCKUfQgxEfxJc","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import { IncomingMessage } from 'http';\n     3→import { DocumentStore } from './database.js';\n     4→import { Operation, apply, transform, validate, inputLength } from './ot.js';\n     5→\n     6→interface Client {\n     7→  ws: WebSocket;\n     8→  documentId: string;\n     9→}\n    10→\n    11→interface DocumentSession {\n    12→  content: string;\n    13→  version: number;\n    14→  /** History of operations, indexed by version (ops[i] transitions version i to i+1) */\n    15→  ops: Operation[];\n    16→}\n    17→\n    18→interface ClientMessage {\n    19→  type: string;\n    20→  operation?: Operation;\n    21→  version?: number;\n    22→}\n    23→\n    24→export class CollaborationServer {\n    25→  private wss: WebSocketServer;\n    26→  private store: DocumentStore;\n    27→  private clients: Map<WebSocket, Client> = new Map();\n    28→  private sessions: Map<string, DocumentSession> = new Map();\n    29→\n    30→  constructor(wss: WebSocketServer, store: DocumentStore) {\n    31→    this.wss = wss;\n    32→    this.store = store;\n    33→\n    34→    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n    35→      this.handleConnection(ws, req);\n    36→    });\n    37→  }\n    38→\n    39→  private getDocumentIdFromUrl(url: string | undefined): string | null {\n    40→    if (!url) return null;\n    41→    // Expected paths: /documents/:id or /ws/documents/:id\n    42→    const match = url.match(/\\/documents\\/([^/?]+)/);\n    43→    return match ? match[1] : null;\n    44→  }\n    45→\n    46→  private getOrCreateSession(documentId: string): DocumentSession | null {\n    47→    let session = this.sessions.get(documentId);\n    48→    if (session) return session;\n    49→\n    50→    const doc = this.store.getDocument(documentId);\n    51→    if (!doc) return null;\n    52→\n    53→    session = {\n    54→      content: doc.content,\n    55→      version: doc.version,\n    56→      ops: [],\n    57→    };\n    58→    this.sessions.set(documentId, session);\n    59→    return session;\n    60→  }\n    61→\n    62→  private handleConnection(ws: WebSocket, req: IncomingMessage): void {\n    63→    const documentId = this.getDocumentIdFromUrl(req.url);\n    64→    if (!documentId) {\n    65→      this.sendError(ws, 'Invalid URL: document ID required');\n    66→      ws.close(1008, 'Document ID required');\n    67→      return;\n    68→    }\n    69→\n    70→    const session = this.getOrCreateSession(documentId);\n    71→    if (!session) {\n    72→      this.sendError(ws, 'Document not found');\n    73→      ws.close(1008, 'Document not found');\n    74→      return;\n    75→    }\n    76→\n    77→    const client: Client = { ws, documentId };\n    78→    this.clients.set(ws, client);\n    79→\n    80→    // Send initial sync\n    81→    this.send(ws, {\n    82→      type: 'sync',\n    83→      content: session.content,\n    84→      version: session.version,\n    85→    });\n    86→\n    87→    ws.on('message', (data) => {\n    88→      try {\n    89→        const message = JSON.parse(data.toString()) as ClientMessage;\n    90→        this.handleMessage(ws, client, message);\n    91→      } catch (err) {\n    92→        this.sendError(ws, 'Invalid message format');\n    93→      }\n    94→    });\n    95→\n    96→    ws.on('close', () => {\n    97→      this.clients.delete(ws);\n    98→    });\n    99→\n   100→    ws.on('error', () => {\n   101→      this.clients.delete(ws);\n   102→    });\n   103→  }\n   104→\n   105→  private handleMessage(ws: WebSocket, client: Client, message: ClientMessage): void {\n   106→    if (message.type !== 'operation') {\n   107→      this.sendError(ws, `Unknown message type: ${message.type}`);\n   108→      return;\n   109→    }\n   110→\n   111→    if (!message.operation || typeof message.version !== 'number') {\n   112→      this.sendError(ws, 'operation and version are required');\n   113→      return;\n   114→    }\n   115→\n   116→    const validationError = validate(message.operation);\n   117→    if (validationError) {\n   118→      this.sendError(ws, `Invalid operation: ${validationError}`);\n   119→      return;\n   120→    }\n   121→\n   122→    const session = this.sessions.get(client.documentId);\n   123→    if (!session) {\n   124→      this.sendError(ws, 'Document session not found');\n   125→      return;\n   126→    }\n   127→\n   128→    const clientVersion = message.version;\n   129→    if (clientVersion < 0 || clientVersion > session.version) {\n   130→      this.sendError(ws, `Invalid version: ${clientVersion} (server is at ${session.version})`);\n   131→      return;\n   132→    }\n   133→\n   134→    let op = message.operation;\n   135→\n   136→    // Transform against all operations that have happened since the client's version\n   137→    const baseVersion = session.version - session.ops.length;\n   138→    const startIdx = clientVersion - baseVersion;\n   139→\n   140→    if (startIdx < 0 || startIdx > session.ops.length) {\n   141→      this.sendError(ws, `Version ${clientVersion} is too old, cannot transform`);\n   142→      return;\n   143→    }\n   144→\n   145→    for (let i = startIdx; i < session.ops.length; i++) {\n   146→      try {\n   147→        const [transformedOp] = transform(op, session.ops[i]);\n   148→        op = transformedOp;\n   149→      } catch (err) {\n   150→        const msg = err instanceof Error ? err.message : 'Transform failed';\n   151→        this.sendError(ws, `Transform error: ${msg}`);\n   152→        return;\n   153→      }\n   154→    }\n   155→\n   156→    // Validate that the operation fits the current document\n   157→    if (inputLength(op) !== session.content.length) {\n   158→      this.sendError(\n   159→        ws,\n   160→        `Operation input length (${inputLength(op)}) does not match document length (${session.content.length})`\n   161→      );\n   162→      return;\n   163→    }\n   164→\n   165→    // Apply the transformed operation\n   166→    try {\n   167→      session.content = apply(session.content, op);\n   168→    } catch (err) {\n   169→      const msg = err instanceof Error ? err.message : 'Apply failed';\n   170→      this.sendError(ws, `Apply error: ${msg}`);\n   171→      return;\n   172→    }\n   173→\n   174→    session.version++;\n   175→    session.ops.push(op);\n   176→\n   177→    // Persist to database\n   178→    this.store.updateDocumentContent(\n   179→      client.documentId,\n   180→      session.content,\n   181→      session.version,\n   182→      JSON.stringify(op)\n   183→    );\n   184→\n   185→    // Acknowledge to sender\n   186→    this.send(ws, {\n   187→      type: 'ack',\n   188→      version: session.version,\n   189→    });\n   190→\n   191→    // Broadcast to other clients on same document\n   192→    this.broadcast(client.documentId, ws, {\n   193→      type: 'operation',\n   194→      operation: op,\n   195→      version: session.version,\n   196→    });\n   197→  }\n   198→\n   199→  private send(ws: WebSocket, data: unknown): void {\n   200→    if (ws.readyState === WebSocket.OPEN) {\n   201→      ws.send(JSON.stringify(data));\n   202→    }\n   203→  }\n   204→\n   205→  private sendError(ws: WebSocket, message: string): void {\n   206→    this.send(ws, { type: 'error', message });\n   207→  }\n   208→\n   209→  private broadcast(documentId: string, exclude: WebSocket, data: unknown): void {\n   210→    const msg = JSON.stringify(data);\n   211→    for (const [clientWs, client] of this.clients) {\n   212→      if (client.documentId === documentId && clientWs !== exclude && clientWs.readyState === WebSocket.OPEN) {\n   213→        clientWs.send(msg);\n   214→      }\n   215→    }\n   216→  }\n   217→\n   218→  closeAll(): void {\n   219→    for (const [ws] of this.clients) {\n   220→      ws.close(1001, 'Server shutting down');\n   221→    }\n   222→    this.clients.clear();\n   223→    this.sessions.clear();\n   224→  }\n   225→}\n   226→"}]},"parent_tool_use_id":"toolu_01SSunhwmgSoxP95nQLziiYo","session_id":"a785380d-83fd-49c7-bf44-139e6dae5c7d","uuid":"bd5820e9-2a60-4555-8ef0-fb17f2cb8e84"}
