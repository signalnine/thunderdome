+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_012aQEWJwwp18f7YZ3jzQcFX","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011hHhoj5J9ciUDyTMNDRPR3","name":"Write","input":{"file_path":"/workspace/src/collaboration.ts","content":"import { WebSocketServer, WebSocket } from 'ws';\nimport { IncomingMessage } from 'http';\nimport { DocumentStore } from './database.js';\nimport { Operation, apply, transform, validate, inputLength } from './ot.js';\n\ninterface Client {\n  ws: WebSocket;\n  documentId: string;\n}\n\ninterface DocumentSession {\n  content: string;\n  version: number;\n  /** History of operations, indexed relative to baseVersion. ops[i] transitions (baseVersion + i) to (baseVersion + i + 1). */\n  ops: Operation[];\n  baseVersion: number;\n}\n\nconst MAX_OPS_HISTORY = 1000;\n\ninterface ClientMessage {\n  type: string;\n  operation?: Operation;\n  version?: number;\n}\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private store: DocumentStore;\n  private clients: Map<WebSocket, Client> = new Map();\n  private sessions: Map<string, DocumentSession> = new Map();\n\n  constructor(wss: WebSocketServer, store: DocumentStore) {\n    this.wss = wss;\n    this.store = store;\n\n    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n      this.handleConnection(ws, req);\n    });\n  }\n\n  private getDocumentIdFromUrl(url: string | undefined): string | null {\n    if (!url) return null;\n    const match = url.match(/\\/documents\\/([^/?]+)/);\n    return match ? match[1] : null;\n  }\n\n  private getOrCreateSession(documentId: string): DocumentSession | null {\n    let session = this.sessions.get(documentId);\n    if (session) return session;\n\n    const doc = this.store.getDocument(documentId);\n    if (!doc) return null;\n\n    // Load operation history from database so transforms work after restart\n    const storedOps = this.store.getOperationsFrom(documentId, 0);\n    const ops: Operation[] = [];\n    for (const row of storedOps) {\n      try {\n        ops.push(JSON.parse(row.operations) as Operation);\n      } catch {\n        // Skip malformed ops\n      }\n    }\n\n    session = {\n      content: doc.content,\n      version: doc.version,\n      ops,\n      baseVersion: 0,\n    };\n    this.sessions.set(documentId, session);\n    return session;\n  }\n\n  private pruneOps(session: DocumentSession): void {\n    if (session.ops.length > MAX_OPS_HISTORY) {\n      const excess = session.ops.length - MAX_OPS_HISTORY;\n      session.ops.splice(0, excess);\n      session.baseVersion += excess;\n    }\n  }\n\n  private handleConnection(ws: WebSocket, req: IncomingMessage): void {\n    const documentId = this.getDocumentIdFromUrl(req.url);\n    if (!documentId) {\n      this.sendError(ws, 'Invalid URL: document ID required');\n      ws.close(1008, 'Document ID required');\n      return;\n    }\n\n    const session = this.getOrCreateSession(documentId);\n    if (!session) {\n      this.sendError(ws, 'Document not found');\n      ws.close(1008, 'Document not found');\n      return;\n    }\n\n    const client: Client = { ws, documentId };\n    this.clients.set(ws, client);\n\n    // Send initial sync\n    this.send(ws, {\n      type: 'sync',\n      content: session.content,\n      version: session.version,\n    });\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString()) as ClientMessage;\n        this.handleMessage(ws, client, message);\n      } catch {\n        this.sendError(ws, 'Invalid message format');\n      }\n    });\n\n    ws.on('close', () => {\n      this.clients.delete(ws);\n      this.cleanupSessionIfEmpty(documentId);\n    });\n\n    ws.on('error', () => {\n      this.clients.delete(ws);\n      this.cleanupSessionIfEmpty(documentId);\n    });\n  }\n\n  private cleanupSessionIfEmpty(documentId: string): void {\n    for (const [, client] of this.clients) {\n      if (client.documentId === documentId) return;\n    }\n    // No more clients on this document — remove session from memory\n    this.sessions.delete(documentId);\n  }\n\n  private handleMessage(ws: WebSocket, client: Client, message: ClientMessage): void {\n    if (message.type !== 'operation') {\n      this.sendError(ws, `Unknown message type: ${message.type}`);\n      return;\n    }\n\n    if (!message.operation || typeof message.version !== 'number') {\n      this.sendError(ws, 'operation and version are required');\n      return;\n    }\n\n    const validationError = validate(message.operation);\n    if (validationError) {\n      this.sendError(ws, `Invalid operation: ${validationError}`);\n      return;\n    }\n\n    const session = this.sessions.get(client.documentId);\n    if (!session) {\n      this.sendError(ws, 'Document session not found');\n      return;\n    }\n\n    const clientVersion = message.version;\n    if (clientVersion < 0 || clientVersion > session.version) {\n      this.sendError(ws, `Invalid version: ${clientVersion} (server is at ${session.version})`);\n      return;\n    }\n\n    let op = message.operation;\n\n    // Transform against all operations that have happened since the client's version\n    const startIdx = clientVersion - session.baseVersion;\n\n    if (startIdx < 0) {\n      this.sendError(ws, `Version ${clientVersion} is too old, cannot transform`);\n      return;\n    }\n\n    for (let i = startIdx; i < session.ops.length; i++) {\n      try {\n        const [transformedOp] = transform(op, session.ops[i]);\n        op = transformedOp;\n      } catch (err) {\n        const msg = err instanceof Error ? err.message : 'Transform failed';\n        this.sendError(ws, `Transform error: ${msg}`);\n        return;\n      }\n    }\n\n    // Validate that the operation fits the current document\n    if (inputLength(op) !== session.content.length) {\n      this.sendError(\n        ws,\n        `Operation input length (${inputLength(op)}) does not match document length (${session.content.length})`\n      );\n      return;\n    }\n\n    // Apply the transformed operation\n    let newContent: string;\n    try {\n      newContent = apply(session.content, op);\n    } catch (err) {\n      const msg = err instanceof Error ? err.message : 'Apply failed';\n      this.sendError(ws, `Apply error: ${msg}`);\n      return;\n    }\n\n    const newVersion = session.version + 1;\n\n    // Persist to database first — if this fails, we don't update in-memory state\n    try {\n      this.store.updateDocumentContent(\n        client.documentId,\n        newContent,\n        newVersion,\n        JSON.stringify(op)\n      );\n    } catch (err) {\n      const msg = err instanceof Error ? err.message : 'Persistence failed';\n      this.sendError(ws, `Persistence error: ${msg}`);\n      return;\n    }\n\n    // Only update in-memory state after successful persistence\n    session.content = newContent;\n    session.version = newVersion;\n    session.ops.push(op);\n    this.pruneOps(session);\n\n    // Acknowledge to sender\n    this.send(ws, {\n      type: 'ack',\n      version: session.version,\n    });\n\n    // Broadcast to other clients on same document\n    this.broadcast(client.documentId, ws, {\n      type: 'operation',\n      operation: op,\n      version: session.version,\n    });\n  }\n\n  private send(ws: WebSocket, data: unknown): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(data));\n    }\n  }\n\n  private sendError(ws: WebSocket, message: string): void {\n    this.send(ws, { type: 'error', message });\n  }\n\n  private broadcast(documentId: string, exclude: WebSocket, data: unknown): void {\n    const msg = JSON.stringify(data);\n    for (const [clientWs, client] of this.clients) {\n      if (client.documentId === documentId && clientWs !== exclude && clientWs.readyState === WebSocket.OPEN) {\n        clientWs.send(msg);\n      }\n    }\n  }\n\n  /** Evict a document session and disconnect al