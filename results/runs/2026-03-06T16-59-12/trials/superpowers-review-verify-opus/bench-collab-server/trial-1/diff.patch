new file mode 100644
index 0000000..0c78447
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,280 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { DocumentStore } from './database.js';
+import { Operation, apply, transform, validate, inputLength } from './ot.js';
+
+interface Client {
+  ws: WebSocket;
+  documentId: string;
+}
+
+interface DocumentSession {
+  content: string;
+  version: number;
+  /** History of operations, indexed relative to baseVersion. ops[i] transitions (baseVersion + i) to (baseVersion + i + 1). */
+  ops: Operation[];
+  baseVersion: number;
+}
+
+const MAX_OPS_HISTORY = 1000;
+
+interface ClientMessage {
+  type: string;
+  operation?: Operation;
+  version?: number;
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private store: DocumentStore;
+  private clients: Map<WebSocket, Client> = new Map();
+  private sessions: Map<string, DocumentSession> = new Map();
+
+  constructor(wss: WebSocketServer, store: DocumentStore) {
+    this.wss = wss;
+    this.store = store;
+
+    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      this.handleConnection(ws, req);
+    });
+  }
+
+  private getDocumentIdFromUrl(url: string | undefined): string | null {
+    if (!url) return null;
+    const match = url.match(/\/documents\/([^/?]+)/);
+    return match ? match[1] : null;
+  }
+
+  private getOrCreateSession(documentId: string): DocumentSession | null {
+    let session = this.sessions.get(documentId);
+    if (session) return session;
+
+    const doc = this.store.getDocument(documentId);
+    if (!doc) return null;
+
+    // Load operation history from database so transforms work after restart
+    const storedOps = this.store.getOperationsFrom(documentId, 0);
+    const ops: Operation[] = [];
+    for (const row of storedOps) {
+      try {
+        ops.push(JSON.parse(row.operations) as Operation);
+      } catch {
+        // Skip malformed ops
+      }
+    }
+
+    session = {
+      content: doc.content,
+      version: doc.version,
+      ops,
+      baseVersion: 0,
+    };
+    this.sessions.set(documentId, session);
+    return session;
+  }
+
+  private pruneOps(session: DocumentSession): void {
+    if (session.ops.length > MAX_OPS_HISTORY) {
+      const excess = session.ops.length - MAX_OPS_HISTORY;
+      session.ops.splice(0, excess);
+      session.baseVersion += excess;
+    }
+  }
+
+  private handleConnection(ws: WebSocket, req: IncomingMessage): void {
+    const documentId = this.getDocumentIdFromUrl(req.url);
+    if (!documentId) {
+      this.sendError(ws, 'Invalid URL: document ID required');
+      ws.close(1008, 'Document ID required');
+      return;
+    }
+
+    const session = this.getOrCreateSession(documentId);
+    if (!session) {
+      this.sendError(ws, 'Document not found');
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    const client: Client = { ws, documentId };
+    this.clients.set(ws, client);
+
+    // Send initial sync
+    this.send(ws, {
+      type: 'sync',
+      content: session.content,
+      version: session.version,
+    });
+
+    ws.on('message', (data) => {
+      try {
+        const message = JSON.parse(data.toString()) as ClientMessage;
+        this.handleMessage(ws, client, message);
+      } catch {
+        this.sendError(ws, 'Invalid message format');
+      }
+    });
+
+    ws.on('close', () => {
+      this.clients.delete(ws);
+      this.cleanupSessionIfEmpty(documentId);
+    });
+
+    ws.on('error', () => {
+      this.clients.delete(ws);
+      this.cleanupSessionIfEmpty(documentId);
+    });
+  }
+
+  private cleanupSessionIfEmpty(documentId: string): void {
+    for (const [, client] of this.clients) {
+      if (client.documentId === documentId) return;
+    }
+    // No more clients on this document — remove session from memory
+    this.sessions.delete(documentId);
+  }
+
+  private handleMessage(ws: WebSocket, client: Client, message: ClientMessage): void {
+    if (message.type !== 'operation') {
+      this.sendError(ws, `Unknown message type: ${message.type}`);
+      return;
+    }
+
+    if (!message.operation || typeof message.version !== 'number') {
+      this.sendError(ws, 'operation and version are required');
+      return;
+    }
+
+    const validationError = validate(message.operation);
+    if (validationError) {
+      this.sendError(ws, `Invalid operation: ${validationError}`);
+      return;
+    }
+
+    const session = this.sessions.get(client.documentId);
+    if (!session) {
+      this.sendError(ws, 'Document session not found');
+      return;
+    }
+
+    const clientVersion = message.version;
+    if (clientVersion < 0 || clientVersion > session.version) {
+      this.sendError(ws, `Invalid version: ${clientVersion} (server is at ${session.version})`);
+      return;
+    }
+
+    let op = message.operation;
+
+    // Transform against all operations that have happened since the client's version
+    const startIdx = clientVersion - session.baseVersion;
+
+    if (startIdx < 0) {
+      this.sendError(ws, `Version ${clientVersion} is too old, cannot transform`);
+      return;
+    }
+
+    for (let i = startIdx; i < session.ops.length; i++) {
+      try {
+        const [transformedOp] = transform(op, session.ops[i]);
+        op = transformedOp;
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : 'Transform failed';
+        this.sendError(ws, `Transform error: ${msg}`);
+        return;
+      }
+    }
+
+    // Validate that the operation fits the current document
+    if (inputLength(op) !== session.content.length) {
+      this.sendError(
+        ws,
+        `Operation input length (${inputLength(op)}) does not match document length (${session.content.length})`
+      );
+      return;
+    }
+
+    // Apply the transformed operation
+    let newContent: string;
+    try {
+      newContent = apply(session.content, op);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : 'Apply failed';
+      this.sendError(ws, `Apply error: ${msg}`);
+      return;
+    }
+
+    const newVersion = session.version + 1;
+
+    // Persist to database first — if this fails, we don't update in-memory state
+    try {
+      this.store.updateDocumentContent(
+        client.documentId,
+        newContent,
+        newVersion,
+        JSON.stringify(op)
+      );
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : 'Persistence failed';
+      this.sendError(ws, `Persistence error: ${msg}`);
+      return;
+    }
+
+    // Only update in-memory state after successful persistence
+    session.content = newContent;
+    session.version = newVersion;
+    session.ops.push(op);
+    this.pruneOps(session);
+
+    // Acknowledge to sender
+    this.send(ws, {
+      type: 'ack',
+      version: session.version,
+    });
+
+    // Broadcast to other clients on same document
+    this.broadcast(client.documentId, ws, {
+      type: 'operation',
+      operation: op,
+      version: session.version,
+    });
+  }
+
+  private send(ws: WebSocket, data: unknown): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(data));
+    }
+  }
+
+  private sendError(ws: WebSocket, message: string): void {
+    this.send(ws, { type: 'error', message });
+  }
+
+  private broadcast(documentId: string, exclude: WebSocket, data: unknown): void {
+    const msg = JSON.stringify(data);
+    for (const [clientWs, client] of this.clients) {
+      if (client.documentId === documentId && clientWs !== exclude && clientWs.readyState === WebSocket.OPEN) {
+        clientWs.send(msg);
+      }
+    }
+  }
+
+  /** Evict a document session and disconnect all clients on it. */
+  evictDocument(documentId: string): void {
+    this.sessions.delete(documentId);
+    for (const [ws, client] of this.clients) {
+      if (client.documentId === documentId) {
+        this.send(ws, { type: 'error', message: 'Document has been deleted' });
+        ws.close(1008, 'Document deleted');
+        this.clients.delete(ws);
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const [ws] of this.clients) {
+      ws.close(1001, 'Server shutting down');
+    }
+    this.clients.clear();
+    this.sessions.clear();
+  }
+}
diff --git a/src/database.ts b/src/database.ts
new file mode 100644
index 0000000..12e6d81
--- /dev/null
+++ b/src/database.ts
@@ -0,0 +1,170 @@
+import Database from 'better-sqlite3';
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operations: string;
+  created_at: string;
+}
+
+export function createDatabase(dbPath: string = ':memory:'): Database.Database {
+  const db = Database(dbPath);
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      version INTEGER NOT NULL DEFAULT 0,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      operations TEXT NOT NULL DEFAULT '[]',
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE,
+      UNIQUE(document_id, version)
+    );
+
+    CREATE INDEX IF NOT EXISTS idx_versions_doc_version
+      ON versions(document_id, version);
+  `);
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+  private stmts: {
+    insert: Database.Statement;
+    getById: Database.Statement;
+    getAll: Database.Statement;
+    update: Database.Statement;
+    updateContent: Database.Statement;
+    delete: Database.Statement;
+    insertVersion: Database.Statement;
+    getVersions: Database.Statement;
+    getVersion: Database.Statement;
+    getOpsFrom: Database.Statement;
+  };
+
+  private createDocumentTxn: Database.Transaction<
+    (id: string, title: string, content: string) => DocumentRow
+  >;
+
+  private updateContentTxn: Database.Transaction<
+    (id: string, content: string, version: number, operations: string) => DocumentRow
+  >;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+    this.stmts = {
+      insert: db.prepare(
+        `INSERT INTO documents (id, title, content, version) VALUES (?, ?, ?, 0)`
+      ),
+      getById: db.prepare(`SELECT * FROM documents WHERE id = ?`),
+      getAll: db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`),
+      update: db.prepare(
+        `UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?`
+      ),
+      updateContent: db.prepare(
+        `UPDATE documents SET content = ?, version = ?, updated_at = datetime('now') WHERE id = ?`
+      ),
+      delete: db.prepare(`DELETE FROM documents WHERE id = ?`),
+      insertVersion: db.prepare(
+        `INSERT INTO versions (document_id, version, content, operations) VALUES (?, ?, ?, ?)`
+      ),
+      getVersions: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+      ),
+      getVersion: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? AND version = ?`
+      ),
+      getOpsFrom: db.prepare(
+        `SELECT operations, version FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC`
+      ),
+    };
+
+    this.createDocumentTxn = db.transaction(
+      (id: string, title: string, content: string) => {
+        this.stmts.insert.run(id, title, content);
+        this.stmts.insertVersion.run(id, 0, content, '[]');
+        return this.stmts.getById.get(id) as DocumentRow;
+      }
+    );
+
+    this.updateContentTxn = db.transaction(
+      (id: string, content: string, version: number, operations: string) => {
+        this.stmts.updateContent.run(content, version, id);
+        this.stmts.insertVersion.run(id, version, content, operations);
+        return this.stmts.getById.get(id) as DocumentRow;
+      }
+    );
+  }
+
+  createDocument(id: string, title: string, content: string = ''): DocumentRow {
+    return this.createDocumentTxn(id, title, content);
+  }
+
+  getDocument(id: string): DocumentRow | undefined {
+    return this.stmts.getById.get(id) as DocumentRow | undefined;
+  }
+
+  getAllDocuments(): DocumentRow[] {
+    return this.stmts.getAll.all() as DocumentRow[];
+  }
+
+  updateDocumentTitle(id: string, title: string): DocumentRow | undefined {
+    const result = this.stmts.update.run(title, id);
+    if (result.changes === 0) return undefined;
+    return this.stmts.getById.get(id) as DocumentRow;
+  }
+
+  updateDocumentContent(
+    id: string,
+    content: string,
+    version: number,
+    operations: string
+  ): DocumentRow | undefined {
+    return this.updateContentTxn(id, content, version, operations);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.stmts.delete.run(id);
+    return result.changes > 0;
+  }
+
+  getVersionHistory(documentId: string): VersionRow[] {
+    return this.stmts.getVersions.all(documentId) as VersionRow[];
+  }
+
+  getVersion(documentId: string, version: number): VersionRow | undefined {
+    return this.stmts.getVersion.get(documentId, version) as VersionRow | undefined;
+  }
+
+  getOperationsFrom(documentId: string, fromVersion: number): { operations: string; version: number }[] {
+    return this.stmts.getOpsFrom.all(documentId, fromVersion) as { operations: string; version: number }[];
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
