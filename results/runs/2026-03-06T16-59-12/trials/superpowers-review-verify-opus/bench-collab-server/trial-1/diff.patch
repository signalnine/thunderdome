dleConnection(ws: WebSocket, req: IncomingMessage): void {\n    const documentId = this.getDocumentIdFromUrl(req.url);\n    if (!documentId) {\n      this.sendError(ws, 'Invalid URL: document ID required');\n      ws.close(1008, 'Document ID required');\n      return;\n    }\n\n    const session = this.getOrCreateSession(documentId);\n    if (!session) {\n      this.sendError(ws, 'Document not found');\n      ws.close(1008, 'Document not found');\n      return;\n    }\n\n    const client: Client = { ws, documentId };\n    this.clients.set(ws, client);\n\n    // Send initial sync\n    this.send(ws, {\n      type: 'sync',\n      content: session.content,\n      version: session.version,\n    });\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString()) as ClientMessage;\n        this.handleMessage(ws, client, message);\n      } catch (err) {\n        this.sendError(ws, 'Invalid message format');\n      }\n    });\n\n    ws.on('close', () => {\n      this.clients.delete(ws);\n    });\n\n    ws.on('error', () => {\n      this.clients.delete(ws);\n    });\n  }\n\n  private handleMessage(ws: WebSocket, client: Client, message: ClientMessage): void {\n    if (message.type !== 'operation') {\n      this.sendError(ws, `Unknown message type: ${message.type}`);\n      return;\n    }\n\n    if (!message.operation || typeof message.version !== 'number') {\n      this.sendError(ws, 'operation and version are required');\n      return;\n    }\n\n    const validationError = validate(message.operation);\n    if (validationError) {\n      this.sendError(ws, `Invalid operation: ${validationError}`);\n      return;\n    }\n\n    const session = this.sessions.get(client.documentId);\n    if (!session) {\n      this.sendError(ws, 'Document session not found');\n      return;\n    }\n\n    const clientVersion = message.version;\n    if (clientVersion < 0 || clientVersion > session.version) {\n      this.sendError(ws, `Invalid version: ${clientVersion} (server is at ${session.version})`);\n      return;\n    }\n\n    let op = message.operation;\n\n    // Transform against all operations that have happened since the client's version\n    const baseVersion = session.version - session.ops.length;\n    const startIdx = clientVersion - baseVersion;\n\n    if (startIdx < 0 || startIdx > session.ops.length) {\n      this.sendError(ws, `Version ${clientVersion} is too old, cannot transform`);\n      return;\n    }\n\n    for (let i = startIdx; i < session.ops.length; i++) {\n      try {\n        const [transformedOp] = transform(op, session.ops[i]);\n        op = transformedOp;\n      } catch (err) {\n        const msg = err instanceof Error ? err.message : 'Transform failed';\n        this.sendError(ws, `Transform error: ${msg}`);\n        return;\n      }\n    }\n\n    // Validate that the operation fits the current document\n    if (inputLength(op) !== session.content.length) {\n      this.sendError(\n        ws,\n        `Operation input length (${inputLength(op)}) does not match document length (${session.content.length})`\n      );\n      return;\n    }\n\n    // Apply the transformed operation\n    try {\n      session.content = apply(session.content, op);\n    } catch (err) {\n      const msg = err instanceof Error ? err.message : 'Apply failed';\n      this.sendError(ws, `Apply error: ${msg}`);\n      return;\n    }\n\n    session.version++;\n    session.ops.push(op);\n\n    // Persist to database\n    this.store.updateDocumentContent(\n      client.documentId,\n      session.content,\n      session.version,\n      JSON.stringify(op)\n    );\n\n    // Acknowledge to sender\n    this.send(ws, {\n      type: 'ack',\n      version: session.version,\n    });\n\n    // Broadcast to other clients on same document\n    this.broadcast(client.documentId, ws, {\n      type: 'operation',\n      operation: op,\n      version: session.version,\n    });\n  }\n\n  private send(ws: WebSocket, data: unknown): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(data));\n    }\n  }\n\n  private sendError(ws: WebSocket, message: string): void {\n    this.send(ws, { type: 'error', message });\n  }\n\n  private broadcast(documentId: string, exclude: WebSocket, data: unknown): void {\n    const msg = JSON.stringify(data);\n    for (const [clientWs, client] of this.clients) {\n      if (client.documentId === documentId && clientWs !== exclude && clientWs.readyState === WebSocket.OPEN) {\n        clientWs.send(msg);\n      }\n    }\n  }\n\n  closeAll(): void {\n    for (const [ws] of this.clients) {\n      ws.close(1001, 'Server shutting down');\n    }\n    this.clients.clear();\n    this.sessions.clear();\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":328,"cache_read_input_tokens":26901,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":328},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a785380d-83fd-49c7-bf44-139e6dae5c7d","uuid":"d3664efc-df51-4b5b-a1e1-3eb8e28a74ce"}
