@@ -0,0 +1,572 @@
+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws an error if any cycle (including self-references) is found.
+ */
+function detectCycles(events: Event[]): void {
+  const eventIds = new Set(events.map(e => e.id));
+
+  // Check for self-references first
+  for (const event of events) {
+    if (event.prerequisites?.includes(event.id)) {
+      throw new Error(`Cycle detected: event "${event.id}" has a self-reference`);
+    }
+  }
+
+  // Build adjacency list: prerequisite -> dependents
+  const adjList = new Map<string, string[]>();
+  for (const event of events) {
+    if (!adjList.has(event.id)) {
+      adjList.set(event.id, []);
+    }
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (eventIds.has(prereq)) {
+          if (!adjList.has(prereq)) {
+            adjList.set(prereq, []);
+          }
+          adjList.get(prereq)!.push(event.id);
+        }
+      }
+    }
+  }
+
+  // DFS cycle detection with coloring:
+  // WHITE (0) = unvisited, GRAY (1) = in current path, BLACK (2) = fully explored
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const id of eventIds) {
+    color.set(id, WHITE);
+  }
+
+  function dfs(node: string): boolean {
+    color.set(node, GRAY);
+    const neighbors = adjList.get(node) || [];
+    for (const neighbor of neighbors) {
+      if (color.get(neighbor) === GRAY) {
+        return true; // cycle found
+      }
+      if (color.get(neighbor) === WHITE && dfs(neighbor)) {
+        return true;
+      }
+    }
+    color.set(node, BLACK);
+    return false;
+  }
+
+  for (const id of eventIds) {
+    if (color.get(id) === WHITE) {
+      if (dfs(id)) {
+        throw new Error('Cycle detected in prerequisite graph');
+      }
+    }
+  }
+}
+
+/**
+ * Topological sort of events based on prerequisites.
+ * Returns event IDs in an order such that prerequisites come before dependents.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventMap = new Map(events.map(e => [e.id, e]));
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjList = new Map<string, string[]>();
+
+  for (const id of eventIds) {
+    inDegree.set(id, 0);
+    adjList.set(id, []);
+  }
+
+  for (const event of events) {
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (eventIds.has(prereq)) {
+          adjList.get(prereq)!.push(event.id);
+          inDegree.set(event.id, (inDegree.get(event.id) || 0) + 1);
+        }
+      }
+    }
+  }
+
+  // Use a priority queue approach: prefer events with fewer attendees first
+  // to leave larger rooms available for bigger events
+  const queue: string[] = [];
+  for (const [id, degree] of inDegree) {
+    if (degree === 0) {
+      queue.push(id);
+    }
+  }
+
+  const result: string[] = [];
+  while (queue.length > 0) {
+    // Sort by number of dependents (descending) to schedule foundational events first
+    queue.sort((a, b) => {
+      const eventA = eventMap.get(a)!;
+      const eventB = eventMap.get(b)!;
+      // Schedule events with more dependents first
+      const depsA = adjList.get(a)?.length || 0;
+      const depsB = adjList.get(b)?.length || 0;
+      if (depsA !== depsB) return depsB - depsA;
+      // Then by duration (longer first to place them early when more flexibility)
+      return eventB.duration - eventA.duration;
+    });
+
+    const node = queue.shift()!;
+    result.push(node);
+
+    for (const neighbor of adjList.get(node)!) {
+      const newDegree = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, newDegree);
+      if (newDegree === 0) {
+        queue.push(neighbor);
+      }
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Find the earliest start time for an event in a given room,
+ * considering existing assignments, prerequisites, and time constraints.
+ */
+function findEarliestStart(
+  event: Event,
+  room: Room,
+  assignments: Assignment[],
+  eventMap: Map<string, Event>,
+  gap: number,
+  startTime: number,
+  endTime: number
+): number | null {
+  // Check capacity
+  const attendees = event.attendees ?? 1;
+  if (attendees > room.capacity) {
+    return null;
+  }
+
+  // Find earliest possible start based on prerequisites
+  let earliest = startTime;
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assignments.find(a => a.eventId === prereqId);
+      if (prereqAssignment) {
+        earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+      } else {
+        // Prerequisite references an event not in our list — ignore
+        // (or it hasn't been scheduled, meaning we can't schedule this one properly)
+        const prereqEvent = eventMap.get(prereqId);
+        if (prereqEvent) {
+          // Prerequisite exists but wasn't scheduled — we can't schedule this event
+          return null;
+        }
+      }
+    }
+  }
+
+  // Check if the event can even fit within the time window
+  if (earliest + event.duration > endTime) {
+    return null;
+  }
+
+  // Get all assignments for this room, sorted by start time
+  const roomAssignments = assignments
+    .filter(a => a.roomId === room.id)
+    .sort((a, b) => a.startTime - b.startTime);
+
+  // Try to find the earliest slot in this room
+  let candidateStart = earliest;
+
+  for (const existing of roomAssignments) {
+    // If the candidate fits before this existing assignment
+    if (candidateStart + event.duration + gap <= existing.startTime) {
+      return candidateStart;
+    }
+    // Otherwise, move candidate past this existing assignment
+    candidateStart = Math.max(candidateStart, existing.endTime + gap);
+  }
+
+  // Check if we can fit after all existing assignments
+  if (candidateStart + event.duration <= endTime) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+/**
+ * Core scheduling function using backtracking with optimization.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  // Detect cycles first
+  detectCycles(events);
+
+  const gap = options.gap ?? 15;
+  const eventMap = new Map(events.map(e => [e.id, e]));
+
+  // Get topologically sorted order
+  const sortedIds = topologicalSort(events);
+
+  // Sort rooms by capacity (ascending) for efficient assignment
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  // Try to schedule events using a greedy approach with backtracking
+  // First, try the greedy approach
+  const greedyResult = greedySchedule(sortedIds, eventMap, sortedRooms, options, gap);
+
+  // If all events are scheduled, return
+  if (greedyResult.unscheduled.length === 0) {
+    return greedyResult;
+  }
+
+  // Try to improve by exploring alternative placements
+  const improvedResult = optimizedSchedule(events, eventMap, sortedRooms, options, gap);
+
+  // Return whichever scheduled more events
+  if (improvedResult.assignments.length >= greedyResult.assignments.length) {
+    return improvedResult;
+  }
+
+  return greedyResult;
+}
+
+function greedySchedule(
+  sortedIds: string[],
+  eventMap: Map<string, Event>,
+  sortedRooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): ScheduleResult {
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  for (const eventId of sortedIds) {
+    const event = eventMap.get(eventId)!;
+    let bestRoom: Room | null = null;
+    let bestStart: number | null = null;
+
+    // Try preferred room first
+    if (event.preferredRoom) {
+      const preferredRoom = sortedRooms.find(r => r.id === event.preferredRoom);
+      if (preferredRoom) {
+        const start = findEarliestStart(
+          event, preferredRoom, assignments, eventMap,
+          gap, options.startTime, options.endTime
+        );
+        if (start !== null) {
+          bestRoom = preferredRoom;
+          bestStart = start;
+        }
+      }
+    }
+
+    // If preferred room didn't work, try others
+    if (bestRoom === null) {
+      for (const room of sortedRooms) {
+        const start = findEarliestStart(
+          event, room, assignments, eventMap,
+          gap, options.startTime, options.endTime
+        );
+        if (start !== null) {
+          if (bestStart === null || start < bestStart) {
+            bestRoom = room;
+            bestStart = start;
+          }
+        }
+      }
+    }
+
+    if (bestRoom !== null && bestStart !== null) {
+      assignments.push({
+        eventId: event.id,
+        roomId: bestRoom.id,
+        startTime: bestStart,
+        endTime: bestStart + event.duration,
+      });
+    } else {
+      unscheduled.push(event.id);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
+
+/**
+ * Optimized scheduling that tries multiple strategies and picks the best result.
+ * Uses different orderings and room assignment strategies to maximize scheduled events.
+ */
+function optimizedSchedule(
+  events: Event[],
+  eventMap: Map<string, Event>,
+  sortedRooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): ScheduleResult {
+  const eventIds = new Set(events.map(e => e.id));
+
+  // Build dependency info
+  const dependents = new Map<string, Set<string>>();
+  const prerequisites = new Map<string, Set<string>>();
+  for (const event of events) {
+    dependents.set(event.id, new Set());
+    prerequisites.set(event.id, new Set());
+  }
+  for (const event of events) {
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (eventIds.has(prereq)) {
+          dependents.get(prereq)!.add(event.id);
+          prerequisites.get(event.id)!.add(prereq);
+        }
+      }
+    }
+  }
+
+  // Count transitive dependents
+  function countTransitiveDependents(id: string, visited: Set<string> = new Set()): number {
+    if (visited.has(id)) return 0;
+    visited.add(id);
+    let count = 0;
+    for (const dep of dependents.get(id) || []) {
+      count += 1 + countTransitiveDependents(dep, visited);
+    }
+    return count;
+  }
+
+  // Generate multiple orderings that respect prerequisites
+  function generateOrdering(
+    compareFn: (a: string, b: string) => number
+  ): string[] {
+    const inDegree = new Map<string, number>();
+    const adj = new Map<string, string[]>();
+    for (const id of eventIds) {
+      inDegree.set(id, 0);
+      adj.set(id, []);
+    }
+    for (const event of events) {
+      if (event.prerequisites) {
+        for (const prereq of event.prerequisites) {
+          if (eventIds.has(prereq)) {
+            adj.get(prereq)!.push(event.id);
+            inDegree.set(event.id, (inDegree.get(event.id) || 0) + 1);
+          }
+        }
+      }
+    }
+
+    const queue: string[] = [];
+    for (const [id, degree] of inDegree) {
+      if (degree === 0) queue.push(id);
+    }
+
+    const result: string[] = [];
+    while (queue.length > 0) {
+      queue.sort(compareFn);
+      const node = queue.shift()!;
+      result.push(node);
+      for (const neighbor of adj.get(node)!) {
+        const newDegree = inDegree.get(neighbor)! - 1;
+        inDegree.set(neighbor, newDegree);
+        if (newDegree === 0) queue.push(neighbor);
+      }
+    }
+    return result;
+  }
+
+  const transitiveDeps = new Map<string, number>();
+  for (const id of eventIds) {
+    transitiveDeps.set(id, countTransitiveDependents(id));
+  }
+
+  const orderings: string[][] = [
+    // Strategy 1: Most transitive dependents first
+    generateOrdering((a, b) => {
+      return (transitiveDeps.get(b) || 0) - (transitiveDeps.get(a) || 0);
+    }),
+    // Strategy 2: Shortest duration first (fit more events)
+    generateOrdering((a, b) => {
+      const evA = eventMap.get(a)!;
+      const evB = eventMap.get(b)!;
+      return evA.duration - evB.duration;
+    }),
+    // Strategy 3: Largest attendees first (hardest to place)
+    generateOrdering((a, b) => {
+      const evA = eventMap.get(a)!;
+      const evB = eventMap.get(b)!;
+      return (evB.attendees ?? 1) - (evA.attendees ?? 1);
+    }),
+    // Strategy 4: Longest duration first
+    generateOrdering((a, b) => {
+      const evA = eventMap.get(a)!;
+      const evB = eventMap.get(b)!;
+      return evB.duration - evA.duration;
+    }),
+    // Strategy 5: Most constrained first (fewest eligible rooms)
+    generateOrdering((a, b) => {
+      const evA = eventMap.get(a)!;
+      const evB = eventMap.get(b)!;
+      const eligibleA = sortedRooms.filter(r => r.capacity >= (evA.attendees ?? 1)).length;
+      const eligibleB = sortedRooms.filter(r => r.capacity >= (evB.attendees ?? 1)).length;
+      return eligibleA - eligibleB;
+    }),
+  ];
+
+  let bestResult: ScheduleResult = { assignments: [], unscheduled: events.map(e => e.id) };
+
+  for (const ordering of orderings) {
+    // Try with standard room ordering
+    const result1 = greedySchedule(ordering, eventMap, sortedRooms, options, gap);
+    if (result1.assignments.length > bestResult.assignments.length) {
+      bestResult = result1;
+    }
+
+    // Try with reversed room ordering (largest room first)
+    const reversedRooms = [...sortedRooms].reverse();
+    const result2 = greedySchedule(ordering, eventMap, reversedRooms, options, gap);
+    if (result2.assignments.length > bestResult.assignments.length) {
+      bestResult = result2;
+    }
+
+    // Early exit if all events scheduled
+    if (bestResult.unscheduled.length === 0) {
+      return bestResult;
+    }
+  }
+
+  // If we still have unscheduled events, try backtracking for small instances
+  if (bestResult.unscheduled.length > 0 && events.length <= 20) {
+    const btResult = backtrackSchedule(events, eventMap, sortedRooms, options, gap);
+    if (btResult.assignments.length > bestResult.assignments.length) {
+      bestResult = btResult;
+    }
+  }
+
+  return bestResult;
+}
+
+/**
+ * Backtracking scheduler for smaller problem instances.
+ * Tries to find the optimal placement by exploring different room/time combinations.
+ */
+function backtrackSchedule(
+  events: Event[],
+  eventMap: Map<string, Event>,
+  sortedRooms: Room[],
+  options: ScheduleOptions,
+  gap: number
+): ScheduleResult {
+  const eventIds = new Set(events.map(e => e.id));
+
+  // Build prerequisite info
+  const prereqMap = new Map<string, Set<string>>();
+  for (const event of events) {
+    const prereqs = new Set<string>();
+    if (event.prerequisites) {
+      for (const p of event.prerequisites) {
+        if (eventIds.has(p)) prereqs.add(p);
+      }
+    }
+    prereqMap.set(event.id, prereqs);
+  }
+
+  // Get a topological ordering for the base order
+  const baseOrdering = topologicalSort(events);
+
+  let bestAssignments: Assignment[] = [];
+
+  function backtrack(
+    index: number,
+    assignments: Assignment[],
+    scheduled: Set<string>
+  ): void {
+    // Pruning: even if we schedule all remaining, can we beat best?
+    const remaining = baseOrdering.length - index;
+    if (assignments.length + remaining <= bestAssignments.length) {
+      return;
+    }
+
+    if (index >= baseOrdering.length) {
+      if (assignments.length > bestAssignments.length) {
+        bestAssignments = [...assignments];
+      }
+      return;
+    }
+
+    const eventId = baseOrdering[index];
+    const event = eventMap.get(eventId)!;
+
+    // Check if all prerequisites are scheduled
+    const prereqs = prereqMap.get(eventId)!;
+    let prereqsMet = true;
+    for (const p of prereqs) {
+      if (!scheduled.has(p)) {
+        prereqsMet = false;
+        break;
+      }
+    }
+
+    if (!prereqsMet) {
+      // Skip this event (can't schedule it)
+      backtrack(index + 1, assignments, scheduled);
+      return;
+    }
+
+    // Try placing in each room
+    let placed = false;
+
+    // Try preferred room first
+    const roomOrder = [...sortedRooms];
+    if (event.preferredRoom) {
+      const prefIdx = roomOrder.findIndex(r => r.id === event.preferredRoom);
+      if (prefIdx > 0) {
+        const [prefRoom] = roomOrder.splice(prefIdx, 1);
+        roomOrder.unshift(prefRoom);
+      }
+    }
+
+    for (const room of roomOrder) {
+      const start = findEarliestStart(
+        event, room, assignments, eventMap,
+        gap, options.startTime, options.endTime
+      );
+      if (start !== null) {
+        placed = true;
+        const assignment: Assignment = {
+          eventId: event.id,
+          roomId: room.id,
+          startTime: start,
+          endTime: start + event.duration,
+        };
+        assignments.push(assignment);
+        scheduled.add(eventId);
+        backtrack(index + 1, assignments, scheduled);
+        assignments.pop();
+        scheduled.delete(eventId);
+      }
+    }
+
+    // Also try skipping this event (it might allow better overall placement)
+    backtrack(index + 1, assignments, scheduled);
+
+    if (!placed && assignments.length > bestAssignments.length) {
+      bestAssignments = [...assignments];
+    }
+  }
+
+  backtrack(0, [], new Set());
+
+  const scheduledIds = new Set(bestAssignments.map(a => a.eventId));
+  const unscheduled = events.filter(e => !scheduledIds.has(e.id)).map(e => e.id);
+
+  return { assignments: bestAssignments, unscheduled };
+}
