index 0000000..87a91ef
--- /dev/null
+++ b/src/tracker.test.ts
@@ -0,0 +1,200 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "./tracker.js";
+import { mkdirSync, rmSync, existsSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+const testDir = join(tmpdir(), "time-tracker-test-" + process.pid);
+
+function testFile(name: string): string {
+  return join(testDir, name);
+}
+
+beforeEach(() => {
+  mkdirSync(testDir, { recursive: true });
+});
+
+afterEach(() => {
+  rmSync(testDir, { recursive: true, force: true });
+});
+
+describe("TimeTracker", () => {
+  describe("start and stop", () => {
+    it("should start and stop a timer", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      tracker.start("coding");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].start).toBeTypeOf("number");
+      expect(entries[0].stop).toBeTypeOf("number");
+      expect(entries[0].stop!).toBeGreaterThanOrEqual(entries[0].start);
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].stop).toBeNull();
+    });
+
+    it("should throw when starting with empty name", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      tracker.start("task");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      tracker.start("编码");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("编码");
+    });
+
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      tracker.start("🚀 Launch prep");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 Launch prep");
+    });
+
+    it("should persist unicode names correctly", () => {
+      const fp = testFile("unicode.json");
+      const tracker = new TimeTracker(fp);
+      tracker.start("日本語テスト 🎌");
+      tracker.stop();
+      tracker.save();
+
+      const tracker2 = new TimeTracker(fp);
+      tracker2.load();
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("日本語テスト 🎌");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should save and load entries", () => {
+      const fp = testFile("persist.json");
+      const tracker = new TimeTracker(fp);
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+      tracker.save();
+
+      const tracker2 = new TimeTracker(fp);
+      tracker2.load();
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[1].task).toBe("task2");
+    });
+
+    it("should create directories automatically", () => {
+      const fp = join(testDir, "nested", "deep", "data.json");
+      const tracker = new TimeTracker(fp);
+      tracker.start("task");
+      tracker.stop();
+      tracker.save();
+      expect(existsSync(fp)).toBe(true);
+    });
+
+    it("should handle loading from non-existent file", () => {
+      const tracker = new TimeTracker(testFile("nonexistent.json"));
+      tracker.load();
+      expect(tracker.getEntries()).toHaveLength(0);
+    });
+  });
+
+  describe("getEntries with date filter", () => {
+    it("should filter entries by date range", () => {
+      const fp = testFile("filter.json");
+      const tracker = new TimeTracker(fp);
+
+      tracker.start("old task");
+      tracker.stop();
+      tracker.start("new task");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+
+      // Test with a clear boundary
+      const futureDate = new Date(entries[1].start + 100000);
+      const emptyResult = tracker.getEntries({ from: futureDate });
+      expect(emptyResult).toHaveLength(0);
+
+      // Test 'to' filter
+      const pastDate = new Date(entries[0].start - 1);
+      const noneBeforePast = tracker.getEntries({ to: pastDate });
+      expect(noneBeforePast).toHaveLength(0);
+
+      // Test range that includes all
+      const allInRange = tracker.getEntries({
+        from: new Date(entries[0].start),
+        to: new Date(entries[1].start),
+      });
+      expect(allInRange).toHaveLength(2);
+    });
+
+    it("should return all entries when no filter provided", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      tracker.start("a");
+      tracker.stop();
+      tracker.start("b");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task name", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("review");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeTypeOf("number");
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["review"]).toBeTypeOf("number");
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker(testFile("data.json"));
+      tracker.start("running");
+
+      const summary = tracker.getSummary();
+      expect(summary["running"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+});
diff --git a/src/tracker.ts b/src/tracker.ts
new file mode 100644
index 0000000..68629f9
--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,104 @@
+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: number;
+  stop: number | null;
+}
+
+export interface DateRangeFilter {
+  from?: Date;
+  to?: Date;
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // If a timer is currently running, stop it first
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = Date.now();
+    }
+
+    this.entries.push({
+      task,
+      start: Date.now(),
+      stop: null,
+    });
+  }
+
+  stop(): void {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+    running.stop = Date.now();
+  }
+
+  getEntries(filter?: DateRangeFilter): TimeEntry[] {
+    if (!filter) {
+      return [...this.entries];
+    }
+
+    const fromMs = filter.from ? filter.from.getTime() : -Infinity;
+    const toMs = filter.to ? filter.to.getTime() : Infinity;
+
+    return this.entries.filter((entry) => {
+      return entry.start >= fromMs && entry.start <= toMs;
+    });
+  }
+
+  getSummary(): TimeSummary {
+    const summary: TimeSummary = {};
+
+    for (const entry of this.entries) {
+      const end = entry.stop ?? Date.now();
+      const duration = end - entry.start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+
+  save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+
+  load(): void {
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (!Array.isArray(parsed)) {
+        throw new Error("Invalid data format: expected an array");
+      }
+      this.entries = parsed as TimeEntry[];
+    } catch (err) {
+      if (err instanceof Error && "code" in err && (err as NodeJS.ErrnoException).code === "ENOENT") {
+        this.entries = [];
+        return;
+      }
+      throw err;
+    }
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((entry) => entry.stop === null);
+  }
+}
