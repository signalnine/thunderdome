json({ error: 'Parent folder not found' });\n        return;\n      }\n      if (!hasPermission(store, user.id, 'folder', parentId, 'editor')) {\n        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n        return;\n      }\n    }\n\n    const folder = {\n      id: generateId(),\n      name,\n      parentId: parentId || null,\n      ownerId: user.id,\n      createdAt: new Date().toISOString(),\n    };\n\n    store.folders.set(folder.id, folder);\n\n    // Owner permission\n    store.permissions.push({\n      id: generateId(),\n      resourceType: 'folder',\n      resourceId: folder.id,\n      userId: user.id,\n      role: 'owner',\n    });\n\n    // Log activity\n    store.activityLog.push({\n      id: generateId(),\n      action: 'folder_created',\n      userId: user.id,\n      resourceType: 'folder',\n      resourceId: folder.id,\n      timestamp: new Date().toISOString(),\n    });\n\n    res.status(201).json(folder);\n  });\n\n  // Get folder\n  router.get('/:id', (req, res) => {\n    const { id } = req.params;\n    const user = req.user!;\n\n    const folder = store.folders.get(id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, user.id, 'folder', id, 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Get child folders and documents\n    const children: string[] = [];\n    for (const [childId, childFolder] of store.folders) {\n      if (childFolder.parentId === id) {\n        children.push(childId);\n      }\n    }\n\n    const documents: string[] = [];\n    for (const [docId, doc] of store.documents) {\n      if (doc.folderId === id) {\n        documents.push(docId);\n      }\n    }\n\n    res.status(200).json({\n      ...folder,\n      children,\n      documents,\n    });\n  });\n\n  // Update folder\n  router.put('/:id', (req, res) => {\n    const { id } = req.params;\n    const { name } = req.body;\n    const user = req.user!;\n\n    const folder = store.folders.get(id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, user.id, 'folder', id, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    if (name && typeof name === 'string') {\n      folder.name = name;\n    }\n\n    // Log activity\n    store.activityLog.push({\n      id: generateId(),\n      action: 'folder_updated',\n      userId: user.id,\n      resourceType: 'folder',\n      resourceId: folder.id,\n      timestamp: new Date().toISOString(),\n    });\n\n    res.status(200).json(folder);\n  });\n\n  // Delete folder\n  router.delete('/:id', (req, res) => {\n    const { id } = req.params;\n    const user = req.user!;\n\n    const folder = store.folders.get(id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, user.id, 'folder', id, 'owner')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Recursively delete child folders and documents\n    deleteFolderRecursive(store, id, user.id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n\nfunction deleteFolderRecursive(store: Store, folderId: string, userId: string): void {\n  // Delete child folders recursively\n  for (const [childId, childFolder] of store.folders) {\n    if (childFolder.parentId === folderId) {\n      deleteFolderRecursive(store, childId, userId);\n    }\n  }\n\n  // Delete documents in this folder\n  for (const [docId, doc] of store.documents) {\n    if (doc.folderId === folderId) {\n      store.documents.delete(docId);\n      store.permissions = store.permissions.filter(\n        (p) => !(p.resourceType === 'document' && p.resourceId === docId),\n      );\n      store.activityLog.push({\n        id: generateId(),\n        action: 'document_deleted',\n        userId,\n        resourceType: 'document',\n        resourceId: docId,\n        timestamp: new Date().toISOString(),\n      });\n    }\n  }\n\n  // Delete the folder itself\n  store.folders.delete(folderId);\n  store.permissions = store.permissions.filter(\n    (p) => !(p.resourceType === 'folder' && p.resourceId === folderId),\n  );\n\n  // Log activity\n  store.activityLog.push({\n    id: generateId(),\n    action: 'folder_deleted',\n    userId,\n    resourceType: 'folder',\n    resourceId: folderId,\n    timestamp: new Date().toISOString(),\n  });\n}\n","numLines":205,"startLine":1,"totalLines":205}}}
