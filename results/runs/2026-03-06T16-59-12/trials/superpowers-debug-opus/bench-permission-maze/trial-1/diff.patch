+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import type { Express } from 'express';
+import { createApp } from './app.js';
+
+let app: Express;
+
+// Helper functions
+async function registerUser(username: string, password: string) {
+  const res = await request(app)
+    .post('/auth/register')
+    .send({ username, password });
+  return res;
+}
+
+async function loginUser(username: string, password: string) {
+  const res = await request(app)
+    .post('/auth/login')
+    .send({ username, password });
+  return res;
+}
+
+async function registerAndLogin(username: string, password: string) {
+  await registerUser(username, password);
+  const loginRes = await loginUser(username, password);
+  return { token: loginRes.body.token, userId: loginRes.body.user.id };
+}
+
+async function createFolder(token: string, name: string, parentId?: string) {
+  const body: Record<string, string> = { name };
+  if (parentId) body.parentId = parentId;
+  const res = await request(app)
+    .post('/folders')
+    .set('Authorization', `Bearer ${token}`)
+    .send(body);
+  return res;
+}
+
+async function createDocument(token: string, title: string, content: string, folderId: string) {
+  const res = await request(app)
+    .post('/documents')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ title, content, folderId });
+  return res;
+}
+
+async function shareResource(
+  token: string,
+  resourceType: string,
+  resourceId: string,
+  userId: string,
+  role: string,
+) {
+  const res = await request(app)
+    .post('/share')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ resourceType, resourceId, userId, role });
+  return res;
+}
+
+describe('Document Management API', () => {
+  beforeEach(() => {
+    app = createApp();
+  });
+
+  // =====================
+  // AUTH TESTS
+  // =====================
+  describe('Authentication', () => {
+    it('should register a new user', async () => {
+      const res = await registerUser('alice', 'password123');
+      expect(res.status).toBe(201);
+      expect(res.body).toHaveProperty('id');
+      expect(res.body.username).toBe('alice');
+      expect(res.body).not.toHaveProperty('password');
+    });
+
+    it('should reject duplicate username', async () => {
+      await registerUser('alice', 'password123');
+      const res = await registerUser('alice', 'otherpass');
+      expect(res.status).toBe(409);
+    });
+
+    it('should reject registration with missing fields', async () => {
+      const res = await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice' });
+      expect(res.status).toBe(400);
+    });
+
+    it('should login with valid credentials', async () => {
+      await registerUser('alice', 'password123');
+      const res = await loginUser('alice', 'password123');
+      expect(res.status).toBe(200);
+      expect(res.body).toHaveProperty('token');
+      expect(res.body.user.username).toBe('alice');
+    });
+
+    it('should reject login with invalid password', async () => {
+      await registerUser('alice', 'password123');
+      const res = await loginUser('alice', 'wrongpass');
+      expect(res.status).toBe(401);
+    });
+
+    it('should reject login with non-existent user', async () => {
+      const res = await loginUser('nobody', 'password');
+      expect(res.status).toBe(401);
+    });
+
+    it('should reject requests without auth token', async () => {
+      const res = await request(app).get('/folders/123');
+      expect(res.status).toBe(401);
+    });
+
+    it('should reject requests with invalid token', async () => {
+      const res = await request(app)
+        .get('/folders/123')
+        .set('Authorization', 'Bearer invalidtoken');
+      expect(res.status).toBe(401);
+    });
+  });
+
+  // =====================
+  // FOLDER TESTS
+  // =====================
+  describe('Folders', () => {
+    let token: string;
+    let userId: string;
+
+    beforeEach(async () => {
+      const user = await registerAndLogin('alice', 'pass');
+      token = user.token;
+      userId = user.userId;
+    });
+
+    it('should create a root folder', async () => {
+      const res = await createFolder(token, 'My Folder');
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe('My Folder');
+      expect(res.body.parentId).toBeNull();
+      expect(res.body.ownerId).toBe(userId);
+    });
+
+    it('should create a nested folder', async () => {
+      const parent = await createFolder(token, 'Parent');
+      const child = await createFolder(token, 'Child', parent.body.id);
+      expect(child.status).toBe(201);
+      expect(child.body.parentId).toBe(parent.body.id);
+    });
+
+    it('should reject folder creation with missing name', async () => {
+      const res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({});
+      expect(res.status).toBe(400);
+    });
+
+    it('should reject nested folder with non-existent parent', async () => {
+      const res = await createFolder(token, 'Child', 'non-existent-id');
+      expect(res.status).toBe(404);
+    });
+
+    it('should get a folder with children and documents', async () => {
+      const parent = await createFolder(token, 'Parent');
+      const child = await createFolder(token, 'Child', parent.body.id);
+      const doc = await createDocument(token, 'Doc', 'content', parent.body.id);
+
+      const res = await request(app)
+        .get(`/folders/${parent.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('Parent');
+      expect(res.body.children).toContain(child.body.id);
+      expect(res.body.documents).toContain(doc.body.id);
+    });
+
+    it('should return 404 for non-existent folder', async () => {
+      const res = await request(app)
+        .get('/folders/non-existent')
+        .set('Authorization', `Bearer ${token}`);
+      expect(res.status).toBe(404);
+    });
+
+    it('should update a folder name', async () => {
+      const folder = await createFolder(token, 'Original');
+      const res = await request(app)
+        .put(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Updated' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('Updated');
+    });
+
+    it('should delete a folder', async () => {
+      const folder = await createFolder(token, 'ToDelete');
+      const res = await request(app)
+        .delete(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(204);
+
+      const getRes = await request(app)
+        .get(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+      expect(getRes.status).toBe(404);
+    });
+
+    it('should recursively delete child folders and documents', async () => {
+      const parent = await createFolder(token, 'Parent');
+      const child = await createFolder(token, 'Child', parent.body.id);
+      await createDocument(token, 'Doc', 'content', child.body.id);
+
+      await request(app)
+        .delete(`/folders/${parent.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      const childRes = await request(app)
+        .get(`/folders/${child.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+      expect(childRes.status).toBe(404);
+    });
+  });
+
+  // =====================
+  // DOCUMENT TESTS
+  // =====================
+  describe('Documents', () => {
+    let token: string;
+    let folderId: string;
+
+    beforeEach(async () => {
+      const user = await registerAndLogin('alice', 'pass');
+      token = user.token;
+      const folder = await createFolder(token, 'Docs');
+      folderId = folder.body.id;
+    });
+
+    it('should create a document', async () => {
+      const res = await createDocument(token, 'My Doc', 'Hello world', folderId);
+      expect(res.status).toBe(201);
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('Hello world');
+      expect(res.body.folderId).toBe(folderId);
+    });
+
+    it('should reject document creation with missing title', async () => {
+      const res = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ content: 'text', folderId });
+      expect(res.status).toBe(400);
+    });
+
+    it('should reject document creation with missing folderId', async () => {
+      const res = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'text' });
+      expect(res.status).toBe(400);
+    });
+
+    it('should reject document creation for non-existent folder', async () => {
+      const res = await createDocument(token, 'Doc', 'text', 'non-existent-id');
+      expect(res.status).toBe(404);
+    });
+
+    it('should get a document', async () => {
+      const doc = await createDocument(token, 'Doc', 'content', folderId);
+      const res = await request(app)
+        .get(`/documents/${doc.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('Doc');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      const res = await request(app)
+        .get('/documents/non-existent')
+        .set('Authorization', `Bearer ${token}`);
+      expect(res.status).toBe(404);
+    });
+
+    it('should update a document', async () => {
