ce(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n      const res = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(res.status).toBe(200);\n    });\n\n    it('should deny viewer from editing folder', async () => {\n      const folder = await createFolder(aliceToken, 'Shared');\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Renamed' });\n      expect(res.status).toBe(403);\n    });\n\n    it('should allow editor to modify folder', async () => {\n      const folder = await createFolder(aliceToken, 'Shared');\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Renamed by Bob' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Renamed by Bob');\n    });\n\n    it('should deny editor from deleting folder', async () => {\n      const folder = await createFolder(aliceToken, 'Shared');\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n      const res = await request(app)\n        .delete(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(res.status).toBe(403);\n    });\n\n    it('should share a document', async () => {\n      const folder = await createFolder(aliceToken, 'Folder');\n      const doc = await createDocument(aliceToken, 'Doc', 'content', folder.body.id);\n\n      // Bob can't access initially\n      let res = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(res.status).toBe(403);\n\n      // Share with bob as viewer\n      await shareResource(aliceToken, 'document', doc.body.id, bobId, 'viewer');\n\n      // Now bob can read\n      res = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(res.status).toBe(200);\n    });\n\n    it('should inherit folder permissions for documents', async () => {\n      const folder = await createFolder(aliceToken, 'Shared Folder');\n      const doc = await createDocument(aliceToken, 'Doc', 'content', folder.body.id);\n\n      // Share folder with bob as viewer\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n      // Bob should be able to read document in shared folder\n      const res = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(res.status).toBe(200);\n    });\n\n    it('should inherit nested folder permissions', async () => {\n      const parent = await createFolder(aliceToken, 'Parent');\n      const child = await createFolder(aliceToken, 'Child', parent.body.id);\n\n      // Share parent with bob as viewer\n      await shareResource(aliceToken, 'folder', parent.body.id, bobId, 'viewer');\n\n      // Bob should be able to read child folder\n      const res = await request(app)\n        .get(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(res.status).toBe(200);\n    });\n\n    it('should use most permissive role from multiple paths', async () => {\n      const folder = await createFolder(aliceToken, 'Folder');\n      const doc = await createDocument(aliceToken, 'Doc', 'content', folder.body.id);\n\n      // Share folder with bob as viewer\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n      // Share document directly with bob as editor\n      await shareResource(aliceToken, 'document', doc.body.id, bobId, 'editor');\n\n      // Bob should be able to edit (most permissive from direct share)\n      const res = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'updated by bob' });\n      expect(res.status).toBe(200);\n    });\n\n    it('should reject sharing with missing fields', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ resourceType: 'folder' });\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject sharing non-existent resource', async () => {\n      const res = await shareResource(aliceToken, 'folder', 'non-existent', bobId, 'viewer');\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject sharing to non-existent user', async () => {\n      const folder = await createFolder(aliceToken, 'Folder');\n      const res = await shareResource(aliceToken, 'folder', folder.body.id, 'non-existent', 'viewer');\n      expect(res.status).toBe(404);\n    });\n\n    it('should allow editor to share with others', async () => {\n      const charlie = await registerAndLogin('charlie', 'pass');\n      const folder = await createFolder(aliceToken, 'Folder');\n\n      // Alice shares with Bob as editor\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n      // Bob should be able to share with Charlie\n      const res = await shareResource(bobToken, 'folder', folder.body.id, charlie.userId, 'viewer');\n      expect(res.status).toBe(200);\n    });\n\n    it('should deny viewer from sharing', async () => {\n      const charlie = await registerAndLogin('charlie', 'pass');\n      const folder = await createFolder(aliceToken, 'Folder');\n\n      // Alice shares with Bob as viewer\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n      // Bob should not be able to share with Charlie\n      const res = await shareResource(bobToken, 'folder', folder.body.id, charlie.userId, 'viewer');\n      expect(res.status).toBe(403);\n    });\n\n    it('should allow editor with folder permission to create documents', async () => {\n      const folder = await createFolder(aliceToken, 'Shared Folder');\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n      const res = await createDocument(bobToken, 'Bob Doc', 'from bob', folder.body.id);\n      expect(res.status).toBe(201);\n    });\n\n    it('should deny viewer from creating documents in folder', async () => {\n      const folder = await createFolder(aliceToken, 'Shared Folder');\n      await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n      const res = await createDocument(bobToken, 'Bob Doc', 'from bob', folder.body.id);\n      expect(res.status).toBe(403);\n    });\n  });\n\n  // =====================\n  // ACTIVITY LOG TESTS\n  // =====================\n  describe('Activity Log', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const user = await registerAndLogin('alice', 'pass');\n      token = user.token;\n    });\n\n    it('should log document creation', async () => {\n      const folder = await createFolder(token, 'Folder');\n      await createDocument(token, 'Doc', 'content', folder.body.id);\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(Array.isArray(res.body)).toBe(true);\n\n      const docCreated = res.body.find(\n        (a: Record<string, string>) => a.action === 'document_created',\n      );\n      expect(docCreated).toBeDefined();\n      expect(docCreated.resourceType).toBe('document');\n    });\n\n    it('should log document update', async () => {\n      const folder = await createFolder(token, 'Folder');\n      const doc = await createDocument(token, 'Doc', 'content', folder.body.id);\n\n      await request(app)\n        .put(`/document