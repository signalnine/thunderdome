+      // Share folder as editor, document as viewer
+      await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'editor');
+      await shareResource(alice.token, 'document', doc.body.id, bob.userId, 'viewer');
+
+      // Bob should get the most permissive (editor from folder)
+      const res = await request(app)
+        .put(`/documents/${doc.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`)
