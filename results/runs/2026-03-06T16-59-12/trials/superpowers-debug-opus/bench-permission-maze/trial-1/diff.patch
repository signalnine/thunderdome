: Role = role === 'owner' ? 'owner' : 'editor';\n    if (!hasPermission(store, currentUser.id, typedResourceType, resourceId, requiredRole)) {\n      res.status(403).json({ error: 'Insufficient permissions to share this resource' });\n      return;\n    }\n\n    // Remove existing permission for same user+resource if exists\n    store.permissions = store.permissions.filter(\n      (p) =>\n        !(\n          p.resourceType === typedResourceType &&\n          p.resourceId === resourceId &&\n          p.userId === userId\n        ),\n    );\n\n    // Add new permission\n    const permission = {\n      id: generateId(),\n      resourceType: typedResourceType,\n      resourceId,\n      userId,\n      role: role as Role,\n    };\n    store.permissions.push(permission);\n\n    // Log activity\n    store.activityLog.push({\n      id: generateId(),\n      action: 'resource_shared',\n      userId: currentUser.id,\n      resourceType: typedResourceType,\n      resourceId,\n      timestamp: new Date().toISOString(),\n      details: {\n        sharedWith: userId,\n        role,\n      },\n    });\n\n    res.status(200).json(permission);\n  });\n\n  return router;\n}\n","numLines":101,"startLine":1,"totalLines":101}}}
