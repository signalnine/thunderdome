@@ -0,0 +1,169 @@
+import { Router } from 'express';
+import type { Store } from '../store.js';
+import { generateId } from '../helpers.js';
+import { authMiddleware, type AuthenticatedRequest } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function documentsRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create document
+  router.post('/', (req, res) => {
+    const { title, content, folderId } = req.body;
+    const user = (req as AuthenticatedRequest).user!;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    if (!folderId || typeof folderId !== 'string') {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+    const doc = {
+      id: generateId(),
+      title,
+      content: String(content),
+      folderId,
+      ownerId: user.id,
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    store.documents.set(doc.id, doc);
+
+    // Owner permission
+    store.permissions.push({
+      id: generateId(),
+      resourceType: 'document',
+      resourceId: doc.id,
+      userId: user.id,
+      role: 'owner',
+    });
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_created',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req, res) => {
+    const { id } = req.params;
+    const user = (req as AuthenticatedRequest).user!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'document', id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req, res) => {
+    const { id } = req.params;
+    const { title, content } = req.body;
+    const user = (req as AuthenticatedRequest).user!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'document', id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (title !== undefined && typeof title === 'string') {
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_updated',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req, res) => {
+    const { id } = req.params;
+    const user = (req as AuthenticatedRequest).user!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, user.id, 'document', id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    store.documents.delete(id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === id),
+    );
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_deleted',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
