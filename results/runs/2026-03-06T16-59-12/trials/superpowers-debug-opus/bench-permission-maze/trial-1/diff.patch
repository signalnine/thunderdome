     if (!store.folders.has(resourceId)) {\n        res.status(404).json({ error: 'Folder not found' });\n        return;\n      }\n    } else {\n      if (!store.documents.has(resourceId)) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n    }\n\n    // Verify target user exists\n    if (!store.users.has(userId)) {\n      res.status(404).json({ error: 'Target user not found' });\n      return;\n    }\n\n    // Check permissions: editors can share, owners can share and manage roles\n    const requiredRole: Role = role === 'owner' ? 'owner' : 'editor';\n    if (!hasPermission(store, currentUser.id, typedResourceType, resourceId, requiredRole)) {\n      res.status(403).json({ error: 'Insufficient permissions to share this resource' });\n      return;\n    }\n\n    // Remove existing permission for same user+resource if exists\n    store.permissions = store.permissions.filter(\n      (p) =>\n        !(\n          p.resourceType === typedResourceType &&\n          p.resourceId === resourceId &&\n          p.userId === userId\n        ),\n    );\n\n    // Add new permission\n    const permission = {\n      id: generateId(),\n      resourceType: typedResourceType,\n      resourceId,\n      userId,\n      role: role as Role,\n    };\n    store.permissions.push(permission);\n\n    // Log activity\n    store.activityLog.push({\n      id: generateId(),\n      action: 'resource_shared',\n      userId: currentUser.id,\n      resourceType: typedResourceType,\n      resourceId,\n      timestamp: new Date().toISOString(),\n      details: {\n        sharedWith: userId,\n        role,\n      },\n    });\n\n    res.status(200).json(permission);\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":2,"oldLines":7,"newStart":2,"newLines":7,"lines":[" import type { Store } from '../store.js';"," import type { ResourceType, Role } from '../types.js';"," import { generateId } from '../helpers.js';","-import { authMiddleware } from '../