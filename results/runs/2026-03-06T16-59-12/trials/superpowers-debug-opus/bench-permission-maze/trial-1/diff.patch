+import { Router } from 'express';
+import type { Store } from '../store.js';
+import { authMiddleware } from '../middleware.js';
+
+export function activityRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Get activity log
+  router.get('/', (req, res) => {
+    // Return activities in reverse chronological order
+    const activities = [...store.activityLog].reverse();
+    res.status(200).json(activities);
+  });
+
+  return router;
+}
