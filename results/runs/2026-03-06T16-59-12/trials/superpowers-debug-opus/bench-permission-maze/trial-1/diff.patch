@@ -0,0 +1,69 @@
+import type { Store } from './store.js';
+import type { Role, ResourceType } from './types.js';
+
+const ROLE_LEVELS: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+/**
+ * Get the effective role for a user on a resource, considering:
+ * 1. Direct permissions on the resource
+ * 2. Permissions inherited from parent folders (for documents and nested folders)
+ * 3. The most permissive role wins when multiple paths grant access
+ */
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string,
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check direct permissions on this resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      if (!bestRole || ROLE_LEVELS[perm.role] > ROLE_LEVELS[bestRole]) {
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // Check inherited permissions from parent folders
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);
+      if (folderRole && (!bestRole || ROLE_LEVELS[folderRole] > ROLE_LEVELS[bestRole])) {
+        bestRole = folderRole;
+      }
+    }
+  } else if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);
+      if (parentRole && (!bestRole || ROLE_LEVELS[parentRole] > ROLE_LEVELS[bestRole])) {
+        bestRole = parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string,
+  requiredRole: Role,
+): boolean {
+  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effectiveRole) return false;
+  return ROLE_LEVELS[effectiveRole] >= ROLE_LEVELS[requiredRole];
+}
