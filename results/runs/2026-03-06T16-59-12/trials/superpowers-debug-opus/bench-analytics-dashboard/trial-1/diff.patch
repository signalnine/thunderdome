es: JSON.parse(e.properties),\n        timestamp: e.timestamp,\n        userId: e.user_id,\n        sessionId: e.session_id,\n      })),\n      total: events.length,\n      limit: queryLimit,\n      offset: queryOffset,\n    });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
