 events without auth\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .send({ name: \"page_view\" });\n\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should ingest batch events\", async () => {\n      const res = await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"page_view\", properties: { url: \"/about\" } },\n            { name: \"click\", properties: { button: \"cta\" } },\n          ],\n        });\n\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it(\"should list events\", async () => {\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\" });\n\n      const res = await request(app)\n        .get(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(1);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"pass\", tenantId: \"t1\" });\n      token = reg.body.token;\n\n      // Insert test events\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-15T10:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-15T11:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n            { name: \"click\", properties: { button: \"cta\" }, timestamp: \"2024-01-15T12:00:00Z\" },\n          ],\n        });\n    });\n\n    it(\"should count events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it(\"should count with filters\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", filters: { url: \"/home\" } });\n\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(2);\n    });\n\n    it(\"should return timeseries\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/timeseries\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", interval: \"day\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBe(2);\n    });\n\n    it(\"should return breakdown\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/breakdown\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", property: \"url\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBe(2);\n      expect(res.body.data[0].count).toBe(2);\n    });\n  });\n\n  describe(\"Tenant Isolation\", () => {\n    let token1: string;\n    let token2: string;\n\n    beforeEach(async () => {\n      const reg1 = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"user@t1.com\", password: \"pass\", tenantId: \"t1\" });\n      token1 = reg1.body.token;\n\n      const reg2 = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"user@t2.com\", password: \"pass\", tenantId: \"t2\" });\n      token2 = reg2.body.token;\n\n      // T1 events\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token1}`)\n        .send({ name: \"page_view\" });\n\n      // T2 events\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token2}`)\n        .send({ name: \"page_view\" });\n    });\n\n    it(\"should isolate event counts by tenant\", async () => {\n      const res1 = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token1}`)\n        .send({ eventName: \"page_view\" });\n\n      expect(res1.body.count).toBe(1);\n\n      const res2 = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token2}`)\n        .send({ eventName: \"page_view\" });\n\n      expect(res2.body.count).toBe(1);\n    });\n\n    it(\"should isolate dashboards by tenant\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token1}`)\n        .send({ name: \"T1 Dashboard\" });\n\n      const res = await request(app)\n        .get(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token2}`);\n\n      expect(res.body.dashboards.length).toBe(0);\n    });\n  });\n\n  describe(\"Dashboard CRUD\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"pass\", tenantId: \"t1\" });\n      token = reg.body.token;\n    });\n\n    it(\"should create a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\", config: { theme: \"dark\" } });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"My Dashboard\");\n      expect(res.body.config.theme).toBe(\"dark\");\n    });\n\n    it(\"should list dashboards\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .get(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(1);\n    });\n\n    it(\"should get a single dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Dashboard 1\");\n    });\n\n    it(\"should update a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .put(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Updated Dashboard\" });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Updated Dashboard\");\n    });\n\n    it(\"should delete a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .delete(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(get.status).toBe(404);\n    });\n  });\n\n  describe(\"Data Export\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"pass\", tenantId: \"t1\" });\n      token = reg.body.token;\n\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"cta\" } },\n          ],\n        });\n\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Test Dashboard\" });\n    });\n\n    it(\"should export events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(2);\n    });\n\n    it(\"should export events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should export dashboards as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/dashboards/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(1);\n    });\n\n    it(\"should export dashboards as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/dashboards/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should reject export without auth\", async () => {\n      const res = await request(app).get(\"/api/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
