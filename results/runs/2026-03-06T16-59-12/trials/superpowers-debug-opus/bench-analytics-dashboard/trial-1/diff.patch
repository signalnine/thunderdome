+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { name, properties, timestamp, sessionId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.user!.tenantId, name, eventProperties, eventTimestamp, req.user!.userId, sessionId || null);
+
+    res.status(201).json({
+      id,
+      tenantId: req.user!.tenantId,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+    });
+  });
+
+  // Ingest batch of events
+  router.post("/batch", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const insertStmt = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string; sessionId?: string }>) => {
+      const results: Array<{ id: string; name: string }> = [];
+      for (const evt of evts) {
+        if (!evt.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = evt.timestamp || new Date().toISOString();
+        const eventProperties = evt.properties ? JSON.stringify(evt.properties) : "{}";
+        insertStmt.run(id, req.user!.tenantId, evt.name, eventProperties, eventTimestamp, req.user!.userId, evt.sessionId || null);
+        results.push({ id, name: evt.name });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+
+    res.status(201).json({
+      inserted: results.length,
+      events: results,
+    });
+  });
+
+  // List events for tenant
+  router.get("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { name, limit, offset } = req.query;
+    const queryLimit = Math.min(Number(limit) || 100, 1000);
+    const queryOffset = Number(offset) || 0;
+
+    let query = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [req.user!.tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(String(name));
+    }
+
+    query += " ORDER BY timestamp DESC LIMIT ? OFFSET ?";
+    params.push(queryLimit, queryOffset);
+
+    const events = db.prepare(query).all(...params) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string;
+      session_id: string | null;
+    }>;
+
+    res.json({
+      events: events.map((e) => ({
+        id: e.id,
+        tenantId: e.tenant_id,
+        name: e.name,
+        properties: JSON.parse(e.properties),
+        timestamp: e.timestamp,
+        userId: e.user_id,
+        sessionId: e.session_id,
+      })),
+      total: events.length,
+      limit: queryLimit,
+      offset: queryOffset,
+    });
+  });
+
+  return router;
+}
