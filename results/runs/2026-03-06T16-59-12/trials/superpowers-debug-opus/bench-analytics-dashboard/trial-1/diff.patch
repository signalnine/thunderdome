uld not allow viewer to change roles\", async () => {\n      const viewer = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"viewer@example.com\", password: \"pass\", tenantId: \"t1\" });\n\n      const res = await request(app)\n        .put(`/api/users/${viewer.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${viewer.body.token}`)\n        .send({ role: \"admin\" });\n\n      expect(res.status).toBe(403);\n    });\n\n    it(\"should not allow admin to change roles across tenants\", async () => {\n      const admin = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"admin@t1.com\", password: \"pass\", tenantId: \"t1\", role: \"admin\" });\n\n      const user = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"user@t2.com\", password: \"pass\", tenantId: \"t2\" });\n\n      const res = await request(app)\n        .put(`/api/users/${user.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${admin.body.token}`)\n        .send({ role: \"editor\" });\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"pass\", tenantId: \"t1\" });\n      token = reg.body.token;\n    });\n\n    it(\"should ingest a single event\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n      expect(res.body.properties.url).toBe(\"/home\");\n    });\n\n    it(\"should reject events without auth\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .send({ name