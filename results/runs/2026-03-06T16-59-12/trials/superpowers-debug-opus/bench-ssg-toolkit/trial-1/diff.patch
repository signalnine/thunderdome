n=\"2.0\">\n<channel>\n<title>${config.title}</title>\n<link>${config.baseUrl}</link>\n${items}\n</channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { Plugin, ContentFile, BuildContext } from '../core/types.js';","+import { Plugin, BuildContext } from '../core/types.js';"," "," export function createRssFeedPlugin(): Plugin {","   return {"]}],"userModified":false,"replaceAll":false}}
