+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: evaluate all gates in dependency order and return all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder circuit.
+ *
+ * Strategy: Structurally analyze the adder pattern. A correct N-bit ripple-carry adder
+ * has a specific gate structure per bit. We identify violations of this structure
+ * to find swapped output wires.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Build lookup structures
+  const gateByOut = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOut.set(g.out, g);
+  }
+
+  // Helper: check if a gate has specific inputs (order-independent)
+  function hasInputs(gate: Gate, a: string, b: string): boolean {
+    return (
+      (gate.in1 === a && gate.in2 === b) ||
+      (gate.in1 === b && gate.in2 === a)
+    );
+  }
+
+  // Determine the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2, g.out]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+
+  // For structural analysis, we need to know what each gate's output is *used for*
+  // (i.e., which gates consume it as input). Build a consumer map.
+  const consumers = new Map<string, Gate[]>();
+  for (const g of gates) {
+    if (!consumers.has(g.in1)) consumers.set(g.in1, []);
+    consumers.get(g.in1)!.push(g);
+    if (!consumers.has(g.in2)) consumers.set(g.in2, []);
+    consumers.get(g.in2)!.push(g);
+  }
+
+  // Approach: structural rule checking
+  // For each gate, check if its output violates the expected pattern for its structural role.
+  //
+  // Rules for a correct ripple-carry adder:
+  // 1. XOR(x_i, y_i) for i>0 should NOT output to z_i directly; it outputs to an intermediate t_i
+  //    which is then XORed with carry to produce z_i.
+  //    Exception: bit 0 where XOR(x00, y00) -> z00
+  // 2. XOR(x_i, y_i) for i>0: the output should be used as input to exactly one XOR and one AND gate
+  // 3. The gate producing z_i (for i>0, i<numBits) must be an XOR gate
+  // 4. The final z (z_{numBits}) must come from an OR gate (final carry)
+  // 5. AND gates should not output to z wires (except possibly the final carry bit)
+  // 6. OR gates (carry) should not output to z wires (except the final bit z_{numBits})
+  // 7. XOR gates that are not the x_i XOR y_i type should output to z wires
+
+  // Use a rule-based approach to flag anomalies:
+  const badWires = new Set<string>();
+
+  // Rule 1: Any XOR gate with xNN/yNN inputs (for NN > 0) whose output is a z wire is wrong
+  // (because it should go through another XOR with carry first)
+  for (const g of gates) {
+    if (g.op === 'XOR') {
+      const isXYInput =
+        (g.in1.match(/^x\d+$/) && g.in2.match(/^y\d+$/)) ||
+        (g.in1.match(/^y\d+$/) && g.in2.match(/^x\d+$/));
+      if (isXYInput) {
+        // Extract bit number
+        const bitStr = g.in1.match(/\d+$/)?.[0] ?? g.in2.match(/\d+$/)?.[0];
+        const bit = parseInt(bitStr!, 10);
+        if (bit > 0 && g.out.match(/^z\d+$/)) {
+          // This XOR(x_i, y_i) should not directly output to z - it's swapped
+          badWires.add(g.out);
+        }
+      }
+    }
+  }
+
+  // Rule 2: Any non-XOR gate outputting to z (except the highest z bit) is wrong
+  const highestZ = `z${String(numBits).padStart(2, '0')}`;
+  for (const g of gates) {
+    if (g.out.match(/^z\d+$/) && g.out !== highestZ && g.op !== 'XOR') {
+      badWires.add(g.out);
+    }
+  }
+
+  // Rule 3: XOR gates that are NOT XOR(x_i, y_i) should output to a z wire
+  // (These are the "final sum" XOR gates: t_i XOR c_{i-1} -> z_i)
+  for (const g of gates) {
+    if (g.op === 'XOR') {
+      const isXYInput =
+        (g.in1.match(/^x\d+$/) && g.in2.match(/^y\d+$/)) ||
+        (g.in1.match(/^y\d+$/) && g.in2.match(/^x\d+$/));
+      if (!isXYInput && !g.out.match(/^z\d+$/)) {
+        // This is a second-level XOR that should output to z but doesn't
+        badWires.add(g.out);
+      }
+    }
+  }
+
+  // Rule 4: XOR(x_i, y_i) for i>0 output should be consumed by exactly one XOR and one AND
+  // If consumed by an OR, that's wrong (the output wire is in the wrong place)
+  for (const g of gates) {
+    if (g.op === 'XOR') {
+      const isXYInput =
+        (g.in1.match(/^x\d+$/) && g.in2.match(/^y\d+$/)) ||
+        (g.in1.match(/^y\d+$/) && g.in2.match(/^x\d+$/));
+      if (isXYInput) {
+        const bitStr = g.in1.match(/\d+$/)?.[0] ?? g.in2.match(/\d+$/)?.[0];
+        const bit = parseInt(bitStr!, 10);
+        if (bit > 0) {
+          const cons = consumers.get(g.out) ?? [];
+          for (const c of cons) {
+            if (c.op === 'OR') {
+              // t_i should never feed into an OR gate directly
+              badWires.add(g.out);
+            }
+          }
+        }
+      }
+    }
+  }
+
+  // Rule 5: AND gates (except AND(x00, y00)) output should be consumed by OR gates only
+  // If an AND gate's output feeds into a non-OR gate (like XOR), it's likely swapped
+  for (const g of gates) {
+    if (g.op === 'AND') {
+      // Skip AND(x00, y00) since bit 0 carry has special behavior
+      const isX0Y0 = hasInputs(g, 'x00', 'y00');
+      if (!isX0Y0) {
+        const cons = consumers.get(g.out) ?? [];
+        for (const c of cons) {
+          if (c.op !== 'OR') {
+            badWires.add(g.out);
+          }
+        }
+      }
+    }
+  }
+
+  // Now we have a set of "bad" output wires. In a circuit with exactly 4 swaps (8 wires),
+  // we should have identified exactly 8 bad wires.
+  // However, some rules might flag the same wire multiple times or miss some.
+  // Let's collect and return them sorted.
+
+  return [...badWires].sort();
+}
