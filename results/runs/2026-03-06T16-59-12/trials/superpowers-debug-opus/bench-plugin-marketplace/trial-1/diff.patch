+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRunner } from './index.js';
+import type { RunnerService } from '../types.js';
+
+describe('Sandboxed Runner', () => {
+  let runner: RunnerService;
+
+  beforeEach(() => {
+    runner = createRunner();
+  });
+
+  describe('execute', () => {
+    it('should execute simple code and return result', async () => {
+      const result = await runner.execute('1 + 2');
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(3);
+      expect(result.duration).toBeGreaterThanOrEqual(0);
+      expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+    });
+
+    it('should return string output', async () => {
+      const result = await runner.execute('"hello world"');
+      expect(result.success).toBe(true);
+      expect(result.output).toBe('hello world');
+    });
+
+    it('should handle errors gracefully', async () => {
+      const result = await runner.execute('throw new Error("test error")');
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('test error');
+    });
+
+    it('should handle syntax errors', async () => {
+      const result = await runner.execute('const {');
+      expect(result.success).toBe(false);
+      expect(result.error).toBeDefined();
+    });
+
+    it('should pass context variables to sandbox', async () => {
+      const result = await runner.execute('x + y', { x: 10, y: 20 });
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(30);
+    });
+
+    it('should isolate from global scope', async () => {
+      const result = await runner.execute('typeof require');
+      expect(result.success).toBe(true);
+      expect(result.output).toBe('undefined');
+    });
+
+    it('should capture console.log output', async () => {
+      const result = await runner.execute('console.log("hello"); undefined');
+      expect(result.success).toBe(true);
+    });
+
+    it('should handle object return values', async () => {
+      const result = await runner.execute('({ a: 1, b: "two" })');
+      expect(result.success).toBe(true);
+      expect(result.output).toEqual({ a: 1, b: 'two' });
+    });
+  });
+
+  describe('executeWithTimeout', () => {
+    it('should timeout long-running code', async () => {
+      const result = await runner.executeWithTimeout('while(true) {}', 100);
+      expect(result.success).toBe(false);
+      expect(result.error).toBeDefined();
+    });
+
+    it('should not timeout fast code', async () => {
+      const result = await runner.executeWithTimeout('42', 5000);
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(42);
+    });
+
+    it('should support context with timeout', async () => {
+      const result = await runner.executeWithTimeout('value * 2', 5000, {
+        value: 21,
+      });
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(42);
+    });
+  });
+});
