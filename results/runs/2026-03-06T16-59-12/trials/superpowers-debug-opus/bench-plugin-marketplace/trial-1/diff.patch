+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from './index.js';
+import type { ReviewService } from '../types.js';
+
+describe('Review System', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  describe('addReview', () => {
+    it('should add a review and assign an id', () => {
+      const review = reviews.addReview({
+        pluginName: 'test-plugin',
+        pluginVersion: '1.0.0',
+        userId: 'user1',
+        rating: 5,
+        comment: 'Great plugin!',
+      });
+      expect(review.id).toBeDefined();
+      expect(review.id).toBeGreaterThan(0);
+      expect(review.pluginName).toBe('test-plugin');
+      expect(review.rating).toBe(5);
+      expect(review.flagged).toBe(false);
+      expect(review.createdAt).toBeDefined();
+    });
+
+    it('should auto-increment ids', () => {
+      const r1 = reviews.addReview({
+        pluginName: 'p1',
+        pluginVersion: '1.0.0',
+        userId: 'u1',
+        rating: 3,
+        comment: 'ok',
+      });
+      const r2 = reviews.addReview({
+        pluginName: 'p2',
+        pluginVersion: '1.0.0',
+        userId: 'u2',
+        rating: 4,
+        comment: 'good',
+      });
+      expect(r2.id).toBeGreaterThan(r1.id);
+    });
+
+    it('should reject invalid ratings', () => {
+      expect(() =>
+        reviews.addReview({
+          pluginName: 'p',
+          pluginVersion: '1.0.0',
+          userId: 'u',
+          rating: 0,
+          comment: '',
+        })
+      ).toThrow();
+      expect(() =>
+        reviews.addReview({
+          pluginName: 'p',
+          pluginVersion: '1.0.0',
+          userId: 'u',
+          rating: 6,
+          comment: '',
+        })
+      ).toThrow();
+    });
+  });
+
+  describe('getReviews', () => {
+    it('should return reviews for a plugin', () => {
+      reviews.addReview({
+        pluginName: 'p1',
+        pluginVersion: '1.0.0',
+        userId: 'u1',
+        rating: 5,
+        comment: 'great',
+      });
+      reviews.addReview({
+        pluginName: 'p1',
+        pluginVersion: '1.0.0',
+        userId: 'u2',
+        rating: 4,
+        comment: 'good',
+      });
+      reviews.addReview({
+        pluginName: 'p2',
+        pluginVersion: '1.0.0',
+        userId: 'u1',
+        rating: 3,
+        comment: 'ok',
+      });
+      const result = reviews.getReviews('p1');
+      expect(result).toHaveLength(2);
+    });
+
+    it('should return empty for nonexistent plugin', () => {
+      expect(reviews.getReviews('nonexistent')).toHaveLength(0);
+    });
+  });
+
+  describe('getAverageRating', () => {
+    it('should compute average rating', () => {
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });
+      expect(reviews.getAverageRating('p1')).toBe(4);
+    });
+
+    it('should exclude flagged reviews from average', () => {
+      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'spam' });
+      // Flag the spam review
+      reviews.flagReview(r1.id + 2); // third review
+      // Average should be (5 + 3) / 2 = 4
+      expect(reviews.getAverageRating('p1')).toBe(4);
+    });
+
+    it('should return 0 for no reviews', () => {
+      expect(reviews.getAverageRating('nonexistent')).toBe(0);
+    });
+
+    it('should return 0 when all reviews are flagged', () => {
+      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.flagReview(r.id);
+      expect(reviews.getAverageRating('p1')).toBe(0);
+    });
+  });
+
+  describe('flagReview', () => {
+    it('should flag a review', () => {
+      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.flagReview(r.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+      expect(flagged[0].id).toBe(r.id);
+    });
+
+    it('should throw for nonexistent review', () => {
+      expect(() => reviews.flagReview(999)).toThrow();
+    });
+  });
+
+  describe('getFlaggedReviews', () => {
+    it('should return only flagged reviews', () => {
+      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });
+      reviews.flagReview(r1.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+    });
+  });
+
+  describe('removeReview', () => {
+    it('should remove a review', () => {
+      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      expect(reviews.removeReview(r.id)).toBe(true);
+      expect(reviews.getReviews('p1')).toHaveLength(0);
+    });
+
+    it('should return false for nonexistent review', () => {
+      expect(reviews.removeReview(999)).toBe(false);
+    });
+  });
+
+  describe('getReviewsByUser', () => {
+    it('should return reviews by a specific user', () => {
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user-a', rating: 5, comment: '' });
+      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'user-a', rating: 4, comment: '' });
+      reviews.addReview({ pluginName: 'p3', pluginVersion: '1.0.0', userId: 'user-b', rating: 3, comment: '' });
+      const result = reviews.getReviewsByUser('user-a');
+      expect(result).toHaveLength(2);
+    });
+  });
+
+  describe('getReviewCount', () => {
+    it('should return correct count', () => {
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });
+      expect(reviews.getReviewCount('p1')).toBe(2);
+    });
+
+    it('should return 0 for nonexistent plugin', () => {
+      expect(reviews.getReviewCount('nonexistent')).toBe(0);
+    });
+  });
+});
