   expect(registry.get('nonexistent')).toBeNull();\n    });\n\n    it('should return the latest registered version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      const found = registry.get('test-plugin');\n      expect(found!.version).toBe('2.0.0');\n    });\n  });\n\n  describe('getVersion', () => {\n    it('should return specific version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      const found = registry.getVersion('test-plugin', '1.0.0');\n      expect(found).not.toBeNull();\n      expect(found!.version).toBe('1.0.0');\n    });\n\n    it('should return null for nonexistent version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();\n    });\n\n    it('should return null for nonexistent plugin', () => {\n      expect(registry.getVersion('nonexistent', '1.0.0')).toBeNull();\n    });\n  });\n\n  describe('list', () => {\n    it('should return all plugins', () => {\n      registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n      registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n      const all = registry.list();\n      expect(all).toHaveLength(2);\n    });\n\n    it('should return empty array when no plugins', () => {\n      expect(registry.list()).toHaveLength(0);\n    });\n  });\n\n  describe('search', () => {\n    it('should search by name', () => {\n      registry.register(makeManifest({ name: 'my-logger', description: 'logs stuff' }));\n      registry.register(makeManifest({ name: 'my-parser', description: 'parses stuff' }));\n      const results = registry.search('logger');\n      expect(results).toHaveLength(1);\n      expect(results[0].name).toBe('my-logger');\n    });\n\n    it('should search by description', () => {\n      registry.register(makeManifest({ name: 'foo', description: 'amazing tool' }));\n      const results = registry.search('amazing');\n      expect(results).toHaveLength(1);\n    });\n\n    it('should search by author', () => {\n      registry.register(makeManifest({ name: 'foo', author: 'john-doe' }));\n      const results = registry.search('john');\n      expect(results).toHaveLength(1);\n    });\n\n    it('should be case-insensitive', () => {\n      registry.register(makeManifest({ name: 'MyPlugin' }));\n      expect(registry.search('myplugin')).toHaveLength(1);\n      expect(registry.search('MYPLUGIN')).toHaveLength(1);\n    });\n  });\n\n  describe('remove', () => {\n    it('should remove a specific version', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      const removed = registry.remove('test-plugin', '1.0.0');\n      expect(removed).toBe(true);\n      expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n      expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n    });\n\n    it('should return false for nonexistent plugin', () => {\n      expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n    });\n\n    it('should clean up plugin entry when last version removed', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.remove('test-plugin', '1.0.0');\n      expect(registry.get('test-plugin')).toBeNull();\n    });\n  });\n\n  describe('listVersions', () => {\n    it('should list all versions', () => {\n      registry.register(makeManifest({ version: '1.0.0' }));\n      registry.register(makeManifest({ version: '1.1.0' }));\n      registry.register(makeManifest({ version: '2.0.0' }));\n      const versions = registry.listVersions('test-plugin');\n      expect(versions).toHaveLength(3);\n      expect(versions).toContain('1.0.0');\n      expect(versions).toContain('1.1.0');\n      expect(versions).toContain('2.0.0');\n    });\n\n    it('