+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should move task to DLQ after retries exhausted', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext();
+    queue.fail(task.id, 'permanent error');
+
+    const dlq = queue.getDeadLetterTasks();
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].id).toBe(task.id);
+    expect(dlq[0].error).toBe('permanent error');
+  });
+
+  it('should retain error info and failure count', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext();
+    queue.fail(task.id, 'error msg');
+
+    const dlq = queue.getDeadLetterTasks();
+    expect(dlq[0].error).toBe('error msg');
+    expect(dlq[0].failureCount).toBe(1);
+  });
+
+  it('should have per-queue DLQs', () => {
+    const t1 = queue.add({ payload: 'email', queue: 'emails', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext('emails');
+    queue.fail(t1.id, 'email error');
+
+    const t2 = queue.add({ payload: 'notif', queue: 'notifications', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext('notifications');
+    queue.fail(t2.id, 'notif error');
+
+    expect(queue.getDeadLetterTasks('emails')).toHaveLength(1);
+    expect(queue.getDeadLetterTasks('notifications')).toHaveLength(1);
+  });
+
+  it('should retry a dead-lettered task', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext();
+    queue.fail(task.id, 'error');
+
+    const dlq = queue.getDeadLetterTasks();
+    const retried = queue.retryDeadLetter(dlq[0].id);
+    expect(retried.status).toBe('pending');
+    expect(retried.payload).toBe('test');
+
+    // DLQ should be empty now
+    expect(queue.getDeadLetterTasks()).toHaveLength(0);
+  });
+
+  it('should clear DLQ for a queue', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext();
+    queue.fail(task.id, 'error');
+
+    expect(queue.getDeadLetterTasks()).toHaveLength(1);
+    queue.clearDeadLetterQueue();
+    expect(queue.getDeadLetterTasks()).toHaveLength(0);
+  });
+
+  it('should throw when retrying non-existent dead letter task', () => {
+    expect(() => queue.retryDeadLetter('nonexistent')).toThrow();
+  });
+
+  it('should return empty array for queue with no DLQ tasks', () => {
+    expect(queue.getDeadLetterTasks('empty')).toHaveLength(0);
+  });
+
+  it('should store deadLetteredAt timestamp', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext();
+    queue.fail(task.id, 'error');
+
+    const dlq = queue.getDeadLetterTasks();
+    expect(dlq[0].deadLetteredAt).toBeInstanceOf(Date);
+  });
+});
