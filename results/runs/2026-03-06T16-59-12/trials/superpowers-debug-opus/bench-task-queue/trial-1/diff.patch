+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should allow tasks with dependencies', () => {
+    const t1 = queue.add({ payload: 'first' });
+    const t2 = queue.add({ payload: 'second', dependencies: [t1.id] });
+    expect(t2.dependencies).toContain(t1.id);
+  });
+
+  it('should block tasks with unresolved dependencies', () => {
+    const t1 = queue.add({ payload: 'first' });
+    queue.add({ payload: 'second', dependencies: [t1.id] });
+
+    // t2 should not be available since t1 hasn't completed
+    const next = queue.getNext();
+    expect(next?.payload).toBe('first');
+
+    const next2 = queue.getNext();
+    expect(next2).toBeNull(); // t2 still blocked
+  });
+
+  it('should unblock tasks when dependencies complete', () => {
+    const t1 = queue.add({ payload: 'first' });
+    queue.add({ payload: 'second', dependencies: [t1.id] });
+
+    const processing = queue.getNext();
+    queue.complete(processing!.id);
+
+    const next = queue.getNext();
+    expect(next?.payload).toBe('second');
+  });
+
+  it('should reject dependencies on non-existent tasks', () => {
+    expect(() => {
+      queue.add({ payload: 'test', dependencies: ['nonexistent'] });
+    }).toThrow();
+  });
+
+  it('should handle multiple dependencies', () => {
+    const t1 = queue.add({ payload: 'a' });
+    const t2 = queue.add({ payload: 'b' });
+    queue.add({ payload: 'c', dependencies: [t1.id, t2.id] });
+
+    // Process t1
+    const p1 = queue.getNext();
+    queue.complete(p1!.id);
+
+    // t3 still blocked because t2 isn't done
+    const p2 = queue.getNext();
+    expect(p2?.payload).toBe('b');
+    expect(queue.getNext()).toBeNull(); // t3 still blocked
+
+    // Complete t2
+    queue.complete(p2!.id);
+
+    // Now t3 is available
+    const p3 = queue.getNext();
+    expect(p3?.payload).toBe('c');
+  });
+
+  it('should keep dependents blocked when dependency fails', () => {
+    const t1 = queue.add({ payload: 'first', maxRetries: 1, backoffDelay: 0 });
+    queue.add({ payload: 'second', dependencies: [t1.id] });
+
+    const processing = queue.getNext();
+    queue.fail(processing!.id, 'error');
+
+    // t2 remains blocked because t1 failed (not completed)
+    expect(queue.getNext()).toBeNull();
+  });
+
+  it('should inspect dependency status', () => {
+    const t1 = queue.add({ payload: 'first' });
+    const t2 = queue.add({ payload: 'second' });
+    const t3 = queue.add({ payload: 'third', dependencies: [t1.id, t2.id] });
+
+    let status = queue.getDependencyStatus(t3.id);
+    expect(status.pending).toContain(t1.id);
+    expect(status.pending).toContain(t2.id);
+    expect(status.resolved).toHaveLength(0);
+
+    // Complete t1
+    const p1 = queue.getNext();
+    queue.complete(p1!.id);
+
+    status = queue.getDependencyStatus(t3.id);
+    expect(status.resolved).toContain(t1.id);
+    expect(status.pending).toContain(t2.id);
+  });
+});
