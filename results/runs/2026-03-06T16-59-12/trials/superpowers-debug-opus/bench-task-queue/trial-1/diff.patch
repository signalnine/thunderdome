@@ -0,0 +1,82 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should stop accepting new tasks after shutdown', async () => {
+    await queue.shutdown();
+    expect(() => queue.add({ payload: 'test' })).toThrow(/shutting down/);
+  });
+
+  it('should complete immediately when no tasks processing', async () => {
+    const result = await queue.shutdown();
+    expect(result.duration).toBeDefined();
+    expect(result.cancelled).toBeGreaterThanOrEqual(0);
+    expect(result.completed).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should report completed and cancelled counts', async () => {
+    const t1 = queue.add({ payload: 'done' });
+    queue.add({ payload: 'pending' });
+
+    queue.getNext();
+    queue.complete(t1.id);
+
+    const result = await queue.shutdown();
+    expect(result.completed).toBe(1);
+    expect(result.cancelled).toBeGreaterThanOrEqual(1);
+  });
+
+  it('should be idempotent', async () => {
+    const result1 = queue.shutdown();
+    const result2 = queue.shutdown();
+    expect(result1).toBe(result2);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let called = false;
+    queue.onShutdown(() => {
+      called = true;
+    });
+    await queue.shutdown();
+    expect(called).toBe(true);
+  });
+
+  it('should report shutdown status', async () => {
+    expect(queue.shuttingDown).toBe(false);
+    const promise = queue.shutdown();
+    expect(queue.shuttingDown).toBe(true);
+    await promise;
+  });
+
+  it('should force-cancel processing tasks after timeout', async () => {
+    const task = queue.add({ payload: 'slow' });
+    queue.getNext();
+
+    // Shutdown with very short timeout
+    const result = await queue.shutdown({ timeout: 100 });
+
+    const updated = queue.getTask(task.id);
+    expect(updated?.status).toBe('cancelled');
+    expect(result.cancelled).toBeGreaterThanOrEqual(1);
+  });
+
+  it('should cancel pending tasks on shutdown', async () => {
+    queue.add({ payload: 'pending1' });
+    queue.add({ payload: 'pending2' });
+
+    const result = await queue.shutdown();
+    expect(result.cancelled).toBe(2);
+  });
+
+  it('should return shutdown duration', async () => {
+    const result = await queue.shutdown();
+    expect(typeof result.duration).toBe('number');
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+});
