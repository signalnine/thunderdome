+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should have unlimited concurrency by default', () => {
+    expect(queue.getConcurrency()).toBe(0);
+  });
+
+  it('should set concurrency limit', () => {
+    queue.setConcurrency('default', 2);
+    expect(queue.getConcurrency('default')).toBe(2);
+  });
+
+  it('should return null when concurrency limit reached', () => {
+    queue.setConcurrency('default', 1);
+    queue.add({ payload: 'a' });
+    queue.add({ payload: 'b' });
+
+    queue.getNext(); // takes first task
+    const second = queue.getNext(); // should be null (limit reached)
+    expect(second).toBeNull();
+  });
+
+  it('should free concurrency slot on complete', () => {
+    queue.setConcurrency('default', 1);
+    const t1 = queue.add({ payload: 'a' });
+    queue.add({ payload: 'b' });
+
+    queue.getNext(); // takes t1
+    queue.complete(t1.id); // frees slot
+
+    const next = queue.getNext(); // should now get t2
+    expect(next?.payload).toBe('b');
+  });
+
+  it('should free concurrency slot on fail', () => {
+    queue.setConcurrency('default', 1);
+    const t1 = queue.add({ payload: 'a', maxRetries: 1, backoffDelay: 0 });
+    queue.add({ payload: 'b' });
+
+    queue.getNext();
+    queue.fail(t1.id);
+
+    const next = queue.getNext();
+    expect(next?.payload).toBe('b');
+  });
+
+  it('should track active count', () => {
+    queue.add({ payload: 'a' });
+    queue.add({ payload: 'b' });
+
+    expect(queue.getActiveCount()).toBe(0);
+    queue.getNext();
+    expect(queue.getActiveCount()).toBe(1);
+    queue.getNext();
+    expect(queue.getActiveCount()).toBe(2);
+  });
+
+  it('should respect priority within concurrency limit', () => {
+    queue.setConcurrency('default', 1);
+    queue.add({ payload: 'low', priority: 10 });
+    queue.add({ payload: 'high', priority: 1 });
+
+    const task = queue.getNext();
+    expect(task?.payload).toBe('high');
+  });
+
+  it('should operate per-queue', () => {
+    queue.setConcurrency('q1', 1);
+    queue.add({ payload: 'a', queue: 'q1' });
+    queue.add({ payload: 'b', queue: 'q1' });
+    queue.add({ payload: 'c', queue: 'q2' });
+    queue.add({ payload: 'd', queue: 'q2' });
+
+    queue.getNext('q1'); // takes one from q1
+    expect(queue.getNext('q1')).toBeNull(); // q1 at limit
+    expect(queue.getNext('q2')).toBeDefined(); // q2 has no limit
+    expect(queue.getNext('q2')).toBeDefined(); // q2 still unlimited
+  });
+});
diff --git a/src/__tests__/phase09.test.ts b/src/__tests__/phase09.test.ts
