+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should complete a processing task', () => {
+    const task = queue.add({ payload: 'test' });
+    queue.getNext();
+    queue.complete(task.id);
+    expect(queue.getTask(task.id)?.status).toBe('completed');
+  });
+
+  it('should fail a task and retry with backoff', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 3, backoffDelay: 100 });
+    queue.getNext();
+    queue.fail(task.id, 'some error');
+
+    // Task should be pending again with a delay
+    const updated = queue.getTask(task.id);
+    expect(updated?.status).toBe('pending');
+    expect(updated?.failureCount).toBe(1);
+    expect(updated?.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should apply exponential backoff', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 3, backoffDelay: 1000 });
+
+    // First attempt
+    queue.getNext();
+    const beforeFail1 = Date.now();
+    queue.fail(task.id);
+    const delay1 = queue.getTask(task.id)!.availableAt.getTime() - beforeFail1;
+    expect(delay1).toBeGreaterThanOrEqual(900); // ~1000ms
+    expect(delay1).toBeLessThanOrEqual(1200);
+  });
+
+  it('should track attempt count', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 3, backoffDelay: 0 });
+
+    // First attempt
+    queue.getNext();
+    expect(queue.getTask(task.id)?.attempt).toBe(1);
+  });
+
+  it('should default maxRetries to 3', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should default backoffDelay to 1000', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    const task = queue.add({ payload: 'test', queue: 'emails', priority: 2, maxRetries: 3, backoffDelay: 0 });
+    queue.getNext('emails');
+    queue.fail(task.id);
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.queue).toBe('emails');
+    expect(updated.priority).toBe(2);
+  });
+
+  it('should remain failed when retries exhausted', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 0 });
+
+    queue.getNext();
+    queue.fail(task.id, 'error');
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.status).toBe('failed');
+  });
+
+  it('should not allow completing a non-processing task', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(() => queue.complete(task.id)).toThrow();
+  });
+
+  it('should not allow failing a non-processing task', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(() => queue.fail(task.id)).toThrow();
+  });
+
+  it('should store error information', () => {
+    const task = queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext();
+    queue.fail(task.id, 'Something went wrong');
+
+    const updated = queue.getTask(task.id)!;
+    expect(updated.error).toBe('Something went wrong');
+  });
+});
