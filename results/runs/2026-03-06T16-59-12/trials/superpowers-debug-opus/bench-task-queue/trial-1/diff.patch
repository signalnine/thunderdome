@@ -0,0 +1,81 @@
+/** Status of a task in its lifecycle */
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+/** Task object representing a unit of work */
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+  progress: number;
+  progressMessage?: string;
+}
+
+/** Options for adding a task */
+export interface AddTaskOptions<T = unknown> {
+  payload: T;
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+/** A dead-lettered task */
+export interface DeadLetteredTask<T = unknown> {
+  id: string;
+  payload: T;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  error?: string;
+  failureCount: number;
+  deadLetteredAt: Date;
+}
+
+/** Progress update event */
+export interface ProgressUpdate {
+  taskId: string;
+  progress: number;
+  message?: string;
+}
+
+/** Progress listener callback */
+export type ProgressListener = (update: ProgressUpdate) => void;
+
+/** Schedule for recurring tasks */
+export interface Schedule<T = unknown> {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: T;
+  lastRun?: Date;
+}
+
+/** Middleware function type */
+export type MiddlewareFunction<T = unknown> = (
+  task: Task<T>,
+  next: () => Promise<void>
+) => Promise<void>;
+
+/** Task processing handler */
+export type TaskHandler<T = unknown> = (task: Task<T>) => Promise<void>;
+
+/** Shutdown result summary */
+export interface ShutdownResult {
+  completed: number;
+  cancelled: number;
+  duration: number;
+}
