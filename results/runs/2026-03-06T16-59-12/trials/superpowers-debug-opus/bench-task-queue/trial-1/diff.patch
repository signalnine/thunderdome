+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 2: Named Queues', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should use default queue when no name specified', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(task.queue).toBe('default');
+  });
+
+  it('should add tasks to named queues', () => {
+    const task = queue.add({ payload: 'email', queue: 'emails' });
+    expect(task.queue).toBe('emails');
+  });
+
+  it('should keep queues independent', () => {
+    queue.add({ payload: 'email', queue: 'emails' });
+    queue.add({ payload: 'notification', queue: 'notifications' });
+
+    const emailTask = queue.getNext('emails');
+    expect(emailTask?.payload).toBe('email');
+
+    const notifTask = queue.getNext('notifications');
+    expect(notifTask?.payload).toBe('notification');
+  });
+
+  it('should return null for non-existent queue', () => {
+    expect(queue.getNext('nonexistent')).toBeNull();
+  });
+
+  it('should return null for empty queue', () => {
+    queue.add({ payload: 'x', queue: 'emails' });
+    queue.getNext('emails');
+    expect(queue.getNext('emails')).toBeNull();
+  });
+
+  it('should list all queue names', () => {
+    queue.add({ payload: 'a', queue: 'alpha' });
+    queue.add({ payload: 'b', queue: 'beta' });
+    const names = queue.listQueues();
+    expect(names).toContain('alpha');
+    expect(names).toContain('beta');
+  });
+
+  it('should track pending count per queue', () => {
+    queue.add({ payload: 'a', queue: 'q1' });
+    queue.add({ payload: 'b', queue: 'q1' });
+    queue.add({ payload: 'c', queue: 'q2' });
+
+    expect(queue.pendingCount('q1')).toBe(2);
+    expect(queue.pendingCount('q2')).toBe(1);
+  });
+
+  it('should be backward-compatible (default queue)', () => {
+    queue.add({ payload: 'test' });
+    const task = queue.getNext();
+    expect(task?.payload).toBe('test');
+    expect(task?.queue).toBe('default');
+  });
+
+  it('should implicitly create queue on first add', () => {
+    queue.add({ payload: 'test', queue: 'new-queue' });
+    expect(queue.listQueues()).toContain('new-queue');
+  });
+});
