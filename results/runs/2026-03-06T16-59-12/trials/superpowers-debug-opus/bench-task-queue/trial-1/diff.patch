+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = queue.add({ payload: { message: 'hello' } });
+    expect(task).toBeDefined();
+    expect(task.id).toBeDefined();
+    expect(task.payload).toEqual({ message: 'hello' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should assign unique IDs to tasks', () => {
+    const t1 = queue.add({ payload: 'a' });
+    const t2 = queue.add({ payload: 'b' });
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should return tasks in FIFO order', () => {
+    queue.add({ payload: 'first' });
+    queue.add({ payload: 'second' });
+    queue.add({ payload: 'third' });
+
+    const t1 = queue.getNext();
+    const t2 = queue.getNext();
+    const t3 = queue.getNext();
+
+    expect(t1?.payload).toBe('first');
+    expect(t2?.payload).toBe('second');
+    expect(t3?.payload).toBe('third');
+  });
+
+  it('should transition tasks to processing state', () => {
+    queue.add({ payload: 'test' });
+    const task = queue.getNext();
+    expect(task?.status).toBe('processing');
+  });
+
+  it('should return null when no tasks available', () => {
+    const task = queue.getNext();
+    expect(task).toBeNull();
+  });
+
+  it('should track pending count', () => {
+    expect(queue.pendingCount()).toBe(0);
+    queue.add({ payload: 'a' });
+    queue.add({ payload: 'b' });
+    expect(queue.pendingCount()).toBe(2);
+    queue.getNext();
+    expect(queue.pendingCount()).toBe(1);
+  });
+
+  it('should not return tasks that are already processing', () => {
+    queue.add({ payload: 'only one' });
+    queue.getNext(); // moves to processing
+    const next = queue.getNext();
+    expect(next).toBeNull();
+  });
+
+  it('should retrieve task by ID', () => {
+    const added = queue.add({ payload: 'find me' });
+    const found = queue.getTask(added.id);
+    expect(found).toBeDefined();
+    expect(found?.payload).toBe('find me');
+  });
+});
