+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SZXWTTYwB52UEuehJnLQzL","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017a1gZqQXcwZiXjTbE16G4n","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport {\n  Task,\n  TaskStatus,\n  AddTaskOptions,\n  DeadLetteredTask,\n  ProgressListener,\n  ProgressUpdate,\n  Schedule,\n  MiddlewareFunction,\n  TaskHandler,\n  ShutdownResult,\n} from './types.js';\nimport { parseCron, cronMatches, CronExpression } from './cron.js';\n\nconst DEFAULT_QUEUE = 'default';\nconst DEFAULT_PRIORITY = 5;\nconst DEFAULT_MAX_RETRIES = 3;\nconst DEFAULT_BACKOFF_DELAY = 1000;\n\n/** Internal queue state */\ninterface QueueState {\n  concurrencyLimit: number; // 0 means unlimited\n  middleware: MiddlewareFunction[];\n  handler?: TaskHandler;\n}\n\nexport class TaskQueue {\n  /** All tasks indexed by ID */\n  private tasks: Map<string, Task> = new Map();\n\n  /** Per-queue state */\n  private queueStates: Map<string, QueueState> = new Map();\n\n  /** Dead letter queues - per queue name */\n  private deadLetterQueues: Map<string, DeadLetteredTask[]> = new Map();\n\n  /** Progress listeners - per task ID */\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n\n  /** Recurring schedules */\n  private schedules: Map<string, Schedule & { parsed: CronExpression }> = new Map();\n\n  /** Shutdown state */\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // ──────────────────────────────────────────────\n  // Phase 1: Basic FIFO Queue\n  // ──────────────────────────────────────────────\n\n  /**\n   * Add a task to the queue.\n   */\n  add<T = unknown>(options: AddTaskOptions<T> | T): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Queue is shutting down, cannot add new tasks');\n    }\n\n    // Support simple payload or full options\n    const opts: AddTaskOptions<T> = this.isAddTaskOptions(options)\n      ? options\n      : { payload: options };\n\n    const queueName = opts.queue ?? DEFAULT_QUEUE;\n    const priority = opts.priority ?? DEFAULT_PRIORITY;\n\n    // Phase 3: validate priority\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 7: validate dependencies\n    const dependencies = opts.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task \"${depId}\" does not exist`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      // We need to check that adding this task doesn't create cycles.\n      // Since this task doesn't exist yet, we check if any dependency\n      // transitively depends on... well, this task doesn't exist yet,\n      // so circular deps can only happen if deps form a cycle among themselves\n      // or if a dep is waiting on something that will eventually wait on this task.\n      // Since this task is new, it can't be in anyone's dep list yet.\n      // But we should still validate that dependencies themselves aren't in a cycle.\n    }\n\n    // Compute availability time (Phase 4)\n    let availableAt = new Date();\n    if (opts.availableAt) {\n      availableAt = opts.availableAt;\n    } else if (opts.delay && opts.delay > 0) {\n      availableAt = new Date(Date.now() + opts.delay);\n    }\n\n    // Ensure queue state exists\n    this.ensureQueueState(queueName);\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload: opts.payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: new Date(),\n      availableAt,\n      attempt: 0,\n      maxRetries: opts.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: opts.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failureCount: 0,\n      dependencies,\n      resolvedDependencies: new Set<string>(),\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    return task;\n  }\n\n  /**\n   * Retrieve the next available task from the queue.\n   */\n  getNext(queueName?: string): Task | null {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const state = this.queueStates.get(queue);\n\n    // Phase 8: Check concurrency limit\n    if (state && state.concurrencyLimit > 0) {\n      const activeCount = this.getActiveCount(queue);\n      if (activeCount >= state.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queue) continue;\n      if (task.status !== 'pending') continue;\n\n      // Phase 4: check availability\n      if (task.availableAt > now) continue;\n\n      // Phase 7: check dependencies\n      if (!this.areDependenciesResolved(task)) continue;\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort: priority first (lower = higher priority), then availableAt, then createdAt (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt += 1;\n    return task;\n  }\n\n  /**\n   * Get the count of pending tasks in a queue.\n   */\n  pendingCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  /**\n   * Get a task by ID.\n   */\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 2: Named Queues\n  // ──────────────────────────────────────────────\n\n  /**\n   * List all queue names.\n   */\n  listQueues(): string[] {\n    const queueNames = new Set<string>();\n    for (const task of this.tasks.values()) {\n      queueNames.add(task.queue);\n    }\n    // Also include queues that have state but might not have tasks\n    for (const name of this.queueStates.keys()) {\n      queueNames.add(name);\n    }\n    return Array.from(queueNames);\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 5: Retry with Backoff\n  // ──────────────────────────────────────────────\n\n  /**\n   * Mark a task as completed.\n   */\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task \"${taskId}\" not found`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not processing (status: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Phase 7: check if any blocked tasks become unblocked\n    this.resolveDependent(taskId);\n  }\n\n  /**\n   * Mark a task as failed. If retries remain, re-enqueue with backoff.\n   */\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task \"${taskId}\" not found`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not processing (status: ${task.status})`);\n    }\n\n    task.failureCount++;\n    task.error = error;\n\n    if (task.attempt < task.maxRetries) {\n      // Re-enqueue with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // Phase 6: Move to dead letter queue\n      task.status = 'failed';\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 6: Dead Letter Queue\n  // ──────────────────────────────────────────────\n\n  /**\n   * Get dead-lettered tasks for a queue.\n   */\n  getDeadLetterTasks(queueName?: string): DeadLetteredTask[] {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    return this.deadLetterQueues.get(queue) ?? [];\n  }\n\n  /**\n   * Move a dead-lettered task back to its original queue.\n   */\n  retryDeadLetter(taskId: string): Task {\n    // Find in DLQs\n    for (const [queueName, dlq] of this.deadLetterQueues.entries()) {\n      const index = dlq.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const dlTask = dlq[index];\n        dlq.splice(index, 1);\n\n        // Create a fresh task with the same payload\n        const task: Task = {\n          id: randomUUID(),\n          payload: dlTask.payload,\n          status: 'pending',\n          queue: queueName,\n          priority: dlTask.priority,\n          createdAt: new Date(),\n          availableAt: new Date(),\n          attempt: 0,\n          maxRetries: DEFAULT_MAX_RETRIES,\n          backoffDelay: DEFAULT_BACKOFF_DELAY,\n          failureCount: 0,\n          dependencies: [],\n          resolvedDependencies: new Set(),\n          progress: 0,\n        };\n\n        this.tasks.set(task.id, task);\n        return task;\n      }\n    }\n\n    throw new Error(`Dead-lettered task \"${taskId}\" not found`);\n  }\n\n  /**\n   * Clear all dead-lettered tasks for a queue.\n   */\n  clearDeadLetterQueue(queueName?: string): void {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    this.deadLetterQueues.set(queue, []);\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 7: Task Dependencies\n  // ──────────────────────────────────────────────\n\n  /**\n   * Check if a task's dependencies are all resolved.\n   */\n  getDependencyStatus(taskId: string): { resolved: string[]; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task \"${taskId}\" not found`);\n    }\n\n    const resolved: string[] = [];\n    const pending: string[] = [];\n\n    for (const depId of task.dependencies) {\n      if (task.resolvedDependencies.has(depId)) {\n        resolved.push(depId);\n      } else {\n        const depTask = this.tasks.get(depId);\n        if (depTask && depTask.status === 'completed') {\n          resolved.push(depId);\n        } else {\n          pending.push(depId);\n        }\n      }\n    }\n\n    return { resolved, pending };\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 8: Concurrency Control\n  // ──────────────────────────────────────────────\n\n  /**\n   * Set the concurrency limit for a queue. 0 means unlimited.\n   */\n  setConcurrency(queueName: string, limit: number): void {\n    const state = this.ensureQueueState(queueName);\n    state.concurrencyLimit = limit;\n  }\n\n  /**\n   * Get the concurrency limit for a queue. 0 means unlimited.\n   */\n  getConcurrency(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const state = this.queueStates.get(queue);\n    return state?.concurrencyLimit ?? 0;\n  }\n\n  /**\n   * Get the count of currently processing tasks in a queue.\n   */\n  getActiveCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'processing') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 9: Progress and Cancellation\n  // ──────────────────────────────────────────────\n\n  /**\n   * Report progress on a processing task.\n   */\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task \"${taskId}\" not found`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not processing (status: ${task.status})`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      const update: ProgressUpdate = { taskId, progress, message };\n      for (const listener of listeners) {\n        listener(update);\n      }\n    }\n  }\n\n  /**\n   * Get progress of a task.\n   */\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task \"${taskId}\" not found`);\n    }\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  /**\n   * Subscribe to progress updates for a task.\n   */\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  /**\n   * Cancel a task.\n   */\n  cancel(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task \"${taskId}\" not f