dates: number[] = [];\n      const unsub = queue.onProgress(task.id, (update) => {\n        updates.push(update.progress);\n      });\n\n      queue.reportProgress(task.id, 25);\n      unsub();\n      queue.reportProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should not allow reporting progress on non-processing task', () => {\n      const task = queue.add({ payload: 'test' });\n      expect(() => queue.reportProgress(task.id, 50)).toThrow();\n    });\n  });\n\n  describe('Cancellation', () => {\n    it('should cancel a pending task', () => {\n      const task = queue.add({ payload: 'test' });\n      queue.cancel(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should cancel a processing task', () => {\n      const task = queue.add({ payload: 'test' });\n      queue.getNext();\n      queue.cancel(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should remove cancelled pending tasks from queue', () => {\n      const t1 = queue.add({ payload: 'first' });\n      queue.add({ payload: 'second' });\n\n      queue.cancel(t1.id);\n      const next = queue.getNext();\n      expect(next?.payload).toBe('second');\n    });\n\n    it('should not allow cancelling completed tasks', () => {\n      const task = queue.add({ payload: 'test' });\n      queue.getNext();\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = queue.add({ payload: 'test', maxRetries: 3 });\n      queue.getNext();\n      queue.cancel(task.id);\n\n      // Task should remain cancelled, not re-queued\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getNext()).toBeNull();\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":986,"cache_read_in