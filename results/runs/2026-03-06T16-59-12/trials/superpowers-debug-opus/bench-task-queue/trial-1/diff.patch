+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should create a schedule', () => {
+    const schedule = queue.addSchedule({
+      id: 'daily-report',
+      cron: '0 0 * * *',
+      queue: 'reports',
+      payload: { type: 'daily' },
+    });
+
+    expect(schedule.id).toBe('daily-report');
+    expect(schedule.cron).toBe('0 0 * * *');
+    expect(schedule.queue).toBe('reports');
+  });
+
+  it('should list active schedules', () => {
+    queue.addSchedule({ id: 's1', cron: '0 * * * *', payload: 'hourly' });
+    queue.addSchedule({ id: 's2', cron: '0 0 * * *', payload: 'daily' });
+
+    const schedules = queue.listSchedules();
+    expect(schedules).toHaveLength(2);
+  });
+
+  it('should remove a schedule', () => {
+    queue.addSchedule({ id: 's1', cron: '0 * * * *', payload: 'hourly' });
+    queue.removeSchedule('s1');
+    expect(queue.listSchedules()).toHaveLength(0);
+  });
+
+  it('should enqueue tasks on tick when schedule matches', () => {
+    queue.addSchedule({
+      id: 'every-5-min',
+      cron: '*/5 * * * *',
+      payload: 'recurring',
+    });
+
+    // Tick at a time divisible by 5 minutes
+    const now = new Date('2024-01-01T00:00:00Z');
+    const tasks = queue.tick(now);
+    expect(tasks).toHaveLength(1);
+    expect(tasks[0].payload).toBe('recurring');
+  });
+
+  it('should not duplicate tasks in same minute', () => {
+    queue.addSchedule({
+      id: 'every-5-min',
+      cron: '*/5 * * * *',
