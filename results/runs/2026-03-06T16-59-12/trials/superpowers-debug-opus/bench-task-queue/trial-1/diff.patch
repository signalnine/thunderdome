EFAULT_BACKOFF_DELAY,\n          failureCount: 0,\n          dependencies: [],\n          resolvedDependencies: new Set(),\n          progress: 0,\n        };\n\n        this.tasks.set(task.id, task);\n        return task;\n      }\n    }\n\n    throw new Error(`Dead-lettered task \"${taskId}\" not found`);\n  }\n\n  /**\n   * Clear all dead-lettered tasks for a queue.\n   */\n  clearDeadLetterQueue(queueName?: string): void {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    this.deadLetterQueues.set(queue, []);\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 7: Task Dependencies\n  // ──────────────────────────────────────────────\n\n  /**\n   * Check if a task's dependencies are all resolved.\n   */\n  getDependencyStatus(taskId: string): { resolved: string[]; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task \"${taskId}\" not found`);\n    }\n\n    const resolved: string[] = [];\n    const pending: string[] = [];\n\n    for (const depId of task.dependencies) {\n      if (task.resolvedDependencies.has(depId)) {\n        resolved.push(depId);\n      } else {\n        const depTask = this.tasks.get(depId);\n        if (depTask && depTask.status === 'completed') {\n          resolved.push(depId);\n        } else {\n          pending.push(depId);\n        }\n      }\n    }\n\n    return { resolved, pending };\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 8: Concurrency Control\n  // ──────────────────────────────────────────────\n\n  /**\n   * Set the concurrency limit for a queue. 0 means unlimited.\n   */\n  setConcurrency(queueName: string, limit: number): void {\n    const state = this.ensureQueueState(queueName);\n    state.concurrencyLimit = limit;\n  }\n\n  /**\n   * Get the concurrency limit for a queue. 0 means unlimited.\n   */\n  getConcurrency(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const state = this.q