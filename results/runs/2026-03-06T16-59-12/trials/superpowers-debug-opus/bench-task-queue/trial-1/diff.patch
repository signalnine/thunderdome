+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should register and execute middleware', async () => {
+    const log: string[] = [];
+
+    queue.use(async (_task, next) => {
+      log.push('middleware1-before');
+      await next();
+      log.push('middleware1-after');
+    });
+
+    queue.process(async () => {
+      log.push('handler');
+    });
+
+    const task = queue.add({ payload: 'test' });
+    queue.getNext();
+    await queue.processTask(task.id);
+
+    expect(log).toEqual(['middleware1-before', 'handler', 'middleware1-after']);
+  });
+
+  it('should chain multiple middleware in order', async () => {
+    const log: string[] = [];
+
+    queue.use(async (_task, next) => {
+      log.push('mw1');
+      await next();
+    });
+
+    queue.use(async (_task, next) => {
+      log.push('mw2');
+      await next();
+    });
+
+    queue.process(async () => {
+      log.push('handler');
+    });
+
+    const task = queue.add({ payload: 'test' });
+    queue.getNext();
+    await queue.processTask(task.id);
+
+    expect(log).toEqual(['mw1', 'mw2', 'handler']);
+  });
+
+  it('should skip processing when middleware does not call next', async () => {
+    const log: string[] = [];
+
+    queue.use(async () => {
+      log.push('blocking-middleware');
+      // does NOT call next
+    });
+
+    queue.process(async () => {
+      log.push('handler');
+    });
+
+    const task = queue.add({ payload: 'test' });
+    queue.getNext();
+    await queue.processTask(task.id);
+
+    expect(log).toEqual(['blocking-middleware']);
+  });
+
+  it('should allow middleware to modify task', async () => {
+    queue.use(async (task, next) => {
+      (task.payload as Record<string, unknown>).modified = true;
+      await next();
+    });
+
+    let receivedPayload: unknown;
+    queue.process(async (task) => {
+      receivedPayload = task.payload;
+    });
+
+    const task = queue.add({ payload: { original: true } });
+    queue.getNext();
+    await queue.processTask(task.id);
+
+    expect(receivedPayload).toEqual({ original: true, modified: true });
+  });
+
+  it('should fail task when middleware throws', async () => {
+    queue.use(async () => {
+      throw new Error('middleware error');
+    });
+
+    const task = queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 0 });
+    queue.getNext();
+
+    await expect(queue.processTask(task.id)).rejects.toThrow('middleware error');
+
+    const updated = queue.getTask(task.id);
+    expect(updated?.status).toBe('failed');
+  });
+
+  it('should have per-queue middleware', async () => {
+    const log: string[] = [];
+
+    queue.use('q1', async (_task, next) => {
+      log.push('q1-mw');
+      await next();
+    });
+
+    queue.use('q2', async (_task, next) => {
+      log.push('q2-mw');
+      await next();
+    });
+
+    queue.process('q1', async () => { log.push('q1-handler'); });
+    queue.process('q2', async () => { log.push('q2-handler'); });
+
+    const t1 = queue.add({ payload: 'test', queue: 'q1' });
+    queue.getNext('q1');
+    await queue.processTask(t1.id);
+
+    expect(log).toEqual(['q1-mw', 'q1-handler']);
+  });
+
+  it('should work without middleware (handler only)', async () => {
+    const log: string[] = [];
+
+    queue.process(async () => {
+      log.push('handler');
+    });
+
+    const task = queue.add({ payload: 'test' });
+    queue.getNext();
+    await queue.processTask(task.id);
+
+    expect(log).toEqual(['handler']);
+  });
+
+  it('should work without handler (middleware only)', async () => {
+    const log: string[] = [];
+
+    queue.use(async (_task, next) => {
+      log.push('middleware');
+      await next();
+    });
+
+    const task = queue.add({ payload: 'test' });
+    queue.getNext();
+    await queue.processTask(task.id);
+
+    expect(log).toEqual(['middleware']);
+  });
+});
