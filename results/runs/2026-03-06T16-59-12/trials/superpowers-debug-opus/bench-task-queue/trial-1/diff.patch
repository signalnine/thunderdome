> = new Map();\n\n  /** Shutdown state */\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // ──────────────────────────────────────────────\n  // Phase 1: Basic FIFO Queue\n  // ──────────────────────────────────────────────\n\n  /**\n   * Add a task to the queue.\n   */\n  add<T = unknown>(options: AddTaskOptions<T> | T): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Queue is shutting down, cannot add new tasks');\n    }\n\n    // Support simple payload or full options\n    const opts: AddTaskOptions<T> = this.isAddTaskOptions(options)\n      ? options\n      : { payload: options };\n\n    const queueName = opts.queue ?? DEFAULT_QUEUE;\n    const priority = opts.priority ?? DEFAULT_PRIORITY;\n\n    // Phase 3: validate priority\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 7: validate dependencies\n    const dependencies = opts.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task \"${depId}\" does not exist`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      // We need to check that adding this task doesn't create cycles.\n      // Since this task doesn't exist yet, we check if any dependency\n      // transitively depends on... well, this task doesn't exist yet,\n      // so circular deps can only happen if deps form a cycle among themselves\n      // or if a dep is waiting on something that will eventually wait on this task.\n      // Since this task is new, it can't be in anyone's dep list yet.\n      // But we should still validate that dependencies themselves aren't in a cycle.\n    }\n\n    // Compute availability time (Phase 4)\n    let availableAt = new Date();\n    if (opts.availableAt) {\n      availableAt = opts.availableAt;\n    } else if (opts.delay && opts.delay > 0) {\n      availableAt = new Date(Date.now() + opts.delay);\n    }\n\n    // Ensure queue state exists\n    this.ensureQueueState(queueName);\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload: opts.payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: new Date(),\n      availableAt,\n      attempt: 0,\n      maxRetries: opts.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: opts.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failureCount: 0,\n      dependencies,\n      resolvedDependencies: new Set<string>(),\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    return task;\n  }\n\n  /**\n   * Retrieve the next available task from the queue.\n   */\n  getNext(queueName?: string): Task | null {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const state = this.queueStates.get(queue);\n\n    // Phase 8: Check concurrency limit\n    if (state && state.concurrencyLimit > 0) {\n      const activeCount = this.getActiveCount(queue);\n      if (activeCount >= state.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queue) continue;\n      if (task.status !== 'pending') continue;\n\n      // Phase 4: check availability\n      if (task.availableAt > now) continue;\n\n      // Phase 7: check dependencies\n      if (!this.areDependenciesResolved(task)) continue;\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort: priority first (lower = higher priority), then availableAt, then createdAt (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt += 1;\n    return task;\n  }\n\n  /**\n   * Get the count of pending tasks in a queue.\n   */\n  pendingCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  /**\n   * Get a task by ID.\n   */\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 2: Named Queues\n  // ──────────────────────────────────────────────\n\n  /**\n   * List all queue names.\n   */\n  listQueues(): string[] {\n    const queueNames = new Set<string>();\n    for (const task of this.tasks.values()) {\n      queueNames.add(task.queue);\n    }\n    // Also include queues that have state but might not have tasks\n    for (const name of this.queueStates.keys()) {\n      queueNames.add(name);\n    }\n    return Array.from(queueNames);\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 5: Retry with Backoff\n  // ──────────────────────────────────────────────\n\n  /**\n   * Mark a task as completed.\n   */\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task \"${taskId}\" not found`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not processing (status: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Phase 7: check if any blocked tasks become unblocked\n    this.resolveDependent(taskId);\n  }\n\n  /**\n   * Mark a task as failed. If retries rema