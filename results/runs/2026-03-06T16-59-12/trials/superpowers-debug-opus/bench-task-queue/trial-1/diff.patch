+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 3: Priority', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should default priority to 5', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(task.priority).toBe(5);
+  });
+
+  it('should accept custom priority', () => {
+    const task = queue.add({ payload: 'urgent', priority: 1 });
+    expect(task.priority).toBe(1);
+  });
+
+  it('should return higher priority tasks first', () => {
+    queue.add({ payload: 'low', priority: 10 });
+    queue.add({ payload: 'high', priority: 1 });
+    queue.add({ payload: 'medium', priority: 5 });
+
+    expect(queue.getNext()?.payload).toBe('high');
+    expect(queue.getNext()?.payload).toBe('medium');
+    expect(queue.getNext()?.payload).toBe('low');
+  });
+
+  it('should maintain FIFO within same priority', () => {
+    queue.add({ payload: 'first', priority: 3 });
+    queue.add({ payload: 'second', priority: 3 });
+    queue.add({ payload: 'third', priority: 3 });
+
+    expect(queue.getNext()?.payload).toBe('first');
+    expect(queue.getNext()?.payload).toBe('second');
+    expect(queue.getNext()?.payload).toBe('third');
+  });
+
+  it('should reject invalid priorities', () => {
+    expect(() => queue.add({ payload: 'bad', priority: 0 })).toThrow();
+    expect(() => queue.add({ payload: 'bad', priority: 11 })).toThrow();
+    expect(() => queue.add({ payload: 'bad', priority: -1 })).toThrow();
+    expect(() => queue.add({ payload: 'bad', priority: 1.5 })).toThrow();
+  });
+
+  it('should maintain per-queue priority ordering', () => {
+    queue.add({ payload: 'q1-low', queue: 'q1', priority: 10 });
+    queue.add({ payload: 'q1-high', queue: 'q1', priority: 1 });
+    queue.add({ payload: 'q2-low', queue: 'q2', priority: 10 });
+    queue.add({ payload: 'q2-high', queue: 'q2', priority: 1 });
+
+    expect(queue.getNext('q1')?.payload).toBe('q1-high');
+    expect(queue.getNext('q2')?.payload).toBe('q2-high');
+    expect(queue.getNext('q1')?.payload).toBe('q1-low');
+    expect(queue.getNext('q2')?.payload).toBe('q2-low');
+  });
+});
