@@ -0,0 +1,113 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  describe('Progress', () => {
+    it('should report progress on a processing task', () => {
+      const task = queue.add({ payload: 'test' });
+      queue.getNext();
+      queue.reportProgress(task.id, 50, 'halfway');
+
+      const progress = queue.getProgress(task.id);
+      expect(progress.progress).toBe(50);
+      expect(progress.message).toBe('halfway');
+    });
+
+    it('should start at 0 progress', () => {
+      const task = queue.add({ payload: 'test' });
+      const progress = queue.getProgress(task.id);
+      expect(progress.progress).toBe(0);
+    });
+
+    it('should reject invalid progress values', () => {
+      const task = queue.add({ payload: 'test' });
+      queue.getNext();
+      expect(() => queue.reportProgress(task.id, -1)).toThrow();
+      expect(() => queue.reportProgress(task.id, 101)).toThrow();
+    });
+
+    it('should notify progress listeners', () => {
+      const task = queue.add({ payload: 'test' });
+      queue.getNext();
+
+      const updates: number[] = [];
+      queue.onProgress(task.id, (update) => {
+        updates.push(update.progress);
+      });
+
+      queue.reportProgress(task.id, 25);
+      queue.reportProgress(task.id, 50);
+      queue.reportProgress(task.id, 75);
+
+      expect(updates).toEqual([25, 50, 75]);
+    });
+
+    it('should support unsubscribe', () => {
+      const task = queue.add({ payload: 'test' });
+      queue.getNext();
+
+      const updates: number[] = [];
+      const unsub = queue.onProgress(task.id, (update) => {
+        updates.push(update.progress);
+      });
+
+      queue.reportProgress(task.id, 25);
+      unsub();
+      queue.reportProgress(task.id, 50);
+
+      expect(updates).toEqual([25]);
+    });
+
+    it('should not allow reporting progress on non-processing task', () => {
+      const task = queue.add({ payload: 'test' });
+      expect(() => queue.reportProgress(task.id, 50)).toThrow();
+    });
+  });
+
+  describe('Cancellation', () => {
+    it('should cancel a pending task', () => {
+      const task = queue.add({ payload: 'test' });
+      queue.cancel(task.id);
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+    });
+
+    it('should cancel a processing task', () => {
+      const task = queue.add({ payload: 'test' });
+      queue.getNext();
+      queue.cancel(task.id);
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+    });
+
+    it('should remove cancelled pending tasks from queue', () => {
+      const t1 = queue.add({ payload: 'first' });
+      queue.add({ payload: 'second' });
+
+      queue.cancel(t1.id);
+      const next = queue.getNext();
+      expect(next?.payload).toBe('second');
+    });
+
+    it('should not allow cancelling completed tasks', () => {
+      const task = queue.add({ payload: 'test' });
+      queue.getNext();
+      queue.complete(task.id);
+      expect(() => queue.cancel(task.id)).toThrow();
+    });
+
+    it('should not retry cancelled tasks', () => {
+      const task = queue.add({ payload: 'test', maxRetries: 3 });
+      queue.getNext();
+      queue.cancel(task.id);
+
+      // Task should remain cancelled, not re-queued
+      expect(queue.getTask(task.id)?.status).toBe('cancelled');
+      expect(queue.getNext()).toBeNull();
+    });
+  });
+});
