diff --git a/src/TaskQueue.ts b/src/TaskQueue.ts
new file mode 100644
index 0000000..cd59dfa
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,799 @@
+import { randomUUID } from 'node:crypto';
+import {
+  Task,
+  AddTaskOptions,
+  DeadLetteredTask,
+  ProgressListener,
+  ProgressUpdate,
+  Schedule,
+  MiddlewareFunction,
+  TaskHandler,
+  ShutdownResult,
+} from './types.js';
+import { parseCron, cronMatches, CronExpression } from './cron.js';
+
+const DEFAULT_QUEUE = 'default';
+const DEFAULT_PRIORITY = 5;
+const DEFAULT_MAX_RETRIES = 3;
+const DEFAULT_BACKOFF_DELAY = 1000;
+
+/** Internal queue state */
+interface QueueState {
+  concurrencyLimit: number; // 0 means unlimited
+  middleware: MiddlewareFunction[];
+  handler?: TaskHandler;
+}
+
+export class TaskQueue {
+  /** All tasks indexed by ID */
+  private tasks: Map<string, Task> = new Map();
+
+  /** Per-queue state */
+  private queueStates: Map<string, QueueState> = new Map();
+
+  /** Dead letter queues - per queue name */
+  private deadLetterQueues: Map<string, DeadLetteredTask[]> = new Map();
+
+  /** Progress listeners - per task ID */
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+
+  /** Recurring schedules */
+  private schedules: Map<string, Schedule & { parsed: CronExpression }> = new Map();
+
+  /** Shutdown state */
+  private isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // ──────────────────────────────────────────────
+  // Phase 1: Basic FIFO Queue
+  // ──────────────────────────────────────────────
+
+  /**
+   * Add a task to the queue.
+   */
+  add<T = unknown>(options: AddTaskOptions<T> | T): Task<T> {
+    if (this.isShuttingDown) {
+      throw new Error('Queue is shutting down, cannot add new tasks');
+    }
+
+    // Support simple payload or full options
+    const opts: AddTaskOptions<T> = this.isAddTaskOptions(options)
+      ? options
+      : { payload: options };
+
+    const queueName = opts.queue ?? DEFAULT_QUEUE;
+    const priority = opts.priority ?? DEFAULT_PRIORITY;
+
+    // Phase 3: validate priority
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Phase 7: validate dependencies
+    const dependencies = opts.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task "${depId}" does not exist`);
+      }
+    }
+
+    // Circular dependency detection
+    if (dependencies.length > 0) {
+      // We need to check that adding this task doesn't create cycles.
+      // Since this task doesn't exist yet, we check if any dependency
+      // transitively depends on... well, this task doesn't exist yet,
+      // so circular deps can only happen if deps form a cycle among themselves
+      // or if a dep is waiting on something that will eventually wait on this task.
+      // Since this task is new, it can't be in anyone's dep list yet.
+      // But we should still validate that dependencies themselves aren't in a cycle.
+    }
+
+    // Compute availability time (Phase 4)
+    let availableAt = new Date();
+    if (opts.availableAt) {
+      availableAt = opts.availableAt;
+    } else if (opts.delay && opts.delay > 0) {
+      availableAt = new Date(Date.now() + opts.delay);
+    }
+
+    // Ensure queue state exists
+    this.ensureQueueState(queueName);
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload: opts.payload,
+      status: 'pending',
+      queue: queueName,
+      priority,
+      createdAt: new Date(),
+      availableAt,
+      attempt: 0,
+      maxRetries: opts.maxRetries ?? DEFAULT_MAX_RETRIES,
+      backoffDelay: opts.backoffDelay ?? DEFAULT_BACKOFF_DELAY,
+      failureCount: 0,
+      dependencies,
+      resolvedDependencies: new Set<string>(),
+      progress: 0,
+    };
+
+    this.tasks.set(task.id, task as Task);
+    return task;
+  }
+
+  /**
+   * Retrieve the next available task from the queue.
+   */
+  getNext(queueName?: string): Task | null {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const state = this.queueStates.get(queue);
+
+    // Phase 8: Check concurrency limit
+    if (state && state.concurrencyLimit > 0) {
+      const activeCount = this.getActiveCount(queue);
+      if (activeCount >= state.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+    const candidates: Task[] = [];
+
+    for (const task of this.tasks.values()) {
+      if (task.queue !== queue) continue;
+      if (task.status !== 'pending') continue;
+
+      // Phase 4: check availability
+      if (task.availableAt > now) continue;
+
+      // Phase 7: check dependencies
+      if (!this.areDependenciesResolved(task)) continue;
+
+      candidates.push(task);
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Sort: priority first (lower = higher priority), then availableAt, then createdAt (FIFO)
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();
+      if (availDiff !== 0) return availDiff;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempt += 1;
+    return task;
+  }
+
+  /**
+   * Get the count of pending tasks in a queue.
+   */
+  pendingCount(queueName?: string): number {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queue && task.status === 'pending') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  /**
+   * Get a task by ID.
+   */
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 2: Named Queues
+  // ──────────────────────────────────────────────
+
+  /**
+   * List all queue names.
+   */
+  listQueues(): string[] {
+    const queueNames = new Set<string>();
+    for (const task of this.tasks.values()) {
+      queueNames.add(task.queue);
+    }
+    // Also include queues that have state but might not have tasks
+    for (const name of this.queueStates.keys()) {
+      queueNames.add(name);
+    }
+    return Array.from(queueNames);
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 5: Retry with Backoff
+  // ──────────────────────────────────────────────
+
+  /**
+   * Mark a task as completed.
+   */
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not processing (status: ${task.status})`);
+    }
+
+    task.status = 'completed';
+    task.progress = 100;
+
+    // Phase 7: check if any blocked tasks become unblocked
+    this.resolveDependent(taskId);
+  }
+
+  /**
+   * Mark a task as failed. If retries remain, re-enqueue with backoff.
+   */
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not processing (status: ${task.status})`);
+    }
+
+    task.failureCount++;
+    task.error = error;
+
+    if (task.attempt < task.maxRetries) {
+      // Re-enqueue with exponential backoff
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.availableAt = new Date(Date.now() + delay);
+      task.status = 'pending';
+      task.progress = 0;
+      task.progressMessage = undefined;
+    } else {
+      // Phase 6: Move to dead letter queue
+      task.status = 'failed';
+      this.moveToDeadLetterQueue(task);
+    }
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 6: Dead Letter Queue
+  // ──────────────────────────────────────────────
+
+  /**
+   * Get dead-lettered tasks for a queue.
+   */
+  getDeadLetterTasks(queueName?: string): DeadLetteredTask[] {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    return this.deadLetterQueues.get(queue) ?? [];
+  }
+
+  /**
+   * Move a dead-lettered task back to its original queue.
+   */
+  retryDeadLetter(taskId: string): Task {
+    // Find in DLQs
+    for (const [queueName, dlq] of this.deadLetterQueues.entries()) {
+      const index = dlq.findIndex(t => t.id === taskId);
+      if (index !== -1) {
+        const dlTask = dlq[index];
+        dlq.splice(index, 1);
+
+        // Create a fresh task with the same payload
+        const task: Task = {
+          id: randomUUID(),
+          payload: dlTask.payload,
+          status: 'pending',
+          queue: queueName,
+          priority: dlTask.priority,
+          createdAt: new Date(),
+          availableAt: new Date(),
+          attempt: 0,
+          maxRetries: DEFAULT_MAX_RETRIES,
+          backoffDelay: DEFAULT_BACKOFF_DELAY,
+          failureCount: 0,
+          dependencies: [],
+          resolvedDependencies: new Set(),
+          progress: 0,
+        };
+
+        this.tasks.set(task.id, task);
+        return task;
+      }
+    }
+
+    throw new Error(`Dead-lettered task "${taskId}" not found`);
+  }
+
+  /**
+   * Clear all dead-lettered tasks for a queue.
+   */
+  clearDeadLetterQueue(queueName?: string): void {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    this.deadLetterQueues.set(queue, []);
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 7: Task Dependencies
+  // ──────────────────────────────────────────────
+
+  /**
+   * Check if a task's dependencies are all resolved.
+   */
+  getDependencyStatus(taskId: string): { resolved: string[]; pending: string[] } {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found`);
+    }
+
+    const resolved: string[] = [];
+    const pending: string[] = [];
+
+    for (const depId of task.dependencies) {
+      if (task.resolvedDependencies.has(depId)) {
+        resolved.push(depId);
+      } else {
+        const depTask = this.tasks.get(depId);
+        if (depTask && depTask.status === 'completed') {
+          resolved.push(depId);
+        } else {
+          pending.push(depId);
+        }
+      }
+    }
+
+    return { resolved, pending };
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 8: Concurrency Control
+  // ──────────────────────────────────────────────
+
+  /**
+   * Set the concurrency limit for a queue. 0 means unlimited.
+   */
+  setConcurrency(queueName: string, limit: number): void {
+    const state = this.ensureQueueState(queueName);
+    state.concurrencyLimit = limit;
+  }
+
+  /**
+   * Get the concurrency limit for a queue. 0 means unlimited.
+   */
+  getConcurrency(queueName?: string): number {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const state = this.queueStates.get(queue);
+    return state?.concurrencyLimit ?? 0;
+  }
+
+  /**
+   * Get the count of currently processing tasks in a queue.
+   */
+  getActiveCount(queueName?: string): number {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queue && task.status === 'processing') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 9: Progress and Cancellation
+  // ──────────────────────────────────────────────
+
+  /**
+   * Report progress on a processing task.
+   */
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not processing (status: ${task.status})`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      const update: ProgressUpdate = { taskId, progress, message };
+      for (const listener of listeners) {
+        listener(update);
+      }
+    }
+  }
+
+  /**
+   * Get progress of a task.
+   */
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found`);
+    }
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  /**
+   * Subscribe to progress updates for a task.
+   */
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+        if (listeners.size === 0) {
+          this.progressListeners.delete(taskId);
+        }
+      }
+    };
+  }
+
+  /**
+   * Cancel a task.
+   */
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found`);
+    }
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" cannot be cancelled (status: ${task.status})`);
+    }
+
+    task.status = 'cancelled';
+    task.progress = 0;
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 10: Recurring Tasks
+  // ──────────────────────────────────────────────
+
+  /**
+   * Create a recurring schedule.
+   */
+  addSchedule<T = unknown>(options: {
+    id?: string;
+    cron: string;
+    queue?: string;
+    payload: T;
+  }): Schedule<T> {
+    if (this.isShuttingDown) {
+      throw new Error('Queue is shutting down, cannot add schedules');
+    }
+
+    const parsed = parseCron(options.cron);
+    const id = options.id ?? randomUUID();
+    const queue = options.queue ?? DEFAULT_QUEUE;
+
+    const schedule: Schedule<T> & { parsed: CronExpression } = {
+      id,
+      cron: options.cron,
+      queue,
+      payload: options.payload,
+      parsed,
+    };
+
+    this.schedules.set(id, schedule as Schedule & { parsed: CronExpression });
+
+    return {
+      id,
+      cron: options.cron,
+      queue,
+      payload: options.payload,
+    };
+  }
+
+  /**
+   * Remove a recurring schedule.
+   */
+  removeSchedule(scheduleId: string): boolean {
+    return this.schedules.delete(scheduleId);
+  }
+
+  /**
+   * List all active schedules.
+   */
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values()).map(s => ({
+      id: s.id,
+      cron: s.cron,
+      queue: s.queue,
+      payload: s.payload,
+      lastRun: s.lastRun,
+    }));
+  }
+
+  /**
+   * Manual tick: check all schedules and enqueue tasks for due ones.
+   */
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const enqueuedTasks: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (cronMatches(schedule.parsed, currentTime)) {
+        // Only enqueue if we haven't already enqueued for this minute
+        if (schedule.lastRun) {
+          const lastMinute = new Date(schedule.lastRun);
+          lastMinute.setSeconds(0, 0);
+          const currentMinute = new Date(currentTime);
+          currentMinute.setSeconds(0, 0);
+          if (lastMinute.getTime() === currentMinute.getTime()) {
+            continue;
+          }
+        }
+
+        schedule.lastRun = currentTime;
+        const task = this.add({
+          payload: schedule.payload,
+          queue: schedule.queue,
+        });
+        enqueuedTasks.push(task);
+      }
+    }
+
+    return enqueuedTasks;
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 11: Middleware Pipeline
+  // ──────────────────────────────────────────────
+
+  /**
+   * Register middleware for a queue.
+   */
+  use(queueName: string, middleware: MiddlewareFunction): void;
+  use(middleware: MiddlewareFunction): void;
+  use(queueNameOrMiddleware: string | MiddlewareFunction, middleware?: MiddlewareFunction): void {
+    let queueName: string;
+    let mw: MiddlewareFunction;
+
+    if (typeof queueNameOrMiddleware === 'string') {
+      queueName = queueNameOrMiddleware;
+      mw = middleware!;
+    } else {
+      queueName = DEFAULT_QUEUE;
+      mw = queueNameOrMiddleware;
+    }
+
+    const state = this.ensureQueueState(queueName);
+    state.middleware.push(mw);
+  }
+
+  /**
+   * Register a processing handler for a queue.
+   */
+  process(queueName: string, handler: TaskHandler): void;
+  process(handler: TaskHandler): void;
+  process(queueNameOrHandler: string | TaskHandler, handler?: TaskHandler): void {
+    let queueName: string;
+    let h: TaskHandler;
+
+    if (typeof queueNameOrHandler === 'string') {
+      queueName = queueNameOrHandler;
+      h = handler!;
+    } else {
+      queueName = DEFAULT_QUEUE;
+      h = queueNameOrHandler;
+    }
+
+    const state = this.ensureQueueState(queueName);
+    state.handler = h;
+  }
+
+  /**
+   * Process a task through the middleware pipeline and handler.
+   */
+  async processTask(taskId: string): Promise<void> {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found`);
+    }
+
+    const state = this.queueStates.get(task.queue);
+    const middlewares = state?.middleware ?? [];
+    const handler = state?.handler;
+
+    let index = 0;
+
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, async () => {
+          await executeNext();
+        });
+        // If middleware didn't call next, stop the chain
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+    } catch (err) {
+      // Middleware or handler error -> fail the task
+      const errorMessage = err instanceof Error ? err.message : String(err);
+      if (task.status === 'processing') {
+        this.fail(taskId, errorMessage);
+      }
+      throw err;
+    }
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 12: Graceful Shutdown
+  // ──────────────────────────────────────────────
+
+  /**
+   * Register a callback to be called during shutdown.
+   */
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  /**
+   * Initiate graceful shutdown.
+   */
+  shutdown(options?: { timeout?: number }): Promise<ShutdownResult> {
+    // Idempotent: return same promise if already shutting down
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.executeShutdown(options?.timeout ?? 30000);
+    return this.shutdownPromise;
+  }
+
+  /**
+   * Check if the queue is shutting down.
+   */
+  get shuttingDown(): boolean {
+    return this.isShuttingDown;
+  }
+
+  // ──────────────────────────────────────────────
+  // Private helpers
+  // ──────────────────────────────────────────────
+
+  private isAddTaskOptions(value: unknown): value is AddTaskOptions {
+    return (
+      typeof value === 'object' &&
+      value !== null &&
+      'payload' in value
+    );
+  }
+
+  private ensureQueueState(queueName: string): QueueState {
+    if (!this.queueStates.has(queueName)) {
+      this.queueStates.set(queueName, {
+        concurrencyLimit: 0,
+        middleware: [],
+      });
+    }
+    return this.queueStates.get(queueName)!;
+  }
+
+  private moveToDeadLetterQueue(task: Task): void {
+    if (!this.deadLetterQueues.has(task.queue)) {
+      this.deadLetterQueues.set(task.queue, []);
+    }
+
+    const dlTask: DeadLetteredTask = {
+      id: task.id,
+      payload: task.payload,
+      queue: task.queue,
+      priority: task.priority,
+      createdAt: task.createdAt,
+      error: task.error,
+      failureCount: task.failureCount,
+      deadLetteredAt: new Date(),
+    };
+
+    this.deadLetterQueues.get(task.queue)!.push(dlTask);
+  }
+
+  private areDependenciesResolved(task: Task): boolean {
+    if (task.dependencies.length === 0) return true;
+
+    for (const depId of task.dependencies) {
+      if (task.resolvedDependencies.has(depId)) continue;
+
+      const depTask = this.tasks.get(depId);
+      if (!depTask || depTask.status !== 'completed') {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private resolveDependent(completedTaskId: string): void {
+    for (const task of this.tasks.values()) {
+      if (task.dependencies.includes(completedTaskId)) {
+        task.resolvedDependencies.add(completedTaskId);
+      }
+    }
+  }
+
+  private async executeShutdown(timeout: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+    let completed = 0;
+    let cancelled = 0;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      try {
+        await cb();
+      } catch {
+        // Callbacks should not prevent shutdown
+      }
+    }
+
+    // Cancel all pending tasks
+    for (const task of this.tasks.values()) {
+      if (task.status === 'pending') {
+        task.status = 'cancelled';
+        cancelled++;
+      }
+    }
+
+    // Wait for processing tasks with timeout
+    const processingTasks = this.getProcessingTasks();
+    if (processingTasks.length > 0) {
+      const waitStart = Date.now();
+      while (Date.now() - waitStart < timeout) {
+        const stillProcessing = this.getProcessingTasks();
+        if (stillProcessing.length === 0) break;
+        await new Promise(resolve => setTimeout(resolve, 50));
+      }
+
+      // Force-cancel remaining processing tasks
+      for (const task of this.getProcessingTasks()) {
+        task.status = 'cancelled';
+        cancelled++;
+      }
+    }
+
+    // Count completed tasks
+    for (const task of this.tasks.values()) {
+      if (task.status === 'completed') {
+        completed++;
+      }
+    }
+
+    const duration = Date.now() - startTime;
+    return { completed, cancelled, duration };
+  }
+
+  private getProcessingTasks(): Task[] {
+    const result: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        result.push(task);
+      }
+    }
+    return result;
+  }
+}
