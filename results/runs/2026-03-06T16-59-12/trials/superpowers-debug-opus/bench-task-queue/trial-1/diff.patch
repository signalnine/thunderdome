+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../TaskQueue.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should add delayed tasks with delay in ms', () => {
+    const task = queue.add({ payload: 'delayed', delay: 5000 });
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should not return delayed tasks before their time', () => {
+    queue.add({ payload: 'delayed', delay: 60000 });
+    expect(queue.getNext()).toBeNull();
+  });
+
+  it('should return non-delayed tasks over delayed ones', () => {
+    queue.add({ payload: 'delayed', delay: 60000 });
+    queue.add({ payload: 'immediate' });
+
+    const task = queue.getNext();
+    expect(task?.payload).toBe('immediate');
+  });
+
+  it('should accept a specific availableAt date', () => {
+    const futureDate = new Date(Date.now() + 60000);
+    const task = queue.add({ payload: 'scheduled', availableAt: futureDate });
+    expect(task.availableAt.getTime()).toBe(futureDate.getTime());
+  });
+
+  it('should return delayed tasks after their time has passed', () => {
+    const pastDate = new Date(Date.now() - 1000);
+    queue.add({ payload: 'ready', availableAt: pastDate });
+
+    const task = queue.getNext();
+    expect(task?.payload).toBe('ready');
+  });
+
+  it('should order by availability time when multiple delayed tasks become available', () => {
+    const now = Date.now();
+    queue.add({ payload: 'later', availableAt: new Date(now - 100) });
+    queue.add({ payload: 'earlier', availableAt: new Date(now - 200) });
+
+    expect(queue.getNext()?.payload).toBe('earlier');
+    expect(queue.getNext()?.payload).toBe('later');
+  });
+
+  it('should work with named queues', () => {
+    queue.add({ payload: 'delayed', queue: 'emails', delay: 60000 });
+    queue.add({ payload: 'immediate', queue: 'emails' });
+
+    const task = queue.getNext('emails');
+    expect(task?.payload).toBe('immediate');
+  });
+
+  it('should track availability time on task object', () => {
+    const task = queue.add({ payload: 'test', delay: 5000 });
+    expect(task.availableAt).toBeInstanceOf(Date);
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+});
