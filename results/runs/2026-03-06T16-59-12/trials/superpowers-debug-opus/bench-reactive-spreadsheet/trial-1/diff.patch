+          while (this.peek()?.type === 'COMMA') {
+            this.consume();
+            args.push(this.parseComparison());
+          }
+        }
+        this.expect('RPAREN');
+        return { type: 'func', name, args };
+      }
+      case 'LPAREN': {
+        this.consume();
+        const node = this.parseComparison();
+        this.expect('RPAREN');
+        return node;
+      }
+      default:
+        throw new Error(`Unexpected token: ${t.value} (${t.type})`);
+    }
+  }
+}
+
+// ─── Dependency Extraction ──────────────────────────────────────────────────
+
+function extractDependencies(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+  const walk = (n: ASTNode) => {
+    switch (n.type) {
+      case 'cell':
+        deps.add(n.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(n.start, n.end);
+        for (const c of cells) deps.add(c);
+        break;
+      }
+      case 'binop':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'func':
+        for (const arg of n.args) walk(arg);
+        break;
+      // number, string, boolean have no deps
+    }
+  };
+  walk(node);
+  return deps;
+}
+
+// ─── Evaluator ──────────────────────────────────────────────────────────────
+
+type CellValue = string | number | boolean | null;
+
+function evaluate(node: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+    case 'string':
+      return node.value;
+    case 'boolean':
+      return node.value;
+    case 'cell':
+      return getCellValue(node.ref);
+    case 'range':
+      throw new Error('Range cannot be used outside of a function');
+    case 'unary': {
+      const val = evaluate(node.operand, getCellValue);
+      if (node.op === '-' && typeof val === 'number') return -val;
+      throw new Error(`Cannot negate non-number: ${val}`);
+    }
+    case 'binop': {
+      const left = evaluate(node.left, getCellValue);
+      const right = evaluate(node.right, getCellValue);
+
+      // Comparison operators
+      switch (node.op) {
+        case '=':
+          return left === right;
+        case '<>':
+          return left !== right;
+        case '>':
+          return (left as number) > (right as number);
+        case '<':
+          return (left as number) < (right as number);
+        case '>=':
+          return (left as number) >= (right as number);
+        case '<=':
+          return (left as number) <= (right as number);
+      }
+
+      // Arithmetic operators
+      const l = typeof left === 'number' ? left : 0;
+      const r = typeof right === 'number' ? right : 0;
+      switch (node.op) {
+        case '+':
+          return l + r;
+        case '-':
+          return l - r;
+        case '*':
+          return l * r;
+        case '/':
+          if (r === 0) throw new Error('Division by zero');
+          return l / r;
+      }
+      throw new Error(`Unknown operator: ${node.op}`);
+    }
+    case 'func': {
+      return evaluateFunction(node.name, node.args, getCellValue);
+    }
+  }
