+
+function resolveRange(arg: ASTNode, getCellValue: (ref: string) => CellValue): CellValue[] {
+  if (arg.type === 'range') {
+    const cells = expandRange(arg.start, arg.end);
+    return cells.map(c => getCellValue(c));
+  }
+  return [evaluate(arg, getCellValue)];
+}
+
+function evaluateFunction(name: string, args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue {
