+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  // ─── Basic Values ───────────────────────────────────────────────────────
+
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve floating point numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+
+    it('should store and retrieve strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBeNull();
+    });
+
+    it('should handle case-insensitive cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('a1')).toBe(10);
+    });
+  });
+
+  // ─── Display ────────────────────────────────────────────────────────────
+
+  describe('getDisplay', () => {
+    it('should display numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display computed formula values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  // ─── getCells ───────────────────────────────────────────────────────────
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+  });
+
+  // ─── Simple Formulas ──────────────────────────────────────────────────
+
+  describe('simple formulas', () => {
+    it('should evaluate arithmetic: addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate arithmetic: subtraction', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 50);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate arithmetic: multiplication', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate arithmetic: division', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should handle parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('B1', 3);
+      sheet.set('C1', '=(A1+B1)*2');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should handle operator precedence', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('B1', 3);
+      sheet.set('C1', 4);
+      sheet.set('D1', '=A1+B1*C1');
+      expect(sheet.get('D1')).toBe(14);
+    });
+
+    it('should handle numeric literals in formulas', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+    });
+
+    it('should handle unary minus', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-10);
+    });
+  });
+
+  // ─── Comparison Operators ─────────────────────────────────────────────
+
+  describe('comparison operators', () => {
+    it('should evaluate greater than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1>A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate less than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1<A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate greater than or equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1>=A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate less than or equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1<=A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('A3', '=A1=A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+
+    it('should evaluate not equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 3);
+      sheet.set('A3', '=A1<>A2');
+      expect(sheet.get('A3')).toBe(true);
+    });
+  });
+
+  // ─── Built-in Functions ───────────────────────────────────────────────
+
+  describe('SUM', () => {
+    it('should sum a column range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('A3', 3);
+      sheet.set('A4', 4);
+      sheet.set('A5', 5);
+      sheet.set('B1', '=SUM(A1:A5)');
+      expect(sheet.get('B1')).toBe(15);
+    });
+
+    it('should sum a row range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', 30);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(60);
+    });
+
+    it('should sum a block range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('B1', 3);
+      sheet.set('B2', 4);
+      sheet.set('C1', '=SUM(A1:B2)');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should ignore non-numeric values in SUM', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 'text');
+      sheet.set('A3', 20);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+  });
+
+  describe('AVERAGE', () => {
+    it('should compute average', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
+  describe('MIN', () => {
+    it('should find minimum', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MIN(A1:A3)');
+      expect(sheet.get('B1')).toBe(5);
+    });
+  });
+
+  describe('MAX', () => {
+    it('should find maximum', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MAX(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
+  describe('COUNT', () => {
+    it('should count numeric values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 'text');
+      sheet.set('A3', 20);
+      sheet.set('A4', true);
+      sheet.set('B1', '=COUNT(A1:A4)');
+      expect(sheet.get('B1')).toBe(2);
+    });
+  });
+
+  describe('IF', () => {
