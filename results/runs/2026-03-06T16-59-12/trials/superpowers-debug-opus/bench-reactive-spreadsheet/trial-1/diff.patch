+            sum += v;
+            count++;
+          }
+        }
+      }
+      return count === 0 ? 0 : sum / count;
+    }
+    case 'MIN': {
+      let min = Infinity;
+      for (const arg of args) {
+        const vals = resolveRange(arg, getCellValue);
+        for (const v of vals) {
+          if (typeof v === 'number' && v < min) min = v;
+        }
+      }
+      return min === Infinity ? 0 : min;
+    }
+    case 'MAX': {
+      let max = -Infinity;
+      for (const arg of args) {
+        const vals = resolveRange(arg, getCellValue);
+        for (const v of vals) {
+          if (typeof v === 'number' && v > max) max = v;
+        }
+      }
+      return max === -Infinity ? 0 : max;
+    }
+    case 'COUNT': {
+      let count = 0;
+      for (const arg of args) {
+        const vals = resolveRange(arg, getCellValue);
+        for (const v of vals) {
+          if (typeof v === 'number') count++;
+        }
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length < 3) throw new Error('IF requires 3 arguments');
+      const condition = evaluate(args[0], getCellValue);
+      if (condition === true || (typeof condition === 'number' && condition !== 0)) {
+        return evaluate(args[1], getCellValue);
+      }
+      return evaluate(args[2], getCellValue);
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// ─── Spreadsheet Class ─────────────────────────────────────────────────────
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  computed: CellValue;
+  deps: Set<string>; // cells this cell depends on
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: key cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    // Parse the value
+    let formula: ASTNode | null = null;
+    let newDeps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const tokens = tokenize(value.substring(1));
+      formula = new Parser(tokens).parse();
+      newDeps = extractDependencies(formula);
+    }
+
+    // Check for circular references before committing
+    if (newDeps.size > 0) {
+      this.checkCircular(ref, newDeps);
+    }
+
+    // Remove old reverse dependencies
+    const existing = this.cells.get(ref);
+    if (existing) {
+      for (const dep of existing.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    // Add new reverse dependencies
+    for (const dep of newDeps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Compute value
+    const computed = formula ? evaluate(formula, (r) => this.getComputed(r)) : this.coerceRaw(value);
+
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      computed,
+      deps: newDeps,
+    };
+
+    this.cells.set(ref, cellData);
+
+    // Propagate reactive updates
+    this.propagate(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  private coerceRaw(value: string | number | boolean): CellValue {
+    if (typeof value === 'number' || typeof value === 'boolean') return value;
+    // String values are stored as strings
+    return value;
+  }
+
+  private getComputed(ref: string): CellValue {
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  private checkCircular(target: string, deps: Set<string>): void {
+    // BFS/DFS from deps to see if we reach target
+    const visited = new Set<string>();
+    const stack = [...deps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === target) {
+        throw new Error(`Circular reference detected: ${target}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.deps) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private propagate(changedRef: string): void {
+    // Topological sort of all transitive dependents, then recompute in order
+    const visited = new Set<string>();
+    const order: string[] = [];
+
+    const visit = (ref: string) => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      order.push(ref);
+    };
+
+    // Start from direct dependents of changedRef
+    const directDeps = this.dependents.get(changedRef);
+    if (!directDeps || directDeps.size === 0) return;
+
+    for (const dep of directDeps) {
+      visit(dep);
+    }
+
+    // Recompute in reverse topological order
+    order.reverse();
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        data.computed = evaluate(data.formula, (r) => this.getComputed(r));
+      }
+    }
+  }
+}
