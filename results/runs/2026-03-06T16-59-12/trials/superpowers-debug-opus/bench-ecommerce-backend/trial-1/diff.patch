alytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cartId1 = cartService.createCart('user1');\n    cartService.addItem(cartId1, 'p1', 1);\n    const cartId2 = cartService.createCart('user2');\n    cartService.addItem(cartId2, 'p1', 1);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    orders.createOrder('user1', cartId1, 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // 1 order / 2 carts = 0.5\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should rank top products', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, 'p1', 3);\n    cartService.addItem(cartId, 'p2', 1);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.createOrder('user1', cartId, 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n  });\n\n  it('should return 0 for conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n});\n\ndescribe('Integration: Full Order Flow', () => {\n  it('should process a complete order lifecycle', async () => {\n    const bus = new EventBus();\n\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const productId = catalog.createProduct('Widget', 25.00, 'gadgets');\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Set inventory\n    inventory.setStock(productId, 50);\n\n    // Create cart and add item\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, productId, 2);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Calculate total\n    const cart = cartService.getCart(cartId);\n    const price = pricing.getPrice(productId);\n    const totals = pricing.calculateTotal(\n      cart!.items.map(i => ({ ...i, price }))\n    );\n    expect(totals.subtotal).toBe(50);\n    expect(totals.tax).toBe(5);\n    expect(totals.total).toBe(55);\n\n    // Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n    expect(inventory.getStock(productId)).toBe(48);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, totals.total);\n    const order = orders.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    const updatedOrder = orders.getOrder(orderId);\n    expect(updatedOrder!.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    const userNotifs = notifications.getNotifications('user1');\n    expect(userNotifs.length).toBeGreaterThanOrEqual(3);\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBe(55);\n    expect(analytics.getEventCount(Events.PRODUCT_CREA