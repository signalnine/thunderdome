Res.body.id;\n   844→\n   845→    const q1 = await connectWs(port, docId);\n   846→    await waitForMessage(q1, 'sync');\n   847→\n   848→    const q2 = await connectWs(port, docId);\n   849→    await waitForMessage(q2, 'sync');\n   850→\n   851→    // Client 1: insert at beginning\n   852→    q1.ws.send(JSON.stringify({\n   853→      type: 'operation',\n   854→      version: 0,\n   855→      components: [\n   856→        { type: 'insert', text: 'X' },\n   857→        { type: 'retain', count: 2 },\n   858→      ],\n   859→    }));\n   860→\n   861→    // Client 2: insert at end\n   862→    q2.ws.send(JSON.stringify({\n   863→      type: 'operation',\n   864→      version: 0,\n   865→      components: [\n   866→        { type: 'retain', count: 2 },\n   867→        { type: 'insert', text: 'Y' },\n   868→      ],\n   869→    }));\n   870→\n   871→    await waitForMessage(q1, 'ack');\n   872→    await waitForMessage(q2, 'ack');\n   873→\n   874→    await new Promise(r => setTimeout(r, 100));\n   875→\n   876→    const docRes = await request(`http://localhost:${port}`)\n   877→      .get(`/documents/${docId}`);\n   878→    expect(docRes.body.content).toBe('XABY');\n   879→\n   880→    await closeWs(q1);\n   881→    await closeWs(q2);\n   882→  });\n   883→\n   884→  it('should preserve all content from concurrent multi-char inserts', async () => {\n   885→    const createRes = await request(`http://localhost:${port}`)\n   886→      .post('/documents')\n   887→      .send({ title: 'Multi Char', content: '' });\n   888→    const docId = createRes.body.id;\n   889→\n   890→    const q1 = await connectWs(port, docId);\n   891→    await waitForMessage(q1, 'sync');\n   892→\n   893→    const q2 = await connectWs(port, docId);\n   894→    await waitForMessage(q2, 'sync');\n   895→\n   896→    q1.ws.send(JSON.stringify({\n   897→      type: 'operation',\n   898→      version: 0,\n   899→      components: [{ type: 'insert', text: 'Hello' }],\n   900→    }));\n   901→\n   902→    