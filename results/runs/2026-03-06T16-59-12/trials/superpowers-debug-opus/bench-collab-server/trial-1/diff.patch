s.json(doc);\n    } catch (err) {\n      res.status(500).json({ error: 'Failed to update document' });\n    }\n  });\n\n  // Partially update a document\n  router.patch('/documents/:id', (req: Request, res: Response) => {\n    try {\n      const { title, content } = req.body;\n      const doc = database.updateDocument(req.params.id, { title, content });\n      if (!doc) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n      res.json(doc);\n    } catch (err) {\n      res.status(500).json({ error: 'Failed to update document' });\n    }\n  });\n\n  // Delete a document\n  router.delete('/documents/:id', (req: Request, res: Response) => {\n    try {\n      const deleted = database.deleteDocument(req.params.id);\n      if (!deleted) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n      res.status(204).send();\n    } catch (err) {\n      res.status(500).json({ error: 'Failed to delete document' });\n    }\n  });\n\n  // Get document version history\n  router.get('/documents/:id/versions', (req: Request, res: Response) => {\n    try {\n      const doc = database.getDocument(req.params.id);\n      if (!doc) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n      const versions = database.getVersions(req.params.id);\n      res.json(versions);\n    } catch (err) {\n      res.status(500).json({ error: 'Failed to get versions' });\n    }\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":338,"cache_read_input_tokens":30660,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":338},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"dffd4562-2ac8-427b-9ba3-553141feeb15","uuid":"972fa225-a2a9-4bb1-bb74-4fd5cdaaf9f5"}
