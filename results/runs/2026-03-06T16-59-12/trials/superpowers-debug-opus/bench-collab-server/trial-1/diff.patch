es: Record<string, unknown>[] = [];\n    const handler = (data: Buffer | string) => {\n      messages.push(JSON.parse(typeof data === 'string' ? data : data.toString()));\n    };\n    ws.on('message', handler);\n    setTimeout(() => {\n      ws.removeListener('message', handler);\n      resolve(messages);\n    }, durationMs);\n  });\n}\n\nfunction closeWs(ws: WebSocket): Promise<void> {\n  return new Promise((resolve) => {\n    if (ws.readyState === WebSocket.CLOSED || ws.readyState === WebSocket.CLOSING) {\n      resolve();\n      return;\n    }\n    ws.on('close', () => resolve());\n    ws.close();\n  });\n}","newString":"// Message queue that buffers all messages from a WebSocket\ninterface QueuedWs {\n  ws: WebSocket;\n  messages: Record<string, unknown>[];\n  waiters: Array<{ resolve: (msg: Record<string, unknown>) => void; reject: (err: Error) => void; filter?: string }>;\n}\n\nfunction createQueuedWs(ws: WebSocket): QueuedWs {\n  const q: QueuedWs = { ws, messages: [], waiters: [] };\n  ws.on('message', (data: Buffer | string) => {\n    const msg = JSON.parse(typeof data === 'string' ? data : data.toString());\n    // Check if any waiter wants this message\n    for (let i = 0; i < q.waiters.length; i++) {\n      const w = q.waiters[i];\n      if (!w.filter || msg.type === w.filter) {\n        q.waiters.splice(i, 1);\n        w.resolve(msg);\n        return;\n      }\n    }\n    // No waiter matched, buffer it\n    q.messages.push(msg);\n  });\n  return q;\n}\n\n// Helper to connect a WebSocket to a document, buffering messages from start\nfunction connectWs(port: number, docId: string): Promise<QueuedWs> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}`);\n    const q = createQueuedWs(ws);\n    ws.on('open', () => resolve(q));\n    ws.on('error', reject);\n  });\n}\n\n// Helper to wait for a specific message type (checks buffer first)\nfunction waitForMessage(q: QueuedWs, type: string, timeout = 5000): Promise<Record<string, unknown>> {\n  // Check buffer first\n  for (let i = 0; i < q.messages.length; i++) {\n    if ((q.messages[i] as Record<string, unknown>).type === type) {\n      return Promise.resolve(q.messages.splice(i, 1)[0]);\n    }\n  }\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => {\n      const idx = q.waiters.indexOf(waiter);\n      if (idx >= 0) q.waiters.splice(idx, 1);\n      reject(new Error(`Timeout waiting for ${type}`));\n    }, timeout);\n    const waiter = {\n      filter: type,\n      resolve: (msg: Record<string, unknown>) => { clearTimeout(timer); resolve(msg); },\n      reject: (err: Error) => { clearTimeout(timer); reject(err); },\n    };\n    q.waiters.push(waiter);\n  });\n}\n\nfunction closeWs(q: QueuedWs): Promise<void> {\n  return new Promise((resolve) => {\n    if (q.ws.readyState === WebSocket.CLOSED || q.ws.readyState === WebSocket.CLOSING) {\n      resolve();\n      return;\n    }\n    q.ws.on('close', () => resolve());\n    q.ws.close();\n  });\n}","originalFile":"import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from 'vitest';\nimport request from 'supertest';\nimport { WebSocket } from 'ws';\nimport { createApp, AppInstance } from './server.js';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\n// Helper to connect a WebSocket to a document\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\n// Helper to wait for a specific message type\nfunction waitForMessage(ws: WebSocket, type: string, timeout = 5000): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error(`Timeout waiting for ${type}`)), timeout);\n    const handler = (data: Buffer | string) => {\n      const msg = JSON.parse(typeof data === 'string' ? data : data.toString());\n      if (msg.type === type) {\n        clearTimeout(timer);\n        ws.removeListener('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\n// Helper to wait for any next message\nfunction waitForAnyMessage(ws: WebSocket, timeout = 5000): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('Timeout waiting for message')), timeout);\n    ws.once('message', (data: Buffer | string) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(typeof data === 'string' ? data : data.toString()));\n    });\n  });\n}\n\n// Helper to collect messages for a duration\nfunction collectMessages(ws: WebSocket, durationMs: number): Promise<Record<string, unknown>[]> {\n  return new Promise((resolve) => {\n    const messages: Record<string, unknown>[] = [];\n    const handler = (data: Buffer | string) => {\n      messages.push(JSON.parse(typeof data === 'string' ? data : data.toString()));\n    };\n    ws.on('message', handler);\n    setTimeout(() => {\n      ws.removeListener('message', handler);\n      resolve(messages);\n    }, durationMs);\n  });\n}\n\nfunction closeWs(ws: WebSocket): Promise<void> {\n  return new Promise((resolve) => {\n    if (ws.readyState === WebSocket.CLOSED || ws.readyState === WebSocket.CLOSING) {\n      resolve();\n      return;\n    }\n    ws.on('close', () => resolve());\n    ws.close();\n  });\n}\n\n// ─── REST CRUD ───────────────────────────────────────────\n\ndescribe('REST CRUD', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should create a document with title and content', async () => {\n    const res = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Test Doc', content: 'Hello world' })\n      .expect(201);\n\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello world');\n    expect(res.body).toHaveProperty('created_at');\n    expect(res.body).toHaveProperty('updated_at');\n  });\n\n  it('should create a document with empty content by default', async () => {\n    const res = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Empty Doc' })\n      .expect(201);\n\n    expect(res.body.content).toBe('');\n  });\n\n  it('should reject document creation without title', async () => {\n    await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ content: 'no title' })\n      .expect(400);\n  });\n\n  it('should get a document by ID', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Get Me', content: 'content here' });\n\n    const res = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`)\n      .expect(200);\n\n    expect(res.body.id).toBe(createRes.body.id);\n    expect(res.body.title).toBe('Get Me');\n    expect(res.body.content).toBe('content here');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    await request(`http://localhost:${port}`)\n      .get('/documents/nonexistent-id')\n      .expect(404);\n  });\n\n  it('should list all documents', async () => {\n    const res = await request(`http://localhost:${port}`)\n      .get('/documents')\n      .expect(200);\n\n    expect(Array.isArray(res.body)).toBe(true);\n    expect(res.body.length).toBeGreaterThan(0);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Update Me', content: 'original' });\n\n    const res = await request(`http://localhost:${port}`)\n      .put(`/documents/${createRes.body.id}`)\n      .send({ title: 'Updated Title', content: 'updated content' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Updated Title');\n    expect(res.body.content).toBe('updated content');\n  });\n\n  it('should partially update a document', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Patch Me', content: 'original content' });\n\n    const res = await request(`http://localhost:${port}`)\n      .patch(`/documents/${createRes.body.id}`)\n      .send({ title: 'Patched Title' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Patched Title');\n    expect(res.body.content).toBe('original content');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Delete Me', content: 'to be deleted' });\n\n    await request(`http://localhost:${port}`)\n      .delete(`/documents/${createRes.body.id}`)\n      .expect(204);\n\n    await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`)\n      .expect(404);\n  });\n\n  it('should get document version history', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Versioned', content: 'v1' });\n\n    const res = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}/versions`)\n      .expect(200);\n\n    expect(Array.isArray(res.body)).toBe(true);\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0]).toHaveProperty('version');\n    expect(res.body[0]).toHaveProperty('content');\n  });\n});\n\n// ─── WebSocket Lifecycle ─────────────────────────────────\n\ndescribe('WebSocket Lifecycle', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should connect to a document via WebSocket', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'WS Doc', content: 'ws content' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    const sync = await waitForMessage(ws, 'sync');\n\n    expect(sync.type).toBe('sync');\n    expect(sync.content).toBe('ws content');\n    expect(sync.version).toBe(0);\n    expect(sync).toHaveProperty('clientId');\n\n    await closeWs(ws);\n  });\n\n  it('should receive sync with current document state on connect', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Sync Doc', content: 'initial content' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    const sync = await waitForMessage(ws, 'sync');\n\n    expect(sync.content).toBe('initial content');\n    expect(sync.documentId).toBe(createRes.body.id);\n\n    await closeWs(ws);\n  });\n\n  it('should reject connection for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent-id`);\n    const msg = await waitForMessage(ws, 'error');\n    expect(msg.type).toBe('error');\n    await closeWs(ws);\n  });\n\n  it('should reject connection with invalid path', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/invalid-path`);\n    const msg = await waitForMessage(ws, 'error');\n    expect(msg.type).toBe('error');\n    await closeWs(ws);\n  });\n\n  it('should notify others when a client joins', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Join Notify', content: '' });\n\n    const ws1 = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws1, 'sync');\n\n    // Start listening before second client connects\n    const joinPromise = waitForMessage(ws1, 'client_joined');\n    const ws2 = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws2, 'sync');\n\n    const joinMsg = await joinPromise;\n    expect(joinMsg.type).toBe('client_joined');\n    expect(joinMsg).toHaveProperty('clientId');\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should notify others when a client leaves', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Leave Notify', content: '' });\n\n    const ws1 = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws2, 'sync');\n\n    const leavePromise = waitForMessage(ws1, 'client_left');\n    await closeWs(ws2);\n\n    const leaveMsg = await leavePromise;\n    expect(leaveMsg.type).toBe('client_left');\n\n    await closeWs(ws1);\n  });\n\n  it('should support multiple concurrent connections to same document', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Multi Connect', content: 'shared' });\n\n    const clients: WebSocket[] = [];\n    for (let i = 0; i < 5; i++) {\n      const ws = await connectWs(port, createRes.body.id);\n      await waitForMessage(ws, 'sync');\n      clients.push(ws);\n    }\n\n    expect(clients.length).toBe(5);\n\n    for (const ws of clients) {\n      await closeWs(ws);\n    }\n  });\n\n  it('should assign unique client IDs to each connection', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Unique IDs', content: '' });\n\n    const ws1 = await connectWs(port, createRes.body.id);\n    const sync1 = await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, createRes.body.id);\n    const sync2 = await waitForMessage(ws2, 'sync');\n\n    expect(sync1.clientId).not.toBe(sync2.clientId);\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n});\n\n// ─── Single Client Editing ───────────────────────────────\n\ndescribe('Single Client Editing', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should apply an insert operation', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Insert Test', content: '' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    const sync = await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: sync.version,\n      components: [{ type: 'insert', text: 'Hello' }],\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('Hello');\n\n    await closeWs(ws);\n  });\n\n  it('should apply a delete operation', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Delete Test', content: 'Hello World' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    const sync = await waitForMessage(ws, 'sync');\n\n    // Delete \"World\" (chars 6-10)\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: sync.version,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'delete', count: 6 },\n      ],\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('Hello');\n\n    await closeWs(ws);\n  });\n\n  it('should apply sequential operations', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Sequential Ops', content: '' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws, 'sync');\n\n    // Insert \"Hello\"\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'Hello' }],\n    }));\n    const ack1 = await waitForMessage(ws, 'ack');\n    expect(ack1.version).toBe(1);\n\n    // Insert \" World\" at end\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' World' },\n      ],\n    }));\n    const ack2 = await waitForMessage(ws, 'ack');\n    expect(ack2.version).toBe(2);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('Hello World');\n\n    await closeWs(ws);\n  });\n\n  it('should update version history after operations', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Version History', content: '' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'First edit' }],\n    }));\n    await waitForMessage(ws, 'ack');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      components: [\n        { type: 'retain', count: 10 },\n        { type: 'insert', text: ', second edit' },\n      ],\n    }));\n    await waitForMessage(ws, 'ack');\n\n    const versionsRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}/versions`);\n\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(3); // init + 2 ops\n\n    await closeWs(ws);\n  });\n\n  it('should broadcast operations to other connected clients', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Broadcast', content: '' });\n\n    const ws1 = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws2, 'sync');\n    // ws1 gets client_joined notification\n    await waitForMessage(ws1, 'client_joined');\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'Broadcast test' }],\n    }));\n\n    const opMsg = await waitForMessage(ws2, 'operation');\n    expect(opMsg.type).toBe('operation');\n    expect(opMsg.version).toBe(1);\n    expect(opMsg.components).toEqual([{ type: 'insert', text: 'Broadcast test' }]);\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should handle retain operations correctly', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Retain Test', content: 'ABCDEF' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws, 'sync');\n\n    // Insert \"X\" at position 3 (between C and D)\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 3 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 3 },\n      ],\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('ABCXDEF');\n\n    await closeWs(ws);\n  });\n});\n\n// ─── Two-Client Convergence ──────────────────────────────\n\ndescribe('Two-Client Convergence', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should converge when two clients insert at different positions', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Convergence 1', content: 'ABCDEF' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    const sync1 = await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    const sync2 = await waitForMessage(ws2, 'sync');\n\n    // Both clients are at version 0, content \"ABCDEF\"\n\n    // Client 1: insert \"X\" at position 2\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 2 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 4 },\n      ],\n    }));\n\n    // Client 2: insert \"Y\" at position 4 (simultaneously, before seeing client 1's op)\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 4 },\n        { type: 'insert', text: 'Y' },\n        { type: 'retain', count: 2 },\n      ],\n    }));\n\n    // Wait for both acks\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    // Small delay for processing\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    // Both X and Y should be present\n    expect(docRes.body.content).toContain('X');\n    expect(docRes.body.content).toContain('Y');\n    expect(docRes.body.content.length).toBe(8); // 6 + X + Y\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should converge when two clients insert at the same position', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Same Position', content: 'AB' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    // Both insert at position 1\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 1 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 1 },\n      ],\n    }));\n\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 1 },\n        { type: 'insert', text: 'Y' },\n        { type: 'retain', count: 1 },\n      ],\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    // Both X and Y should be present, order doesn't matter\n    expect(docRes.body.content).toContain('X');\n    expect(docRes.body.content).toContain('Y');\n    expect(docRes.body.content).toContain('A');\n    expect(docRes.body.content).toContain('B');\n    expect(docRes.body.content.length).toBe(4); // A + X + Y + B\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should converge when one client inserts and another deletes', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Insert Delete', content: 'ABCDEF' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1: insert \"X\" at position 3\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 3 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 3 },\n      ],\n    }));\n\n    // Client 2: delete \"DE\" (positions 3-4)\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 3 },\n        { type: 'delete', count: 2 },\n        { type: 'retain', count: 1 },\n      ],\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    // X should be inserted, DE should be deleted\n    expect(docRes.body.content).toContain('X');\n    expect(docRes.body.content).not.toContain('D');\n    expect(docRes.body.content).not.toContain('E');\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should converge when both clients delete overlapping regions', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Delete Overlap', content: 'ABCDEF' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1: delete \"BCD\" (positions 1-3)\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 1 },\n        { type: 'delete', count: 3 },\n        { type: 'retain', count: 2 },\n      ],\n    }));\n\n    // Client 2: delete \"CDE\" (positions 2-4)\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 2 },\n        { type: 'delete', count: 3 },\n        { type: 'retain', count: 1 },\n      ],\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    // Only A and F should remain (both deleted B,C,D,E)\n    expect(docRes.body.content).toBe('AF');\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should handle rapid sequential edits from two clients', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Rapid Edits', content: '' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1 inserts \"A\"\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'A' }],\n    }));\n    const ack1 = await waitForMessage(ws1, 'ack');\n\n    // Client 2 inserts \"B\" (at version 0, before receiving client 1's op)\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'B' }],\n    }));\n    const ack2 = await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toContain('A');\n    expect(docRes.body.content).toContain('B');\n    expect(docRes.body.content.length).toBe(2);\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should maintain version consistency across clients', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Version Consistency', content: 'XY' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1 edits\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 2 },\n        { type: 'insert', text: 'Z' },\n      ],\n    }));\n    const ack1 = await waitForMessage(ws1, 'ack');\n    expect(ack1.version).toBe(1);\n\n    // Wait for ws2 to receive the operation broadcast\n    await waitForMessage(ws2, 'operation');\n\n    // Client 2 edits at version 1 (the correct current version)\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      components: [\n        { type: 'insert', text: 'W' },\n        { type: 'retain', count: 3 },\n      ],\n    }));\n    const ack2 = await waitForMessage(ws2, 'ack');\n    expect(ack2.version).toBe(2);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n    expect(docRes.body.content).toBe('WXYZ');\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should handle insert and delete at document boundaries', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Boundaries', content: 'AB' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1: insert at beginning\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 2 },\n      ],\n    }));\n\n    // Client 2: insert at end\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 2 },\n        { type: 'insert', text: 'Y' },\n      ],\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n    expect(docRes.body.content).toBe('XABY');\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should preserve all content from concurrent multi-char inserts', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Multi Char', content: '' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1: insert \"Hello\"\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'Hello' }],\n    }));\n\n    // Client 2: insert \"World\"\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'World' }],\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n    expect(docRes.body.content).toContain('Hello');\n    expect(docRes.body.content).toContain('World');\n    expect(docRes.body.content.length).toBe(10);\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n});\n\n// ─── Stress Test ─────────────────────────────────────────\n\ndescribe('Stress Test', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Stress Test', content: '' });\n    const docId = createRes.body.id;\n\n    const clients: WebSocket[] = [];\n    const syncs: Record<string, unknown>[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(port, docId);\n      const sync = await waitForMessage(ws, 'sync');\n      clients.push(ws);\n      syncs.push(sync);\n    }\n\n    // Each client inserts a character at version 0\n    for (let i = 0; i < 10; i++) {\n      clients[i].send(JSON.stringify({\n        type: 'operation',\n        version: 0,\n        components: [{ type: 'insert', text: String(i) }],\n      }));\n    }\n\n    // Wait for all acks\n    for (let i = 0; i < 10; i++) {\n      await waitForMessage(clients[i], 'ack');\n    }\n\n    await new Promise(r => setTimeout(r, 200));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    // All 10 characters should be present\n    expect(docRes.body.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(docRes.body.content).toContain(String(i));\n    }\n\n    for (const ws of clients) {\n      await closeWs(ws);\n    }\n  });\n\n  it('should handle rapid sequential operations from many clients', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Rapid Stress', content: 'START' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1: sequential inserts\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: '-A' },\n      ],\n    }));\n    await waitForMessage(ws1, 'ack');\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      components: [\n        { type: 'retain', count: 7 },\n        { type: 'insert', text: '-B' },\n      ],\n    }));\n    await waitForMessage(ws1, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n    expect(docRes.body.content).toContain('START');\n    expect(docRes.body.content).toContain('-A');\n    expect(docRes.body.content).toContain('-B');\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should not corrupt document with many concurrent inserts', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Corruption Test', content: 'BASE' });\n    const docId = createRes.body.id;\n\n    const numClients = 10;\n    const clients: WebSocket[] = [];\n\n    for (let i = 0; i < numClients; i++) {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws, 'sync');\n      clients.push(ws);\n    }\n\n    // All clients insert at version 0 at the end\n    for (let i = 0; i < numClients; i++) {\n      clients[i].send(JSON.stringify({\n        type: 'operation',\n        version: 0,\n        components: [\n          { type: 'retain', count: 4 },\n          { type: 'insert', text: `[${i}]` },\n        ],\n      }));\n    }\n\n    // Wait for all acks\n    for (let i = 0; i < numClients; i++) {\n      await waitForMessage(clients[i], 'ack');\n    }\n\n    await new Promise(r => setTimeout(r, 300));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toContain('BASE');\n    for (let i = 0; i < numClients; i++) {\n      expect(docRes.body.content).toContain(`[${i}]`);\n    }\n\n    for (const ws of clients) {\n      await closeWs(ws);\n    }\n  });\n\n  it('should handle 10+ clients connecting and disconnecting', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Connect Disconnect', content: 'test' });\n    const docId = createRes.body.id;\n\n    // Connect and disconnect 15 clients\n    for (let i = 0; i < 15; i++) {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws, 'sync');\n      await closeWs(ws);\n    }\n\n    // Verify document is still intact\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n    expect(docRes.body.content).toBe('test');\n  });\n\n  it('should maintain document integrity after mixed concurrent operations', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Mixed Ops', content: 'ABCDEF' });\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(port, docId);\n    await waitForMessage(ws1, 'sync');\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2, 'sync');\n\n    const ws3 = await connectWs(port, docId);\n    await waitForMessage(ws3, 'sync');\n\n    // Three concurrent operations at version 0\n    // Client 1: insert \"X\" at position 0\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 6 },\n      ],\n    }));\n\n    // Client 2: insert \"Y\" at position 3\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 3 },\n        { type: 'insert', text: 'Y' },\n        { type: 'retain', count: 3 },\n      ],\n    }));\n\n    // Client 3: insert \"Z\" at position 6\n    ws3.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 6 },\n        { type: 'insert', text: 'Z' },\n      ],\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n    await waitForMessage(ws3, 'ack');\n\n    await new Promise(r => setTimeout(r, 200));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toContain('X');\n    expect(docRes.body.content).toContain('Y');\n    expect(docRes.body.content).toContain('Z');\n    expect(docRes.body.content).toContain('A');\n    expect(docRes.body.content).toContain('F');\n    expect(docRes.body.content.length).toBe(9); // 6 + X + Y + Z\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n    await closeWs(ws3);\n  });\n});\n\n// ─── Error Handling ──────────────────────────────────────\n\ndescribe('Error Handling', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should reject operations with invalid components', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Invalid Op', content: 'test' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'invalid_type' }],\n    }));\n\n    const errMsg = await waitForMessage(ws, 'error');\n    expect(errMsg.type).toBe('error');\n\n    await closeWs(ws);\n  });\n\n  it('should reject operations with wrong document length', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Wrong Length', content: 'test' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws, 'sync');\n\n    // Retain more than document length\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'retain', count: 100 }],\n    }));\n\n    const errMsg = await waitForMessage(ws, 'error');\n    expect(errMsg.type).toBe('error');\n\n    await closeWs(ws);\n  });\n\n  it('should handle malformed JSON gracefully', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Malformed', content: 'test' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send('not valid json{{{');\n\n    const errMsg = await waitForMessage(ws, 'error');\n    expect(errMsg.type).toBe('error');\n\n    await closeWs(ws);\n  });\n\n  it('should handle unknown message types', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Unknown Type', content: 'test' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({ type: 'unknown_type' }));\n\n    const errMsg = await waitForMessage(ws, 'error');\n    expect(errMsg.type).toBe('error');\n\n    await closeWs(ws);\n  });\n\n  it('should not crash server after error and allow continued operation', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Recovery', content: 'hello' });\n\n    const ws = await connectWs(port, createRes.body.id);\n    await waitForMessage(ws, 'sync');\n\n    // Send invalid operation\n    ws.send('garbage');\n    await waitForMessage(ws, 'error');\n\n    // Verify server still works\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' world' },\n      ],\n    }));\n\n    const ack = await waitForMessage(ws, 'ack');\n    expect(ack.version).toBe(1);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('hello world');\n\n    await closeWs(ws);\n  });\n});\n\n// ─── Persistence ─────────────────────────────────────────\n\ndescribe('Persistence', () => {\n  let tmpDir: string;\n\n  beforeEach(() => {\n    tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'collab-test-'));\n  });\n\n  afterEach(() => {\n    fs.rmSync(tmpDir, { recursive: true, force: true });\n  });\n\n  it('should persist documents across server restarts', async () => {\n    const dbPath = path.join(tmpDir, 'test.db');\n\n    // Start server, create document\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n\n    const createRes = await request(`http://localhost:${port1}`)\n      .post('/documents')\n      .send({ title: 'Persistent', content: 'survives restart' });\n\n    const docId = createRes.body.id;\n    await app1.stop();\n\n    // Start new server with same DB\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n\n    const docRes = await request(`http://localhost:${port2}`)\n      .get(`/documents/${docId}`)\n      .expect(200);\n\n    expect(docRes.body.title).toBe('Persistent');\n    expect(docRes.body.content).toBe('survives restart');\n\n    await app2.stop();\n  });\n\n  it('should persist edits made via WebSocket across restarts', async () => {\n    const dbPath = path.join(tmpDir, 'test-ws.db');\n\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n\n    const createRes = await request(`http://localhost:${port1}`)\n      .post('/documents')\n      .send({ title: 'WS Persist', content: '' });\n\n    const docId = createRes.body.id;\n\n    const ws = await connectWs(port1, docId);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'persistent content' }],\n    }));\n    await waitForMessage(ws, 'ack');\n\n    await closeWs(ws);\n    await app1.stop();\n\n    // Restart with same DB\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n\n    const docRes = await request(`http://localhost:${port2}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toBe('persistent content');\n\n    await app2.stop();\n  });\n\n  it('should persist version history across restarts', async () => {\n    const dbPath = path.join(tmpDir, 'test-versions.db');\n\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n\n    const createRes = await request(`http://localhost:${port1}`)\n      .post('/documents')\n      .send({ title: 'Version Persist', content: '' });\n\n    const docId = createRes.body.id;\n\n    const ws = await connectWs(port1, docId);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'edit1' }],\n    }));\n    await waitForMessage(ws, 'ack');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' edit2' },\n      ],\n    }));\n    await waitForMessage(ws, 'ack');\n\n    await closeWs(ws);\n    await app1.stop();\n\n    // Restart with same DB\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n\n    const versionsRes = await request(`http://localhost:${port2}`)\n      .get(`/documents/${docId}/versions`);\n\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(3); // init + 2 edits\n\n    await app2.stop();\n  });\n});\n","structuredPatch":[{"oldStart":6,"oldLines":65,"newStart":6,"newLines":73,"lines":[" import path from 'path';"," import os from 'os';"," ","-// Helper to connect a WebS