+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01NcfeSvjSoiFn2DkWqGQmD8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01T5pZTtbDkYdQRegFph4HGm","name":"Write","input":{"file_path":"/workspace/src/websocket.ts","content":"import { WebSocketServer, WebSocket } from 'ws';\nimport { IncomingMessage } from 'http';\nimport { Server as HttpServer } from 'http';\nimport { randomUUID } from 'crypto';\nimport { DatabaseWrapper } from './database.js';\nimport {\n  OpComponent,\n  applyOperation,\n  transformAgainstAll,\n  validateOperation,\n} from './ot.js';\n\ninterface ClientConnection {\n  ws: WebSocket;\n  clientId: string;\n  documentId: string;\n}\n\ninterface DocumentState {\n  version: number;\n  content: string;\n  // History of operations since version 0, indexed by the version they produced\n  operationLog: OpComponent[][];\n  clients: Map<string, ClientConnection>;\n}\n\nexport interface WebSocketHandler {\n  wss: WebSocketServer;\n  close(): void;\n}\n\nexport function createWebSocketHandler(\n  server: HttpServer,\n  database: DatabaseWrapper\n): WebSocketHandler {\n  const wss = new WebSocketServer({ server });\n  const documents = new Map<string, DocumentState>();\n\n  function getOrLoadDocumentState(docId: string): DocumentState | null {\n    if (documents.has(docId)) {\n      return documents.get(docId)!;\n    }\n\n    const doc = database.getDocument(docId);\n    if (!doc) return null;\n\n    const latestVersion = database.getLatestVersion(docId);\n    const versions = database.getVersions(docId);\n\n    // Rebuild operation log from persisted versions\n    const operationLog: OpComponent[][] = [];\n    for (const v of versions) {\n      if (v.version > 0 && v.operation) {\n        try {\n          operationLog[v.version - 1] = JSON.parse(v.operation);\n        } catch {\n          // Skip malformed operations\n        }\n      }\n    }\n\n    const state: DocumentState = {\n      version: latestVersion,\n      content: doc.content,\n      operationLog,\n      clients: new Map(),\n    };\n\n    documents.set(docId, state);\n    return state;\n  }\n\n  function broadcastToOthers(docState: DocumentState, senderId: string, message: object): void {\n    const msg = JSON.stringify(message);\n    for (const [clientId, client] of docState.clients) {\n      if (clientId !== senderId && client.ws.readyState === WebSocket.OPEN) {\n        client.ws.send(msg);\n      }\n    }\n  }\n\n  wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n    const url = req.url || '';\n    // Extract document ID from path: /documents/:id or /ws/documents/:id\n    const match = url.match(/\\/(?:ws\\/)?documents\\/([^/?]+)/);\n\n    if (!match) {\n      ws.send(JSON.stringify({ type: 'error', message: 'Invalid WebSocket path. Use /documents/:id' }));\n      ws.close(1008, 'Invalid path');\n      return;\n    }\n\n    const documentId = match[1];\n    const clientId = randomUUID();\n\n    const docState = getOrLoadDocumentState(documentId);\n    if (!docState) {\n      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));\n      ws.close(1008, 'Document not found');\n      return;\n    }\n\n    // Register client\n    const connection: ClientConnection = { ws, clientId, documentId };\n    docState.clients.set(clientId, connection);\n    database.addConnection(clientId, documentId);\n\n    // Send sync message with current state\n    ws.send(JSON.stringify({\n      type: 'sync',\n      documentId,\n      content: docState.content,\n      version: docState.version,\n      clientId,\n    }));\n\n    // Notify others about new client\n    broadcastToOthers(docState, clientId, {\n      type: 'client_joined',\n      clientId,\n    });\n\n    ws.on('message', (data: Buffer | string) => {\n      try {\n        const message = JSON.parse(typeof data === 'string' ? data : data.toString());\n\n        if (message.type === 'operation') {\n          handleOperation(docState, clientId, message);\n        } else if (message.type === 'cursor') {\n          // Forward cursor updates to other clients\n          broadcastToOthers(docState, clientId, {\n            type: 'cursor',\n            clientId,\n            position: message.position,\n          });\n        } else {\n          ws.send(JSON.stringify({\n            type: 'error',\n            message: `Unknown message type: ${message.type}`,\n          }));\n        }\n      } catch (err) {\n        ws.send(JSON.stringify({\n          type: 'error',\n          message: 'Invalid message format',\n        }));\n      }\n    });\n\n    ws.on('close', () => {\n      docState.clients.delete(clientId);\n      database.removeConnection(clientId);\n\n      broadcastToOthers(docState, clientId, {\n        type: 'client_left',\n        clientId,\n      });\n\n      // Clean up empty document states after a delay\n      if (docState.clients.size === 0) {\n        setTimeout(() => {\n          const state = documents.get(documentId);\n          if (state && state.clients.size === 0) {\n            documents.delete(documentId);\n          }\n        }, 30000);\n      }\n    });\n\n    ws.on('error', () => {\n      docState.clients.delete(clientId);\n      database.removeConnection(clientId);\n    });\n  });\n\n  function handleOperation(\n    docState: DocumentState,\n    clientId: string,\n    message: { version: number; components: OpComponent[] }\n  ): void {\n    const client = docState.clients.get(clientId);\n    if (!client) return;\n\n    const clientVersion = message.version;\n    let components = message.components;\n\n    // Validate basic structure\n    if (!Array.isArray(components) || components.length === 0) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: 'Invalid operation: components must be a non-empty array',\n      }));\n      return;\n    }\n\n    // Validate each component has proper structure\n    for (const comp of components) {\n      if (!comp || typeof comp !== 'object' || !comp.type) {\n        client.ws.send(JSON.stringify({\n          type: 'error',\n          message: 'Invalid operation: each component must have a type',\n        }));\n        return;\n      }\n      if (!['retain', 'insert', 'delete'].includes(comp.type)) {\n        client.ws.send(JSON.stringify({\n          type: 'error',\n          message: `Invalid operation type: ${comp.type}`,\n        }));\n        return;\n      }\n    }\n\n    if (typeof clientVersion !== 'number' || clientVersion < 0) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: 'Invalid version number',\n      }));\n      return;\n    }\n\n    if (clientVersion > docState.version) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: `Client version ${clientVersion} is ahead of server version ${docState.version}`,\n      }));\n      return;\n    }\n\n    // Transform against all operations that happened since clientVersion\n    if (clientVersion < docState.version) {\n      const missedOps = docState.operationLog.slice(clientVersion);\n      const validMissedOps = missedOps.filter(op => op !== undefined);\n      if (validMissedOps.length > 0) {\n        components = transformAgainstAll(components, validMissedOps);\n      }\n    }\n\n    // Validate transformed operation against current document\n    const validationError = validateOperation(components, docState.content.length);\n    if (validationError) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: `Invalid operation: ${validationError}`,\n      }));\n      return;\n    }\n\n    // Apply operation\n    try {\n      const newContent = applyOperation(docState.content, components);\n      const newVersion = docState.version + 1;\n\n      // Update in-memory state\n      docState.content = newContent;\n      docState.operationLog[docState.version] = components;\n      docState.version = newVersion;\n\n      // Persist to database\n      database.updateDocumentContent(docState.clients.values().next().value!.documentId, newContent);\n      database.addVersion(\n        docState.clients.values().next().value!.documentId,\n        newVersion,\n        newContent,\n        JSON.stringify(components)\n      );\n\n      // Acknowledge to sender\n      client.ws.send(JSON.stringify({\n        type: 'ack',\n        version: newVersion,\n      }));\n\n      // Broadcast to all other clients\n      broadcastToOthers(docState, clientId, {\n        type: 'operation',\n        version: newVersion,\n        components,\n        clientId,\n      });\n    } catch (err) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: `Failed to apply operation: ${err instanceof Error ? err.message : 'unknown error'}`,\n      }));\n    }\n  }\n\n  function close(): void {\n    // Close all client connections\n    for (const [, docState] of documents) {\n      for (const [, client] of docState.clients) {\n        client.ws.close(1001, 'Server shutting down');\n      }\n    }\n    documents.clear();\n    database.clearConnections();\n    wss.close();\n  }\n\n  return { wss, close };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":338,"cache_read_input_tokens":32054,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":338},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"dffd4562-2ac8-427b-9ba3-553141feeb15","uuid":"c534fd8f-15d6-43b2-a42a-d45585a6a713"}
