+import express from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import { createDatabase, DatabaseWrapper } from './database.js';
+import { createRouter } from './routes.js';
+import { createWebSocketHandler, WebSocketHandler } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const app = express();
+  app.use(express.json());
+
+  const database: DatabaseWrapper = createDatabase(dbPath);
+  const router = createRouter(database);
+  app.use(router);
+
+  let server: HttpServer | null = null;
+  let wsHandler: WebSocketHandler | null = null;
+
+  async function start(port?: number): Promise<number> {
+    return new Promise((resolve) => {
+      server = createServer(app);
+      wsHandler = createWebSocketHandler(server, database);
+
+      const listenPort = port ?? 0;
+      server.listen(listenPort, () => {
+        const addr = server!.address();
+        const actualPort = typeof addr === 'object' && addr ? addr.port : listenPort;
+        resolve(actualPort);
+      });
+    });
+  }
+
+  async function stop(): Promise<void> {
+    return new Promise((resolve, reject) => {
+      if (wsHandler) {
+        wsHandler.close();
+        wsHandler = null;
+      }
+
+      if (server) {
+        server.close((err) => {
+          database.close();
+          if (err) reject(err);
+          else resolve();
+        });
+        server = null;
+      } else {
+        database.close();
+        resolve();
+      }
+    });
+  }
+
+  return { app, start, stop };
+}
+
+export default createApp;
