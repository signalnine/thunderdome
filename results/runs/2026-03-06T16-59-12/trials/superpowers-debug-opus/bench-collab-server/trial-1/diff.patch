+
+// Message queue that buffers all messages from a WebSocket
+interface QueuedWs {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  waiters: Array<{ resolve: (msg: Record<string, unknown>) => void; filter?: string }>;
+}
+
+function createQueuedWs(ws: WebSocket): QueuedWs {
+  const q: QueuedWs = { ws, messages: [], waiters: [] };
+  ws.on('message', (data: Buffer | string) => {
+    const msg = JSON.parse(typeof data === 'string' ? data : data.toString()) as Record<string, unknown>;
+    // Check if any waiter wants this message
+    for (let i = 0; i < q.waiters.length; i++) {
+      const w = q.waiters[i];
+      if (!w.filter || msg.type === w.filter) {
+        q.waiters.splice(i, 1);
+        w.resolve(msg);
+        return;
+      }
+    }
+    // No waiter matched, buffer it
+    q.messages.push(msg);
+  });
+  return q;
+}
+
+// Helper to connect a WebSocket to a document, buffering messages from start
+function connectWs(port: number, docId: string): Promise<QueuedWs> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}`);
+    const q = createQueuedWs(ws);
+    ws.on('open', () => resolve(q));
+    ws.on('error', reject);
+  });
+}
+
+// Helper to wait for a specific message type (checks buffer first)
+function waitForMessage(q: QueuedWs, type: string, timeout = 5000): Promise<Record<string, unknown>> {
+  // Check buffer first
+  for (let i = 0; i < q.messages.length; i++) {
+    if (q.messages[i].type === type) {
+      return Promise.resolve(q.messages.splice(i, 1)[0]);
+    }
+  }
+  return new Promise((resolve, reject) => {
+    const timer = setTimeout(() => {
+      const idx = q.waiters.indexOf(waiter);
+      if (idx >= 0) q.waiters.splice(idx, 1);
+      reject(new Error(`Timeout waiting for ${type}`));
+    }, timeout);
+    const waiter = {
+      filter: type,
+      resolve: (msg: Record<string, unknown>) => { clearTimeout(timer); resolve(msg); },
+    };
+    q.waiters.push(waiter);
+  });
+}
+
+function closeWs(q: QueuedWs): Promise<void> {
+  return new Promise((resolve) => {
+    if (q.ws.readyState === WebSocket.CLOSED || q.ws.readyState === WebSocket.CLOSING) {
+      resolve();
+      return;
+    }
+    q.ws.on('close', () => resolve());
+    q.ws.close();
+  });
+}
