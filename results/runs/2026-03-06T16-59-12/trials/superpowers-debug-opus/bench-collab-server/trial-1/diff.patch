ait waitForMessage(q, 'sync');\n   247→\n   248→    expect(sync.content).toBe('initial content');\n   249→    expect(sync.documentId).toBe(createRes.body.id);\n   250→\n   251→    await closeWs(q);\n   252→  });\n   253→\n   254→  it('should reject connection for non-existent document', async () => {\n   255→    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent-id`);\n   256→    const q = createQueuedWs(ws);\n   257→    const msg = await waitForMessage(q, 'error');\n   258→    expect(msg.type).toBe('error');\n   259→    await closeWs(q);\n   260→  });\n   261→\n   262→  it('should reject connection with invalid path', async () => {\n   263→    const ws = new WebSocket(`ws://localhost:${port}/invalid-path`);\n   264→    const q = createQueuedWs(ws);\n   265→    const msg = await waitForMessage(q, 'error');\n   266→    expect(msg.type).toBe('error');\n   267→    await closeWs(q);\n   268→  });\n   269→\n   270→  it('should notify others when a client joins', async () => {\n   271→    const createRes = await request(`http://localhost:${port}`)\n   272→      .post('/documents')\n   273→      .send({ title: 'Join Notify', content: '' });\n   274→\n   275→    const q1 = await connectWs(port, createRes.body.id);\n   276→    await waitForMessage(q1, 'sync');\n   277→\n   278→    const q2 = await connectWs(port, createRes.body.id);\n   279→    await waitForMessage(q2, 'sync');\n   280→\n   281→    const joinMsg = await waitForMessage(q1, 'client_joined');\n   282→    expect(joinMsg.type).toBe('client_joined');\n   283→    expect(joinMsg).toHaveProperty('clientId');\n   284→\n   285→    await closeWs(q1);\n   286→    await closeWs(q2);\n   287→  });\n   288→\n   289→  it('should notify others when a client leaves', async () => {\n   290→    const createRes = await request(`http://localhost:${port}`)\n   291→      .post('/documents')\n   292→      .send({ title: 'Leave Notify', content: '' });\n   293→\n   294→    const q1 = await connectWs(port, createRes.body.id);\n   295→    await waitForMessage(q1, 'sync');\n   296→\n   297→    const q2 = await connectWs(port, createRes.body.id);\n   298→    await waitForMessage(q2, 'sync');\n   299→\n   300→    // Drain any client_joined message on q1\n   301→    await waitForMessage(q1, 'client_joined');\n   302→\n   303→    const leavePromise = waitForMessage(q1, 'client_left');\n   304→    await closeWs(q2);\n   305→\n   306→    const leaveMsg = await leavePromise;\n   307→    expect(leaveMsg.type).toBe('client_left');\n   308→\n   309→    await closeWs(q1);\n   310→  });\n   311→\n   312→  it('should support multiple concurrent connections to same document', async () => {\n   313→    const createRes = await request(`http://localhost:${port}`)\n   314→      .post('/documents')\n   315→      .send({ title: 'Multi Connect', content: 'shared' });\n   316→\n   317→    const clients: QueuedWs[] = [];\n   318→    for (let i = 0; i < 5; i++) {\n   319→      const q = await connectWs(port, createRes.body.id);\n   320→      await waitForMessage(q, 'sync');\n   321→      clients.push(q);\n   322→    }\n   323→\n   324→    expect(clients.length).toBe(5);\n   325→\n   326→    for (const q of clients) {\n   327→      await closeWs(q);\n   328→    }\n   329→  });\n   330→\n   331→  it('should assign unique client IDs to each connection', async () => {\n   332→    const createRes = await request(`http://localhost:${port}`)\n   333→      .post('/documents')\n   334→      .send({ title: 'Unique IDs', content: '' });\n   335→\n   336→    const q1 = await connectWs(port, createRes.body.id);\n   337→    const sync1 = await waitForMessage(q1, 'sync');\n   338→\n   339→    const q2 = await connectWs(port, createRes.body.id);\n   340→    const sync2 = await waitForMessage(q2, 'sync');\n   341→\n   342→    expect(sync1.clientId).not.toBe(sync2.clientId);\n   343→\n   344→    await closeWs(q1);\n   345→    await closeWs(q2);\n   346→  });\n   347→});\n   348→\n   349→// ─── Single Client Editing ───────────────────────────────\n   350→\n   351→describe('Single Client Editing', () => {\n   352→  let app: AppInstance;\n   353→  let port: number;\n   354→\n   355→  beforeAll(async () => {\n   356→    app = createApp(':memory:');\n   357→    port = await app.start(0);\n   358→  });\n   359→\n   360→  afterAll(async () => {\n   361→    await app.stop();\n   362→  });\n   363→\n   364→  it('should apply an insert operation', async () => {\n   365→    const createRes = await request(`http://localhost:${port}`)\n   366→      .post('/documents')\n   367→      .send({ title: 'Insert Test', content: '' });\n   368→\n   369→    const q = await connectWs(port, createRes.body.id);\n   370→    const sync = await waitForMessage(q, 'sync');\n   371→\n   372→    q.ws.send(JSON.stringify({\n   373→      type: 'operation',\n   374→      version: sync.version,\n   375→      components: [{ type: 'insert', text: 'Hello' }],\n   376→    }));\n   377→\n   378→    const ack = await waitForMessage(q, 'ack');\n   379→    expect(ack.version).toBe(1);\n   380→\n   381→    const docRes = await request(`http://localhost:${port}`)\n   382→      .get(`/documents/${createRes.body.id}`);\n   383→    expect(docRes.body.content).toBe('Hello');\n   384→\n   385→    await closeWs(q);\n   386→  });\n   387→\n   388→  it('should apply a delete operation', async () => {\n   389→    const createRes = await request(`http://localhost:${port}`)\n   390→      .post('/documents')\n   391→      .send({ title: 'Delete Test', content: 'Hello World' });\n   392→\n   393→    const q = await connectWs(port, createRes.body.id);\n   394→    await waitForMessage(q, 'sync');\n   395→\n   396→    q.ws.send(JSON.stringify({\n   397→      type: 'operation',\n   398→      version: 0,\n   399→      components: [\n   400→        { type: 'retain', count: 5 },\n   401→        { type: 'delete', count: 6 },\n   402→      ],\n   403→    }));\n   404→\n   405→    const ack = await waitForMessage(q, 'ack');\n   406→    expect(ack.version).toBe(1);\n   407→\n   408→    const docRes = await request(`http://localhost:${port}`)\n   409→      .get(`/documents/${createRes.body.id}`);\n   410→    expect(docRes.body.content).toBe('Hello');\n   411→\n   412→    await closeWs(q);\n   413→  });\n   414→\n   415→  it('should apply sequential operations', async () => {\n   416→    const createRes = await request(`http://localhost:${port}`)\n   417→      .post('/documents')\n   418→      .send({ title: 'Sequential Ops', content: '' });\n   419→\n   420→    const q = await connectWs(port, createRes.body.id);\n   421→    await waitForMessage(q, 'sync');\n   422→\n   423→    q.ws.send(JSON.stringify({\n   424→      type: 'operation',\n   425→      version: 0,\n   426→      components: [{ type: 'insert', text: 'Hello' }],\n   427→    }));\n   428→    const ack1 = await waitForMessage(q, 'ack');\n   429→    expect(ack1.version).toBe(1);\n   430→\n   431→    q.ws.send(JSON.stringify({\n   432→      type: 'operation',\n   433→      version: 1,\n   434→      components: [\n   435→        { type: 'retain', count: 5 },\n   436→        { type: 'insert', text: ' World' },\n   437→      ],\n   438→    }));\n   439→    const ack2 = await waitForMessage(q, 'ack');\n   440→    expect(ack2.version).toBe(2);\n   441→\n   442→    const docRes = await request(`http://localhost:${port}`)\n   443→      .get(`/documents/${createRes.body.id}`);\n   444→    expect(docRes.body.content).toBe('Hello World');\n   445→\n   446→    await closeWs(q);\n   447→  });\n   448→\n   449→  it('should update version history after operations', async () => {\n   450→    const createRes = await request(`http://localhost:${port}`)\n   451→      .post('/documents')\n   452→      .send({ title: 'Version History', content: '' });\n   453→\n   454→    const q = await connectWs(port, createRes.body.id);\n   455→    await waitForMessage(q, 'sync');\n   456→\n   457→    q.ws.send(JSON.stringify({\n   458→      type: 'operation',\n   459→      version: 0,\n   460→      components: [{ type: 'insert', text: 'First edit' }],\n   461→    }));\n   462→    await waitForMessage(q, 'ack');\n   463→\n   464→    q.ws.send(JSON.stringify({\n   465→      type: 'operation',\n   466→      version: 1,\n   467→      components: [\n   468→        { type: 'retain', count: 10 },\n   469→        { type: 'insert', text: ', second edit' },\n   470→      ],\n   471→    }));\n   472→    await waitForMessage(q, 'ack');\n   473→\n   474→    const versionsRes = await request(`http://localhost:${port}`)\n   475→      .get(`/documents/${createRes.body.id}/versions`);\n   476→\n   477→    expect(versionsRes.body.length).toBeGreaterThanOrEqual(3);\n   478→\n   479→    await closeWs(q);\n   480→  });\n   481→\n   482→  it('should broadcast operations to other connected clients', async () => {\n   483→    const createRes = await request(`http://localhost:${port}`)\n   484→      .post('/documents')\n   485→      .send({ title: 'Broadcast', content: '' });\n   486→\n   487→    const q1 = await connectWs(port, createRes.body.id);\n   488→    await waitForMessage(q1, 'sync');\n   489→\n   490→    const q2 = await connectWs(port, createRes.body.id);\n   491→    await waitForMessage(q2, 'sync');\n   492→    await waitForMessage(q1, 'client_joined');\n   493→\n   494→    q1.ws.send(JSON.stringify({\n   495→      type: 'operation',\n   496→      version: 0,\n   497→      components: [{ type: 'insert', text: 'Broadcast test' }],\n   498→    }));\n   499→\n   500→    const opMsg = await waitForMessage(q2, 'operation');\n   501→    expect(opMsg.type).toBe('operation');\n   502→    expect(opMsg.version).toBe(1);\n   503→    expect(opMsg.components).toEqual([{ type: 'insert', text: 'Broadcast test' }]);\n   504→\n   505→    await closeWs(q1);\n   506→    await closeWs(q2);\n   507→  });\n   508→\n   509→  it('should handle retain operations correctly', async () => {\n   510→    const createRes = await request(`http://localhost:${port}`)\n   511→      .post('/documents')\n   512→      .send({ title: 'Retain Test', content: 'ABCDEF' });\n   513→\n   514→    const q = await connectWs(port, createRes.body.id);\n   515→    await waitForMessage(q, 'sync');\n   516→\n   517→    q.ws.send(JSON.stringify({\n   518→      type: 'operation',\n   519→      version: 0,\n   520→      components: [\n   521→        { type: 'retain', count: 3 },\n   522→        { type: 'insert', text: 'X' },\n   523→        { type: 'retain', count: 3 },\n   524→      ],\n   525→    }));\n   526→\n   527→    const ack = await waitForMessage(q, 'ack');\n   528→    expect(ack.version).toBe(1);\n   529→\n   530→    const docRes = await request(`http://localhost:${port}`)\n   531→      .get(`/documents/${createRes.body.id}`);\n   532→    expect(docRes.body.content).toBe('ABCXDEF');\n   533→\n   534→    await closeWs(q);\n   535→  });\n   536→});\n   537→\n   538→// ─── Two-Client Convergence ──────────────────────────────\n   539→\n   540→describe('Two-Client Convergence', () => {\n   541→  let app: AppInstance;\n   542→  let port: number;\n   543→\n   544→  beforeAll(async () => {\n   545→    app = createApp(':memory:');\n   546→    port = await app.start(0);\n   547→  });\n   548→\n   549→  afterAll(async () => {\n   550→    await app.stop();\n   551→  });\n   552→\n   553→  it('should converge when two clients insert at different positions', async () => {\n   554→    const createRes = await request(`http://localhost:${port}`)\n   555→      .post('/documents')\n   556→      .send({ title: 'Convergence 1', content: 'ABCDEF' });\n   557→    const docId = createRes.body.id;\n   558→\n   559→    const q1 = await connectWs(port, docId);\n   560→    await waitForMessage(q1, 'sync');\n   561→\n   562→    const q2 = await connectWs(port, docId);\n   563→    await waitForMessage(q2, 'sync');\n   564→\n   565→    // Client 1: insert \"X\" at position 2\n   566→    q1.ws.send(JSON.stringify({\n   567→      type: 'operation',\n   568→      version: 0,\n   569→      components: [\n   570→        { type: 'retain', count: 2 },\n   571→        { type: 'insert', text: 'X' },\n   572→        { type: 'retain', count: 4 },\n   573→      ],\n   574→    }));\n   575→\n   576→    // Client 2: insert \"Y\" at position 4 (simultaneously, before seeing client 1's op)\n   577→    q2.ws.send(JSON.stringify({\n   578→      type: 'operation',\n   579→      version: 0,\n   580→      components: [\n   581→        { type: 'retain', count: 4 },\n   582→        { type: 'insert', text: 'Y' },\n   583→        { type: 'retain', count: 2 },\n   584→      ],\n   585→    }));\n   586→\n   587→    await waitForMessage(q1, 'ack');\n   588→    await waitForMessage(q2, 'ack');\n   589→\n   590→    await new Promise(r => setTimeout(r, 100));\n   591→\n   592→    const docRes = await request(`http://localhost:${port}`)\n   593→      .get(`/documents/${docId}`);\n   594→\n   595→    expect(docRes.body.content).toContain('X');\n   596→    expect(docRes.body.content).toContain('Y');\n   597→    expect(docRes.body.content.length).toBe(8);\n   598→\n   599→    await closeWs(q1);\n   600→    await closeWs(q2);\n   601→  });\n   602→\n   603→  it('should converge when two clients insert at the same position', async () => {\n   604→    const createRes = await request(`http://localhost:${port}`)\n   605→      .post('/documents')\n   606→      .send({ title: 'Same Position', content: 'AB' });\n   607→    const docId = createRes.body.id;\n   608→\n   609→    const q1 = await connectWs(port, docId);\n   610→    await waitForMessage(q1, 'sync');\n   611→\n   612→    const q2 = await connectWs(port, docId);\n   613→    await waitForMessage(q2, 'sync');\n   614→\n   615→    q1.ws.send(JSON.stringify({\n   616→      type: 'operation',\n   617→      version: 0,\n   618→      components: [\n   619→        { type: 'retain', count: 1 },\n   620→        { type: 'insert', text: 'X' },\n   621→        { type: 'retain', count: 1 },\n   622→      ],\n   623→    }));\n   624→\n   625→    q2.ws