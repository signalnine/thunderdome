tain('START');\n  1018→    expect(docRes.body.content).toContain('-A');\n  1019→    expect(docRes.body.content).toContain('-B');\n  1020→\n  1021→    await closeWs(q1);\n  1022→    await closeWs(q2);\n  1023→  });\n  1024→\n  1025→  it('should not corrupt document with many concurrent inserts', async () => {\n  1026→    const createRes = await request(`http://localhost:${port}`)\n  1027→      .post('/documents')\n  1028→      .send({ title: 'Corruption Test', content: 'BASE' });\n  1029→    const docId = createRes.body.id;\n  1030→\n  1031→    const numClients = 10;\n  1032→    const clients: QueuedWs[] = [];\n  1033→\n  1034→    for (let i = 0; i < numClients; i++) {\n  1035→      const q = await connectWs(port, docId);\n  1036→      await waitForMessage(q, 'sync');\n  1037→      clients.push(q);\n  1038→    }\n  1039→\n  1040→    for (let i = 0; i < numClients; i++) {\n  1041→      clients[i].ws.send(JSON.stringify({\n  1042→        type: 'operation',\n  1043→        version: 0,\n  1044→        components: [\n  1045→          { type: 'retain', count: 4 },\n  1046→          { type: 'insert', text: `[${i}]` },\n  1047→        ],\n  1048→      }));\n  1049→    }\n  1050→\n  1051→    for (let i = 0; i < numClients; i++) {\n  1052→      await waitForMessage(clients[i], 'ack');\n  1053→    }\n  1054→\n  1055→    await new Promise(r => setTimeout(r, 300));\n  1056→\n  1057→    const docRes = await request(`http://localhost:${port}`)\n  1058→      .get(`/documents/${docId}`);\n  1059→\n  1060→    expect(docRes.body.content).toContain('BASE');\n  1061→    for (let i = 0; i < numClients; i++) {\n  1062→      expect(docRes.body.content).toContain(`[${i}]`);\n  1063→    }\n  1064→\n  1065→    for (const q of clients) {\n  1066→      await closeWs(q);\n  1067→    }\n  1068→  });\n  1069→\n  1070→  it('should handle 10+ clients connecting and disconnecting', async () => {\n  1071→    const createRes = await request(`http://localhost:${port}`)\n  1072→      .post('/documents')\n  1073→      .send({ title: 'Connect Disconnect', content: 'test' });\n  1074→    const docId = createRes.body.id;\n  1075→\n  1076→    for (let i = 0; i < 15; i++) {\n  1077→      const q = await connectWs(port, docId);\n  1078→      await waitForMessage(q, 'sync');\n  1079→      await closeWs(q);\n  1080→    }\n  1081→\n  1082→    const docRes = await request(`http://localhost:${port}`)\n  1083→      .get(`/documents/${docId}`);\n  1084→    expect(docRes.body.content).toBe('test');\n  1085→  });\n  1086→\n  1087→  it('should maintain document integrity after mixed concurrent operations', async () => {\n  1088→    const createRes = await request(`http://localhost:${port}`)\n  1089→      .post('/documents')\n  1090→      .send({ title: 'Mixed Ops', content: 'ABCDEF' });\n  1091→    const docId = createRes.body.id;\n  1092→\n  1093→    const q1 = await connectWs(port, docId);\n  1094→    await waitForMessage(q1, 'sync');\n  1095→\n  1096→    const q2 = await connectWs(port, docId);\n  1097→    await waitForMessage(q2, 'sync');\n  1098→\n  1099→    const q3 = await connectWs(port, docId);\n  1100→    await waitForMessage(q3, 'sync');\n  1101→\n  1102→    // Client 1: insert \"X\" at position 0\n  1103→    q1.ws.send(JSON.stringify({\n  1104→      type: 'operation',\n  1105→      version: 0,\n  1106→      components: [\n  1107→        { type: 'insert', text: 'X' },\n  1108→        { type: 'retain', count: 6 },\n  1109→      ],\n  1110→    }));\n  1111→\n  1112→    // Client 2: insert \"Y\" at position 3\n  1113→    q2.ws.send(JSON.stringify({\n  1114→      type: 'operation',\n  1115→      version: 0,\n  1116→      components: [\n  1117→        { type: 'retain', count: 3 },\n  1118→        { type: 'insert', text: 'Y' },\n  1119→        { type: 'retain', count: 3 },\n  1120→      ],\n  1121→    }));\n  1122→\n  1123→    // Client 3: insert \"Z\" at position 6\n  1124→    q3.ws.send(JSON.stringify({\n  1125→      type: 'operation',\n  1126→      version: 0,\n  1127→      components: [\n  1128→        { type: 'retain', count: 6 },\n  1129→        { type: 'insert', text: 'Z' },\n  1130→      ],\n  1131→    }));\n  1132→\n  1133→    await waitForMessage(q1, 'ack');\n  1134→    await waitForMessage(q2, 'ack');\n  1135→    await waitForMessage(q3, 'ack');\n  1136→\n  1137→    await new Promise(r => setTimeout(r, 200));\n  1138→\n  1139→    const docRes = await request(`http://localhost:${port}`)\n  1140→      .get(`/documents/${docId}`);\n  1141→\n  1142→    expect(docRes.body.content).toContain('X');\n  1143→    expect(docRes.body.content).toContain('Y');\n  1144→    expect(docRes.body.content).toContain('Z');\n  1145→    expect(docRes.body.content).toContain('A');\n  1146→    expect(docRes.body.content).toContain('F');\n  1147→    expect(docRes.body.content.length).toBe(9);\n  1148→\n  1149→    await closeWs(q1);\n  1150→    await closeWs(q2);\n  1151→    await closeWs(q3);\n  1152→  });\n  1153→});\n  1154→\n  1155→// ─── Error Handling ──────────────────────────────────────\n  1156→\n  1157→describe('Error Handling', () => {\n  1158→  let app: AppInstance;\n  1159→  let port: number;\n  1160→\n  1161→  beforeAll(async () => {\n  1162→    app = createApp(':memory:');\n  1163→    port = await app.start(0);\n  1164→  });\n  1165→\n  1166→  afterAll(async () => {\n  1167→    await app.stop();\n  1168→  });\n  1169→\n  1170→  it('should reject operations with invalid components', async () => {\n  1171→    const createRes = await request(`http://localhost:${port}`)\n  1172→      .post('/documents')\n  1173→      .send({ title: 'Invalid Op', content: 'test' });\n  1174→\n  1175→    const q = await connectWs(port, createRes.body.id);\n  1176→    await waitForMessage(q, 'sync');\n  1177→\n  1178→    q.ws.send(JSON.stringify({\n  1179→      type: 'operation',\n  1180→      version: 0,\n  1181→      components: [{ type: 'invalid_type' }],\n  1182→    }));\n  1183→\n  1184→    const errMsg = await waitForMessage(q, 'error');\n  1185→    expect(errMsg.type).toBe('error');\n  1186→\n  1187→    await closeWs(q);\n  1188→  });\n  1189→\n  1190→  it('should reject operations with wrong document length', async () => {\n  1191→    const createRes = await request(`http://localhost:${port}`)\n  1192→      .post('/documents')\n  1193→      .send({ title: 'Wrong Length', content: 'test' });\n  1194→\n  1195→    const q = await connectWs(port, createRes.body.id);\n  1196→    await waitForMessage(q, 'sync');\n  1197→\n  1198→    q.ws.send(JSON.stringify({\n  1199→      type: 'operation',\n  1200→      version: 0,\n  1201→      components: [{ type: 'retain', count: 100 }],\n  1202→    }));\n  1203→\n  1204→    const errMsg = await waitForMessage(q, 'error');\n  1205→    expect(errMsg.type).toBe('error');\n  1206→\n  1207→    await closeWs(q);\n  1208→  });\n  1209→\n  1210→  it('should handle malformed JSON gracefully', async () => {\n  1211→    const createRes = await request(`http://localhost:${port}`)\n  1212→      .post('/documents')\n  1213→      .send({ title: 'Malformed', content: 'test' });\n  1214→\n  1215→    const q = await connectWs(port, createRes.body.id);\n  1216→    await waitForMessage(q, 'sync');\n  1217→\n  1218→    q.ws.send('not valid json{{{');\n  1219→\n  1220→    const errMsg = await waitForMessage(q, 'error');\n  1221→    expect(errMsg.type).toBe('error');\n  1222→\n  1223→    await closeWs(q);\n  1224→  });\n  1225→\n  1226→  it('should handle unknown message types', async () => {\n  1227→    const createRes = await request(`http://localhost:${port}`)\n  1228→      .post('/documents')\n  1229→      .send({ title: 'Unknown Type', content: 'test' });\n  1230→\n  1231→    const q = await connectWs(port, createRes.body.id);\n  1232→    await waitForMessage(q, 'sync');\n  1233→\n  1234→    q.ws.send(JSON.stringify({ type: 'unknown_type' }));\n  1235→\n  1236→    const errMsg = await waitForMessage(q, 'error');\n  1237→    expect(errMsg.type).toBe('error');\n  1238→\n  1239→    await closeWs(q);\n  1240→  });\n  1241→\n  1242→  it('should not crash server after error and allow continued operation', async () => {\n  1243→    const createRes = await request(`http://localhost:${port}`)\n  1244→      .post('/documents')\n  1245→      .send({ title: 'Recovery', content: 'hello' });\n  1246→\n  1247→    const q = await connectWs(port, createRes.body.id);\n  1248→    await waitForMessage(q, 'sync');\n  1249→\n  1250→    q.ws.send('garbage');\n  1251→    await waitForMessage(q, 'error');\n  1252→\n  1253→    q.ws.send(JSON.stringify({\n  1254→      type: 'operation',\n  1255→      version: 0,\n  1256→      components: [\n  1257→        { type: 'retain', count: 5 },\n  1258→        { type: 'insert', text: ' world' },\n  1259→      ],\n  1260→    }));\n  1261→\n  1262→    const ack = await waitForMessage(q, 'ack');\n  1263→    expect(ack.version).toBe(1);\n  1264→\n  1265→    const docRes = await request(`http://localhost:${port}`)\n  1266→      .get(`/documents/${createRes.body.id}`);\n  1267→    expect(docRes.body.content).toBe('hello world');\n  1268→\n  1269→    await closeWs(q);\n  1270→  });\n  1271→});\n  1272→\n  1273→// ─── Persistence ─────────────────────────────────────────\n  1274→\n  1275→describe('Persistence', () => {\n  1276→  let tmpDir: string;\n  1277→\n  1278→  beforeEach(() => {\n  1279→    tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'collab-test-'));\n  1280→  });\n  1281→\n  1282→  afterEach(() => {\n  1283→    fs.rmSync(tmpDir, { recursive: true, force: true });\n  1284→  });\n  1285→\n  1286→  it('should persist documents across server restarts', async () => {\n  1287→    const dbPath = path.join(tmpDir, 'test.db');\n  1288→\n  1289→    const app1 = createApp(dbPath);\n  1290→    const port1 = await app1.start(0);\n  1291→\n  1292→    const createRes = await request(`http://localhost:${port1}`)\n  1293→      .post('/documents')\n  1294→      .send({ title: 'Persistent', content: 'survives restart' });\n  1295→\n  1296→    const docId = createRes.body.id;\n  1297→    await app1.stop();\n  1298→\n  1299→    const app2 = createApp(dbPath);\n  1300→    const port2 = await app2.start(0);\n  1301→\n  1302→    const docRes = await request(`http://localhost:${port2}`)\n  1303→      .get(`/documents/${docId}`)\n  1304→      .expect(200);\n  1305→\n  1306→    expect(docRes.body.title).toBe('Persistent');\n  1307→    expect(docRes.body.content).toBe('survives restart');\n  1308→\n  1309→    await app2.stop();\n  1310→  });\n  1311→\n  1312→  it('should persist edits made via WebSocket across restarts', async () => {\n  1313→    const dbPath = path.join(tmpDir, 'test-ws.db');\n  1314→\n  1315→    const app1 = createApp(dbPath);\n  1316→    const port1 = await app1.start(0);\n  1317→\n  1318→    const createRes = await request(`http://localhost:${port1}`)\n  1319→      .post('/documents')\n  1320→      .send({ title: 'WS Persist', content: '' });\n  1321→\n  1322→    const docId = createRes.body.id;\n  1323→\n  1324→    const q = await connectWs(port1, docId);\n  1325→    await waitForMessage(q, 'sync');\n  1326→\n  1327→    q.ws.send(JSON.stringify({\n  1328→      type: 'operation',\n  1329→      version: 0,\n  1330→      components: [{ type: 'insert', text: 'persistent content' }],\n  1331→    }));\n  1332→    await waitForMessage(q, 'ack');\n  1333→\n  1334→    await closeWs(q);\n  1335→    // Small delay to ensure WS close completes before server stop\n  1336→    await new Promise(r => setTimeout(r, 50));\n  1337→    await app1.stop();\n  1338→\n  1339→    const app2 = createApp(dbPath);\n  1340→    const port2 = await app2.start(0);\n  1341→\n  1342→    const docRes = await request(`http://localhost:${port2}`)\n  1343→      .get(`/documents/${docId}`);\n  1344→\n  1345→    expect(docRes.body.content).toBe('persistent content');\n  1346→\n  1347→    await app2.stop();\n  1348→  });\n  1349→\n  1350→  it('should persist version history across restarts', async () => {\n  1351→    const dbPath = path.join(tmpDir, 'test-versions.db');\n  1352→\n  1353→    const app1 = createApp(dbPath);\n  1354→    const port1 = await app1.start(0);\n  1355→\n  1356→    const createRes = await request(`http://localhost:${port1}`)\n  1357→      .post('/documents')\n  1358→      .send({ title: 'Version Persist', content: '' });\n  1359→\n  1360→    const docId = createRes.body.id;\n  1361→\n  1362→    const q = await connectWs(port1, docId);\n  1363→    await waitForMessage(q, 'sync');\n  1364→\n  1365→    q.ws.send(JSON.stringify({\n  1366→      type: 'operation',\n  1367→      version: 0,\n  1368→      components: [{ type: 'insert', text: 'edit1' }],\n  1369→    }));\n  1370→    await waitForMessage(q, 'ack');\n  1371→\n  1372→    q.ws.send(JSON.stringify({\n  1373→      type: 'operation',\n  1374→      version: 1,\n  1375→      components: [\n  1376→        { type: 'retain', count: 5 },\n  1377→        { type: 'insert', text: ' edit2' },\n  1378→      ],\n  1379→    }));\n  1380→    await waitForMessage(q, 'ack');\n  1381→\n  1382→    await closeWs(q);\n  1383→    await new Promise(r => setTimeout(r, 50));\n  1384→    await app1.stop();\n  1385→\n  1386→    const app2 = createApp(dbPath);\n  1387→    const port2 = await app2.start(0);\n  1388→\n  1389→    const versionsRes = await request(`http://localhost:${port2}`)\n  1390→      .get(`/documents/${docId}/versions`);\n  1391→\n  1392→    expect(versionsRes.body.length).toBeGreaterThanOrEqual(3);\n  1393→\n  1394→    await app2.stop();\n  1395→  });\n  1396→});\n  1397→"}]},"parent_tool_use_id":null,"session_id":"dffd4562-2ac8-427b-9ba3-553141feeb15","uuid":"8ee10f93-7c49-4bdd-9c32-ed7f0edea661","tool_use_result":{"type":"update","filePath":"/workspace/src/server.test.ts","content":"import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from 'vitest';\nimport request from 'supertest';\nimport { WebSocket } from 'ws';\nimport { createApp, AppInstance } from './server.js';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\n// Message queue that buffers all messages from a WebSocket\ninterface QueuedWs {\n  ws: WebSocket;\n  messages: Record<string, unknown>[];\n  waiters: Array<{ resolve: (msg: Record<string, unknown>) => void; filter?: string }>;\n}\n\nfunction createQueuedWs(ws: WebSocket): QueuedWs {\n  const q: QueuedWs = { ws, messages: [], waiters: [] };\n  ws.on('message', (data: Buffer | string) => {\n    const msg = JSON.parse(typeof data === 'string' ? data : data.toString()) as Record<string, unknown>;\n    // Check if any waiter wants this message\n    for (let i = 0; i < q.waiters.length; i++) {\n      const w = q.waiters[i];\n      if (!w.filter || msg.type === w.filter) {\n        q.waiters.splice(i, 1);\n        w.resolve(msg);\n        return;\n      }\n    }\n    // No waiter matched, buffer it\n    q.messages.push(msg);\n  });\n  return q;\n}\n\n// Helper to connect a WebSocket to a document, buffering messages from start\nfunction connectWs(port: number, docId: string): Promise<QueuedWs> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}`);\n    const q = createQueuedWs(ws);\n    ws.on('open', () => resolve(q));\n    ws.on('error', reject);\n  });\n}\n\n// Helper to wait for a specific message type (checks buffer first)\nfunction waitForMessage(q: QueuedWs, type: string, timeout = 5000): Promise<Record<string, unknown>> {\n  // Check buffer first\n  for (let i = 0; i < q.messages.length; i++) {\n    if (q.messages[i].type === type) {\n      return Promise.resolve(q.messages.splice(i, 1)[0]);\n    }\n  }\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => {\n      const idx = q.waiters.indexOf(waiter);\n      if (idx >= 0) q.waiters.splice(idx, 1);\n      reject(new Error(`Timeout waiting for ${type}`));\n    }, timeout);\n    const waiter = {\n      filter: type,\n      resolve: (msg: Record<string, unknown>) => { clearTimeout(timer); resolve(msg); },\n    };\n    q.waiters.push(waiter);\n  });\n}\n\nfunction closeWs(q: QueuedWs): Promise<void> {\n  return new Promise((resolve) => {\n    if (q.ws.readyState === WebSocket.CLOSED || q.ws.readyState === WebSocket.CLOSING) {\n      resolve();\n      return;\n    }\n    q.ws.on('close', () => resolve());\n    q.ws.close();\n  });\n}\n\n// ─── REST CRUD ───────────────────────────────────────────\n\ndescribe('REST CRUD', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should create a document with title and content', async () => {\n    const res = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Test Doc', content: 'Hello world' })\n      .expect(201);\n\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello world');\n    expect(res.body).toHaveProperty('created_at');\n    expect(res.body).toHaveProperty('updated_at');\n  });\n\n  it('should create a document with empty content by default', async () => {\n    const res = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Empty Doc' })\n      .expect(201);\n\n    expect(res.body.content).toBe('');\n  });\n\n  it('should reject document creation without title', async () => {\n    await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ content: 'no title' })\n      .expect(400);\n  });\n\n  it('should get a document by ID', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Get Me', content: 'content here' });\n\n    const res = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`)\n      .expect(200);\n\n    expect(res.body.id).toBe(createRes.body.id);\n    expect(res.body.title).toBe('Get Me');\n    expect(res.body.content).toBe('content here');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    await request(`http://localhost:${port}`)\n      .get('/documents/nonexistent-id')\n      .expect(404);\n  });\n\n  it('should list all documents', async () => {\n    const res = await request(`http://localhost:${port}`)\n      .get('/documents')\n      .expect(200);\n\n    expect(Array.isArray(res.body)).toBe(true);\n    expect(res.body.length).toBeGreaterThan(0);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Update Me', content: 'original' });\n\n    const res = await request(`http://localhost:${port}`)\n      .put(`/documents/${createRes.body.id}`)\n      .send({ title: 'Updated Title', content: 'updated content' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Updated Title');\n    expect(res.body.content).toBe('updated content');\n  });\n\n  it('should partially update a document', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Patch Me', content: 'original content' });\n\n    const res = await request(`http://localhost:${port}`)\n      .patch(`/documents/${createRes.body.id}`)\n      .send({ title: 'Patched Title' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Patched Title');\n    expect(res.body.content).toBe('original content');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Delete Me', content: 'to be deleted' });\n\n    await request(`http://localhost:${port}`)\n      .delete(`/documents/${createRes.body.id}`)\n      .expect(204);\n\n    await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`)\n      .expect(404);\n  });\n\n  it('should get document version history', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Versioned', content: 'v1' });\n\n    const res = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}/versions`)\n      .expect(200);\n\n    expect(Array.isArray(res.body)).toBe(true);\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0]).toHaveProperty('version');\n    expect(res.body[0]).toHaveProperty('content');\n  });\n});\n\n// ─── WebSocket Lifecycle ─────────────────────────────────\n\ndescribe('WebSocket Lifecycle', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should connect to a document via WebSocket', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'WS Doc', content: 'ws content' });\n\n    const q = await connectWs(port, createRes.body.id);\n    const sync = await waitForMessage(q, 'sync');\n\n    expect(sync.type).toBe('sync');\n    expect(sync.content).toBe('ws content');\n    expect(sync.version).toBe(0);\n    expect(sync).toHaveProperty('clientId');\n\n    await closeWs(q);\n  });\n\n  it('should receive sync with current document state on connect', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Sync Doc', content: 'initial content' });\n\n    const q = await connectWs(port, createRes.body.id);\n    const sync = await waitForMessage(q, 'sync');\n\n    expect(sync.content).toBe('initial content');\n    expect(sync.documentId).toBe(createRes.body.id);\n\n    await closeWs(q);\n  });\n\n  it('should reject connection for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent-id`);\n    const q = createQueuedWs(ws);\n    const msg = await waitForMessage(q, 'error');\n    expect(msg.type).toBe('error');\n    await closeWs(q);\n  });\n\n  it('should reject connection with invalid path', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/invalid-path`);\n    const q = createQueuedWs(ws);\n    const msg = await waitForMessage(q, 'error');\n    expect(msg.type).toBe('error');\n    await closeWs(q);\n  });\n\n  it('should notify others when a client joins', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Join Notify', content: '' });\n\n    const q1 = await connectWs(port, createRes.body.id);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, createRes.body.id);\n    await waitForMessage(q2, 'sync');\n\n    const joinMsg = await waitForMessage(q1, 'client_joined');\n    expect(joinMsg.type).toBe('client_joined');\n    expect(joinMsg).toHaveProperty('clientId');\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should notify others when a client leaves', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Leave Notify', content: '' });\n\n    const q1 = await connectWs(port, createRes.body.id);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, createRes.body.id);\n    await waitForMessage(q2, 'sync');\n\n    // Drain any client_joined message on q1\n    await waitForMessage(q1, 'client_joined');\n\n    const leavePromise = waitForMessage(q1, 'client_left');\n    await closeWs(q2);\n\n    const leaveMsg = await leavePromise;\n    expect(leaveMsg.type).toBe('client_left');\n\n    await closeWs(q1);\n  });\n\n  it('should support multiple concurrent connections to same document', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Multi Connect', content: 'shared' });\n\n    const clients: QueuedWs[] = [];\n    for (let i = 0; i < 5; i++) {\n      const q = await connectWs(port, createRes.body.id);\n      await waitForMessage(q, 'sync');\n      clients.push(q);\n    }\n\n    expect(clients.length).toBe(5);\n\n    for (const q of clients) {\n      await closeWs(q);\n    }\n  });\n\n  it('should assign unique client IDs to each connection', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Unique IDs', content: '' });\n\n    const q1 = await connectWs(port, createRes.body.id);\n    const sync1 = await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, createRes.body.id);\n    const sync2 = await waitForMessage(q2, 'sync');\n\n    expect(sync1.clientId).not.toBe(sync2.clientId);\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n});\n\n// ─── Single Client Editing ───────────────────────────────\n\ndescribe('Single Client Editing', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should apply an insert operation', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Insert Test', content: '' });\n\n    const q = await connectWs(port, createRes.body.id);\n    const sync = await waitForMessage(q, 'sync');\n\n    q.ws.send(JSON.stringify({\n      type: 'operation',\n      version: sync.version,\n      components: [{ type: 'insert', text: 'Hello' }],\n    }));\n\n    const ack = await waitForMessage(q, 'ack');\n    expect(ack.version).toBe(1);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('Hello');\n\n    await closeWs(q);\n  });\n\n  it('should apply a delete operation', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Delete Test', content: 'Hello World' });\n\n    const q = await connectWs(port, createRes.body.id);\n    await waitForMessage(q, 'sync');\n\n    q.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'delete', count: 6 },\n      ],\n    }));\n\n    const ack = await waitForMessage(q, 'ack');\n    expect(ack.version).toBe(1);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('Hello');\n\n    await closeWs(q);\n  });\n\n  it('should apply sequential operations', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Sequential Ops', content: '' });\n\n    const q = await connectWs(port, createRes.body.id);\n    await waitForMessage(q, 'sync');\n\n    q.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'Hello' }],\n    }));\n    const ack1 = await waitForMessage(q, 'ack');\n    expect(ack1.version).toBe(1);\n\n    q.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' World' },\n      ],\n    }));\n    const ack2 = await waitForMessage(q, 'ack');\n    expect(ack2.version).toBe(2);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('Hello World');\n\n    await closeWs(q);\n  });\n\n  it('should update version history after operations', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Version History', content: '' });\n\n    const q = await connectWs(port, createRes.body.id);\n    await waitForMessage(q, 'sync');\n\n    q.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'First edit' }],\n    }));\n    await waitForMessage(q, 'ack');\n\n    q.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      components: [\n        { type: 'retain', count: 10 },\n        { type: 'insert', text: ', second edit' },\n      ],\n    }));\n    await waitForMessage(q, 'ack');\n\n    const versionsRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}/versions`);\n\n    expect(versionsRes.body.length).toBeGreaterThanOrEqual(3);\n\n    await closeWs(q);\n  });\n\n  it('should broadcast operations to other connected clients', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Broadcast', content: '' });\n\n    const q1 = await connectWs(port, createRes.body.id);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, createRes.body.id);\n    await waitForMessage(q2, 'sync');\n    await waitForMessage(q1, 'client_joined');\n\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'Broadcast test' }],\n    }));\n\n    const opMsg = await waitForMessage(q2, 'operation');\n    expect(opMsg.type).toBe('operation');\n    expect(opMsg.version).toBe(1);\n    expect(opMsg.components).toEqual([{ type: 'insert', text: 'Broadcast test' }]);\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should handle retain operations correctly', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Retain Test', content: 'ABCDEF' });\n\n    const q = await connectWs(port, createRes.body.id);\n    await waitForMessage(q, 'sync');\n\n    q.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 3 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 3 },\n      ],\n    }));\n\n    const ack = await waitForMessage(q, 'ack');\n    expect(ack.version).toBe(1);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${createRes.body.id}`);\n    expect(docRes.body.content).toBe('ABCXDEF');\n\n    await closeWs(q);\n  });\n});\n\n// ─── Two-Client Convergence ──────────────────────────────\n\ndescribe('Two-Client Convergence', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should converge when two clients insert at different positions', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Convergence 1', content: 'ABCDEF' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    // Client 1: insert \"X\" at position 2\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 2 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 4 },\n      ],\n    }));\n\n    // Client 2: insert \"Y\" at position 4 (simultaneously, before seeing client 1's op)\n    q2.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 4 },\n        { type: 'insert', text: 'Y' },\n        { type: 'retain', count: 2 },\n      ],\n    }));\n\n    await waitForMessage(q1, 'ack');\n    await waitForMessage(q2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toContain('X');\n    expect(docRes.body.content).toContain('Y');\n    expect(docRes.body.content.length).toBe(8);\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should converge when two clients insert at the same position', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Same Position', content: 'AB' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 1 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 1 },\n      ],\n    }));\n\n    q2.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 1 },\n        { type: 'insert', text: 'Y' },\n        { type: 'retain', count: 1 },\n      ],\n    }));\n\n    await waitForMessage(q1, 'ack');\n    await waitForMessage(q2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toContain('X');\n    expect(docRes.body.content).toContain('Y');\n    expect(docRes.body.content).toContain('A');\n    expect(docRes.body.content).toContain('B');\n    expect(docRes.body.content.length).toBe(4);\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should converge when one client inserts and another deletes', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Insert Delete', content: 'ABCDEF' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    // Client 1: insert \"X\" at position 3\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 3 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 3 },\n      ],\n    }));\n\n    // Client 2: delete \"DE\" (positions 3-4)\n    q2.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 3 },\n        { type: 'delete', count: 2 },\n        { type: 'retain', count: 1 },\n      ],\n    }));\n\n    await waitForMessage(q1, 'ack');\n    await waitForMessage(q2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toContain('X');\n    expect(docRes.body.content).not.toContain('D');\n    expect(docRes.body.content).not.toContain('E');\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should converge when both clients delete overlapping regions', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Delete Overlap', content: 'ABCDEF' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    // Client 1: delete \"BCD\" (positions 1-3)\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 1 },\n        { type: 'delete', count: 3 },\n        { type: 'retain', count: 2 },\n      ],\n    }));\n\n    // Client 2: delete \"CDE\" (positions 2-4)\n    q2.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 2 },\n        { type: 'delete', count: 3 },\n        { type: 'retain', count: 1 },\n      ],\n    }));\n\n    await waitForMessage(q1, 'ack');\n    await waitForMessage(q2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toBe('AF');\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should handle rapid sequential edits from two clients', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Rapid Edits', content: '' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    // Client 1 inserts \"A\"\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'A' }],\n    }));\n    await waitForMessage(q1, 'ack');\n\n    // Client 2 inserts \"B\" (at version 0, before receiving client 1's op)\n    q2.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'B' }],\n    }));\n    await waitForMessage(q2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content).toContain('A');\n    expect(docRes.body.content).toContain('B');\n    expect(docRes.body.content.length).toBe(2);\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should maintain version consistency across clients', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Version Consistency', content: 'XY' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    // Client 1 edits\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 2 },\n        { type: 'insert', text: 'Z' },\n      ],\n    }));\n    const ack1 = await waitForMessage(q1, 'ack');\n    expect(ack1.version).toBe(1);\n\n    // Wait for q2 to receive the operation broadcast\n    await waitForMessage(q2, 'operation');\n\n    // Client 2 edits at version 1\n    q2.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      components: [\n        { type: 'insert', text: 'W' },\n        { type: 'retain', count: 3 },\n      ],\n    }));\n    const ack2 = await waitForMessage(q2, 'ack');\n    expect(ack2.version).toBe(2);\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n    expect(docRes.body.content).toBe('WXYZ');\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should handle insert and delete at document boundaries', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Boundaries', content: 'AB' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    // Client 1: insert at beginning\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 2 },\n      ],\n    }));\n\n    // Client 2: insert at end\n    q2.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 2 },\n        { type: 'insert', text: 'Y' },\n      ],\n    }));\n\n    await waitForMessage(q1, 'ack');\n    await waitForMessage(q2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n    expect(docRes.body.content).toBe('XABY');\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n\n  it('should preserve all content from concurrent multi-char inserts', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Multi Char', content: '' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'Hello' }],\n    }));\n\n    q2.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [{ type: 'insert', text: 'World' }],\n    }));\n\n    await waitForMessage(q1, 'ack');\n    await waitForMessage(q2, 'ack');\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n    expect(docRes.body.content).toContain('Hello');\n    expect(docRes.body.content).toContain('World');\n    expect(docRes.body.content.length).toBe(10);\n\n    await closeWs(q1);\n    await closeWs(q2);\n  });\n});\n\n// ─── Stress Test ─────────────────────────────────────────\n\ndescribe('Stress Test', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Stress Test', content: '' });\n    const docId = createRes.body.id;\n\n    const clients: QueuedWs[] = [];\n\n    for (let i = 0; i < 10; i++) {\n      const q = await connectWs(port, docId);\n      await waitForMessage(q, 'sync');\n      clients.push(q);\n    }\n\n    // Each client inserts a character at version 0\n    for (let i = 0; i < 10; i++) {\n      clients[i].ws.send(JSON.stringify({\n        type: 'operation',\n        version: 0,\n        components: [{ type: 'insert', text: String(i) }],\n      }));\n    }\n\n    for (let i = 0; i < 10; i++) {\n      await waitForMessage(clients[i], 'ack');\n    }\n\n    await new Promise(r => setTimeout(r, 200));\n\n    const docRes = await request(`http://localhost:${port}`)\n      .get(`/documents/${docId}`);\n\n    expect(docRes.body.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(docRes.body.content).toContain(String(i));\n    }\n\n    for (const q of clients) {\n      await closeWs(q);\n    }\n  });\n\n  it('should handle rapid sequential operations from many clients', async () => {\n    const createRes = await request(`http://localhost:${port}`)\n      .post('/documents')\n      .send({ title: 'Rapid Stress', content: 'START' });\n    const docId = createRes.body.id;\n\n    const q1 = await connectWs(port, docId);\n    await waitForMessage(q1, 'sync');\n\n    const q2 = await connectWs(port, docId);\n    await waitForMessage(q2, 'sync');\n\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      version: 0,\n      components: [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: '-A' },\n      ],\n    }));\n    await waitForMessage(q1, 'ack');\n\n    q1.ws.send(JSON.stringify({\n      type: 'operation',\n      vers