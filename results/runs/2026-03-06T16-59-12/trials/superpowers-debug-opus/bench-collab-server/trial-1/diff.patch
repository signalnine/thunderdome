diff --git a/src/database.ts b/src/database.ts
new file mode 100644
index 0000000..41e0325
--- /dev/null
+++ b/src/database.ts
@@ -0,0 +1,172 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import fs from 'fs';
+import path from 'path';
+import { fileURLToPath } from 'url';
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = path.dirname(__filename);
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): DatabaseWrapper {
+  return new DatabaseWrapper(dbPath);
+}
+
+export class DatabaseWrapper {
+  public db: Database.Database;
+
+  constructor(dbPath?: string) {
+    const resolvedPath = dbPath || ':memory:';
+    this.db = new Database(resolvedPath);
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('foreign_keys = ON');
+    this.initialize();
+  }
+
+  private initialize(): void {
+    const schemaPath = path.resolve(__dirname, '..', 'schema.sql');
+    if (fs.existsSync(schemaPath)) {
+      const schema = fs.readFileSync(schemaPath, 'utf-8');
+      this.db.exec(schema);
+    } else {
+      this.db.exec(`
+        CREATE TABLE IF NOT EXISTS documents (
+          id TEXT PRIMARY KEY,
+          title TEXT NOT NULL,
+          content TEXT NOT NULL DEFAULT '',
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+
+        CREATE TABLE IF NOT EXISTS versions (
+          id INTEGER PRIMARY KEY AUTOINCREMENT,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          version INTEGER NOT NULL,
+          content TEXT NOT NULL,
+          operation TEXT,
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          UNIQUE(document_id, version)
+        );
+
+        CREATE TABLE IF NOT EXISTS active_connections (
+          id TEXT PRIMARY KEY,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+      `);
+    }
+  }
+
+  // Document CRUD
+  createDocument(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version
+    this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 0, ?, ?)'
+    ).run(id, content, JSON.stringify({ type: 'init', content }));
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    const stmt = this.db.prepare('SELECT * FROM documents WHERE id = ?');
+    return stmt.get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    this.db.prepare(
+      "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(title, content, id);
+
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+    return result.changes > 0;
+  }
+
+  // Version management
+  getVersions(documentId: string): Version[] {
+    const stmt = this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    );
+    return stmt.all(documentId) as Version[];
+  }
+
+  getLatestVersion(documentId: string): number {
+    const stmt = this.db.prepare(
+      'SELECT MAX(version) as max_version FROM versions WHERE document_id = ?'
+    );
+    const result = stmt.get(documentId) as { max_version: number | null };
+    return result?.max_version ?? 0;
+  }
+
+  addVersion(documentId: string, version: number, content: string, operation: string): void {
+    this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    ).run(documentId, version, content, operation);
+  }
+
+  updateDocumentContent(id: string, content: string): void {
+    this.db.prepare(
+      "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(content, id);
+  }
+
+  // Connection management
+  addConnection(connectionId: string, documentId: string): void {
+    if (!this.db.open) return;
+    this.db.prepare(
+      'INSERT OR REPLACE INTO active_connections (id, document_id) VALUES (?, ?)'
+    ).run(connectionId, documentId);
+  }
+
+  removeConnection(connectionId: string): void {
+    if (!this.db.open) return;
+    this.db.prepare('DELETE FROM active_connections WHERE id = ?').run(connectionId);
+  }
+
+  clearConnections(): void {
+    if (!this.db.open) return;
+    this.db.prepare('DELETE FROM active_connections').run();
+  }
+
+  close(): void {
+    if (this.db.open) {
+      this.db.close();
+    }
+  }
+}
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..c1004f5
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,350 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are sequences of components:
+ * - { type: 'retain', count: N } -- keep N characters unchanged
+ * - { type: 'insert', text: string } -- insert text at current position
+ * - { type: 'delete', count: N } -- delete N characters at current position
+ *
+ * An operation's "input length" is the sum of retain + delete counts.
+ * An operation's "output length" is the sum of retain + insert lengths.
+ * The input length must equal the document length before application.
+ */
+
+export interface RetainOp {
+  type: 'retain';
+  count: number;
+}
+
+export interface InsertOp {
+  type: 'insert';
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  count: number;
+}
+
+export type OpComponent = RetainOp | InsertOp | DeleteOp;
+
+export interface Operation {
+  docId: string;
+  version: number;  // the version the client was at when it generated this op
+  components: OpComponent[];
+  clientId?: string;
+}
+
+/**
+ * Apply an operation to a document string, returning the new string.
+ */
+export function applyOperation(doc: string, components: OpComponent[]): string {
+  let pos = 0;
+  let result = '';
+
+  for (const comp of components) {
+    switch (comp.type) {
+      case 'retain':
+        if (pos + comp.count > doc.length) {
+          throw new Error(
+            `Retain overflows document: pos=${pos}, count=${comp.count}, doc length=${doc.length}`
+          );
+        }
+        result += doc.slice(pos, pos + comp.count);
+        pos += comp.count;
+        break;
+      case 'insert':
+        result += comp.text;
+        break;
+      case 'delete':
+        if (pos + comp.count > doc.length) {
+          throw new Error(
+            `Delete overflows document: pos=${pos}, count=${comp.count}, doc length=${doc.length}`
+          );
+        }
+        pos += comp.count;
+        break;
+    }
+  }
+
+  // Append any remaining characters (if operation didn't cover full doc)
+  result += doc.slice(pos);
+  return result;
+}
+
+/**
+ * Compute input length of an operation (how long the doc must be before applying).
+ */
+export function inputLength(components: OpComponent[]): number {
+  let len = 0;
+  for (const comp of components) {
+    if (comp.type === 'retain') len += comp.count;
+    else if (comp.type === 'delete') len += comp.count;
+  }
+  return len;
+}
+
+/**
+ * Compute output length of an operation (how long the doc will be after applying).
+ */
+export function outputLength(components: OpComponent[]): number {
+  let len = 0;
+  for (const comp of components) {
+    if (comp.type === 'retain') len += comp.count;
+    else if (comp.type === 'insert') len += comp.text.length;
+  }
+  return len;
+}
+
+/**
+ * Transform two concurrent operations a and b (both applied to the same document state)
+ * so that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ * where [a', b'] = transform(a, b).
+ *
+ * Returns [a', b'] where:
+ *   a' should be applied after b
+ *   b' should be applied after a
+ */
+export function transform(
+  aComponents: OpComponent[],
+  bComponents: OpComponent[]
+): [OpComponent[], OpComponent[]] {
+  const aPrime: OpComponent[] = [];
+  const bPrime: OpComponent[] = [];
+
+  // Use iterators with splitting support
+  const aIter = new OpIterator(aComponents);
+  const bIter = new OpIterator(bComponents);
+
+  while (aIter.hasNext() || bIter.hasNext()) {
+    const a = aIter.peek();
+    const b = bIter.peek();
+
+    // If both are exhausted, we're done
+    if (!a && !b) break;
+
+    // Insert in a has priority (insert goes first in a')
+    if (a && a.type === 'insert') {
+      aPrime.push({ type: 'insert', text: a.text });
+      bPrime.push({ type: 'retain', count: a.text.length });
+      aIter.next();
+      continue;
+    }
+
+    // Insert in b
+    if (b && b.type === 'insert') {
+      bPrime.push({ type: 'insert', text: b.text });
+      aPrime.push({ type: 'retain', count: b.text.length });
+      bIter.next();
+      continue;
+    }
+
+    if (!a || !b) {
+      throw new Error('Transform mismatch: operations have different base lengths');
+    }
+
+    // Both retain
+    if (a.type === 'retain' && b.type === 'retain') {
+      const min = Math.min(a.count, b.count);
+      aPrime.push({ type: 'retain', count: min });
+      bPrime.push({ type: 'retain', count: min });
+      aIter.consume(min);
+      bIter.consume(min);
+    }
+    // a deletes, b deletes: both delete same region
+    else if (a.type === 'delete' && b.type === 'delete') {
+      const min = Math.min(a.count, b.count);
+      // Both deleted the same chars — no output for either
+      aIter.consume(min);
+      bIter.consume(min);
+    }
+    // a deletes, b retains
+    else if (a.type === 'delete' && b.type === 'retain') {
+      const min = Math.min(a.count, b.count);
+      aPrime.push({ type: 'delete', count: min });
+      // b' doesn't need to retain what a deleted
+      aIter.consume(min);
+      bIter.consume(min);
+    }
+    // a retains, b deletes
+    else if (a.type === 'retain' && b.type === 'delete') {
+      const min = Math.min(a.count, b.count);
+      bPrime.push({ type: 'delete', count: min });
+      // a' doesn't need to retain what b deleted
+      aIter.consume(min);
+      bIter.consume(min);
+    }
+    else {
+      throw new Error(`Unexpected OT component combination: ${a.type} / ${b.type}`);
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/**
+ * Transform operation a against a sequence of operations that have been applied
+ * since a was generated. Returns the transformed operation.
+ */
+export function transformAgainstAll(
+  op: OpComponent[],
+  serverOps: OpComponent[][]
+): OpComponent[] {
+  let transformed = op;
+  for (const serverOp of serverOps) {
+    const [, bPrime] = transform(serverOp, transformed);
+    transformed = bPrime;
+  }
+  return transformed;
+}
+
+/**
+ * Normalize an operation by merging adjacent same-type components
+ * and removing no-ops.
+ */
+export function normalize(components: OpComponent[]): OpComponent[] {
+  const result: OpComponent[] = [];
+  for (const comp of components) {
+    if (comp.type === 'retain' && comp.count === 0) continue;
+    if (comp.type === 'delete' && comp.count === 0) continue;
+    if (comp.type === 'insert' && comp.text === '') continue;
+
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (last.type === 'retain' && comp.type === 'retain') {
+        (last as RetainOp).count += comp.count;
+        continue;
+      }
+      if (last.type === 'delete' && comp.type === 'delete') {
+        (last as DeleteOp).count += comp.count;
+        continue;
+      }
+      if (last.type === 'insert' && comp.type === 'insert') {
+        (last as InsertOp).text += comp.text;
+        continue;
+      }
+    }
+    result.push({ ...comp });
+  }
+  return result;
+}
+
+/**
+ * Validate that an operation is well-formed for a given document length.
+ */
+export function validateOperation(components: OpComponent[], docLength: number): string | null {
+  let consumedInput = 0;
+  for (let i = 0; i < components.length; i++) {
+    const comp = components[i];
+    if (comp.type === 'retain') {
+      if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {
+        return `Invalid retain count at index ${i}: ${comp.count}`;
+      }
+      consumedInput += comp.count;
+    } else if (comp.type === 'delete') {
+      if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {
+        return `Invalid delete count at index ${i}: ${comp.count}`;
+      }
+      consumedInput += comp.count;
+    } else if (comp.type === 'insert') {
+      if (typeof comp.text !== 'string') {
+        return `Invalid insert text at index ${i}`;
+      }
+    } else {
+      return `Unknown operation type at index ${i}: ${(comp as OpComponent).type}`;
+    }
+  }
+
+  if (consumedInput !== docLength) {
+    return `Operation input length (${consumedInput}) does not match document length (${docLength})`;
+  }
+  return null;
+}
+
+/**
+ * Helper: create a simple insert operation at a position.
+ */
+export function makeInsert(pos: number, text: string, docLength: number): OpComponent[] {
+  const components: OpComponent[] = [];
+  if (pos > 0) components.push({ type: 'retain', count: pos });
+  components.push({ type: 'insert', text });
+  if (pos < docLength) components.push({ type: 'retain', count: docLength - pos });
+  return components;
+}
+
+/**
+ * Helper: create a simple delete operation at a position.
+ */
+export function makeDelete(pos: number, count: number, docLength: number): OpComponent[] {
+  const components: OpComponent[] = [];
+  if (pos > 0) components.push({ type: 'retain', count: pos });
+  components.push({ type: 'delete', count });
+  const remaining = docLength - pos - count;
+  if (remaining > 0) components.push({ type: 'retain', count: remaining });
+  return components;
+}
+
+/**
+ * Iterator that allows peeking and partial consumption of op components.
+ */
+class OpIterator {
+  private components: OpComponent[];
+  private index: number;
+  private offset: number; // how much of current component has been consumed
+
+  constructor(components: OpComponent[]) {
+    this.components = components;
+    this.index = 0;
+    this.offset = 0;
+  }
+
+  hasNext(): boolean {
+    return this.index < this.components.length;
+  }
+
+  peek(): OpComponent | null {
+    if (!this.hasNext()) return null;
+    const comp = this.components[this.index];
+    if (this.offset === 0) return comp;
+
+    // Return remaining portion
+    if (comp.type === 'retain') {
+      return { type: 'retain', count: comp.count - this.offset };
+    } else if (comp.type === 'delete') {
+      return { type: 'delete', count: comp.count - this.offset };
+    } else {
+      return { type: 'insert', text: comp.text.slice(this.offset) };
+    }
+  }
+
+  next(): OpComponent | null {
+    const comp = this.peek();
+    if (comp) {
+      this.index++;
+      this.offset = 0;
+    }
+    return comp;
+  }
+
+  consume(n: number): void {
+    const comp = this.components[this.index];
+    if (!comp) return;
+
+    let size: number;
+    if (comp.type === 'insert') {
+      size = comp.text.length - this.offset;
+    } else if (comp.type === 'retain') {
+      size = comp.count - this.offset;
+    } else {
+      size = comp.count - this.offset;
+    }
+
+    if (n >= size) {
+      this.index++;
+      this.offset = 0;
+    } else {
+      this.offset += n;
+    }
+  }
+}
