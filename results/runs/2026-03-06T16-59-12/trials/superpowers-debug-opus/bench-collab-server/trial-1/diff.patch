-  it('Connecting to non-existent document returns error', async () => {
-    const ws = new WebSocket(`ws://localhost:${port}/nonexistent-doc-id`);
-    const messages: Record<string, unknown>[] = [];
-    ws.on('message', (data) => messages.push(JSON.parse(data.toString())));
-    await new Promise<void>((resolve) => ws.on('open', resolve));
-
-    // Wait for the error message
-    await new Promise<void>((resolve) => {
-      const interval = setInterval(() => {
-        if (messages.length > 0) {
-          clearInterval(interval);
-          resolve();
-        }
-      }, 10);
-      setTimeout(() => { clearInterval(interval); resolve(); }, 2000);
-    });
-
-    expect(messages.length).toBeGreaterThan(0);
-    expect(messages[0].type).toBe('error');
-    expect(String(messages[0].message)).toContain('not found');
-    await delay(100);
-  });
