} from 'vitest';\nimport { schedule } from '../src/index.js';\n\ndescribe('schedule', () => {\n  const defaultOptions = { startTime: 540, endTime: 1020 }; // 9am - 5pm\n\n  it('schedules a single event', () => {\n    const events = [{ id: 'e1', name: 'Event 1', duration: 60 }];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, rooms, defaultOptions);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0].eventId).toBe('e1');\n    expect(result.assignments[0].roomId).toBe('r1');\n    expect(result.assignments[0].startTime).toBe(540);\n    expect(result.assignments[0].endTime).toBe(600);\n  });\n\n  it('respects room capacity', () => {\n    const events = [{ id: 'e1', name: 'Event 1', duration: 60, attendees: 20 }];\n    const rooms = [{ id: 'r1', name: 'Small Room', capacity: 10 }];\n    const result = schedule(events, rooms, defaultOptions);\n\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['e1']);\n  });\n\n  it('respects time window', () => {\n    const events = [{ id: 'e1', name: 'Event 1', duration: 600 }]; // 10 hours\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, rooms, defaultOptions); // 8 hour window\n\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['e1']);\n  });\n\n  it('handles gaps between events in the same room', () => {\n    const events = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60 },\n    ];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, rooms, { ...defaultOptions, gap: 15 });\n\n    expect(result.assignments).toHaveLength(2);\n    const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n    const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n    // Gap of at least 15 minutes between events in same room\n    if (a1.roomId === a2.roomId) {\n      const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n      expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(15);\n    }\n  });\n\n  it('respects prerequisites', () => {\n    const events = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n    ];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, rooms, defaultOptions);\n\n    expect(result.assignments).toHaveLength(2);\n    const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n    const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15); // prerequisite + gap\n  });\n\n  it('throws on self-referencing prerequisite', () => {\n    const events = [{ id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] }];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n  });\n\n  it('throws on prerequisite cycle', () => {\n    const events = [\n      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n    ];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n  });\n\n  it('honors preferred room when possible', () => {\n    const events = [{ id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'r2' }];\n    const rooms = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n      { id: 'r2', name: 'Room 2', capacity: 10 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n\n    expect(result.assignments[0].roomId).toBe('r2');\n  });\n\n  it('uses alternative room when preferred is not available', () => {\n    const events = [\n      { id: 'e1', name: 'Event 1', duration: 60, attendees: 20, preferredRoom: 'r1' },\n    ];\n    const rooms = [\n      { id: 'r1', name: 'Small Room', capacity: 10 },\n      { id: 'r2', name: 'Big Room', capacity: 30 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].roomId).toBe('r2');\n  });\n\n  it('handles empty events', () => {\n    const result = schedule([], [{ id: 'r1', name: 'Room 1', capacity: 10 }], defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n\n  it('schedules events in multiple rooms', () => {\n    const events = [\n      { id: 'e1', name: 'Event 1', duration: 480 }, // fills entire 8-hour window\n      { id: 'e2', name: 'Event 2', duration: 60 },\n    ];\n    const rooms = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n      { id: 'r2', name: 'Room 2', capacity: 10 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n\n    expect(result.assignments).toHaveLength(2);\n  });\n\n  it('default gap is 15 minutes', () => {\n    const events = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60 },\n    ];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n\n    expect(result.assignments).toHaveLength(2);\n    const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n    const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n    if (a1.roomId === a2.roomId) {\n      const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n      expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(15);\n    }\n  });\n\n  it('gap of 0 allows back-to-back scheduling', () => {\n    const events = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60 },\n    ];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, rooms, { ...defaultOptions, gap: 0 });\n\n    expect(result.assignments).toHaveLength(2);\n    const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n    const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n    const [first, second] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n    expect(second.startTime).toBe(first.endTime);\n  });\n\n  it('throws on 3-event cycle', () => {\n    const events = [\n      { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e3'] },\n      { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e2'] },\n    ];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n  });\n\n  it('maximizes number of scheduled events', () => {\n    // One big event and three small ones. Room can fit either the big one or all three small ones.\n    // Scheduler should prefer 3 small events over 1 big one.\n    const events = [\n      { id: 'big', name: 'Big Event', duration: 460 }, // takes almost full day\n      { id: 's1', name: 'Small 1', duration: 60 },\n      { id: 's2', name: 'Small 2', duration: 60 },\n      { id: 's3', name: 'Small 3', duration: 60 },\n    ];\n    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    // 9am to 5pm = 480 min. Big takes 460, leaving 20 min (not enough for small + gap).\n    // Three smalls: 60 + 15 + 60 + 15 + 60 = 210 min. Fits easily.\n    const result = schedule(events, rooms, defaultOptions);\n\n    // Should schedule at least 3 events\n    expect(result.assignments.length).toBeGreaterThanOrEqual(3);\n  });\n});\n","structuredPatch":[{"oldStart":172,"oldLines":6,"newStart":172,"newLines":38,"lines":["     expect(() => schedule(events, rooms, defaultOptions)).toT