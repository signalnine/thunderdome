ring, number>();\n    62→  for (const e of events) {\n    63→    color.set(e.id, WHITE);\n    64→  }\n    65→\n    66→  const order: string[] = [];\n    67→\n    68→  function dfs(id: string): void {\n    69→    color.set(id, GRAY);\n    70→    const ev = eventMap.get(id);\n    71→    if (ev?.prerequisites) {\n    72→      for (const preId of ev.prerequisites) {\n    73→        if (!eventIds.has(preId)) continue;\n    74→        const c = color.get(preId);\n    75→        if (c === GRAY) {\n    76→          throw new Error(`Prerequisite cycle detected involving event \"${preId}\"`);\n    77→        }\n    78→        if (c === WHITE) {\n    79→          dfs(preId);\n    80→        }\n    81→      }\n    82→    }\n    83→    color.set(id, BLACK);\n    84→    order.push(id);\n    85→  }\n    86→\n    87→  for (const e of events) {\n    88→    if (color.get(e.id) === WHITE) {\n    89→      dfs(e.id);\n    90→    }\n    91→  }\n    92→\n    93→  return order;\n    94→}\n    95→\n    96→/**\n    97→ * Compute topological levels. Level 0 = no prerequisites, level 1 = depends only on level 0, etc.\n    98→ */\n    99→function computeTopoLevels(events: Event[], eventIds: Set<string>): Map<string, number> {\n   100→  const levels = new Map<string, number>();\n   101→  const eventMap = new Map<string, Event>();\n   102→  for (const e of events) {\n   103→    eventMap.set(e.id, e);\n   104→  }\n   105→\n   106→  function getLevel(id: string): number {\n   107→    if (levels.has(id)) return levels.get(id)!;\n   108→    const ev = eventMap.get(id);\n   109→    if (!ev?.prerequisites || ev.prerequisites.length === 0) {\n   110→      levels.set(id, 0);\n   111→      return 0;\n   112→    }\n   113→    let maxPreLevel = -1;\n   114→    for (const preId of ev.prerequisites) {\n   115→      if (eventIds.has(preId)) {\n   116→        maxPreLevel = Math.max(maxPreLevel, getLevel(preId));\n   117→      }\n   118→    }\n   119→    const level = maxPreLevel + 1;\n   120→    levels.set(id, level);\n   121→    return level;\n   122→  }\n   123→\n   124→  for (const e of events) {\n   125→    getLevel(e.id);\n   126→  }\n   127→  return levels;\n   128→}\n   129→\n   130→/**\n   131→ * Find the earliest start time for an event in a given room.\n   132→ */\n   133→function findEarliestStartInRoom(\n   134→  duration: number,\n   135→  roomAssignments: Assignment[],\n   136→  earliestStart: number,\n   137→  endTime: number,\n   138→  gap: number,\n   139→): number | null {\n   140→  if (earliestStart + duration > endTime) {\n   141→    return null;\n   142→  }\n   143→\n   144→  const sorted = roomAssignments.slice().sort((a, b) => a.startTime - b.startTime);\n   145→\n   146→  let candidate = earliestStart;\n   147→\n   148→  for (const existing of sorted) {\n   149→    if (candidate + duration + gap <= existing.startTime) {\n   150→      break;\n   151→    }\n   152→    if (candidate < existing.endTime + gap) {\n   153→      candidate = existing.endTime + gap;\n   154→    }\n   155→  }\n   156→\n   157→  if (candidate + duration <= endTime) {\n   158→    return candidate;\n   159→  }\n   160→\n   161→  return null;\n   162→}\n   163→\n   164→/**\n   165→ * Compute the earliest an event can start based on prerequisite end times.\n   166→ */\n   167→function computeEarliestFromPrereqs(\n   168→  event: Event,\n   169→  prereqEndTimes: Map<string, number>,\n   170→  eventIds: Set<string>,\n   171→  windowStart: number,\n   172→  gap: number,\n   173→): number | null {\n   174→  let earliest = windowStart;\n   175→  if (event.prerequisites) {\n   176→    for (const preId of event.prerequisites) {\n   177→      if (eventIds.has(preId)) {\n   178→        const preEnd = prereqEndTimes.get(preId);\n   179→        if (preEnd === undefined) {\n   180→          return null;\n   181→        }\n   182→        earliest = Math.max(earliest, preEnd + gap);\n   183→      }\n   184→    }\n   185→  }\n   186→  return earliest;\n   187→}\n   188→\n   189→/**\n   190→ * Generate multiple topological orderings with different sorting strategies\n   191→ * within each topological level.\n   192→ */\n   193→function generateOrderings(\n   194→  events: Event[],\n   195→  eventIds: Set<string>,\n   196→): string[][] {\n   197→  const levels = computeTopoLevels(events, eventIds);\n   198→  const eventMap = new Map<string, Event>();\n   199→  for (const e of events) {\n   200→    eventMap.set(e.id, e);\n   201→  }\n   202→\n   203→  // Group by level\n   204→  const maxLevel = Math.max(...[...levels.values()], 0);\n   205→  const levelGroups: string[][] = [];\n   206→  for (let i = 0; i <= maxLevel; i++) {\n   207→    levelGroups.push([]);\n   208→  }\n   209→  for (const [id, level] of levels) {\n   210→    levelGroups[level].push(id);\n   211→  }\n   212→\n   213→  const orderings: string[][] = [];\n   214→\n   215→  // Strategy 1: shortest duration first within each level\n   216→  const shortFirst = levelGroups.flatMap(group =>\n   217→    [...group].sort((a, b) => eventMap.get(a)!.duration - eventMap.get(b)!.duration)\n   218→  );\n   219→  orderings.push(shortFirst);\n   220→\n   221→  // Strategy 2: longest duration first within each level\n   222→  const longFirst = levelGroups.flatMap(group =>\n   223→    [...group].sort((a, b) => eventMap.get(b)!.duration - eventMap.get(a)!.duration)\n   224→  );\n   225→  orderings.push(longFirst);\n   226→\n   227→  // Strategy 3: most constrained first (most prerequisites, fewest eligible rooms implied by attendees)\n   228→  const constrainedFirst = levelGroups.flatMap(group =>\n   229→    [...group].sort((a, b) => {\n   230→      const ea = eventMap.get(a)!;\n   231→      const eb = eventMap.get(b)!;\n   232→      const attendeesA = ea.attendees ?? 1;\n   233→      const attendeesB = eb.attendees ?? 1;\n   234→      // Higher attendees = more constrained\n   235→      if (attendeesA !== attendeesB) return attendeesB - attendeesA;\n   236→      return ea.duration - eb.duration;\n   237→    })\n   238→  );\n   239→  orderings.push(constrainedFirst);\n   240→\n   241→  // Strategy 4: fewest dependents first (events that don't block others scheduled first)\n   242→  const dependentCount = new Map<string, number>();\n   243→  for (const e of events) {\n   244→    dependentCount.set(e.id, 0);\n   245→  }\n   246→  for (const e of events) {\n   247→    if (e.prerequisites) {\n   248→      for (const preId of e.prerequisites) {\n   249→        if (eventIds.has(preId)) {\n   250→          dependentCount.set(preId, (dependentCount.get(preId) ?? 0) + 1);\n   251→        }\n   252→      }\n   253→    }\n   254→  }\n   255→  const leastDepsFirst = levelGroups.flatMap(group =>\n   256→    [...group].sort((a, b) => {\n   257→      const da = dependentCount.get(a) ?? 0;\n   258→      const db = dependentCount.get(b) ?? 0;\n   259→      if (da !== db) return da - db;\n   260→      return eventMap.get(a)!.duration - eventMap.get(b)!.duration;\n   261→    })\n   262→  );\n   263→  orderings.push(leastDepsFirst);\n   264→\n   265→  return orderings;\n   266→}\n   267→\n   268→// ── Core Greedy Scheduler ────────────────────────────────────────────────────\n   269→\n   270→function greedySchedule(\n   271→  order: string[],\n   272→  eventMap: Map<string, Event>,\n   273→  eventIds: Set<string>,\n   274→  rooms: Room[],\n   275→  startTime: number,\n   276→  endTime: number,\n   277→  gap: number,\n   278→): ScheduleResult {\n   279→  const roomSchedules = new Map<string, Assignment[]>();\n   280→  for (const room of rooms) {\n   281→    roomSchedules.set(room.id, []);\n   282→  }\n   283→  const prereqEndTimes = new Map<string, number>();\n   284→  const assignments: Assignment[] = [];\n   285→  const unscheduled: string[] = [];\n   286→\n   287→  for (const eventId of order) {\n   288→    const event = eventMap.get(eventId)!;\n   289→    const attendees = event.attendees ?? 1;\n   290→\n   291→    const earliest = computeEarliestFromPrereqs(event, prereqEndTimes, eventIds, startTime, gap);\n   292→    if (earliest === null) {\n   293→      unscheduled.push(eventId);\n   294→      continue;\n   295→    }\n   296→\n   297→    const eligibleRooms = rooms.filter(r => r.capacity >= attendees);\n   298→    if (eligibleRooms.length === 0) {\n   299→      unscheduled.push(eventId);\n   300→      continue;\n   301→    }\n   302→\n   303→    // Order rooms: preferred first, then by capacity (smallest first)\n   304→    let orderedRooms: Room[];\n   305→    if (event.preferredRoom) {\n   306→      const preferred = eligibleRooms.find(r => r.id === event.preferredRoom);\n   307→      if (preferred) {\n   308→        orderedRooms = [preferred, ...eligibleRooms.filter(r => r.id !== event.preferredRoom)];\n   309→      } else {\n   310→        orderedRooms = eligibleRooms;\n   311→      }\n   312→    } else {\n   313→      orderedRooms = eligibleRooms;\n   314→    }\n   315→\n   316→    let bestAssignment: Assignment | null = null;\n   317→    let bestStart = Infinity;\n   318→\n   319→    for (const room of orderedRooms) {\n   320→      const roomSched = roomSchedules.get(room.id)!;\n   321→      const start = findEarliestStartInRoom(\n   322→        event.duration, roomSched, earliest, endTime, gap,\n   323→      );\n   324→\n   325→      if (start !== null) {\n   326→        if (event.preferredRoom === room.id) {\n   327→          bestAssignment = {\n   328→            eventId,\n   329→            roomId: room.id,\n   330→            startTime: start,\n   331→            endTime: start + event.duration,\n   332→          };\n   333→          break;\n   334→        }\n   335→        if (start < bestStart) {\n   336→          bestStart = start;\n   337→          bestAssignment = {\n   338→            eventId,\n   339→            roomId: room.id,\n   340→            startTime: start,\n   341→            endTime: start + event.duration,\n   342→          };\n   343→        }\n   344→      }\n   345→    }\n   346→\n   347→    if (bestAssignment) {\n   348→      assignments.push(bestAssignment);\n   349→      roomSchedules.get(bestAssignment.roomId)!.push(bestAssignment);\n   350→      prereqEndTimes.set(eventId, bestAssignment.endTime);\n   351→    } else {\n   352→      unscheduled.push(eventId);\n   353→    }\n   354→  }\n   355→\n   356→  return { assignments, unscheduled };\n   357→}\n   358→\n   359→// ── Main Scheduler ──────────────────────────────────────────────────────────\n   360→\n   361→export function schedule(\n   362→  events: Event[],\n   363→  rooms: Room[],\n   364→  options: ScheduleOptions,\n   365→): ScheduleResult {\n   366→  const gap = options.gap ?? DEFAULT_GAP;\n   367→  const { startTime, endTime } = options;\n   368→\n   369→  if (events.length === 0) {\n   370→    return { assignments: [], unscheduled: [] };\n   371→  }\n   372→\n   373→  // 1. Cycle detection + topological sort (also validates the DAG)\n   374→  topologicalSort(events);\n   375→\n   376→  const eventMap = new Map<string, Event>();\n   377→  for (const e of events) {\n   378→    eventMap.set(e.id, e);\n   379→  }\n   380→  const eventIds = new Set(events.map(e => e.id));\n   381→\n   382→  // Sort rooms by capacity ascending for better packing\n   383→  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n   384→\n   385→  // 2. Generate multiple valid topological orderings with different heuristics\n   386→  const orderings = generateOrderings(events, eventIds);\n   387→\n   388→  // 3. Try each ordering with rooms sorted ascending and descending\n   389→  let bestResult: ScheduleResult = { assignments: [], unscheduled: events.map(e => e.id) };\n   390→  let bestCount = 0;\n   391→\n   392→  const roomOrderings = [\n   393→    sortedRooms,\n   394→    [...sortedRooms].reverse(),\n   395→  ];\n   396→\n   397→  for (const order of orderings) {\n   398→    for (const roomOrder of roomOrderings) {\n   399→      const result = greedySchedule(\n   400→        order, eventMap, eventIds, roomOrder, startTime, endTime, gap,\n   401→      );\n   402→\n   403→      if (result.assignments.length > bestCount) {\n   404→        bestCount = result.assignments.length;\n   405→        bestResult = result;\n   406→\n   407→        // If everything is scheduled, no need to try more\n   408→        if (bestCount === events.length) {\n   409→          return bestResult;\n   410→        }\n   411→      }\n   412→    }\n   413→  }\n   414→\n   415→  // 4. If still have unscheduled, try removing blocking events (limit for performance)\n   416→  if (bestResult.unscheduled.length > 0 && events.length <= 200) {\n   417→    const improved = trySwapOptimization(\n   418→      events, eventMap, eventIds, sortedRooms, startTime, endTime, gap, bestResult,\n   419→    );\n   420→    if (improved.assignments.length > bestCount) {\n   421→      bestResult = improved;\n   422→    }\n   423→  }\n   424→\n   425→  return bestResult;\n   426→}\n   427→\n   428→export default schedule;\n   429→\n   430→export class Scheduler {\n   431→  schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n   432→    return schedule(events, rooms, options);\n   433→  }\n   434→}\n   435→\n   436→export function createScheduler(): { schedule: typeof schedule } {\n   437→  return { schedule };\n   438→}\n   439→\n   440→/**\n   441→ * Try removing each scheduled event to see if we can fit more events overall.\n   442→ */\n   443→function trySwapOptimization(\n   444→  events: Event[],\n   445→  eventMap: Map<string, Event>,\n   446→  eventIds: Set<string>,\n   447→  sortedRooms: Room[],\n   448→  startTime: number,\n   449→  endTime: number,\n   450→  gap: number,\n   451→  currentResult: ScheduleResult,\n   452→): ScheduleResult {\n   453→  let bestResult = currentResult;\n   454→  let bestCount = currentResult.assignments.length;\n   455→\n   456→  // Build dependency info\n   457→  const dependents = new Map<string, Set<string>>();\n   458→  for (const e of events) {\n   459→    dependents.set(e.id, new Set());\n   460→  }\n   461→  for (const e of events) {\n   462→    if (e.prerequisites) {\n   463→      for (const preId of e.prerequisites) {\n   464→        if (eventIds.has(preId)) {\n   465→          dependents.get(preId)!.add(e.id);\n   466→        }\n   467→      }\n   468→    }\n   469→  }\n   470→\n   471→  const scheduledSet = new Set(currentResult.assignments.map(a => a.eventId));\n   472→\n   473→  for (const removedAssignment of currentResult.assignments) {\n   474→    const removedId = removedAssignment.eventId;\n   475→\n   476→    // Don't remove events that are prerequisites for other scheduled events\n   477→    let hasDep = false;\n   478→    for (const depId of dependents.get(removedId) ?? []) {\n   479→      if (scheduledSet.has(depId)) {\n   480→        hasDep = true;\n   481→        break;\n   482→      }\n   483→    }\n   484→    if (hasDep) continue;\n   485→\n   486→    // Try scheduling everything except the removed event\n   487→    const remainingEvents = events.filter(e => e.id !== removedId);\n   488→    const remainingIds = new Set(remainingEvents.map(e => e.id));\n   489→\n   490→    // Generate orderings for the remaining events\n   491→    const orderings = generateOrderings(remainingEvents, remainingIds);\n   492→\n   493→    for (const order of orderings) {\n   494→      const candidate = greedySchedule(\n   495→        order, eventMap, remainingIds, sortedRooms, startTime, endTime, gap,\n   496→      );\n   497→\n   498→      // The removed event is inherently unscheduled\n   499→      const totalScheduled = candidate.assignments.length;\n   500→\n   501→      if (totalScheduled > bestCount) {\n   502→        bestCount = totalScheduled;\n   503→        // Add removed event to unscheduled\n   504→        if (!candidate.unscheduled.includes(removedId)) {\n   505→          candidate.unscheduled.push(removedId);\n   506→        }\n   507→        bestResult = candidate;\n   508→      }\n   509→\n   510→      if (totalScheduled === remainingEvents.length) break;\n   511→    }\n   512→  }\n   513→\n   514→  return bestResult;\n   515→}\n   516→"}]},"parent_tool_use_id":null,"session_id":"c3636f67-9a71-4e2b-ba4a-9bedc2dc9ef0","uuid":"c99d1a31-bb42-4dca-90d4-d414e1a6d472","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"// ── Data Model ──────────────────────────────────────────────────────────────\n\nexport interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n// ── Helpers ─────────────────────────────────────────────────────────────────\n\nconst DEFAULT_GAP = 15;\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws if a cycle (including self-references) is found.\n * Returns a topological order (prerequisites before dependents).\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map(e => e.id));\n\n  // Check for self-references\n  for (const e of events) {\n    if (e.prerequisites?.includes(e.id)) {\n      throw new Error(`Prerequisite cycle detected: event \"${e.id}\" references itself`);\n    }\n  }\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const ev = eventMap.get(id);\n    if (ev?.prerequisites) {\n      for (const preId of ev.prerequisites) {\n        if (!eventIds.has(preId)) continue;\n        const c = color.get(preId);\n        if (c === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event \"${preId}\"`);\n        }\n        if (c === WHITE) {\n          dfs(preId);\n        }\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Compute topological levels. Level 0 = no prerequisites, level 1 = depends only on level 0, etc.\n */\nfunction computeTopoLevels(events: Event[], eventIds: Set<string>): Map<string, number> {\n  const levels = new Map<string, number>();\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const ev = eventMap.get(id);\n    if (!ev?.prerequisites || ev.prerequisites.length === 0) {\n      levels.set(id, 0);\n      return 0;\n    }\n    let maxPreLevel = -1;\n    for (const preId of ev.prerequisites) {\n      if (eventIds.has(preId)) {\n        maxPreLevel = Math.max(maxPreLevel, getLevel(preId));\n      }\n    }\n    const level = maxPreLevel + 1;\n    levels.set(id, level);\n    return level;\n  }\n\n  for (const e of events) {\n    getLevel(e.id);\n  }\n  return levels;\n}\n\n/**\n * Find the earliest start time for an event in a given room.\n */\nfunction findEarliestStartInRoom(\n  duration: number,\n  roomAssignments: Assignment[],\n  earliestStart: number,\n  endTime: number,\n  gap: number,\n): number | null {\n  if (earliestStart + duration > endTime) {\n    return null;\n  }\n\n  const sorted = roomAssignments.slice().sort((a, b) => a.startTime - b.startTime);\n\n  let candidate = earliestStart;\n\n  for (const existing of sorted) {\n    if (candidate + duration + gap <= existing.startTime) {\n      break;\n    }\n    if (candidate < existing.endTime + gap) {\n      candidate = existing.endTime + gap;\n    }\n  }\n\n  if (candidate + duration <= endTime) {\n    return candidate;\n  }\n\n  return null;\n}\n\n/**\n * Compute the earliest an event can start based on prerequisite end times.\n */\nfunction computeEarliestFromPrereqs(\n  event: Event,\n  prereqEndTimes: Map<string, number>,\n  eventIds: Set<string>,\n  windowStart: number,\n  gap: number,\n): number | null {\n  let earliest = windowStart;\n  if (event.prerequisites) {\n    for (const preId of event.prerequisites) {\n      if (eventIds.has(preId)) {\n        const preEnd = prereqEndTimes.get(preId);\n        if (preEnd === undefined) {\n          return null;\n        }\n        earliest = Math.max(earliest, preEnd + gap);\n      }\n    }\n  }\n  return earliest;\n}\n\n/**\n * Generate multiple topological orderings with different sorting strategies\n * within each topological level.\n */\nfunction generateOrderings(\n  events: Event[],\n  eventIds: Set<string>,\n): string[][] {\n  const levels = computeTopoLevels(events, eventIds);\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Group by level\n  const maxLevel = Math.max(...[...levels.values()], 0);\n  const levelGroups: string[][] = [];\n  for (let i = 0; i <= maxLevel; i++) {\n    levelGroups.push([]);\n  }\n  for (const [id, level] of levels) {\n    levelGroups[level].push(id);\n  }\n\n  const orderings: string[][] = [];\n\n  // Strategy 1: shortest duration first within each level\n  const shortFirst = levelGroups.flatMap(group =>\n    [...group].sort((a, b) => eventMap.get(a)!.duration - eventMap.get(b)!.duration)\n  );\n  orderings.push(shortFirst);\n\n  // Strategy 2: longest duration first within each level\n  const longFirst = levelGroups.flatMap(group =>\n    [...group].sort((a, b) => eventMap.get(b)!.duration - eventMap.get(a)!.duration)\n  );\n  orderings.push(longFirst);\n\n  // Strategy 3: most constrained first (most prerequisites, fewest eligible rooms implied by attendees)\n  const constrainedFirst = levelGroups.flatMap(group =>\n    [...group].sort((a, b) => {\n      const ea = eventMap.get(a)!;\n      const eb = eventMap.get(b)!;\n      const attendeesA = ea.attendees ?? 1;\n      const attendeesB = eb.attendees ?? 1;\n      // Higher attendees = more constrained\n      if (attendeesA !== attendeesB) return attendeesB - attendeesA;\n      return ea.duration - eb.duration;\n    })\n  );\n  orderings.push(constrainedFirst);\n\n  // Strategy 4: fewest dependents first (events that don't block others scheduled first)\n  const dependentCount = new Map<string, number>();\n  for (const e of events) {\n    dependentCount.set(e.id, 0);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (eventIds.has(preId)) {\n          dependentCount.set(preId, (dependentCount.get(preId) ?? 0) + 1);\n        }\n      }\n    }\n  }\n  const leastDepsFirst = levelGroups.flatMap(group =>\n    [...group].sort((a, b) => {\n      const da = dependentCount.get(a) ?? 0;\n      const db = dependentCount.get(b) ?? 0;\n      if (da !== db) return da - db;\n      return eventMap.get(a)!.duration - eventMap.get(b)!.duration;\n    })\n  );\n  orderings.push(leastDepsFirst);\n\n  return orderings;\n}\n\n// ── Core Greedy Scheduler ────────────────────────────────────────────────────\n\nfunction greedySchedule(\n  order: string[],\n  eventMap: Map<string, Event>,\n  eventIds: Set<string>,\n  rooms: Room[],\n  startTime: number,\n  endTime: number,\n  gap: number,\n): ScheduleResult {\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n  const prereqEndTimes = new Map<string, number>();\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  for (const eventId of order) {\n    const event = eventMap.get(eventId)!;\n    const attendees = event.attendees ?? 1;\n\n    const earliest = computeEarliestFromPrereqs(event, prereqEndTimes, eventIds, startTime, gap);\n    if (earliest === null) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    const eligibleRooms = rooms.filter(r => r.capacity >= attendees);\n    if (eligibleRooms.length === 0) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    // Order rooms: preferred first, then by capacity (smallest first)\n    let orderedRooms: Room[];\n    if (event.preferredRoom) {\n      const preferred = eligibleRooms.find(r => r.id === event.preferredRoom);\n      if (preferred) {\n        orderedRooms = [preferred, ...eligibleRooms.filter(r => r.id !== event.preferredRoom)];\n      } else {\n        orderedRooms = eligibleRooms;\n      }\n    } else {\n      orderedRooms = eligibleRooms;\n    }\n\n    let bestAssignment: Assignment | null = null;\n    let bestStart = Infinity;\n\n    for (const room of orderedRooms) {\n      const roomSched = roomSchedules.get(room.id)!;\n      const start = findEarliestStartInRoom(\n        event.duration, roomSched, earliest, endTime, gap,\n      );\n\n      if (start !== null) {\n        if (event.preferredRoom === room.id) {\n          bestAssignment = {\n            eventId,\n            roomId: room.id,\n            startTime: start,\n            endTime: start + event.duration,\n          };\n          break;\n        }\n        if (start < bestStart) {\n          bestStart = start;\n          bestAssignment = {\n            eventId,\n            roomId: room.id,\n            startTime: start,\n            endTime: start + event.duration,\n          };\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignments.push(bestAssignment);\n      roomSchedules.get(bestAssignment.roomId)!.push(bestAssignment);\n      prereqEndTimes.set(eventId, bestAssignment.endTime);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\n// ── Main Scheduler ──────────────────────────────────────────────────────────\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n): ScheduleResult {\n  const gap = options.gap ?? DEFAULT_GAP;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // 1. Cycle detection + topological sort (also validates the DAG)\n  topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n  const eventIds = new Set(events.map(e => e.id));\n\n  // Sort rooms by capacity ascending for better packing\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // 2. Generate multiple valid topological orderings with different heuristics\n  const orderings = generateOrderings(events, eventIds);\n\n  // 3. Try each ordering with rooms sorted ascending and descending\n  let bestResult: ScheduleResult = { assignments: [], unscheduled: events.map(e => e.id) };\n  let bestCount = 0;\n\n  const roomOrderings = [\n    sortedRooms,\n    [...sortedRooms].reverse(),\n  ];\n\n  for (const order of orderings) {\n    for (const roomOrder of roomOrderings) {\n      const result = greedySchedule(\n        order, eventMap, eventIds, roomOrder, startTime, endTime, gap,\n      );\n\n      if (result.assignments.length > bestCount) {\n        bestCount = result.assignments.length;\n        bestResult = result;\n\n        // If everything is scheduled, no need to try more\n        if (bestCount === events.length) {\n          return bestResult;\n        }\n      }\n    }\n  }\n\n  // 4. If still have unscheduled, try removing blocking events (limit for performance)\n  if (bestResult.unscheduled.length > 0 && events.length <= 200) {\n    const improved = trySwapOptimization(\n      events, eventMap, eventIds, sortedRooms, startTime, endTime, gap, bestResult,\n    );\n    if (improved.assignments.length > bestCount) {\n      bestResult = improved;\n    }\n  }\n\n  return bestResult;\n}\n\nexport default schedule;\n\nexport class Scheduler {\n  schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n    return schedule(events, rooms, options);\n  }\n}\n\nexport function createScheduler(): { schedule: typeof schedule } {\n  return { schedule };\n}\n\n/**\n * Try removing each scheduled event to see if we can fit more events overall.\n */\nfunction trySwapOptimization(\n  events: Event[],\n  eventMap: Map<string, Event>,\n  eventIds: Set<string>,\n  sortedRooms: Room[],\n  startTime: number,\n  endTime: number,\n  gap: number,\n  currentResult: ScheduleResult,\n): ScheduleResult {\n  let bestResult = currentResult;\n  let bestCount = currentResult.assignments.length;\n\n  // Build dependency info\n  const dependents = new Map<string, Set<string>>();\n  for (const e of events) {\n    dependents.set(e.id, new Set());\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (eventIds.has(preId)) {\n          dependents.get(preId)!.add(e.id);\n        }\n      }\n    }\n  }\n\n  const scheduledSet = new Set(currentResult.assignments.map(a => a.eventId));\n\n  for (const removedAssignment of currentResult.assignments) {\n    const removedId = removedAssignment.eventId;\n\n    // Don't remove events that are prerequisites for other scheduled events\n    let hasDep = false;\n    for (const depId of dependents.get(removedId) ?? []) {\n      if (scheduledSet.has(depId)) {\n        hasDep = true;\n        break;\n      }\n    }\n    if (hasDep) continue;\n\n    // Try scheduling everything except the removed event\n    const remainingEvents = events.filter(e => e.id !== removedId);\n    const remainingIds = new Set(remainingEvents.map(e => e.id));\n\n    // Generate orderings for the remaining events\n    const orderings = generateOrderings(remainingEvents, remainingIds);\n\n    for (const order of orderings) {\n      const candidate = greedySchedule(\n        order, eventMap, remainingIds, sortedRooms, startTime, endTime, gap,\n      );\n\n      // The removed event is inherently unscheduled\n      const totalScheduled = candidate.assignments.length;\n\n      if (totalScheduled > bestCount) {\n        bestCount = totalScheduled;\n        // Add removed event to unscheduled\n        if (!candidate.unscheduled.includes(removedId)) {\n          candidate.unscheduled.push(removedId);\n        }\n        bestResult = candidate;\n      }\n\n      if (totalScheduled === remainingEvents.length) break;\n    }\n  }\n\n  return bestResult;\n}\n","numLines":516,"startLine":1,"totalLines":516}}}
