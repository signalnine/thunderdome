filePath":"/workspace/src/index.ts","content":"// ── Data Model ──────────────────────────────────────────────────────────────\n\nexport interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n// ── Helpers ─────────────────────────────────────────────────────────────────\n\nconst DEFAULT_GAP = 15;\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws if a cycle (including self-references) is found.\n * Returns a topological order (prerequisites before dependents).\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map(e => e.id));\n\n  // Check for self-references\n  for (const e of events) {\n    if (e.prerequisites?.includes(e.id)) {\n      throw new Error(`Prerequisite cycle detected: event \"${e.id}\" references itself`);\n    }\n  }\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const ev = eventMap.get(id);\n    if (ev?.prerequisites) {\n      for (const preId of ev.prerequisites) {\n        if (!eventIds.has(preId)) continue;\n        const c = color.get(preId);\n        if (c === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event \"${preId}\"`);\n        }\n        if (c === WHITE) {\n          dfs(preId);\n        }\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Compute topological levels. Level 0 = no prerequisites, level 1 = depends only on level 0, etc.\n */\nfunction computeTopoLevels(events: Event[], eventIds: Set<string>): Map<string, number> {\n  const levels = new Map<string, number>();\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const ev = eventMap.get(id);\n    if (!ev?.prerequisites || ev.prerequisites.length === 0) {\n      levels.set(id, 0);\n      return 0;\n    }\n    let maxPreLevel = -1;\n    for (const preId of ev.prerequisites) {\n      if (eventIds.has(preId)) {\n        maxPreLevel = Math.max(maxPreLevel, getLevel(preId));\n      }\n    }\n    const level = maxPreLevel + 1;\n    levels.set(id, level);\n    return level;\n  }\n\n  for (const e of events) {\n    getLevel(e.id);\n  }\n  return levels;\n}\n\n/**\n * Find the earliest start time for an event in a given room.\n */\nfunction findEarliestStartInRoom(\n  duration: number,\n  roomAssignments: Assignment[],\n  earliestStart: number,\n  endTime: number,\n  gap: number,\n): number | null {\n  if (earliestStart + duration > endTime) {\n    return null;\n  }\n\n  const sorted = roomAssignments.slice().sort((a, b) => a.startTime - b.startTime);\n\n  let candidate = earliestStart;\n\n  for (const existing of sorted) {\n    if (candidate + duration + gap <= existing.startTime) {\n      break;\n    }\n    if (candidate < existing.endTime + gap) {\n      candidate = existing.endTime + gap;\n    }\n  }\n\n  if (candidate + duration <= endTime) {\n    return candidate;\n  }\n\n  return null;\n}\n\n/**\n * Compute the earliest an event can start based on prerequisite end times.\n */\nfunction computeEarliestFromPrereqs(\n  event: Event,\n  prereqEndTimes: Map<string, number>,\n  eventIds: Set<string>,\n  windowStart: number,\n  gap: number,\n): number | null {\n  let earliest = windowStart;\n  if (event.prerequisites) {\n    for (const preId of event.prerequisites) {\n      if (eventIds.has(preId)) {\n        const preEnd = prereqEndTimes.get(preId);\n        if (preEnd === undefined) {\n          return null;\n        }\n        earliest = Math.max(earliest, preEnd + gap);\n      }\n    }\n  }\n  return earliest;\n}\n\n/**\n * Generate multiple topological orderings with different sorting strategies\n * within each topological level.\n */\nfunction generateOrderings(\n  events: Event[],\n  eventIds: Set<string>,\n): string[][] {\n  const levels = computeTopoLevels(events, eventIds);\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Group by level\n  const maxLevel = Math.max(...[...levels.values()], 0);\n  const levelGroups: string[][] = [];\n  for (let i = 0; i <= maxLevel; i++) {\n    levelGroups.push([]);\n  }\n  for (const [id, level] of levels) {\n    levelGroups[level].push(id);\n  }\n\n  const orderings: string[][] = [];\n\n  // Strategy 1: shortest duration first within each level\n  const shortFirst = levelGroups.flatMap(group =>\n    [...group].sort((a, b) => eventMap.get(a)!.duration - eventMap.get(b)!.duration)\n  );\n  orderings.push(shortFirst);\n\n  // Strategy 2: longest duration first within each level\n  const longFirst = levelGroups.flatMap(group =>\n    [...group].sort((a, b) => eventMap.get(b)!.duration - eventMap.get(a)!.duration)\n  );\n  orderings.push(longFirst);\n\n  // Strategy 3: most constrained first (most prerequisites, fewest eligible rooms implied by attendees)\n  const constrainedFirst = levelGroups.flatMap(group =>\n    [...group].sort((a, b) => {\n      const ea = eventMap.get(a)!;\n      const eb = eventMap.get(b)!;\n      const attendeesA = ea.attendees ?? 1;\n      const attendeesB = eb.attendees ?? 1;\n      // Higher attendees = more constrained\n      if (attendeesA !== attendeesB) return attendeesB - attendeesA;\n      return ea.duration - eb.duration;\n    })\n  );\n  orderings.push(constrainedFirst);\n\n  // Strategy 4: fewest dependents first (events that don't block others scheduled first)\n  const dependentCount = new Map<string, number>();\n  for (const e of events) {\n    dependentCount.set(e.id, 0);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (eventIds.has(preId)) {\n          dependentCount.set(preId, (dependentCount.get(preId) ?? 0) + 1);\n        }\n      }\n    }\n  }\n  const leastDepsFirst = levelGroups.flatMap(group =>\n    [...group].sort((a, b) => {\n      const da = dependentCount.get(a) ?? 0;\n      const db = dependentCount.get(b) ?? 0;\n      if (da !== db) return da - db;\n      return eventMap.get(a)!.duration - eventMap.get(b)!.duration;\n    })\n  );\n  orderings.push(leastDepsFirst);\n\n  return orderings;\n}\n\n// ── Core Greedy Scheduler ────────────────────────────────────────────────────\n\nfunction greedySchedule(\n  order: string[],\n  eventMap: Map<string, Event>,\n  eventIds: Set<string>,\n  rooms: Room[],\n  startTime: number,\n  endTime: number,\n  gap: number,\n): ScheduleResult {\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n  const prereqEndTimes = new Map<string, number>();\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  for (const eventId of order) {\n    const event = eventMap.get(eventId)!;\n    const attendees = event.attendees ?? 1;\n\n    const earliest = computeEarliestFromPrereqs(event, prereqEndTimes, eventIds, startTime, gap);\n    if (earliest === null) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    const eligibleRooms = rooms.filter(r => r.capacity >= attendees);\n    if (eligibleRooms.length === 0) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    // Order rooms: preferred first, then by capacity (smallest first)\n    let orderedRooms: Room[];\n    if (event.preferredRoom) {\n      const preferred = eligibleRooms.find(r => r.id === event.preferredRoom);\n      if (preferred) {\n        orderedRooms = [preferred, ...eligibleRooms.filter(r => r.id !== event.preferredRoom)];\n      } else {\n        orderedRooms = eligibleRooms;\n      }\n    } else {\n      orderedRooms = eligibleRooms;\n    }\n\n    let bestAssignment: Assignment | null = null;\n    let bestStart = Infinity;\n\n    for (const room of orderedRooms) {\n      const roomSched = roomSchedules.get(room.id)!;\n      const start = findEarliestStartInRoom(\n        event.duration, roomSched, earliest, endTime, gap,\n      );\n\n      if (start !== null) {\n        if (event.preferredRoom === room.id) {\n          bestAssignment = {\n            eventId,\n            roomId: room.id,\n            startTime: start,\n            endTime: start + event.duration,\n          };\n          break;\n        }\n        if (start < bestStart) {\n          bestStart = start;\n          bestAssignment = {\n            eventId,\n            roomId: room.id,\n            startTime: start,\n            endTime: start + event.duration,\n          };\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignments.push(bestAssignment);\n      roomSchedules.get(bestAssignment.roomId)!.push(bestAssignment);\n      prereqEndTimes.set(eventId, bestAssignment.endTime);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\n// ── Main Scheduler ──────────────────────────────────────────────────────────\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n): ScheduleResult {\n  const gap = options.gap ?? DEFAULT_GAP;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // 1. Cycle detection + topological sort (also validates the DAG)\n  topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n  const eventIds = new Set(events.map(e => e.id));\n\n  // Sort rooms by capacity ascending for better packing\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // 2. Generate multiple valid topological orderings with different heuristics\n  const orderings = generateOrderings(events, eventIds);\n\n  // 3. Try each ordering with rooms sorted ascending and descending\n  let bestResult: ScheduleResult = { assignments: [], unscheduled: events.map(e => e.id) };\n  let bestCount = 0;\n\n  const roomOrderings = [\n    sortedRooms,\n    [...sortedRooms].reverse(),\n  ];\n\n  for (const order of orderings) {\n    for (const roomOrder of roomOrderings) {\n      const result = greedySchedule(\n        order, eventMap, eventIds, roomOrder, startTime, endTime, gap,\n      );\n\n      if (result.assignments.length > bestCount) {\n        bestCount = result.assignments.length;\n        bestResult = result;\n\n        // If everything is scheduled, no need to try more\n        if (bestCount === events.length) {\n          return bestResult;\n        }\n      }\n    }\n  }\n\n  // 4. If still have unscheduled, try removing blocking events\n  if (bestResult.unscheduled.length > 0) {\n    const improved = trySwapOptimization(\n      events, eventMap, eventIds, sortedRooms, startTime, endTime, gap, bestResult,\n    );\n    if (improved.assignments.length > bestCount) {\n      bestResult = improved;\n    }\n  }\n\n  return bestResult;\n}\n\n/**\n * Try removing each scheduled event to see if we can fit more events overall.\n */\nfunction trySwapOptimization(\n  events: Event[],\n  eventMap: Map<string, Event>,\n  eventIds: Set<string>,\n  sortedRooms: Room[],\n  startTime: number,\n  endTime: number,\n  gap: number,\n  currentResult: ScheduleResult,\n): ScheduleResult {\n  let bestResult = currentResult;\n  let bestCount = currentResult.assignments.length;\n\n  // Build dependency info\n  const dependents = new Map<string, Set<string>>();\n  for (const e of events) {\n    dependents.set(e.id, new Set());\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (eventIds.has(preId)) {\n          dependents.get(preId)!.add(e.id);\n        }\n      }\n    }\n  }\n\n  const scheduledSet = new Set(currentResult.assignments.map(a => a.eventId));\n\n  for (const removedAssignment of currentResult.assignments) {\n    const removedId = removedAssignment.eventId;\n\n    // Don't remove events that are prerequisites for other scheduled events\n    let hasDep = false;\n    for (const depId of dependents.get(removedId) ?? []) {\n      if (scheduledSet.has(depId)) {\n        hasDep = true;\n        break;\n      }\n    }\n    if (hasDep) continue;\n\n    // Try scheduling everything except the removed event\n    const remainingEvents = events.filter(e => e.id !== removedId);\n    const remainingIds = new Set(remainingEvents.map(e => e.id));\n\n    // Generate orderings for the remaining events\n    const orderings = generateOrderings(remainingEvents, remainingIds);\n\n    for (const order of orderings) {\n      const candidate = greedySchedule(\n        order, eventMap, remainingIds, sortedRooms, startTime, endTime, gap,\n      );\n\n      // The removed event is inherently unscheduled\n      const totalScheduled = candidate.assignments.length;\n\n      if (totalScheduled > bestCount) {\n        bestCount = totalScheduled;\n        // Add removed event to unscheduled\n        if (!candidate.unscheduled.includes(removedId)) {\n          candidate.unscheduled.push(removedId);\n        }\n        bestResult = candidate;\n      }\n\n      if (totalScheduled === remainingEvents.length) break;\n    }\n  }\n\n  return bestResult;\n}\n","structuredPatch":[{"oldStart":70,"oldLines":7,"newStart":70,"newLines":6,"lines":["     const ev = eventMap.get(id);","     if (ev?.prerequisites) {","       for (const preId of ev.prerequisites) {","-        // Only traverse prerequisites that are in the event set","         if (!eventIds.has(preId)) continue;","         const c = color.get(preId);","         if (c === GRAY) {"]},{"oldStart":95,"oldLines":9,"newStart":94,"newLines":42,"lines":[" }"," "," /**","- * Find the earliest start time for an event in a given room,","- * respecting room schedule and the event's earliest possible start.","+ * Compute topological levels. Level 0 = no prerequisites, level 1 = depends only on level 0, etc.","  */","+function computeTopoLevels(events: Event[], eventIds: Set<string>): Map<string, number> {","+  const levels = new Map<string, number>();","+  const eventMap = new Map<string, Event>();","+  for (const e of events) {","+    eventMap.set(e.id, e);","+  }","+","+  function getLevel(id: string): number {","+    if (levels.has(id)) return levels.get(id)!;","+    const ev = eventMap.get(id);","+    if (!ev?.prerequisites || ev.prerequisites.length === 0) {","+      levels.set(id, 0);","+      return 0;","+    }","+    let maxPreLevel = -1;","+    for (const preId of ev.prerequisites) {","+      if (eventIds.has(preId)) {","+        maxPreLevel = Math.max(maxPreLevel, getLevel(preId));","+      }","+    }","+    const level = maxPreLevel + 1;","+    levels.set(id, level);","+    return level;","+  }","+","+  for (const e of events) {","+    getLevel(e.id);","+  }","+  return levels;","+}","+","+/**","+ * Find the earliest start time for an event in a given room.","+ */"," function findEarliestStartInRoom(","   duration: number,","   roomAssignments: Assignment[],"]},{"oldStart":109,"oldLines":17,"newStart":141,"newLines":14,"lines":["     return null;","   }"," ","-  // Sor