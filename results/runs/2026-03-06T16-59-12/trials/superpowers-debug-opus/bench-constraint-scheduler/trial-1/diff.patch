me","+  // and re-running the greedy on the remaining events + previously unscheduled","+  for (const removedAssignment of currentResult.assignments) {","+    const removedId = removedAssignment.eventId;","+    const removedEvent = eventMap.get(removedId)!;","+","+    // Don't remove events that are prerequisites for other scheduled events","+    let isDep = false;","+    for (const asgn of currentResult.assignments) {","+      if (asgn.eventId === removedId) continue;","+      const ev = eventMap.get(asgn.eventId)!;","+      if (ev.prerequisites?.includes(removedId)) {","+        isDep = true;","+        break;","+      }","+    }","+    if (isDep) continue;","+","+    // Create new topoOrder without the removed event","+    const newTopoOrder = topoOrder.filter(id => id !== removedId);","+","+    const candidate = greedySchedule(","+      newTopoOrder, eventMap, eventIds, sortedRooms, startTime, endTime, gap,","+    );","+","+    // Include removed event in unscheduled","+    if (!candidate.unscheduled.includes(removedId) &&","+        !candidate.assignments.some(a => a.eventId === removedId)) {","+      candidate.unscheduled.push(removedId);","+    }","+","+    if (candidate.assignments.length > bestCount) {","+      bestCount = candidate.assignments.length;","+      bestResult = candidate;","+    }","+  }","+","+  // Also try scheduling unscheduled events with different room orderings","+  // by sorting rooms by capacity descending","+  const reversedRooms = [...sortedRooms].reverse();","+  const altResult = greedySchedule(","+    topoOrder, eventMap, eventIds, reversedRooms, startTime, endTime, gap,","+  );","+  if (altResult.assignments.length > bestCount) {","+    bestResult = altResult;","+    bestCount = altResult.assignments.length;","+  }","+","+  return bestResult;","+}"]}],"originalFile":"// ── Data Model ──────────────────────────────────────────────────────────────\n\nexport interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n// ── Helpers ─────────────────────────────────────────────────────────────────\n\nconst DEFAULT_GAP = 15;\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws if a cycle (including self-references) is found.\n * Returns a topological order (reverse post-order).\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Check for self-references first\n  for (const e of events) {\n    if (e.prerequisites?.includes(e.id)) {\n      throw new Error(`Prerequisite cycle detected: event \"${e.id}\" references itself`);\n    }\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const ev = eventMap.get(id);\n    if (ev?.prerequisites) {\n      for (const preId of ev.prerequisites) {\n        const c = color.get(preId);\n        if (c === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event \"${preId}\"`);\n        }\n        if (c === WHITE) {\n          dfs(preId);\n        }\n        // if BLACK, already processed — skip\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n\n  return order; // topological order: prerequisites come before dependents\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering room availability and prerequisite completion times.\n */\nfunction findEarliestStart(\n  eventId: string,\n  duration: number,\n  roomId: string,\n  roomSchedule: Assignment[],\n  prereqEndTimes: Map<string, number>,\n  prerequisites: string[] | undefined,\n  options: ScheduleOptions,\n  gap: number,\n): number | null {\n  const { startTime, endTime } = options;\n\n  // Earliest possible start: after all prerequisites finish + gap\n  let earliest = startTime;\n  if (prerequisites) {\n    for (const preId of prerequisites) {\n      const preEnd = prereqEndTimes.get(preId);\n      if (preEnd === undefined) {\n        // prerequisite not scheduled — can't schedule this event\n        return null;\n      }\n      earliest = Math.max(earliest, preEnd + gap);\n    }\n  }\n\n  // Check if event can even fit within the time window\n  if (earliest + duration > endTime) {\n    return null;\n  }\n\n  // Find a slot in the room's schedule\n  // Room schedule is sorted by startTime\n  const sorted = [...roomSchedule].sort((a, b) => a.startTime - b.startTime);\n\n  // Try to fit before the first event, between events, or after the last event\n  // Candidate start times: earliest possible, or after each existing event + gap\n  let candidate = earliest;\n\n  for (const existing of sorted) {\n    // If candidate + duration fits before existing event starts (with gap)\n    if (candidate + duration + gap <= existing.startTime || candidate + duration <= existing.startTime) {\n      // We need gap between end of our event and start of existing only if they're adjacent\n      if (candidate + duration + gap <= existing.startTime) {\n        // Fits before this event with gap\n        if (candidate + duration <= endTime) {\n          return candidate;\n        }\n      }\n      // If our event ends exactly at existing.startTime but without gap, try after\n      if (candidate + duration <= existing.startTime && candidate + duration + gap > existing.startTime) {\n        // Not enough gap, need to try after this event\n      } else if (candidate + duration <= endTime) {\n        return candidate;\n      }\n    }\n    // Move candidate to after this event + gap\n    candidate = Math.max(candidate, existing.endTime + gap);\n  }\n\n  // Try after the last event\n  if (candidate + duration <= endTime) {\n    return candidate;\n  }\n\n  return null;\n}\n\n// ── Main Scheduler ──────────────────────────────────────────────────────────\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n): ScheduleResult {\n  const gap = options.gap ?? DEFAULT_GAP;\n\n  // 1. Cycle detection + topological sort\n  const topoOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Sort rooms by capacity ascending (try smaller rooms first for better packing)\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Room schedules: roomId -> list of assignments\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  // Track prerequisite end times\n  const prereqEndTimes = new Map<string, number>();\n\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  // 2. Schedule events in topological order\n  // This ensures prerequisites are scheduled before dependents\n  for (const eventId of topoOrder) {\n    const event = eventMap.get(eventId)!;\n    const attendees = event.attendees ?? 1;\n\n    // Find all rooms that can fit this event\n    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n\n    if (eligibleRooms.length === 0) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    // Check if prerequisites are all scheduled\n    let prereqsMet = true;\n    if (event.prerequisites) {\n      for (const preId of event.prerequisites) {\n        if (!prereqEndTimes.has(preId)) {\n          prereqsMet = false;\n          break;\n        }\n      }\n    }\n\n    if (!prereqsMet) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    // Try preferred room first, then others\n    let orderedRooms: Room[];\n    if (event.preferredRoom) {\n      const preferred = eligibleRooms.find(r => r.id === event.preferredRoom);\n      if (preferred) {\n        const others = eligibleRooms.filter(r => r.id !== event.preferredRoom);\n        orderedRooms = [preferred, ...others];\n      } else {\n        orderedRooms = eligibleRooms;\n      }\n    } else {\n      orderedRooms = eligibleRooms;\n    }\n\n    let bestAssignment: Assignment | null = null;\n    let bestStart = Infinity;\n\n    for (const room of orderedRooms) {\n      const roomSched = roomSchedules.get(room.id)!;\n      const start = findEarliestStart(\n        eventId,\n        event.duration,\n        room.id,\n        roomSched,\n        prereqEndTimes,\n        event.prerequisites,\n        options,\n        gap,\n      );\n\n      if (start !== null) {\n        // For preferred rooms, pick it immediately if it gives a valid slot\n        if (event.preferredRoom === room.id) {\n          bestAssignment = {\n            eventId,\n            roomId: room.id,\n            startTime: start,\n            endTime: start + event.duration,\n          };\n          break;\n        }\n\n        // Otherwise, pick the earliest start time\n        if (start < bestStart) {\n          bestStart = start;\n          bestAssignment = {\n            eventId,\n            roomId: room.id,\n            startTime: start,\n            endTime: start + event.duration,\n          };\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignments.push(bestAssignment);\n      roomSchedules.get(bestAssignment.roomId)!.push(bestAssignment);\n      prereqEndTimes.set(eventId, bestAssignment.endTime);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n"}}
