+      const result = store.get('doc1');
+      expect(result).toEqual({ name: 'test', value: 42 });
+    });
+
+    it('should throw on duplicate create', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.create('doc1', { a: 2 })).toThrow();
+    });
+
+    it('should throw when getting non-existent doc', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 2, b: 3 });
+    });
+
+    it('should throw when updating non-existent doc', () => {
+      expect(() => store.update('nonexistent', { a: 1 })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting non-existent doc', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('should deep clone on storage - mutations do not affect stored content', () => {
+      const content = { nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
