try.deleted ? baseEntry.content : null;\n        const theirsContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;\n        const oursContent = existingEntry && !existingEntry.deleted ? existingEntry.content : null;\n\n        // Determine if the merged outcome means the doc should be deleted\n        const theirDeleted = (baseContent !== null && theirsContent === null);\n        const ourDeleted = (baseContent !== null && oursContent === null);\n\n        if ((theirDeleted && !oursContent) || (ourDeleted && !theirsContent)) {\n          // Document should be deleted\n          if (existingEntry) {\n            existingEntry.deleted = true;\n          }\n          continue;\n        }\n\n        if (existingEntry) {\n          // Update existing document\n          const version: Version = {\n            id: generateId(),\n            timestamp: Date.now(),\n            content: deepClone(content),\n          };\n          existingEntry.content = deepClone(content);\n          existingEntry.deleted = false;\n          existingEntry.versions.push(version);\n        } else {\n          // New document from source branch\n          const version: Version = {\n            id: generateId(),\n            timestamp: Date.now(),\n            content: deepClone(content),\n          };\n          targetBranchData.documents.set(docId, {\n            content: deepClone(content),\n            versions: [version],\n            deleted: false,\n          });\n        }\n      }\n    }\n\n    return {\n      merged,\n      conflicts: allConflicts,\n      applied,\n    };\n  }\n\n  private getCurrentBranchData(): BranchData {\n    const data = this.branches.get(this.currentBranch);\n    if (!data) {\n      throw new Error(`Branch \"${this.currentBranch}\" not found`);\n    }\n    return data;\n  }\n\n  private findCommonAncestor(\n    branchA: string,\n    branchB: string,\n  ): Map<string, DocumentEntry> | null {\n    const branchAData = this.branches.get(bran