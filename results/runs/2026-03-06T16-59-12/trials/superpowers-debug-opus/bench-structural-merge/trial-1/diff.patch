diff --git a/src/edge-cases.test.ts b/src/edge-cases.test.ts
new file mode 100644
index 0000000..2d35093
--- /dev/null
+++ b/src/edge-cases.test.ts
@@ -0,0 +1,210 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore Edge Cases', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Delete edge cases', () => {
+    it('should allow re-creating a document after delete', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      store.create('doc1', { a: 2 });
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+
+    it('should throw when updating a deleted doc', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.update('doc1', { a: 2 })).toThrow();
+    });
+
+    it('should throw when deleting an already-deleted doc', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+  });
+
+  describe('Merge: deletion scenarios', () => {
+    it('should propagate deletion from source when target unchanged', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.delete('doc1');
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should handle only target having changes (no source changes)', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      // Only modify on main (target)
+      store.update('doc1', { a: 2 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      // No changes from feature, so no merged docs
+      // Main still has its value
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+
+    it('should handle document created only on source branch during merge', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('newdoc', { x: 1 });
+
+      store.switchBranch('main');
+      expect(() => store.get('newdoc')).toThrow();
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('newdoc')).toEqual({ x: 1 });
+    });
+
+    it('should handle document created only on target branch during merge', () => {
+      store.createBranch('feature');
+
+      // Create doc on main only
+      store.create('newdoc', { x: 1 });
+
+      const result = store.merge('feature');
+      // Feature has no changes, so this should be empty
+      expect(result.applied).toBe(true);
+    });
+  });
+
+  describe('Merge: mixed conflict and non-conflict', () => {
+    it('should handle mix of conflicting and non-conflicting fields', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+
+      // main changes a and b
+      store.update('doc1', { a: 10, b: 20, c: 3 });
+
+      // feature changes b and c
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 30, c: 30 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(false);
+      // b is conflicting (20 vs 30)
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].path).toBe('b');
+      expect(result.conflicts[0].base).toBe(2);
+      expect(result.conflicts[0].ours).toBe(20);
+      expect(result.conflicts[0].theirs).toBe(30);
+
+      // merged should show ours for conflicts, theirs for non-conflicts
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 30 });
+
+      // Current branch should be unchanged since there are conflicts
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });
+    });
+  });
+
+  describe('Merge: multiple documents', () => {
+    it('should merge multiple docs with mixed changes cleanly', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { x: 10 });
+      store.create('doc3', { m: 100 });
+      store.createBranch('feature');
+
+      // main modifies doc1
+      store.update('doc1', { a: 2 });
+
+      // feature modifies doc2 and doc3
+      store.switchBranch('feature');
+      store.update('doc2', { x: 20 });
+      store.update('doc3', { m: 200 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 2 });
+      expect(store.get('doc2')).toEqual({ x: 20 });
+      expect(store.get('doc3')).toEqual({ m: 200 });
+    });
+  });
+
+  describe('Deep cloning in version history', () => {
+    it('should deep clone version content', () => {
+      store.create('doc1', { nested: { value: 1 } });
+      const history = store.getHistory('doc1');
+      (history[0].content as any).nested.value = 999;
+
+      const history2 = store.getHistory('doc1');
+      expect(history2[0].content).toEqual({ nested: { value: 1 } });
+    });
+  });
+
+  describe('Branch from specific branch', () => {
+    it('should create branch from another non-current branch', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+
+      // Create branch from feature while on feature
+      store.createBranch('feature2', 'feature');
+      store.switchBranch('feature2');
+      expect(store.get('doc1')).toEqual({ a: 2 });
+
+      // Modify feature2
+      store.update('doc1', { a: 3 });
+
+      // feature should be unchanged
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+  });
+
+  describe('Merge with new fields added by both sides', () => {
+    it('should merge when both sides add different new fields', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 1, b: 2 });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, c: 3 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1, b: 2, c: 3 });
+      expect(store.get('doc1')).toEqual({ a: 1, b: 2, c: 3 });
+    });
+  });
+
+  describe('Merge: field removal', () => {
+    it('should handle field removal on one side', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      // Feature removes field b
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1 });
+      expect(store.get('doc1')).toEqual({ a: 1 });
+    });
+  });
