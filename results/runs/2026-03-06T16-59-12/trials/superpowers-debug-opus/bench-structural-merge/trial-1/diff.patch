t key of Object.keys(obj)) {\n    const fullPath = prefix ? `${prefix}.${key}` : key;\n    const value = obj[key];\n    if (value !== null && value !== undefined && typeof value === 'object' && !Array.isArray(value)) {\n      paths.push(...collectLeafPaths(value, fullPath));\n    } else {\n      paths.push(fullPath);\n    }\n  }\n  return paths;\n}\n\ninterface DocMergeResult {\n  merged: object;\n  conflicts: Conflict[];\n  deleted: boolean;\n}\n\nfunction threeWayMergeDocument(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string\n): DocMergeResult {\n  const conflicts: Conflict[] = [];\n\n  // If document didn't exist in base\n  if (base === null) {\n    // Both created the same document - merge their fields\n    if (ours !== null && theirs !== null) {\n      const merged = deepClone(ours) as any;\n      const baseObj = {} as any;\n      const oursObj = ours as any;\n      const theirsObj = theirs as any;\n\n      const allPaths = new Set<string>();\n      collectLeafPaths(oursObj).forEach(p => allPaths.add(p));\n      collectLeafPaths(theirsObj).forEach(p => allPaths.add(p));\n\n      for (const path of allPaths) {\n        const baseVal = getValueAtPath(baseObj, path);\n        const ourVal = getValueAtPath(oursObj, path);\n        const theirVal = getValueAtPath(theirsObj, path);\n\n        const ourChanged = !deepEquals(baseVal, ourVal);\n        const theirChanged = !deepEquals(baseVal, theirVal);\n\n        if (ourChanged && theirChanged && !deepEquals(ourVal, theirVal)) {\n          conflicts.push({\n            documentId,\n            path,\n            base: deepClone(baseVal),\n            ours: deepClone(ourVal),\n            theirs: deepClone(theirVal),\n          });\n          // Keep ours for merged result\n          setValueAtPath(merged, path, deepClone(ourVal));\n        } else if (theirChanged && !ourChanged) {\n          setValueAtPath(merged, path, deepClone(theirVal));\n        }\n        // If ourChanged and !theirChanged, ours is already in merged\n      }\n\n      return { merged, conflicts, deleted: false };\n    }\n    // Only one side created it\n    if (ours !== null) return { merged: deepClone(ours), conflicts: [], deleted: false };\n    if (theirs !== null) return { merged: deepClone(theirs), conflicts: [], deleted: false };\n    return { merged: {}, conflicts: [], deleted: false };\n  }\n\n  // Base exists\n  // If one side deleted and other didn't change, take the deletion\n  // If one side deleted and other changed, conflict\n  if (ours === null && theirs === null) {\n    // Both deleted - no conflict, result is deleted\n    return { merged: deepClone(base), conflicts: [], deleted: true };\n  }\n\n  if (ours === null) {\n    // We deleted, they may have changed\n    const theyChanged = !deepEquals(base, theirs);\n    if (theyChanged) {\n      // Conflict: we deleted, they modified\n      conflicts.push({\n        documentId,\n        path: '',\n        base: deepClone(base),\n        ours: null,\n        theirs: deepClone(theirs),\n      });\n      return { merged: deepClone(base), conflicts, deleted: true };\n    }\n    // They didn't change, we deleted - take deletion\n    return { merged: deepClone(base), conflicts: [], deleted: true };\n  }\n\n  if (theirs === null) {\n    // They deleted, we may have changed\n    const weChanged = !deepEquals(base, ours);\n    if (weChanged) {\n      // Conflict: they deleted, we modified\n      conflicts.push({\n        documentId,\n        path: '',\n        base: deepClone(base),\n        ours: deepClone(ours),\n        theirs: null,\n      });\n      // In merged result, favor ours (keep it)\n      return { merged: deepClone(ours), conflicts, deleted: false };\n    }\n    // We didn't change, they deleted - take deletion\n    return { merged: deepClone(base), conflicts: [], deleted: true };\n  }\n\n  // Both sides exist - field-level merge\n  const baseObj = base as any;\n  const oursObj = ours as any;\n  const theirsObj = theirs as any;\n  const merged = deepClone(base) as any;\n\n  // Collect all leaf paths from all three\n  const allPaths = new Set<string>();\n  collectLeafPaths(baseObj).forEach(p => allPaths.add(p));\n  collectLeafPaths(oursObj).forEach(p => allPaths.add(p));\n  collectLeafPaths(theirsObj).forEach(p => allPaths.add(p));\n\n  for (const path of allPaths) {\n    const baseVal = getValueAtPath(baseObj, path);\n    const ourVal = getValueAtPath(oursObj, path);\n    const theirVal = getValueAtPath(theirsObj, path);\n\n    const ourChanged = !deepEquals(baseVal, ourVal);\n    const theirChanged = !deepEquals(baseVal, theirVal);\n\n    if (ourChanged && theirChanged) {\n      if (!deepEquals(ourVal, theirVal)) {\n        // Conflict\n        conflicts.push({\n          documentId,\n          path,\n          base: deepClone(baseVal),\n          ours: deepClone(ourVal),\n          theirs: deepClone(theirVal),\n        });\n        // For merged result, favor ours\n        if (ourVal === undefined) {\n          deleteValueAtPath(merged, path);\n        } else {\n          setValueAtPath(merged, path, deepClone(ourVal));\n        }\n      } else {\n        // Both changed to same value - no conflict\n        if (ourVal === undefined) {\n          deleteValueAtPath(merged, path);\n        } else {\n          setValueAtPath(merged, path, deepClone(ourVal));\n        }\n      }\n    } else if (ourChanged) {\n      if (ourVal === undefined) {\n        deleteValueAtPath(merged, path);\n      } else {\n        setValueAtPath(merged, path, deepClone(ourVal));\n      }\n    } else if (theirChanged) {\n      if (theirVal === undefined) {\n        deleteValueAtPath(merged, path);\n      } else {\n        setValueAtPath(merged, path, deepClone(theirVal));\n      }\n    }\n    // Neither changed - keep base value (already in merged)\n  }\n\n  return { merged, conflicts, deleted: false };\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      parentBranch: null,\n      branchPointSnapshot: null,\n    });\n  }\n\n  // Document CRUD\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const version: Version = {\n      id: generateId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    branch.documents.set(id, {\n      content: deepClone(content),\n      versions: existing && existing.deleted ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return deepClone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n\n    const version: Version = {\n      id: generateId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    entry.content = deepClone(content);\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    entry.deleted = true;\n  }\n\n  // Version History\n\n  getHistory(id: string): Version[] {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return entry.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = entry.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // Branching\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n\n    const sourceBranchName = fromBranch || this.currentBranch;\n    const sourceBranch = this.branches.get(sourceBranchName);\n    if (!sourceBranch) {\n      throw new Error(`Branch \"${sourceBranchName}\" not found`);\n    }\n\n    const clonedDocs = cloneDocumentsMap(sourceBranch.documents);\n\n    this.branches.set(name, {\n      documents: clonedDocs,\n      parentBranch: sourceBranchName,\n      branchPointSnapshot: cloneDocumentsMap(sourceBranch.documents),\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys()).sort();\n  }\n\n  // Merging\n\n  merge(sourceBranch: string): MergeResult {\n    const sourceBranchData = this.branches.get(sourceBranch);\n    if (!sourceBranchData) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n\n    const targetBranchData = this.getCurrentBranchData();\n\n    // Find common ancestor (branch point snapshot)\n    // The common ancestor is the state of the source branch when it was created,\n    // OR the state of the target branch when the source was created from it,\n    // OR the state when one was created from the other.\n    const baseSnapshot = this.findCommonAncestor(sourceBranch, this.currentBranch);\n\n    // Collect all document IDs across base, source, and target\n    const allDocIds = new Set<string>();\n    if (baseSnapshot) {\n      for (const id of baseSnapshot.keys()) allDocIds.add(id);\n    }\n    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);\n    for (const id of targetBranchData.documents.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const allConflicts: Conflict[] = [];\n    let hasChanges = false;\n\n    const deletions = new Set<string>();\n\n    for (const docId of allDocIds) {\n      const baseEntry = baseSnapshot ? baseSnapshot.get(docId) : undefined;\n      const oursEntry = targetBranchData.documents.get(docId);\n      const theirsEntry = sourceBranchData.documents.get(docId);\n\n      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;\n      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;\n      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;\n\n      // Check if anything actually changed\n      const oursChanged = !deepEquals(baseContent, oursContent);\n      const theirsChanged = !deepEquals(baseContent, theirsContent);\n\n      if (!oursChanged && !theirsChanged) {\n        // No changes on either side for this document - skip\n        continue;\n      }\n\n      hasChanges = true;\n\n      const result = threeWayMergeDocument(baseContent, oursContent, theirsContent, docId);\n      merged[docId] = result.merged;\n      allConflicts.push(...result.conflicts);\n\n      if (result.deleted) {\n        deletions.add(docId);\n      }\n    }\n\n    if (!hasChanges) {\n      // Fast-forward / no-op\n      return {\n        merged: {},\n        conflicts: [],\n        applied: true,\n      };\n    }\n\n    const applied = allConflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge to the current branch\n      for (const [docId, content] of Object.entries(merged)) {\n        const existingEntry = targetBranchData.documents.get(docId);\n\n        if (deletions.has(docId)) {\n          // Document should be deleted\n          if (existingEntry) {\n            existingEntry.deleted = true;\n          }\n          continue;\n        }\n\n        if (existingEntry) {\n          // Update existing document\n          const version: Version = {\n            id: generateId(),\n            timestamp: Date.now(),\n            content: deepClone(content),\n          };\n          existingEntry.content = deepClone(content);\n          existingEntry.deleted = false;\n          existingEntry.versions.push(version);\n        } else {\n          // New document from source branch\n          const version: Version = {\n            id: generateId(),\n            timestamp: Date.now(),\n            content: deepClone(content),\n          };\n          targetBranchData.documents.set(docId, {\n            content: deepClone(content),\n            versions: [version],\n            deleted: false,\n          });\n        }\n      }\n    }\n\n    return {\n      merged,\n      conflicts: allConflicts,\n      applied,\n    };\n  }\n\n  private getCurrentBranchData(): BranchData {\n    const data = this.branches.get(this.currentBranch);\n    if (!data) {\n      throw new Error(`Branch \"${this.currentBranch}\" not found`);\n    }\n    return data;\n  }\n\n  private findCommonAncestor(\n    branchA: string,\n    branchB: string,\n  ): Map<string, DocumentEntry> | null {\n    const branchAData = this.branches.get(branchA);\n    const branchBData = this.branches.get(branchB);\n\n    if (!branchAData || !branchBData) return null;\n\n    // If branchA was created from branchB, the ancestor is branchA's branch point snapshot\n    if (branchAData.parentBranch === branchB && branchAData.branchPointSnapshot) {\n      return branchAData.branchPointSnapshot;\n    }\n\n    // If branchB was created from branchA, the ancestor is branchB's branch point snapshot\n    if (branchBData.parentBranch === branchA && branchBData.branchPointSnapshot) {\n      return branchBData.branchPointSnapshot;\n    }\n\n    // If both share a common parent, we need to find the common ancestor\n    // For simplicity, walk up the parent chain\n    const ancestorsA = this.getAncestorChain(branchA);\n    const ancestorsB = this.getAncestorChain(branchB);\n\n    // Find common ancestor\n    for (const ancestor of ancestorsA) {\n      if (ancestorsB.includes(ancestor)) {\n        // The common ancestor is the branch point of the first branch that diverged\n        // Use the branch point snapshot of whichever branch was created later\n        const branchASnapshot = branchAData.branchPointSnapshot;\n        const branchBSnapshot = branchBData.branchPointSnapshot;\n\n        // Return the one that exists, preferring the more specific one\n        if (branchAData.parentBranch === ancestor && branchASnapshot) {\n          return branchASnapshot;\n        }\n        if (branchBData.parentBranch === ancestor && branchBSnapshot) {\n          return branchBSnapshot;\n        }\n\n        return branchASnapshot || branchBSnapshot || new Map();\n      }\n    }\n\n    // No common ancestor found - treat as empty base\n    return new Map();\n  }\n\n  private getAncestorChain(branchName: string): string[] {\n    const chain: string[] = [branchName];\n    let current = branchName;\n\n    while (true) {\n      const data = this.branches.get(current);\n      if (!data || !data.parentBranch) break;\n      chain.push(data.parentBranch);\n      current = data.parentBranch;\n    }\n\n    return chain;\n  }\n}\n","structuredPatch":[{"oldStart":591,"oldLines":12,"newStart":591,"newLines":12,"lin