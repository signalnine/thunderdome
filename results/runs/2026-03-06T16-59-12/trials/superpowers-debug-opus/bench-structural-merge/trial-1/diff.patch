ray.isArray(obj)) {\n    return paths;\n  }\n  for (const key of Object.keys(obj)) {\n    const fullPath = prefix ? `${prefix}.${key}` : key;\n    const value = obj[key];\n    if (value !== null && value !== undefined && typeof value === 'object' && !Array.isArray(value)) {\n      paths.push(...collectLeafPaths(value, fullPath));\n    } else {\n      paths.push(fullPath);\n    }\n  }\n  return paths;\n}\n\ninterface DocMergeResult {\n  merged: object;\n  conflicts: Conflict[];\n  deleted: boolean;\n}\n\nfunction threeWayMergeDocument(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string\n): DocMergeResult {\n  const conflicts: Conflict[] = [];\n\n  // If document didn't exist in base\n  if (base === null) {\n    // Both created the same document - merge their fields\n    if (ours !== null && theirs !== null) {\n      const merged = deepClone(ours) as any;\n      const baseObj = {} as any;\n      const oursObj = ours as any;\n      const theirsObj = theirs as any;\n\n      const allPaths = new Set<string>();\n      collectLeafPaths(oursObj).forEach(p => allPaths.add(p));\n      collectLeafPaths(theirsObj).forEach(p => allPaths.add(p));\n\n      for (const path of allPaths) {\n        const baseVal = getValueAtPath(baseObj, path);\n        const ourVal = getValueAtPath(oursObj, path);\n        const theirVal = getValueAtPath(theirsObj, path);\n\n        const ourChanged = !deepEquals(baseVal, ourVal);\n        const theirChanged = !deepEquals(baseVal, theirVal);\n\n        if (ourChanged && theirChanged && !deepEquals(ourVal, theirVal)) {\n          conflicts.push({\n            documentId,\n            path,\n            base: deepClone(baseVal),\n            ours: deepClone(ourVal),\n            theirs: deepClone(theirVal),\n          });\n          // Keep ours for merged result\n          setValueAtPath(merged, path, deepClone(ourVal));\n        } else if (theirChanged && !ourChanged) {\n          setValueAtPath(merged, p