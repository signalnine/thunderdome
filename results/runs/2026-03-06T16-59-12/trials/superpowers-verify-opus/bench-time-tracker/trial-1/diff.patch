@@ -0,0 +1,93 @@
+import { loadData, saveData } from "./storage.js";
+import type {
+  DateRangeFilter,
+  TimeEntry,
+  TimeSummary,
+  TrackerData,
+} from "./types.js";
+
+export class TimeTracker {
+  private data: TrackerData;
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.data = loadData(filePath);
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+    this.data.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  getEntries(filter?: DateRangeFilter): TimeEntry[] {
+    if (!filter) {
+      return [...this.data.entries];
+    }
+
+    return this.data.entries.filter((entry) => {
+      const entryStart = new Date(entry.start);
+      if (filter.from && entryStart < filter.from) {
+        return false;
+      }
+      if (filter.to && entryStart > filter.to) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  getSummary(filter?: DateRangeFilter): TimeSummary {
+    const entries = this.getEntries(filter);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  getRunningEntry(): TimeEntry | null {
+    return this.data.entries.find((e) => e.stop === null) ?? null;
+  }
+
+  private save(): void {
+    saveData(this.filePath, this.data);
+  }
+}
