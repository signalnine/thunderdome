d persist it\", () => {\n      const tracker = new TimeTracker(filePath);\n      const entry = tracker.start(\"coding\");\n\n      expect(entry.task).toBe(\"coding\");\n      expect(entry.start).toBeTruthy();\n      expect(entry.stop).toBeNull();\n\n      // Verify persistence\n      const raw = JSON.parse(fs.readFileSync(filePath, \"utf-8\"));\n      expect(raw.entries).toHaveLength(1);\n      expect(raw.entries[0].task).toBe(\"coding\");\n    });\n\n    it(\"should throw on empty task name\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.start(\"\")).toThrow(\"Task name cannot be empty\");\n      expect(() => tracker.start(\"   \")).toThrow(\"Task name cannot be empty\");\n    });\n\n    it(\"should auto-stop previous timer when starting a new one\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      const entry2 = tracker.start(\"task2\");\n\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].stop).not.toBeNull();\n      expect(entries[1].task).toBe(\"task2\");\n      expect(entry2.stop).toBeNull();\n    });\n  });\n\n  describe(\"stop\", () => {\n    it(\"should stop a running timer\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      const stopped = tracker.stop();\n\n      expect(stopped.task).toBe(\"coding\");\n      expect(stopped.stop).not.toBeNull();\n    });\n\n    it(\"should throw when no timer is running\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n  });\n\n  describe(\"getEntries\", () => {\n    it(\"should return all entries\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"a\");\n      tracker.stop();\n      tracker.start(\"b\");\n      tracker.stop();\n\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it(\"should filter by date range\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"old\");\n      tracker.stop();\n\n      const from = new Date();\n      tracker.start(\"new\");\n      tracker.stop();\n\n      const filtered = tracker.getEntries({ from });\n      expect(filtered).toHaveLength(1);\n      expect(filtered[0].task).toBe(\"new\");\n    });\n\n    it(\"should filter by to date\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"first\");\n      tracker.stop();\n      const to = new Date();\n\n      // Small delay to ensure separation\n      tracker.start(\"second\");\n      tracker.stop();\n\n      const filtered = tracker.getEntries({ to });\n      // Both may be included if they happen at the same millisecond,\n      // but at minimum the first entry should be there\n      expect(filtered.length).toBeGreaterThanOrEqual(1);\n      expect(filtered[0].task).toBe(\"first\");\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should sum durations per task\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n    });\n\n    it(\"should include running tasks using current time\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"running\");\n      const summary = tracker.getSummary();\n      expect(summary[\"running\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should reload data from file\", () => {\n      const tracker1 = new TimeTracker(filePath);\n      tracker1.start(\"persist-test\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"persist-test\");\n    });\n\n    it(\"should create parent directories if they don't exist\", () => {\n      const nested = path.join(\n        os.tmpdir(),\n        \"tracker-deep-\" + Date.now(),\n        \"a\",\n        \"b\",\n        \"data.json\"\n      );\n      const tracker = new TimeTracker(nested);\n      tracker.start(\"deep\");\n      tracker.stop();\n\n      expect(fs.existsSync(nested)).toBe(true);\n\n      // Cleanup\n      fs.rmSync(path.dirname(path.dirname(path.dirname(nested))), {\n        recursive: true,\n      });\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle unicode task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"café ☕\");\n      tracker.stop();\n      tracker.start(\"日本語タスク\");\n      tracker.stop();\n      tracker.start(\"🚀 rocket launch\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(3);\n      expect(entries[0].task).toBe(\"café ☕\");\n      expect(entries[1].task).toBe(\"日本語タスク\");\n      expect(entries[2].task).toBe(\"🚀 rocket launch\");\n\n      const summary = tracker.getSummary();\n      expect(summary[\"café ☕\"]).toBeGreaterThanOrEqual(0);\n      expect(summary[\"日本語タスク\"]).toBeGreaterThanOrEqual(0);\n      expect(summary[\"🚀 rocket launch\"]).toBeGreaterThanOrEqual(0);\n    });\n\n    it(\"should persist unicode names correctly\", () => {\n      const tracker1 = new TimeTracker(filePath);\n      tracker1.start(\"émojis 🎉🎊\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"émojis 🎉🎊\");\n    });\n  });\n\n  describe(\"getRunningEntry\", () => {\n    it(\"should return null when no timer is running\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(tracker.getRunningEntry()).toBeNull();\n    });\n\n    it(\"should return the running entry\