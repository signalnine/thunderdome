--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,595 @@
+import { randomUUID } from "node:crypto";
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchState {
+  docs: Map<string, DocEntry>;
+  /** The snapshot id of the branch point, used to find common ancestor */
+  parentBranch: string | null;
+  /** Snapshot of docs at the time this branch was created */
+  snapshot: Map<string, object | null> | null;
+}
+
+function deepClone<T>(obj: T): T {
+  if (obj === null || obj === undefined || typeof obj !== "object") {
+    return obj;
+  }
+  return JSON.parse(JSON.stringify(obj)) as T;
+}
+
+function getNestedValue(obj: Record<string, unknown>, path: string): unknown {
+  const parts = path.split(".");
+  let current: unknown = obj;
+  for (const part of parts) {
+    if (current === null || current === undefined || typeof current !== "object") {
+      return undefined;
+    }
+    current = (current as Record<string, unknown>)[part];
+  }
+  return current;
+}
+
+function setNestedValue(obj: Record<string, unknown>, path: string, value: unknown): void {
+  const parts = path.split(".");
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (current[part] === undefined || current[part] === null || typeof current[part] !== "object") {
+      current[part] = {};
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+function deleteNestedValue(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split(".");
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (current[part] === undefined || current[part] === null || typeof current[part] !== "object") {
+      return;
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  delete current[parts[parts.length - 1]];
+}
+
+/**
+ * Collect all leaf paths from an object (dot-separated).
+ * For non-object values, returns the path to that value.
+ * For nested objects, recurses deeper.
+ * Arrays are treated as leaf values (not recursed into).
+ */
+function collectPaths(obj: unknown, prefix: string = ""): string[] {
+  if (obj === null || obj === undefined || typeof obj !== "object" || Array.isArray(obj)) {
+    return prefix === "" ? [] : [prefix];
+  }
+  const record = obj as Record<string, unknown>;
+  const keys = Object.keys(record);
+  if (keys.length === 0 && prefix !== "") {
+    return [prefix];
+  }
+  const paths: string[] = [];
+  for (const key of keys) {
+    const newPrefix = prefix === "" ? key : `${prefix}.${key}`;
+    paths.push(...collectPaths(record[key], newPrefix));
+  }
+  return paths;
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null || a === undefined || b === undefined) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== "object") return a === b;
+  return JSON.stringify(a) === JSON.stringify(b);
+}
+
+/**
+ * Three-way merge of two objects against a common base.
+ * Returns the merged result and any conflicts.
+ */
+function threeWayMerge(
+  base: object | null,
+  ours: object | null,
+  theirs: object | null,
+  documentId: string
+): { merged: object; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+
+  // If both deleted or identical, trivial
+  if (ours === null && theirs === null) {
+    return { merged: {}, conflicts: [] };
+  }
+
+  const baseObj = (base ?? {}) as Record<string, unknown>;
+  const oursObj = (ours ?? {}) as Record<string, unknown>;
+  const theirsObj = (theirs ?? {}) as Record<string, unknown>;
+
+  // Collect all unique paths from all three
+  const allPaths = new Set<string>();
+  for (const p of collectPaths(baseObj)) allPaths.add(p);
+  for (const p of collectPaths(oursObj)) allPaths.add(p);
+  for (const p of collectPaths(theirsObj)) allPaths.add(p);
+
+  const merged = deepClone(oursObj) as Record<string, unknown>;
+
+  for (const path of allPaths) {
+    const baseVal = getNestedValue(baseObj, path);
+    const oursVal = getNestedValue(oursObj, path);
+    const theirsVal = getNestedValue(theirsObj, path);
+
+    const oursChanged = !deepEqual(baseVal, oursVal);
+    const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      // No changes, keep as-is
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      // Only ours changed, already in merged
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      // Only theirs changed, apply theirs
+      if (theirsVal === undefined) {
+        deleteNestedValue(merged, path);
+      } else {
+        setNestedValue(merged, path, deepClone(theirsVal));
+      }
+      continue;
+    }
+
+    // Both changed
+    if (deepEqual(oursVal, theirsVal)) {
+      // Both changed to the same value, no conflict
+      continue;
+    }
+
+    // Conflict: both changed to different values
+    // merged keeps "ours" (already there)
+    conflicts.push({
+      documentId,
+      path,
+      base: deepClone(baseVal),
+      ours: deepClone(oursVal),
+      theirs: deepClone(theirsVal),
+    });
+  }
+
+  return { merged, conflicts };
+}
+
+function cloneDocEntry(entry: DocEntry): DocEntry {
+  return {
+    content: deepClone(entry.content),
+    versions: entry.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+function cloneBranchDocs(docs: Map<string, DocEntry>): Map<string, DocEntry> {
+  const cloned = new Map<string, DocEntry>();
+  for (const [id, entry] of docs) {
+    cloned.set(id, cloneDocEntry(entry));
+  }
+  return cloned;
+}
+
+function snapshotDocs(docs: Map<string, DocEntry>): Map<string, object | null> {
+  const snap = new Map<string, object | null>();
+  for (const [id, entry] of docs) {
+    snap.set(id, entry.deleted ? null : deepClone(entry.content));
+  }
+  return snap;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = "main";
+
+  constructor() {
+    this.branches.set("main", {
+      docs: new Map(),
+      parentBranch: null,
+      snapshot: null,
+    });
+  }
+
+  private getBranchState(name?: string): BranchState {
+    const branchName = name ?? this.currentBranch;
+    const branch = this.branches.get(branchName);
+    if (!branch) {
+      throw new Error(`Branch "${branchName}" does not exist`);
+    }
+    return branch;
+  }
+
+  // --- Document CRUD ---
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchState();
+    const existing = branch.docs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: randomUUID(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    const entry: DocEntry = {
+      content: deepClone(content),
+      versions: existing?.deleted ? [...existing.versions, version] : [version],
+      deleted: false,
+    };
+
+    branch.docs.set(id, entry);
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchState();
+    const entry = branch.docs.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchState();
+    const entry = branch.docs.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    const version: Version = {
+      id: randomUUID(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchState();
+    const entry = branch.docs.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    entry.deleted = true;
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchState();
+    const entry = branch.docs.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return entry.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchState();
+    const entry = branch.docs.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = entry.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.getBranchState(sourceName);
+
+    const newBranch: BranchState = {
+      docs: cloneBranchDocs(source.docs),
+      parentBranch: sourceName,
+      snapshot: snapshotDocs(source.docs),
+    };
+    this.branches.set(name, newBranch);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  merge(sourceBranch: string): MergeResult {
+    const targetState = this.getBranchState();
+    const sourceState = this.getBranchState(sourceBranch);
+
+    // Find common ancestor: the snapshot stored when the source branch was created
+    // We need to find the divergence point between these two branches
+    const baseSnapshot = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    // Collect all document IDs across base, source, and target
+    const allDocIds = new Set<string>();
+    if (baseSnapshot) {
+      for (const id of baseSnapshot.keys()) allDocIds.add(id);
+    }
+    for (const id of sourceState.docs.keys()) allDocIds.add(id);
+    for (const id of targetState.docs.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseContent = baseSnapshot ? (baseSnapshot.get(docId) ?? null) : null;
+      const sourceEntry = sourceState.docs.get(docId);
+      const targetEntry = targetState.docs.get(docId);
+
+      const sourceContent = sourceEntry && !sourceEntry.deleted ? deepClone(sourceEntry.content) : null;
+      const targetContent = targetEntry && !targetEntry.deleted ? deepClone(targetEntry.content) : null;
+
+      // Check if anything changed
+      const sourceChanged = !deepEqual(baseContent, sourceContent);
+      const targetChanged = !deepEqual(baseContent, targetContent);
+
+      if (!sourceChanged && !targetChanged) {
+        // No changes on either side for this doc
+        if (targetContent !== null) {
+          merged[docId] = targetContent;
+        }
+        continue;
+      }
+
+      if (sourceChanged && !targetChanged) {
+        // Only source changed
+        if (sourceContent !== null) {
+          merged[docId] = sourceContent;
+        }
+        // If source deleted, don't include in merged
+        continue;
+      }
+
+      if (!sourceChanged && targetChanged) {
+        // Only target changed
+        if (targetContent !== null) {
+          merged[docId] = targetContent;
+        }
+        continue;
+      }
+
+      // Both changed - need three-way merge
+      // Handle deletion cases
+      if (sourceContent === null && targetContent === null) {
+        // Both deleted - no conflict
+        continue;
+      }
+
+      if (sourceContent === null || targetContent === null) {
+        // One side deleted, other modified - conflict at document level
+        // For merged result, use "ours" (target) approach
+        if (targetContent !== null) {
+          merged[docId] = targetContent;
+        }
+        // This is a conflict: one side deleted, other modified
+        allConflicts.push({
+          documentId: docId,
+          path: "",
+          base: deepClone(baseContent),
+          ours: targetContent !== null ? deepClone(targetContent) : undefined,
+          theirs: sourceContent !== null ? deepClone(sourceContent) : undefined,
+        });
+        continue;
+      }
+
+      // Both modified - do structural merge
+      const { merged: mergedDoc, conflicts } = threeWayMerge(
+        baseContent,
+        targetContent,
+        sourceContent,
+        docId
+      );
+      merged[docId] = mergedDoc;
+      allConflicts.push(...conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply merged result to current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const targetEntry = targetState.docs.get(docId);
+          const baseContent = baseSnapshot ? (baseSnapshot.get(docId) ?? null) : null;
+          const sourceEntry = sourceState.docs.get(docId);
+          const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;
+
+          const sourceChanged = !deepEqual(baseContent, sourceContent);
+
+          if (sourceChanged) {
+            if (targetEntry && !targetEntry.deleted) {
+              // Document exists on target, update it
+              if (!deepEqual(targetEntry.content, merged[docId])) {
+                const version: Version = {
+                  id: randomUUID(),
+                  timestamp: Date.now(),
+                  content: deepClone(merged[docId]),
+                };
+                targetEntry.content = deepClone(merged[docId]);
+                targetEntry.versions.push(version);
+              }
+            } else if (targetEntry && targetEntry.deleted) {
+              // Was deleted on target but source modified - restore
+              const version: Version = {
+                id: randomUUID(),
+                timestamp: Date.now(),
+                content: deepClone(merged[docId]),
+              };
+              targetEntry.content = deepClone(merged[docId]);
+              targetEntry.deleted = false;
+              targetEntry.versions.push(version);
+            } else {
+              // New document from source
+              const version: Version = {
+                id: randomUUID(),
+                timestamp: Date.now(),
+                content: deepClone(merged[docId]),
+              };
+              targetState.docs.set(docId, {
+                content: deepClone(merged[docId]),
+                versions: [version],
+                deleted: false,
+              });
+            }
+          }
+        } else {
+          // Not in merged = was deleted
+          const targetEntry = targetState.docs.get(docId);
+          const baseContent = baseSnapshot ? (baseSnapshot.get(docId) ?? null) : null;
+          const sourceEntry = sourceState.docs.get(docId);
+          const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;
+          const sourceChanged = !deepEqual(baseContent, sourceContent);
+
+          if (sourceChanged && targetEntry && !targetEntry.deleted) {
+            // Source deleted and target hasn't changed - delete on target
+            targetEntry.deleted = true;
+          }
+        }
+      }
+    }
+
+    return {
+      merged,
+      conflicts: allConflicts,
+      applied,
+    };
+  }
+
+  private findCommonAncestor(
+    branchA: string,
+    branchB: string
+  ): Map<string, object | null> | null {
+    // Walk up the branch lineage to find a common ancestor snapshot
+    // The snapshot is taken when a branch is created from another
+
+    const stateA = this.branches.get(branchA)!;
+    const stateB = this.branches.get(branchB)!;
+
+    // Case 1: branchA was created from branchB
+    if (stateA.parentBranch === branchB && stateA.snapshot) {
+      return stateA.snapshot;
+    }
+
+    // Case 2: branchB was created from branchA
+    if (stateB.parentBranch === branchA && stateB.snapshot) {
+      return stateB.snapshot;
+    }
+
+    // Case 3: Both branches were created from a common parent
+    // Walk up lineage for both to find common ancestor
+    const ancestorsA = this.getBranchLineage(branchA);
+    const ancestorsB = this.getBranchLineage(branchB);
+
+    // Find common parent in lineage
+    for (const anc of ancestorsA) {
+      if (ancestorsB.includes(anc)) {
+        // Both derive from this branch - use the later snapshot
+        // (the snapshot from the branch that was created second is more recent)
+        const snapA = this.getSnapshotForAncestor(branchA, anc);
+        const snapB = this.getSnapshotForAncestor(branchB, anc);
+        // Use the earlier snapshot (the one closer to the common ancestor)
+        if (snapA && snapB) {
+          // Return the snapshot of the branch that was created from the common parent
+          // For a proper common ancestor, we need the state at divergence
+          return snapA;
+        }
+        return snapA ?? snapB ?? null;
+      }
+    }
+
+    // No common ancestor - empty base
+    return new Map();
+  }
+
+  private getBranchLineage(branchName: string): string[] {
+    const lineage: string[] = [];
+    let current: string | null = branchName;
+    while (current !== null) {
+      lineage.push(current);
+      const state = this.branches.get(current);
+      current = state?.parentBranch ?? null;
+    }
+    return lineage;
+  }
+
+  private getSnapshotForAncestor(
+    branchName: string,
+    ancestor: string
+  ): Map<string, object | null> | null {
+    let current = branchName;
+    while (current !== ancestor) {
+      const state = this.branches.get(current);
+      if (!state) return null;
+      if (state.parentBranch === ancestor) {
+        return state.snapshot;
+      }
+      current = state.parentBranch!;
+    }
+    return null;
+  }
+}
