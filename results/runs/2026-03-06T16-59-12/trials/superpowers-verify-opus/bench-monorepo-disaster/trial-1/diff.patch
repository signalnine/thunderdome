+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kqsif6oDu6F2rLSQ8Ca45R","type":"tool_result","content":"     1→/**\n     2→ * User CRUD routes.\n     3→ */\n     4→\n     5→import { Router, type Request, type Response } from 'express';\n     6→import {\n     7→  createUser,\n     8→  getUserById,\n     9→  getAllUsers,\n    10→  validateCreateUser,\n    11→  validateUserId,\n    12→  canManageUsers,\n    13→  type Role,\n    14→} from '@monorepo/core';\n    15→\n    16→export const usersRouter = Router();\n    17→\n    18→// List all users\n    19→usersRouter.get('/', (_req: Request, res: Response) => {\n    20→  try {\n    21→    const users = getAllUsers();\n    22→    res.json({ users });\n    23→  } catch (err) {\n    24→    res.status(500).json({ error: 'Failed to fetch users' });\n    25→  }\n    26→});\n    27→\n    28→// Get user by ID\n    29→usersRouter.get('/:id', (req: Request, res: Response) => {\n    30→  try {\n    31→    const validation = validateUserId(req.params['id']!);\n    32→    if (!validation.success) {\n    33→      res.status(400).json({ errors: validation.errors });\n    34→      return;\n    35→    }\n    36→\n    37→    const user = getUserById(validation.data!);\n    38→    if (!user) {\n    39→      res.status(404).json({ error: 'User not found' });\n    40→      return;\n    41→    }\n    42→    res.json({ user });\n    43→  } catch (err) {\n    44→    res.status(500).json({ error: 'Failed to fetch user' });\n    45→  }\n    46→});\n    47→\n    48→// Create a new user\n    49→usersRouter.post('/', (req: Request, res: Response) => {\n    50→  try {\n    51→    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    52→    if (!canManageUsers(callerRole)) {\n    53→      res.status(403).json({ error: 'Insufficient permissions' });\n    54→      return;\n    55→    }\n    56→\n    57→    const validation = validateCreateUser(req.body);\n    58→    if (!validation.success) {\n    59→      res.status(400).json({ errors: validation.errors });\n    60→      return;\n    61→    }\n    62→\n    63→    const user = createUser(req.body);\n    64→    res.status(201).json({ user });\n    65→  } catch (err) {\n    66→    if (err instanceof Error && err.message.includes('UNIQUE')) {\n    67→      res.status(409).json({ error: 'Email already exists' });\n    68→      return;\n    69→    }\n    70→    res.status(500).json({ error: 'Failed to create user' });\n    71→  }\n    72→});\n    73→\n    74→// Delete user by ID\n    75→usersRouter.delete('/:id', (req: Request, res: Response) => {\n    76→  try {\n    77→    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    78→    if (!canManageUsers(callerRole)) {\n    79→      res.status(403).json({ error: 'Insufficient permissions' });\n    80→      return;\n    81→    }\n    82→\n    83→    const validation = validateUserId(req.params['id']!);\n    84→    if (!validation.success) {\n    85→      res.status(400).json({ errors: validation.errors });\n    86→      return;\n    87→    }\n    88→\n    89→    const user = getUserById(validation.data!);\n    90→    if (!user) {\n    91→      res.status(404).json({ error: 'User not found' });\n    92→      return;\n    93→    }\n    94→\n    95→    // In a real app, we'd delete here\n    96→    res.status(200).json({ message: 'User deleted', user });\n    97→  } catch (err) {\n    98→    res.status(500).json({ error: 'Failed to delete user' });\n    99→  }\n   100→});\n   101→"}]},"parent_tool_use_id":null,"session_id":"6f1d17cd-cf74-4ca0-abb2-4b27a4c5ddd1","uuid":"2b624762-c709-4e59-9176-dbe6a44d5471","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/api/src/routes/users.ts","content":"/**\n * User CRUD routes.\n */\n\nimport { Router, type Request, type Response } from 'express';\nimport {\n  createUser,\n  getUserById,\n  getAllUsers,\n  validateCreateUser,\n  validateUserId,\n  canManageUsers,\n  type Role,\n} from '@monorepo/core';\n\nexport const usersRouter = Router();\n\n// List all users\nusersRouter.get('/', (_req: Request, res: Response) => {\n  try {\n    const users = getAllUsers();\n    res.json({ users });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to fetch users' });\n  }\n});\n\n// Get user by ID\nusersRouter.get('/:id', (req: Request, res: Response) => {\n  try {\n    const validation = validateUserId(req.params['id']!);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = getUserById(validation.data!);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json({ user });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to fetch user' });\n  }\n});\n\n// Create a new user\nusersRouter.post('/', (req: Request, res: Response) => {\n  try {\n    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    if (!canManageUsers(callerRole)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const validation = validateCreateUser(req.body);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = createUser(req.body);\n    res.status(201).json({ user });\n  } catch (err) {\n    if (err instanceof Error && err.message.includes('UNIQUE')) {\n      res.status(409).json({ error: 'Email already exists' });\n      return;\n    }\n    res.status(500).json({ error: 'Failed to create user' });\n  }\n});\n\n// Delete user by ID\nusersRouter.delete('/:id', (req: Request, res: Response) => {\n  try {\n    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    if (!canManageUsers(callerRole)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const validation = validateUserId(req.params['id']!);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = getUserById(validation.data!);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    // In a real app, we'd delete here\n    res.status(200).json({ message: 'User deleted', user });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to delete user' });\n  }\n});\n","numLines":101,"startLine":1,"totalLines":101}}}
