index 0000000..59dfeed
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,228 @@
+import { WebSocket } from "ws";
+import { DocumentDatabase } from "./database.js";
+import {
+  Operation,
+  apply,
+  transform,
+  validate,
+} from "./ot.js";
+
+export interface ConnectedClient {
+  ws: WebSocket;
+  clientId: string;
+  docId: string;
+}
+
+export interface DocumentSession {
+  docId: string;
+  clients: Map<string, ConnectedClient>;
+  /** Server version — incremented with each accepted operation */
+  version: number;
+  /** Current document content */
+  content: string;
+  /** History of operations, indexed by the version they produced (1-based) */
+  history: Operation[];
+}
+
+export type OutgoingMessage =
+  | { type: "sync"; content: string; version: number; clientId: string }
+  | { type: "ack"; version: number }
+  | { type: "operation"; operation: Operation; version: number; clientId: string }
+  | { type: "error"; message: string };
+
+export class CollaborationManager {
+  private sessions: Map<string, DocumentSession> = new Map();
+  private db: DocumentDatabase;
+
+  constructor(db: DocumentDatabase) {
+    this.db = db;
+  }
+
+  /**
+   * Join a document session. Returns the sync message to send to the client.
+   */
+  joinDocument(
+    docId: string,
+    clientId: string,
+    ws: WebSocket
+  ): OutgoingMessage | null {
+    const doc = this.db.getDocument(docId);
+    if (!doc) return null;
+
+    let session = this.sessions.get(docId);
+    if (!session) {
+      // Load document state from DB
+      const latestVersion = this.db.getLatestVersion(docId);
+      session = {
+        docId,
+        clients: new Map(),
+        version: latestVersion,
+        content: doc.content,
+        history: [],
+      };
+
+      // Load operation history from DB
+      const versions = this.db.getVersions(docId);
+      for (const v of versions) {
+        if (v.operation) {
+          try {
+            const parsed = JSON.parse(v.operation);
+            if (parsed.type !== "init" && parsed.operation) {
+              session.history[v.version] = parsed.operation;
+            }
+          } catch {
+            // skip invalid entries
+          }
+        }
+      }
+
+      this.sessions.set(docId, session);
+    }
+
+    session.clients.set(clientId, { ws, clientId, docId });
+
+    return {
+      type: "sync",
+      content: session.content,
+      version: session.version,
+      clientId,
+    };
+  }
+
+  /**
+   * Remove a client from a document session.
+   */
+  leaveDocument(docId: string, clientId: string): void {
+    const session = this.sessions.get(docId);
+    if (!session) return;
+    session.clients.delete(clientId);
+
+    if (session.clients.size === 0) {
+      // Persist final state to DB before removing session
+      this.db.updateDocumentContent(session.docId, session.content);
+      this.sessions.delete(docId);
+    }
+  }
+
+  /**
+   * Receive and process an operation from a client.
+   */
+  receiveOperation(
+    docId: string,
+    clientId: string,
+    clientVersion: number,
+    operation: Operation
+  ): OutgoingMessage | null {
+    const session = this.sessions.get(docId);
+    if (!session) {
+      return { type: "error", message: "No active session for this document" };
+    }
+
+    // Validate the operation against the document at clientVersion
+    // First, transform against all operations since clientVersion
+    let transformed = operation;
+
+    if (clientVersion < 0 || clientVersion > session.version) {
+      return {
+        type: "error",
+        message: `Invalid version: ${clientVersion}. Server is at version ${session.version}`,
+      };
+    }
+
+    // Transform against all operations that happened after the client's version
+    for (let v = clientVersion + 1; v <= session.version; v++) {
+      const serverOp = session.history[v];
+      if (serverOp) {
+        const [transformedOp] = transform(transformed, serverOp, true);
+        transformed = transformedOp;
+      }
+    }
+
+    // Validate the transformed operation
+    const error = validate(transformed, session.content.length);
+    if (error) {
+      return { type: "error", message: `Invalid operation: ${error}` };
+    }
+
+    // Apply the operation
+    try {
+      const newContent = apply(session.content, transformed);
+      session.version++;
+      session.content = newContent;
+      session.history[session.version] = transformed;
+
+      // Persist to DB
+      this.db.addVersion(docId, newContent, {
+        clientId,
+        operation: transformed,
+      });
+
+      // Send ack to the client that made the change
+      const client = session.clients.get(clientId);
+      if (client && client.ws.readyState === WebSocket.OPEN) {
+        const ackMsg: OutgoingMessage = {
+          type: "ack",
+          version: session.version,
+        };
+        client.ws.send(JSON.stringify(ackMsg));
+      }
+
+      // Broadcast to all other clients
+      for (const [id, c] of session.clients) {
+        if (id !== clientId && c.ws.readyState === WebSocket.OPEN) {
+          const opMsg: OutgoingMessage = {
+            type: "operation",
+            operation: transformed,
+            version: session.version,
+            clientId,
+          };
+          c.ws.send(JSON.stringify(opMsg));
+        }
+      }
+
+      return null; // success, messages already sent
+    } catch (e) {
+      const msg = e instanceof Error ? e.message : "Unknown error applying operation";
+      return { type: "error", message: msg };
+    }
+  }
+
+  /**
+   * Get the current content of a document from the active session (if any)
+   * or from the database.
+   */
+  getDocumentContent(docId: string): string | null {
+    const session = this.sessions.get(docId);
+    if (session) return session.content;
+    const doc = this.db.getDocument(docId);
+    return doc ? doc.content : null;
+  }
+
+  /**
+   * Flush all active sessions to database.
+   */
+  flushAll(): void {
+    for (const session of this.sessions.values()) {
+      this.db.updateDocumentContent(session.docId, session.content);
+    }
+  }
+
+  /**
+   * Close all client connections and flush.
+   */
+  closeAll(): void {
+    for (const session of this.sessions.values()) {
+      for (const client of session.clients.values()) {
+        if (client.ws.readyState === WebSocket.OPEN) {
+          client.ws.close(1001, "Server shutting down");
+        }
+      }
+      this.db.updateDocumentContent(session.docId, session.content);
+    }
+    this.sessions.clear();
+  }
+
+  getSession(docId: string): DocumentSession | undefined {
+    return this.sessions.get(docId);
+  }
+}
