@@ -0,0 +1,103 @@
+import { WebSocketServer, WebSocket } from "ws";
+import { IncomingMessage, Server as HttpServer } from "http";
+import { randomUUID } from "crypto";
+import { CollaborationManager, OutgoingMessage } from "./collaboration.js";
+import { Operation } from "./ot.js";
+
+interface IncomingOperationMessage {
+  type: "operation";
+  version: number;
+  operation: Operation;
+}
+
+function isValidMessage(data: unknown): data is IncomingOperationMessage {
+  if (typeof data !== "object" || data === null) return false;
+  const msg = data as Record<string, unknown>;
+  return (
+    msg.type === "operation" &&
+    typeof msg.version === "number" &&
+    Array.isArray(msg.operation)
+  );
+}
+
+export function setupWebSocket(
+  server: HttpServer,
+  collab: CollaborationManager
+): WebSocketServer {
+  const wss = new WebSocketServer({ server });
+
+  wss.on("connection", (ws: WebSocket, req: IncomingMessage) => {
+    const url = req.url;
+    if (!url) {
+      sendError(ws, "Missing URL");
+      ws.close(1008, "Missing URL");
+      return;
+    }
+
+    // Parse document ID from URL path: /ws/documents/:id
+    const match = url.match(/^\/ws\/documents\/([^/?]+)/);
+    if (!match) {
+      sendError(ws, "Invalid WebSocket path. Expected /ws/documents/:docId");
+      ws.close(1008, "Invalid path");
+      return;
+    }
+
+    const docId = match[1];
+    const clientId = randomUUID();
+
+    // Join the document session
+    const syncMsg = collab.joinDocument(docId, clientId, ws);
+    if (!syncMsg) {
+      sendError(ws, "Document not found");
+      ws.close(1008, "Document not found");
+      return;
+    }
+
+    // Send the sync message
+    ws.send(JSON.stringify(syncMsg));
+
+    ws.on("message", (data: Buffer | string) => {
+      let parsed: unknown;
+      try {
+        parsed = JSON.parse(typeof data === "string" ? data : data.toString());
+      } catch {
+        sendError(ws, "Invalid JSON");
+        return;
+      }
+
+      if (!isValidMessage(parsed)) {
+        sendError(ws, "Invalid message format. Expected { type: 'operation', version: number, operation: [] }");
+        return;
+      }
+
+      const result = collab.receiveOperation(
+        docId,
+        clientId,
+        parsed.version,
+        parsed.operation
+      );
+
+      // If receiveOperation returns a message, it's an error
+      if (result) {
+        ws.send(JSON.stringify(result));
+      }
+    });
+
+    ws.on("close", () => {
+      collab.leaveDocument(docId, clientId);
+    });
+
+    ws.on("error", () => {
+      collab.leaveDocument(docId, clientId);
+    });
+  });
+
+  return wss;
+}
+
+function sendError(ws: WebSocket, message: string): void {
+  const msg: OutgoingMessage = { type: "error", message };
+  if (ws.readyState === WebSocket.OPEN) {
+    ws.send(JSON.stringify(msg));
+  }
+}
