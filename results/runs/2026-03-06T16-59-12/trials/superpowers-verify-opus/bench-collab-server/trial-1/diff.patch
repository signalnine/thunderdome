+++ b/src/ot.ts
@@ -0,0 +1,358 @@
+/**
+ * Operational Transformation (OT) engine for collaborative text editing.
+ *
+ * Operations are represented as arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string
+ * - number < 0: delete |N| characters
+ *
+ * The input length of an operation must match the document length it's applied to.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface ClientOperation {
+  type: "operation";
+  docId: string;
+  version: number;
+  operation: Operation;
+  clientId: string;
+}
+
+/** Get the input length an operation expects */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === "number") {
+      if (c > 0) len += c;       // retain
+      else len += Math.abs(c);    // delete
+    }
+    // inserts don't consume input
+  }
+  return len;
+}
+
+/** Get the output length an operation produces */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === "number") {
+      if (c > 0) len += c;       // retain
+      // delete produces nothing
+    } else {
+      len += c.length;            // insert
+    }
+  }
+  return len;
+}
+
+/** Normalize an operation by merging adjacent same-type components */
+function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === "number" && c === 0) continue;
+    if (typeof c === "string" && c === "") continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+    if (typeof c === "string" && typeof last === "string") {
+      result[result.length - 1] = last + c;
+    } else if (typeof c === "number" && typeof last === "number") {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else {
+      result.push(c);
+    }
+  }
+  return result;
+}
+
+/** Apply an operation to a document string */
+export function apply(doc: string, op: Operation): string {
+  let pos = 0;
+  let result = "";
+
+  for (const c of op) {
+    if (typeof c === "number") {
+      if (c > 0) {
+        // retain
+        if (pos + c > doc.length) {
+          throw new Error(
+            `Retain past end of document: pos=${pos}, retain=${c}, docLen=${doc.length}`
+          );
+        }
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        const delCount = Math.abs(c);
+        if (pos + delCount > doc.length) {
+          throw new Error(
+            `Delete past end of document: pos=${pos}, delete=${delCount}, docLen=${doc.length}`
+          );
+        }
+        pos += delCount;
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+
+  if (pos !== doc.length) {
+    throw new Error(
+      `Operation did not consume entire document: consumed=${pos}, docLen=${doc.length}`
+    );
+  }
+
+  return result;
+}
+
+/**
+ * Iterator for walking through operation components character by character.
+ */
+class OpIterator {
+  private ops: Operation;
+  private index: number;
+  private offset: number;
+
+  constructor(ops: Operation) {
+    this.ops = ops;
+    this.index = 0;
+    this.offset = 0;
+  }
+
+  hasNext(): boolean {
+    return this.index < this.ops.length;
+  }
+
+  /** Peek at the type of the current component */
+  peekType(): "retain" | "insert" | "delete" | "none" {
+    if (!this.hasNext()) return "none";
+    const c = this.ops[this.index];
+    if (typeof c === "string") return "insert";
+    if (c > 0) return "retain";
+    return "delete";
+  }
+
+  /** Take n units from the current component */
+  take(n: number): OpComponent {
+    if (!this.hasNext()) {
+      throw new Error("No more components to take from");
+    }
+
+    const c = this.ops[this.index];
+
+    if (typeof c === "string") {
+      // Insert: take n characters
+      if (n >= c.length - this.offset) {
+        const result = c.slice(this.offset);
+        this.index++;
+        this.offset = 0;
+        return result;
+      }
+      const result = c.slice(this.offset, this.offset + n);
+      this.offset += n;
+      return result;
+    }
+
+    // Number component (retain or delete)
+    const remaining = Math.abs(c) - this.offset;
+    const sign = c > 0 ? 1 : -1;
+
+    if (n >= remaining) {
+      this.index++;
+      this.offset = 0;
+      return sign * remaining;
+    }
+    this.offset += n;
+    return sign * n;
+  }
+
+  /** Take all remaining from the current component */
+  takeAll(): OpComponent {
+    if (!this.hasNext()) {
+      throw new Error("No more components");
+    }
+    const c = this.ops[this.index];
+    if (typeof c === "string") {
+      const result = c.slice(this.offset);
+      this.index++;
+      this.offset = 0;
+      return result;
+    }
+    const remaining = Math.abs(c) - this.offset;
+    const sign = c > 0 ? 1 : -1;
+    this.index++;
+    this.offset = 0;
+    return sign * remaining;
+  }
+
+  peekLength(): number {
+    if (!this.hasNext()) return Infinity;
+    const c = this.ops[this.index];
+    if (typeof c === "string") return c.length - this.offset;
+    return Math.abs(c) - this.offset;
+  }
+}
+
+/**
+ * Transform two concurrent operations so they can both be applied.
+ * Given operations A and B that were both created against the same document,
+ * returns [A', B'] such that apply(apply(doc, A), B') === apply(apply(doc, B), A').
+ *
+ * `leftPriority` means A's inserts go first when both insert at the same position.
+ */
+export function transform(
+  opA: Operation,
+  opB: Operation,
+  leftPriority: boolean = true
+): [Operation, Operation] {
+  const iterA = new OpIterator(opA);
+  const iterB = new OpIterator(opB);
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  while (iterA.hasNext() || iterB.hasNext()) {
+    const typeA = iterA.peekType();
+    const typeB = iterB.peekType();
+
+    // If A inserts, include it in A' and retain it in B'
+    if (typeA === "insert" && (leftPriority || typeB !== "insert")) {
+      const ins = iterA.takeAll() as string;
+      aPrime.push(ins);
+      bPrime.push(ins.length);
+      continue;
+    }
+
+    // If B inserts, include it in B' and retain it in A'
+    if (typeB === "insert") {
+      const ins = iterB.takeAll() as string;
+      bPrime.push(ins);
+      aPrime.push(ins.length);
+      continue;
+    }
+
+    if (typeA === "none" && typeB === "none") break;
+
+    if (typeA === "none" || typeB === "none") {
+      throw new Error("Operations have different base lengths");
+    }
+
+    const lenA = iterA.peekLength();
+    const lenB = iterB.peekLength();
+    const minLen = Math.min(lenA, lenB);
+
+    if (typeA === "retain" && typeB === "retain") {
+      // Both retain: both primes retain
+      iterA.take(minLen);
+      iterB.take(minLen);
+      aPrime.push(minLen);
+      bPrime.push(minLen);
+    } else if (typeA === "delete" && typeB === "delete") {
+      // Both delete the same content: neither outputs anything
+      iterA.take(minLen);
+      iterB.take(minLen);
+    } else if (typeA === "delete" && typeB === "retain") {
+      // A deletes, B retains: A' deletes, B' skips
+      iterA.take(minLen);
+      iterB.take(minLen);
+      aPrime.push(-minLen);
+    } else if (typeA === "retain" && typeB === "delete") {
+      // B deletes, A retains: B' deletes, A' skips
+      iterA.take(minLen);
+      iterB.take(minLen);
+      bPrime.push(-minLen);
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/**
+ * Compose two sequential operations into one.
+ * compose(A, B) produces an operation C such that apply(doc, C) === apply(apply(doc, A), B).
+ */
+export function compose(opA: Operation, opB: Operation): Operation {
+  const iterA = new OpIterator(opA);
+  const iterB = new OpIterator(opB);
+  const result: Operation = [];
+
+  while (iterA.hasNext() || iterB.hasNext()) {
+    const typeA = iterA.peekType();
+    const typeB = iterB.peekType();
+
+    // A deletes consume from A without advancing B
+    if (typeA === "delete") {
+      result.push(iterA.takeAll());
+      continue;
+    }
+
+    // B inserts produce without consuming from A
+    if (typeB === "insert") {
+      result.push(iterB.takeAll());
+      continue;
+    }
+
+    if (typeA === "none" && typeB === "none") break;
+
+    if (typeA === "none" || typeB === "none") {
+      throw new Error("Compose: mismatched operation lengths");
+    }
+
+    const lenA = iterA.peekLength();
+    const lenB = iterB.peekLength();
+    const minLen = Math.min(lenA, lenB);
+
+    if (typeA === "retain" && typeB === "retain") {
+      iterA.take(minLen);
+      iterB.take(minLen);
+      result.push(minLen);
+    } else if (typeA === "retain" && typeB === "delete") {
+      iterA.take(minLen);
+      iterB.take(minLen);
+      result.push(-minLen);
+    } else if (typeA === "insert" && typeB === "retain") {
+      const taken = iterA.take(minLen) as string;
+      iterB.take(taken.length);
+      result.push(taken);
+    } else if (typeA === "insert" && typeB === "delete") {
+      // Insert then delete cancels out
+      const taken = iterA.take(minLen) as string;
+      iterB.take(taken.length);
+    }
+  }
+
+  return normalize(result);
+}
+
+/** Validate an operation against a document length */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) return "Operation must be an array";
+
+  for (const c of op) {
+    if (typeof c === "number") {
+      if (!Number.isInteger(c)) return "Numeric components must be integers";
+      if (c === 0) return "Zero-length components are not allowed";
+    } else if (typeof c === "string") {
+      if (c === "") return "Empty string inserts are not allowed";
+    } else {
+      return "Components must be numbers or strings";
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
