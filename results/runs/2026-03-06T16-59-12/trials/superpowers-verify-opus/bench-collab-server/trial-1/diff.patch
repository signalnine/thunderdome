    wss!.close(() => resolve());\n        });\n      }\n\n      // Close HTTP server\n      await new Promise<void>((resolve, reject) => {\n        httpServer.close((err) => {\n          if (err) reject(err);\n          else resolve();\n        });\n      });\n\n      // Close database\n      db.close();\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null}}
