@@ -0,0 +1,69 @@
+import express from "express";
+import { createServer, Server as HttpServer } from "http";
+import { WebSocketServer } from "ws";
+import { DocumentDatabase } from "./database.js";
+import { CollaborationManager } from "./collaboration.js";
+import { createRouter } from "./routes.js";
+import { setupWebSocket } from "./websocket.js";
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = new DocumentDatabase(dbPath ?? ":memory:");
+  const collab = new CollaborationManager(db);
+  const app = express();
+  const httpServer: HttpServer = createServer(app);
+
+  // Set up REST routes
+  app.use("/api", createRouter(db, collab));
+
+  // Set up WebSocket
+  let wss: WebSocketServer | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      wss = setupWebSocket(httpServer, collab);
+
+      return new Promise((resolve) => {
+        httpServer.listen(port ?? 0, () => {
+          const addr = httpServer.address();
+          const actualPort =
+            typeof addr === "object" && addr !== null ? addr.port : 0;
+          resolve(actualPort);
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      // Close all collaboration sessions
+      collab.closeAll();
+
+      // Close WebSocket server
+      if (wss) {
+        for (const client of wss.clients) {
+          client.terminate();
+        }
+        await new Promise<void>((resolve) => {
+          wss!.close(() => resolve());
+        });
+      }
+
+      // Close HTTP server
+      await new Promise<void>((resolve, reject) => {
+        httpServer.close((err) => {
+          if (err) reject(err);
+          else resolve();
+        });
+      });
+
+      // Close database
+      db.close();
+    },
+  };
+}
