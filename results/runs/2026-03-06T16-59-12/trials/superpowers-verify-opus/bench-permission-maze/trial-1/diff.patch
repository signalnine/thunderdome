n    await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ title: 'Updated' })\n      .expect(200);\n  });\n\n  it('should allow editor to share with others', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n    const { userId: charlieId } = await createUser('charlie', 'pass');\n    const folder = await createFolder(aliceToken, 'Folder');\n    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.id);\n\n    // Alice shares with Bob as editor\n    await request(app)\n      .post('/shares')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'document',\n        resourceId: doc.id,\n        userId: bobId,\n        role: 'editor',\n      });\n\n    // Bob shares with Charlie as viewer\n    const res = await request(app)\n      .post('/shares')\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({\n        resourceType: 'document',\n        resourceId: doc.id,\n        userId: charlieId,\n        role: 'viewer',\n      });\n\n    expect(res.status).toBe(201);\n  });\n\n  it('should not allow viewer to share', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n    const { userId: charlieId } = await createUser('charlie', 'pass');\n    const folder = await createFolder(aliceToken, 'Folder');\n    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.id);\n\n    // Alice shares with Bob as viewer\n    await request(app)\n      .post('/shares')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'document',\n        resourceId: doc.id,\n        userId: bobId,\n        role: 'viewer',\n      });\n\n    // Bob tries to share with Charlie - should fail\n    await