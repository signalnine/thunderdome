+export interface User {
+  id: string;
+  username: string;
+  password: string;
+  token?: string;
+}
+
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+export interface Share {
+  id: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
+
+export interface ActivityLogEntry {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  timestamp: string;
+  details?: string;
+}
