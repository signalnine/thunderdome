@@ -0,0 +1,112 @@
+import type { Store } from './store.js';
+import type { Role } from './types.js';
+
+const ROLE_LEVELS: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check if user is the owner of the resource
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.ownerId === userId) return 'owner';
+  } else {
+    const doc = store.documents.get(resourceId);
+    if (doc && doc.ownerId === userId) return 'owner';
+  }
+
+  // Check direct shares on this resource
+  for (const share of store.shares) {
+    if (
+      share.userId === userId &&
+      share.resourceType === resourceType &&
+      share.resourceId === resourceId
+    ) {
+      if (!bestRole || ROLE_LEVELS[share.role] > ROLE_LEVELS[bestRole]) {
+        bestRole = share.role;
+      }
+    }
+  }
+
+  // If this is a document, also check folder-level shares
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveFolderRole(store, userId, doc.folderId);
+      if (folderRole && (!bestRole || ROLE_LEVELS[folderRole] > ROLE_LEVELS[bestRole])) {
+        bestRole = folderRole;
+      }
+    }
+  }
+
+  // If this is a folder, check parent folder shares (inherited)
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);
+      if (parentRole && (!bestRole || ROLE_LEVELS[parentRole] > ROLE_LEVELS[bestRole])) {
+        bestRole = parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+function getEffectiveFolderRole(
+  store: Store,
+  userId: string,
+  folderId: string
+): Role | null {
+  const folder = store.folders.get(folderId);
+  if (!folder) return null;
+
+  // Check if user owns the folder
+  if (folder.ownerId === userId) return 'owner';
+
+  let bestRole: Role | null = null;
+
+  // Check direct shares on this folder
+  for (const share of store.shares) {
+    if (
+      share.userId === userId &&
+      share.resourceType === 'folder' &&
+      share.resourceId === folderId
+    ) {
+      if (!bestRole || ROLE_LEVELS[share.role] > ROLE_LEVELS[bestRole]) {
+        bestRole = share.role;
+      }
+    }
+  }
+
+  // Check parent folder shares (inherited)
+  if (folder.parentId) {
+    const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);
+    if (parentRole && (!bestRole || ROLE_LEVELS[parentRole] > ROLE_LEVELS[bestRole])) {
+      bestRole = parentRole;
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  requiredRole: Role
+): boolean {
+  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effectiveRole) return false;
+  return ROLE_LEVELS[effectiveRole] >= ROLE_LEVELS[requiredRole];
+}
