(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Get child folders\n    const children: typeof folder[] = [];\n    for (const f of store.folders.values()) {\n      if (f.parentId === id) {\n        children.push(f);\n      }\n    }\n\n    // Get documents in this folder\n    const documents: { id: string; title: string; createdAt: string; updatedAt: string }[] = [];\n    for (const doc of store.documents.values()) {\n      if (doc.folderId === id) {\n        documents.push({ id: doc.id, title: doc.title, createdAt: doc.createdAt, updatedAt: doc.updatedAt });\n      }\n    }\n\n    res.status(200).json({ ...folder, children, documents });\n  });\n\n  // Update folder\n  router.put('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n    const { id } = req.params;\n    const userId = req.userId!;\n    const { name } = req.body;\n\n    const folder = store.folders.get(id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', id, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    if (name) {\n      folder.name = name;\n    }\n\n    res.status(200).json(folder);\n  });\n\n  // Delete folder\n  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n    const { id } = req.params;\n    const userId = req.userId!;\n\n    const folder = store.folders.get(id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', id, 'owner')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Delete all documents in folder recursively\n    deleteFolderRecursive(store, id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n\nfunction deleteFolderRecursive(store: Store, folderId: string) {\n  // Delete child folders recursively\n  for (const folder of store.folders.values()) {\n    if (folder.parentId === folderId) {\n      deleteFolderRecursive(store, folder.id);\n    }\n  }\n\n  // Delete documents in this folder\n  for (const doc of store.documents.values()) {\n    if (doc.folderId === folderId) {\n      store.documents.delete(doc.id);\n      // Remove shares for document\n      for (let i = store.shares.length - 1; i >= 0; i--) {\n        if (store.shares[i].resourceType === 'document' && store.shares[i].resourceId === doc.id) {\n          store.shares.splice(i, 1);\n        }\n      }\n    }\n  }\n\n  // Remove shares for folder\n  for (let i = store.shares.length - 1; i >= 0; i--) {\n    if (store.shares[i].resourceType === 'folder' && store.shares[i].resourceId === folderId) {\n      store.shares.splice(i, 1);\n    }\n  }\n\n  store.folders.delete(folderId);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":380,"cache_read_input_tokens":22879,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":380},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"65bf1d80-4fe0-40e2-9562-91e5b4db1490","uuid":"a17a19e4-6b58-4b2b-adfa-53bea43686cb"}
