+import { Router, type Response } from 'express';
+import type { Store } from './store.js';
+import type { AuthRequest } from './auth.js';
+import { requireAuth } from './auth.js';
+import { hasPermission } from './permissions.js';
+import { logActivity } from './activity.js';
+
+export function createDocumentRouter(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const { title, content, folderId } = req.body;
+    const userId = req.userId!;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = store.nextId();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    logActivity(store, {
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  // Update document
+  router.put('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const userId = req.userId!;
+    const { title, content } = req.body;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (title !== undefined) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    doc.updatedAt = new Date().toISOString();
+
+    logActivity(store, {
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+    });
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    store.documents.delete(id);
+
+    // Remove shares for this document
+    for (let i = store.shares.length - 1; i >= 0; i--) {
+      if (store.shares[i].resourceType === 'document' && store.shares[i].resourceId === id) {
+        store.shares.splice(i, 1);
+      }
+    }
+
+    logActivity(store, {
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
