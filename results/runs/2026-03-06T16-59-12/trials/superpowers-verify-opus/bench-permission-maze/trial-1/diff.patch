)\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'document',\n        resourceId: doc.id,\n        userId: bobId,\n        role: 'viewer',\n      });\n\n    const res = await request(app)\n      .get(`/shares/document/${doc.id}`)\n      .set('Authorization', `Bearer ${aliceToken}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveLength(1);\n    expect(res.body[0].userId).toBe(bobId);\n  });\n\n  it('should remove a share', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n    const folder = await createFolder(aliceToken, 'Folder');\n    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.id);\n\n    const shareRes = await request(app)\n      .post('/shares')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'document',\n        resourceId: doc.id,\n        userId: bobId,\n        role: 'viewer',\n      });\n\n    // Bob can read\n    await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .expect(200);\n\n    // Alice removes the share\n    await request(app)\n      .delete(`/shares/${shareRes.body.id}`)\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .expect(204);\n\n    // Bob can no longer read\n    await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .expect(403);\n  });\n\n  it('should reject share with invalid resourceType', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    await request(app)\n      .post('/shares')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({\n        resourceType: 'invalid',\n        resourceId: '1',\n        userId: bobId,\n        role: 'viewer',\n      }