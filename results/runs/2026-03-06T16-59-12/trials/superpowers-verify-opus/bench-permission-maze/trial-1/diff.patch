@@ -0,0 +1,160 @@
+import { Router, type Response } from 'express';
+import type { Store } from './store.js';
+import type { AuthRequest } from './auth.js';
+import type { Role } from './types.js';
+import { requireAuth } from './auth.js';
+import { hasPermission } from './permissions.js';
+import { logActivity } from './activity.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function createShareRouter(store: Store): Router {
+  const router = Router();
+
+  // Share a resource
+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const { resourceType, resourceId, userId: targetUserId, role } = req.body;
+    const currentUserId = req.userId!;
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+      return;
+    }
+
+    if (!['folder', 'document'].includes(resourceType)) {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'role must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Current user needs editor or higher to share
+    if (!hasPermission(store, currentUserId, resourceType, resourceId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    // Only owners can assign the owner role
+    if (role === 'owner' && !hasPermission(store, currentUserId, resourceType, resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can assign the owner role' });
+      return;
+    }
+
+    // Check if a share already exists for this user+resource, and update it
+    const existingIndex = store.shares.findIndex(
+      s => s.resourceType === resourceType && s.resourceId === resourceId && s.userId === targetUserId
+    );
+
+    if (existingIndex !== -1) {
+      store.shares[existingIndex].role = role;
+      const share = store.shares[existingIndex];
+
+      logActivity(store, {
+        action: 'share_updated',
+        userId: currentUserId,
+        resourceType,
+        resourceId,
+        details: `Shared with user ${targetUserId} as ${role}`,
+      });
+
+      res.status(200).json(share);
+      return;
+    }
+
+    const id = store.nextId();
+    const share = { id, resourceType, resourceId, userId: targetUserId, role };
+    store.shares.push(share);
+
+    logActivity(store, {
+      action: 'share_created',
+      userId: currentUserId,
+      resourceType,
+      resourceId,
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(201).json(share);
+  });
+
+  // Get shares for a resource
+  router.get('/:resourceType/:resourceId', requireAuth, (req: AuthRequest, res: Response) => {
+    const { resourceType, resourceId } = req.params;
+    const userId = req.userId!;
+
+    if (!['folder', 'document'].includes(resourceType)) {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    if (!hasPermission(store, userId, resourceType as 'folder' | 'document', resourceId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const shares = store.shares.filter(
+      s => s.resourceType === resourceType && s.resourceId === resourceId
+    );
+
+    res.status(200).json(shares);
+  });
+
+  // Remove a share
+  router.delete('/:shareId', requireAuth, (req: AuthRequest, res: Response) => {
+    const { shareId } = req.params;
+    const userId = req.userId!;
+
+    const shareIndex = store.shares.findIndex(s => s.id === shareId);
+    if (shareIndex === -1) {
+      res.status(404).json({ error: 'Share not found' });
+      return;
+    }
+
+    const share = store.shares[shareIndex];
+
+    if (!hasPermission(store, userId, share.resourceType, share.resourceId, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions to remove share' });
+      return;
+    }
+
+    store.shares.splice(shareIndex, 1);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
