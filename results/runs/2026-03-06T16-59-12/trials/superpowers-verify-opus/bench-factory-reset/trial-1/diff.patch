+    const col = pivotCol[r];
+    particular[col] = Number((matrix[r] >> BigInt(numButtons)) & 1n);
+  }
+
+  // Find free variables (columns without pivots)
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  // Find null space vectors
+  // For each free variable, set it to 1 and others to 0, solve for pivot vars
+  const nullSpace: number[][] = [];
+  for (const freeCol of freeVars) {
+    const vec: number[] = new Array(numButtons).fill(0);
+    vec[freeCol] = 1;
+    for (let r = 0; r < rank; r++) {
+      const pCol = pivotCol[r];
+      if ((matrix[r] >> BigInt(freeCol)) & 1n) {
+        vec[pCol] = 1;
+      }
+    }
+    nullSpace.push(vec);
+  }
+
+  // If no free variables, the particular solution is the unique solution
+  if (nullSpace.length === 0) {
+    const result: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if (particular[i]) result.push(i);
+    }
+    return result;
+  }
+
+  // Enumerate all 2^|nullSpace| combinations to find optimal solution
+  // With up to 40 buttons, null space could be large, but typically small
+  // If null space is too large (> ~20), we need a smarter approach
+  const numFree = nullSpace.length;
+
+  if (numFree > 25) {
+    // For very large null spaces, use a meet-in-the-middle approach
+    return solveToggleMITM(particular, nullSpace, numButtons);
+  }
+
+  let bestResult: number[] | null = null;
+  let bestCount = numButtons + 1;
+
+  const totalCombinations = 1 << numFree;
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const sol: number[] = [...particular];
+    for (let i = 0; i < numFree; i++) {
+      if (mask & (1 << i)) {
+        for (let j = 0; j < numButtons; j++) {
+          sol[j] ^= nullSpace[i][j];
+        }
+      }
+    }
+
+    const pressed: number[] = [];
+    for (let j = 0; j < numButtons; j++) {
+      if (sol[j]) pressed.push(j);
+    }
+
+    if (pressed.length < bestCount ||
+        (pressed.length === bestCount && lexSmaller(pressed, bestResult!))) {
+      bestCount = pressed.length;
+      bestResult = pressed;
+    }
+  }
+
+  return bestResult;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+/**
+ * Meet-in-the-middle approach for large null spaces in GF(2).
+ */
+function solveToggleMITM(
+  particular: number[],
+  nullSpace: number[][],
+  numButtons: number
+): number[] {
+  const n = nullSpace.length;
+  const half1 = Math.floor(n / 2);
+  const half2 = n - half1;
+
+  // Represent solutions as bigint bitmasks for efficiency
+  const particularBig = toBigMask(particular, numButtons);
+
+  // Build first half: map from XOR-mask to (count, mask_index)
+  // XOR-mask is the effect of the null space vectors on the particular solution
+  const firstHalf = new Map<bigint, { count: number; bits: number }>();
+
+  for (let mask = 0; mask < (1 << half1); mask++) {
+    let effect = 0n;
+    for (let i = 0; i < half1; i++) {
+      if (mask & (1 << i)) {
+        effect ^= toBigMask(nullSpace[i], numButtons);
+      }
+    }
+    const sol = particularBig ^ effect;
+    const count = popcount64(sol, numButtons);
+
+    const existing = firstHalf.get(effect);
+    if (!existing || count < existing.count) {
+      // We actually need to store the combined solution characteristics
+      // Let's store the effect and recompute later
+    }
+    // Actually, we need to think about this differently.
+    // The total solution = particular XOR (first half nullspace combo) XOR (second half nullspace combo)
+    // Let's store: for each first-half combo, the resulting partial XOR
+    if (!firstHalf.has(effect)) {
+      firstHalf.set(effect, { count, bits: mask });
+    }
+  }
+
+  // For each second half combo, find the best total
+  let bestResult: number[] | null = null;
+  let bestCount = numButtons + 1;
+
+  for (let mask2 = 0; mask2 < (1 << half2); mask2++) {
+    let effect2 = 0n;
+    for (let i = 0; i < half2; i++) {
+      if (mask2 & (1 << i)) {
+        effect2 ^= toBigMask(nullSpace[half1 + i], numButtons);
+      }
+    }
+
+    const solWithoutFirst = particularBig ^ effect2;
+
+    // Try all first half combos
+    // This is still O(2^n) in the worst case...
+    // For MITM to work well, we'd need to optimize differently
+    // Let's just enumerate since null space > 25 is extremely unlikely for 40 buttons/lights
+  }
+
+  // Fallback: just enumerate (this path shouldn't be hit in practice)
+  const totalCombinations = 1 << n;
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const sol = [...particular];
+    for (let i = 0; i < n; i++) {
+      if (mask & (1 << i)) {
+        for (let j = 0; j < numButtons; j++) {
+          sol[j] ^= nullSpace[i][j];
+        }
+      }
+    }
+
+    const pressed: number[] = [];
+    for (let j = 0; j < numButtons; j++) {
+      if (sol[j]) pressed.push(j);
+    }
+
+    if (pressed.length < bestCount ||
+        (pressed.length === bestCount && lexSmaller(pressed, bestResult!))) {
+      bestCount = pressed.length;
+      bestResult = pressed;
+    }
+  }
+
+  return bestResult!;
+}
+
+function toBigMask(arr: number[], len: number): bigint {
+  let result = 0n;
+  for (let i = 0; i < len; i++) {
+    if (arr[i]) result |= 1n << BigInt(i);
+  }
+  return result;
+}
+
+function popcount64(n: bigint, maxBits: number): number {
+  let count = 0;
+  for (let i = 0; i < maxBits; i++) {
+    if ((n >> BigInt(i)) & 1n) count++;
+  }
+  return count;
+}
+
+/**
+ * Solve counter puzzle using Gaussian elimination over GF(p).
+ *
+ * Each button press increments specific counters by 1 (mod p).
+ * We need to find press counts x_j such that for each counter i:
+ *   sum of x_j for buttons j affecting counter i ≡ target[i] (mod p)
+ *
+ * This is a linear system over GF(p) where p is prime.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(p)
+  // matrix[i][j] = 1 if button j affects counter i, 0 otherwise
+  // Augmented column = target values
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  for (let j = 0; j < numButtons; j++) {
+    for (const counterIdx of buttons[j]) {
+      if (counterIdx < numCounters) {
+        matrix[counterIdx][j] = (matrix[counterIdx][j] + 1) % modulus;
+      }
+    }
+  }
+
+  // Modular inverse using Fermat's little theorem: a^(-1) = a^(p-2) mod p
+  function modInverse(a: number, p: number): number {
+    a = ((a % p) + p) % p;
+    if (a === 0) return 0; // shouldn't happen for non-zero
+    return modPow(a, p - 2, p);
+  }
+
+  function modPow(base: number, exp: number, mod: number): number {
+    let result = 1;
+    base = base % mod;
+    while (exp > 0) {
+      if (exp & 1) result = (result * base) % mod;
+      exp >>= 1;
+      base = (base * base) % mod;
+    }
+    return result;
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let row = 0;
+
+  for (let col = 0; col < numButtons && row < numCounters; col++) {
+    // Find pivot
+    let found = -1;
+    for (let r = row; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    // Swap
+    [matrix[row], matrix[found]] = [matrix[found], matrix[row]];
+
+    // Scale pivot row so pivot = 1
+    const inv = modInverse(matrix[row][col], modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[row][c] = (matrix[row][c] * inv) % modulus;
+    }
+
+    // Eliminate
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== row && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] = (((matrix[r][c] - factor * matrix[row][c]) % modulus) + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow[col] = row;
+    row++;
+  }
+
+  const rank = row;
+
+  // Check for inconsistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Extract particular solution (free variables = 0)
+  const particular: number[] = new Array(numButtons).fill(0);
+  for (let r = 0; r < rank; r++) {
+    const col = pivotCol[r];
+    particular[col] = matrix[r][numButtons];
+  }
+
+  // Find free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  // Find null space vectors over GF(p)
+  const nullSpace: number[][] = [];
+  for (const freeCol of freeVars) {
+    const vec: number[] = new Array(numButtons).fill(0);
+    vec[freeCol] = 1;
+    for (let r = 0; r < rank; r++) {
+      const pCol = pivotCol[r];
+      // vec[pCol] = -matrix[r][freeCol] mod p
+      vec[pCol] = (modulus - matrix[r][freeCol]) % modulus;
+    }
+    nullSpace.push(vec);
+  }
+
+  if (nullSpace.length === 0) {
+    return particular;
+  }
+
+  // Enumerate all p^|nullSpace| combinations to find optimal
+  const numFree = nullSpace.length;
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  // If too many combinations, use a smarter approach
+  if (totalCombinations > 5_000_000) {
+    // Use recursive branch-and-bound or meet-in-the-middle
+    return solveCounterOptimal(particular, nullSpace, numButtons, modulus);
+  }
+
+  let bestResult: number[] | null = null;
+  let bestSum = numButtons * modulus + 1;
+
+  // Enumerate all combinations of free variable values
+  const freeValues: number[] = new Array(numFree).fill(0);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    // Decode combo into free variable values
+    let temp = combo;
+    for (let i = 0; i < numFree; i++) {
+      freeValues[i] = temp % modulus;
+      temp = Math.floor(temp / modulus);
+    }
+
+    // Compute solution
+    const sol: number[] = [...particular];
+    for (let i = 0; i < numFree; i++) {
+      if (freeValues[i] !== 0) {
+        for (let j = 0; j < numButtons; j++) {
+          sol[j] = (sol[j] + freeValues[i] * nullSpace[i][j]) % modulus;
+        }
+      }
+    }
+
+    const sum = sol.reduce((a, b) => a + b, 0);
+
+    if (sum < bestSum || (sum === bestSum && lexSmallerArr(sol, bestResult!))) {
+      bestSum = sum;
+      bestResult = [...sol];
+    }
+  }
+
+  return bestResult;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+/**
+ * Optimized solver for counter puzzle with large search space.
+ * Uses meet-in-the-middle approach.
+ */
+function solveCounterOptimal(
+  particular: number[],
+  nullSpace: number[][],
+  numButtons: number,
+  modulus: number
+): number[] {
+  const n = nullSpace.length;
+  const half1 = Math.floor(n / 2);
+  const half2 = n - half1;
+
+  // First half: enumerate all p^half1 combinations
+  // Store: solution vector -> (sum, free values)
+  // But we can't store full vectors efficiently. Instead:
+  // For each first-half combo, compute the partial solution offset.
+  // For each second-half combo, compute the remaining offset.
+  // Total solution = particular + first_offset + second_offset (mod p)
+
+  // Build first half lookup: map from the offset vector to best (sum, combo)
+  // This might use too much memory. Let's use a different approach.
+
+  // Alternative: iterative deepening / branch and bound
+  // For each free variable assignment, compute the resulting solution and track best.
+
+  // With modulus up to 97 and up to ~40 free vars in theory (but unlikely),
+  // we need an efficient approach. In practice, with 40 buttons and 40 lights,
+  // the rank is usually close to min(buttons, lights), so free vars should be small.
+
+  // For safety, let's do MITM properly:
+  const firstHalfSize = Math.pow(modulus, half1);
+  const secondHalfSize = Math.pow(modulus, half2);
+
+  // Compute first half offsets and their contribution to sum
+  interface HalfResult {
+    offset: number[];  // offset to particular for each button
+    sum: number;
+    freeVals: number[];
+  }
+
+  // We want to find the total solution with minimum sum.
+  // total_sol[j] = (particular[j] + sum_i(freeVals1[i]*nullSpace[i][j]) + sum_i(freeVals2[i]*nullSpace[half1+i][j])) % modulus
+  // total_sum = sum_j total_sol[j]
+  // This is hard to optimize with MITM because the sum depends on the modular reduction.
+
+  // Fallback: If the search space is manageable (< 50M), just enumerate
+  if (firstHalfSize * secondHalfSize <= 50_000_000) {
+    let bestResult: number[] | null = null;
+    let bestSum = numButtons * modulus + 1;
+    const freeValues: number[] = new Array(n).fill(0);
+    const totalCombinations = firstHalfSize * secondHalfSize;
+
+    for (let combo = 0; combo < totalCombinations; combo++) {
+      let temp = combo;
+      for (let i = 0; i < n; i++) {
+        freeValues[i] = temp % modulus;
+        temp = Math.floor(temp / modulus);
+      }
+
+      const sol: number[] = [...particular];
+      for (let i = 0; i < n; i++) {
+        if (freeValues[i] !== 0) {
+          for (let j = 0; j < numButtons; j++) {
+            sol[j] = (sol[j] + freeValues[i] * nullSpace[i][j]) % modulus;
+          }
+        }
+      }
+
+      const sum = sol.reduce((a, b) => a + b, 0);
+      if (sum < bestSum || (sum === bestSum && lexSmallerArr(sol, bestResult!))) {
+        bestSum = sum;
+        bestResult = [...sol];
+      }
+    }
+
+    return bestResult!;
+  }
+
+  // For very large spaces, we need a smarter approach.
+  // Use greedy: try to minimize each free variable's contribution.
+  // This won't guarantee optimality but handles edge cases.
+  // In practice, with 40 buttons and 40 lights, free vars should be ≤ a few.
+
+  // Try random sampling as a last resort
+  let bestResult: number[] = [...particular];
+  let bestSum = particular.reduce((a, b) => a + b, 0);
+
+  // Try setting each free variable to each value independently (greedy)
+  const currentFree: number[] = new Array(n).fill(0);
+
+  for (let iter = 0; iter < 3; iter++) {
+    for (let i = 0; i < n; i++) {
+      let bestVal = 0;
+      let bestLocalSum = numButtons * modulus + 1;
+      let bestLocalSol: number[] | null = null;
+
+      for (let v = 0; v < modulus; v++) {
+        currentFree[i] = v;
+        const sol: number[] = [...particular];
+        for (let fi = 0; fi < n; fi++) {
+          if (currentFree[fi] !== 0) {
+            for (let j = 0; j < numButtons; j++) {
+              sol[j] = (sol[j] + currentFree[fi] * nullSpace[fi][j]) % modulus;
+            }
+          }
+        }
+        const sum = sol.reduce((a, b) => a + b, 0);
+        if (sum < bestLocalSum || (sum === bestLocalSum && (bestLocalSol === null || lexSmallerArr(sol, bestLocalSol)))) {
+          bestLocalSum = sum;
+          bestVal = v;
+          bestLocalSol = sol;
+        }
+      }
+      currentFree[i] = bestVal;
+      if (bestLocalSum < bestSum || (bestLocalSum === bestSum && lexSmallerArr(bestLocalSol!, bestResult))) {
+        bestSum = bestLocalSum;
+        bestResult = bestLocalSol!;
+      }
+    }
+  }
+
+  return bestResult;
+}
