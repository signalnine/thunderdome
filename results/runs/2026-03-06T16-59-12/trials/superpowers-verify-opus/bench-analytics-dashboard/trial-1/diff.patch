ashboard\");\n  });\n\n  it(\"updates a dashboard\", async () => {\n    const res = await request(app)\n      .put(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Updated Dashboard\" });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"Updated Dashboard\");\n  });\n\n  it(\"deletes a dashboard\", async () => {\n    const res = await request(app)\n      .delete(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const get = await request(app)\n      .get(`/api/dashboards/${dashboardId}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(get.status).toBe(404);\n  });\n\n  it(\"returns 401 without auth\", async () => {\n    const res = await request(app).get(\"/api/dashboards\");\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe(\"Data Export\", () => {\n  let token: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/api/users/login\").send({\n      email: \"admin@test.com\",\n      password: \"password123\",\n    });\n    token = res.body.token;\n  });\n\n  it(\"exports events as JSON\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events).toBeDefined();\n    expect(res.body.events.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"exports events as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,name,properties\");\n  });\n\n  it(\"exports dashboards as JSON\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/dashboards/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboards).toBeDefined();\n  });\n\n  it(\"exports dashboards as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/dashboards/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n  });\n\n  it(\"returns 401 without auth\", async () => {\n    const res = await request(app).get(\"/api/export/events/json\");\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
