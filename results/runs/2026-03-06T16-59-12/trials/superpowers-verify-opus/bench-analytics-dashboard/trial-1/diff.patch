ull;\n      count: number;\n    }>;\n    res.json({ data: results });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":862,"cache_read_input_tokens":23418,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":862},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5510028b-970d-4ba4-b1c6-9f1082a664b8","uuid":"ecc1f7d0-3afc-46ec-9676-76980da8a1c3"}
