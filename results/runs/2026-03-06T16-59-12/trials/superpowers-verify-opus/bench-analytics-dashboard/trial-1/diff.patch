+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { authMiddleware } from "../auth.js";
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export function createDashboardRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post("/", authMiddleware, (req: Request, res: Response): void => {
+    const { name, config } = req.body;
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, ownerId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenantId,
+      name,
+      ownerId,
+      config: config || {},
+      createdAt: now,
+      updatedAt: now,
+    });
+  });
+
+  // List dashboards for tenant
+  router.get("/", authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const rows = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    const dashboards = rows.map((row) => ({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+    }));
+
+    res.json({ dashboards });
+  });
+
+  // Get single dashboard
+  router.get("/:id", authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const row = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    res.json({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { name, config } = req.body;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?"
+    ).run(updatedName, updatedConfig, now, req.params.id);
+
+    res.json({
+      id: existing.id,
+      tenantId: existing.tenant_id,
+      name: updatedName,
+      ownerId: existing.owner_id,
+      config: JSON.parse(updatedConfig),
+      createdAt: existing.created_at,
+      updatedAt: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const existing = db
+      .prepare("SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as { id: string } | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(req.params.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
