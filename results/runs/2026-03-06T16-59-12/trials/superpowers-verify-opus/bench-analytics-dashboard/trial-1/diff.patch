ects invalid credentials\", async () => {\n    const res = await request(app).post(\"/api/users/login\").send({\n      email: \"admin@test.com\",\n      password: \"wrong\",\n    });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"gets user profile\", async () => {\n    const res = await request(app)\n      .get(\"/api/users/me\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.email).toBe(\"admin@test.com\");\n    expect(res.body.role).toBe(\"admin\");\n  });\n\n  it(\"returns 401 without token\", async () => {\n    const res = await request(app).get(\"/api/users/me\");\n    expect(res.status).toBe(401);\n  });\n\n  it(\"admin can change user role\", async () => {\n    // Register a second user in the same tenant\n    const reg = await request(app).post(\"/api/users/register\").send({\n      email: \"viewer@test.com\",\n      password: \"password123\",\n      tenantId: \"tenant-1\",\n      role: \"viewer\",\n    });\n    expect(reg.status).toBe(201);\n\n    const res = await request(app)\n      .put(`/api/users/${reg.body.id}/role`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe(\"editor\");\n  });\n\n  it(\"non-admin cannot change role\", async () => {\n    const login = await request(app).post(\"/api/users/login\").send({\n      email: \"viewer@test.com\",\n      password: \"password123\",\n    });\n    const viewerToken = login.body.token;\n\n    const res = await request(app)\n      .put(`/api/users/${userId}/role`)\n      .set(\"Authorization\", `Bearer ${viewerToken}`)\n      .send({ role: \"viewer\" });\n    expect(res.status).toBe(403);\n  });\n});\n\ndescribe(\"Event Ingestion\", () => {\n  let token: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/api/users/login\").send({\n      email: \"admin@test.com\",\n      password: \"password123\",\n    });\n    token = res.body.token;\n  });\n\n  it(\"ingests a single event\", async () => {\n    const res = await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        name: \"page_view\",\n        properties: { url: \"/home\", browser: \"chrome\" },\n        timestamp: \"2024-01-15T10:00:00Z\",\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"page_view\");\n    expect(res.body.properties.url).toBe(\"/home\");\n  });\n\n  it(\"returns 401 without auth\", async () => {\n    const res = await request(app).post(\"/api/events\").send({\n      name: \"page_view\",\n    });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"ingests batch events\", async () => {\n    const res = await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-15T11:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/contact\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n          { name: \"click\", properties: { element: \"button\" }, timestamp: \"2024-01-16T12:00:00Z\" },\n        ],\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.ingested).toBe(3);\n  });\n\n  it(\"rejects empty batch\", async () => {\n    const res = await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ events: [] });\n    expect(res.status).toBe(400);\n  });\n});\n\ndescribe(\"Query Engine\", () => {\n  let token: string;\n\n  beforeAll(async () => {\n    const res = await request(app).post(\"/api/users/login\").send({\n      email: \"admin@test.com\",\n      password: \"password123\",\n    });\n    token = res.body.token;\n  });\n\n  it(\"counts events\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${