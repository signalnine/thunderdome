     );\n    }\n  }\n\n  const WHITE = 0,\n    GRAY = 1,\n    BLACK = 2;\n  const color = new Map<string, number>();\n  for (const id of eventIds) {\n    color.set(id, WHITE);\n  }\n\n  function dfs(node: string): void {\n    color.set(node, GRAY);\n    for (const neighbor of adjacency.get(node) ?? []) {\n      const c = color.get(neighbor);\n      if (c === GRAY) {\n        throw new Error(\n          `Cycle detected in prerequisites involving event \"${neighbor}\"`\n        );\n      }\n      if (c === WHITE) {\n        dfs(neighbor);\n      }\n    }\n    color.set(node, BLACK);\n  }\n\n  for (const id of eventIds) {\n    if (color.get(id) === WHITE) {\n      dfs(id);\n    }\n  }\n}\n\n/**\n * Topological sort of events based on prerequisites.\n * Returns event IDs in dependency order (prerequisites first).\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map((e) => e.id));\n  const inDegree = new Map<string, number>();\n  const adjacency = new Map<string, string[]>();\n\n  for (const event of events) {\n    inDegree.set(event.id, 0);\n    adjacency.set(event.id, []);\n  }\n\n  for (const event of events) {\n    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));\n    inDegree.set(event.id, prereqs.length);\n    for (const prereq of prereqs) {\n      adjacency.get(prereq)!.push(event.id);\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) {\n      queue.push(id);\n    }\n  }\n\n  const result: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    result.push(node);\n    for (const neighbor of adjacency.get(node) ?? []) {\n      const newDeg = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) {\n        queue.push(neighbor);\n      }\n    }\n  }\n\n  return result;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering room occupancy and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  room: Room,\n  roomSchedules: Map<string, Assignment[]>,\n  assignmentMap: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number,\n  knownEventIds: Set<string>\n): number | null {\n  const attendees = event.attendees ?? 1;\n  if (attendees > room.capacity) {\n    return null;\n  }\n\n  // Earliest start based on prerequisites (only consider known events)\n  let earliest = options.startTime;\n  for (const prereqId of event.prerequisites ?? []) {\n    if (!knownEventIds.has(prereqId)) {\n      continue; // Unknown prerequisite, treat as already satisfied\n    }\n    const prereqAssignment = assignmentMap.get(prereqId);\n    if (!prereqAssignment) {\n      // Prerequisite is a known event but not scheduled yet - can't schedule this event\n      return null;\n    }\n    earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n  }\n\n  // Check if event fits within time window at all\n  if (earliest + event.duration > options.endTime) {\n    return null;\n  }\n\n  // Find earliest slot in this room that doesn't conflict\n  const roomEvents = roomSchedules.get(room.id) ?? [];\n\n  if (roomEvents.length === 0) {\n    return earliest;\n  }\n\n  // Sort room events by start time\n  const sorted = [...roomEvents].sort((a, b) => a.startTime - b.startTime);\n\n  // Try to fit before the first event\n  if (earliest + event.duration + gap <= sorted[0].startTime) {\n    return earliest;\n  }\n\n  // Try to fit between events\n  for (let i = 0; i < sorted.length; i++) {\n    const slotStart = Math.max(earliest, sorted[i].endTime + gap);\n    const nextStart =\n      i + 1 < sorted.length ? sorted[i + 1].startTime : options.endTime;\n\n    if (i + 1 < sorted.length) {\n      // Between two events: need room for event + gap before next\n      if (\n        slotStart + event.duration + gap <= nextStart &&\n        slotStart + event.duration <= options.endTime\n      ) {\n        return slotStart;\n      }\n    } else {\n      // After last event: just need to fit within time window\n      if (slotStart + event.duration <= options.endTime) {\n        return slotStart;\n      }\n    }\n  }\n\n  return null;\n}\n\n/**\n * Try to schedule events using backtracking to maximize the number of scheduled events.\n */\nfunction scheduleWithBacktracking(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number\n): ScheduleResult {\n  const eventMap = new Map(events.map((e) => [e.id, e]));\n  const knownEventIds = new Set(events.map((e) => e.id));\n\n  // Use the provided event order (assumed to be topologically valid)\n  const orderedEventIds = events.map((e) => e.id);\n\n  // For each event, determine all feasible (room, startTime) placements\n  // Use a greedy approach with smart ordering to maximize scheduled events\n\n  const assignments: Assignment[] = [];\n  const assignmentMap = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  // Sort rooms by capacity (ascending) for efficient matching\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Process events in topological order\n  for (const eventId of orderedEventIds) {\n    const event = eventMap.get(eventId)!;\n\n    // Check if all prerequisites are scheduled\n    const prereqsMet = (event.prerequisites ?? []).every(\n      (p) => assignmentMap.has(p) || !eventMap.has(p)\n    );\n    if (!prereqsMet) {\n      continue; // Prerequisites not met, skip (will be unscheduled)\n    }\n\n    let bestAssignment: Assignment | null = null;\n    let bestStartTime = Infinity;\n\n    // Try preferred room first\n    if (event.preferredRoom) {\n      const preferredRoom = rooms.find((r) => r.id === event.preferredRoom);\n      if (preferredRoom) {\n        const startTime = findEarliestStart(\n          event,\n          preferredRoom,\n  