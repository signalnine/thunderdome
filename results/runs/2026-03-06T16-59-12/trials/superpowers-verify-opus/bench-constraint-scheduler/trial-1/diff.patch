ent.endTime + gap);\n  }","originalFile":"export interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws an error if a cycle is found (including self-references).\n */\nfunction detectCycles(events: Event[]): void {\n  const eventIds = new Set(events.map((e) => e.id));\n  const adjacency = new Map<string, string[]>();\n\n  for (const event of events) {\n    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));\n    adjacency.set(event.id, prereqs);\n\n    // Self-reference check\n    if (event.prerequisites?.includes(event.id)) {\n      throw new Error(\n        `Cycle detected in prerequisites: event \"${event.id}\" references itself`\n      );\n    }\n  }\n\n  const WHITE = 0,\n    GRAY = 1,\n    BLACK = 2;\n  const color = new Map<string, number>();\n  for (const id of eventIds) {\n    color.set(id, WHITE);\n  }\n\n  function dfs(node: string): void {\n    color.set(node, GRAY);\n    for (const neighbor of adjacency.get(node) ?? []) {\n      const c = color.get(neighbor);\n      if (c === GRAY) {\n        throw new Error(\n          `Cycle detected in prerequisites involving event \"${neighbor}\"`\n        );\n      }\n      if (c === WHITE) {\n        dfs(neighbor);\n      }\n    }\n    color.set(node, BLACK);\n  }\n\n  for (const id of eventIds) {\n    if (color.get(id) === WHITE) {\n      dfs(id);\n    }\n  }\n}\n\n/**\n * Topological sort of events based on prerequisites.\n * Returns event IDs in dependency order (prerequisites first).\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map((e) => e.id));\n  const inDegree = new Map<string, number>();\n  const adjacency = new Map<string, string[]>();\n\n  for (const event of events) {\n    inDegree.set(event.id, 0);\n    adjacency.set(event.id, []);\n  }\n\n  for (const event of events) {\n    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));\n    inDegree.set(event.id, prereqs.length);\n    for (const prereq of prereqs) {\n      adjacency.get(prereq)!.push(event.id);\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) {\n      queue.push(id);\n    }\n  }\n\n  const result: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    result.push(node);\n    for (const neighbor of adjacency.get(node) ?? []) {\n      const newDeg = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) {\n        queue.push(neighbor);\n      }\n    }\n  }\n\n  return result;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering room occupancy and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  room: Room,\n  roomSchedules: Map<string, Assignment[]>,\n  assignmentMap: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number\n): number | null {\n  const attendees = event.attendees ?? 1;\n  if (attendees > room.capacity) {\n    return null;\n  }\n\n  // Earliest start based on prerequisites\n  let earliest = options.startTime;\n  for (const prereqId of event.prerequisites ?? []) {\n    const prereqAssignment = assignmentMap.get(prereqId);\n    if (!prereqAssignment) {\n      // Prerequisite not scheduled yet - can't schedule this event\n      return null;\n    }\n    earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n  }\n\n  // Check if event fits within time window at all\n  if (earliest + event.duration > options.endTime) {\n    return null;\n  }\n\n  // Find earliest slot in this room that doesn't conflict\n  const roomEvents = roomSchedules.get(room.id) ?? [];\n\n  if (roomEvents.length === 0) {\n    return earliest;\n  }\n\n  // Sort room events by start time\n  const sorted = [...roomEvents].sort((a, b) => a.startTime - b.startTime);\n\n  // Try to fit before the first event\n  if (earliest + event.duration + gap <= sorted[0].startTime) {\n    return earliest;\n  }\n\n  // Try to fit between events\n  for (let i = 0; i < sorted.length; i++) {\n    const slotStart = Math.max(earliest, sorted[i].endTime + gap);\n    const nextStart =\n      i + 1 < sorted.length ? sorted[i + 1].startTime : options.endTime;\n\n    if (i + 1 < sorted.length) {\n      // Between two events: need room for event + gap before next\n      if (\n        slotStart + event.duration + gap <= nextStart &&\n        slotStart + event.duration <= options.endTime\n      ) {\n        return slotStart;\n      }\n    } else {\n      // After last event: just need to fit within time window\n      if (slotStart + event.duration <= options.endTime) {\n        return slotStart;\n      }\n    }\n  }\n\n  return null;\n}\n\n/**\n * Try to schedule events using backtracking to maximize the number of scheduled events.\n */\nfunction scheduleWithBacktracking(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number\n): ScheduleResult {\n  const eventMap = new Map(events.map((e) => [e.id, e]));\n\n  // Use the provided event order (assumed to be topologically valid)\n  const orderedEventIds = events.map((e) => e.id);\n\n  // For each event, determine all feasible (room, startTime) placements\n  // Use a greedy approach with smart ordering to maximize scheduled events\n\n  const assignments: Assignment[] = [];\n  const assignmentMap = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  // Sort rooms by capacity (ascending) for efficient matching\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Process events in topological order\n  for (const eventId of orderedEventIds) {\n    const event = eventMap.get(eventId)!;\n\n    // Check if all prerequisites are scheduled\n    const prereqsMet = (event.prerequisites ?? []).every(\n      (p) => assignmentMap.has(p) || !eventMap.has(p)\n    );\n    if (!prereqsMet) {\n      continue; // Prerequisites not met, skip (will be unscheduled)\n    }\n\n    let bestAssignment: Assignment | null = null;\n    let bestStartTime = Infinity;\n\n    // Try preferred room first\n    if (event.preferredRoom) {\n      const preferredRoom = rooms.find((r) => r.id === event.preferredRoom);\n      if (preferredRoom) {\n        const startTime = findEarliestStart(\n          event,\n          preferredRoom,\n          roomSchedules,\n          assignmentMap,\n          options,\n          gap\n        );\n        if (startTime !== null) {\n          bestAssignment = {\n            eventId: event.id,\n            roomId: preferredRoom.id,\n            startTime,\n            endTime: startTime + event.duration,\n          };\n          bestStartTime = startTime;\n        }\n      }\n    }\n\n    // Try other rooms to see if we can get an earlier start\n    // But prefer the preferred room if it gives a reasonable time\n    if (!bestAssignment || !event.preferredRoom) {\n      for (const room of sortedRooms) {\n        if (\n          bestAssignment &&\n          event.preferredRoom &&\n          room.id !== event.preferredRoom\n        ) {\n          // If we have a preferred room assignment, only switch if it's meaningfully earlier\n          continue;\n        }\n\n        const startTime = findEarliestStart(\n          event,\n          room,\n          roomSchedules,\n          assignmentMap,\n          options,\n          gap\n        );\n        if (startTime !== null && startTime < bestStartTime) {\n          bestAssignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime,\n            endTime: startTime + event.duration,\n          };\n          bestStartTime = startTime;\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignments.push(bestAssignment);\n      assignmentMap.set(event.id, bestAssignment);\n      roomSchedules.get(bestAssignment.roomId)!.push(bestAssignment);\n    }\n  }\n\n  const scheduledIds = new Set(assignments.map((a) => a.eventId));\n  const unscheduled = events\n    .filter((e) => !scheduledIds.has(e.id))\n    .map((e) => e.id);\n\n  return { assignments, unscheduled };\n}\n\n/**\n * Advanced scheduling that tries multiple orderings to maximize scheduled events.\n */\nfunction scheduleOptimized(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number\n): ScheduleResult {\n  // If there are unscheduled events from the basic approach,\n  // try alternative orderings to see if we can do better.\n\n  // Start with topologically sorted events\n  const topoOrder = topologicalSort(events);\n  const eventMap = new Map(events.map((e) => [e.id, e]));\n  const topoSortedEvents = topoOrder\n    .filter((id) => eventMap.has(id))\n    .map((id) => eventMap.get(id)!);\n\n  const baseResult = scheduleWithBacktracking(\n    topoSortedEvents,\n    rooms,\n    options,\n    gap\n  );\n\n  if (baseResult.unscheduled.length === 0) {\n    return baseResult;\n  }\n\n  // Try different strategies to maximize scheduling\n  let bestResult = baseResult;\n\n  // Compute topological levels for each event\n  const levels = new Map<string, number>();\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const event = eventMap.get(id);\n    if (!event || !event.prerequisites || event.prerequisites.length === 0) {\n      levels.set(id, 0);\n      return 0;\n    }\n    let maxLevel = 0;\n    for (const prereq of event.prerequisites) {\n      if (eventMap.has(prereq)) {\n        maxLevel = Math.max(maxLevel, getLevel(prereq) + 1);\n      }\n    }\n    levels.set(id, maxLevel);\n    return maxLevel;\n  }\n  for (const e of events) {\n    getLevel(e.id);\n  }\n\n  // Generate alternative orderings that respect topological constraints\n  const orderings: ((a: Event, b: Event) => number)[] = [\n    // By duration descending (longer events first - harder to place)\n    (a, b) => {\n      const la = levels.get(a.id) ?? 0;\n      const lb = levels.get(b.id) ?? 0;\n      if (la !== lb) return la - lb;\n      return b.duration - a.duration;\n    },\n    // By duration ascending (shorter events first - easier to place)\n    (a, b) => {\n      const la = levels.get(a.id) ?? 0;\n      const lb = levels.get(b.id) ?? 0;\n      if (la !== lb) return la - lb;\n      return a.duration - b.duration;\n    },\n    // By attendees descending (more constrained first)\n    (a, b) => {\n      const la = levels.get(a.id) ?? 0;\n      const lb = levels.get(b.id) ?? 0;\n      if (la !== lb) return la - lb;\n      return (b.attendees ?? 1) - (a.attendees ?? 1);\n    },\n    // By number of dependents (events that unlock more events first)\n    (a, b) => {\n      const la = levels.get(a.id) ?? 0;\n      const lb = levels.get(b.id) ?? 0;\n      if (la !== lb) return la - lb;\n      const depsA = events.filter(\n        (e) => e.prerequisites?.includes(a.id)\n      ).length;\n      const depsB = events.filter(\n        (e) => e.prerequisites?.includes(b.id)\n      ).length;\n      return depsB - depsA;\n    },\n  ];\n\n  for (const comparator of orderings) {\n    const sortedEvents = [...events].sort(comparator);\n    const result = scheduleWithBacktracking(sortedEvents, rooms, options, gap);\n    if (result.unscheduled.length < bestResult.unscheduled.length) {\n      bestResult = result;\n      if (bestResult.unscheduled.length === 0) break;\n    }\n  }\n\n  // If still have unscheduled, try a more aggressive approach:\n  // Try removing each unscheduled event's \"blockers\" by rearranging\n  if (bestResult.unscheduled.length > 0 && events.length <= 50) {\n    // Try permutations of the most constrained events\n    const result = tryWithPermutations(events, rooms, options, gap, levels);\n    if (result.unscheduled.length < bestResult.unscheduled.length) {\n      bestResult = result;\n    }\n  }\n\n  return bestResult;\n}\n\n/**\n * Try scheduling with permutations of events at the same topological level.\n */\nfunction tryWithPermutations(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n  levels: Map<string, number>\n): ScheduleResult {\n  // Group events by topological level\n  const eventsByLevel = new Map<number, Event[]>();\n  for (const event of events) {\n    const level = levels.get(event.id) ?? 0;\n    if (!eventsByLevel.has(level)) {\n      eventsByLevel.set(level, []);\n    }\n    eventsByLevel.get(level)!.push(event);\n  }\n\n  const maxLevel = Math.max(...eventsByLevel.keys());\n  let bestResult: ScheduleResult = {\n    assignments: [],\n    unscheduled: events.map((e) => e.id),\n  };\n\n  // Try different random shuffles of events within each level\n  const maxAttempts = Math.min(20, events.length * 2);\n  for (let attempt = 0; attempt < maxAttempts; attempt++) {\n    const orderedEvents: Event[] = [];\n    for (let level = 0; level <= maxLevel; level++) {\n      const levelEvents = eventsByLevel.get(level) ?? [];\n      // Shuffle events within this level\n      const shuffled = [...levelEvents];\n      for (let i = shuffled.length - 1; i > 0; i--) {\n        const j = Math.floor(Math.random() * (i + 1));\n        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];\n      }\n      orderedEvents.push(...shuffled);\n    }\n\n    const result = scheduleWithBacktracking(orderedEvents, rooms, options, gap);\n    if (result.unscheduled.length < bestResult.unscheduled.length) {\n      bestResult = result;\n      if (bestResult.unscheduled.length === 0) break;\n    }\n  }\n\n  return bestResult;\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  // Validate and detect cycles\n  detectCycles(events);\n\n  const gap = options.gap ?? 15;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  if (rooms.length === 0) {\n    return { assignments: [], unscheduled: events.map((e) => e.id) };\n  }\n\n  return scheduleOptimized(events, rooms, options, gap);\n}\n\n// Also export as a class for flexibility\nexport class Scheduler {\n  schedule(\n    events: Event[],\n    rooms: Room[],\n    options: ScheduleOptions\n  ): ScheduleResult {\n    return schedule(events, rooms, options);\n  }\n}\n\nexport function createScheduler(): Scheduler {\n  return new Scheduler();\n}\n\nexport default schedule;\n","structuredPatch":[{"oldStart":137,"oldLines":19,"newStart":137,"newLines":23,"lines":["   roomSchedules: Map<string, Assignment[]>,","   assignmentMap: Map<string, Assignment>,","   options: ScheduleOptions,","-  gap: number","+  gap: number,","+  knownEventIds: Set<string>"," ): number | null {","   const attendees = event.attendees ?? 1;","   if (attendees > room.capacity) {","     return null;","   }"," ","-  // Earliest start based on prerequisites","+  // Earliest start based on prerequisites (only consider known events)","   let earliest = options.startTime;","   for (const prereqId of event.prerequisites ?? []) {","+    if (!knownEventIds.has(prereqId)) {","+      continue; // Unknown prerequisite, treat as already satisfied","+    }","     const prereqAssignment = assignmentMap.get(prereqId);","     if (!prereqAssignment) {","-      // Prerequisite not scheduled yet - can't schedule this event","+      // Prerequisite is a known event but not scheduled yet - can't schedule this event","       return null;","     }","     earli