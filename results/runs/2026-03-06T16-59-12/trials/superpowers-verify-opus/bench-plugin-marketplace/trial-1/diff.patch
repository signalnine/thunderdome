+import { describe, it, expect, beforeEach } from 'vitest';
+import { createResolver } from './index.js';
+import type { ResolverService } from '../types.js';
+
+describe('ResolverService', () => {
+  let resolver: ResolverService;
+
+  beforeEach(() => {
+    resolver = createResolver();
+  });
+
+  describe('resolve', () => {
+    it('should resolve constraints to best available versions', () => {
+      const results = resolver.resolve(
+        [{ name: 'foo', range: '^1.0.0' }],
+        { foo: ['1.0.0', '1.2.0', '1.5.0', '2.0.0'] }
+      );
+      expect(results).toHaveLength(1);
+      expect(results[0].name).toBe('foo');
+      expect(results[0].version).toBe('1.5.0');
+      expect(results[0].satisfies).toBe('^1.0.0');
+    });
+
+    it('should resolve multiple constraints', () => {
+      const results = resolver.resolve(
+        [
+          { name: 'foo', range: '^1.0.0' },
+          { name: 'bar', range: '~2.1.0' },
+        ],
+        {
+          foo: ['1.0.0', '1.2.0', '2.0.0'],
+          bar: ['2.0.0', '2.1.0', '2.1.5', '2.2.0'],
+        }
+      );
+      expect(results).toHaveLength(2);
+      expect(results[0].version).toBe('1.2.0');
+      expect(results[1].version).toBe('2.1.5');
+    });
+
+    it('should throw if no versions available for a dependency', () => {
+      expect(() =>
+        resolver.resolve([{ name: 'foo', range: '^1.0.0' }], {})
+      ).toThrow('No versions available for "foo"');
+    });
+
+    it('should throw if no version satisfies the range', () => {
+      expect(() =>
+        resolver.resolve(
+          [{ name: 'foo', range: '^3.0.0' }],
+          { foo: ['1.0.0', '2.0.0'] }
+        )
+      ).toThrow('No version of "foo" satisfies range "^3.0.0"');
+    });
+
+    it('should handle exact version constraints', () => {
+      const results = resolver.resolve(
+        [{ name: 'foo', range: '1.0.0' }],
+        { foo: ['1.0.0', '2.0.0'] }
+      );
+      expect(results[0].version).toBe('1.0.0');
+    });
+  });
+
+  describe('satisfies', () => {
+    it('should return true for matching version', () => {
+      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+    });
+
+    it('should return false for non-matching version', () => {
+      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+    });
+  });
+
+  describe('maxSatisfying', () => {
+    it('should return the highest satisfying version', () => {
+      expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');
+    });
+
+    it('should return null if no version satisfies', () => {
+      expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();
+    });
+  });
+
+  describe('validRange', () => {
+    it('should return true for valid ranges', () => {
+      expect(resolver.validRange('^1.0.0')).toBe(true);
+      expect(resolver.validRange('~1.0.0')).toBe(true);
+      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+    });
+
+    it('should return false for invalid ranges', () => {
+      expect(resolver.validRange('not-a-version')).toBe(false);
+    });
+  });
+});
