+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { Marketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '"hello from plugin"',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should expose all service modules', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin with no dependencies', async () => {
+      const manifest = makeManifest({ entryPoint: '2 + 2' });
+      const result = await marketplace.installPlugin(manifest);
+
+      expect(result.resolvedDependencies).toEqual([]);
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe(4);
+    });
+
+    it('should register the plugin in the registry after install', async () => {
+      const manifest = makeManifest();
+      await marketplace.installPlugin(manifest);
+
+      const registered = marketplace.registry.get('test-plugin');
+      expect(registered).not.toBeNull();
+      expect(registered?.name).toBe('test-plugin');
+    });
+
+    it('should resolve dependencies during install', async () => {
+      // First register the dependency
+      marketplace.registry.register(makeManifest({
+        name: 'dep-plugin',
+        version: '1.0.0',
+        entryPoint: '"dep loaded"',
+      }));
+      marketplace.registry.register(makeManifest({
+        name: 'dep-plugin',
+        version: '1.2.0',
+        entryPoint: '"dep loaded"',
+      }));
+
+      const manifest = makeManifest({
+        name: 'main-plugin',
+        dependencies: { 'dep-plugin': '^1.0.0' },
+        entryPoint: '"main loaded"',
+      });
+
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-plugin');
+      expect(result.resolvedDependencies[0].version).toBe('1.2.0');
+    });
+
+    it('should reject plugins with circular dependencies', async () => {
+      // Register A which depends on B
+      marketplace.registry.register(makeManifest({
+        name: 'A',
+        version: '1.0.0',
+        dependencies: { B: '^1.0.0' },
+      }));
+
+      // Now install B which depends on A - creates circular dep
+      const manifest = makeManifest({
+        name: 'B',
+        version: '1.0.0',
+        dependencies: { A: '^1.0.0' },
+        entryPoint: '"B loaded"',
+      });
+
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency');
+    });
+
+    it('should reject plugin with missing name', async () => {
+      const manifest = makeManifest({ name: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');
+    });
+
+    it('should reject plugin with missing version', async () => {
+      const manifest = makeManifest({ version: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');
+    });
+
+    it('should reject plugin with missing entryPoint', async () => {
+      const manifest = makeManifest({ entryPoint: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('entryPoint');
+    });
+
+    it('should handle plugin execution errors', async () => {
+      const manifest = makeManifest({
+        entryPoint: 'throw new Error("plugin crash")',
+      });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.executionResult.success).toBe(false);
+      expect(result.executionResult.error).toBe('plugin crash');
+    });
+  });
+});
