+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set<number>(gates.map((_, i) => i));
+
+  let progress = true;
+  while (progress && remaining.size > 0) {
+    progress = false;
+    for (const i of remaining) {
+      const g = gates[i];
+      if (wires[g.in1] !== undefined && wires[g.in2] !== undefined) {
+        const a = wires[g.in1];
+        const b = wires[g.in2];
+        let result: number;
+        switch (g.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[g.out] = result;
+        remaining.delete(i);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 swapped output wires in a broken ripple-carry adder circuit.
+ *
+ * We structurally trace the ripple-carry adder bit by bit, fixing swaps
+ * as we discover them so the chain can continue correctly.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Work on a copy so we don't mutate the caller's gates
+  gates = gates.map((g) => ({ ...g }));
+
+  // Build lookup maps
+  const gateByOut = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOut.set(g.out, g);
+  }
+
+  // Find the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+  const finalZ = `z${String(numBits).padStart(2, '0')}`;
+
+  function isXYInput(w: string): boolean {
+    return /^[xy]\d+$/.test(w);
+  }
+
+  // Helper: find a gate with given op and input pair (order-independent)
+  function findGate(op: Gate['op'], a: string, b: string): Gate | undefined {
+    for (const g of gates) {
+      if (g.op === op && ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Helper: find a gate with given op that has at least one input matching
+  function findGateWithInput(op: Gate['op'], input: string, exclude?: Gate): Gate | undefined {
+    for (const g of gates) {
+      if (g.op === op && g !== exclude && (g.in1 === input || g.in2 === input)) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Collect all consumers of each wire
+  function getConsumers(wire: string): Gate[] {
+    return gates.filter((g) => g.in1 === wire || g.in2 === wire);
+  }
+
+  const swapped = new Set<string>();
+
+  function doSwap(wireA: string, wireB: string): void {
+    const gA = gateByOut.get(wireA)!;
+    const gB = gateByOut.get(wireB)!;
+    gA.out = wireB;
+    gB.out = wireA;
+    gateByOut.set(wireA, gB);
+    gateByOut.set(wireB, gA);
+    swapped.add(wireA);
+    swapped.add(wireB);
+  }
+
+  let carry: string | undefined;
+
+  for (let i = 0; i < numBits; i++) {
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+
+    if (i === 0) {
+      // Half adder
+      const xorGate = findGate('XOR', xi, yi);
+      const andGate = findGate('AND', xi, yi);
+
+      if (!xorGate || !andGate) continue;
+
+      if (xorGate.out !== zi) {
+        doSwap(xorGate.out, zi);
+      }
+
+      // Validate carry: it should not be a z wire (except the final z)
+      carry = andGate.out;
+      if (carry.startsWith('z') && carry !== finalZ) {
+        // Carry is swapped with a z wire. The z wire's gate should produce the carry.
+        // Find what the z-named gate should be
+        const zGate = gateByOut.get(carry);
+        if (zGate) {
+          // This z wire's correct producer should be an XOR gate for that bit
+          // The AND carry ended up on a z wire - swap them
+          // We need to figure out what the carry should be.
+          // Look at what uses carry as input in the correct structure:
+          // carry is used as input to XOR (sum) and AND (propagate) of the next bit.
+          // The wire that is currently at the carry position is a z wire.
+          // This will be caught when we process the next bit.
+        }
+      }
+    } else {
+      // Full adder for bit i
+      const xXOR = findGate('XOR', xi, yi);
+      if (!xXOR || !carry) continue;
+
+      let ti = xXOR.out;
+
+      // Find the sum XOR gate: ti XOR carry -> zi
+      let sumGate = findGate('XOR', ti, carry);
+
+      if (!sumGate) {
+        // Either ti or carry is wrong.
+        // Try to find what uses carry as XOR input (the sum XOR for this bit)
+        const xorWithCarry = findGateWithInput('XOR', carry, xXOR);
+        // Try to find what uses ti as XOR input (should be non-xy XOR)
+        const xorWithTi = findGateWithInput('XOR', ti, xXOR);
+
+        if (xorWithCarry) {
+          // There is an XOR using carry. Its other input should be ti.
+          const otherInput = xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;
+          doSwap(ti, otherInput);
+          ti = otherInput;
+          sumGate = xorWithCarry;
+        } else if (xorWithTi) {
+          // There is an XOR using ti. Its other input should be carry.
+          const otherInput = xorWithTi.in1 === ti ? xorWithTi.in2 : xorWithTi.in1;
+          doSwap(carry, otherInput);
+          carry = otherInput;
+          sumGate = xorWithTi;
+        } else {
+          // Both ti and carry don't appear in any non-xy XOR.
+          // This can happen if carry was swapped to a z wire that isn't used as input.
+          // Check if carry is a z wire
+          if (carry.startsWith('z')) {
+            // The actual carry value is somewhere else.
+            // The gate that outputs zi should be an XOR. Check what gate outputs zi.
+            const ziGate = gateByOut.get(zi);
+            if (ziGate && ziGate.op === 'XOR' && !isXYInput(ziGate.in1) && !isXYInput(ziGate.in2)) {
+              // This XOR uses two non-xy inputs. One should be ti, the other the real carry.
+              const realCarry = ziGate.in1 === ti ? ziGate.in2 : ziGate.in1;
+              if (realCarry !== ti) {
+                doSwap(carry, realCarry);
+                carry = realCarry;
+                sumGate = ziGate;
+              }
+            }
+          }
+          if (!sumGate) continue;
+        }
+      }
+
+      // sumGate should output zi
+      if (sumGate.out !== zi) {
+        doSwap(sumGate.out, zi);
+      }
+
+      // Generate: xi AND yi -> a_i
+      const genGate = findGate('AND', xi, yi);
+      // Propagate: ti AND carry -> b_i
+      const propGate = findGate('AND', ti, carry);
+
+      if (!genGate || !propGate) continue;
+
+      // Carry out: a_i OR b_i -> c_i
+      const carryGate = findGate('OR', genGate.out, propGate.out);
+
+      if (!carryGate) {
+        // One of genGate.out or propGate.out is swapped
+        let orGate: Gate | undefined;
+
+        // Check genGate.out first
+        orGate = findGateWithInput('OR', genGate.out);
+        if (orGate) {
+          const wrongInput = orGate.in1 === genGate.out ? orGate.in2 : orGate.in1;
+          doSwap(propGate.out, wrongInput);
+          carry = orGate.out;
+        } else {
+          // Try propGate.out
+          orGate = findGateWithInput('OR', propGate.out);
+          if (orGate) {
+            const wrongInput = orGate.in1 === propGate.out ? orGate.in2 : orGate.in1;
+            doSwap(genGate.out, wrongInput);
+            carry = orGate.out;
+          }
+        }
+      } else {
+        carry = carryGate.out;
+      }
+    }
+  }
+
+  // The final z output should be the last carry
+  if (carry && carry !== finalZ && gateByOut.has(carry) && gateByOut.has(finalZ)) {
+    doSwap(carry, finalZ);
+  }
+
+  return [...swapped].sort();
+}
