esult: number;\n        switch (g.op) {\n          case 'AND':\n            result = a & b;\n            break;\n          case 'OR':\n            result = a | b;\n            break;\n          case 'XOR':\n            result = a ^ b;\n            break;\n        }\n        wires[g.out] = result;\n        remaining.delete(i);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 swapped output wires in a broken ripple-carry adder circuit.\n *\n * Strategy: A correct ripple-carry adder for bit i (i >= 1) has these gates:\n *   XOR: x_i XOR y_i -> t_i         (partial sum)\n *   XOR: t_i XOR c_{i-1} -> z_i     (final sum = output bit)\n *   AND: x_i AND y_i -> a_i          (generate)\n *   AND: t_i AND c_{i-1} -> b_i      (propagate carry)\n *   OR:  a_i OR b_i -> c_i           (carry out)\n *\n * For bit 0 (half adder):\n *   XOR: x00 XOR y00 -> z00\n *   AND: x00 AND y00 -> c00\n *\n * The highest z output is the final carry.\n *\n * We structurally verify each bit's adder stage and detect anomalies.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup maps\n  const gateByOut = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOut.set(g.out, g);\n  }\n\n  // Find the number of input bits by scanning for x## wires\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  // Helper: find a gate with given op and input pair (order-independent)\n  function findGate(\n    op: Gate['op'],\n    a: string,\n    b: string,\n  ): Gate | undefined {\n    for (const g of gates) {\n      if (g.op === op) {\n        if (\n          (g.in1 === a && g.in2 === b) ||\n          (g.in1 === b && g.in2 === a)\n        ) {\n          return g;\n        }\n      }\n    }\n    return undefined;\n  }\n\n  // We'll collect swapped wires\n  const swapped = new Set<string>();\n\n  // Swap two gate outputs\n  function doSwap(wireA: string, wireB: string): void {\n    const gA = gateByOut.get(wireA)!;\n    const gB = gateByOut.get(wireB)!;\n    // Exchange out fields\n    gA.out = wireB;\n    gB.out = wireA;\n    gateByOut.set(wireA, gB);\n    gateByOut.set(wireB, gA);\n    swapped.add(wireA);\n    swapped.add(wireB);\n  }\n\n  // Trace the adder structure bit-by-bit\n  let carry: string | undefined;\n\n  for (let i = 0; i < numBits; i++) {\n    const xi = `x${String(i).padStart(2, '0')}`;\n    const yi = `y${String(i).padStart(2, '0')}`;\n    const zi = `z${String(i).padStart(2, '0')}`;\n\n    if (i === 0) {\n      // Half adder: XOR -> z00, AND -> c00\n      const xorGate = findGate('XOR', xi, yi);\n      const andGate = findGate('AND', xi, yi);\n\n      if (xorGate && andGate) {\n        // xorGate should output z00\n        if (xorGate.out !== zi) {\n          // The xor gate's output is wrong; it and z00 are swapped\n          doSwap(xorGate.out, zi);\n        }\n        carry = andGate.out;\n        // If carry == some z##, that's also a swap we'll catch later\n      }\n    } else {\n      // Full adder for bit i\n      // Step 1: xXOR = xi XOR yi -> t_i\n      const xXOR = findGate('XOR', xi, yi);\n      if (!xXOR || !carry) {\n        // Something is very wrong; skip\n        continue;\n      }\n\n      let ti = xXOR.out;\n\n      // Step 2: sumGate = t_i XOR carry -> z_i\n      let sumGate = findGate('XOR', ti, carry);\n\n      if (!sumGate) {\n        // t_i or carry might be swapped.\n        // Since carry was validated from the previous stage, t_i is likely swapped.\n        // Look for an XOR gate that uses carry as one input and whose other input is not t_i.\n        // That other input's wire should have been t_i => t_i is swapped with that wire.\n        let foundOtherXOR: Gate | undefined;\n        for (const g of gates) {\n          if (\n            g.op === 'XOR