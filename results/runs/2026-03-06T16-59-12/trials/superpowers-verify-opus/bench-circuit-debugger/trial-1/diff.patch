rally verify each bit's adder stage and detect anomalies.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup maps\n  const gateByOut = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOut.set(g.out, g);\n  }\n\n  // Find the number of input bits by scanning for x## wires\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  // Helper: find a gate with given op and input pair (order-independent)\n  function findGate(\n    op: Gate['op'],\n    a: string,\n    b: string,\n  ): Gate | undefined {\n    for (const g of gates) {\n      if (g.op === op) {\n        if (\n          (g.in1 === a && g.in2 === b) ||\n          (g.in1 === b && g.in2 === a)\n        ) {\n          return g;\n        }\n      }\n    }\n    return undefined;\n  }\n\n  // We'll collect swapped wires\n  const swapped = new Set<string>();\n\n  // Swap two gate outputs\n  function doSwap(wireA: string, wireB: string): void {\n    const gA = gateByOut.get(wireA)!;\n    const gB = gateByOut.get(wireB)!;\n    // Exchange out fields\n    gA.out = wireB;\n    gB.out = wireA;\n    gateByOut.set(wireA, gB);\n    gateByOut.set(wireB, gA);\n    swapped.add(wireA);\n    swapped.add(wireB);\n  }\n\n  // Trace the adder structure bit-by-bit\n  let carry: string | undefined;\n\n  for (let i = 0; i < numBits; i++) {\n    const xi = `x${String(i).padStart(2, '0')}`;\n    const yi = `y${String(i).padStart(2, '0')}`;\n    const zi = `z${String(i).padStart(2, '0')}`;\n\n    if (i === 0) {\n      // Half adder: XOR -> z00, AND -> c00\n      const xorGate = findGate('XOR', xi, yi);\n      const andGate = findGate('AND', xi, yi);\n\n      if (xorGate && andGate) {\n        // xorGate should output z00\n        if (xorGate.out !== zi) {\n          // The xor gate's output is wrong