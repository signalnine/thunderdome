n2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      // Bit 2\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      // Bit 3\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n    // 2 = 0010, 3 = 0011\n    const inputs: Record<string, number> = {\n      x00: 0, x01: 1, x02: 0, x03: 0, // X = 2\n      y00: 1, y01: 1, y02: 0, y03: 0, // Y = 3\n    };\n    const result = simulate(gates, inputs);\n    // 5 = 0101\n    expect(result.z00).toBe(1);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Helper to build a correct N-bit adder\n  function buildAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < numBits; i++) {\n      const pad = String(i).padStart(2, '0');\n      const prevPad = String(i - 1).padStart(2, '0');\n      gates.push({ op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` });\n      gates.push({ op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` });\n      gates.push({ op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` });\n      gates.push({ op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` });\n      gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });\n    }\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], w1: string, w2: string) {\n    const g1 = gates.find((g) => g.out === w1)!;\n    const g2 = gates.find((g) => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n  }\n\n  it('should find swapped wires in a small adder', () => {\n    const correctGates = buildAdder(4);\n    const swappedGates = correctGates.map((g) => ({ ...g }));\n    swapOutputs(swappedGates, 'z01', 'a01');\n    swapOutputs(swappedGates, 't02', 'b02');\n    swapOutputs(swappedGates, 'z03', 'c02');\n    swapOutputs(swappedGates, 'c03', 'a03');\n\n    const result = findSwappedWires(swappedGates);\n    expect(result).toEqual(\n      ['a01', 'a03', 'b02', 'c02', 'c03', 't02', 'z01', 'z03'].sort(),\n    );\n  });\n});\n","structuredPatch":[{"oldStart":109,"oldLines":4,"newStart":109,"newLines":51,"lines":["       ['a01', 'a03', 'b02', 'c02', 'c03', 't02', 'z01', 'z03'].sort(),","     );","   });","+","+  it('should find swaps involving z00 and carry at bit 0', () => {","+    const correctGates = buildAdder(10);","+    const swappedGates = correctGates.map((g) => ({ ...g }));","+    // Swap z00 with c00 (half adder outputs)","+    swapOutputs(swappedGates, 'z00', 'c00');","+    // Swap z05 with t05","+    swapOutputs(swappedGates, 'z05', 't05');","+    // Swap a03 with b03","+    swapOutputs(swappedGates, 'a03', 'b03');","+    // Swap c08 with z09","+    swapOutputs(swappedGates, 'c08', 'z09');","+","+    const result = findSwappedWires(swappedGates);","+    expect(result).toEqual(","+      ['z00', 'c00', 'z05', 't05', 'a03', 'b03', 'c08', 'z09'].sort(),","+    );","+  });","+","+  it('should handle a large 45-bit adder with swaps', () => {","+    const correctGates = buildAdder(45);","+    const swappedGates = correctGates.map((g) => ({ ...g }));","+","+    swapOutputs(swappedGates, 'z10', 'a10');","+    swapOutputs(swappedGates, 't20', 'b20');