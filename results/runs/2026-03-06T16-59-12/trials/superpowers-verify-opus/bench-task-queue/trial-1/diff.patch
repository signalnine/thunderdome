+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01VfATsVDmH73FVhizWmqMD7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016XbY2KNXcqu5Y6EZjNG74A","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskStatus,\n  TaskOptions,\n  DeadLetterEntry,\n  ProgressCallback,\n  Schedule,\n  Middleware,\n  TaskHandler,\n  ConcurrencySettings,\n  ShutdownOptions,\n  ShutdownResult,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\nconst DEFAULT_PRIORITY = 5;\nconst DEFAULT_MAX_RETRIES = 3;\nconst DEFAULT_BACKOFF_DELAY = 1000;\n\nexport class TaskQueue {\n  // Storage\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, Set<string>> = new Map();\n  private deadLetterQueues: Map<string, DeadLetterEntry[]> = new Map();\n\n  // Concurrency\n  private concurrencyLimits: Map<string, number | null> = new Map();\n\n  // Progress subscriptions\n  private progressSubscriptions: Map<string, Set<ProgressCallback>> = new Map();\n\n  // Recurring schedules\n  private schedules: Map<string, Schedule> = new Map();\n\n  // Middleware\n  private middlewareStacks: Map<string, Middleware[]> = new Map();\n  private handlers: Map<string, TaskHandler> = new Map();\n\n  // Shutdown\n  private isShuttingDown = false;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n\n  // Sequence counter for FIFO ordering\n  private sequenceCounter = 0;\n\n  // ============================================================\n  // Phase 1: Basic FIFO Queue\n  // ============================================================\n\n  addTask<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: queue system is shutting down');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    // Validate priority\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Handle delay/availableAt\n    const now = new Date();\n    let availableAt = now;\n    if (options?.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Validate dependencies\n    const dependencies = options?.dependencies ?? [];\n    if (dependencies.length > 0) {\n      // Check all dependencies exist\n      for (const depId of dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n\n      // Detect circular dependencies\n      this.detectCircularDependencies(dependencies);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: dependencies.length > 0 ? 'blocked' : 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failureCount: 0,\n      dependencies: [...dependencies],\n      resolvedDependencies: new Set<string>(),\n      progress: 0,\n      sequenceNumber: this.sequenceCounter++,\n    };\n\n    // Check if all dependencies are already completed\n    if (task.status === 'blocked') {\n      const allResolved = dependencies.every(depId => {\n        const depTask = this.tasks.get(depId);\n        return depTask && depTask.status === 'completed';\n      });\n      if (allResolved) {\n        task.status = 'pending';\n        task.resolvedDependencies = new Set(dependencies);\n      } else {\n        // Mark already-completed ones as resolved\n        for (const depId of dependencies) {\n          const depTask = this.tasks.get(depId);\n          if (depTask && depTask.status === 'completed') {\n            task.resolvedDependencies.add(depId);\n          }\n        }\n      }\n    }\n\n    this.tasks.set(task.id, task as Task);\n\n    // Ensure queue exists\n    if (!this.queues.has(queueName)) {\n      this.queues.set(queueName, new Set());\n    }\n    this.queues.get(queueName)!.add(task.id);\n\n    return task;\n  }\n\n  getNext(queueName?: string): Task | null {\n    const queue = queueName ?? DEFAULT_QUEUE;\n\n    const taskIds = this.queues.get(queue);\n    if (!taskIds || taskIds.size === 0) {\n      return null;\n    }\n\n    // Check concurrency limit\n    const concurrency = this.getConcurrency(queue);\n    if (concurrency.limit !== null && concurrency.active >= concurrency.limit) {\n      return null;\n    }\n\n    const now = new Date();\n\n    // Find all eligible pending tasks\n    const candidates: Task[] = [];\n    for (const taskId of taskIds) {\n      const task = this.tasks.get(taskId);\n      if (!task) continue;\n      if (task.status !== 'pending') continue;\n      if (task.availableAt > now) continue;\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) {\n      return null;\n    }\n\n    // Sort by: priority (asc), availableAt (asc), sequenceNumber (asc)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const aTime = a.availableAt.getTime();\n      const bTime = b.availableAt.getTime();\n      if (aTime !== bTime) return aTime - bTime;\n      return a.sequenceNumber - b.sequenceNumber;\n    });\n\n    const selected = candidates[0];\n    selected.status = 'processing';\n    selected.attempts++;\n\n    return selected;\n  }\n\n  pendingCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const taskIds = this.queues.get(queue);\n    if (!taskIds) return 0;\n\n    let count = 0;\n    for (const taskId of taskIds) {\n      const task = this.tasks.get(taskId);\n      if (task && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ============================================================\n  // Phase 2: Named Queues\n  // ============================================================\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ============================================================\n  // Phase 5: Retry with Backoff / Task Completion\n  // ============================================================\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks can now be unblocked\n    this.checkDependents(taskId);\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n    task.failureCount++;\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // All retries exhausted\n      task.status = 'failed';\n\n      // Move to dead letter queue\n      this.addToDeadLetterQueue(task, error ?? 'Unknown error');\n    }\n  }\n\n  // ============================================================\n  // Phase 6: Dead Letter Queue\n  // ============================================================\n\n  private addToDeadLetterQueue(task: Task, error: string): void {\n    const queueName = task.queue;\n    if (!this.deadLetterQueues.has(queueName)) {\n      this.deadLetterQueues.set(queueName, []);\n    }\n\n    const entry: DeadLetterEntry = {\n      task,\n      error,\n      failureCount: task.failureCount,\n      deadLetteredAt: new Date(),\n    };\n\n    this.deadLetterQueues.get(queueName)!.push(entry);\n  }\n\n  getDeadLetterTasks(queueName?: string): DeadLetterEntry[] {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    return [...(this.deadLetterQueues.get(queue) ?? [])];\n  }\n\n  requeueDeadLetterTask(taskId: string): Task | null {\n    // Find the task in any DLQ\n    for (const [queueName, entries] of this.deadLetterQueues) {\n      const index = entries.findIndex(e => e.task.id === taskId);\n      if (index !== -1) {\n        const entry = entries[index];\n        entries.splice(index, 1);\n\n        const task = entry.task;\n        task.status = 'pending';\n        task.attempts = 0;\n        task.failureCount = 0;\n        task.error = undefined;\n        task.progress = 0;\n        task.progressMessage = undefined;\n        task.availableAt = new Date();\n\n        // Make sure task is in queue set\n        if (!this.queues.has(queueName)) {\n          this.queues.set(queueName, new Set());\n        }\n        this.queues.get(queueName)!.add(task.id);\n\n        return task;\n      }\n    }\n    return null;\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    this.deadLetterQueues.set(queue, []);\n  }\n\n  // ============================================================\n  // Phase 7: Task Dependencies\n  // ============================================================\n\n  private detectCircularDependencies(dependencyIds: string[]): void {\n    // BFS/DFS from each dependency to see if it would create a cycle\n    // Since we're adding a NEW task that depends on these, we need to check\n    // that none of the dependencies (transitively) depend on each other in\n    // a way that would create a cycle. Actually, since the new task doesn't\n    // exist yet, it can't be referenced by any existing tasks. So circular\n    // dependency detection only applies when an existing task would be in the\n    // chain. The new task has no ID yet, so no one can depend on it.\n    // Therefore, direct circular deps are impossible for a new task.\n    // But we still need to verify that the dependencies themselves don't form\n    // invalid chains.\n\n    // Actually, the main concern is: if task A depends on [B, C], and B depends on [C],\n    // that's fine. But if somehow we had A -> B -> A, that's circular. Since A is new and\n    // has no ID yet, no existing task can reference it. So circular dependencies at creation\n    // time for a brand new task are impossible.\n    //\n    // However, if dependencyIds themselves contain circular references among existing tasks,\n    // that would have been caught when those tasks were created. So we're fine.\n    //\n    // The real check needed: are any dependency IDs pointing to tasks that are themselves\n    // blocked on tasks that haven't completed? That's fine - it just means this task waits\n    // longer. No circularity possible with new tasks since they have no dependents yet.\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } | null {\n    const task = this.tasks.get(taskId);\n    if (!task) return null;\n\n    const resolved = Array.from(task.resolvedDependencies);\n    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n\n    return {\n      dependencies: [...task.dependencies],\n      resolved,\n      pending,\n    };\n  }\n\n  private checkDependents(completedTaskId: string): void {\n    // Find all tasks that depend on the completed task\n    for (const [, task] of this.tasks) {\n      if (task.status !== 'blocked') continue;\n      if (!task.dependencies.includes(completedTaskId)) continue;\n\n      task.resolvedDependencies.add(completedTaskId);\n\n      // Check if all dependencies are resolved\n      const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n      if (allResolved) {\n        task.status = 'pending';\n      }\n    }\n  }\n\n  // ============================================================\n  // Phase 8: Concurrency Control\n  // ============================================================\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName?: string): ConcurrencySettings {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const limit = this.concurrencyLimits.get(queue) ?? null;\n\n    let active = 0;\n    const taskIds = this.queues.get(queue);\n    if (taskIds) {\n      for (const taskId of taskIds) {\n        const task = this.tasks.get(taskId);\n        if (task && task.status === 'processing') {\n          active++;\n        }\n      }\n    }\n\n    return { limit, active };\n  }\n\n  // ============================================================\n  // Phase 9: Progress Tracking and Cancellation\n  // ============================================================\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in status: ${task.status}`);\n    }\n\n    task.progress = Math.max(0, Math.min(100, progress));\n    task.progressMessage = message;\n\n    // Notify subscribers\n    const subs = this.progressSubscriptions.get(taskId);\n    if (subs) {\n      for (const callback of subs) {\n        callback(task.progress, task.progressMessage);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } | null {\n    const task = this.tasks.get(taskId);\n    if (!task) return null;\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    if (!this.progressSubscriptions.has(taskId)) {\n      this.progressSubscriptions.set(taskId, new Set());\n    }\n    this.progressSubscriptions.get(taskId)!.add(callback);\n\n    // Return unsubscribe function\n    return () => {\n      const subs = this.progressSubscriptions.get(taskId);\n      if (subs) {\n        subs.delete(callback);\n        if (subs.size === 0) {\n          this.progressSubscriptions.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancel(taskId: string): boolean {\n    const task = this.tasks.get(taskId);\n    if (!task) return false;\n\n    if (task.status === 'pending' || task.status === 'blocked') {\n      task.status = 'cancelled';\n      // Remove from queue\n      const queueTasks = this.queues.get(task.queue);\n      if (queueTasks) {\n        queueTasks.delete(taskId);\n      }\n      return true;\n    }\n\n    if (task.status === 'processing') {\n      task.status = 'cancelled';\n      // Set maxRetries to 0 to prevent retrying\n      task.maxRetries = 0;\n      return true;\n    }\n\n    return false;\n  }\n\n  // ============================================================\n  // Phase 10: Recurring Tasks\n  // ============================================================\n\n  addSchedule(\n    id: string,\n    cron: string,\n    queue: string,\n    payload: unknown,\n    taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>\n  ): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add schedules: queue system is shutting down');\n    }\n\n    // Validate cron expression\n    this.parseCron(cron);\n\n    const schedule: Schedule = {\n      id,\n      cron,\n      queue,\n      payload,\n      taskOptions,\n    };\n\n    this.schedules.set(id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(id: string): boolean {\n    return this.schedules.delete(id);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const createdTasks: Task[] = [];\n\n    for (const [, schedule] of this.schedules) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.addTask(schedule.payload, {\n          queue: schedule.queue,\n          ...schedule.taskOptions,\n        });\n        createdTasks.push(task as Task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  private parseCron(cron: string): { minuteInterval: number | null; minute: number; hour: number } {\n    const parts = cron.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${cron}`);\n    }\n\n    const [minutePart, hourPart, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Validate that day-of-month, month, day-of-week are all wildcards\n    if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {\n      // Allow 0 for specific values in hour/day contexts\n    }\n\n    const result = { minuteInterval: null as number | null, minute: -1, hour: -1 };\n\n    // Parse minute field\n    if (minutePart.startsWith('*/')) {\n      result.minuteInterval = parseInt(minutePart.slice(2), 10);\n      if (isNaN(result.minuteInterval) || result.minuteInterval <= 0) {\n        throw new Error(`Invalid cron expression: ${cron}`);\n      }\n    } else {\n      result.minute = parseInt(minutePart, 10);\n      if (isNaN(result.minute) || result.minute < 0 || result.minute > 59