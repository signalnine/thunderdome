+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01W1V35zuz7YtuGKhzboaPrS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01R4DWLjq7bzDvKLuPobao5S","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ============================================================\n  // Phase 1: Basic FIFO Queue\n  // ============================================================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = queue.addTask({ message: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = queue.addTask('task1');\n      const t2 = queue.addTask('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.addTask('first');\n      queue.addTask('second');\n      queue.addTask('third');\n\n      const t1 = queue.getNext();\n      const t2 = queue.getNext();\n      const t3 = queue.getNext();\n\n      expect(t1?.payload).toBe('first');\n      expect(t2?.payload).toBe('second');\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing state', () => {\n      queue.addTask('task');\n      const task = queue.getNext();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(queue.pendingCount()).toBe(0);\n      queue.addTask('a');\n      queue.addTask('b');\n      expect(queue.pendingCount()).toBe(2);\n      queue.getNext();\n      expect(queue.pendingCount()).toBe(1);\n    });\n\n    it('should track attempts on task retrieval', () => {\n      queue.addTask('task');\n      const task = queue.getNext();\n      expect(task?.attempts).toBe(1);\n    });\n  });\n\n  // ============================================================\n  // Phase 2: Named Queues\n  // ============================================================\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name specified', () => {\n      const task = queue.addTask('task');\n      expect(task.queue).toBe('default');\n    });\n\n    it('should support named queues', () => {\n      queue.addTask('email', { queue: 'emails' });\n      queue.addTask('sms', { queue: 'sms' });\n\n      const emailTask = queue.getNext('emails');\n      const smsTask = queue.getNext('sms');\n\n      expect(emailTask?.payload).toBe('email');\n      expect(smsTask?.payload).toBe('sms');\n    });\n\n    it('should keep named queues independent', () => {\n      queue.addTask('email1', { queue: 'emails' });\n      queue.addTask('default1');\n\n      expect(queue.pendingCount('emails')).toBe(1);\n      expect(queue.pendingCount()).toBe(1);\n\n      queue.getNext('emails');\n      expect(queue.pendingCount('emails')).toBe(0);\n      expect(queue.pendingCount()).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.addTask('a', { queue: 'q1' });\n      queue.addTask('b', { queue: 'q2' });\n      queue.addTask('c', { queue: 'q3' });\n\n      const names = queue.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n      expect(names).toContain('q3');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.getNext('nonexistent')).toBeNull();\n    });\n\n    it('should return null for empty queue', () => {\n      queue.addTask('task', { queue: 'test' });\n      queue.getNext('test');\n      expect(queue.getNext('test')).toBeNull();\n    });\n  });\n\n  // ============================================================\n  // Phase 3: Priority\n  // ============================================================\n  describe('Phase 3: Priority', () => {\n    it('should assign default priority of 5', () => {\n      const task = queue.addTask('task');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      queue.addTask('low', { priority: 10 });\n      queue.addTask('high', { priority: 1 });\n      queue.addTask('medium', { priority: 5 });\n\n      expect(queue.getNext()?.payload).toBe('high');\n      expect(queue.getNext()?.payload).toBe('medium');\n      expect(queue.getNext()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO order within same priority', () => {\n      queue.addTask('first', { priority: 5 });\n      queue.addTask('second', { priority: 5 });\n      queue.addTask('third', { priority: 5 });\n\n      expect(queue.getNext()?.payload).toBe('first');\n      expect(queue.getNext()?.payload).toBe('second');\n      expect(queue.getNext()?.payload).toBe('third');\n    });\n\n    it('should throw error for invalid priority', () => {\n      expect(() => queue.addTask('task', { priority: 0 })).toThrow();\n      expect(() => queue.addTask('task', { priority: 11 })).toThrow();\n      expect(() => queue.addTask('task', { priority: 1.5 })).toThrow();\n    });\n\n    it('should apply priority per queue', () => {\n      queue.addTask('q1-low', { queue: 'q1', priority: 10 });\n      queue.addTask('q1-high', { queue: 'q1', priority: 1 });\n      queue.addTask('q2-low', { queue: 'q2', priority: 10 });\n      queue.addTask('q2-high', { queue: 'q2', priority: 1 });\n\n      expect(queue.getNext('q1')?.payload).toBe('q1-high');\n      expect(queue.getNext('q2')?.payload).toBe('q2-high');\n    });\n  });\n\n  // ============================================================\n  // Phase 4: Delayed and Scheduled Tasks\n  // ============================================================\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should support delay in milliseconds', () => {\n      const task = queue.addTask('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should support specific availableAt time', () => {\n      const future = new Date(Date.now() + 10000);\n      const task = queue.addTask('scheduled', { availableAt: future });\n      expect(task.availableAt).toBe(future);\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should return non-delayed tasks over delayed tasks', () => {\n      queue.addTask('delayed', { delay: 5000, priority: 1 });\n      queue.addTask('immediate', { priority: 5 });\n\n      expect(queue.getNext()?.payload).toBe('immediate');\n    });\n\n    it('should return delayed tasks when available', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      queue.addTask('was-delayed', { availableAt: pastTime });\n\n      const task = queue.getNext();\n      expect(task?.payload).toBe('was-delayed');\n    });\n\n    it('should order available delayed tasks correctly', () => {\n      const now = Date.now();\n      queue.addTask('later', { availableAt: new Date(now - 100) });\n      queue.addTask('earlier', { availableAt: new Date(now - 200) });\n\n      expect(queue.getNext()?.payload).toBe('earlier');\n      expect(queue.getNext()?.payload).toBe('later');\n    });\n\n    it('should work with named queues', () => {\n      queue.addTask('delayed', { queue: 'test', delay: 5000 });\n      expect(queue.getNext('test')).toBeNull();\n    });\n  });\n\n  // ============================================================\n  // Phase 5: Retry with Backoff\n  // ============================================================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark task as completed', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n      queue.complete(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should mark task as failed', () => {\n      queue.addTask('task', { maxRetries: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('failed');\n      expect(t.error).toBe('error');\n    });\n\n    it('should retry failed task with backoff', () => {\n      queue.addTask('task', { maxRetries: 3, backoffDelay: 100 });\n\n      // First attempt\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('pending');\n      expect(t.attempts).toBe(1);\n      expect(t.failureCount).toBe(1);\n      // Should be delayed (100 * 2^0 = 100ms)\n      expect(t.availableAt.getTime()).toBeGreaterThan(Date.now() - 10);\n    });\n\n    it('should use exponential backoff', () => {\n      queue.addTask('task', { maxRetries: 5, backoffDelay: 100 });\n\n      // Attempt 1\n      let task = queue.getNext()!;\n      const beforeFail1 = Date.now();\n      queue.fail(task.id, 'error');\n      let t = queue.getTask(task.id)!;\n      // Delay: 100 * 2^0 = 100ms\n      expect(t.availableAt.getTime() - beforeFail1).toBeGreaterThanOrEqual(90);\n      expect(t.availableAt.getTime() - beforeFail1).toBeLessThan(200);\n\n      // Set available in past so we can get it again\n      t.availableAt = new Date(Date.now() - 1);\n\n      // Attempt 2\n      task = queue.getNext()!;\n      const beforeFail2 = Date.now();\n      queue.fail(task.id, 'error');\n      t = queue.getTask(task.id)!;\n      // Delay: 100 * 2^1 = 200ms\n      expect(t.availableAt.getTime() - beforeFail2).toBeGreaterThanOrEqual(190);\n      expect(t.availableAt.getTime() - beforeFail2).toBeLessThan(300);\n    });\n\n    it('should default to 3 max retries', () => {\n      const task = queue.addTask('task');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default to 1000ms backoff delay', () => {\n      const task = queue.addTask('task');\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      queue.addTask('task', { queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 10 });\n      const task = queue.getNext('myqueue')!;\n      queue.fail(task.id, 'err');\n\n      const t = queue.getTask(task.id)!;\n      expect(t.queue).toBe('myqueue');\n      expect(t.priority).toBe(2);\n    });\n\n    it('should remain failed after retries exhausted', () => {\n      queue.addTask('task', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('failed');\n    });\n  });\n\n  // ============================================================\n  // Phase 6: Dead Letter Queue\n  // ============================================================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move failed tasks to DLQ after retries exhausted', () => {\n      queue.addTask('task', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'final error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].error).toBe('final error');\n      expect(dlq[0].failureCount).toBe(1);\n    });\n\n    it('should retain error info in DLQ', () => {\n      queue.addTask('task', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'specific error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('specific error');\n    });\n\n    it('should support per-queue DLQs', () => {\n      queue.addTask('task1', { queue: 'q1', maxRetries: 1 });\n      queue.addTask('task2', { queue: 'q2', maxRetries: 1 });\n\n      const t1 = queue.getNext('q1')!;\n      const t2 = queue.getNext('q2')!;\n\n      queue.fail(t1.id, 'err1');\n      queue.fail(t2.id, 'err2');\n\n      expect(queue.getDeadLetterTasks('q1').length).toBe(1);\n      expect(queue.getDeadLetterTasks('q2').length).toBe(1);\n    });\n\n    it('should requeue dead-lettered tasks', () => {\n      queue.addTask('task', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      const requeued = queue.requeueDeadLetterTask(task.id)!;\n      expect(requeued).not.toBeNull();\n      expect(requeued.status).toBe('pending');\n      expect(requeued.attempts).toBe(0);\n      expect(requeued.failureCount).toBe(0);\n\n      expect(queue.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      queue.addTask('t1', { maxRetries: 1 });\n      queue.addTask('t2', { maxRetries: 1 });\n\n      queue.fail(queue.getNext()!.id, 'err');\n      queue.fail(queue.getNext()!.id, 'err');\n\n      expect(queue.getDeadLetterTasks().length).toBe(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks().length).toBe(0);\n    });\n  });\n\n  // ============================================================\n  // Phase 7: Task Dependencies\n  // ============================================================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = queue.addTask('dep');\n      const t2 = queue.addTask('dependent', { dependencies: [t1.id] });\n\n      expect(t2.status).toBe('blocked');\n      expect(queue.getNext()?.id).toBe(t1.id);\n      // The blocked task should not be returned\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const t1 = queue.addTask('dep');\n      queue.addTask('dependent', { dependencies: [t1.id] });\n\n      const retrieved = queue.getNext()!;\n      queue.complete(retrieved.id);\n\n      // Now the dependent should be available\n      const dependent = queue.getNext();\n      expect(dependent?.payload).toBe('dependent');\n    });\n\n    it('should handle multiple dependencies', () => {\n      const t1 = queue.addTask('dep1');\n      const t2 = queue.addTask('dep2');\n      queue.addTask('dependent', { dependencies: [t1.id, t2.id] });\n\n      // Complete first dep\n      queue.complete(queue.getNext()!.id);\n      // Dependent still blocked\n      expect(queue.getNext()?.payload).toBe('dep2');\n\n      // Complete second dep\n      queue.complete(queue.getNext()!.id);\n      // Now dependent is available\n      expect(queue.getNext()?.payload).toBe('dependent');\n    });\n\n    it('should throw error for non-existent dependency', () => {\n      expect(() => {\n        queue.addTask('task', { dependencies: ['nonexistent-id'] });\n      }).toThrow();\n    });\n\n    it('should not fail dependents when dependency fails', () => {\n      const dep = queue.addTask('dep', { maxRetries: 1 });\n      const dependent = queue.addTask('dependent', { dependencies: [dep.id] });\n\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      // Dependent remains blocked, not failed\n      const depTask = queue.getTask(dependent.id)!;\n      expect(depTask.status).toBe('blocked');\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = queue.addTask('dep1');\n      const dep2 = queue.addTask('dep2');\n      const dependent = queue.addTask('task', { dependencies: [dep1.id, dep2.id] });\n\n      const status = queue.getDependencyStatus(dependent.id)!;\n      expect(status.dependencies).toHaveLength(2);\n      expect(status.pending).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      queue.complete(queue.getNext()!.id);\n\n      const status2 = queue.getDependencyStatus(dependent.id)!;\n      expect(status2.resolved).toHaveLength(1);\n      expect(status2.pending).toHaveLength(1);\n    });\n\n    it('should handle already-completed dependencies', () => {\n      const dep = queue.addTask('dep');\n      const task = queue.getNext()!;\n      queue.complete(task.id);\n\n      const dependent = queue.addTask('dependent', { dependencies: [dep.id] });\n      expect(dependent.status).toBe('pending');\n    });\n  });\n\n  // ============================================================\n  // Phase 8: Concurrency Control\n  // ============================================================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should default to no concurrency limit', () => {\n      const conc = queue.getConcurrency();\n      expect(conc.limit).toBeNull();\n      expect(conc.active).toBe(0);\n    });\n\n    it('should enforce concurrency limit', () => {\n      queue.setConcurrency('default', 2);\n\n      queue.addTask('t1');\n      queue.addTask('t2');\n      queue.addTask('t3');\n\n      expect(queue.getNext()).not.toBeNull();\n      expect(queue.getNext()).not.toBeNull();\n      expect(queue.getNext()).toBeNull(); // limit reached\n    });\n\n    it('should free slot on completion', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.addTask('t1');\n      queue.addTask('t2');\n\n      const t1 = queue.getNext()!;\n      expect(queue.getNext()).toBeNull();\n\n      queue.complete(t1.id);\n      expect(queue.getNext()).not.toBeNull();\n    });\n\n    it('should free slot on failure', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.addTask('t1', { maxRetries: 1 });\n      queue.addTask('t2');\n\n      const t1 = queue.getNext()!;\n      expect(queue.getNext()).toBeNull();\n\n      queue.fail(t1.id, 'err');\n      const t2 = queue.getNext();\n      expect(t2).not.toBeNull();\n    });\n\n    it('should report active count', () => {\n      queue.addTask('t1');\n      queue.addTask('t2');\n\n      queue.getNext();\n      expect(queue.getConcurrency().active).toBe(1);\n\n      queue.getNext();\n      expect(queue.getConcurrency().active).toBe(2);\n    });\n\n    it('should respect priority with concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.addTask('low', { priority: 10 });\n      queue.addTask('high', { priority: 1 });\n\n      const task = queue.getNext()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ============================================================\n  // Phase 9: Progress Tracking and Cancellation\n  // ============================================================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should update and query progress', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      queue.updateProgress(task.id, 50, 'halfway');\n\n      const progress = queue.getProgress(task.id)!;\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should clamp progress between 0 and 100', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      queue.updateProgress(task.id, 150);\n      expect(queue.getProgress(task.id)!.progress).toBe(100);\n\n      queue.updateProgress(task.id, -10);\n      expect(queue.getProgress(task.id)!.progress).toBe(0);\n    });\n\n    it('should notify progress subscribers', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      const callback = vi.fn();\n      queue.onProgress(task.id, callback);\n\n      queue.updateProgress(task.id, 50, 'half');\n\n      expect(callback).toHaveBeenCalledWith(50, 'half');\n    });\n\n    it('should support unsubscribe', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      const callback = vi.fn();\n      const unsub = queue.onProgress(task.id, callback);\n\n      queue.updateProgress(task.id, 25);\n      expect(callback).toHaveBeenCalledTimes(1);\n\n      unsub();\n      queue.updateProgress(task.id, 50);\n      expect(callback).toHaveBeenCalledTimes(1);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = queue.addTask('task');\n      const cancelled = queue.cancel(task.id);\n\n      expect(cancelled).toBe(true);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      const cancelled = queue.cancel(task.id);\n      expect(cancelled).toBe(true);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not cancel completed tasks', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n      queue.complete(task.id);\n\n      expect(queue.cancel(task.id)).toBe(false);\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.addTask('task', { maxRetries: 3 });\n      const task = queue.getNext()!;\n      queue.cancel(task.id);\n\n      // Ensure task stays cancelled\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getTask(task.id)?.maxRetries).toBe(0);\n    });\n\n    it('should cancel blocked tasks', () => {\n      const dep = queue.addTask('dep');\n      const dependent = queue.addTask('task', { dependencies: [dep.id] });\n\n      const cancelled = queue.cancel(dependent.id);\n      expect(cancelled).toBe(true);\n      expect(queue.getTask(dependent.id)?.status).toBe('cancelled');\n    });\n  });\n\n  // ============================================================\n  // Phase 10: Recurring Tasks\n  // ============================================================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should add a schedule', () => {\n      const schedule = queue.addSchedule('job1', '*/5 * * * *', 'default', { type: 'report' });\n      expect(schedule.id).toBe('job1');\n      expect(schedule.cron).toBe('*/5 * * * *');\n    });\n\n    it('should list schedules', () => {\n      queue.addSchedule('job1', '*/5 * * * *', 'default', 'payload1');\n      queue.addSchedule('job2', '0 * * * *', 'default', 'payload2');\n\n      const schedules = queue.getSchedules();\n      expect(schedules).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      queue.addSchedule('job1', '*/5 * * * *', 'default', 'payload');\n      expect(queue.removeSchedule('job1')).toBe(true);\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should create tasks on tick for */N pattern', () => {\n      queue.addSchedule('job', '*/5 * * * *', 'default', 'recurring');\n\n      // Tick at a time that matches (minute divisible by 5)\n      const time = new Date('2024-01-01T12:10:00');\n      const tasks = queue.tick(time);\n\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toBe('recurring');\n    });\n\n    it('should not create duplicate tasks for same minute', () => {\n      queue.addSchedule('job', '*/5 * * * *', 'default', 'recurring');\n\n      const time = new Date('2024-01-01T12:10:00');\n      queue.tick(time);\n      const tasks2 = queue.tick(time);\n\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should handle hourly cron', () => {\n      queue.addSchedule('job', '0 * * * *', 'default', 'hourly');\n\n      const onHour = new Date('2024-01-01T13:00:00');\n      const offHour = new Date('2024-01-01T13:30:00');\n\n      expect(queue.tick(onHour)).toHaveLength(1);\n      expect(queue.tick(offHour)).toHaveLength(0);\n    });\n\n    it('should handle daily cron', () => {\n      queue.addSchedule('job', '0 0 * * *', 'default', 'daily');\n\n      const midnight = new Date('2024-01-01T00:00:00');\n      const noon = new Date('2024-01-01T12:00:00');\n\n      expect(queue.tick(midnight)).toHaveLength(1);\n      expect(queue.tick(noon)).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removed', () => {\n      queue.addSchedule('job', '*/5 * * * *', 'default', 'recurring');\n      queue.removeSchedule('job');\n\n      const time = new Date('2024-01-01T12:10:00');\n      expect(queue.tick(time)).toHaveLength(0);\n    });\n\n    it('should apply task options to recurring tasks', () => {\n      queue.addSchedule('job', '*/5 * * * *', 'emails', 'task', { priority: 2 });\n\n      const time = new Date('2024-01-01T12:10:00');\n      const tasks = queue.tick(time);\n\n      expect(tasks[0].queue).toBe('emails');\n      expect(tasks[0].priority).toBe(2);\n    });\n  });\n\n  // ============================================================\n  // Phase 11: Middleware Pipeline\n  // ============================================================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run handler on process', async () => {\n      const handler = vi.fn();\n      queue.setHandler('default', handler);\n\n      queue.addTask('task');\n      const task = queue.getNext()!;\n      await queue.process(task.id);\n\n      expect(handler).toHaveBeenCalledWith(task);\n    });\n\n    it('should run middleware before handler', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('middleware');\n        await next();\n      });\n      queue.setHandler('default', () => {\n        order.push('handler');\n      });\n\n      queue.addTask('task');\n      const task = queue.getNext()!;\n      await queue.process(task.id);\n\n      expect(order).toEqual(['middleware', 'handler']);\n    });\n\n    it('should run multiple middleware in order', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('mw1');\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push('mw2');\n        await next();\n      });\n      queue.setHandler('default', () => {\n        order.push('handler');\n      });\n\n      queue.addTask('task');\n      const task = queue.getNext()!;\n      await queue.process(task.id);\n\n      expect(order).toEqual(['mw1', 'mw2', 'handler']);\n    });\n\n    it('should skip handler if middleware does not call next', async () => {\n      const handler = vi.fn();\n\n      queue.use('default', async () => {\n        // Intentionally not calling next\n      });\n      queue.setHandler('default', handler);\n\n      queue.addTask('task');\n      const task = queue.getNext()!;\n      await queue.process(task.id);\n\n      expect(handler).not.toHaveBeenCalled();\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        (task.payload as Record<string, unknown>).modified = true;\n        await next();\n      });\n\n      const handler = vi.fn();\n      queue.setHandler('default', handler);\n\n      queue.addTask({ original: true });\n      const task = queue.getNext()!;\n      await queue.process(task.id);\n\n      expect(handler).toHaveBeenCalled();\n      const calledTask = handler.mock.calls[0][0];\n      expect(calledTask.payload.modified).toBe(true);\n    });\n\n    it('should fail task if middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      queue.addTask('task', { maxRetries: 1 });\n      const task = queue.getNext()!;\n\n      await expect(queue.process(task.id)).rejects.toThrow('middleware error');\n      expect(queue.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      const handler1 = vi.fn();\n      const handler2 = vi.fn();\n\n      queue.use('q1', async (task, next) => {\n        (task as Record<string, unknown>).q1 = true;\n        await next();\n      });\n      queue.setHandler('q1', handler1);\n      queue.setHandler('q2', handler2);\n\n      queue.addTask('t1', { queue: 'q1' });\n      queue.addTask('t2', { queue: 'q2' });\n\n      const t1 = queue.getNext('q1')!;\n      const t2 = queue.getNext('q2')!;\n\n      await queue.process(t1.id);\n      await queue.process(t2.id);\n\n      expect(handler1).toHaveBeenCalled();\n      expect(handler2).toHaveBeenCalled();\n    });\n  });\n\n  // ============================================================\n  // Phase 12: Graceful Shutdown\n  // ============================================================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should stop accepting new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.addTask('task')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately when no processing tasks', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      // Start shutdown in background\n      const shutdownPromise = queue.shutdown({ timeout: 5000 });\n\n      // Complete the task\n      queue.complete(task.id);\n\n      const result = await shutdownPromise;\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force cancel tasks after timeout', async () => {\n      queue.addTask('task');\n      queue.getNext();\n\n      const result = await queue.shutdown({ timeout: 50 });\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      const callback = vi.fn();\n      queue.onShutdown(callback);\n\n      await queue.shutdown();\n      expect(callback).toHaveBeenCalled();\n    });\n\n    it('should return same result on multiple shutdown calls', async () => {\n      const r1 = queue.shutdown();\n      const r2 = queue.shutdown();\n\n      const result1 = await r1;\n      const result2 = await r2;\n      expect(result1).toBe(result2);\n    });\n\n    it('should report shutdown duration', async () => {\n      const result = await queue.shutdown();\n      expect(typeof result.durationMs).toBe('number');\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should reject adding schedules after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.addSchedule('job', '*/5 * * * *', 'default', 'payload')).toThrow(/shutting down/);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":241,"cache_read_input_tokens":34401,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":241},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"77b6fef8-4f38-4e2c-be4a-9efaa031aac7","uuid":"0e662800-53e1-4d74-a375-129a1c57f0b6"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R4DWLjq7bzDvKLuPobao5S","type":"tool_result","content":"File created successfully at: /workspace/src/TaskQueue.test.ts"}]},"parent_tool_use_id":null,"session_id":"77b6fef8-4f38-4e2c-be4a-9efaa031aac7","uuid":"894ccc59-5e3d-44d2-a48e-b46ae641650b","tool_use_result":{"type":"create","filePath":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ============================================================\n  // Phase 1: Basic FIFO Queue\n  // ============================================================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = queue.addTask({ message: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = queue.addTask('task1');\n      const t2 = queue.addTask('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.addTask('first');\n      queue.addTask('second');\n      queue.addTask('third');\n\n      const t1 = queue.getNext();\n      const t2 = queue.getNext();\n      const t3 = queue.getNext();\n\n      expect(t1?.payload).toBe('first');\n      expect(t2?.payload).toBe('second');\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing state', () => {\n      queue.addTask('task');\n      const task = queue.getNext();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(queue.pendingCount()).toBe(0);\n      queue.addTask('a');\n      queue.addTask('b');\n      expect(queue.pendingCount()).toBe(2);\n      queue.getNext();\n      expect(queue.pendingCount()).toBe(1);\n    });\n\n    it('should track attempts on task retrieval', () => {\n      queue.addTask('task');\n      const task = queue.getNext();\n      expect(task?.attempts).toBe(1);\n    });\n  });\n\n  // ============================================================\n  // Phase 2: Named Queues\n  // ============================================================\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name specified', () => {\n      const task = queue.addTask('task');\n      expect(task.queue).toBe('default');\n    });\n\n    it('should support named queues', () => {\n      queue.addTask('email', { queue: 'emails' });\n      queue.addTask('sms', { queue: 'sms' });\n\n      const emailTask = queue.getNext('emails');\n      const smsTask = queue.getNext('sms');\n\n      expect(emailTask?.payload).toBe('email');\n      expect(smsTask?.payload).toBe('sms');\n    });\n\n    it('should keep named queues independent', () => {\n      queue.addTask('email1', { queue: 'emails' });\n      queue.addTask('default1');\n\n      expect(queue.pendingCount('emails')).toBe(1);\n      expect(queue.pendingCount()).toBe(1);\n\n      queue.getNext('emails');\n      expect(queue.pendingCount('emails')).toBe(0);\n      expect(queue.pendingCount()).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.addTask('a', { queue: 'q1' });\n      queue.addTask('b', { queue: 'q2' });\n      queue.addTask('c', { queue: 'q3' });\n\n      const names = queue.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n      expect(names).toContain('q3');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.getNext('nonexistent')).toBeNull();\n    });\n\n    it('should return null for empty queue', () => {\n      queue.addTask('task', { queue: 'test' });\n      queue.getNext('test');\n      expect(queue.getNext('test')).toBeNull();\n    });\n  });\n\n  // ============================================================\n  // Phase 3: Priority\n  // ============================================================\n  describe('Phase 3: Priority', () => {\n    it('should assign default priority of 5', () => {\n      const task = queue.addTask('task');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      queue.addTask('low', { priority: 10 });\n      queue.addTask('high', { priority: 1 });\n      queue.addTask('medium', { priority: 5 });\n\n      expect(queue.getNext()?.payload).toBe('high');\n      expect(queue.getNext()?.payload).toBe('medium');\n      expect(queue.getNext()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO order within same priority', () => {\n      queue.addTask('first', { priority: 5 });\n      queue.addTask('second', { priority: 5 });\n      queue.addTask('third', { priority: 5 });\n\n      expect(queue.getNext()?.payload).toBe('first');\n      expect(queue.getNext()?.payload).toBe('second');\n      expect(queue.getNext()?.payload).toBe('third');\n    });\n\n    it('should throw error for invalid priority', () => {\n      expect(() => queue.addTask('task', { priority: 0 })).toThrow();\n      expect(() => queue.addTask('task', { priority: 11 })).toThrow();\n      expect(() => queue.addTask('task', { priority: 1.5 })).toThrow();\n    });\n\n    it('should apply priority per queue', () => {\n      queue.addTask('q1-low', { queue: 'q1', priority: 10 });\n      queue.addTask('q1-high', { queue: 'q1', priority: 1 });\n      queue.addTask('q2-low', { queue: 'q2', priority: 10 });\n      queue.addTask('q2-high', { queue: 'q2', priority: 1 });\n\n      expect(queue.getNext('q1')?.payload).toBe('q1-high');\n      expect(queue.getNext('q2')?.payload).toBe('q2-high');\n    });\n  });\n\n  // ============================================================\n  // Phase 4: Delayed and Scheduled Tasks\n  // ============================================================\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should support delay in milliseconds', () => {\n      const task = queue.addTask('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should support specific availableAt time', () => {\n      const future = new Date(Date.now() + 10000);\n      const task = queue.addTask('scheduled', { availableAt: future });\n      expect(task.availableAt).toBe(future);\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should return non-delayed tasks over delayed tasks', () => {\n      queue.addTask('delayed', { delay: 5000, priority: 1 });\n      queue.addTask('immediate', { priority: 5 });\n\n      expect(queue.getNext()?.payload).toBe('immediate');\n    });\n\n    it('should return delayed tasks when available', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      queue.addTask('was-delayed', { availableAt: pastTime });\n\n      const task = queue.getNext();\n      expect(task?.payload).toBe('was-delayed');\n    });\n\n    it('should order available delayed tasks correctly', () => {\n      const now = Date.now();\n      queue.addTask('later', { availableAt: new Date(now - 100) });\n      queue.addTask('earlier', { availableAt: new Date(now - 200) });\n\n      expect(queue.getNext()?.payload).toBe('earlier');\n      expect(queue.getNext()?.payload).toBe('later');\n    });\n\n    it('should work with named queues', () => {\n      queue.addTask('delayed', { queue: 'test', delay: 5000 });\n      expect(queue.getNext('test')).toBeNull();\n    });\n  });\n\n  // ============================================================\n  // Phase 5: Retry with Backoff\n  // ============================================================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark task as completed', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n      queue.complete(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should mark task as failed', () => {\n      queue.addTask('task', { maxRetries: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('failed');\n      expect(t.error).toBe('error');\n    });\n\n    it('should retry failed task with backoff', () => {\n      queue.addTask('task', { maxRetries: 3, backoffDelay: 100 });\n\n      // First attempt\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('pending');\n      expect(t.attempts).toBe(1);\n      expect(t.failureCount).toBe(1);\n      // Should be delayed (100 * 2^0 = 100ms)\n      expect(t.availableAt.getTime()).toBeGreaterThan(Date.now() - 10);\n    });\n\n    it('should use exponential backoff', () => {\n      queue.addTask('task', { maxRetries: 5, backoffDelay: 100 });\n\n      // Attempt 1\n      let task = queue.getNext()!;\n      const beforeFail1 = Date.now();\n      queue.fail(task.id, 'error');\n      let t = queue.getTask(task.id)!;\n      // Delay: 100 * 2^0 = 100ms\n      expect(t.availableAt.getTime() - beforeFail1).toBeGreaterThanOrEqual(90);\n      expect(t.availableAt.getTime() - beforeFail1).toBeLessThan(200);\n\n      // Set available in past so we can get it again\n      t.availableAt = new Date(Date.now() - 1);\n\n      // Attempt 2\n      task = queue.getNext()!;\n      const beforeFail2 = Date.now();\n      queue.fail(task.id, 'error');\n      t = queue.getTask(task.id)!;\n      // Delay: 100 * 2^1 = 200ms\n      expect(t.availableAt.getTime() - beforeFail2).toBeGreaterThanOrEqual(190);\n      expect(t.availableAt.getTime() - beforeFail2).toBeLessThan(300);\n    });\n\n    it('should default to 3 max retries', () => {\n      const task = queue.addTask('task');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default to 1000ms backoff delay', () => {\n      const task = queue.addTask('task');\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      queue.addTask('task', { queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 10 });\n      const task = queue.getNext('myqueue')!;\n      queue.fail(task.id, 'err');\n\n      const t = queue.getTask(task.id)!;\n      expect(t.queue).toBe('myqueue');\n      expect(t.priority).toBe(2);\n    });\n\n    it('should remain failed after retries exhausted', () => {\n      queue.addTask('task', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('failed');\n    });\n  });\n\n  // ============================================================\n  // Phase 6: Dead Letter Queue\n  // ============================================================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move failed tasks to DLQ after retries exhausted', () => {\n      queue.addTask('task', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'final error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].error).toBe('final error');\n      expect(dlq[0].failureCount).toBe(1);\n    });\n\n    it('should retain error info in DLQ', () => {\n      queue.addTask('task', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'specific error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('specific error');\n    });\n\n    it('should support per-queue DLQs', () => {\n      queue.addTask('task1', { queue: 'q1', maxRetries: 1 });\n      queue.addTask('task2', { queue: 'q2', maxRetries: 1 });\n\n      const t1 = queue.getNext('q1')!;\n      const t2 = queue.getNext('q2')!;\n\n      queue.fail(t1.id, 'err1');\n      queue.fail(t2.id, 'err2');\n\n      expect(queue.getDeadLetterTasks('q1').length).toBe(1);\n      expect(queue.getDeadLetterTasks('q2').length).toBe(1);\n    });\n\n    it('should requeue dead-lettered tasks', () => {\n      queue.addTask('task', { maxRetries: 1, backoffDelay: 1 });\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      const requeued = queue.requeueDeadLetterTask(task.id)!;\n      expect(requeued).not.toBeNull();\n      expect(requeued.status).toBe('pending');\n      expect(requeued.attempts).toBe(0);\n      expect(requeued.failureCount).toBe(0);\n\n      expect(queue.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      queue.addTask('t1', { maxRetries: 1 });\n      queue.addTask('t2', { maxRetries: 1 });\n\n      queue.fail(queue.getNext()!.id, 'err');\n      queue.fail(queue.getNext()!.id, 'err');\n\n      expect(queue.getDeadLetterTasks().length).toBe(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks().length).toBe(0);\n    });\n  });\n\n  // ============================================================\n  // Phase 7: Task Dependencies\n  // ============================================================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = queue.addTask('dep');\n      const t2 = queue.addTask('dependent', { dependencies: [t1.id] });\n\n      expect(t2.status).toBe('blocked');\n      expect(queue.getNext()?.id).toBe(t1.id);\n      // The blocked task should not be returned\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const t1 = queue.addTask('dep');\n      queue.addTask('dependent', { dependencies: [t1.id] });\n\n      const retrieved = queue.getNext()!;\n      queue.complete(retrieved.id);\n\n      // Now the dependent should be available\n      const dependent = queue.getNext();\n      expect(dependent?.payload).toBe('dependent');\n    });\n\n    it('should handle multiple dependencies', () => {\n      const t1 = queue.addTask('dep1');\n      const t2 = queue.addTask('dep2');\n      queue.addTask('dependent', { dependencies: [t1.id, t2.id] });\n\n      // Complete first dep\n      queue.complete(queue.getNext()!.id);\n      // Dependent still blocked\n      expect(queue.getNext()?.payload).toBe('dep2');\n\n      // Complete second dep\n      queue.complete(queue.getNext()!.id);\n      // Now dependent is available\n      expect(queue.getNext()?.payload).toBe('dependent');\n    });\n\n    it('should throw error for non-existent dependency', () => {\n      expect(() => {\n        queue.addTask('task', { dependencies: ['nonexistent-id'] });\n      }).toThrow();\n    });\n\n    it('should not fail dependents when dependency fails', () => {\n      const dep = queue.addTask('dep', { maxRetries: 1 });\n      const dependent = queue.addTask('dependent', { dependencies: [dep.id] });\n\n      const task = queue.getNext()!;\n      queue.fail(task.id, 'error');\n\n      // Dependent remains blocked, not failed\n      const depTask = queue.getTask(dependent.id)!;\n      expect(depTask.status).toBe('blocked');\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = queue.addTask('dep1');\n      const dep2 = queue.addTask('dep2');\n      const dependent = queue.addTask('task', { dependencies: [dep1.id, dep2.id] });\n\n      const status = queue.getDependencyStatus(dependent.id)!;\n      expect(status.dependencies).toHaveLength(2);\n      expect(status.pending).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      queue.complete(queue.getNext()!.id);\n\n      const status2 = queue.getDependencyStatus(dependent.id)!;\n      expect(status2.resolved).toHaveLength(1);\n      expect(status2.pending).toHaveLength(1);\n    });\n\n    it('should handle already-completed dependencies', () => {\n      const dep = queue.addTask('dep');\n      const task = queue.getNext()!;\n      queue.complete(task.id);\n\n      const dependent = queue.addTask('dependent', { dependencies: [dep.id] });\n      expect(dependent.status).toBe('pending');\n    });\n  });\n\n  // ============================================================\n  // Phase 8: Concurrency Control\n  // ============================================================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should default to no concurrency limit', () => {\n      const conc = queue.getConcurrency();\n      expect(conc.limit).toBeNull();\n      expect(conc.active).toBe(0);\n    });\n\n    it('should enforce concurrency limit', () => {\n      queue.setConcurrency('default', 2);\n\n      queue.addTask('t1');\n      queue.addTask('t2');\n      queue.addTask('t3');\n\n      expect(queue.getNext()).not.toBeNull();\n      expect(queue.getNext()).not.toBeNull();\n      expect(queue.getNext()).toBeNull(); // limit reached\n    });\n\n    it('should free slot on completion', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.addTask('t1');\n      queue.addTask('t2');\n\n      const t1 = queue.getNext()!;\n      expect(queue.getNext()).toBeNull();\n\n      queue.complete(t1.id);\n      expect(queue.getNext()).not.toBeNull();\n    });\n\n    it('should free slot on failure', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.addTask('t1', { maxRetries: 1 });\n      queue.addTask('t2');\n\n      const t1 = queue.getNext()!;\n      expect(queue.getNext()).toBeNull();\n\n      queue.fail(t1.id, 'err');\n      const t2 = queue.getNext();\n      expect(t2).not.toBeNull();\n    });\n\n    it('should report active count', () => {\n      queue.addTask('t1');\n      queue.addTask('t2');\n\n      queue.getNext();\n      expect(queue.getConcurrency().active).toBe(1);\n\n      queue.getNext();\n      expect(queue.getConcurrency().active).toBe(2);\n    });\n\n    it('should respect priority with concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n\n      queue.addTask('low', { priority: 10 });\n      queue.addTask('high', { priority: 1 });\n\n      const task = queue.getNext()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ============================================================\n  // Phase 9: Progress Tracking and Cancellation\n  // ============================================================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should update and query progress', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      queue.updateProgress(task.id, 50, 'halfway');\n\n      const progress = queue.getProgress(task.id)!;\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should clamp progress between 0 and 100', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      queue.updateProgress(task.id, 150);\n      expect(queue.getProgress(task.id)!.progress).toBe(100);\n\n      queue.updateProgress(task.id, -10);\n      expect(queue.getProgress(task.id)!.progress).toBe(0);\n    });\n\n    it('should notify progress subscribers', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      const callback = vi.fn();\n      queue.onProgress(task.id, callback);\n\n      queue.updateProgress(task.id, 50, 'half');\n\n      expect(callback).toHaveBeenCalledWith(50, 'half');\n    });\n\n    it('should support unsubscribe', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      const callback = vi.fn();\n      const unsub = queue.onProgress(task.id, callback);\n\n      queue.updateProgress(task.id, 25);\n      expect(callback).toHaveBeenCalledTimes(1);\n\n      unsub();\n      queue.updateProgress(task.id, 50);\n      expect(callback).toHaveBeenCalledTimes(1);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = queue.addTask('task');\n      const cancelled = queue.cancel(task.id);\n\n      expect(cancelled).toBe(true);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getNext()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      const cancelled = queue.cancel(task.id);\n      expect(cancelled).toBe(true);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not cancel completed tasks', () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n      queue.complete(task.id);\n\n      expect(queue.cancel(task.id)).toBe(false);\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.addTask('task', { maxRetries: 3 });\n      const task = queue.getNext()!;\n      queue.cancel(task.id);\n\n      // Ensure task stays cancelled\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getTask(task.id)?.maxRetries).toBe(0);\n    });\n\n    it('should cancel blocked tasks', () => {\n      const dep = queue.addTask('dep');\n      const dependent = queue.addTask('task', { dependencies: [dep.id] });\n\n      const cancelled = queue.cancel(dependent.id);\n      expect(cancelled).toBe(true);\n      expect(queue.getTask(dependent.id)?.status).toBe('cancelled');\n    });\n  });\n\n  // ============================================================\n  // Phase 10: Recurring Tasks\n  // ===================