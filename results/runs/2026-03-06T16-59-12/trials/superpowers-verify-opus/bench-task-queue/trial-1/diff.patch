const selected = candidates[0];\n    selected.status = 'processing';\n    selected.attempts++;\n\n    return selected;\n  }\n\n  pendingCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const taskIds = this.queues.get(queue);\n    if (!taskIds) return 0;\n\n    let count = 0;\n    for (const taskId of taskIds) {\n      const task = this.tasks.get(taskId);\n      if (task && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ============================================================\n  // Phase 2: Named Queues\n  // ============================================================\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ============================================================\n  // Phase 5: Retry with Backoff / Task Completion\n  // ============================================================\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks can now be unblocked\n    this.checkDependents(taskId);\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n    task.failureCount++;\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n      task