+  // Phase 4: Delayed and Scheduled Tasks
+  // ============================================================
+  describe('Phase 4: Delayed and Scheduled Tasks', () => {
+    it('should support delay in milliseconds', () => {
+      const task = queue.addTask('delayed', { delay: 5000 });
+      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());
+      expect(queue.getNext()).toBeNull();
+    });
+
+    it('should support specific availableAt time', () => {
+      const future = new Date(Date.now() + 10000);
+      const task = queue.addTask('scheduled', { availableAt: future });
+      expect(task.availableAt).toBe(future);
+      expect(queue.getNext()).toBeNull();
+    });
+
+    it('should return non-delayed tasks over delayed tasks', () => {
+      queue.addTask('delayed', { delay: 5000, priority: 1 });
+      queue.addTask('immediate', { priority: 5 });
+
+      expect(queue.getNext()?.payload).toBe('immediate');
+    });
+
+    it('should return delayed tasks when available', () => {
+      const pastTime = new Date(Date.now() - 1000);
+      queue.addTask('was-delayed', { availableAt: pastTime });
+
+      const task = queue.getNext();
+      expect(task?.payload).toBe('was-delayed');
+    });
+
+    it('should order available delayed tasks correctly', () => {
+      const now = Date.now();
+      queue.addTask('later', { availableAt: new Date(now - 100) });
+      queue.addTask('earlier', { availableAt: new Date(now - 200) });
+
+      expect(queue.getNext()?.payload).toBe('earlier');
+      expect(queue.getNext()?.payload).toBe('later');
+    });
+
+    it('should work with named queues', () => {
+      queue.addTask('delayed', { queue: 'test', delay: 5000 });
+      expect(queue.getNext('test')).toBeNull();
+    });
+  });
+
