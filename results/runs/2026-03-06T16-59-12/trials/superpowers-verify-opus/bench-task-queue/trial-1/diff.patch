ue.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      const handler1 = vi.fn();\n      const handler2 = vi.fn();\n\n      queue.use('q1', async (task, next) => {\n        (task as Record<string, unknown>).q1 = true;\n        await next();\n      });\n      queue.setHandler('q1', handler1);\n      queue.setHandler('q2', handler2);\n\n      queue.addTask('t1', { queue: 'q1' });\n      queue.addTask('t2', { queue: 'q2' });\n\n      const t1 = queue.getNext('q1')!;\n      const t2 = queue.getNext('q2')!;\n\n      await queue.process(t1.id);\n      await queue.process(t2.id);\n\n      expect(handler1).toHaveBeenCalled();\n      expect(handler2).toHaveBeenCalled();\n    });\n  });\n\n  // ============================================================\n  // Phase 12: Graceful Shutdown\n  // ============================================================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should stop accepting new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.addTask('task')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately when no processing tasks', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      queue.addTask('task');\n      const task = queue.getNext()!;\n\n      // Start shutdown in background\n      const shutdownPromise = queue.shutdown({ timeout: 5000 });\n\n      // Complete the task\n      queue.complete(task.id);\n\n      const result = await shutdownPromise;\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force cancel tasks after timeout', async () => {\n      queue.addTask('task');\n      qu