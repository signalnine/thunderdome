taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in status: ${task.status}`);\n    }\n\n    task.progress = Math.max(0, Math.min(100, progress));\n    task.progressMessage = message;\n\n    // Notify subscribers\n    const subs = this.progressSubscriptions.get(taskId);\n    if (subs) {\n      for (const callback of subs) {\n        callback(task.progress, task.progressMessage);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } | null {\n    const task = this.tasks.get(taskId);\n    if (!task) return null;\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    if (!this.progressSubscriptions.has(taskId)) {\n      this.progressSubscriptions.set(taskId, new Set());\n    }\n    this.progressSubscriptions.get(taskId)!.add(callback);\n\n    // Return unsubscribe function\n    return () => {\n      const subs = this.progressSubscriptions.get(taskId);\n      if (subs) {\n        subs.delete(callback);\n        if (subs.size === 0) {\n          this.progressSubscriptions.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancel(taskId: string): boolean {\n    const task = this.tasks.get(taskId);\n    if (!task) return false;\n\n    if (task.status === 'pending' || task.status === 'blocked') {\n      task.status = 'cancelled';\n      // Remove from queue\n      const queueTasks = this.queues.get(task.queue);\n      if (queueTasks) {\n        queueTasks.delete(taskId);\n      }\n      return true;\n    }\n\n    if (task.status === 'processing') {\n      task.status = 'cancelled';\n      // Set maxRetries to 0 to prevent retrying\n      task.maxRetries = 0;\n      return true;\n    }\n\n    return false;\n  }\n\n  // ============================================================\n  // Phase 10: Recurring Tasks\n  // ============================================================\n\n  addSchedule(\n    id: string,\n    cron: string,\n    queue: string,\n    payload: unknown,\n    taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>\n  ): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add schedules: queue system is shutting down');\n    }\n\n    // Validate cron expression\n    this.parseCron(cron);\n\n    const schedule: Schedule = {\n      id,\n      cron,\n      queue,\n      payload,\n      taskOptions,\n    };\n\n    this.schedules.set(id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(id: string): boolean {\n    return this.schedules.delete(id);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const createdTasks: Task[] = [];\n\n    for (const [, schedule] of this.schedules) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.addTask(schedule.payload, {\n          queue: schedule.queue,\n          ...schedule.taskOptions,\n        });\n        createdTasks.push(task as Task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  private parseCron(cron: string): { minuteInterval: number | null; minute: number; hour: number } {\n    const parts = cron.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${cron}`);\n    }\n\n    const [minutePart, hourPart, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Validate that day-of-month, month, day-of-week are all wildcards\n    if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {\n      // Allow 0 for specific values in hour/day contexts\n    }\n\n    const result = { minuteInterval: null as number | null, minute: -1, hour: -1 };\n\n    // Parse minute field\n    if (minutePart.startsWith('*/')) {\n      result.minuteInterval = parseInt(minutePart.slice(2), 10);\n      if (isNaN(result.minuteInterval) || result.minuteInterval <= 0) {\n        throw new Error(`Invalid cron expression: ${cron}`);\n      }\n    } else {\n      result.minute = parseInt(minutePart, 10);\n      if (isNaN(result.minute) || result.minute < 0 || result.minute > 59) {\n        throw new Error(`Invalid cron expression: ${cron}`);\n      }\n    }\n\n    // Parse hour field\n    if (hourPart === '*') {\n      result.hour = -1; // any hour\n    } else {\n      result.hour = parseInt(hourPart, 10);\n      if (isNaN(result.hour) || result.hour < 0 || result.hour > 23) {\n        throw new Error(`Invalid cron expression: ${cron}`);\n      }\n    }\n\n    return result;\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parsed = this.parseCron(schedule.cron);\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Check minute match\n    let minuteMatch = false;\n    if (parsed.minuteInterval !== null) {\n      // */N pattern - check if current minute is divisible by N\n      minuteMatch = currentMinute % parsed.minuteInterval === 0;\n    } else {\n      minuteMatch = currentMinute === parsed.minute;\n    }\n\n    // Check hour match\n    let hourMatch = false;\n    if (parsed.hour === -1) {\n      hourMatch = true; // any hour\n    } else {\n      hourMatch = currentHour === parsed.hour;\n    }\n\n    if (!minuteMatch || !hourMatch) {\n      return false;\n    }\n\n    // Check if already ran this minute\n    if (schedule.lastRun) {\n      const lastRunMinute = schedule.lastRun.getMinutes();\n      const lastRunHour = schedule.lastRun.getHours();\n      const lastRunDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (lastRunDate === nowDate && lastRunHour === currentHour && lastRunMinute === currentMinute) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  // ============================================================\n  // Phase 11: Middleware Pipeline\n  // ============================================================\n\n  use(queueName: string, middleware: Middleware): void {\n    if (!this.middlewareStacks.has(queueName)) {\n      this.middlewareStacks.set(queueName, []);\n    }\n    this.middlewareStacks.get(queueName)!.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: TaskHandler): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  async process(taskId: string): Promise<void> {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task must be in processing status to run middleware pipeline`);\n    }\n\n    const queueName = task.queue;\n    const middlewares = this.middlewareStacks.get(queueName) ?? [];\n    const handler = this.handlers.get(queueName);\n\n    try {\n      let index = 0;\n      const executeNext = async (): Promise<void> => {\n        if (index < middlewares.length) {\n          const mw = middlewares[index++];\n          await mw(task, executeNext);\n        } else if (handler) {\n          await handler(task);\n        }\n      };\n\n      await executeNext();\n    } catch (err) {\n      const errorMessage = err instanceof Error ? err.message : String(err);\n      this.fail(taskId, errorMessage);\n      throw err;\n    }\n  }\n\n  // ============================================================\n  // Phase 12: Graceful Shutdown\n  // ============================================================\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(options);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    const timeout = options?.timeout ?? 30000;\n    const startTime = Date.now();\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Run shutdown callbacks\n    for (const callback of this.shutdownCallbacks) {\n      try {\n        await callback();\n      } catch {\n        // Ignore callback errors during shutdown\n      }\n    }\n\n    // Find all processing tasks\n    const processingTasks: Task[] = [];\n    for (const [, task] of this.tasks) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      const durationMs = Date.now() - startTime;\n      return { completed, forceCancelled, durationMs };\n    }\n\n    // Wait for processing tasks to complete, up to timeout\n    const waitStart = Date.now();\n    while (Date.now() - waitStart < timeout) {\n      const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n      if (stillProcessing.length === 0) break;\n      await new Promise(resolve => setTimeout(resolve, 10));\n    }\n\n    // Count completed and force-cancel remaining\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        task.status = 'cancelled';\n        task.maxRetries = 0;\n        forceCancelled++;\n      } else if (task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    const durationMs = Date.now() - startTime;\n    return { completed, forceCancelled, durationMs };\n  }\n\n  get isShutdown(): boolean {\n    return this.isShuttingDown;\n  }\n}\n","structuredPatch":[{"oldStart":313,"oldLines":7,"newStart":313,"newLines":7,"lines":["   // Phase 7: Task Dependencies","   // ============================================================"," ","-  private detectCircularDependencies(dependencyIds: string[]): void {","+  private detectCircularDependencies(_dependencyIds: string[]): void {","     // BF