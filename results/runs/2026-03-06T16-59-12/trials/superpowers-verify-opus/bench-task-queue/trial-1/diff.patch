+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YUVizjrCa2dNMbBijA8mfa","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import type {\n     3→  Task,\n     4→  TaskOptions,\n     5→  DeadLetterEntry,\n     6→  ProgressCallback,\n     7→  Schedule,\n     8→  Middleware,\n     9→  TaskHandler,\n    10→  ConcurrencySettings,\n    11→  ShutdownOptions,\n    12→  ShutdownResult,\n    13→} from './types.js';\n    14→\n    15→const DEFAULT_QUEUE = 'default';\n    16→const DEFAULT_PRIORITY = 5;\n    17→const DEFAULT_MAX_RETRIES = 3;\n    18→const DEFAULT_BACKOFF_DELAY = 1000;\n    19→\n    20→export class TaskQueue {\n    21→  // Storage\n    22→  private tasks: Map<string, Task> = new Map();\n    23→  private queues: Map<string, Set<string>> = new Map();\n    24→  private deadLetterQueues: Map<string, DeadLetterEntry[]> = new Map();\n    25→\n    26→  // Concurrency\n    27→  private concurrencyLimits: Map<string, number | null> = new Map();\n    28→\n    29→  // Progress subscriptions\n    30→  private progressSubscriptions: Map<string, Set<ProgressCallback>> = new Map();\n    31→\n    32→  // Recurring schedules\n    33→  private schedules: Map<string, Schedule> = new Map();\n    34→\n    35→  // Middleware\n    36→  private middlewareStacks: Map<string, Middleware[]> = new Map();\n    37→  private handlers: Map<string, TaskHandler> = new Map();\n    38→\n    39→  // Shutdown\n    40→  private isShuttingDown = false;\n    41→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    42→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    43→\n    44→  // Sequence counter for FIFO ordering\n    45→  private sequenceCounter = 0;\n    46→\n    47→  // ============================================================\n    48→  // Phase 1: Basic FIFO Queue\n    49→  // ============================================================\n    50→\n    51→  addTask<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    52→    if (this.isShuttingDown) {\n    53→      throw new Error('Cannot add tasks: queue system is shutting down');\n    54→    }\n    55→\n    56→    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    57→    const priority = options?.priority ?? DEFAULT_PRIORITY;\n    58→\n    59→    // Validate priority\n    60→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    61→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    62→    }\n    63→\n    64→    // Handle delay/availableAt\n    65→    const now = new Date();\n    66→    let availableAt = now;\n    67→    if (options?.availableAt) {\n    68→      availableAt = options.availableAt;\n    69→    } else if (options?.delay != null && options.delay > 0) {\n    70→      availableAt = new Date(now.getTime() + options.delay);\n    71→    }\n    72→\n    73→    // Validate dependencies\n    74→    const dependencies = options?.dependencies ?? [];\n    75→    if (dependencies.length > 0) {\n    76→      // Check all dependencies exist\n    77→      for (const depId of dependencies) {\n    78→        if (!this.tasks.has(depId)) {\n    79→          throw new Error(`Dependency task not found: ${depId}`);\n    80→        }\n    81→      }\n    82→\n    83→      // Detect circular dependencies\n    84→      this.detectCircularDependencies(dependencies);\n    85→    }\n    86→\n    87→    const task: Task<T> = {\n    88→      id: randomUUID(),\n    89→      payload,\n    90→      status: dependencies.length > 0 ? 'blocked' : 'pending',\n    91→      queue: queueName,\n    92→      priority,\n    93→      createdAt: now,\n    94→      availableAt,\n    95→      attempts: 0,\n    96→      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n    97→      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n    98→      failureCount: 0,\n    99→      dependencies: [...dependencies],\n   100→      resolvedDependencies: new Set<string>(),\n   101→      progress: 0,\n   102→      sequenceNumber: this.sequenceCounter++,\n   103→    };\n   104→\n   105→    // Check if all dependencies are already completed\n   106→    if (task.status === 'blocked') {\n   107→      const allResolved = dependencies.every(depId => {\n   108→        const depTask = this.tasks.get(depId);\n   109→        return depTask && depTask.status === 'completed';\n   110→      });\n   111→      if (allResolved) {\n   112→        task.status = 'pending';\n   113→        task.resolvedDependencies = new Set(dependencies);\n   114→      } else {\n   115→        // Mark already-completed ones as resolved\n   116→        for (const depId of dependencies) {\n   117→          const depTask = this.tasks.get(depId);\n   118→          if (depTask && depTask.status === 'completed') {\n   119→            task.resolvedDependencies.add(depId);\n   120→          }\n   121→        }\n   122→      }\n   123→    }\n   124→\n   125→    this.tasks.set(task.id, task as Task);\n   126→\n   127→    // Ensure queue exists\n   128→    if (!this.queues.has(queueName)) {\n   129→      this.queues.set(queueName, new Set());\n   130→    }\n   131→    this.queues.get(queueName)!.add(task.id);\n   132→\n   133→    return task;\n   134→  }\n   135→\n   136→  getNext(queueName?: string): Task | null {\n   137→    const queue = queueName ?? DEFAULT_QUEUE;\n   138→\n   139→    const taskIds = this.queues.get(queue);\n   140→    if (!taskIds || taskIds.size === 0) {\n   141→      return null;\n   142→    }\n   143→\n   144→    // Check concurrency limit\n   145→    const concurrency = this.getConcurrency(queue);\n   146→    if (concurrency.limit !== null && concurrency.active >= concurrency.limit) {\n   147→      return null;\n   148→    }\n   149→\n   150→    const now = new Date();\n   151→\n   152→    // Find all eligible pending tasks\n   153→    const candidates: Task[] = [];\n   154→    for (const taskId of taskIds) {\n   155→      const task = this.tasks.get(taskId);\n   156→      if (!task) continue;\n   157→      if (task.status !== 'pending') continue;\n   158→      if (task.availableAt > now) continue;\n   159→      candidates.push(task);\n   160→    }\n   161→\n   162→    if (candidates.length === 0) {\n   163→      return null;\n   164→    }\n   165→\n   166→    // Sort by: priority (asc), availableAt (asc), sequenceNumber (asc)\n   167→    candidates.sort((a, b) => {\n   168→      if (a.priority !== b.priority) return a.priority - b.priority;\n   169→      const aTime = a.availableAt.getTime();\n   170→      const bTime = b.availableAt.getTime();\n   171→      if (aTime !== bTime) return aTime - bTime;\n   172→      return a.sequenceNumber - b.sequenceNumber;\n   173→    });\n   174→\n   175→    const selected = candidates[0];\n   176→    selected.status = 'processing';\n   177→    selected.attempts++;\n   178→\n   179→    return selected;\n   180→  }\n   181→\n   182→  pendingCount(queueName?: string): number {\n   183→    const queue = queueName ?? DEFAULT_QUEUE;\n   184→    const taskIds = this.queues.get(queue);\n   185→    if (!taskIds) return 0;\n   186→\n   187→    let count = 0;\n   188→    for (const taskId of taskIds) {\n   189→      const task = this.tasks.get(taskId);\n   190→      if (task && task.status === 'pending') {\n   191→        count++;\n   192→      }\n   193→    }\n   194→    return count;\n   195→  }\n   196→\n   197→  // ============================================================\n   198→  // Phase 2: Named Queues\n   199→  // ============================================================\n   200→\n   201→  getQueueNames(): string[] {\n   202→    return Array.from(this.queues.keys());\n   203→  }\n   204→\n   205→  // ============================================================\n   206→  // Phase 5: Retry with Backoff / Task Completion\n   207→  // ============================================================\n   208→\n   209→  complete(taskId: string): void {\n   210→    const task = this.tasks.get(taskId);\n   211→    if (!task) {\n   212→      throw new Error(`Task not found: ${taskId}`);\n   213→    }\n   214→    if (task.status !== 'processing') {\n   215→      throw new Error(`Cannot complete task in status: ${task.status}`);\n   216→    }\n   217→\n   218→    task.status = 'completed';\n   219→    task.progress = 100;\n   220→\n   221→    // Check if any blocked tasks can now be unblocked\n   222→    this.checkDependents(taskId);\n   223→  }\n   224→\n   225→  fail(taskId: string, error?: string): void {\n   226→    const task = this.tasks.get(taskId);\n   227→    if (!task) {\n   228→      throw new Error(`Task not found: ${taskId}`);\n   229→    }\n   230→    if (task.status !== 'processing') {\n   231→      throw new Error(`Cannot fail task in status: ${task.status}`);\n   232→    }\n   233→\n   234→    task.error = error;\n   235→    task.failureCount++;\n   236→\n   237→    if (task.attempts < task.maxRetries) {\n   238→      // Retry with exponential backoff\n   239→      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n   240→      task.availableAt = new Date(Date.now() + delay);\n   241→      task.status = 'pending';\n   242→      task.progress = 0;\n   243→      task.progressMessage = undefined;\n   244→    } else {\n   245→      // All retries exhausted\n   246→      task.status = 'failed';\n   247→\n   248→      // Move to dead letter queue\n   249→      this.addToDeadLetterQueue(task, error ?? 'Unknown error');\n   250→    }\n   251→  }\n   252→\n   253→  // ============================================================\n   254→  // Phase 6: Dead Letter Queue\n   255→  // ============================================================\n   256→\n   257→  private addToDeadLetterQueue(task: Task, error: string): void {\n   258→    const queueName = task.queue;\n   259→    if (!this.deadLetterQueues.has(queueName)) {\n   260→      this.deadLetterQueues.set(queueName, []);\n   261→    }\n   262→\n   263→    const entry: DeadLetterEntry = {\n   264→      task,\n   265→      error,\n   266→      failureCount: task.failureCount,\n   267→      deadLetteredAt: new Date(),\n   268→    };\n   269→\n   270→    this.deadLetterQueues.get(queueName)!.push(entry);\n   271→  }\n   272→\n   273→  getDeadLetterTasks(queueName?: string): DeadLetterEntry[] {\n   274→    const queue = queueName ?? DEFAULT_QUEUE;\n   275→    return [...(this.deadLetterQueues.get(queue) ?? [])];\n   276→  }\n   277→\n   278→  requeueDeadLetterTask(taskId: string): Task | null {\n   279→    // Find the task in any DLQ\n   280→    for (const [queueName, entries] of this.deadLetterQueues) {\n   281→      const index = entries.findIndex(e => e.task.id === taskId);\n   282→      if (index !== -1) {\n   283→        const entry = entries[index];\n   284→        entries.splice(index, 1);\n   285→\n   286→        const task = entry.task;\n   287→        task.status = 'pending';\n   288→        task.attempts = 0;\n   289→        task.failureCount = 0;\n   290→        task.error = undefined;\n   291→        task.progress = 0;\n   292→        task.progressMessage = undefined;\n   293→        task.availableAt = new Date();\n   294→\n   295→        // Make sure task is in queue set\n   296→        if (!this.queues.has(queueName)) {\n   297→          this.queues.set(queueName, new Set());\n   298→        }\n   299→        this.queues.get(queueName)!.add(task.id);\n   300→\n   301→        return task;\n   302→      }\n   303→    }\n   304→    return null;\n   305→  }\n   306→\n   307→  clearDeadLetterQueue(queueName?: string): void {\n   308→    const queue = queueName ?? DEFAULT_QUEUE;\n   309→    this.deadLetterQueues.set(queue, []);\n   310→  }\n   311→\n   312→  // ============================================================\n   313→  // Phase 7: Task Dependencies\n   314→  // ============================================================\n   315→\n   316→  private detectCircularDependencies(_dependencyIds: string[]): void {\n   317→    // BFS/DFS from each dependency to see if it would create a cycle\n   318→    // Since we're adding a NEW task that depends on these, we need to check\n   319→    // that none of the dependencies (transitively) depend on each other in\n   320→    // a way that would create a cycle. Actually, since the new task doesn't\n   321→    // exist yet, it can't be referenced by any existing tasks. So circular\n   322→    // dependency detection only applies when an existing task would be in the\n   323→    // chain. The new task has no ID yet, so no one can depend on it.\n   324→    // Therefore, direct circular deps are impossible for a new task.\n   325→    // But we still need to verify that the dependencies themselves don't form\n   326→    // invalid chains.\n   327→\n   328→    // Actually, the main concern is: if task A depends on [B, C], and B depends on [C],\n   329→    // that's fine. But if somehow we had A -> B -> A, that's circular. Since A is new and\n   330→    // has no ID yet, no existing task can reference it. So circular dependencies at creation\n   331→    // time for a brand new task are impossible.\n   332→    //\n   333→    // However, if dependencyIds themselves contain circular references among existing tasks,\n   334→    // that would have been caught when those tasks were created. So we're fine.\n   335→    //\n   336→    // The real check needed: are any dependency IDs pointing to tasks that are themselves\n   337→    // blocked on tasks that haven't completed? That's fine - it just means this task waits\n   338→    // longer. No circularity possible with new tasks since they have no dependents yet.\n   339→  }\n   340→\n   341→  getTask(taskId: string): Task | undefined {\n   342→    return this.tasks.get(taskId);\n   343→  }\n   344→\n   345→  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } | null {\n   346→    const task = this.tasks.get(taskId);\n   347→    if (!task) return null;\n   348→\n   349→    const resolved = Array.from(task.resolvedDependencies);\n   350→    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n   351→\n   352→    return {\n   353→      dependencies: [...task.dependencies],\n   354→      resolved,\n   355→      pending,\n   356→    };\n   357→  }\n   358→\n   359→  private checkDependents(completedTaskId: string): void {\n   360→    // Find all tasks that depend on the completed task\n   361→    for (const [, task] of this.tasks) {\n   362→      if (task.status !== 'blocked') continue;\n   363→      if (!task.dependencies.includes(completedTaskId)) continue;\n   364→\n   365→      task.resolvedDependencies.add(completedTaskId);\n   366→\n   367→      // Check if all dependencies are resolved\n   368→      const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n   369→      if (allResolved) {\n   370→        task.status = 'pending';\n   371→      }\n   372→    }\n   373→  }\n   374→\n   375→  // ============================================================\n   376→  // Phase 8: Concurrency Control\n   377→  // ============================================================\n   378→\n   379→  setConcurrency(queueName: string, limit: number | null): void {\n   380→    this.concurrencyLimits.set(queueName, limit);\n   381→  }\n   382→\n   383→  getConcurrency(queueName?: string): ConcurrencySettings {\n   384→    const queue = queueName ?? DEFAULT_QUEUE;\n   385→    const limit = this.concurrencyLimits.get(queue) ?? null;\n   386→\n   387→    let active = 0;\n   388→    const taskIds = this.queues.get(queue);\n   389→    if (taskIds) {\n   390→      for (const taskId of taskIds) {\n   391→        const task = this.tasks.get(taskId);\n   392→        if (task && task.status === 'processing') {\n   393→          active++;\n   394→        }\n   395→      }\n   396→    }\n   397→\n   398→    return { limit, active };\n   399→  }\n   400→\n   401→  // ============================================================\n   402→  // Phase 9: Progress Tracking and Cancellation\n   403→  // ============================================================\n   404→\n   405→  updateProgress(taskId: string, progress: number, message?: string): void {\n   406→    const task = this.tasks.get(taskId);\n   407→    if (!task) {\n   408→      throw new Error(`Task not found: ${taskId}`);\n   409→    }\n   410→    if (task.status !== 'processing') {\n   411→      throw new Error(`Cannot update progress for task in status: ${task.status}`);\n   412→    }\n   413→\n   414→    task.progress = Math.max(0, Math.min(100, progress));\n   415→    task.progressMessage = message;\n   416→\n   417→    // Notify subscribers\n   418→    const subs = this.progressSubscriptions.get(taskId);\n   419→    if (subs) {\n   420→      for (const callback of subs) {\n   421→        callback(task.progress, task.progressMessage);\n   422→      }\n   423→    }\n   424→  }\n   425→\n   426→  getProgress(taskId: string): { progress: number; message?: string } | null {\n   427→    const task = this.tasks.get(taskId);\n   428→    if (!task) return null;\n   429→    return { progress: task.progress, message: task.progressMessage };\n   430→  }\n   431→\n   432→  onProgress(taskId: string, callback: ProgressCallback): () => void {\n   433→    if (!this.progressSubscriptions.has(taskId)) {\n   434→      this.progressSubscriptions.set(taskId, new Set());\n   435→    }\n   436→    this.progressSubscriptions.get(taskId)!.add(callback);\n   437→\n   438→    // Return unsubscribe function\n   439→    return () => {\n   440→      const subs = this.progressSubscriptions.get(taskId);\n   441→      if (subs) {\n   442→        subs.delete(callback);\n   443→        if (subs.size === 0) {\n   444→          this.progressSubscriptions.delete(taskId);\n   445→        }\n   446→      }\n   447→    };\n   448→  }\n   449→\n   450→  cancel(taskId: string): boolean {\n   451→    const task = this.tasks.get(taskId);\n   452→    if (!task) return false;\n   453→\n   454→    if (task.status === 'pending' || task.status === 'blocked') {\n   455→      task.status = 'cancelled';\n   456→      // Remove from queue\n   457→      const queueTasks = this.queues.get(task.queue);\n   458→      if (queueTasks) {\n   459→        queueTasks.delete(taskId);\n   460→      }\n   461→      return true;\n   462→    }\n   463→\n   464→    if (task.status === 'processing') {\n   465→      task.status = 'cancelled';\n   466→      // Set maxRetries to 0 to prevent retrying\n   467→      task.maxRetries = 0;\n   468→      return true;\n   469→    }\n   470→\n   471→    return false;\n   472→  }\n   473→\n   474→  // ============================================================\n   475→  // Phase 10: Recurring Tasks\n   476→  // ============================================================\n   477→\n   478→  addSchedule(\n   479→    id: string,\n   480→    cron: string,\n   481→    queue: string,\n   482→    payload: unknown,\n   483→    taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>\n   484→  ): Schedule {\n   485→    if (this.isShuttingDown) {\n   486→      throw new Error('Cannot add schedules: queue system is shutting down');\n   487→    }\n   488→\n   489→    // Validate cron expression\n   490→    this.parseCron(cron);\n   491→\n   492→    const schedule: Schedule = {\n   493→      id,\n   494→      cron,\n   495→      queue,\n   496→      payload,\n   497→      taskOptions,\n   498→    };\n   499→\n   500→    this.schedules.set(id, schedule);\n   501→    return schedule;\n   502→  }\n   503→\n   504→  removeSchedule(id: string): boolean {\n   505→    return this.schedules.delete(id);\n   506→  }\n   507→\n   508→  getSchedules(): Schedule[] {\n   509→    return Array.from(this.schedules.values());\n   510→  }\n   511→\n   512→  tick(now?: Date): Task[] {\n   513→    const currentTime = now ?? new Date();\n   514→    const createdTasks: Task[] = [];\n   515→\n   516→    for (const [, schedule] of this.schedules) {\n   517→      if (this.shouldRunSchedule(schedule, currentTime)) {\n   518→        const task = this.addTask(schedule.payload, {\n   519→          queue: schedule.queue,\n   520→          ...schedule.taskOptions,\n   521→        });\n   522→        createdTasks.push(task as Task);\n   523→        schedule.lastRun = currentTime;\n   524→      }\n   525→    }\n   526→\n   527→    return createdTasks;\n   528→  }\n   529→\n   530→  private parseCron(cron: string): { minuteInterval: number | null; minute: number; hour: number } {\n   531→    const parts = cron.trim().split(/\\s+/);\n   532→    if (parts.length !== 5) {\n   533→      throw new Error(`Invalid cron expression: ${cron}`);\n   534→    }\n   535→\n   536→    const [minutePart, hourPart, dayOfMonth, month, dayOfWeek] = parts;\n   537→\n   538→    // Validate that day-of-month, month, day-of-week are all wildcards\n   539→    if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {\n   540→      // Allow 0 for specific values in hour/day contexts\n   541→    }\n   542→\n   543→    const result = { minuteInterval: null as number | null, minute: -1, hour: -1 };\n   544→\n   545→    // Parse minute field\n   546→    if (minutePart.startsWith('*/')) {\n   547→      result.minuteInterval = parseInt(minutePart.slice(2), 10);\n   548→      if (isNaN(result.minuteInterval) || result.minuteInterval <= 0) {\n   549→        throw new Error(`Invalid cron expression: ${cron}`);\n   550→      }\n   551→    } else {\n   552→      result.minute = parseInt(minutePart, 10);\n   553→      if (isNaN(result.minute) || result.minute < 0 || result.minute > 59) {\n   554→        throw new Error(`Invalid cron expression: ${cron}`);\n   555→      }\n   556→    }\n   557→\n   558→    // Parse hour field\n   559→    if (hourPart === '*') {\n   560→      result.hour = -1; // any hour\n   561→    } else {\n   562→      result.hour = parseInt(hourPart, 10);\n   563→      if (isNaN(result.hour) || result.hour < 0 || result.hour > 23) {\n   564→        throw new Error(`Invalid cron expression: ${cron}`);\n   565→      }\n   566→    }\n   567→\n   568→    return result;\n   569→  }\n   570→\n   571→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   572→    const parsed = this.parseCron(schedule.cron);\n   573→\n   574→    const currentMinute = now.getMinutes();\n   575→    const currentHour = now.getHours();\n   576→\n   577→    // Check minute match\n   578→    let minuteMatch = false;\n   579→    if (parsed.minuteInterval !== null) {\n   580→      // */N pattern - check if current minute is divisible by N\n   581→      minuteMatch = currentMinute % parsed.minuteInterval === 0;\n   582→    } else {\n   583→      minuteMatch = currentMinute === parsed.minute;\n   584→    }\n   585→\n   586→    // Check hour match\n   587→    let hourMatch = false;\n   588→    if (parsed.hour === -1) {\n   589→      hourMatch = true; // any hour\n   590→    } else {\n   591→      hourMatch = currentHour === parsed.hour;\n   592→    }\n   593→\n   594→    if (!minuteMatch || !hourMatch) {\n   595→      return false;\n   596→    }\n   597→\n   598→    // Check if already ran this minute\n   599→    if (schedule.lastRun) {\n   600→      const lastRunMinute = schedule.lastRun.getMinutes();\n   601→      const lastRunHour = schedule.lastRun.getHours();\n   602→      const lastRunDate = schedule.lastRun.toDateString();\n   603→      const nowDate = now.toDateString();\n   604→\n   605→      if (lastRunDate === nowDate && lastRunHour === currentHour && lastRunMinute === currentMinute) {\n   606→        return false;\n   607→      }\n   608→    }\n   609→\n   610→    return true;\n   611→  }\n   612→\n   613→  // ============================================================\n   614→  // Phase 11: Middleware Pipeline\n   615→  // ============================================================\n   616→\n   617→  use(queueName: string, middleware: Middleware): void {\n   618→    if (!this.middlewareStacks.has(queueName)) {\n   619→      this.middlewareStacks.set(queueName, []);\n   620→    }\n   621→    this.middlewareStacks.get(queueName)!.push(middleware);\n   622→  }\n   623→\n   624→  setHandler(queueName: string, handler: TaskHandler): void {\n   625→    this.handlers.set(queueName, handler);\n   626→  }\n   627→\n   628→  async process(taskId: string): Promise<void> {\n   629→    const task = this.tasks.get(taskId);\n   630→    if (!task) {\n   631→      throw new Error(`Task not found: ${taskId}`);\n   632→    }\n   633→    if (task.status !== 'processing') {\n   634→      throw new Error(`Task must be in processing status to run middleware pipeline`);\n   635→    }\n   636→\n   637→    const queueName = task.queue;\n   638→    const middlewares = this.middlewareStacks.get(queueName) ?? [];\n   639→    const handler = this.handlers.get(queueName);\n   640→\n   641→    try {\n   642→      let index = 0;\n   643→      const executeNext = async (): Promise<void> => {\n   644→        if (index < middlewares.length) {\n   645→          const mw = middlewares[index++];\n   646→          await mw(task, executeNext);\n   647→        } else if (handler) {\n   648→          await handler(task);\n   649→        }\n   650→      };\n   651→\n   652→      await executeNext();\n   653→    } catch (err) {\n   654→      const errorMessage = err instanceof Error ? err.message : String(err);\n   655→      this.fail(taskId, errorMessage);\n   656→      throw err;\n   657→    }\n   658→  }\n   659→\n   660→  // ============================================================\n   661→  // Phase 12: Graceful Shutdown\n   662→  // ============================================================\n   663→\n   664→  onShutdown(callback: () => void | Promise<void>): void {\n   665→    this.shutdownCallbacks.push(callback);\n   666→  }\n   667→\n   668→  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   669→    if (this.shutdownPromise) {\n   670→      return this.shutdownPromise;\n   671→    }\n   672→\n   673→    this.isShuttingDown = true;\n   674→    this.shutdownPromise = this.performShutdown(options);\n   675→    return this.shutdownPromise;\n   676→  }\n   677→\n   678→  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   679→    const timeout = options?.timeout ?? 30000;\n   680→    const startTime = Date.now();\n   681→    let completed = 0;\n   682→    let forceCancelled = 0;\n   683→\n   684→    // Run shutdown callbacks\n   685→    for (const callback of this.shutdownCallbacks) {\n   686→      try {\n   687→        await callback();\n   688→      } catch {\n   689→        // Ignore callback errors during shutdown\n   690→      }\n   691→    }\n   692→\n   693→    // Find all processing tasks\n   694→    const processingTasks: Task[] = [];\n   695→    for (const [, task] of this.tasks) {\n   696→      if (task.status === 'processing') {\n   697→        processingTasks.push(task);\n   698→      }\n   699→    }\n   700→\n   701→    if (processingTasks.length === 0) {\n   702→      const durationMs = Date.now() - startTime;\n   703→      return { completed, forceCancelled, durationMs };\n   704→    }\n   705→\n   706→    // Wait for processing tasks to complete, up to timeout\n   707→    const waitStart = Date.now();\n   708→    while (Date.now() - waitStart < timeout) {\n   709→      const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n   710→      if (stillProcessing.length === 0) break;\n   711→      await new Promise(resolve => setTimeout(resolve, 10));\n   712→    }\n   713→\n   714→    // Count completed and force-cancel remaining\n   715→    for (const task of processingTasks) {\n   716→      if (task.status === 'processing') {\n   717→        task.status = 'cancelled';\n   718→        task.maxRetries = 0;\n   719→        forceCancelled++;\n   720→      } else if (task.status === 'completed') {\n   721→        completed++;\n   722→      }\n   723→    }\n   724→\n   725→    const durationMs = Date.now() - startTime;\n   726→    return { completed, forceCancelled, durationMs };\n   727→  }\n   728→\n   729→  get isShutdown(): boolean {\n   730→    return this.isShuttingDown;\n   731→  }\n   732→}\n   733→"}]},"parent_tool_use_id":null,"session_id":"77b6fef8-4f38-4e2c-be4a-9efaa031aac7","uuid":"4c079bc0-3d3b-48e5-acc4-dc223bdead7a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskOptions,\n  DeadLetterEntry,\n  ProgressCallback,\n  Schedule,\n  Middleware,\n  TaskHandler,\n  ConcurrencySettings,\n  ShutdownOptions,\n  ShutdownResult,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\nconst DEFAULT_PRIORITY = 5;\nconst DEFAULT_MAX_RETRIES = 3;\nconst DEFAULT_BACKOFF_DELAY = 1000;\n\nexport class TaskQueue {\n  // Storage\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, Set<string>> = new Map();\n  private deadLetterQueues: Map<string, DeadLetterEntry[]> = new Map();\n\n  // Concurrency\n  private concurrencyLimits: Map<string, number | null> = new Map();\n\n  // Progress subscriptions\n  private progressSubscriptions: Map<string, Set<ProgressCallback>> = new Map();\n\n  // Recurring schedules\n  private schedules: Map<string, Schedule> = new Map();\n\n  // Middleware\n  private middlewareStacks: Map<string, Middleware[]> = new Map();\n  private handlers: Map<string, TaskHandler> = new Map();\n\n  // Shutdown\n  private isShuttingDown = false;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n\n  // Sequence counter for FIFO ordering\n  private sequenceCounter = 0;\n\n  // ============================================================\n  // Phase 1: Basic FIFO Queue\n  // ============================================================\n\n  addTask<T = unknown>(payload: T, options?: TaskOptions): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: queue system is shutting down');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    // Validate priority\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Handle delay/availableAt\n    const now = new Date();\n    let availableAt = now;\n    if (options?.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Validate dependencies\n    const dependencies = options?.dependencies ?? [];\n    if (dependencies.length > 0) {\n      // Check all dependencies exist\n      for (const depId of dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n\n      // Detect circular dependencies\n      this.detectCircularDependencies(dependencies);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: dependencies.length > 0 ? 'blocked' : 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failureCount: 0,\n      dependencies: [...dependencies],\n      resolvedDependencies: new Set<string>(),\n      progress: 0,\n      sequenceNumber: this.sequenceCounter++,\n    };\n\n    // Check if all dependencies are already completed\n    if (task.status === 'blocked') {\n      const allResolved = dependencies.every(depId => {\n        const depTask = this.tasks.get(depId);\n        return depTask && depTask.status === 'completed';\n      });\n      if (allResolved) {\n        task.status = 'pending';\n        task.resolvedDependencies = new Set(dependencies);\n      } else {\n        // Mark already-completed ones as resolved\n        for (const depId of dependencies) {\n          const depTask = this.tasks.get(depId);\n          if (depTask && depTask.status === 'completed') {\n            task.resolvedDependencies.add(depId);\n          }\n        }\n      }\n    }\n\n    this.tasks.set(task.id, task as Task);\n\n    // Ensure queue exists\n    if (!this.queues.has(queueName)) {\n      this.queues.set(queueName, new Set());\n    }\n    this.queues.get(queueName)!.add(task.id);\n\n    return task;\n  }\n\n  getNext(queueName?: string): Task | null {\n    const queue = queueName ?? DEFAULT_QUEUE;\n\n    const taskIds = this.queues.get(queue);\n    if (!taskIds || taskIds.size === 0) {\n      return null;\n    }\n\n    // Check concurrency limit\n    const concurrency = this.getConcurrency(queue);\n    if (concurrency.limit !== null && concurrency.active >= concurrency.limit) {\n      return null;\n    }\n\n    const now = new Date();\n\n    // Find all eligible pending tasks\n    const candidates: Task[] = [];\n    for (const taskId of taskIds) {\n      const task = this.tasks.get(taskId);\n      if (!task) continue;\n      if (task.status !== 'pending') continue;\n      if (task.availableAt > now) continue;\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) {\n      return null;\n    }\n\n    // Sort by: priority (asc), availableAt (asc), sequenceNumber (asc)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const aTime = a.availableAt.getTime();\n      const bTime = b.availableAt.getTime();\n      if (aTime !== bTime) return aTime - bTime;\n      return a.sequenceNumber - b.sequenceNumber;\n    });\n\n    const selecte