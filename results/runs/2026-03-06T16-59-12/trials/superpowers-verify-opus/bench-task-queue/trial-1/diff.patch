+// ============================================================
+// Core Types for the Task Queue System
+// ============================================================
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'blocked';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+  progress: number;
+  progressMessage?: string;
+  sequenceNumber: number;
+}
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface AddTaskResult<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  dependencies: string[];
+}
+
+export interface DeadLetterEntry<T = unknown> {
+  task: Task<T>;
+  error: string;
+  failureCount: number;
+  deadLetteredAt: Date;
+}
+
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>;
+  lastRun?: Date;
+}
+
+export type Middleware = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type TaskHandler = (task: Task) => Promise<void> | void;
+
+export interface ConcurrencySettings {
+  limit: number | null;
+  active: number;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
