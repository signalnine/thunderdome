}\n\n  // ============================================================\n  // Phase 7: Task Dependencies\n  // ============================================================\n\n  private detectCircularDependencies(dependencyIds: string[]): void {\n    // BFS/DFS from each dependency to see if it would create a cycle\n    // Since we're adding a NEW task that depends on these, we need to check\n    // that none of the dependencies (transitively) depend on each other in\n    // a way that would create a cycle. Actually, since the new task doesn't\n    // exist yet, it can't be referenced by any existing tasks. So circular\n    // dependency detection only applies when an existing task would be in the\n    // chain. The new task has no ID yet, so no one can depend on it.\n    // Therefore, direct circular deps are impossible for a new task.\n    // But we still need to verify that the dependencies themselves don't form\n    // invalid chains.\n\n    // Actually, the main concern is: if task A depends on [B, C], and B depends on [C],\n    // that's fine. But if somehow we had A -> B -> A, that's circular. Since A is new and\n    // has no ID yet, no existing task can reference it. So circular dependencies at creation\n    // time for a brand new task are impossible.\n    //\n    // However, if dependencyIds themselves contain circular references among existing tasks,\n    // that would have been caught when those tasks were created. So we're fine.\n    //\n    // The real check needed: are any dependency IDs pointing to tasks that are themselves\n    // blocked on tasks that haven't completed? That's fine - it just means this task waits\n    // longer. No circularity possible with new tasks since they have no dependents yet.\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } | null {\n    const task = this.tasks.get(taskId)