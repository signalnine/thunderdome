+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TCsGR5BSwXdZv43WumxsZw","type":"tool_result","content":"     1Рєњ// Force a non-UTC timezone so timezone-sensitive bugs are exposed\n     2Рєњprocess.env.TZ = 'America/New_York';\n     3Рєњ\n     4Рєњimport { describe, it, expect, beforeEach } from 'vitest';\n     5Рєњimport type Database from 'better-sqlite3';\n     6Рєњimport { createDatabase } from '../src/db/connection.js';\n     7Рєњimport { createInvoice, getInvoicesByDateRange } from '../src/db/queries.js';\n     8Рєњimport { calculateInvoiceTotal } from '../src/services/billing.js';\n     9Рєњimport { getMonthlyReport } from '../src/services/reporting.js';\n    10Рєњimport { formatDate } from '../src/utils/dates.js';\n    11Рєњ\n    12Рєњlet db: Database.Database;\n    13Рєњ\n    14РєњbeforeEach(() => {\n    15Рєњ  db = createDatabase(':memory:');\n    16Рєњ});\n    17Рєњ\n    18Рєњdescribe('Regression Tests', () => {\n    19Рєњ  it('discount calculation with 15% rate produces correct total', () => {\n    20Рєњ    // subtotal=500, 15% discount => 425, 10% tax => 467.50\n    21Рєњ    const total = calculateInvoiceTotal(500, 0.15, 0.1);\n    22Рєњ    expect(total).toBe(467.5);\n    23Рєњ  });\n    24Рєњ\n    25Рєњ  it('tax and discount combined for small invoice', () => {\n    26Рєњ    // subtotal=50, 20% discount => 40, 5% tax => 42\n    27Рєњ    const total = calculateInvoiceTotal(50, 0.2, 0.05);\n    28Рєњ    expect(total).toBe(42);\n    29Рєњ  });\n    30Рєњ\n    31Рєњ  it('date range query includes end date boundary', () => {\n    32Рєњ    createInvoice(db, {\n    33Рєњ      customer_id: 'cust-1',\n    34Рєњ      date: '2024-06-30',\n    35Рєњ      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n    36Рєњ    });\n    37Рєњ    const invoices = getInvoicesByDateRange(db, '2024-06-01', '2024-06-30');\n    38Рєњ    expect(invoices).toHaveLength(1);\n    39Рєњ    expect(invoices[0].date).toBe('2024-06-30');\n    40Рєњ  });\n    41Рєњ\n    42Рєњ  it('month boundary grouping assigns first day to correct month', () => {\n    43Рєњ    // Invoice on March 1 should be in month 3, not month 2\n    44Рєњ    createInvoice(db, {\n    45Рєњ      customer_id: 'cust-1',\n    46Рєњ      date: '2024-03-01',\n    47Рєњ      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n    48Рєњ    });\n    49Рєњ    const report = getMonthlyReport(db, 2024);\n    50Рєњ    const march = report.find(r => r.month === 3);\n    51Рєњ    const feb = report.find(r => r.month === 2);\n    52Рєњ\n    53Рєњ    expect(march).toBeDefined();\n    54Рєњ    expect(march!.count).toBe(1);\n    55Рєњ    expect(march!.total_revenue).toBe(200);\n    56Рєњ    expect(feb).toBeUndefined();\n    57Рєњ  });\n    58Рєњ\n    59Рєњ  it('multiple months reporting shows correct distribution', () => {\n    60Рєњ    createInvoice(db, {\n    61Рєњ      customer_id: 'cust-1', date: '2024-04-15',\n    62Рєњ      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n    63Рєњ    });\n    64Рєњ    createInvoice(db, {\n    65Рєњ      customer_id: 'cust-1', date: '2024-05-15',\n    66Рєњ      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n    67Рєњ    });\n    68Рєњ    createInvoice(db, {\n    69Рєњ      customer_id: 'cust-1', date: '2024-06-15',\n    70Рєњ      subtotal: 300, discount_rate: 0, tax_rate: 0, total: 300, status: 'paid',\n    71Рєњ    });\n    72Рєњ\n    73Рєњ    const report = getMonthlyReport(db, 2024);\n    74Рєњ    expect(report).toHaveLength(3);\n    75Рєњ    expect(report[0].month).toBe(4);\n    76Рєњ    expect(report[1].month).toBe(5);\n    77Рєњ    expect(report[2].month).toBe(6);\n    78Рєњ    expect(report[0].total_revenue).toBe(100);\n    79Рєњ    expect(report[1].total_revenue).toBe(200);\n    80Рєњ    expect(report[2].total_revenue).toBe(300);\n    81Рєњ  });\n    82Рєњ\n    83Рєњ  it('zero discount rate still calculates correctly', () =