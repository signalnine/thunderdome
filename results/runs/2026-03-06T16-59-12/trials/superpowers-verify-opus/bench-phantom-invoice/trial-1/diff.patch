+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JnDB8YN779ncNXjgZnVsfo","type":"tool_result","content":"     1Рєњimport Database from 'better-sqlite3';\n     2Рєњ\n     3Рєњexport function createDatabase(filename: string = ':memory:'): Database.Database {\n     4Рєњ  const db = new Database(filename);\n     5Рєњ\n     6Рєњ  db.pragma('journal_mode = WAL');\n     7Рєњ\n     8Рєњ  db.exec(`\n     9Рєњ    CREATE TABLE IF NOT EXISTS invoices (\n    10Рєњ      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    11Рєњ      customer_id TEXT NOT NULL,\n    12Рєњ      date TEXT NOT NULL,\n    13Рєњ      subtotal REAL NOT NULL,\n    14Рєњ      discount_rate REAL NOT NULL DEFAULT 0,\n    15Рєњ      tax_rate REAL NOT NULL DEFAULT 0,\n    16Рєњ      total REAL NOT NULL,\n    17Рєњ      status TEXT NOT NULL DEFAULT 'draft'\n    18Рєњ    );\n    19Рєњ\n    20Рєњ    CREATE TABLE IF NOT EXISTS line_items (\n    21Рєњ      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    22Рєњ      invoice_id INTEGER NOT NULL,\n    23Рєњ      description TEXT NOT NULL,\n    24Рєњ      quantity INTEGER NOT NULL,\n    25Рєњ      unit_price REAL NOT NULL,\n    26Рєњ      FOREIGN KEY (invoice_id) REFERENCES invoices(id)\n    27Рєњ    );\n    28Рєњ  `);\n    29Рєњ\n    30Рєњ  return db;\n    31Рєњ}\n    32Рєњ"}]},"parent_tool_use_id":"toolu_01F6pfWyCPDMYEEFvHhXWeNV","session_id":"70b03738-a862-4edc-bc42-ac3ff90fe96f","uuid":"c4929276-b922-4832-b358-8a99eabc2640"}
