+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TGQZDYPoN8yDVv2EtoVYiz","type":"tool_result","content":"     1Рєњimport type Database from 'better-sqlite3';\n     2Рєњimport type { Invoice, InvoiceSummary, CustomerReport } from '../models/invoice.js';\n     3Рєњ\n     4Рєњ/**\n     5Рєњ * Generate a monthly revenue report for a given year.\n     6Рєњ * Groups invoices by their UTC month and aggregates totals.\n     7Рєњ */\n     8Рєњexport function getMonthlyReport(\n     9Рєњ  db: Database.Database,\n    10Рєњ  year: number,\n    11Рєњ): InvoiceSummary[] {\n    12Рєњ  const startDate = `${year}-01-01`;\n    13Рєњ  const endDate = `${year}-12-31`;\n    14Рєњ\n    15Рєњ  const stmt = db.prepare(`\n    16Рєњ    SELECT * FROM invoices\n    17Рєњ    WHERE date >= ? AND date <= ?\n    18Рєњ    ORDER BY date ASC\n    19Рєњ  `);\n    20Рєњ\n    21Рєњ  const invoices = stmt.all(startDate, endDate) as Invoice[];\n    22Рєњ\n    23Рєњ  // Group invoices by month\n    24Рєњ  const monthlyMap = new Map<number, { count: number; total: number }>();\n    25Рєњ\n    26Рєњ  for (const inv of invoices) {\n    27Рєњ    const d = new Date(inv.date + 'T00:00:00Z');\n    28Рєњ    const month = d.getMonth() + 1; // 1-indexed\n    29Рєњ\n    30Рєњ    const current = monthlyMap.get(month) || { count: 0, total: 0 };\n    31Рєњ    current.count += 1;\n    32Рєњ    current.total += inv.total;\n    33Рєњ    monthlyMap.set(month, current);\n    34Рєњ  }\n    35Рєњ\n    36Рєњ  // Convert to array of summaries\n    37Рєњ  const summaries: InvoiceSummary[] = [];\n    38Рєњ  for (const [month, data] of monthlyMap) {\n    39Рєњ    summaries.push({\n    40Рєњ      month,\n    41Рєњ      year,\n    42Рєњ      count: data.count,\n    43Рєњ      total_revenue: Math.round(data.total * 100) / 100,\n    44Рєњ    });\n    45Рєњ  }\n    46Рєњ\n    47Рєњ  return summaries.sort((a, b) => a.month - b.month);\n    48Рєњ}\n    49Рєњ\n    50Рєњ/**\n    51Рєњ * Generate a report for a specific customer.\n    52Рєњ */\n    53Рєњexport function getCustomerReport(\n    54Рєњ  db: Database.Database,\n    55Рєњ  customerId: string,\n    56Рєњ): CustomerReport {\n    57Рєњ  const stmt = db.prepare(`\n    58Рєњ    SELECT * FROM invoices\n    59Рєњ    WHERE customer_id = ?\n    60Рєњ  `);\n    61Рєњ\n    62Рєњ  const invoices = stmt.all(customerId) as Invoice[];\n    63Рєњ\n    64Рєњ  const totalSpent = invoices.reduce((sum, inv) => sum + inv.total, 0);\n    65Рєњ\n    66Рєњ  return {\n    67Рєњ    customer_id: customerId,\n    68Рєњ    invoice_count: invoices.length,\n    69Рєњ    total_spent: Math.round(totalSpent * 100) / 100,\n    70Рєњ    average_invoice: invoices.length > 0\n    71Рєњ      ? Math.round((totalSpent / invoices.length) * 100) / 100\n    72Рєњ      : 0,\n    73Рєњ  };\n    74Рєњ}\n    75Рєњ\n    76Рєњ/**\n    77Рєњ * Get total revenue for a date period.\n    78Рєњ */\n    79Рєњexport function getRevenueByPeriod(\n    80Рєњ  db: Database.Database,\n    81Рєњ  start: string,\n    82Рєњ  end: string,\n    83Рєњ): { total: number; count: number } {\n    84Рєњ  const stmt = db.prepare(`\n    85Рєњ    SELECT COALESCE(SUM(total), 0) as total, COUNT(*) as count\n    86Рєњ    FROM invoices\n    87Рєњ    WHERE date >= ? AND date <= ?\n    88Рєњ  `);\n    89Рєњ\n    90Рєњ  const result = stmt.get(start, end) as { total: number; count: number };\n    91Рєњ  return {\n    92Рєњ    total: Math.round(result.total * 100) / 100,\n    93Рєњ    count: result.count,\n    94Рєњ  };\n    95Рєњ}\n    96Рєњ"}]},"parent_tool_use_id":null,"session_id":"70b03738-a862-4edc-bc42-ac3ff90fe96f","uuid":"6fc8a49a-1685-4931-8d17-00c8886f9afa","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/services/reporting.ts","content":"import type Database from 'better-sqlite3';\nimport type { Invoice, InvoiceSummary, CustomerReport } from '../models/invoice.js';\n\n/**\n * Generate a monthly revenue report for a given year.\n * Groups invoices by their UTC month and aggregates totals.\n */\nexport function getMonthlyReport(\n  db: Database.Database,\n  year: number,\n): InvoiceSummary[] {\n  const startDate = `${year}-01-01`;\n  const endDate = `${year}-12-31`;\n\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE date >= ? AND date <= ?\n    ORDER BY date ASC\n  `);\n\n  const invoices = stmt.all(startDate, endDate) as Invoice[];\n\n  // Group invoices by month\n  const monthlyMap = new Map<number, { count: number; total: number }>();\n\n  for (const inv of invoices) {\n    const d = new Date(inv.date + 'T00:00:00Z');\n    const month = d.getMonth() + 1; // 1-indexed\n\n    const current = monthlyMap.get(month) || { count: 0, total: 0 };\n    current.count += 1;\n    current.total += inv.total;\n    monthlyMap.set(month, current);\n  }\n\n  // Convert to array of summaries\n  const summaries: InvoiceSummary[] = [];\n  for (const [month, data] of monthlyMap) {\n    summaries.push({\n      month,\n      year,\n      count: data.count,\n      total_revenue: Math.round(data.total * 100) / 100,\n    });\n  }\n\n  return summaries.sort((a, b) => a.month - b.month);\n}\n\n/**\n * Generate a report for a specific customer.\n */\nexport function getCustomerReport(\n  db: Database.Database,\n  customerId: string,\n): CustomerReport {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE customer_id = ?\n  `);\n\n  const invoices = stmt.all(customerId) as Invoice[];\n\n  const totalSpent = invoices.reduce((sum, inv) => sum + inv.total, 0);\n\n  return {\n    customer_id: customerId,\n    invoice_count: invoices.length,\n    total_spent: Math.round(totalSpent * 100) / 100,\n    average_invoice: invoices.length > 0\n      ? Math.round((totalSpent / invoices.length) * 100) / 100\n      : 0,\n  };\n}\n\n/**\n * Get total revenue for a date period.\n */\nexport function getRevenueByPeriod(\n  db: Database.Database,\n  start: string,\n  end: string,\n): { total: number; count: number } {\n  const stmt = db.prepare(`\n    SELECT COALESCE(SUM(total), 0) as total, COUNT(*) as count\n    FROM invoices\n    WHERE date >= ? AND date <= ?\n  `);\n\n  const result = stmt.get(start, end) as { total: number; count: number };\n  return {\n    total: Math.round(result.total * 100) / 100,\n    count: result.count,\n  };\n}\n","numLines":96,"startLine":1,"totalLines":96}}}
