+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MFj5dbDppmT1DTf5xC4BL6","type":"tool_result","content":"     1Рєњimport type Database from 'better-sqlite3';\n     2Рєњimport type { Invoice, LineItem } from '../models/invoice.js';\n     3Рєњ\n     4Рєњ/**\n     5Рєњ * Retrieve invoices within a date range (inclusive on both ends).\n     6Рєњ */\n     7Рєњexport function getInvoicesByDateRange(\n     8Рєњ  db: Database.Database,\n     9Рєњ  startDate: string,\n    10Рєњ  endDate: string,\n    11Рєњ): Invoice[] {\n    12Рєњ  const stmt = db.prepare(`\n    13Рєњ    SELECT * FROM invoices\n    14Рєњ    WHERE date >= ? AND date < ?\n    15Рєњ    ORDER BY date ASC\n    16Рєњ  `);\n    17Рєњ  return stmt.all(startDate, endDate) as Invoice[];\n    18Рєњ}\n    19Рєњ\n    20Рєњ/**\n    21Рєњ * Retrieve a single invoice by ID, including its line items.\n    22Рєњ */\n    23Рєњexport function getInvoiceById(\n    24Рєњ  db: Database.Database,\n    25Рєњ  id: number,\n    26Рєњ): (Invoice & { line_items: LineItem[] }) | undefined {\n    27Рєњ  const invoiceStmt = db.prepare('SELECT * FROM invoices WHERE id = ?');\n    28Рєњ  const invoice = invoiceStmt.get(id) as Invoice | undefined;\n    29Рєњ\n    30Рєњ  if (!invoice) return undefined;\n    31Рєњ\n    32Рєњ  const itemsStmt = db.prepare('SELECT * FROM line_items WHERE invoice_id = ?');\n    33Рєњ  const line_items = itemsStmt.all(id) as LineItem[];\n    34Рєњ\n    35Рєњ  return { ...invoice, line_items };\n    36Рєњ}\n    37Рєњ\n    38Рєњ/**\n    39Рєњ * Create a new invoice with line items.\n    40Рєњ */\n    41Рєњexport function createInvoice(\n    42Рєњ  db: Database.Database,\n    43Рєњ  data: Invoice & { line_items?: LineItem[] },\n    44Рєњ): number {\n    45Рєњ  const insertInvoice = db.prepare(`\n    46Рєњ    INSERT INTO invoices (customer_id, date, subtotal, discount_rate, tax_rate, total, status)\n    47Рєњ    VALUES (?, ?, ?, ?, ?, ?, ?)\n    48Рєњ  `);\n    49Рєњ\n    50Рєњ  const insertLineItem = db.prepare(`\n    51Рєњ    INSERT INTO line_items (invoice_id, description, quantity, unit_price)\n    52Рєњ    VALUES (?, ?, ?, ?)\n    53Рєњ  `);\n    54Рєњ\n    55Рєњ  const result = insertInvoice.run(\n    56Рєњ    data.customer_id,\n    57Рєњ    data.date,\n    58Рєњ    data.subtotal,\n    59Рєњ    data.discount_rate,\n    60Рєњ    data.tax_rate,\n    61Рєњ    data.total,\n    62Рєњ    data.status || 'draft',\n    63Рєњ  );\n    64Рєњ\n    65Рєњ  const invoiceId = result.lastInsertRowid as number;\n    66Рєњ\n    67Рєњ  if (data.line_items) {\n    68Рєњ    for (const item of data.line_items) {\n    69Рєњ      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    70Рєњ    }\n    71Рєњ  }\n    72Рєњ\n    73Рєњ  return invoiceId;\n    74Рєњ}\n    75Рєњ\n    76Рєњ/**\n    77Рєњ * Retrieve all invoices for a specific customer.\n    78Рєњ */\n    79Рєњexport function getInvoicesByCustomer(\n    80Рєњ  db: Database.Database,\n    81Рєњ  customerId: string,\n    82Рєњ): Invoice[] {\n    83Рєњ  const stmt = db.prepare(`\n    84Рєњ    SELECT * FROM invoices\n    85Рєњ    WHERE customer_id = ?\n    86Рєњ    ORDER BY date ASC\n    87Рєњ  `);\n    88Рєњ  return stmt.all(customerId) as Invoice[];\n    89Рєњ}\n    90Рєњ"}]},"parent_tool_use_id":"toolu_01F6pfWyCPDMYEEFvHhXWeNV","session_id":"70b03738-a862-4edc-bc42-ac3ff90fe96f","uuid":"ec5fd54e-d9aa-4106-a6b4-ba14cf38cf6a"}
