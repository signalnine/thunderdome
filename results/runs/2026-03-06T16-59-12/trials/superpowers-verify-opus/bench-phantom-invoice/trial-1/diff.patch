ineItem = db.prepare(`\n    51Рєњ    INSERT INTO line_items (invoice_id, description, quantity, unit_price)\n    52Рєњ    VALUES (?, ?, ?, ?)\n    53Рєњ  `);\n    54Рєњ\n    55Рєњ  const result = insertInvoice.run(\n    56Рєњ    data.customer_id,\n    57Рєњ    data.date,\n    58Рєњ    data.subtotal,\n    59Рєњ    data.discount_rate,\n    60Рєњ    data.tax_rate,\n    61Рєњ    data.total,\n    62Рєњ    data.status || 'draft',\n    63Рєњ  );\n    64Рєњ\n    65Рєњ  const invoiceId = result.lastInsertRowid as number;\n    66Рєњ\n    67Рєњ  if (data.line_items) {\n    68Рєњ    for (const item of data.line_items) {\n    69Рєњ      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    70Рєњ    }\n    71Рєњ  }\n    72Рєњ\n    73Рєњ  return invoiceId;\n    74Рєњ}\n    75Рєњ\n    76Рєњ/**\n    77Рєњ * Retrieve all invoices for a specific customer.\n    78Рєњ */\n    79Рєњexport function getInvoicesByCustomer(\n    80Рєњ  db: Database.Database,\n    81Рєњ  customerId: string,\n    82Рєњ): Invoice[] {\n    83Рєњ  const stmt = db.prepare(`\n    84Рєњ    SELECT * FROM invoices\n    85Рєњ    WHERE customer_id = ?\n    86Рєњ    ORDER BY date ASC\n    87Рєњ  `);\n    88Рєњ  return stmt.all(customerId) as Invoice[];\n    89Рєњ}\n    90Рєњ"}]},"parent_tool_use_id":null,"session_id":"70b03738-a862-4edc-bc42-ac3ff90fe96f","uuid":"61198315-929b-4202-ab0d-60232c8370e2","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/db/queries.ts","content":"import type Database from 'better-sqlite3';\nimport type { Invoice, LineItem } from '../models/invoice.js';\n\n/**\n * Retrieve invoices within a date range (inclusive on both ends).\n */\nexport function getInvoicesByDateRange(\n  db: Database.Database,\n  startDate: string,\n  endDate: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE date >= ? AND date < ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(startDate, endDate) as Invoice[];\n}\n\n/**\n * Retrieve a single invoice by ID, including its line items.\n */\nexport function getInvoiceById(\n  db: Database.Database,\n  id: number,\n): (Invoice & { line_items: LineItem[] }) | undefined {\n  const invoiceStmt = db.prepare('SELECT * FROM invoices WHERE id = ?');\n  const invoice = invoiceStmt.get(id) as Invoice | undefined;\n\n  if (!invoice) return undefined;\n\n  const itemsStmt = db.prepare('SELECT * FROM line_items WHERE invoice_id = ?');\n  const line_items = itemsStmt.all(id) as LineItem[];\n\n  return { ...invoice, line_items };\n}\n\n/**\n * Create a new invoice with line items.\n */\nexport function createInvoice(\n  db: Database.Database,\n  data: Invoice & { line_items?: LineItem[] },\n): number {\n  const insertInvoice = db.prepare(`\n    INSERT INTO invoices (customer_id, date, subtotal, discount_rate, tax_rate, total, status)\n    VALUES (?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const insertLineItem = db.prepare(`\n    INSERT INTO line_items (invoice_id, description, quantity, unit_price)\n    VALUES (?, ?, ?, ?)\n  `);\n\n  const result = insertInvoice.run(\n    data.customer_id,\n    data.date,\n    data.subtotal,\n    data.discount_rate,\n    data.tax_rate,\n    data.total,\n    data.status || 'draft',\n  );\n\n  const invoiceId = result.lastInsertRowid as number;\n\n  if (data.line_items) {\n    for (const item of data.line_items) {\n      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    }\n  }\n\n  return invoiceId;\n}\n\n/**\n * Retrieve all invoices for a specific customer.\n */\nexport function getInvoicesByCustomer(\n  db: Database.Database,\n  customerId: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE customer_id = ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(customerId) as Invoice[];\n}\n","numLines":90,"startLine":1,"totalLines":90}}}
