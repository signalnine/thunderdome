+type Direction = 'down' | 'down-left' | 'down-right';
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') {
+      return [0, c];
+    }
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':
+      return [row + 1, col];
+    case 'down-left':
+      return [row + 1, col - 1];
+    case 'down-right':
+      return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+// Encode (row, col, dir) as a single integer for fast set/map operations.
+// dir: 0=down, 1=down-left, 2=down-right
+function dirIndex(dir: Direction): number {
+  switch (dir) {
+    case 'down': return 0;
+    case 'down-left': return 1;
+    case 'down-right': return 2;
+  }
+}
+
+function stateKey(row: number, col: number, dir: Direction, cols: number): number {
+  return (row * cols + col) * 3 + dirIndex(dir);
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<number>(); // cell keys: row * cols + col
+  const seenStates = new Set<number>(); // state keys: (row, col, dir)
+
+  interface Beam {
+    row: number;
+    col: number;
+    dir: Direction;
+  }
+
+  const queue: Beam[] = [];
+  const [sr, sc] = source;
+  visited.add(sr * cols + sc);
+
+  // Initial beam starts at source going down
+  const initKey = stateKey(sr, sc, 'down', cols);
+  seenStates.add(initKey);
+  queue.push({ row: sr, col: sc, dir: 'down' });
+
+  while (queue.length > 0) {
+    const beam = queue.pop()!;
+    const [nr, nc] = advance(beam.row, beam.col, beam.dir);
+
+    if (!inBounds(nr, nc, rows, cols)) continue;
+
+    visited.add(nr * cols + nc);
+    const cell = grid[nr][nc];
+
+    if (cell === '^') {
+      const dirs: Direction[] = ['down-left', 'down-right'];
+      for (const d of dirs) {
+        const sk = stateKey(nr, nc, d, cols);
+        if (!seenStates.has(sk)) {
+          seenStates.add(sk);
+          queue.push({ row: nr, col: nc, dir: d });
+        }
+      }
+    } else {
+      const sk = stateKey(nr, nc, beam.dir, cols);
+      if (!seenStates.has(sk)) {
+        seenStates.add(sk);
+        queue.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // For path counting, we accumulate the number of paths that reach each
+  // (row, col, dir) state. When a state is processed, it propagates its
+  // path count to successor states (or to the exit total).
+  // We process states in row order (top to bottom) to ensure dependencies
+  // are resolved before use.
+
+  // pathCount[stateKey] = number of distinct paths reaching this state
+  const pathCount = new Map<number, bigint>();
+
+  const [sr, sc] = source;
+  const initKey = stateKey(sr, sc, 'down', cols);
+  pathCount.set(initKey, 1n);
+
+  // Process row by row, top to bottom. Within each row, for each cell,
+  // check all 3 directions. This ensures we process parent states before children.
+  let totalPaths = 0n;
+
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      const dirs: Direction[] = ['down', 'down-left', 'down-right'];
+      for (const dir of dirs) {
+        const sk = stateKey(r, c, dir, cols);
+        const count = pathCount.get(sk);
+        if (count === undefined) continue;
+
+        const [nr, nc] = advance(r, c, dir);
+
+        if (!inBounds(nr, nc, rows, cols)) {
+          // Beam exits the grid
+          totalPaths += count;
+          continue;
+        }
+
+        const cell = grid[nr][nc];
+
+        if (cell === '^') {
+          // Splitter: propagate to down-left and down-right
+          for (const d of ['down-left', 'down-right'] as Direction[]) {
+            const nsk = stateKey(nr, nc, d, cols);
+            pathCount.set(nsk, (pathCount.get(nsk) ?? 0n) + count);
+          }
+        } else {
+          // Continue same direction
+          const nsk = stateKey(nr, nc, dir, cols);
+          pathCount.set(nsk, (pathCount.get(nsk) ?? 0n) + count);
+        }
+      }
+    }
+  }
+
+  return totalPaths;
+}
