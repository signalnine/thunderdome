+    // Row 2: splitter at (2,1) → DL to (3,0), DR to (3,2)
+    //         splitter at (2,3) → DL to (3,2), DR to (3,4)
+    // Row 3: splitter at (3,0) → 2 exits; (3,2) no splitter → 1 exit each (2 beams); splitter at (3,4) → 2 exits
+    // Total: 2 + 1 + 1 + 2 = 6
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '^', '.', '^', '.'],
+      ['^', '.', '.', '.', '^'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+
+  it('handles large grids with many splitters efficiently', () => {
