+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('returns 0 for empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('returns 0 for grid with no source', () => {
+    const grid = [
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it('beam goes straight down with no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Visits: (0,1), (1,1), (2,1)
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visits: (0,1), (1,1), (2,1), (3,0), (3,2) → 5
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example 2: two splitters on row 2', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Visits: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) → 6
+    // Note: (3,-1) is out of bounds, (3,1) hit by two beams but counted once
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('source on single-row grid', () => {
+    const grid = [
+      ['.', 'S', '.'],
+    ];
+    // Only the source cell is visited, beam exits immediately
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam absorbed when going out of bounds left', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // (0,0) -> (1,0) hits splitter -> down-left (2,-1) absorbed, down-right (2,1) visited
+    // Visited: (0,0), (1,0), (2,1) → 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('beam absorbed when going out of bounds right', () => {
+    const grid = [
+      ['.', '.', 'S'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // (0,2) -> (1,2) hits splitter -> down-left (2,1), down-right (2,3) absorbed
+    // Visited: (0,2), (1,2), (2,1) → 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('multiple splitters in chain', () => {
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '^', '.', '^', '.'],
+      ['^', '.', '.', '.', '^'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Row 0: (0,2) source
+    // Row 1: (1,2) splitter -> DL, DR
+    // Row 2: DL->(2,1) splitter -> DL, DR; DR->(2,3) splitter -> DL, DR
+    // Row 3: From (2,1)DL->(3,0) splitter -> DL,DR; (2,1)DR->(3,2); (2,3)DL->(3,2); (2,3)DR->(3,4) splitter -> DL,DR
+    // Row 4: (3,0)DL->(4,-1) OOB; (3,0)DR->(4,1); (3,2)down-left=>(4,1); (3,2)down-right=>(4,3); (3,4)DL->(4,3); (3,4)DR->(4,5) OOB
+    // Visited cells: (0,2),(1,2),(2,1),(2,3),(3,0),(3,2),(3,4),(4,1),(4,3) → 9
+    expect(countBeamCells(grid)).toBe(9);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('returns 0n for empty grid', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('returns 0n for grid with no source', () => {
+    const grid = [
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it('single path with no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('example 1: single splitter gives 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example 2: two splitters gives 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
