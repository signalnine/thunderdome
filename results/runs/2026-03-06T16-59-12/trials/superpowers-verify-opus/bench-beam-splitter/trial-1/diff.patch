+    // Each splitter doubles the paths
+    const col = 100;
+    for (let i = 0; i < 50; i++) {
+      const row = (i + 1) * 3; // spread splitters every 3 rows
+      if (row < rows && col >= 0 && col < cols) {
+        grid[row][col] = '^';
+      }
+    }
