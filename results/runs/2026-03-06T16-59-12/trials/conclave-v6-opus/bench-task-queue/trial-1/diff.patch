diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..ce4b4f9
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,61 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+  error?: string;
+  runAt?: Date;
+  delay?: number;
+}
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  runAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface ScheduleOptions {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  options?: Omit<TaskOptions, 'queue'>;
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  options?: Omit<TaskOptions, 'queue'>;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void> | void;
+export type ProcessorFn = (task: Task) => Promise<void> | void;
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  elapsed: number;
+}
