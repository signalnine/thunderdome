322→\n   323→  // Phase 9: Progress and Cancellation\n   324→  updateProgress(taskId: string, progress: number, message?: string): void {\n   325→    const task = this.allTasks.get(taskId);\n   326→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   327→    if (task.status !== 'processing') {\n   328→      throw new Error(`Task ${taskId} is not in processing state`);\n   329→    }\n   330→\n   331→    task.progress = progress;\n   332→    task.progressMessage = message;\n   333→\n   334→    const listeners = this.progressListeners.get(taskId);\n   335→    if (listeners) {\n   336→      for (const cb of listeners) {\n   337→        cb(progress, message);\n   338→      }\n   339→    }\n   340→  }\n   341→\n   342→  getProgress(taskId: string): { progress: number; message?: string } {\n   343→    const task = this.allTasks.get(taskId);\n   344→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   345→    return { progress: task.progress, message: task.progressMessage };\n   346→  }\n   347→\n   348→  onProgress(taskId: string, callback: ProgressCallback): void {\n   349→    let listeners = this.progressListeners.get(taskId);\n   350→    if (!listeners) {\n   351→      listeners = new Set();\n   352→      this.progressListeners.set(taskId, listeners);\n   353→    }\n   354→    listeners.add(callback);\n   355→  }\n   356→\n   357→  offProgress(taskId: string, callback: ProgressCallback): void {\n   358→    const listeners = this.progressListeners.get(taskId);\n   359→    if (listeners) {\n   360→      listeners.delete(callback);\n   361→    }\n   362→  }\n   363→\n   364→  cancel(taskId: string): Task {\n   365→    const task = this.allTasks.get(taskId);\n   366→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   367→\n   368→    if (task.status === 'pending') {\n   369→      const bucket = this.queues.get(task.queue);\n   370→      if (bucket) {\n   371→        const idx = bucket.tasks.findIndex(t => t.id === taskId);\n   372→      