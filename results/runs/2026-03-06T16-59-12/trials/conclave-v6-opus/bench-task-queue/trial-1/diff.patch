n      this.queues.set(name, bucket);\n    }\n    return bucket;\n  }\n\n  enqueue<T>(payload: T, options?: TaskOptions): Task<T> {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down, cannot add new tasks');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    if (options?.runAt) {\n      availableAt = options.runAt;\n    } else if (options?.delay && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Validate dependencies\n    if (options?.dependencies) {\n      for (const depId of options.dependencies) {\n        if (!this.allTasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n      // Check for circular dependencies\n      this.detectCircularDependencies(options.dependencies);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: now,\n      queue: queueName,\n      priority,\n      availableAt,\n      attempts: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      dependencies: options?.dependencies ? [...options.dependencies] : [],\n      progress: 0,\n      delay: options?.delay,\n      runAt: options?.runAt,\n    };\n\n    this.allTasks.set(task.id, task as Task);\n    const bucket = this.getOrCreateBucket(queueName);\n    this.insertSorted(bucket.tasks, task as Task);\n\n    return task;\n  }\n\n  dequeue(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const bucket = this.queues.get(name);\n    if (!bucket) return null;\n\n    // Check