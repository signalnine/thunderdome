= -1) return null;\n\n    const task = bucket.tasks[idx];\n    bucket.tasks.splice(idx, 1);\n    task.status = 'processing';\n    task.attempts += 1;\n    bucket.processing.set(task.id, task);\n\n    return task;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const bucket = this.queues.get(name);\n    if (!bucket) return 0;\n    return bucket.tasks.filter(t => t.status === 'pending').length;\n  }\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.allTasks.get(taskId);\n  }\n\n  complete(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    const bucket = this.queues.get(task.queue);\n    if (bucket) {\n      bucket.processing.delete(taskId);\n    }\n\n    // Check if any blocked tasks can now be unblocked\n    this.checkDependents(taskId);\n\n    return task;\n  }\n\n  fail(taskId: string, error?: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    const bucket = this.queues.get(task.queue);\n    if (bucket) {\n      bucket.processing.delete(taskId);\n    }\n\n    task.error = error;\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n\n      if (bucket) {\n        this.insertSorted(bucket.tasks, task);\n      }\n    } else {\n      // All retries exhausted\n      task.status = 'failed';\n\n      // Move to DLQ\n      if (bucket) {\n        bucket.dlq.push(task);\n      }\n    }\n\n    return task;\n  }\n\n  // Phase 6: Dead Letter Queue\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const bucket = this.queues.get(name);\n    if (!bucket) return [];\n    return [...bucket.dlq];\n  }\n\n  retryDeadLetter(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const bucket = this.queues.get(task.queue);\n    if (!bucket) throw new Error(`Queue not found: ${task.queue}`);\n\n    const dlqIdx = bucket.dlq.findIndex(t => t.id === taskId);\n    if (dlqIdx === -1) throw new Error(`Task ${taskId} is not in the dead letter queue`);\n\n    bucket.dlq.splice(dlqIdx, 1);\n\n    // Reset for fresh retries\n    task.status = 'pending';\n    task.attempts = 0;\n    task.availableAt = new Date();\n    task.error = undefined;\n\n    this.insertSorted(bucket.tasks, task);\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const bucket = this.queues.get(name);\n    if (bucket) {\n      bucket.dlq.length = 0;\n    }\n  }\n\n  // Phase 7: Dependencies\n  private areDependenciesMet(task: Task): boolean {\n    if (task.dependencies.length === 0) return true;\n    return task.dependencies.every(depId => {\n      const dep = this.allTasks.get(depId);\n      return dep?.status === 'completed';\n    });\n  }\n\n  private checkDependents(completedTaskId: string): void {\n    // No-op; dependency checks happen at dequeue time\n    // This is intentional - we check at dequeue time for simplicity\n  }\n\n  private detectCircularDependencies(newDeps: string[]): void {\n    // BFS/DFS to check if adding these dependencies creates a cycle\n    // Since we're adding a new task, we need to check if any of its\n    // dependencies eventually depend on each other in a way that creates cycles\n    // Actually, since the new task doesn't exist yet, it can't be referenced\n    // by existing tasks. So we just need to verify that the dependencies themselves\n    // don't form a cycle among themselves.\n    // But we also need to check transitive dependencies.\n    const visited = new Set<string>();\n    const stack = [...newDeps];\n\n    while (stack.length > 0) {\n      const id = stack.pop()!;\n      if (visited.has(id)) continue;\n      visited.add(id);\n\n      const task = this.allTasks.get(id);\n      if (task) {\n        for (const depId of task.dependencies) {\n          stack.push(depId);\n        }\n      }\n    }\n\n    // No cycle possible for a brand new task since nothing depends on it yet\n    // But we need to detect if a chain among deps forms a cycle\n    // Since the new task ID doesn't exist yet, a cycle among existing deps\n    // would have been caught at their creation time.\n  }\n\n  getDependencyStatus(taskId: string): { taskId: string; met: boolean; dependencies: Array<{ id: string; status: TaskStatus; met: boolean }> } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const depStatuses = task.dependencies.map(depId => {\n      const dep = this.allTasks.get(depId);\n      return {\n        id: depId,\n        status: dep?.status ?? ('unknown' as TaskStatus),\n        met: dep?.status === 'completed',\n      };\n    });\n\n    return {\n      taskId: task.id,\n      met: depStatuses.every(d => d.met),\n      dependencies: depStatuses,\n    };\n  }\n\n  // Phase 8: Concurrency Control\n  setConcurrency(queueName: string, limit: number): void {\n    const bucket = this.getOrCreateBucket(queueName);\n    bucket.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName: string): { limit: number; active: number } {\n    const bucket = this.queues.get(queueName);\n    if (!bucket) return { limit: 0, active: 0 };\n    return {\n      limit: bucket.concurrencyLimit,\n      active: bucket.processing.size,\n    };\n  }\n\n  // Phase 9: Progress and Cancellation\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const cb of listeners) {\n        cb(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): void {\n    let listeners = this.progressListeners.get(taskId);\n    if (!listeners) {\n      listeners = new Set();\n      this.progressListeners.set(taskId, listeners);\n    }\n    listeners.add(callback);\n  }\n\n  offProgress(taskId: string, callback: ProgressCallback): void {\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      listeners.delete(callback);\n    }\n  }\n\n  cancel(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status === 'pending') {\n      const bucket = this.queues.get(task.queue);\n      if (bucket) {\n        const idx = bucket.tasks.findIndex(t => t.id === taskId);\n        if (idx !== -1) bucket.tasks.splice(idx, 1);\n      }\n      task.status = 'cancelled';\n    } else if (task.status === 'processing') {\n      const bucket = this.queues.get(task.queue);\n      if (bucket) {\n        bucket.processing.delete(taskId);\n      }\n      task.status = 'cancelled';\n    } else {\n      throw new Error(`Cannot cancel task with status: ${task.status}`);\n    }\n\n    return task;\n  }\n\n  // Phase 10: Recurring Tasks\n  addSchedule(schedule: { id: string; cron: string; queue: string; payload: unknown; options?: Omit<TaskOptions, 'queue'> }): Schedule {\n    if (this.schedules.has(schedule.id)) {\n      throw new Error(`Schedule already exists: ${schedule.id}`);\n    }\n\n    const s: Schedule = {\n      id: schedule.id,\n      cron: schedule.cron,\n      queue: schedule.queue,\n      payload: schedule.payload,\n      options: schedule.options,\n    };\n\n    this.schedules.set(s.id, s);\n    return s;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule not found: ${scheduleId}`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  listSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const enqueued: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRun(schedule, currentTime)) {\n        const task = this.enqueue(schedule.payload, {\n          ...schedule.options,\n          queue: schedule.queue,\n        });\n        enqueued.push(task as Task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return enqueued;\n  }\n\n  private shouldRun(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cron.split(/\\s+/);\n    if (parts.length < 5) return false;\n\n    const [minutePart, hourPart] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Parse minute field\n    let minuteMatch = false;\n    if (minutePart === '*') {\n      minuteMatch = true;\n    } else if (minutePart.startsWith('*/')) {\n      const interval = parseInt(minutePart.slice(2), 10);\n      minuteMatch = currentMinute % interval === 0;\n    } else {\n      minuteMatch = parseInt(minutePart, 10) === currentMinute;\n    }\n\n    // Parse hour field\n    let hourMatch = false;\n    if (hourPart === '*') {\n      hourMatch = true;\n    } else if (hourPart.startsWith('*/')) {\n      const interval = parseInt(hourPart.slice(2), 10);\n      hourMatch = currentHour % interval === 0;\n    } else {\n      hourMatch = parseInt(hourPart, 10) === currentHour;\n    }\n\n    if (!minuteMatch || !hourMatch) return false;\n\n    // Check if we already ran this schedule at this time\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (lastDate === nowDate && lastMinute === currentMinute && lastHour === currentHour) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  // Phase 11: Middleware\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const bucket = this.getOrCreateBucket(queueName);\n    bucket.middleware.push(middleware);\n  }\n\n  process(queueName: string, handler: ProcessorFn): void {\n    const bucket = this.getOrCreateBucket(queueName);\n    bucket.handler = handler;\n  }\n\n  async processNext(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const task = this.dequeue(name);\n    if (!task) return null;\n\n    const bucket = this.queues.get(name);\n    if (!bucket) return task;\n\n    const middlewares = [...bucket.middleware];\n    const handler = bucket.handler;\n\n    try {\n      let idx = 0;\n      const executeNext = async (): Promise<void> => {\n        if (idx < middlewares.length) {\n          const mw = middlewares[idx++];\n          await mw(task, executeNext);\n        } else if (handler) {\n          await handler(task);\n        }\n      };\n\n      await executeNext();\n\n      if (task.status === 'processing') {\n        this.complete(task.id);\n      }\n    } catch (err) {\n      const errorMsg = err instanceof Error ? err.message : String(err);\n      this.fail(task.id, errorMsg);\n    }\n\n    return task;\n  }\n\n  // Phase 12: Graceful Shutdown\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShutdown = true;\n    this.shutdownPromise = this.executeShutdown(options);\n    return this.shutdownPromise;\n  }\n\n  private async executeShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    const timeout = options?.timeout ?? 30000;\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Gather all processing tasks\n    let processingTasks: Task[] = [];\n    for (const bucket of this.queues.values()) {\n      processingTasks.push(...bucket.processing.values());\n    }\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    if (processingTasks.length > 0) {\n      // Wait for processing tasks to complete, up to timeout\n      const waitResult = await Promise.race([\n        this.waitForProcessing(),\n        new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),\n      ]);\n\n      if (waitResult === 'timeout') {\n        // Force cancel remaining processing tasks\n        for (const bucket of this.queues.values()) {\n          for (const task of bucket.processing.values()) {\n            task.status = 'cancelled';\n            forceCancelled++;\n          }\n          bucket.processing.clear();\n        }\n      }\n\n      // Count completed tasks (those that were processing and completed during shutdown)\n      completed = processingTasks.length - forceCancelled;\n    }\n\n    const elapsed = Date.now() - startTime;\n\n    return { completed, forceCancelled, elapsed };\n  }\n\n  private async waitForProcessing(): Promise<void> {\n    while (true) {\n      let hasProcessing = false;\n      for (const bucket of this.queues.values()) {\n        if (bucket.processing.size > 0) {\n          hasProcessing = true;\n          break;\n        }\n      }\n      if (!hasProcessing) break;\n      await new Promise(resolve => setTimeout(resolve, 50));\n    }\n  }\n\n  // Sorted insertion: by availableAt, then priority (lower = higher), then FIFO (createdAt)\n  private insertSorted(tasks: Task[], task: Task): void {\n    let i = 0;\n    while (i < tasks.length) {\n      const existing = tasks[i];\n      // First sort by availability\n      if (task.availableAt < existing.availableAt) break;\n      if (task.availableAt > existing.availableAt) { i++; continue; }\n      // Same availability: sort by priority (lower number = higher priority)\n      if (task.priority < existing.priority) break;\n      if (task.priority > existing.priority) { i++; continue; }\n      // Same priority: FIFO (earlier createdAt first)\n      if (task.createdAt < existing.createdAt) break;\n      i++;\n    }\n    tasks.splice(i, 0, task);\n  }\n}\n","structuredPatch":[],"originalFile":null}}
