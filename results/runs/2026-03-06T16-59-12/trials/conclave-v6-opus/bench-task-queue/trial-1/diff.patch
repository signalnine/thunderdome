n  });\n\n  it('should cancel a pending task and remove it from the queue', () => {\n    const task = queue.enqueue('cancel-me');\n    expect(queue.size()).toBe(1);\n\n    queue.cancel(task.id);\n\n    expect(queue.size()).toBe(0);\n    expect(queue.dequeue()).toBeNull();\n    const cancelled = queue.getTask(task.id);\n    expect(cancelled!.status).toBe('cancelled');\n  });\n\n  it('should cancel a processing task', () => {\n    queue.enqueue('work');\n    const task = queue.dequeue()!;\n    queue.cancel(task.id);\n    expect(task.status).toBe('cancelled');\n  });\n\n  it('should never retry a cancelled task', () => {\n    vi.useFakeTimers();\n    queue.enqueue('cancel-no-retry', { maxRetries: 3, backoffDelay: 100 });\n    const task = queue.dequeue()!;\n\n    queue.cancel(task.id);\n\n    vi.advanceTimersByTime(10000);\n    expect(queue.dequeue()).toBeNull();\n    expect(queue.getTask(task.id)!.status).toBe('cancelled');\n    vi.useRealTimers();\n  });\n\n  it('should receive progress message in callback', () => {\n    queue.enqueue('work');\n    const task = queue.dequeue()!;\n    const messages: (string | undefined)[] = [];\n\n    queue.onProgress(task.id, (_progress, message) => {\n      messages.push(message);\n    });\n\n    queue.updateProgress(task.id, 50, 'processing chunk 1');\n    queue.updateProgress(task.id, 100, 'done');\n\n    expect(messages).toEqual(['processing chunk 1', 'done']);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4192,"cache_read_input_tokens":45459,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4192},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"63e03ec7-e878-44fc-94f5-afd9daa258f7","uuid":"1ba4f119-2c09-476f-8d51-8b8713580d57"}
