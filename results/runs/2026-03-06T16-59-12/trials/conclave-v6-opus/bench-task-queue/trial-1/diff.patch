ould be unblocked\n    const dep = queue.dequeue();\n    expect(dep).not.toBeNull();\n    expect(dep!.payload).toBe('dependent');\n    expect(dep!.id).toBe(dependent.id);\n  });","originalFile":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('Phase 07: Task Dependencies', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should allow tasks to declare dependencies on other tasks', () => {\n    const t1 = queue.enqueue('task1');\n    const t2 = queue.enqueue('task2', { dependencies: [t1.id] });\n    expect(t2.dependencies).toContain(t1.id);\n  });\n\n  it('should block tasks with unresolved dependencies from dequeue', () => {\n    const t1 = queue.enqueue('parent');\n    queue.enqueue('child', { dependencies: [t1.id] });\n\n    // Should dequeue t1, not child (child is blocked)\n    const dequeued = queue.dequeue();\n    expect(dequeued!.payload).toBe('parent');\n\n    // Child is still blocked\n    const next = queue.dequeue();\n    expect(next).toBeNull();\n  });\n\n  it('should unblock tasks when their dependencies complete', () => {\n    const t1 = queue.enqueue('parent');\n    queue.enqueue('child', { dependencies: [t1.id] });\n\n    const parent = queue.dequeue()!;\n    queue.complete(parent.id);\n\n    const child = queue.dequeue();\n    expect(child).not.toBeNull();\n    expect(child!.payload).toBe('child');\n  });\n\n  it('should detect and reject direct circular dependencies', () => {\n    const t1 = queue.enqueue('task1');\n    const t2 = queue.enqueue('task2', { dependencies: [t1.id] });\n\n    // t1 depends on t2, t2 depends on t1 => circular\n    // But since t1 already exists without deps, the circular would require\n    // modifying t1's deps. Let's test indirect cycle detection.\n    // A direct cycle: A -> B -> A is impossible since A already exists when B is created.\n    // What we can test: A -> B, C -> A, B -> C (indirect cycle)\n    // Actually, since A is already created, B depends on A.\n    // Now creating C with deps on B: C -> B -> A (no cycle).\n    // The issue is creating a task that depends on a task that depends on itself.\n    // Let's test: create t1, create t2 with dep [t1], then try to\n    // modify... Actually we can't create a circular dependency with this API\n    // since tasks can only depend on previously created tasks.\n\n    // The real test is detecting it via the dependency status.\n    // Let's test that depending on a non-existent task throws an error.\n    expect(t2.dependencies).toContain(t1.id);\n  });\n\n  it('should throw when depending on a non-existent task', () => {\n    expect(() =>\n      queue.enqueue('orphan', { dependencies: ['nonexistent-id'] })\n    ).toThrow();\n  });\n\n  it('should keep dependents blocked when a dependency fails', () => {\n    const parent = queue.enqueue('parent');\n    queue.enqueue('child', { dependencies: [parent.id] });\n\n    const p = queue.dequeue()!;\n    queue.fail(p.id, 'parent failed');\n\n    // Child should remain blocked (not auto-failed)\n    const child = queue.dequeue();\n    expect(child).toBeNull();\n  });\n\n  it('should support multiple dependencies', () => {\n    const t1 = queue.enqueue('dep1');\n    const t2 = queue.enqueue('dep2');\n    queue.enqueue('dependent', { dependencies: [t1.id, t2.id] });\n\n    const d1 = queue.dequeue()!;\n    queue.complete(d1.id);\n\n    // Still blocked (t2 not complete)\n    expect(queue.dequeue()).toBeNull();\n\n    const d2 = queue.dequeue();\n    expect(d2).toBeNull();\n\n    // Actually we need to dequeue t2 first and complete it\n    // t2 is still pending, let's dequeue it\n    // Wait: we already dequeued d1 (which is t1), and t2 is still pending\n    // But the dependent is also pending. dequeue should return t2 (no deps, pending).\n    // Let me re-check: t1 and t2 have no deps, dependent has deps [t1, t2].\n    // After dequeuing and completing t1, t2 is still pending.\n    // dequeue should return t2 next.\n  });\n\n  it('should allow inspecting dependency status', () => {\n    const t1 = queue.enqueue('dep1');\n    const t2 = queue.enqueue('dep2');\n    const dependent = queue.enqueue('dependent', { dependencies: [t1.id, t2.id] });\n\n    const status = queue.getDependencyStatus(dependent.id);\n    expect(status.met).toBe(false);\n    expect(status.dependencies.length).toBe(2);\n\n    // Complete t1\n    const d1 = queue.dequeue()!;\n    queue.complete(d1.id);\n\n    const status2 = queue.getDependencyStatus(dependent.id);\n    expect(status2.met).toBe(false);\n    expect(status2.dependencies.find(d => d.id === t1.id)!.met).toBe(true);\n\n    // Complete t2\n    const d2 = queue.dequeue()!;\n    queue.complete(d2.id);\n\n    const status3 = queue.getDependencyStatus(dependent.id);\n    expect(status3.met).toBe(true);\n  });\n});\n","structuredPatch":[{"oldStart":81,"oldLines":24,"newStart":81,"newLines":27,"lines":["   it('should support multiple dependencies', () => {","     const t1 = queue.enqueue('dep1');","     const t2 = queue.enqueue('dep2');","-    queue.enqueue('dependent', { dependencies: [t1.id, t2.id] });","+    const dependent = queue.enqueue('dependent', { dependencies: [t1.id, t2.id] });"," ","+    // Dequeue t1 (first available, no deps)","     const d1 = queue.dequeue()!;","+    expect(d1.payload).toBe('dep1');","     queue.complete(d1.id);"," ","-    // Still blocked (t2 not complete)","+    // t2 is still pending and has no deps, so it should dequeue next (dependent is still blocked)","+    const d2 = queue.dequeue()!;","+    expect(d2.payload).toBe('dep2');","+","+    // dependent is still blocked because t2 is not completed yet","     expect(queue.dequeue()).toBeNull();"," ","-    const d2 = queue.dequeue();","-    expect(d2).toBeNull();","+    queue.complete(d2.id);"," ","-    // Actually we need to dequeue t2 first and complete it","-    // t2 is still pending, let's dequeue it","-    // Wait: 