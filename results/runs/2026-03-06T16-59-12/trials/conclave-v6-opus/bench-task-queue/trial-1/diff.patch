empty queue', () => {\n    const task = queue.dequeue();\n    expect(task).toBeNull();\n  });\n\n  it('should return null after all tasks have been dequeued', () => {\n    queue.enqueue('only');\n    queue.dequeue();\n    const task = queue.dequeue();\n    expect(task).toBeNull();\n  });\n\n  it('should report the correct size of pending tasks', () => {\n    expect(queue.size()).toBe(0);\n    queue.enqueue('a');\n    queue.enqueue('b');\n    expect(queue.size()).toBe(2);\n    queue.dequeue();\n    expect(queue.size()).toBe(1);\n    queue.dequeue();\n    expect(queue.size()).toBe(0);\n  });\n\n  it('should accept any payload type', () => {\n    const t1 = queue.enqueue('string');\n    const t2 = queue.enqueue(42);\n    const t3 = queue.enqueue({ complex: true });\n    const t4 = queue.enqueue([1, 2, 3]);\n    const t5 = queue.enqueue(null);\n\n    expect(t1.payload).toBe('string');\n    expect(t2.payload).toBe(42);\n    expect(t3.payload).toEqual({ complex: true });\n    expect(t4.payload).toEqual([1, 2, 3]);\n    expect(t5.payload).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":296,"cache_read_input_tokens":36450,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":296},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"63e03ec7-e878-44fc-94f5-afd9daa258f7","uuid":"4474c32a-1838-4748-bd7d-b0b5f082ab1f"}
