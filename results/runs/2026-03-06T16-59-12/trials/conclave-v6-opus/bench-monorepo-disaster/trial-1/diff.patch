);\n      }\n    }\n\n    expect(filesWithMarkers).toEqual([]);\n  });\n\n  it('has no .env files with secrets', () => {\n    const allFiles = getAllFiles(ROOT_DIR);\n    const envFiles = allFiles.filter((f) => {\n      const name = f.split('/').pop() || '';\n      return name === '.env' || name.match(/^\\.env\\./);\n    });\n\n    const envFilesWithSecrets: string[] = [];\n    for (const envFile of envFiles) {\n      const content = readFileSync(envFile, 'utf-8');\n      if (\n        content.includes('PASSWORD') ||\n        content.includes('SECRET') ||\n        content.includes('TOKEN') ||\n        content.includes('API_KEY')\n      ) {\n        envFilesWithSecrets.push(envFile.replace(ROOT_DIR + '/', ''));\n      }\n    }\n\n    expect(envFilesWithSecrets).toEqual([]);\n  });\n\n  it('all packages build successfully', () => {\n    try {\n      execSync('npx tsc -b --force', {\n        cwd: ROOT_DIR,\n        encoding: 'utf-8',\n        timeout: 60000,\n      });\n    } catch (err) {\n      const error = err as { stdout?: string; stderr?: string };\n      throw new Error(\n        `Build failed:\\n${error.stdout || ''}${error.stderr || ''}`\n      );\n    }\n  });\n\n  it('TypeScript strict mode is enabled in all packages', () => {\n    const packages = ['core', 'api', 'worker'];\n\n    for (const pkg of packages) {\n      const tsconfigPath = join(ROOT_DIR, 'packages', pkg, 'tsconfig.json');\n      expect(existsSync(tsconfigPath), `${pkg}/tsconfig.json must exist`).toBe(\n        true\n      );\n\n      const tsconfig = JSON.parse(readFileSync(tsconfigPath, 'utf-8'));\n      expect(\n        tsconfig.compilerOptions?.strict,\n        `${pkg} must have strict: true`\n      ).toBe(true);\n    }\n  });\n});\n","numLines":133,"startLine":1,"totalLines":133}}}
