ds = new Set(bestAssignments.map((a) => a.eventId));\n+  const unscheduled = events.filter((e) => !scheduledIds.has(e.id)).map((e) => e.id);\n+\n+  return { assignments: bestAssignments, unscheduled };\n+}\n+\n+/**\n+ * Check if eventA is a (direct or transitive) prerequisite of eventB.\n+ */\n+function isPrerequisiteOf(\n+  eventAId: string,\n+  eventBId: string,\n+  eventMap: Map<string, Event>\n+): boolean {\n+  const visited = new Set<string>();\n+  const stack = [eventBId];\n+\n+  while (stack.length > 0) {\n+    const current = stack.pop()!;\n+    if (visited.has(current)) continue;\n+    visited.add(current);\n+\n+    const evt = eventMap.get(current);\n+    if (!evt?.prerequisites) continue;\n+\n+    for (const pre of evt.prerequisites) {\n+      if (pre === eventAId) return true;\n+      stack.push(pre);\n+    }\n+  }\n+\n+  return false;\n+}","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
