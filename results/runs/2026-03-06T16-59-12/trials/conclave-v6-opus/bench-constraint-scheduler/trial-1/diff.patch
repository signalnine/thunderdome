694-13a04f82390d","tool_use_result":{"type":"update","filePath":"/workspace/src/scheduler.ts","content":"// Types and implementation for constraint-based event scheduler\n\nexport interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n/**\n * Topological sort using Kahn's algorithm. Throws on cycles.\n * Returns event IDs in valid prerequisite order.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map((e) => e.id));\n  const inDegree = new Map<string, number>();\n  const adjacency = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    adjacency.set(e.id, []);\n  }\n\n  for (const e of events) {\n    if (!e.prerequisites) continue;\n    for (const pre of e.prerequisites) {\n      if (!eventIds.has(pre)) continue; // ignore unknown prerequisites\n      adjacency.get(pre)!.push(e.id);\n      inDegree.set(e.id, inDegree.get(e.id)! + 1);\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const current = queue.shift()!;\n    sorted.push(current);\n    for (const neighbor of adjacency.get(current)!) {\n      const newDeg = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  if (sorted.length !== events.length) {\n    throw new Error('Prerequisite cycle detected');\n  }\n\n  return sorted;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * respecting room timeline gaps and prerequisite end times.\n */\nfunction findEarliestStart(\n  event: Event,\n  roomId: string,\n  roomTimelines: Map<string, Assignment[]>,\n  eventEndTimes: Map<string, number>,\n  options: ScheduleOptions,\n  gap: number\n): number | null {\n  const windowStart = options.startTime;\n  const windowEnd = options.endTime;\n\n  // Earliest based on prerequisites\n  let earliest = windowStart;\n  if (event.prerequisites) {\n    for (const preId of event.prerequisites) {\n      const preEnd = eventEndTimes.get(preId);\n      if (preEnd !== undefined) {\n        earliest = Math.max(earliest, preEnd + gap);\n      }\n    }\n  }\n\n  // Check room timeline for available slot\n  const timeline = roomTimelines.get(roomId) || [];\n\n  if (timeline.length === 0) {\n    // Room is empty, check if event fits starting from earliest\n    const endTime = earliest + event.duration;\n    if (endTime <= windowEnd) return earliest;\n    return null;\n  }\n\n  // Sort timeline by start time\n  const sorted = [...timeline].sort((a, b) => a.startTime - b.startTime);\n\n  // Try before the first event\n  if (earliest + event.duration <= sorted[0].startTime - gap ||\n      (earliest + event.duration <= sorted[0].startTime && gap === 0)) {\n    const gapNeeded = sorted[0].startTime - earliest - event.duration;\n    if (gapNeeded >= gap) {\n      const endTime = earliest + event.duration;\n      if (endTime <= windowEnd) return earliest;\n    }\n  }\n\n  // Try gaps between events\n  for (let i = 0; i < sorted.length; i++) {\n    const candidateStart = Math.max(earliest, sorted[i].endTime + gap);\n    const candidateEnd = candidateStart + event.duration;\n\n    // Check if this fits before the next event (or end of window)\n    const nextStart = i + 1 < sorted.length ? sorted[i + 1].startTime : windowEnd + gap;\n\n    if (candidateEnd <= windowEnd && candidateEnd + gap <= nextStart) {\n      return candidateStart;\n    }\n    // Also allow if it's the last event and fits in window\n    if (i + 1 >= sorted.length && candidateEnd <= windowEnd) {\n      return candidateStart;\n    }\n  }\n\n  return null;\n}\n\n/**\n * Try scheduling a set of events and return the result.\n * Used by the optimization loop.\n */\nfunction trySchedule(\n  eventSubset: Event[],\n  eventMap: Map<string, Event>,\n  sortedOrder: string[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number\n): { assignments: Assignment[]; scheduled: Set<string> } {\n  const subsetIds = new Set(eventSubset.map((e) => e.id));\n  const roomTimelines = new Map<string, Assignment[]>();\n  const eventEndTimes = new Map<string, number>();\n  const assignments: Assignment[] = [];\n  const scheduled = new Set<string>();\n\n  for (const r of rooms) {\n    roomTimelines.set(r.id, []);\n  }\n\n  // Process events in topological order, but only those in subset\n  for (const eventId of sortedOrder) {\n    if (!subsetIds.has(eventId)) continue;\n    const event = eventMap.get(eventId)!;\n    const attendees = event.attendees ?? 1;\n\n    // Check prerequisites are all scheduled\n    if (event.prerequisites) {\n      const allPresMet = event.prerequisites.every(\n        (preId) => !subsetIds.has(preId) || scheduled.has(preId)\n      );\n      if (!allPresMet) continue;\n    }\n\n    // Get candidate rooms: preferred first, then by best-fit capacity\n    const validRooms = rooms.filter((r) => r.capacity >= attendees);\n    if (validRooms.length === 0) continue;\n\n    // Sort: preferred room first, then by capacity (smallest fitting)\n    const sortedRooms = [...validRooms].sort((a, b) => {\n      if (event.preferredRoom) {\n        if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n        if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n      }\n      return a.capacity - b.capacity;\n    });\n\n    let bestStart: number | null = null;\n    let bestRoom: string | null = null;\n\n    for (const r of sortedRooms) {\n      const start = findEarliestStart(\n        event,\n        r.id,\n        roomTimelines,\n        eventEndTimes,\n        options,\n        gap\n      );\n      if (start !== null) {\n        // Prefer preferred room even if it starts slightly later\n        if (event.preferredRoom && r.id === event.preferredRoom) {\n          bestStart = start;\n          bestRoom = r.id;\n          break;\n        }\n        if (bestStart === null || start < bestStart) {\n          bestStart = start;\n          bestRoom = r.id;\n        }\n      }\n    }\n\n    if (bestStart !== null && bestRoom !== null) {\n      const assignment: Assignment = {\n        eventId: event.id,\n        roomId: bestRoom,\n        startTime: bestStart,\n        endTime: bestStart + event.duration,\n      };\n      assignments.push(assignment);\n      roomTimelines.get(bestRoom)!.push(assignment);\n      eventEndTimes.set(event.id, assignment.endTime);\n      scheduled.add(event.id);\n    }\n  }\n\n  return { assignments, scheduled };\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  if (rooms.length === 0) {\n    return { assignments: [], unscheduled: events.map((e) => e.id) };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Cycle detection via topological sort (throws on cycle)\n  const sortedOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // First pass: greedy schedule all events\n  const firstResult = trySchedule(events, eventMap, sortedOrder, rooms, options, gap);\n\n  if (firstResult.scheduled.size === events.length) {\n    return {\n      assignments: firstResult.assignments,\n      unscheduled: [],\n    };\n  }\n\n  // Optimization: try removing unscheduled-blocking events\n  // For events that couldn't be scheduled, check if removing some\n  // scheduled events allows more total events\n  let bestAssignments = firstResult.assignments;\n  let bestCount = firstResult.scheduled.size;\n\n  const unscheduledFirst = events.filter((e) => !firstResult.scheduled.has(e.id));\n\n  // Try removing each scheduled event one at a time and see if we can fit more\n  for (const removeCandidate of firstResult.assignments) {\n    const subsetWithout = events.filter((e) => e.id !== removeCandidate.eventId);\n\n    // Check that removing this doesn't break prerequisite chains for others\n    const hasDependent = events.some(\n      (e) => e.prerequisites?.includes(removeCandidate.eventId) && firstResult.scheduled.has(e.id)\n    );\n\n    // Only try removing if nothing critical depends on it, or if the\n    // unscheduled events don't depend on it either\n    const result = trySchedule(subsetWithout, eventMap, sortedOrder, rooms, options, gap);\n\n    // Now try adding back the unscheduled events from first pass\n    // plus the removed event, to see if more fit\n    const remainingEvents = events.filter((e) => !result.scheduled.has(e.id));\n\n    if (remainingEvents.length > 0) {\n      // Try scheduling remaining in existing timeline\n      const allToTry = [...subsetWithout];\n      const fullResult = trySchedule(events.filter(e => e.id !== removeCandidate.eventId), eventMap, sortedOrder, rooms, options, gap);\n\n      if (fullResult.scheduled.size > bestCount) {\n        bestAssignments = fullResult.assignments;\n        bestCount = fullResult.scheduled.size;\n      }\n    }\n  }\n\n  // More aggressive optimization: try all subsets of events sorted by\n  // \"most constrained first\" principle - shorter events are more flexible\n  // Try sorting events differently and re-running\n  const byDuration = [...events].sort((a, b) => a.duration - b.duration);\n\n  // Build a new sort order that respects topological order but prefers shorter events\n  const topoLevel = new Map<string, number>();\n  for (let i = 0; i < sortedOrder.length; i++) {\n    topoLevel.set(sortedOrder[i], i);\n  }\n\n  const altOrder = [...sortedOrder].sort((a, b) => {\n    const levelA = topoLevel.get(a)!;\n    const levelB = topoLevel.get(b)!;\n    // If at the same topological level, prefer shorter events\n    const eventA = eventMap.get(a)!;\n    const eventB = eventMap.get(b)!;\n\n    // Check if one must come before the other (transitively)\n    // Simple: if a is prerequisite of b (directly or transitively), a comes first\n    if (isPrerequisiteOf(a, b, eventMap)) return -1;\n    if (isPrerequisiteOf(b, a, eventMap)) return 1;\n\n    // Same level: shorter duration first\n    return eventA.duration - eventB.duration;\n  });\n\n  const altResult = trySchedule(events, eventMap, altOrder, rooms, options, gap);\n  if (altResult.scheduled.size > bestCount) {\n    bestAssignments = altResult.assignments;\n    bestCount = altResult.scheduled.size;\n  }\n\n  // Also try: sort by number of valid rooms (ascending) - most constrained first\n  const validRoomCount = new Map<string, number>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const count = rooms.filter((r) => r.capacity >= attendees).length;\n    validRoomCount.set(e.id, count);\n  }\n\n  const constraintOrder = [...sortedOrder].sort((a, b) => {\n    if (isPrerequisiteOf(a, b, eventMap)) return -1;\n    if (isPrerequisiteOf(b, a, eventMap)) return 1;\n\n    const countA = validRoomCount.get(a)!;\n    const countB = validRoomCount.get(b)!;\n    if (countA !== countB) return countA - countB;\n\n    const eventA = eventMap.get(a)!;\n    const eventB = eventMap.get(b)!;\n    return eventA.duration - eventB.duration;\n  });\n\n  const constraintResult = trySchedule(events, eventMap, constraintOrder, rooms, options, gap);\n  if (constraintResult.scheduled.size > bestCount) {\n    bestAssignments = constraintResult.assignments;\n    bestCount =