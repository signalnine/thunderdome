xpect(result.assignments.length + result.unscheduled.length).toBe(2);\n    });\n  });\n\n  describe('prerequisite constraints', () => {\n    it('schedules prerequisites before dependents', () => {\n      const events = [\n        event('A', 60),\n        event('B', 60, { prerequisites: ['A'] }),\n      ];\n      const rooms = [room('R1', 10), room('R2', 10)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const a = result.assignments.find((x) => x.eventId === 'A')!;\n      const b = result.assignments.find((x) => x.eventId === 'B')!;\n\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime);\n    });\n\n    it('enforces gap between prerequisite and dependent', () => {\n      const events = [\n        event('A', 60),\n        event('B', 60, { prerequisites: ['A'] }),\n      ];\n      const rooms = [room('R1', 10), room('R2', 10)];\n      const options: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n      const result = schedule(events, rooms, options);\n\n      expect(result.assignments).toHaveLength(2);\n      const a = result.assignments.find((x) => x.eventId === 'A')!;\n      const b = result.assignments.find((x) => x.eventId === 'B')!;\n\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n    });\n\n    it('handles chain of prerequisites', () => {\n      const events = [\n        event('A', 30),\n        event('B', 30, { prerequisites: ['A'] }),\n        event('C', 30, { prerequisites: ['B'] }),\n      ];\n      const rooms = [room('R1', 10)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const a = result.assignments.find((x) => x.eventId === 'A')!;\n      const b = result.assignments.find((x) => x.eventId === 'B')!;\n      const c = result.assignments.find((x) => x.eventId === 'C')!;\n\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n      expect(c.startTim