r((e) => e.id !== removeCandidate.eventId);\n    const result = trySchedule(subsetWithout, eventMap, sortedOrder, rooms, options, gap);\n\n    if (result.scheduled.size > bestCount) {\n      bestAssignments = result.assignments;\n      bestCount = result.scheduled.size;\n    }\n  }","originalFile":"// Types and implementation for constraint-based event scheduler\n\nexport interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n/**\n * Topological sort using Kahn's algorithm. Throws on cycles.\n * Returns event IDs in valid prerequisite order.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map((e) => e.id));\n  const inDegree = new Map<string, number>();\n  const adjacency = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    adjacency.set(e.id, []);\n  }\n\n  for (const e of events) {\n    if (!e.prerequisites) continue;\n    for (const pre of e.prerequisites) {\n      if (!eventIds.has(pre)) continue; // ignore unknown prerequisites\n      adjacency.get(pre)!.push(e.id);\n      inDegree.set(e.id, inDegree.get(e.id)! + 1);\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const current = queue.shift()!;\n    sorted.push(current);\n    for (const neighbor of adjacency.get(current)!) {\n      const newDeg = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  if (sorted.length !== events.length) {\n    throw new Error('Prerequisite cycle detected');\n  }\n\n  return sorted;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * respecting room timeline gaps and prerequisite end times.\n */\nfunction findEarliestStart(\n  event: Event,\n  roomId: string,\n  roomTimelines: Map<string, Assignment[]>,\n  eventEndTimes: Map<string, number>,\n  options: ScheduleOptions,\n  gap: number\n): number | null {\n  const windowStart = options.startTime;\n  const windowEnd = options.endTime;\n\n  // Earliest based on prerequisites\n  let earliest = windowStart;\n  if (event.prerequisites) {\n    for (const preId of event.prerequisites) {\n      const preEnd = eventEndTimes.get(preId);\n      if (preEnd !== undefined) {\n        earliest = Math.max(earliest, preEnd + gap);\n      }\n    }\n  }\n\n  // Check room timeline for available slot\n  const timeline = roomTimelines.get(roomId) || [];\n\n  if (timeline.length === 0) {\n    // Room is empty, check if event fits starting from earliest\n    const endTime = earliest + event.duration;\n    if (endTime <= windowEnd) return earliest;\n    return null;\n  }\n\n  // Sort timeline by start time\n  const sorted = [...timeline].sort((a, b) => a.startTime - b.startTime);\n\n  // Try before the first event\n  if (earliest + event.duration <= sorted[0].startTime - gap ||\n      (earliest + event.duration <= sorted[0].startTime && gap === 0)) {\n    const gapNeeded = sorted[0].startTime - earliest - event.duration;\n    if (gapNeeded >= gap) {\n      const endTime = earliest + event.duration;\n      if (endTime <= windowEnd) return earliest;\n    }\n  }\n\n  // Try gaps between events\n  for (let i = 0; i < sorted.length; i++) {\n    const candidateStart = Math.max(earliest, sorted[i].endTime + gap);\n    const candidateEnd = candidateStart + event.duration;\n\n    // Check if this fits before the next event (or end of window)\n    const nextStart = i + 1 < sorted.length ? sorted[i + 1].startTime : windowEnd + gap;\n\n    if (candidateEnd <= windowEnd && candidateEnd + gap <= nextStart) {\n      return candidateStart;\n    }\n    // Also allow if it's the last event and fits in window\n    if (i + 1 >= sorted.length && candidateEnd <= windowEnd) {\n      return candidateStart;\n    }\n  }\n\n  return null;\n}\n\n/**\n * Try scheduling a set of events and return the result.\n * Used by the optimization loop.\n */\nfunction trySchedule(\n  eventSubset: Event[],\n  eventMap: Map<string, Event>,\n  sortedOrder: string[],\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number\n): { assignments: Assignment[]; scheduled: Set<string> } {\n  const subsetIds = new Set(eventSubset.map((e) => e.id));\n  const roomTimelines = new Map<string, Assignment[]>();\n  const eventEndTimes = new Map<string, number>();\n  const assignments: Assignment[] = [];\n  const scheduled = new Set<string>();\n\n  for (const r of rooms) {\n    roomTimelines.set(r.id, []);\n  }\n\n  // Process events in topological order, but only those in subset\n  for (const eventId of sortedOrder) {\n    if (!subsetIds.has(eventId)) continue;\n    const event = eventMap.get(eventId)!;\n    const attendees = event.attendees ?? 1;\n\n    // Check prerequisites are all scheduled\n    if (event.prerequisites) {\n      const allPresMet = event.prerequisites.every(\n        (preId) => !subsetIds.has(preId) || scheduled.has(preId)\n      );\n      if (!allPresMet) continue;\n    }\n\n    // Get candidate rooms: preferred first, then by best-fit capacity\n    const validRooms = rooms.filter((r) => r.capacity >= attendees);\n    if (validRooms.length === 0) continue;\n\n    // Sort: preferred room first, then by capacity (smallest fitting)\n    const sortedRooms = [...validRooms].sort((a, b) => {\n      if (event.preferredRoom) {\n        if (a.id === event.preferredRoom && b.id !== event.preferredRo