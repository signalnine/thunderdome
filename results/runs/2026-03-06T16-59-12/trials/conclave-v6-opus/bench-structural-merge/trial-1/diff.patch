ect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);\n    });\n  });\n\n  describe('Version History', () => {\n    test('getHistory returns versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    test('each version has a unique id and timestamp', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n      expect(typeof history[0].timestamp).toBe('number');\n      expect(typeof history[1].timestamp).toBe('number');\n    });\n\n    test('getVersion returns content at a specific version', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });\n    });\n\n    test('getHistory throws for nonexistent document', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    test('getVersion throws for nonexistent version', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'bad-version')).toThrow();\n    });\n\n    test('getHistory returns deep clones', () => {\n      store.create('doc1', { v: 1 });\n      const history = store.getHistory('doc1');\n      (history[0].content as Record<string, number>).v = 999;\n      expect((store.getHistory('doc1')[0].content as Record<string, number>).v).toBe(1);\n    });\n  });\n\n  describe('Branching', () => {\n    test('default branch is main', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    test('listBranches returns all branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n      store.createBranch('feature');\n      expect(store.listBranches().sort()).toEqual(['feature', 'main']);\n    });\n\n    test('createBranch creates a new branch from current branch', () => {\n      store.create('doc1', { v: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n      expect(store.get('doc1')).toEqual({ v: 1 });\n    });\n\n    test('createBranch from a specific branch', () => {\n      store.create('doc1', { v: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { v: 2 });\n      store.switchBranch('main');\n      store.createBranch('hotfix', 'feature');\n      store.switchBranch('hotfix');\n      expect(store.get('doc1')).toEqual({ v: 2 });\n    });\n\n    test('changes on one branch are not visible on another', () => {\n      store.create('doc1', { v: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { v: 2 });\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ v: 1 });\n    });\n\n    test('switchBranch throws for nonexistent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    test('createBranch throws if branch already exists', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    test('documents created on a branch do not exist on other branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { v: 1 });\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    test('deleting on a branch does not affect other branches', () => {\n      store.create('doc1', { v: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ v: 1 });\n    });\n  });\n});\n","numLines":174,"startLine":1,"totalLines":174}}}
