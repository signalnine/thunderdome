index 0000000..259ccd5
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,432 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+interface DocState {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchState {
+  documents: Map<string, DocState>;
+}
+
+let versionCounter = 0;
+function nextVersionId(): string {
+  return `v${++versionCounter}`;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+  private branchAncestors: Map<string, Map<string, DocState>> = new Map();
+
+  constructor() {
+    this.branches.set('main', { documents: new Map() });
+  }
+
+  private getCurrentBranchState(): BranchState {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document '${id}' already exists`);
+    }
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: nextVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+    branch.documents.set(id, {
+      content: cloned,
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: nextVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+    doc.content = cloned;
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version '${versionId}' not found for document '${id}'`);
+    }
+    return deepClone(version.content);
+  }
+
+  private cloneBranchDocuments(docs: Map<string, DocState>): Map<string, DocState> {
+    const cloned = new Map<string, DocState>();
+    for (const [id, doc] of docs) {
+      cloned.set(id, {
+        content: deepClone(doc.content),
+        versions: doc.versions.map(v => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+        deleted: doc.deleted,
+      });
+    }
+    return cloned;
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch '${name}' already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch '${sourceName}' not found`);
+    }
+    const clonedDocs = this.cloneBranchDocuments(source.documents);
+    this.branches.set(name, { documents: clonedDocs });
+    this.branchAncestors.set(name, this.cloneBranchDocuments(source.documents));
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch '${name}' not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch '${sourceBranch}' not found`);
+    }
+    const current = this.getCurrentBranchState();
+
+    // Find ancestor snapshot
+    const ancestorDocs: Map<string, DocState> = this.branchAncestors.get(sourceBranch) ?? new Map();
+
+    // Collect all document IDs across all three states
+    const allDocIds = new Set<string>();
+    for (const id of ancestorDocs.keys()) allDocIds.add(id);
+    for (const id of current.documents.keys()) allDocIds.add(id);
+    for (const id of source.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    const changes: Array<{ id: string; content: object | null }> = [];
+
+    for (const docId of allDocIds) {
+      const baseDoc = ancestorDocs.get(docId);
+      const oursDoc = current.documents.get(docId);
+      const theirsDoc = source.documents.get(docId);
+
+      const baseExists = baseDoc && !baseDoc.deleted;
+      const oursExists = oursDoc && !oursDoc.deleted;
+      const theirsExists = theirsDoc && !theirsDoc.deleted;
+
+      const baseContent = baseExists ? baseDoc.content : undefined;
+      const oursContent = oursExists ? oursDoc.content : undefined;
+      const theirsContent = theirsExists ? theirsDoc.content : undefined;
+
+      // Check if anything changed from base
+      const oursChanged = !deepEqual(baseContent, oursContent) || (baseExists !== oursExists);
+      const theirsChanged = !deepEqual(baseContent, theirsContent) || (baseExists !== theirsExists);
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes on either side — skip
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        // Only source changed — take theirs
+        if (!theirsExists) {
+          // They deleted it
+          changes.push({ id: docId, content: null });
+        } else {
+          merged[docId] = deepClone(theirsContent!);
+          changes.push({ id: docId, content: deepClone(theirsContent!) });
+        }
+        continue;
+      }
+
+      if (oursChanged && !theirsChanged) {
+        // Only we changed — keep ours (already on current branch)
+        if (oursExists) {
+          merged[docId] = deepClone(oursContent!);
+        }
+        // If we deleted, it stays deleted; nothing to put in merged
+        continue;
+      }
+
+      // Both changed
+      if (!oursExists && !theirsExists) {
+        // Both deleted — no conflict
+        continue;
+      }
+
+      if (!oursExists || !theirsExists) {
+        // One deleted, one modified — treat as one-side-only for simplicity
+        // If ours deleted, keep ours (deleted); if theirs deleted, apply delete
+        if (!theirsExists) {
+          // They deleted, we modified — keep ours
+          merged[docId] = deepClone(oursContent!);
+        } else {
+          // We deleted, they modified — keep ours (deleted)
+        }
+        continue;
+      }
+
+      // Both modified and both exist — do structural three-way merge
+      const docConflicts: Conflict[] = [];
+      const mergedContent = threeWayMerge(
+        baseContent ?? {},
+        oursContent!,
+        theirsContent!,
+        docId,
+        '',
+        docConflicts,
+      );
+
+      merged[docId] = mergedContent;
+      conflicts.push(...docConflicts);
+
+      if (docConflicts.length === 0) {
+        changes.push({ id: docId, content: deepClone(mergedContent) });
+      }
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply changes to current branch
+      for (const change of changes) {
+        const doc = current.documents.get(change.id);
+        if (change.content === null) {
+          // Delete
+          if (doc) {
+            doc.deleted = true;
+          }
+        } else if (doc && !doc.deleted) {
+          // Update existing
+          doc.content = deepClone(change.content);
+          const version: Version = {
+            id: nextVersionId(),
+            timestamp: Date.now(),
+            content: deepClone(change.content),
+          };
+          doc.versions.push(version);
+        } else {
+          // Create new
+          const content = deepClone(change.content);
+          const version: Version = {
+            id: nextVersionId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          current.documents.set(change.id, {
+            content,
+            versions: [version],
+            deleted: false,
+          });
+        }
+      }
+    }
+
+    return { merged, conflicts, applied };
+  }
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === undefined && b === undefined) return true;
+  if (a === undefined || b === undefined) return false;
+  if (a === null && b === null) return true;
+  if (a === null || b === null) return false;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return a === b;
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+  if (Array.isArray(a)) {
+    const bArr = b as unknown[];
+    if (a.length !== bArr.length) return false;
+    return a.every((val, i) => deepEqual(val, bArr[i]));
+  }
+  const aObj = a as Record<string, unknown>;
+  const bObj = b as Record<string, unknown>;
+  const aKeys = Object.keys(aObj);
+  const bKeys = Object.keys(bObj);
+  if (aKeys.length !== bKeys.length) return false;
+  return aKeys.every(key => key in bObj && deepEqual(aObj[key], bObj[key]));
+}
+
+function threeWayMerge(
+  base: object,
+  ours: object,
+  theirs: object,
+  documentId: string,
+  pathPrefix: string,
+  conflicts: Conflict[],
+): object {
+  const baseObj = base as Record<string, unknown>;
+  const oursObj = ours as Record<string, unknown>;
+  const theirsObj = theirs as Record<string, unknown>;
+
+  const allKeys = new Set<string>();
+  for (const k of Object.keys(baseObj)) allKeys.add(k);
+  for (const k of Object.keys(oursObj)) allKeys.add(k);
+  for (const k of Object.keys(theirsObj)) allKeys.add(k);
+
+  const result: Record<string, unknown> = {};
+
+  for (const key of allKeys) {
+    const baseVal = baseObj[key];
+    const oursVal = oursObj[key];
+    const theirsVal = theirsObj[key];
+    const fullPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+
+    const oursChanged = !deepEqual(baseVal, oursVal);
+    const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      // No change
+      if (key in baseObj) result[key] = deepClone(baseVal);
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      // Only theirs changed — take theirs
+      if (key in theirsObj) {
+        result[key] = deepClone(theirsVal);
+      }
+      // If theirs removed the key, don't include it
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      // Only ours changed — take ours
+      if (key in oursObj) {
+        result[key] = deepClone(oursVal);
+      }
+      // If ours removed the key, don't include it
+      continue;
+    }
+
+    // Both changed
+    if (deepEqual(oursVal, theirsVal)) {
+      // Both changed to same value — no conflict
+      if (key in oursObj) {
+        result[key] = deepClone(oursVal);
+      }
+      continue;
+    }
+
+    // Both changed to different values
+    // If both are plain objects, recurse
+    if (
+      oursVal !== null && theirsVal !== null &&
+      typeof oursVal === 'object' && typeof theirsVal === 'object' &&
+      !Array.isArray(oursVal) && !Array.isArray(theirsVal) &&
+      baseVal !== null && typeof baseVal === 'object' && !Array.isArray(baseVal)
+    ) {
+      result[key] = threeWayMerge(
+        baseVal as object,
+        oursVal as object,
+        theirsVal as object,
+        documentId,
+        fullPath,
+        conflicts,
+      );
+      continue;
+    }
+
+    // Conflict — take ours for the merged result
+    conflicts.push({
+      documentId,
+      path: fullPath,
+      base: deepClone(baseVal),
+      ours: deepClone(oursVal),
+      theirs: deepClone(theirsVal),
+    });
+    result[key] = deepClone(oursVal);
+  }
+
+  return result;
+}
