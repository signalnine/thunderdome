lete('nonexistent')).toThrow();\n    });\n\n    test('get returns a deep clone, not the original object', () => {\n      const content = { nested: { value: 1 } };\n      store.create('doc1', content);\n      const retrieved = store.get('doc1') as { nested: { value: number } };\n      retrieved.nested.value = 999;\n      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);\n    });\n\n    test('create deep clones input so mutations do not affect stored data', () => {\n      const content = { nested: { value: 1 } };\n      store.create('doc1', content);\n      content.nested.value = 999;\n      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);\n    });\n  });\n\n  describe('Version History', () => {\n    test('getHistory returns versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    test('each version has a unique id and timestamp', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n      expect(typeof history[0].timestamp).toBe('number');\n      expect(typeof history[1].timestamp).toBe('number');\n    });\n\n    test('getVersion returns content at a specific version', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });\n    });\n\n    test('getHistory throws for nonexistent documen