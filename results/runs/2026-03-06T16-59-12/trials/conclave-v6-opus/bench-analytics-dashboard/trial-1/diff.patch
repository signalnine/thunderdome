 idx_events_timestamp ON events(timestamp);\n    47→CREATE INDEX IF NOT EXISTS idx_dashboards_tenant ON dashboards(tenant_id);\n    48→CREATE INDEX IF NOT EXISTS idx_users_tenant ON users(tenant_id);\n    49→"}]},"parent_tool_use_id":"toolu_01CWyAHSvhowSePoEWzSswc2","session_id":"81d6606f-01b3-4de3-876b-c16d53bac7ec","uuid":"60071720-3e90-418a-9535-7f196fec6c22"}
