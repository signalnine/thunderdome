+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LjdciCnmJjKbWTqrboGnbh","type":"tool_result","content":"     1→import { createHmac, randomBytes } from 'crypto';\n     2→import jwt from 'jsonwebtoken';\n     3→\n     4→const JWT_SECRET = process.env.JWT_SECRET || 'analytics-dashboard-secret-key';\n     5→\n     6→export function hashPassword(password: string): string {\n     7→  const salt = randomBytes(16).toString('hex');\n     8→  const hash = createHmac('sha256', salt).update(password).digest('hex');\n     9→  return `${salt}:${hash}`;\n    10→}\n    11→\n    12→export function verifyPassword(password: string, storedHash: string): boolean {\n    13→  const [salt, hash] = storedHash.split(':');\n    14→  const candidateHash = createHmac('sha256', salt).update(password).digest('hex');\n    15→  return candidateHash === hash;\n    16→}\n    17→\n    18→export interface TokenPayload {\n    19→  userId: string;\n    20→  tenantId: string;\n    21→  role: string;\n    22→}\n    23→\n    24→export function generateToken(payload: TokenPayload): string {\n    25→  return jwt.sign(payload, JWT_SECRET, { expiresIn: '24h' });\n    26→}\n    27→\n    28→export function verifyToken(token: string): TokenPayload | null {\n    29→  try {\n    30→    const decoded = jwt.verify(token, JWT_SECRET) as TokenPayload;\n    31→    return decoded;\n    32→  } catch {\n    33→    return null;\n    34→  }\n    35→}\n    36→"}]},"parent_tool_use_id":"toolu_013u8V7HrgnnjepKMVPjqSNA","session_id":"81d6606f-01b3-4de3-876b-c16d53bac7ec","uuid":"14cf5d21-c42b-4e5a-856c-191a8c842ce2"}
