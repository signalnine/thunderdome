 } = res.locals.user;\n\n    const events = db\n      .prepare('SELECT * FROM events WHERE tenant_id = ? ORDER BY timestamp DESC')\n      .all(tenantId) as EventRow[];\n\n    const headers = ['id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];\n    const csvLines = [headers.join(',')];\n\n    for (const e of events) {\n      csvLines.push(\n        [\n          escapeCsvValue(e.id),\n          escapeCsvValue(e.name),\n          escapeCsvValue(e.properties),\n          escapeCsvValue(e.timestamp),\n          escapeCsvValue(e.user_id || ''),\n          escapeCsvValue(e.session_id || ''),\n        ].join(',')\n      );\n    }\n\n    res.setHeader('Content-Type', 'text/csv');\n    res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n    res.send(csvLines.join('\\n'));\n  });\n\n  router.get('/export/dashboards/:id/json', authMiddleware, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { tenantId } = res.locals.user;\n    const dashId = req.params.id;\n\n    const dashboard = db\n      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n      .get(dashId, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    const widgets = db\n      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')\n      .all(dashId) as WidgetRow[];\n\n    res.json({\n      dashboard: {\n        id: dashboard.id,\n        name: dashboard.name,\n        config: JSON.parse(dashboard.config),\n        createdAt: dashboard.created_at,\n        updatedAt: dashboard.updated_at,\n        widgets: widgets.map((w) => ({\n          id: w.id,\n          type: w.type,\n          config: JSON.parse(w.config),\n          positionX: w.position_x,\n          positionY: w.position_y,\n          width: w.width,\n          height: w.height,\n        })),\n      },\n    });\n  });\n\n  router.get('/export/dashboards/:id/csv', authMiddleware, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { tenantId } = res.locals.user;\n    const dashId = req.params.id;\n\n    const dashboard = db\n      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n      .get(dashId, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    const widgets = db\n      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')\n      .all(dashId) as WidgetRow[];\n\n    const headers = ['id', 'name', 'config', 'created_at', 'updated_at'];\n    const csvLines = [headers.join(',')];\n    csvLines.push(\n      [\n        escapeCsvValue(dashboard.id),\n        escapeCsvValue(dashboard.name),\n        escapeCsvValue(dashboard.config),\n        escapeCsvValue(dashboard.created_at),\n        escapeCsvValue(dashboard.updated_at),\n      ].join(',')\n    );\n\n    if (widgets.length > 0) {\n      csvLines.push('');\n      csvLines.push('Widgets');\n      const widgetHeaders = ['id', 'type', 'config', 'position_x', 'position_y', 'width', 'height'];\n      csvLines.push(widgetHeaders.join(','));\n      for (const w of widgets) {\n        csvLines.push(\n          [\n            escapeCsvValue(w.id),\n            escapeCsvValue(w.type),\n            escapeCsvValue(w.config),\n            String(w.position_x),\n            String(w.position_y),\n            String(w.width),\n            String(w.height),\n          ].join(',')\n        );\n      }\n    }\n\n    res.setHeader('Content-Type', 'text/csv');\n    res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${dashId}.csv\"`);\n    res.send(csvLines.join('\\n'));\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1551,"cache_read_input_tokens":47545,"cache_creation":{"epheme