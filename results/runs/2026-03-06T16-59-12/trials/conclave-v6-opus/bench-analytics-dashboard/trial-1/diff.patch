+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UUxjGDikcipZ2NGM1anjKy","type":"tool_result","content":"     1→import { Router, Request, Response } from 'express';\n     2→import { v4 as uuidv4 } from 'uuid';\n     3→import type Database from 'better-sqlite3';\n     4→import { hashPassword, verifyPassword, generateToken } from '../auth.js';\n     5→import { authMiddleware } from '../middleware.js';\n     6→\n     7→export function usersRouter(): Router {\n     8→  const router = Router();\n     9→\n    10→  router.post('/auth/register', (req: Request, res: Response) => {\n    11→    const db: Database.Database = req.app.locals.db;\n    12→    const { email, password, tenantId, role } = req.body;\n    13→\n    14→    if (!email || !password || !tenantId) {\n    15→      res.status(400).json({ error: 'email, password, and tenantId are required' });\n    16→      return;\n    17→    }\n    18→\n    19→    const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);\n    20→    if (existing) {\n    21→      res.status(409).json({ error: 'Email already registered' });\n    22→      return;\n    23→    }\n    24→\n    25→    const id = uuidv4();\n    26→    const passwordHash = hashPassword(password);\n    27→    const userRole = role && ['admin', 'editor', 'viewer'].includes(role) ? role : 'viewer';\n    28→\n    29→    db.prepare(\n    30→      'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'\n    31→    ).run(id, email, passwordHash, tenantId, userRole);\n    32→\n    33→    const token = generateToken({ userId: id, tenantId, role: userRole });\n    34→\n    35→    res.status(201).json({\n    36→      user: { id, email, tenantId, role: userRole },\n    37→      token,\n    38→    });\n    39→  });\n    40→\n    41→  router.post('/auth/login', (req: Request, res: Response) => {\n    42→    const db: Database.Database = req.app.locals.db;\n    43→    const { email, password } = req.body;\n    44→\n    45→    if (!email || !password) {\n    46→      res.status(400).json({ error: 'email and password are required' });\n    47→      return;\n    48→    }\n    49→\n    50→    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email) as\n    51→      | { id: string; email: string; password_hash: string; tenant_id: string; role: string }\n    52→      | undefined;\n    53→\n    54→    if (!user || !verifyPassword(password, user.password_hash)) {\n    55→      res.status(401).json({ error: 'Invalid credentials' });\n    56→      return;\n    57→    }\n    58→\n    59→    const token = generateToken({\n    60→      userId: user.id,\n    61→      tenantId: user.tenant_id,\n    62→      role: user.role,\n    63→    });\n    64→\n    65→    res.json({\n    66→      user: { id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role },\n    67→      token,\n    68→    });\n    69→  });\n    70→\n    71→  router.get('/users/me', authMiddleware, (req: Request, res: Response) => {\n    72→    const db: Database.Database = req.app.locals.db;\n    73→    const { userId } = res.locals.user;\n    74→\n    75→    const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(userId) as\n    76→      | { id: string; email: string; tenant_id: string; role: string; created_at: string }\n    77→      | undefined;\n    78→\n    79→    if (!user) {\n    80→      res.status(404).json({ error: 'User not found' });\n    81→      return;\n    82→    }\n    83→\n    84→    res.json({\n    85→      id: user.id,\n    86→      email: user.email,\n    87→      tenantId: user.tenant_id,\n    88→      role: user.role,\n    89→      createdAt: user.created_at,\n    90→    });\n    91→  });\n    92→\n    93→  router.put('/users/:id/role', authMiddleware, (req: Request, res: Response) => {\n    94→    const db: Database.Database = req.app.locals.db;\n    95→    const { tenantId, role: callerRole } = res.locals.user;\n    96→    const targetId = req.params.id;\n    97→    const { role: newRole } = req.body;\n    98→\n    99→    if (callerRole !== 'admin') {\n   100→      res.status(403).json({ error: 'Only admins can change roles' });\n   101→      return;\n   102→    }\n   103→\n   104→    if (!newRole || !['admin', 'editor', 'viewer'].includes(newRole)) {\n   105→      res.status(400).json({ error: 'Invalid role' });\n   106→      return;\n   107→    }\n   108→\n   109→    // Find target user and ensure same tenant\n   110→    const target = db.prepare('SELECT id, email, tenant_id, role FROM users WHERE id = ? AND tenant_id = ?').get(\n   111→      targetId,\n   112→      tenantId\n   113→    ) as { id: string; email: string; tenant_id: string; role: string } | undefined;\n   114→\n   115→    if (!target) {\n   116→      res.status(404).json({ error: 'User not found in your tenant' });\n   117→      return;\n   118→    }\n   119→\n   120→    db.prepare('UPDATE users SET role = ? WHERE id = ?').run(newRole, targetId);\n   121→\n   122→    res.json({\n   123→      id: target.id,\n   124→      email: target.email,\n   125→      tenantId: target.tenant_id,\n   126→      role: newRole,\n   127→    });\n   128→  });\n   129→\n   130→  return router;\n   131→}\n   132→"}]},"parent_tool_use_id":"toolu_013u8V7HrgnnjepKMVPjqSNA","session_id":"81d6606f-01b3-4de3-876b-c16d53bac7ec","uuid":"d1ad26c0-388e-4e2a-972a-63856c3ccefd"}
