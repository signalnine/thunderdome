rl: '/pricing' }, timestamp: '2024-01-15T10:00:00Z' },\n      ],\n    });\n});\n\ndescribe('POST /api/queries/count', () => {\n  it('should count all events for tenant', async () => {\n    const res = await request(app)\n      .post('/api/queries/count')\n      .set('Authorization', `Bearer ${token}`)\n      .send({});\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(5);\n  });\n\n  it('should count events filtered by name', async () => {\n    const res = await request(app)\n      .post('/api/queries/count')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ eventName: 'page_view' });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(3);\n  });\n\n  it('should not include other tenant events', async () => {\n    const res = await request(app)\n      .post('/api/queries/count')\n      .set('Authorization', `Bearer ${otherToken}`)\n      .send({});\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(1);\n  });\n});\n\ndescribe('POST /api/queries/timeseries', () => {\n  it('should return timeseries data bucketed by day', async () => {\n    const res = await request(app)\n      .post('/api/queries/timeseries')\n      .set('Authorization', `Bearer ${token}`)\n      .send({\n        eventName: 'page_view',\n        startDate: '2024-01-15',\n        endDate: '2024-01-16',\n        interval: 'day',\n      });\n    expect(res.status).toBe(200);\n    expect(res.body.data).toBeDefined();\n    expect(Array.isArray(res.body.data)).toBe(true);\n    // Should have 2 days of data\n    expect(res.body.data.length).toBe(2);\n  });\n\n  it('should respect tenant isolation', async () => {\n    const res = await request(app)\n      .post('/api/queries/timeseries')\n      .set('Authorization', `Bearer ${otherToken}`)\n      .send({\n        eventName: 'page_view',\n        startDate: '2024-01-15',\n        endDate: '2024-01-16',\n        interval: 'day',\n      });\n    expect(res.status).toBe(200);\n    const total = res.body.data.reduce((sum: number, d: { count: number }) => sum + d.count, 0);\n    expect(total).toBe(1);\n  });\n});\n\ndescribe('POST /api/queries/breakdown', () => {\n  it('should breakdown events by property', async () => {\n    const res = await request(app)\n      .post('/api/queries/breakdown')\n      .set('Authorization', `Bearer ${token}`)\n      .send({\n        eventName: 'page_view',\n        property: 'url',\n      });\n    expect(res.status).toBe(200);\n    expect(res.body.data).toBeDefined();\n    expect(Array.isArray(res.body.data)).toBe(true);\n\n    // Should have /home (2) and /about (1)\n    const homeEntry = res.body.data.find((d: { value: string }) => d.value === '/home');\n    const aboutEntry = res.body.data.find((d: { value: string }) => d.value === '/about');\n    expect(homeEntry.count).toBe(2);\n    expect(aboutEntry.count).toBe(1);\n  });\n\n  it('should not include other tenant data in breakdown', async () => {\n    const res = await request(app)\n      .post('/api/queries/breakdown')\n      .set('Authorization', `Bearer ${otherToken}`)\n      .send({\n        eventName: 'page_view',\n        property: 'url',\n      });\n    expect(res.status).toBe(200);\n    expect(res.body.data.length).toBe(1);\n    expect(res.body.data[0].value).toBe('/pricing');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1036,"cache_read_input_tokens":37520,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1036},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"81d6606f-01b3-4de3-876b-c16d53bac7ec","uuid":"624db993-a2bc-4fb2-ab88-144dcaacf5d8"}
