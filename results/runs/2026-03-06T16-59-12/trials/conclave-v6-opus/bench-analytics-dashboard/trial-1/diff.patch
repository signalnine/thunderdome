+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0139UQ9VCzcTgJipJx7iG6ez","type":"tool_result","content":"     1→import { Router, Request, Response } from 'express';\n     2→import type Database from 'better-sqlite3';\n     3→import { authMiddleware } from '../middleware.js';\n     4→\n     5→interface EventRow {\n     6→  id: string;\n     7→  tenant_id: string;\n     8→  name: string;\n     9→  properties: string;\n    10→  timestamp: string;\n    11→  user_id: string | null;\n    12→  session_id: string | null;\n    13→}\n    14→\n    15→interface DashboardRow {\n    16→  id: string;\n    17→  tenant_id: string;\n    18→  name: string;\n    19→  owner_id: string;\n    20→  config: string;\n    21→  created_at: string;\n    22→  updated_at: string;\n    23→}\n    24→\n    25→interface WidgetRow {\n    26→  id: string;\n    27→  dashboard_id: string;\n    28→  type: string;\n    29→  config: string;\n    30→  position_x: number;\n    31→  position_y: number;\n    32→  width: number;\n    33→  height: number;\n    34→}\n    35→\n    36→function escapeCsvValue(val: string): string {\n    37→  if (val.includes(',') || val.includes('\"') || val.includes('\\n')) {\n    38→    return `\"${val.replace(/\"/g, '\"\"')}\"`;\n    39→  }\n    40→  return val;\n    41→}\n    42→\n    43→export function exportRouter(): Router {\n    44→  const router = Router();\n    45→\n    46→  router.get('/export/events/json', authMiddleware, (req: Request, res: Response) => {\n    47→    const db: Database.Database = req.app.locals.db;\n    48→    const { tenantId } = res.locals.user;\n    49→\n    50→    const events = db\n    51→      .prepare('SELECT * FROM events WHERE tenant_id = ? ORDER BY timestamp DESC')\n    52→      .all(tenantId) as EventRow[];\n    53→\n    54→    res.json({\n    55→      events: events.map((e) => ({\n    56→        id: e.id,\n    57→        name: e.name,\n    58→        properties: JSON.parse(e.properties),\n    59→        timestamp: e.timestamp,\n    60→        userId: e.user_id,\n    61→        sessionId: e.session_id,\n    62→      })),\n    63→    });\n    64→  });\n    65→\n    66→  router.get('/export/events/csv', authMiddleware, (req: Request, res: Response) => {\n    67→    const db: Database.Database = req.app.locals.db;\n    68→    const { tenantId } = res.locals.user;\n    69→\n    70→    const events = db\n    71→      .prepare('SELECT * FROM events WHERE tenant_id = ? ORDER BY timestamp DESC')\n    72→      .all(tenantId) as EventRow[];\n    73→\n    74→    const headers = ['id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];\n    75→    const csvLines = [headers.join(',')];\n    76→\n    77→    for (const e of events) {\n    78→      csvLines.push(\n    79→        [\n    80→          escapeCsvValue(e.id),\n    81→          escapeCsvValue(e.name),\n    82→          escapeCsvValue(e.properties),\n    83→          escapeCsvValue(e.timestamp),\n    84→          escapeCsvValue(e.user_id || ''),\n    85→          escapeCsvValue(e.session_id || ''),\n    86→        ].join(',')\n    87→      );\n    88→    }\n    89→\n    90→    res.setHeader('Content-Type', 'text/csv');\n    91→    res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n    92→    res.send(csvLines.join('\\n'));\n    93→  });\n    94→\n    95→  router.get('/export/dashboards/:id/json', authMiddleware, (req: Request, res: Response) => {\n    96→    const db: Database.Database = req.app.locals.db;\n    97→    const { tenantId } = res.locals.user;\n    98→    const dashId = req.params.id;\n    99→\n   100→    const dashboard = db\n   101→      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n   102→      .get(dashId, tenantId) as DashboardRow | undefined;\n   103→\n   104→    if (!dashboard) {\n   105→      res.status(404).json({ error: 'Dashboard not found' });\n   106→      return;\n   107→    }\n   108→\n   109→    const widgets = db\n   110→      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')\n   111→      .all(dashId) as WidgetRow[];\n   112→\n   113→    res.json({\n   114→      dashboard: {\n   115→        id: dashboard.id,\n   116→        name: dashboard.name,\n   117→        config: JSON.parse(dashboard.config),\n   118→        createdAt: dashboard.created_at,\n   119→        updatedAt: dashboard.updated_at,\n   120→        widgets: widgets.map((w) => ({\n   121→          id: w.id,\n   122→          type: w.type,\n   123→          config: JSON.parse(w.config),\n   124→          positionX: w.position_x,\n   125→          positionY: w.position_y,\n   126→          width: w.width,\n   127→          height: w.height,\n   128→        })),\n   129→      },\n   130→    });\n   131→  });\n   132→\n   133→  router.get('/export/dashboards/:id/csv', authMiddleware, (req: Request, res: Response) => {\n   134→    const db: Database.Database = req.app.locals.db;\n   135→    const { tenantId } = res.locals.user;\n   136→    const dashId = req.params.id;\n   137→\n   138→    const dashboard = db\n   139→      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n   140→      .get(dashId, tenantId) as DashboardRow | undefined;\n   141→\n   142→    if (!dashboard) {\n   143→      res.status(404).json({ error: 'Dashboard not found' });\n   144→      return;\n   145→    }\n   146→\n   147→    const widgets = db\n   148→      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')\n   149→      .all(dashId) as WidgetRow[];\n   150→\n   151→    const headers = ['id', 'name', 'config', 'created_at', 'updated_at'];\n   152→    const csvLines = [headers.join(',')];\n   153→    csvLines.push(\n   154→      [\n   155→        escapeCsvValue(dashboard.id),\n   156→        escapeCsvValue(dashboard.name),\n   157→        escapeCsvValue(dashboard.config),\n   158→        escapeCsvValue(dashboard.created_at),\n   159→        escapeCsvValue(dashboard.updated_at),\n   160→      ].join(',')\n   161→    );\n   162→\n   163→    if (widgets.length > 0) {\n   164→      csvLines.push('');\n   165→      csvLines.push('Widgets');\n   166→      const widgetHeaders = ['id', 'type', 'config', 'position_x', 'position_y', 'width', 'height'];\n   167→      csvLines.push(widgetHeaders.join(','));\n   168→      for (const w of widgets) {\n   169→        csvLines.push(\n   170→          [\n   171→            escapeCsvValue(w.id),\n   172→            escapeCsvValue(w.type),\n   173→            escapeCsvValue(w.config),\n   174→            String(w.position_x),\n   175→            String(w.position_y),\n   176→            String(w.width),\n   177→            String(w.height),\n   178→          ].join(',')\n   179→        );\n   180→      }\n   181→    }\n   182→\n   183→    res.setHeader('Content-Type', 'text/csv');\n   184→    res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${dashId}.csv\"`);\n   185→    res.send(csvLines.join('\\n'));\n   186→  });\n   187→\n   188→  return router;\n   189→}\n   190→"}]},"parent_tool_use_id":"toolu_013u8V7HrgnnjepKMVPjqSNA","session_id":"81d6606f-01b3-4de3-876b-c16d53bac7ec","uuid":"bbfcaf77-2ca8-4f79-a23a-85173286a2fa"}
