+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TQ73HLDp83vzbgjkCPJAAy","type":"tool_result","content":"     1→import { Router, Request, Response } from 'express';\n     2→import { v4 as uuidv4 } from 'uuid';\n     3→import type Database from 'better-sqlite3';\n     4→import { authMiddleware } from '../middleware.js';\n     5→\n     6→export function dashboardsRouter(): Router {\n     7→  const router = Router();\n     8→\n     9→  router.post('/dashboards', authMiddleware, (req: Request, res: Response) => {\n    10→    const db: Database.Database = req.app.locals.db;\n    11→    const { tenantId, userId } = res.locals.user;\n    12→    const { name, config } = req.body;\n    13→\n    14→    if (!name) {\n    15→      res.status(400).json({ error: 'Dashboard name is required' });\n    16→      return;\n    17→    }\n    18→\n    19→    const id = uuidv4();\n    20→    const dashConfig = JSON.stringify(config || {});\n    21→    const now = new Date().toISOString();\n    22→\n    23→    db.prepare(\n    24→      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'\n    25→    ).run(id, tenantId, name, userId, dashConfig, now, now);\n    26→\n    27→    res.status(201).json({\n    28→      id,\n    29→      tenantId,\n    30→      name,\n    31→      ownerId: userId,\n    32→      config: config || {},\n    33→      createdAt: now,\n    34→      updatedAt: now,\n    35→    });\n    36→  });\n    37→\n    38→  router.get('/dashboards', authMiddleware, (req: Request, res: Response) => {\n    39→    const db: Database.Database = req.app.locals.db;\n    40→    const { tenantId } = res.locals.user;\n    41→\n    42→    const dashboards = db\n    43→      .prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC')\n    44→      .all(tenantId) as Array<{\n    45→      id: string;\n    46→      tenant_id: string;\n    47→      name: string;\n    48→      owner_id: string;\n    49→      config: string;\n    50→      created_at: string;\n    51→      updated_at: string;\n    52→    }>;\n    53→\n    54→    res.json(\n    55→      dashboards.map((d) => ({\n    56→        id: d.id,\n    57→        tenantId: d.tenant_id,\n    58→        name: d.name,\n    59→        ownerId: d.owner_id,\n    60→        config: JSON.parse(d.config),\n    61→        createdAt: d.created_at,\n    62→        updatedAt: d.updated_at,\n    63→      }))\n    64→    );\n    65→  });\n    66→\n    67→  router.get('/dashboards/:id', authMiddleware, (req: Request, res: Response) => {\n    68→    const db: Database.Database = req.app.locals.db;\n    69→    const { tenantId } = res.locals.user;\n    70→    const dashId = req.params.id;\n    71→\n    72→    const dashboard = db\n    73→      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n    74→      .get(dashId, tenantId) as\n    75→      | { id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string }\n    76→      | undefined;\n    77→\n    78→    if (!dashboard) {\n    79→      res.status(404).json({ error: 'Dashboard not found' });\n    80→      return;\n    81→    }\n    82→\n    83→    res.json({\n    84→      id: dashboard.id,\n    85→      tenantId: dashboard.tenant_id,\n    86→      name: dashboard.name,\n    87→      ownerId: dashboard.owner_id,\n    88→      config: JSON.parse(dashboard.config),\n    89→      createdAt: dashboard.created_at,\n    90→      updatedAt: dashboard.updated_at,\n    91→    });\n    92→  });\n    93→\n    94→  router.put('/dashboards/:id', authMiddleware, (req: Request, res: Response) => {\n    95→    const db: Database.Database = req.app.locals.db;\n    96→    const { tenantId } = res.locals.user;\n    97→    const dashId = req.params.id;\n    98→    const { name, config } = req.body;\n    99→\n   100→    const existing = db\n   101→      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n   102→      .get(dashId, tenantId) as\n   103→      | { id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string }\n   104→      | undefined;\n   105→\n   106→    if (!existing) {\n   107→      res.status(404).json({ error: 'Dashboard not found' });\n   108→      return;\n   109→    }\n   110→\n   111→    const updatedName = name || existing.name;\n   112→    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;\n   113→    const now = new Date().toISOString();\n   114→\n   115→    db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?').run(\n   116→      updatedName,\n   117→      updatedConfig,\n   118→      now,\n   119→      dashId\n   120→    );\n   121→\n   122→    res.json({\n   123→      id: existing.id,\n   124→      tenantId: existing.tenant_id,\n   125→      name: updatedName,\n   126→      ownerId: existing.owner_id,\n   127→      config: JSON.parse(updatedConfig),\n   128→      createdAt: existing.created_at,\n   129→      updatedAt: now,\n   130→    });\n   131→  });\n   132→\n   133→  router.delete('/dashboards/:id', authMiddleware, (req: Request, res: Response) => {\n   134→    const db: Database.Database = req.app.locals.db;\n   135→    const { tenantId } = res.locals.user;\n   136→    const dashId = req.params.id;\n   137→\n   138→    const existing = db\n   139→      .prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?')\n   140→      .get(dashId, tenantId);\n   141→\n   142→    if (!existing) {\n   143→      res.status(404).json({ error: 'Dashboard not found' });\n   144→      return;\n   145→    }\n   146→\n   147→    db.prepare('DELETE FROM dashboards WHERE id = ?').run(dashId);\n   148→    res.status(204).send();\n   149→  });\n   150→\n   151→  return router;\n   152→}\n   153→"}]},"parent_tool_use_id":"toolu_013u8V7HrgnnjepKMVPjqSNA","session_id":"81d6606f-01b3-4de3-876b-c16d53bac7ec","uuid":"0326a350-ee73-4c