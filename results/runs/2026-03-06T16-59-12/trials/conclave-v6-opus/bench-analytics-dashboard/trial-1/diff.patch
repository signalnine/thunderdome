, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { email, password } = req.body;\n\n    if (!email || !password) {\n      res.status(400).json({ error: 'email and password are required' });\n      return;\n    }\n\n    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email) as\n      | { id: string; email: string; password_hash: string; tenant_id: string; role: string }\n      | undefined;\n\n    if (!user || !verifyPassword(password, user.password_hash)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n\n    const token = generateToken({\n      userId: user.id,\n      tenantId: user.tenant_id,\n      role: user.role,\n    });\n\n    res.json({\n      user: { id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role },\n      token,\n    });\n  });\n\n  router.get('/users/me', authMiddleware, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { userId } = res.locals.user;\n\n    const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(userId) as\n      | { id: string; email: string; tenant_id: string; role: string; created_at: string }\n      | undefined;\n\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    res.json({\n      id: user.id,\n      email: user.email,\n      tenantId: user.tenant_id,\n      role: user.role,\n      createdAt: user.created_at,\n    });\n  });\n\n  router.put('/users/:id/role', authMiddleware, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { userId, tenantId, role: callerRole } = res.locals.user;\n    const targetId = req.params.id;\n    const { role: newRole } = req.body;\n\n    if (callerRole !== 'admin') {\n      res.status(403).json({ error: 'Only admins can change roles' });\n      return;\n    }\n\n    if (!newRole || !['admin', 'editor', 'viewer'].includes(newRole)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n\n    // Find target user and ensure same tenant\n    const target = db.prepare('SELECT id, email, tenant_id, role FROM users WHERE id = ? AND tenant_id = ?').get(\n      targetId,\n      tenantId\n    ) as { id: string; email: string; tenant_id: string; role: string } | undefined;\n\n    if (!target) {\n      res.status(404).json({ error: 'User not found in your tenant' });\n      return;\n    }\n\n    db.prepare('UPDATE users SET role = ? WHERE id = ?').run(newRole, targetId);\n\n    res.json({\n      id: target.id,\n      email: target.email,\n      tenantId: target.tenant_id,\n      role: newRole,\n    });\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":92,"oldLines":7,"newStart":92,"newLines":7,"lines":[" ","   router.put('/users/:id/role', authMiddleware, (req: Request, res: Response) => {","     const db: Database.Database = req.app.locals.db;","-    const { userId, tenantId, role: callerRole } = res.locals.user;","+    const { tenantId, role: callerRole } = res.locals.user;","     const targetId = req.params.id;","     const { role: newRole } = req.body;"," "]}],"userModified":false,"replaceAll":false}}
