@@ -0,0 +1,152 @@
+import { Router, Request, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import type Database from 'better-sqlite3';
+import { authMiddleware } from '../middleware.js';
+
+export function dashboardsRouter(): Router {
+  const router = Router();
+
+  router.post('/dashboards', authMiddleware, (req: Request, res: Response) => {
+    const db: Database.Database = req.app.locals.db;
+    const { tenantId, userId } = res.locals.user;
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Dashboard name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const dashConfig = JSON.stringify(config || {});
+    const now = new Date().toISOString();
+
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, userId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenantId,
+      name,
+      ownerId: userId,
+      config: config || {},
+      createdAt: now,
+      updatedAt: now,
+    });
+  });
+
+  router.get('/dashboards', authMiddleware, (req: Request, res: Response) => {
+    const db: Database.Database = req.app.locals.db;
+    const { tenantId } = res.locals.user;
+
+    const dashboards = db
+      .prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC')
+      .all(tenantId) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    }>;
+
+    res.json(
+      dashboards.map((d) => ({
+        id: d.id,
+        tenantId: d.tenant_id,
+        name: d.name,
+        ownerId: d.owner_id,
+        config: JSON.parse(d.config),
+        createdAt: d.created_at,
+        updatedAt: d.updated_at,
+      }))
+    );
+  });
+
+  router.get('/dashboards/:id', authMiddleware, (req: Request, res: Response) => {
+    const db: Database.Database = req.app.locals.db;
+    const { tenantId } = res.locals.user;
+    const dashId = req.params.id;
+
+    const dashboard = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(dashId, tenantId) as
+      | { id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string }
+      | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    res.json({
+      id: dashboard.id,
+      tenantId: dashboard.tenant_id,
+      name: dashboard.name,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+    });
+  });
+
+  router.put('/dashboards/:id', authMiddleware, (req: Request, res: Response) => {
+    const db: Database.Database = req.app.locals.db;
+    const { tenantId } = res.locals.user;
+    const dashId = req.params.id;
+    const { name, config } = req.body;
+
+    const existing = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(dashId, tenantId) as
+      | { id: string; tenant_id: string; name: string; owner_id: string; config: string; created_at: string }
+      | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?').run(
+      updatedName,
+      updatedConfig,
+      now,
+      dashId
+    );
+
+    res.json({
+      id: existing.id,
+      tenantId: existing.tenant_id,
+      name: updatedName,
+      ownerId: existing.owner_id,
+      config: JSON.parse(updatedConfig),
+      createdAt: existing.created_at,
+      updatedAt: now,
+    });
+  });
+
+  router.delete('/dashboards/:id', authMiddleware, (req: Request, res: Response) => {
+    const db: Database.Database = req.app.locals.db;
+    const { tenantId } = res.locals.user;
+    const dashId = req.params.id;
+
+    const existing = db
+      .prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(dashId, tenantId);
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(dashId);
+    res.status(204).send();
+  });
+
+  return router;
+}
