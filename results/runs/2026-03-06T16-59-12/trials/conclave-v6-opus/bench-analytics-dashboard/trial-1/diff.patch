@@ -0,0 +1,24 @@
+import express from 'express';
+import { createDatabase } from './db.js';
+import { usersRouter } from './routes/users.js';
+import { eventsRouter } from './routes/events.js';
+import { queriesRouter } from './routes/queries.js';
+import { dashboardsRouter } from './routes/dashboards.js';
+import { exportRouter } from './routes/export.js';
+
+export function createApp(dbPath?: string): express.Express {
+  const app = express();
+
+  app.use(express.json());
+
+  const db = createDatabase(dbPath || ':memory:');
+  app.locals.db = db;
+
+  app.use('/api', usersRouter());
+  app.use('/api', eventsRouter());
+  app.use('/api', queriesRouter());
+  app.use('/api', dashboardsRouter());
+  app.use('/api', exportRouter());
+
+  return app;
+}
diff --git a/src/auth.test.ts b/src/auth.test.ts
new file mode 100644
index 0000000..b47fc3f
--- /dev/null
+++ b/src/auth.test.ts
@@ -0,0 +1,34 @@
+import { describe, it, expect } from 'vitest';
+import { hashPassword, verifyPassword, generateToken, verifyToken } from './auth.js';
+
+describe('password hashing', () => {
+  it('should hash a password and verify it', () => {
+    const hash = hashPassword('mysecret');
+    expect(hash).not.toBe('mysecret');
+    expect(verifyPassword('mysecret', hash)).toBe(true);
+  });
+
+  it('should reject wrong password', () => {
+    const hash = hashPassword('mysecret');
+    expect(verifyPassword('wrongpassword', hash)).toBe(false);
+  });
+});
+
+describe('JWT tokens', () => {
+  it('should generate and verify a token', () => {
+    const payload = { userId: 'u1', tenantId: 't1', role: 'admin' };
+    const token = generateToken(payload);
+    expect(typeof token).toBe('string');
+
+    const decoded = verifyToken(token);
+    expect(decoded).toBeDefined();
+    expect(decoded!.userId).toBe('u1');
+    expect(decoded!.tenantId).toBe('t1');
+    expect(decoded!.role).toBe('admin');
+  });
+
+  it('should return null for invalid token', () => {
+    const decoded = verifyToken('invalid.token.here');
+    expect(decoded).toBeNull();
+  });
+});
