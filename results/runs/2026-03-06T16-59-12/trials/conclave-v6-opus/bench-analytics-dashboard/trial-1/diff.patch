ession_id":"81d6606f-01b3-4de3-876b-c16d53bac7ec","uuid":"d4fbf24a-cfe2-468d-be38-f1aa28cb86e9","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/routes/queries.ts","content":"import { Router, Request, Response } from 'express';\nimport type Database from 'better-sqlite3';\nimport { authMiddleware } from '../middleware.js';\n\nexport function queriesRouter(): Router {\n  const router = Router();\n\n  router.post('/queries/count', authMiddleware, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { tenantId } = res.locals.user;\n    const { eventName } = req.body;\n\n    let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';\n    const params: unknown[] = [tenantId];\n\n    if (eventName) {\n      query += ' AND name = ?';\n      params.push(eventName);\n    }\n\n    const result = db.prepare(query).get(...params) as { count: number };\n    res.json({ count: result.count });\n  });\n\n  router.post('/queries/timeseries', authMiddleware, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { tenantId } = res.locals.user;\n    const { eventName, startDate, endDate, interval } = req.body;\n\n    // Default interval is 'day'\n    const bucketInterval = interval || 'day';\n\n    let dateFormat: string;\n    if (bucketInterval === 'hour') {\n      dateFormat = '%Y-%m-%dT%H:00:00';\n    } else if (bucketInterval === 'month') {\n      dateFormat = '%Y-%m';\n    } else {\n      // day\n      dateFormat = '%Y-%m-%d';\n    }\n\n    let query = `\n      SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count\n      FROM events\n      WHERE tenant_id = ?\n    `;\n    const params: unknown[] = [tenantId];\n\n    if (eventName) {\n      query += ' AND name = ?';\n      params.push(eventName);\n    }\n\n    if (startDate) {\n      query += ' AND date(timestamp) >= date(?)';\n      params.push(startDate);\n    }\n\n    if (endDate) {\n      query += ' AND date(timestamp) <= date(?)';\n      params.push(endDate);\n    }\n\n    query += ` GROUP BY bucket ORDER BY bucket`;\n\n    const rows = db.prepare(query).all(...params) as Array<{ bucket: string; count: number }>;\n\n    res.json({\n      data: rows.map((r) => ({ date: r.bucket, count: r.count })),\n    });\n  });\n\n  router.post('/queries/breakdown', authMiddleware, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { tenantId } = res.locals.user;\n    const { eventName, property } = req.body;\n\n    if (!property) {\n      res.status(400).json({ error: 'property is required for breakdown queries' });\n      return;\n    }\n\n    let query = `\n      SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count\n      FROM events\n      WHERE tenant_id = ?\n    `;\n    const params: unknown[] = [property, tenantId];\n\n    if (eventName) {\n      query += ' AND name = ?';\n      params.push(eventName);\n    }\n\n    query += ' GROUP BY value ORDER BY count DESC';\n\n    const rows = db.prepare(query).all(...params) as Array<{ value: string; count: number }>;\n\n    res.json({\n      data: rows.map((r) => ({ value: r.value, count: r.count })),\n    });\n  });\n\n  return router;\n}\n","numLines":107,"startLine":1,"totalLines":107}}}
