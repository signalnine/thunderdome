vents (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'\n    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, sessionId || null);\n\n    res.status(201).json({\n      id,\n      tenantId,\n      name,\n      properties: properties || {},\n      timestamp: eventTimestamp,\n    });\n  });\n\n  router.post('/events/batch', authMiddleware, (req: Request, res: Response) => {\n    const db: Database.Database = req.app.locals.db;\n    const { tenantId, userId } = res.locals.user;\n    const { events } = req.body;\n\n    if (!Array.isArray(events) || events.length === 0) {\n      res.status(400).json({ error: 'events must be a non-empty array' });\n      return;\n    }\n\n    const insert = db.prepare(\n      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'\n    );\n\n    const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string; sessionId?: string }>) => {\n      for (const evt of evts) {\n        if (!evt.name) continue;\n        const id = uuidv4();\n        const eventTimestamp = evt.timestamp || new Date().toISOString();\n        const eventProperties = JSON.stringify(evt.properties || {});\n        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId, evt.sessionId || null);\n      }\n    });\n\n    insertMany(events);\n\n    res.status(201).json({ inserted: events.length });\n  });\n\n  return router;\n}\n","numLines":67,"startLine":1,"totalLines":67}}}
