+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F7L2XkCk66rBbLqgu2UVzv","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→\n     3→const SCHEMA = `\n     4→CREATE TABLE IF NOT EXISTS users (\n     5→  id TEXT PRIMARY KEY,\n     6→  email TEXT NOT NULL UNIQUE,\n     7→  password_hash TEXT NOT NULL,\n     8→  tenant_id TEXT NOT NULL,\n     9→  role TEXT NOT NULL DEFAULT 'viewer' CHECK(role IN ('admin', 'viewer', 'editor')),\n    10→  created_at TEXT NOT NULL DEFAULT (datetime('now'))\n    11→);\n    12→\n    13→CREATE TABLE IF NOT EXISTS events (\n    14→  id TEXT PRIMARY KEY,\n    15→  tenant_id TEXT NOT NULL,\n    16→  name TEXT NOT NULL,\n    17→  properties TEXT NOT NULL DEFAULT '{}',\n    18→  timestamp TEXT NOT NULL DEFAULT (datetime('now')),\n    19→  user_id TEXT,\n    20→  session_id TEXT\n    21→);\n    22→\n    23→CREATE TABLE IF NOT EXISTS dashboards (\n    24→  id TEXT PRIMARY KEY,\n    25→  tenant_id TEXT NOT NULL,\n    26→  name TEXT NOT NULL,\n    27→  owner_id TEXT NOT NULL,\n    28→  config TEXT NOT NULL DEFAULT '{}',\n    29→  created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    30→  updated_at TEXT NOT NULL DEFAULT (datetime('now')),\n    31→  FOREIGN KEY (owner_id) REFERENCES users(id)\n    32→);\n    33→\n    34→CREATE TABLE IF NOT EXISTS widgets (\n    35→  id TEXT PRIMARY KEY,\n    36→  dashboard_id TEXT NOT NULL,\n    37→  type TEXT NOT NULL CHECK(type IN ('counter', 'timeseries', 'breakdown', 'funnel')),\n    38→  config TEXT NOT NULL DEFAULT '{}',\n    39→  position_x INTEGER NOT NULL DEFAULT 0,\n    40→  position_y INTEGER NOT NULL DEFAULT 0,\n    41→  width INTEGER NOT NULL DEFAULT 1,\n    42→  height INTEGER NOT NULL DEFAULT 1,\n    43→  FOREIGN KEY (dashboard_id) REFERENCES dashboards(id) ON DELETE CASCADE\n    44→);\n    45→\n    46→CREATE INDEX IF NOT EXISTS idx_events_tenant ON events(tenant_id);\n    47→CREATE INDEX IF NOT EXISTS idx_events_name ON events(name);\n    48→CREATE INDEX IF NOT EXISTS idx_events_timestamp ON events(timestamp);\n    49→CREATE INDEX IF NOT EXISTS idx_dashboards_tenant ON dashboards(tenant_id);\n    50→CREATE INDEX IF NOT EXISTS idx_users_tenant ON users(tenant_id);\n    51→`;\n    52→\n    53→export function createDatabase(dbPath: string): Database.Database {\n    54→  const db = new Database(dbPath);\n    55→\n    56→  db.pragma('journal_mode = WAL');\n    57→  db.pragma('foreign_keys = ON');\n    58→\n    59→  db.exec(SCHEMA);\n    60→\n    61→  return db;\n    62→}\n    63→"}]},"parent_tool_use_id":"toolu_013u8V7HrgnnjepKMVPjqSNA","session_id":"81d6606f-01b3-4de3-876b-c16d53bac7ec","uuid":"e1f960c9-347a-4760-aede-7c350234cb09"}
