@@ -0,0 +1,113 @@
+import type { Operation } from './types.js';
+
+/**
+ * Apply an operation to a document string, returning the new string.
+ */
+export function applyOperation(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    const text = op.text ?? '';
+    return doc.slice(0, pos) + text + doc.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    const count = Math.min(op.count ?? 0, doc.length - pos);
+    return doc.slice(0, pos) + doc.slice(pos + count);
+  }
+}
+
+/**
+ * Transform opToTransform against alreadyApplied.
+ * Returns a new operation equivalent to opToTransform but adjusted
+ * to account for the effect of alreadyApplied.
+ */
+export function transformOperation(opToTransform: Operation, alreadyApplied: Operation): Operation {
+  const op = { ...opToTransform };
+
+  if (op.type === 'insert' && alreadyApplied.type === 'insert') {
+    return transformInsertInsert(op, alreadyApplied);
+  } else if (op.type === 'insert' && alreadyApplied.type === 'delete') {
+    return transformInsertDelete(op, alreadyApplied);
+  } else if (op.type === 'delete' && alreadyApplied.type === 'insert') {
+    return transformDeleteInsert(op, alreadyApplied);
+  } else {
+    return transformDeleteDelete(op, alreadyApplied);
+  }
+}
+
+function transformInsertInsert(op: Operation, against: Operation): Operation {
+  // If against insert is at or before our position, shift right
+  if (against.position <= op.position) {
+    return { ...op, position: op.position + (against.text?.length ?? 0) };
+  }
+  return { ...op };
+}
+
+function transformInsertDelete(op: Operation, against: Operation): Operation {
+  const delEnd = against.position + (against.count ?? 0);
+
+  if (against.position >= op.position) {
+    // Delete is at or after insert position - no shift needed
+    return { ...op };
+  } else if (delEnd <= op.position) {
+    // Delete is entirely before insert - shift left by count
+    return { ...op, position: op.position - (against.count ?? 0) };
+  } else {
+    // Insert is inside the deleted range - move to delete position
+    return { ...op, position: against.position };
+  }
+}
+
+function transformDeleteInsert(op: Operation, against: Operation): Operation {
+  const opEnd = op.position + (op.count ?? 0);
+
+  if (against.position <= op.position) {
+    // Insert is at or before delete position - shift right
+    return { ...op, position: op.position + (against.text?.length ?? 0) };
+  } else if (against.position >= opEnd) {
+    // Insert is after delete range - no change
+    return { ...op };
+  } else {
+    // Insert is inside delete range - expand delete to include inserted text
+    return { ...op, count: (op.count ?? 0) + (against.text?.length ?? 0) };
+  }
+}
+
+function transformDeleteDelete(op: Operation, against: Operation): Operation {
+  const opStart = op.position;
+  const opEnd = opStart + (op.count ?? 0);
+  const agStart = against.position;
+  const agEnd = agStart + (against.count ?? 0);
+
+  if (agEnd <= opStart) {
+    // Against delete is entirely before - shift left
+    return { ...op, position: opStart - (against.count ?? 0) };
+  } else if (agStart >= opEnd) {
+    // Against delete is entirely after - no change
+    return { ...op };
+  } else {
+    // Overlapping ranges
+    const overlapStart = Math.max(opStart, agStart);
+    const overlapEnd = Math.min(opEnd, agEnd);
+    const overlapSize = overlapEnd - overlapStart;
+
+    const newCount = (op.count ?? 0) - overlapSize;
+
+    // Adjust position: if against starts before op, shift left by the non-overlapping prefix
+    const adjustedPosition = agStart < opStart
+      ? opStart - (overlapStart - agStart)
+      : opStart;
+
+    return { ...op, position: adjustedPosition, count: Math.max(0, newCount) };
+  }
+}
+
+/**
+ * Transform an operation against a sequence of already-applied operations.
+ */
+export function transformOperationAgainstMany(op: Operation, appliedOps: Operation[]): Operation {
+  let transformed = op;
+  for (const applied of appliedOps) {
+    transformed = transformOperation(transformed, applied);
+  }
+  return transformed;
+}
