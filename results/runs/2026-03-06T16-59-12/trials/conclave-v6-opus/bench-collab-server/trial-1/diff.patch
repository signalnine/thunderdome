diff --git a/src/database.ts b/src/database.ts
new file mode 100644
index 0000000..608ca22
--- /dev/null
+++ b/src/database.ts
@@ -0,0 +1,148 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'node:fs';
+import { resolve, dirname } from 'node:path';
+import { fileURLToPath } from 'node:url';
+import type { Document, Version, Operation } from './types.js';
+import crypto from 'node:crypto';
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export class DocumentDatabase {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('foreign_keys = ON');
+    this.init();
+  }
+
+  private init(): void {
+    const schemaPath = resolve(__dirname, '..', 'schema.sql');
+    try {
+      const schema = readFileSync(schemaPath, 'utf-8');
+      this.db.exec(schema);
+    } catch {
+      // Fallback: inline schema if file not found
+      this.db.exec(`
+        CREATE TABLE IF NOT EXISTS documents (
+          id TEXT PRIMARY KEY,
+          title TEXT NOT NULL,
+          content TEXT NOT NULL DEFAULT '',
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+        CREATE TABLE IF NOT EXISTS versions (
+          id INTEGER PRIMARY KEY AUTOINCREMENT,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          version INTEGER NOT NULL,
+          content TEXT NOT NULL,
+          operation TEXT,
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          UNIQUE(document_id, version)
+        );
+        CREATE TABLE IF NOT EXISTS active_connections (
+          id TEXT PRIMARY KEY,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+      `);
+    }
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = crypto.randomUUID();
+    const stmt = this.db.prepare(
+      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version (version 0)
+    this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, 0, ?, NULL)`
+    ).run(id, content);
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    const stmt = this.db.prepare(`SELECT * FROM documents WHERE id = ?`);
+    return stmt.get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`);
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    this.db.prepare(
+      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+    ).run(title, content, id);
+
+    return this.getDocument(id)!;
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.db.prepare(`DELETE FROM documents WHERE id = ?`).run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(documentId: string): Version[] {
+    const stmt = this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+    );
+    return stmt.all(documentId) as Version[];
+  }
+
+  getLatestVersion(documentId: string): number {
+    const stmt = this.db.prepare(
+      `SELECT MAX(version) as max_version FROM versions WHERE document_id = ?`
+    );
+    const result = stmt.get(documentId) as { max_version: number | null } | undefined;
+    return result?.max_version ?? 0;
+  }
+
+  getOperationsSinceVersion(documentId: string, sinceVersion: number): Version[] {
+    const stmt = this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC`
+    );
+    return stmt.all(documentId, sinceVersion) as Version[];
+  }
+
+  addVersion(documentId: string, version: number, content: string, operation: Operation): void {
+    this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`
+    ).run(documentId, version, content, JSON.stringify(operation));
+  }
+
+  updateDocumentContent(id: string, content: string): void {
+    this.db.prepare(
+      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`
+    ).run(content, id);
+  }
+
+  addConnection(connectionId: string, documentId: string): void {
+    this.db.prepare(
+      `INSERT OR REPLACE INTO active_connections (id, document_id) VALUES (?, ?)`
+    ).run(connectionId, documentId);
+  }
+
+  removeConnection(connectionId: string): void {
+    this.db.prepare(`DELETE FROM active_connections WHERE id = ?`).run(connectionId);
+  }
+
+  clearConnections(): void {
+    this.db.prepare(`DELETE FROM active_connections`).run();
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..e1c45e6
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,245 @@
+import { describe, it, expect } from 'vitest';
+import { transformOperation, applyOperation } from './ot.js';
+import type { Operation } from './types.js';
+
+describe('applyOperation', () => {
+  it('inserts text at position', () => {
+    expect(applyOperation('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+  });
+
+  it('inserts text at beginning', () => {
+    expect(applyOperation('world', { type: 'insert', position: 0, text: 'hello ' })).toBe('hello world');
+  });
+
+  it('inserts text in middle', () => {
+    expect(applyOperation('helo', { type: 'insert', position: 2, text: 'l' })).toBe('hello');
+  });
+
+  it('deletes text at position', () => {
+    expect(applyOperation('hello world', { type: 'delete', position: 5, count: 6 })).toBe('hello');
+  });
+
+  it('deletes text at beginning', () => {
+    expect(applyOperation('hello world', { type: 'delete', position: 0, count: 6 })).toBe('world');
+  });
+
+  it('handles empty string insert', () => {
+    expect(applyOperation('hello', { type: 'insert', position: 0, text: '' })).toBe('hello');
+  });
+
+  it('handles zero count delete', () => {
+    expect(applyOperation('hello', { type: 'delete', position: 0, count: 0 })).toBe('hello');
+  });
+
+  it('clamps delete count to available text', () => {
+    expect(applyOperation('hi', { type: 'delete', position: 1, count: 100 })).toBe('h');
+  });
+
+  it('inserts into empty string', () => {
+    expect(applyOperation('', { type: 'insert', position: 0, text: 'hello' })).toBe('hello');
+  });
+});
+
+describe('transformOperation', () => {
+  // Transform(opToTransform, againstOp) -> transformed opToTransform
+
+  describe('insert vs insert', () => {
+    it('shifts right when against insert is at or before position', () => {
+      const op: Operation = { type: 'insert', position: 5, text: 'B' };
+      const against: Operation = { type: 'insert', position: 3, text: 'AA' };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(7); // 5 + 2
+    });
+
+    it('does not shift when against insert is after position', () => {
+      const op: Operation = { type: 'insert', position: 3, text: 'B' };
+      const against: Operation = { type: 'insert', position: 5, text: 'AA' };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(3);
+    });
+
+    it('shifts right when against insert is at same position', () => {
+      const op: Operation = { type: 'insert', position: 5, text: 'B' };
+      const against: Operation = { type: 'insert', position: 5, text: 'A' };
+      const result = transformOperation(op, against);
+      // Tie-breaking: the already-applied op wins the position
+      expect(result.position).toBe(6);
+    });
+  });
+
+  describe('insert vs delete', () => {
+    it('shifts left when delete is before insert position', () => {
+      const op: Operation = { type: 'insert', position: 5, text: 'X' };
+      const against: Operation = { type: 'delete', position: 2, count: 2 };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(3); // 5 - 2
+    });
+
+    it('moves to delete position when insert is inside deleted range', () => {
+      const op: Operation = { type: 'insert', position: 4, text: 'X' };
+      const against: Operation = { type: 'delete', position: 2, count: 5 };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(2);
+    });
+
+    it('does not shift when delete is after insert position', () => {
+      const op: Operation = { type: 'insert', position: 2, text: 'X' };
+      const against: Operation = { type: 'delete', position: 5, count: 3 };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(2);
+    });
+  });
+
+  describe('delete vs insert', () => {
+    it('shifts right when insert is before delete position', () => {
+      const op: Operation = { type: 'delete', position: 5, count: 3 };
+      const against: Operation = { type: 'insert', position: 2, text: 'XX' };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(7); // 5 + 2
+    });
+
+    it('shifts right and keeps count when insert is at delete position', () => {
+      const op: Operation = { type: 'delete', position: 5, count: 3 };
+      const against: Operation = { type: 'insert', position: 5, text: 'XX' };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(7);
+      expect(result.count).toBe(3);
+    });
+
+    it('splits delete when insert is inside deleted range', () => {
+      const op: Operation = { type: 'delete', position: 2, count: 6 };
+      const against: Operation = { type: 'insert', position: 4, text: 'XX' };
+      const result = transformOperation(op, against);
+      // The delete must still delete 6 chars but skip the 2 new inserted chars
+      expect(result.position).toBe(2);
+      expect(result.count).toBe(8); // 6 + 2 (delete range expands to include inserted text)
+    });
+
+    it('does not shift when insert is after delete range', () => {
+      const op: Operation = { type: 'delete', position: 2, count: 3 };
+      const against: Operation = { type: 'insert', position: 10, text: 'XX' };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(2);
+      expect(result.count).toBe(3);
+    });
+  });
+
+  describe('delete vs delete', () => {
+    it('shifts left when against delete is fully before', () => {
+      const op: Operation = { type: 'delete', position: 8, count: 3 };
+      const against: Operation = { type: 'delete', position: 2, count: 3 };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(5); // 8 - 3
+      expect(result.count).toBe(3);
+    });
+
+    it('reduces count when against delete overlaps from left', () => {
+      const op: Operation = { type: 'delete', position: 3, count: 5 }; // deletes [3..8)
+      const against: Operation = { type: 'delete', position: 1, count: 4 }; // deletes [1..5)
+      const result = transformOperation(op, against);
+      // overlap is [3..5), size 2. op reduces by 2, position moves to 1
+      expect(result.position).toBe(1);
+      expect(result.count).toBe(3); // 5 - 2
+    });
+
+    it('becomes no-op when against delete fully covers', () => {
+      const op: Operation = { type: 'delete', position: 3, count: 2 }; // deletes [3..5)
+      const against: Operation = { type: 'delete', position: 2, count: 5 }; // deletes [2..7)
+      const result = transformOperation(op, against);
+      expect(result.count).toBe(0);
+    });
+
+    it('reduces count when against delete overlaps from right', () => {
+      const op: Operation = { type: 'delete', position: 2, count: 5 }; // deletes [2..7)
+      const against: Operation = { type: 'delete', position: 5, count: 4 }; // deletes [5..9)
+      const result = transformOperation(op, against);
+      // overlap is [5..7), size 2. op count reduces by 2
+      expect(result.position).toBe(2);
+      expect(result.count).toBe(3); // 5 - 2
+    });
+
+    it('does not change when against delete is fully after', () => {
+      const op: Operation = { type: 'delete', position: 2, count: 3 };
+      const against: Operation = { type: 'delete', position: 8, count: 2 };
+      const result = transformOperation(op, against);
+      expect(result.position).toBe(2);
+      expect(result.count).toBe(3);
+    });
+  });
+
+  describe('convergence property', () => {
+    it('concurrent inserts at different positions converge', () => {
+      const doc = 'hello world';
+      const op1: Operation = { type: 'insert', position: 5, text: ' beautiful' };
+      const op2: Operation = { type: 'insert', position: 0, text: 'Say: ' };
+
+      // Path 1: apply op1 first, then transform op2
+      const doc1a = applyOperation(doc, op1);
+      const op2t = transformOperation(op2, op1);
+      const doc1b = applyOperation(doc1a, op2t);
+
+      // Path 2: apply op2 first, then transform op1
+      const doc2a = applyOperation(doc, op2);
+      const op1t = transformOperation(op1, op2);
+      const doc2b = applyOperation(doc2a, op1t);
+
+      expect(doc1b).toBe(doc2b);
+      expect(doc1b).toContain('Say: ');
+      expect(doc1b).toContain('beautiful');
+    });
+
+    it('concurrent inserts at same position converge (server-authoritative)', () => {
+      // In server-authoritative OT, the server picks the order.
+      // op1 is applied first (server order), then op2 is transformed against op1.
+      const doc = 'hello';
+      const op1: Operation = { type: 'insert', position: 5, text: ' world' };
+      const op2: Operation = { type: 'insert', position: 5, text: ' there' };
+
+      // Server applies op1 first
+      const doc1 = applyOperation(doc, op1); // "hello world"
+      // Transform op2 against op1 (op1 already applied)
+      const op2t = transformOperation(op2, op1);
+      const finalDoc = applyOperation(doc1, op2t);
+
+      // Both insertions must be present
+      expect(finalDoc).toContain('world');
+      expect(finalDoc).toContain('there');
+      // op1 was applied first, so "world" comes first, "there" shifted right
+      expect(finalDoc).toBe('hello world there');
+    });
+
+    it('concurrent delete and insert converge', () => {
+      const doc = 'hello world';
+      const op1: Operation = { type: 'delete', position: 5, count: 6 }; // delete " world"
+      const op2: Operation = { type: 'insert', position: 0, text: 'Say: ' };
+
+      const doc1a = applyOperation(doc, op1);
+      const op2t = transformOperation(op2, op1);
+      const doc1b = applyOperation(doc1a, op2t);
+
+      const doc2a = applyOperation(doc, op2);
+      const op1t = transformOperation(op1, op2);
+      const doc2b = applyOperation(doc2a, op1t);
+
+      expect(doc1b).toBe(doc2b);
+    });
+
+    it('concurrent deletes at overlapping ranges converge', () => {
+      const doc = 'abcdefghij';
+      const op1: Operation = { type: 'delete', position: 2, count: 4 }; // delete cdef
+      const op2: Operation = { type: 'delete', position: 4, count: 4 }; // delete efgh
+
+      const doc1a = applyOperation(doc, op1);
+      const op2t = transformOperation(op2, op1);
+      const doc1b = applyOperation(doc1a, op2t);
+
+      const doc2a = applyOperation(doc, op2);
+      const op1t = transformOperation(op1, op2);
+      const doc2b = applyOperation(doc2a, op1t);
+
+      expect(doc1b).toBe(doc2b);
+      // Both deletes together should remove cdefgh -> "abij"
+      expect(doc1b).toBe('abij');
+    });
+  });
+});
