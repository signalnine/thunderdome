+import express from 'express';
+import { createServer, type Server } from 'node:http';
+import { DocumentDatabase } from './database.js';
+import { createRouter } from './routes.js';
+import { WebSocketManager } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const app = express();
+  const db = new DocumentDatabase(dbPath ?? ':memory:');
+  const router = createRouter(db);
+  app.use(router);
+
+  let server: Server | null = null;
+  let wsManager: WebSocketManager | null = null;
+
+  const start = (port?: number): Promise<number> => {
+    return new Promise((resolve, reject) => {
+      server = createServer(app);
+      wsManager = new WebSocketManager(server, db);
+
+      server.on('error', reject);
+      server.listen(port ?? 0, () => {
+        const addr = server!.address();
+        if (addr && typeof addr === 'object') {
+          resolve(addr.port);
+        } else {
+          reject(new Error('Failed to get server address'));
+        }
+      });
+    });
+  };
+
+  const stop = (): Promise<void> => {
+    return new Promise((resolve, reject) => {
+      if (wsManager) {
+        wsManager.closeAll();
+        wsManager = null;
+      }
+
+      db.clearConnections();
+
+      if (server) {
+        server.close((err) => {
+          db.close();
+          if (err) reject(err);
+          else resolve();
+        });
+        server = null;
+      } else {
+        db.close();
+        resolve();
+      }
+    });
+  };
+
+  return { app, start, stop };
+}
