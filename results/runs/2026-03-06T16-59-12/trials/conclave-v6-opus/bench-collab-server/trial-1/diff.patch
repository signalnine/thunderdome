current deletes at overlapping ranges converge', () => {\n      const doc = 'abcdefghij';\n      const op1: Operation = { type: 'delete', position: 2, count: 4 }; // delete cdef\n      const op2: Operation = { type: 'delete', position: 4, count: 4 }; // delete efgh\n\n      const doc1a = applyOperation(doc, op1);\n      const op2t = transformOperation(op2, op1);\n      const doc1b = applyOperation(doc1a, op2t);\n\n      const doc2a = applyOperation(doc, op2);\n      const op1t = transformOperation(op1, op2);\n      const doc2b = applyOperation(doc2a, op1t);\n\n      expect(doc1b).toBe(doc2b);\n      // Both deletes together should remove cdefgh -> \"abij\"\n      expect(doc1b).toBe('abij');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":396,"cache_read_input_tokens":31320,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":396},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d2897688-e6bb-4a62-94c8-e0f26f54d2bf","uuid":"17865187-b936-44ce-8da6-c5e6f90c8987"}
