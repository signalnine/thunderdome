+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server } from 'node:http';
+import type { DocumentDatabase } from './database.js';
+import type { Operation, ServerMessage } from './types.js';
+import { applyOperation, transformOperationAgainstMany } from './ot.js';
+import crypto from 'node:crypto';
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+export class WebSocketManager {
+  private wss: WebSocketServer;
+  private db: DocumentDatabase;
+  private closed = false;
+  // Map from documentId to set of clients
+  private rooms: Map<string, Set<ClientConnection>> = new Map();
+
+  constructor(server: Server, db: DocumentDatabase) {
+    this.db = db;
+    this.wss = new WebSocketServer({ noServer: true });
+
+    server.on('upgrade', (request, socket, head) => {
+      const url = request.url;
+      if (!url) {
+        socket.destroy();
+        return;
+      }
+
+      // Parse the document ID from the URL path: /docs/:id/ws
+      const match = url.match(/^\/docs\/([^/]+)\/ws(?:\?.*)?$/);
+      if (!match) {
+        socket.destroy();
+        return;
+      }
+
+      const documentId = match[1];
+
+      this.wss.handleUpgrade(request, socket, head, (ws) => {
+        this.handleConnection(ws, documentId);
+      });
+    });
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string): void {
+    // Verify document exists
+    const doc = this.db.getDocument(documentId);
+    if (!doc) {
+      const errorMsg: ServerMessage = { type: 'error', message: 'Document not found' };
+      ws.send(JSON.stringify(errorMsg));
+      ws.close(4004, 'Document not found');
+      return;
+    }
+
+    const clientId = crypto.randomUUID();
+    const client: ClientConnection = { ws, clientId, documentId };
+
+    // Add to room
+    if (!this.rooms.has(documentId)) {
+      this.rooms.set(documentId, new Set());
+    }
+    this.rooms.get(documentId)!.add(client);
+
+    // Track in database
+    this.db.addConnection(clientId, documentId);
+
+    // Send sync message with current document state
+    const version = this.db.getLatestVersion(documentId);
+    const syncMsg: ServerMessage = {
+      type: 'sync',
+      content: doc.content,
+      version,
+    };
+    ws.send(JSON.stringify(syncMsg));
+
+    // Handle messages
+    ws.on('message', (data) => {
+      this.handleMessage(client, data);
+    });
+
+    // Handle disconnect
+    ws.on('close', () => {
+      this.handleDisconnect(client);
+    });
+
+    ws.on('error', () => {
+      this.handleDisconnect(client);
+    });
+  }
+
+  private handleMessage(client: ClientConnection, data: unknown): void {
+    let parsed: unknown;
+    try {
+      parsed = JSON.parse(String(data));
+    } catch {
+      this.sendError(client.ws, 'Invalid JSON');
+      return;
+    }
+
+    if (!parsed || typeof parsed !== 'object') {
+      this.sendError(client.ws, 'Invalid message format');
+      return;
+    }
+
+    const msg = parsed as Record<string, unknown>;
+
+    if (msg.type !== 'operation') {
+      this.sendError(client.ws, `Unknown message type: ${String(msg.type)}`);
+      return;
+    }
+
+    const operation = msg.operation as Operation | undefined;
+    const version = msg.version as number | undefined;
+
+    if (!operation || typeof version !== 'number') {
+      this.sendError(client.ws, 'Missing operation or version');
+      return;
+    }
+
+    if (!this.isValidOperation(operation)) {
+      this.sendError(client.ws, 'Invalid operation');
+      return;
+    }
+
+    this.applyClientOperation(client, operation, version);
+  }
+
+  private isValidOperation(op: unknown): op is Operation {
+    if (!op || typeof op !== 'object') return false;
+    const o = op as Record<string, unknown>;
+    if (o.type === 'insert') {
+      return typeof o.position === 'number' && o.position >= 0 && typeof o.text === 'string';
+    }
+    if (o.type === 'delete') {
+      return typeof o.position === 'number' && o.position >= 0 && typeof o.count === 'number' && o.count >= 0;
+    }
+    return false;
+  }
+
+  private applyClientOperation(client: ClientConnection, operation: Operation, clientVersion: number): void {
+    const doc = this.db.getDocument(client.documentId);
+    if (!doc) {
+      this.sendError(client.ws, 'Document not found');
+      return;
+    }
+
+    const currentVersion = this.db.getLatestVersion(client.documentId);
+
+    // Validate operation bounds
+    if (operation.type === 'insert' && operation.position > doc.content.length) {
+      this.sendError(client.ws, 'Insert position out of bounds');
+      return;
+    }
+    if (operation.type === 'delete' && operation.position > doc.content.length) {
+      this.sendError(client.ws, 'Delete position out of bounds');
+      return;
+    }
+
+    // Get operations that happened since the client's version
+    let transformedOp = operation;
+    if (clientVersion < currentVersion) {
+      const versionsSince = this.db.getOperationsSinceVersion(client.documentId, clientVersion);
+      const opsSince: Operation[] = versionsSince
+        .filter(v => v.operation)
+        .map(v => JSON.parse(v.operation!) as Operation);
+      transformedOp = transformOperationAgainstMany(operation, opsSince);
+    }
+
+    // Apply the transformed operation to the document
+    const newContent = applyOperation(doc.content, transformedOp);
+    const newVersion = currentVersion + 1;
+
+    // Persist
+    this.db.updateDocumentContent(client.documentId, newContent);
+    this.db.addVersion(client.documentId, newVersion, newContent, transformedOp);
+
+    // Ack the client
+    const ackMsg: ServerMessage = { type: 'ack', version: newVersion };
+    client.ws.send(JSON.stringify(ackMsg));
+
+    // Broadcast to other clients in the room
+    const room = this.rooms.get(client.documentId);
+    if (room) {
+      const broadcastMsg: ServerMessage = {
+        type: 'broadcast',
+        operation: transformedOp,
+        version: newVersion,
+        clientId: client.clientId,
+      };
+      const msgStr = JSON.stringify(broadcastMsg);
+      for (const other of room) {
+        if (other.clientId !== client.clientId && other.ws.readyState === WebSocket.OPEN) {
+          other.ws.send(msgStr);
+        }
+      }
+    }
+  }
+
+  private handleDisconnect(client: ClientConnection): void {
+    const room = this.rooms.get(client.documentId);
+    if (room) {
+      room.delete(client);
+      if (room.size === 0) {
+        this.rooms.delete(client.documentId);
+      }
+    }
+    if (!this.closed) {
+      try {
+        this.db.removeConnection(client.clientId);
+      } catch {
+        // Database may be closed during shutdown
+      }
+    }
+  }
+
+  private sendError(ws: WebSocket, message: string): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      const errorMsg: ServerMessage = { type: 'error', message };
+      ws.send(JSON.stringify(errorMsg));
+    }
+  }
+
+  closeAll(): void {
+    this.closed = true;
+    for (const [, room] of this.rooms) {
+      for (const client of room) {
+        client.ws.close(1001, 'Server shutting down');
+      }
+    }
+    this.rooms.clear();
+    this.wss.close();
+  }
+}
