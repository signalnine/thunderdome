g }> = [];\n+\n+        // Add asset routes\n+        for (const asset of assetPaths) {\n+          routes.push({ path: `/assets/${asset}`, handler: 'asset' });\n+        }\n+\n+        // Add content routes for HTML files\n+        for (const path of ctx.output.keys()) {\n+          if (path.endsWith('.html')) {\n+            routes.push({ path: `/${path}`, handler: 'static' });\n+          }\n+        }\n+\n+        const searchIndexPath = ctx.output.has('search-index.json')\n+          ? '/search-index.json'\n+          : '';\n+\n+        ctx.data.set('dev-server-config', {\n+          port: 3000,\n+          routes,\n+          assetPaths,\n+          searchIndexPath,\n+        });\n+      },\n+    },\n+  };\n+}\ndiff --git a/src/plugins/markdown-ext.ts b/src/plugins/markdown-ext.ts\nnew file mode 100644\nindex 0000000..8435cf3\n--- /dev/null\n+++ b/src/plugins/markdown-ext.ts\n@@ -0,0 +1,46 @@\n+import { Plugin, ContentFile, BuildContext } from '../core/types.js';\n+import { marked } from 'marked';\n+\n+export function createMarkdownExtPlugin(): Plugin {\n+  return {\n+    name: 'markdown-ext',\n+    version: '1.0.0',\n+    dependencies: [],\n+    hooks: {\n+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {\n+        let content = file.content;\n+\n+        // Extract and process footnote definitions\n+        const footnoteDefRegex = /^\\[\\^(\\d+)\\]:\\s*(.+)$/gm;\n+        const footnotes: Array<{ id: string; text: string }> = [];\n+        content = content.replace(footnoteDefRegex, (_match, id: string, text: string) => {\n+          footnotes.push({ id, text });\n+          return '';\n+        });\n+\n+        // Replace footnote references with sup/a tags\n+        content = content.replace(/\\[\\^(\\d+)\\]/g, (_match, id: string) => {\n+          return `<sup><a href=\"#fn-${id}\">${id}</a></sup>`;\n+        });\n+\n+        // Process admonition containers (:::type ... :::)\n+        content = content.replace(/^:::([\\w]+)\\n