+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WvzTV6dsRXgJpKQAQNkBuJ","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createAssetPipelinePlugin } from '../../src/plugins/asset-pipeline.js';\n     3→import { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n     4→\n     5→const testConfig: SiteConfig = {\n     6→  title: 'Test Site',\n     7→  baseUrl: 'https://example.com',\n     8→  outputDir: './dist',\n     9→  contentDir: './content',\n    10→  templateDir: './templates',\n    11→};\n    12→\n    13→function makeCtx(): BuildContext {\n    14→  return {\n    15→    config: testConfig,\n    16→    files: [],\n    17→    output: new Map(),\n    18→    assets: new Map(),\n    19→    data: new Map(),\n    20→  };\n    21→}\n    22→\n    23→function makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n    24→  return {\n    25→    slug: 'test',\n    26→    title: 'Test',\n    27→    content: '',\n    28→    metadata: {},\n    29→    ...overrides,\n    30→  };\n    31→}\n    32→\n    33→describe('asset-pipeline plugin', () => {\n    34→  const plugin = createAssetPipelinePlugin();\n    35→\n    36→  it('rewrites relative image URLs to /assets/ path', async () => {\n    37→    const file = makeFile({ content: '<img src=\"./image.png\" alt=\"test\">' });\n    38→    const ctx = makeCtx();\n    39→    const result = await plugin.hooks.transformContent!(file, ctx);\n    40→    expect(result.content).toContain('src=\"/assets/image.png\"');\n    41→    expect(result.content).not.toContain('src=\"./image.png\"');\n    42→  });\n    43→\n    44→  it('rewrites relative link URLs to /assets/ path', async () => {\n    45→    const file = makeFile({ content: '<a href=\"./doc.pdf\">Download</a>' });\n    46→    const ctx = makeCtx();\n    47→    const result = await plugin.hooks.transformContent!(file, ctx);\n    48→    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    49→    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n    50→  });\n    51→\n    52→  it('leaves absolute URLs unchanged', async () => {\n    53→    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    54→    const ctx = makeCtx();\n    55→    const result = await plugin.hooks.transformContent!(file, ctx);\n    56→    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n    57→  });\n    58→\n    59→  it('generates asset manifest in ctx.data', async () => {\n    60→    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    61→    const ctx = makeCtx();\n    62→    await plugin.hooks.transformContent!(file, ctx);\n    63→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    64→    expect(manifest).toBeDefined();\n    65→    expect(manifest.assets).toContain('photo.jpg');\n    66→  });\n    67→\n    68→  it('handles files with no asset references', async () => {\n    69→    const file = makeFile({ content: '<p>No assets here</p>' });\n    70→    const ctx = makeCtx();\n    71→    const result = await plugin.hooks.transformContent!(file, ctx);\n    72→    expect(result.content).toBe('<p>No assets here</p>');\n    73→  });\n    74→\n    75→  it('handles multiple assets in one file', async () => {\n    76→    const file = makeFile({\n    77→      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    78→    });\n    79→    const ctx = makeCtx();\n    80→    await plugin.hooks.transformContent!(file, ctx);\n    81→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    82→    expect(manifest.assets).toContain('a.png');\n    83→    expect(manifest.assets).toContain('b.jpg');\n    84→    expect(manifest.assets).toContain('c.pdf');\n    85→  });\n    86→\n    87→  it('asset manifest includes all discovered assets', async () => {\n    88→    const ctx = makeCtx();\n    89→    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    90→    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    91→    await plugin.hooks.transformContent!(file1, ctx);\n    92→    await plugin.hooks.transformContent!(file2, ctx);\n    93→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    94→    expect(manifest.assets).toHaveLength(2);\n    95→    expect(manifest.assets).toContain('one.png');\n    96→    expect(manifest.assets).toContain('two.png');\n    97→  });\n    98→\n    99→  it('does not double-process already-rewritten URLs', async () => {\n   100→    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n   101→    const ctx = makeCtx();\n   102→    const result = await plugin.hooks.transformContent!(file, ctx);\n   103→    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n   104→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n   105→    expect(!manifest || manifest.assets.length === 0).toBe(true);\n   106→  });\n   107→});\n   108→"}]},"parent_tool_use_id":"toolu_019zsEZhnbw6DWMto7N4Bbpt","session_id":"4b20f5c2-ba8f-41b8-aacc-033337416b1b","uuid":"86c45fbb-e9fd-42c9-832c-646b9da80526"}
