de:fs';\n+import * as path from 'node:path';\n+import type { TimeEntry, TimeSummary, TimeTrackerOptions } from './types.js';\n+\n+interface EntryFilter {\n+  since?: Date;\n+  until?: Date;\n+}\n+\n+interface StorageData {\n+  entries: TimeEntry[];\n+}\n+\n+export class TimeTracker {\n+  private readonly filePath: string;\n+  private entries: TimeEntry[];\n+\n+  constructor(options: TimeTrackerOptions) {\n+    this.filePath = options.filePath;\n+    this.entries = this.load();\n+  }\n+\n+  start(task: string): void {\n+    if (!task || !task.trim()) {\n+      throw new Error('Task name cannot be empty');\n+    }\n+\n+    // Auto-stop any running timer\n+    const running = this.getRunningEntry();\n+    if (running) {\n+      running.endTime = new Date().toISOString();\n+    }\n+\n+    this.entries.push({\n+      task,\n+      startTime: new Date().toISOString(),\n+      endTime: null,\n+    });\n+\n+    this.save();\n+  }\n+\n+  stop(): void {\n+    const running = this.getRunningEntry();\n+    if (!running) {\n+      throw new Error('No timer is currently running');\n+    }\n+\n+    running.endTime = new Date().toISOString();\n+    this.save();\n+  }\n+\n+  getEntries(filter?: EntryFilter): TimeEntry[] {\n+    let result = [...this.entries];\n+\n+    if (filter?.since) {\n+      const sinceMs = filter.since.getTime();\n+      result = result.filter(e => new Date(e.startTime).getTime() >= sinceMs);\n+    }\n+\n+    if (filter?.until) {\n+      const untilMs = filter.until.getTime();\n+      result = result.filter(e => new Date(e.startTime).getTime() <= untilMs);\n+    }\n+\n+    return result;\n+  }\n+\n+  getSummary(): TimeSummary {\n+    const summary: TimeSummary = {};\n+    const now = Date.now();\n+\n+    for (const entry of this.entries) {\n+      const start = new Date(entry.startTime).getTime();\n+      const end = entry.endTime ? new Date(entry.endTime).getTime() : now;\n+      const duration = end - start;\n+\n+      if (summary[entry.task] === undefined) 