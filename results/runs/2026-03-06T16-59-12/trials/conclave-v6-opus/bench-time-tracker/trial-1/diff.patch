+++ b/src/tracker.test.ts
@@ -0,0 +1,248 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import * as fs from 'node:fs';
+import * as path from 'node:path';
+import * as os from 'node:os';
+import { TimeTracker } from './tracker.js';
+
+function createTempFilePath(): string {
+  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'time-tracker-test-'));
+  return path.join(tmpDir, 'data.json');
+}
+
+describe('TimeTracker', () => {
+  let filePath: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    filePath = createTempFilePath();
+    tracker = new TimeTracker({ filePath });
+  });
+
+  afterEach(() => {
+    const dir = path.dirname(filePath);
+    if (fs.existsSync(dir)) {
+      fs.rmSync(dir, { recursive: true });
+    }
+  });
+
+  describe('start and stop timers', () => {
+    it('should start a timer with a task name', () => {
+      tracker.start('coding');
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe('coding');
+      expect(entries[0].startTime).toBeTruthy();
+      expect(entries[0].endTime).toBeNull();
+    });
+
+    it('should stop a running timer', () => {
+      tracker.start('coding');
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].endTime).toBeTruthy();
+    });
+
+    it('should auto-stop previous timer when starting a new one', () => {
+      tracker.start('coding');
+      tracker.start('review');
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe('coding');
+      expect(entries[0].endTime).toBeTruthy();
+      expect(entries[1].task).toBe('review');
+      expect(entries[1].endTime).toBeNull();
+    });
+  });
+
+  describe('error handling', () => {
+    it('should throw when starting with empty name', () => {
+      expect(() => tracker.start('')).toThrow();
+    });
+
+    it('should throw when starting with whitespace-only name', () => {
+      expect(() => tracker.start('   ')).toThrow();
+    });
+
+    it('should throw when stopping with no running timer', () => {
+      expect(() => tracker.stop()).toThrow();
+    });
+
+    it('should throw when stopping after already stopped', () => {
+      tracker.start('coding');
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow();
+    });
+  });
+
+  describe('persistence', () => {
+    it('should save entries to JSON file', () => {
+      tracker.start('coding');
+      tracker.stop();
+      expect(fs.existsSync(filePath)).toBe(true);
+      const data = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
+      expect(data.entries).toHaveLength(1);
+      expect(data.entries[0].task).toBe('coding');
+    });
+
+    it('should load entries from existing file', () => {
+      tracker.start('coding');
+      tracker.stop();
+
+      const tracker2 = new TimeTracker({ filePath });
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe('coding');
+    });
+
+    it('should create parent directories if they do not exist', () => {
+      const deepPath = path.join(os.tmpdir(), `time-tracker-deep-${Date.now()}`, 'a', 'b', 'data.json');
+      const deepTracker = new TimeTracker({ filePath: deepPath });
+      deepTracker.start('coding');
+      deepTracker.stop();
+      expect(fs.existsSync(deepPath)).toBe(true);
+      // cleanup
+      fs.rmSync(path.join(os.tmpdir(), `time-tracker-deep-${Date.now().toString().slice(0, -3)}`), { recursive: true, force: true });
+    });
+
+    it('should handle empty file gracefully', () => {
+      fs.mkdirSync(path.dirname(filePath), { recursive: true });
+      fs.writeFileSync(filePath, '');
+      const tracker2 = new TimeTracker({ filePath });
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(0);
+    });
+  });
+
+  describe('querying entries', () => {
+    it('should return all entries when no filter', () => {
+      tracker.start('task1');
+      tracker.stop();
+      tracker.start('task2');
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it('should filter entries by date range (since)', () => {
+      const past = new Date('2020-01-01T00:00:00.000Z');
+      const now = new Date();
+
+      // Manually create an old entry
+      const oldEntry = {
+        task: 'old-task',
+        startTime: new Date('2019-01-01T00:00:00.000Z').toISOString(),
+        endTime: new Date('2019-01-01T01:00:00.000Z').toISOString(),
+      };
+      const newEntry = {
+        task: 'new-task',
+        startTime: now.toISOString(),
+        endTime: new Date(now.getTime() + 3600000).toISOString(),
+      };
+
+      // Write entries directly to the file
+      fs.mkdirSync(path.dirname(filePath), { recursive: true });
+      fs.writeFileSync(filePath, JSON.stringify({ entries: [oldEntry, newEntry] }));
+
+      const tracker2 = new TimeTracker({ filePath });
+      const filtered = tracker2.getEntries({ since: past });
+      expect(filtered).toHaveLength(1);
+      expect(filtered[0].task).toBe('new-task');
+    });
+
+    it('should filter entries by date range (until)', () => {
+      const cutoff = new Date('2020-06-01T00:00:00.000Z');
+
+      const earlyEntry = {
