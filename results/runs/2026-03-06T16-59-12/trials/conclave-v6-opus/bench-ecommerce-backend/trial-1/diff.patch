ct(analytics.getTopProducts(5)).toEqual([]);\n+  });\n+\n+  test('getTopProducts ranks products by order quantity', async () => {\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 3 }, { productId: 'p2', quantity: 1 }] });\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 50 });\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 5 }] });\n+    const top = analytics.getTopProducts(2);\n+    expect(top).toHaveLength(2);\n+    expect(top[0].productId).toBe('p2'); // 1 + 5 = 6\n+    expect(top[0].count).toBe(6);\n+    expect(top[1].productId).toBe('p1'); // 3\n+    expect(top[1].count).toBe(3);\n+  });\n+\n+  test('getTopProducts respects limit', async () => {\n+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }, { productId: 'p2', quantity: 2 }, { productId: 'p3', quantity: 3 }] });\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 10 });\n+    const top = analytics.getTopProducts(2);\n+    expect(top).toHaveLength(2);\n+  });\n+});\ndiff --git a/src/analytics/index.ts b/src/analytics/index.ts\nnew file mode 100644\nindex 0000000..e44de64\n--- /dev/null\n+++ b/src/analytics/index.ts\n@@ -0,0 +1,88 @@\n+import { EventBus } from '../bus.js';\n+import { Events, PaymentStatus, type AnalyticsService, type CartUpdatedEvent, type OrderCreatedEvent, type PaymentProcessedEvent } from '../types.js';\n+\n+export function createAnalyticsService(bus: EventBus): AnalyticsService {\n+  const eventCounts = new Map<string, number>();\n+  let revenue = 0;\n+  const uniqueCarts = new Set<string>();\n+  let orderCount = 0;\n+  const productCounts = new Map<string, number>();\n+  const orderTotals = new Map<string, number>();\n+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();\n+  const orderedCarts = new Set<string>(); // cartIds that have been ordered\n+  const processedOrderCarts = new Set<string>(); // cartIds whose items have been counted\n+\n+  const trackedEvents = [\n+    Events.PRODUCT_CREATED,\n+    Events.INVENTORY_UPDATED,\n+    Events.LOW_STOCK_ALERT,\n+    Events.CART_UPDATED,\n+    Events.PRICE_CALCULATED,\n+    Events.ORDER_CREATED,\n+    Events.ORDER_STATUS_CHANGED,\n+    Events.PAYMENT_PROCESSED,\n+    Events.NOTIFICATION_SENT,\n+    Events.ANALYTICS_EVENT,\n+  ];\n+\n+  for (const eventName of trackedEvents) {\n+    bus.on(eventName, () => {\n+      eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);\n+    });\n+  }\n+\n+  function countCartItems(cartId: string): void {\n+    if (processedOrderCarts.has(cartId)) return;\n+    const items = cartItems.get(cartId);\n+    if (!items || !orderedCarts.has(cartId)) return;\n+    processedOrderCarts.add(cartId);\n+    for (const item of items) {\n+      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n+    }\n+  }\n+\n+  bus.on(Events.CART_UPDATED, (payload) => {\n+    const event = payload as CartUpdatedEvent;\n+    uniqueCarts.add(event.cartId);\n+    cartItems.set(event.cartId, [...event.items]);\n+    countCartItems(event.cartId);\n+  });\n+\n+  bus.on(Events.ORDER_CREATED, (payload) => {\n+    const event = payload as OrderCreatedEvent;\n+    orderCount++;\n+    orderTotals.set(event.orderId, event.total);\n+    orderedCarts.add(event.cartId);\n+    countCartItems(event.cartId);\n+  });\n+\n+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n+    const event = payload as PaymentProcessedEvent;\n+    if (event.status === PaymentStatus.SUCCESS) {\n+      const total = orderTotals.get(event.orderId) ?? 0;\n+      revenue += total;\n+    }\n+  });\n+\n+  return {\n+    getEventCount(eventType: string): number {\n+      return eventCounts.get(eventType) ?? 0;\n+    },\n+\n+    getRevenue(): number {\n+      return revenue;\n+    },\n+\n+    getConversionRate(): number {\n+      if (uniqueCarts.size === 0) return 0;\n+      return orderCount / uniqueCarts.size;\n+    },\n+\n+    getTopProducts(limit: number) {\n+      return Array.from(productCounts.entries())\n+        .map(([productId, count]) => ({ productId, count }))\n+        .sort((a, b) => b.count - a.count)\n+        .slice(0, limit);\n+    },\n+  };\n+}\ndiff --git a/src/cart/cart.test.ts b/src/cart/cart.test.ts\nnew file mode 100644\nindex 0000000..08025ae\n--- /dev/null\n+++ b/src/cart/cart.test.ts\n@@ -0,0 +1,84 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events, type CartUpdatedEvent } from '../types.js';\n+import { createCartService } from './index.js';\n+\n+describe('CartService', () => {\n+  let bus: EventBus;\n+  let cart: ReturnType<typeof createCartService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    cart = createCartService(bus);\n+  });\n+\n+  test('createCart returns a cart id', () => {\n+    const id = cart.createCart('user1');\n+    expect(id).toBeTruthy();\n+    expect(typeof id).toBe('string');\n+  });\n+\n+  test('getCart returns created cart', () => {\n+    const id = cart.createCart('user1');\n+    const c = cart.getCart(id);\n+    expect(c).toEqual({ id, userId: 'user1', items: [] });\n+  });\n+\n+  test('getCart returns null for unknown id', () => {\n+    expect(cart.getCart('nonexistent')).toBeNull();\n+  });\n+\n+  test('addItem adds an item to the cart', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n+  });\n+\n+  test('addItem consolidates same product quantities', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.addItem(id, 'p1', 3);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n+  });\n+\n+  test('removeItem removes product from cart', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.addItem(id, 'p2', 1);\n+    cart.removeItem(id, 'p1');\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n+  });\n+\n+  test('updateQuantity changes item quantity', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.updateQuantity(id, 'p1', 5);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n+  });\n+\n+  test('clearCart removes all items', () => {\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    cart.addItem(id, 'p2', 1);\n+    cart.clearCart(id);\n+    const c = cart.getCart(id);\n+    expect(c!.items).toEqual([]);\n+  });\n+\n+  test('addItem emits CART_UPDATED event', async () => {\n+    const events: CartUpdatedEvent[] = [];\n+    bus.on(Events.CART_UPDATED, (payload) => { events.push(payload as CartUpdatedEvent); });\n+    const id = cart.createCart('user1');\n+    cart.addItem(id, 'p1', 2);\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(events.length).toBeGreaterThanOrEqual(1);\n+    const last = events[events.length - 1];\n+    expect(last.cartId).toBe(id);\n+    expect(last.userId).toBe('user1');\n+    expect(last.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n+  });\n+});\ndiff --git a/src/cart/index.ts b/src/cart/index.ts\nnew file mode 100644\nindex 0000000..2dde64f\n--- /dev/null\n+++ b/src/cart/index.ts\n@@ -0,0 +1,64 @@\n+import { EventBus } from '../bus.js';\n+import { Events, type CartService, type CartUpdatedEvent } from '../types.js';\n+\n+export function createCartService(bus: EventBus): CartService {\n+  const carts = new Map<string, { id: string; userId: string; items: Array<{ productId: string; quantity: number }> }>();\n+  let counter = 0;\n+\n+  function emitUpdate(cartId: string): void {\n+    const c = carts.get(cartId);\n+    if (!c) return;\n+    const event: CartUpdatedEvent = { cartId: c.id, userId: c.userId, items: [...c.items] };\n+    bus.emit(Events.CART_UPDATED, event);\n+  }\n+\n+  return {\n+    createCart(userId: string): string {\n+      const id = `cart_${++counter}`;\n+      carts.set(id, { id, userId, items: [] });\n+      return id;\n+    },\n+\n+    addItem(cartId: string, productId: string, quantity: number): void {\n+      const c = carts.get(cartId);\n+      if (!c) return;\n+      const existing = c.items.find(i => i.productId === productId);\n+      if (existing) {\n+        existing.quantity += quantity;\n+      } else {\n+        c.items.push({ productId, quantity });\n+      }\n+      emitUpdate(cartId);\n+    },\n+\n+    removeItem(cartId: string, productId: string): void {\n+      const c = carts.get(cartId);\n+      if (!c) return;\n+      c.items = c.items.filter(i => i.productId !== productId);\n+      emitUpdate(cartId);\n+    },\n+\n+    getCart(cartId: string) {\n+      const c = carts.get(cartId);\n+      if (!c) return null;\n+      return { id: c.id, userId: c.userId, items: [...c.items] };\n+    },\n+\n+    clearCart(cartId: string): void {\n+      const c = carts.get(cartId);\n+      if (!c) return;\n+      c.items = [];\n+      emitUpdate(cartId);\n+    },\n+\n+    updateQuantity(cartId: string, productId: string, quantity: number): void {\n+      const c = carts.get(cartId);\n+      if (!c) return;\n+      const item = c.items.find(i => i.productId === productId);\n+      if (item) {\n+        item.quantity = quantity;\n+        emitUpdate(cartId);\n+      }\n+    },\n+  };\n+}\ndiff --git a/src/catalog/catalog.test.ts b/src/catalog/catalog.test.ts\nnew file mode 100644\nindex 0000000..ed01645\n--- /dev/null\n+++ b/src/catalog/catalog.test.ts\n@@ -0,0 +1,89 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events } from '../types.js';\n+import { createCatalogService } from './index.js';\n+\n+describe('CatalogService', () => {\n+  let bus: EventBus;\n+  let catalog: ReturnType<typeof createCatalogService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    catalog = createCatalogService(bus);\n+  });\n+\n+  test('createProduct returns a product id', () => {\n+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n+    expect(id).toBeTruthy();\n+    expect(typeof id).toBe('string');\n+  });\n+\n+  test('getProduct returns created product', () => {\n+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n+    const product = catalog.getProduct(id);\n+    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n+  });\n+\n+  test('getProduct returns null for unknown id', () => {\n+    expect(catalog.getProduct('nonexistent')).toBeNull();\n+  });\n+\n+  test('listProducts returns all products', () => {\n+    catalog.createProduct('A', 1, 'cat1');\n+    catalog.createProduct('B', 2, 'cat2');\n+    const all = catalog.listProducts();\n+    expect(all).toHaveLength(2);\n+  });\n+\n+  test('listProducts filters by category', () => {\n+    catalog.createProduct('A', 1, 'cat1');\n+    catalog.createProduct('B', 2, 'cat2');\n+    catalog.createProduct('C', 3, 'cat1');\n+    const filtered = catalog.listProducts('cat1');\n+    expect(filtered).toHaveLength(2);\n+    expect(filtered.every(p => p.category === 'cat1')).toBe(true);\n+  });\n+\n+  test('searchProducts matches by name substring', () => {\n+    catalog.createProduct('Blue Widget', 5, 'gadgets');\n+    catalog.createProduct('Red Gizmo', 10, 'gadgets');\n+    const results = catalog.searchProducts('widget');\n+    expect(results).toHaveLength(1);\n+    expect(results[0].name).toBe('Blue Widget');\n+  });\n+\n+  test('searchProducts is case-insensitive', () => {\n+    catalog.createProduct('Blue Widget', 5, 'gadgets');\n+    const results = catalog.searchProducts('BLUE');\n+    expect(results).toHaveLength(1);\n+  });\n+\n+  test('updateProduct changes product fields', () => {\n+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n+    catalog.updateProduct(id, { name: 'Super Widget', price: 19.99 });\n+    const product = catalog.getProduct(id);\n+    expect(product!.name).toBe('Super Widget');\n+    expect(product!.price).toBe(19.99);\n+    expect(product!.category).toBe('gadgets');\n+  });\n+\n+  test('removeProduct deletes and returns true', () => {\n+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n+    expect(catalog.removeProduct(id)).toBe(true);\n+    expect(catalog.getProduct(id)).toBeNull();\n+  });\n+\n+  test('removeProduct returns false for unknown id', () => {\n+    expect(catalog.removeProduct('nonexistent')).toBe(false);\n+  });\n+\n+  test('createProduct emits PRODUCT_CREATED event', async () => {\n+    const events: unknown[] = [];\n+    bus.on(Events.PRODUCT_CREATED, (payload) => { events.push(payload); });\n+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n+    // emit is async, need to wait for it\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(events).toHaveLength(1);\n+    expect(events[0]).toEqual({ productId: id, name: 'Widget', price: 9.99, category: 'gadgets' });\n+  });\n+});\ndiff --git a/src/catalog/index.ts b/src/catalog/index.ts\nnew file mode 100644\nindex 0000000..eb6141e\n--- /dev/null\n+++ b/src/catalog/index.ts\n@@ -0,0 +1,46 @@\n+import { EventBus } from '../bus.js';\n+import { Events, type CatalogService, type ProductCreatedEvent } from '../types.js';\n+\n+export function createCatalogService(bus: EventBus): CatalogService {\n+  const products = new Map<string, { id: string; name: string; price: number; category: string }>();\n+  let counter = 0;\n+\n+  return {\n+    createProduct(name: string, price: number, category: string): string {\n+      const id = `prod_${++counter}`;\n+      products.set(id, { id, name, price, category });\n+      const event: ProductCreatedEvent = { productId: id, name, price, category };\n+      bus.emit(Events.PRODUCT_CREATED, event);\n+      return id;\n+    },\n+\n+    getProduct(productId: string) {\n+      return products.get(productId) ?? null;\n+    },\n+\n+    listProducts(category?: string) {\n+      const all = Array.from(products.values());\n+      if (category !== undefined) {\n+        return all.filter(p => p.category === category);\n+      }\n+      return all;\n+    },\n+\n+    searchProducts(query: string) {\n+      const lower = query.toLowerCase();\n+      return Array.from(products.values()).filter(p => p.name.toLowerCase().includes(lower));\n+    },\n+\n+    updateProduct(productId: string, updates: Partial<{ name: string; price: number; category: string }>) {\n+      const product = products.get(productId);\n+      if (!product) return;\n+      if (updates.name !== undefined) product.name = updates.name;\n+      if (updates.price !== undefined) product.price = updates.price;\n+      if (updates.category !== undefined) product.category = updates.category;\n+    },\n+\n+    removeProduct(productId: string): boolean {\n+      return products.delete(productId);\n+    },\n+  };\n+}\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..2a6300c\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,8 @@\n+export { createCatalogService } from './catalog/index.js';\n+export { createInventoryService } from './inventory/index.js';\n+export { createCartService } from './cart/index.js';\n+export { createPricingService } from './pricing/index.js';\n+export { createOrderService } from './orders/index.js';\n+export { createPaymentService } from './payment/index.js';\n+export { createNotificationService } from './notifications/index.js';\n+export { createAnalyticsService } from './analytics/index.js';\ndiff --git a/src/inventory/index.ts b/src/inventory/index.ts\nnew file mode 100644\nindex 0000000..9d1c8df\n--- /dev/null\n+++ b/src/inventory/index.ts\n@@ -0,0 +1,46 @@\n+import { EventBus } from '../bus.js';\n+import { Events, type InventoryService, type InventoryUpdatedEvent, type LowStockAlertEvent } from '../types.js';\n+\n+export function createInventoryService(bus: EventBus): InventoryService {\n+  const stock = new Map<string, number>();\n+  const thresholds = new Map<string, number>();\n+\n+  function checkLowStock(productId: string): void {\n+    const threshold = thresholds.get(productId);\n+    if (threshold === undefined) return;\n+    const qty = stock.get(productId) ?? 0;\n+    if (qty < threshold) {\n+      const event: LowStockAlertEvent = { productId, currentQuantity: qty, threshold };\n+      bus.emit(Events.LOW_STOCK_ALERT, event);\n+    }\n+  }\n+\n+  return {\n+    setStock(productId: string, quantity: number): void {\n+      stock.set(productId, quantity);\n+      const event: InventoryUpdatedEvent = { productId, quantity };\n+      bus.emit(Events.INVENTORY_UPDATED, event);\n+    },\n+\n+    getStock(productId: string): number {\n+      return stock.get(productId) ?? 0;\n+    },\n+\n+    reserve(productId: string, quantity: number): boolean {\n+      const current = stock.get(productId) ?? 0;\n+      if (current < quantity) return false;\n+      stock.set(productId, current - quantity);\n+      checkLowStock(productId);\n+      return true;\n+    },\n+\n+    release(productId: string, quantity: number): void {\n+      const current = stock.get(productId) ?? 0;\n+      stock.set(productId, current + quantity);\n+    },\n+\n+    setLowStockThreshold(productId: string, threshold: number): void {\n+      thresholds.set(productId, threshold);\n+    },\n+  };\n+}\ndiff --git a/src/inventory/inventory.test.ts b/src/inventory/inventory.test.ts\nnew file mode 100644\nindex 0000000..79a1dd2\n--- /dev/null\n+++ b/src/inventory/inventory.test.ts\n@@ -0,0 +1,77 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events, type LowStockAlertEvent, type InventoryUpdatedEvent } from '../types.js';\n+import { createInventoryService } from './index.js';\n+\n+describe('InventoryService', () => {\n+  let bus: EventBus;\n+  let inventory: ReturnType<typeof createInventoryService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    inventory = createInventoryService(bus);\n+  });\n+\n+  test('getStock returns 0 for unknown product', () => {\n+    expect(inventory.getStock('unknown')).toBe(0);\n+  });\n+\n+  test('setStock sets the stock level', () => {\n+    inventory.setStock('p1', 100);\n+    expect(inventory.getStock('p1')).toBe(100);\n+  });\n+\n+  test('setStock emits INVENTORY_UPDATED event', async () => {\n+    const events: InventoryUpdatedEvent[] = [];\n+    bus.on(Events.INVENTORY_UPDATED, (payload) => { events.push(payload as InventoryUpdatedEvent); });\n+    inventory.setStock('p1', 50);\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(events).toHaveLength(1);\n+    expect(events[0]).toEqual({ productId: 'p1', quantity: 50 });\n+  });\n+\n+  test('reserve reduces available stock and returns true', () => {\n+    inventory.setStock('p1', 10);\n+    const result = inventory.reserve('p1', 3);\n+    expect(result).toBe(true);\n+    expect(inventory.getStock('p1')).toBe(7);\n+  });\n+\n+  test('reserve returns false if insufficient stock', () => {\n+    inventory.setStock('p1', 2);\n+    const result = inventory.reserve('p1', 5);\n+    expect(result).toBe(false);\n+    expect(inventory.getStock('p1')).toBe(2);\n+  });\n+\n+  test('release increases stock', () => {\n+    inventory.setStock('p1', 5);\n+    inventory.reserve('p1', 3);\n+    inventory.release('p1', 2);\n+    expect(inventory.getStock('p1')).toBe(4);\n+  });\n+\n+  test('setLowStockThreshold triggers LOW_STOCK_ALERT when stock falls below', async () => {\n+    const alerts: LowStockAlertEvent[] = [];\n+    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload as LowStockAlertEvent); });\n+    inventory.setStock('p1', 10);\n+    inventory.setLowStockThreshold('p1', 5);\n+    inventory.reserve('p1', 6); // stock = 4, below threshold of 5\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(alerts.length).toBeGreaterThanOrEqual(1);\n+    const alert = alerts[alerts.length - 1];\n+    expect(alert.productId).toBe('p1');\n+    expect(alert.currentQuantity).toBe(4);\n+    expect(alert.threshold).toBe(5);\n+  });\n+\n+  test('no LOW_STOCK_ALERT when stock stays above threshold', async () => {\n+    const alerts: LowStockAlertEvent[] = [];\n+    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload as LowStockAlertEvent); });\n+    inventory.setStock('p1', 10);\n+    inventory.setLowStockThreshold('p1', 3);\n+    inventory.reserve('p1', 2); // stock = 8, above threshold\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(alerts).toHaveLength(0);\n+  });\n+});\ndiff --git a/src/notifications/index.ts b/src/notifications/index.ts\nnew file mode 100644\nindex 0000000..c2b2cb5\n--- /dev/null\n+++ b/src/notifications/index.ts\n@@ -0,0 +1,47 @@\n+import { EventBus } from '../bus.js';\n+import { Events, type NotificationService, type OrderCreatedEvent, type OrderStatusChangedEvent, type PaymentProcessedEvent } from '../types.js';\n+\n+export function createNotificationService(bus: EventBus): NotificationService {\n+  const subscribers = new Set<string>();\n+  const userNotifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();\n+  const orderToUser = new Map<string, string>();\n+\n+  function addNotification(userId: string, type: string, message: string): void {\n+    if (!subscribers.has(userId)) return;\n+    if (!userNotifications.has(userId)) {\n+      userNotifications.set(userId, []);\n+    }\n+    userNotifications.get(userId)!.push({ type, message, timestamp: Date.now() });\n+  }\n+\n+  bus.on(Events.ORDER_CREATED, (payload) => {\n+    const event = payload as OrderCreatedEvent;\n+    orderToUser.set(event.orderId, event.userId);\n+  });\n+\n+  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {\n+    const event = payload as OrderStatusChangedEvent;\n+    const userId = orderToUser.get(event.orderId);\n+    if (userId) {\n+      addNotification(userId, 'order_status_changed', `Order ${event.orderId} status changed to ${event.status}`);\n+    }\n+  });\n+\n+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n+    const event = payload as PaymentProcessedEvent;\n+    const userId = orderToUser.get(event.orderId);\n+    if (userId) {\n+      addNotification(userId, 'payment_processed', `Payment for order ${event.orderId}: ${event.status}`);\n+    }\n+  });\n+\n+  return {\n+    subscribe(userId: string): void {\n+      subscribers.add(userId);\n+    },\n+\n+    getNotifications(userId: string) {\n+      return userNotifications.get(userId) ?? [];\n+    },\n+  };\n+}\ndiff --git a/src/notifications/notifications.test.ts b/src/notifications/notifications.test.ts\nnew file mode 100644\nindex 0000000..e3f9361\n--- /dev/null\n+++ b/src/notifications/notifications.test.ts\n@@ -0,0 +1,63 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events, OrderStatus, PaymentStatus } from '../types.js';\n+import { createNotificationService } from './index.js';\n+\n+describe('NotificationService', () => {\n+  let bus: EventBus;\n+  let notifications: ReturnType<typeof createNotificationService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    notifications = createNotificationService(bus);\n+  });\n+\n+  test('getNotifications returns empty array for unknown user', () => {\n+    expect(notifications.getNotifications('unknown')).toEqual([]);\n+  });\n+\n+  test('subscribe registers a user', () => {\n+    notifications.subscribe('user1');\n+    expect(notifications.getNotifications('user1')).toEqual([]);\n+  });\n+\n+  test('records notification on ORDER_CREATED then ORDER_STATUS_CHANGED for subscribed user', async () => {\n+    notifications.subscribe('user1');\n+    // Emit order created to register the mapping\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n+    // Emit status change\n+    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n+    const notifs = notifications.getNotifications('user1');\n+    expect(notifs.length).toBeGreaterThanOrEqual(1);\n+    // Should have notification about order status change\n+    const statusNotif = notifs.find(n => n.type === 'order_status_changed');\n+    expect(statusNotif).toBeTruthy();\n+    expect(statusNotif!.message).toContain('o1');\n+  });\n+\n+  test('records notification on PAYMENT_PROCESSED for subscribed user', async () => {\n+    notifications.subscribe('user1');\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'txn1' });\n+    const notifs = notifications.getNotifications('user1');\n+    const paymentNotif = notifs.find(n => n.type === 'payment_processed');\n+    expect(paymentNotif).toBeTruthy();\n+    expect(paymentNotif!.message).toContain('o1');\n+  });\n+\n+  test('does not record notifications for unsubscribed users', async () => {\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n+    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.SHIPPED, previousStatus: OrderStatus.CONFIRMED });\n+    const notifs = notifications.getNotifications('user1');\n+    expect(notifs).toEqual([]);\n+  });\n+\n+  test('notifications have timestamps', async () => {\n+    notifications.subscribe('user1');\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n+    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n+    const notifs = notifications.getNotifications('user1');\n+    expect(notifs.length).toBeGreaterThan(0);\n+    expect(typeof notifs[0].timestamp).toBe('number');\n+  });\n+});\ndiff --git a/src/orders/index.ts b/src/orders/index.ts\nnew file mode 100644\nindex 0000000..24736ab\n--- /dev/null\n+++ b/src/orders/index.ts\n@@ -0,0 +1,38 @@\n+import { EventBus } from '../bus.js';\n+import { Events, OrderStatus, type OrderService, type OrderCreatedEvent, type OrderStatusChangedEvent } from '../types.js';\n+\n+export function createOrderService(bus: EventBus): OrderService {\n+  const orders = new Map<string, { id: string; userId: string; cartId: string; status: OrderStatus; total: number }>();\n+  let counter = 0;\n+\n+  return {\n+    createOrder(userId: string, cartId: string, total: number): string {\n+      const id = `order_${++counter}`;\n+      orders.set(id, { id, userId, cartId, status: OrderStatus.PENDING, total });\n+      const event: OrderCreatedEvent = { orderId: id, userId, cartId, total };\n+      bus.emit(Events.ORDER_CREATED, event);\n+      return id;\n+    },\n+\n+    getOrder(orderId: string) {\n+      const order = orders.get(orderId);\n+      if (!order) return null;\n+      return { id: order.id, userId: order.userId, status: order.status, total: order.total };\n+    },\n+\n+    updateStatus(orderId: string, status: OrderStatus): void {\n+      const order = orders.get(orderId);\n+      if (!order) return;\n+      const previousStatus = order.status;\n+      order.status = status;\n+      const event: OrderStatusChangedEvent = { orderId, status, previousStatus };\n+      bus.emit(Events.ORDER_STATUS_CHANGED, event);\n+    },\n+\n+    listOrders(userId: string) {\n+      return Array.from(orders.values())\n+        .filter(o => o.userId === userId)\n+        .map(o => ({ id: o.id, status: o.status, total: o.total }));\n+    },\n+  };\n+}\ndiff --git a/src/orders/orders.test.ts b/src/orders/orders.test.ts\nnew file mode 100644\nindex 0000000..86acc8a\n--- /dev/null\n+++ b/src/orders/orders.test.ts\n@@ -0,0 +1,83 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events, OrderStatus, type OrderCreatedEvent, type OrderStatusChangedEvent } from '../types.js';\n+import { createOrderService } from './index.js';\n+\n+describe('OrderService', () => {\n+  let bus: EventBus;\n+  let orders: ReturnType<typeof createOrderService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    orders = createOrderService(bus);\n+  });\n+\n+  test('createOrder returns an order id', () => {\n+    const id = orders.createOrder('user1', 'cart1', 99.99);\n+    expect(id).toBeTruthy();\n+    expect(typeof id).toBe('string');\n+  });\n+\n+  test('createOrder creates order in PENDING status', () => {\n+    const id = orders.createOrder('user1', 'cart1', 99.99);\n+    const order = orders.getOrder(id);\n+    expect(order).toEqual({ id, userId: 'user1', status: OrderStatus.PENDING, total: 99.99 });\n+  });\n+\n+  test('getOrder returns null for unknown id', () => {\n+    expect(orders.getOrder('nonexistent')).toBeNull();\n+  });\n+\n+  test('updateStatus changes order status', () => {\n+    const id = orders.createOrder('user1', 'cart1', 99.99);\n+    orders.updateStatus(id, OrderStatus.CONFIRMED);\n+    const order = orders.getOrder(id);\n+    expect(order!.status).toBe(OrderStatus.CONFIRMED);\n+  });\n+\n+  test('updateStatus progresses through lifecycle', () => {\n+    const id = orders.createOrder('user1', 'cart1', 50);\n+    orders.updateStatus(id, OrderStatus.CONFIRMED);\n+    orders.updateStatus(id, OrderStatus.SHIPPED);\n+    orders.updateStatus(id, OrderStatus.DELIVERED);\n+    expect(orders.getOrder(id)!.status).toBe(OrderStatus.DELIVERED);\n+  });\n+\n+  test('updateStatus supports cancellation', () => {\n+    const id = orders.createOrder('user1', 'cart1', 50);\n+    orders.updateStatus(id, OrderStatus.CANCELLED);\n+    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n+  });\n+\n+  test('listOrders returns orders for a user', () => {\n+    orders.createOrder('user1', 'cart1', 10);\n+    orders.createOrder('user2', 'cart2', 20);\n+    orders.createOrder('user1', 'cart3', 30);\n+    const list = orders.listOrders('user1');\n+    expect(list).toHaveLength(2);\n+    expect(list.every(o => 'id' in o && 'status' in o && 'total' in o)).toBe(true);\n+  });\n+\n+  test('createOrder emits ORDER_CREATED event', async () => {\n+    const events: OrderCreatedEvent[] = [];\n+    bus.on(Events.ORDER_CREATED, (payload) => { events.push(payload as OrderCreatedEvent); });\n+    const id = orders.createOrder('user1', 'cart1', 99.99);\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(events).toHaveLength(1);\n+    expect(events[0]).toEqual({ orderId: id, userId: 'user1', cartId: 'cart1', total: 99.99 });\n+  });\n+\n+  test('updateStatus emits ORDER_STATUS_CHANGED event with previousStatus', async () => {\n+    const events: OrderStatusChangedEvent[] = [];\n+    bus.on(Events.ORDER_STATUS_CHANGED, (payload) => { events.push(payload as OrderStatusChangedEvent); });\n+    const id = orders.createOrder('user1', 'cart1', 50);\n+    orders.updateStatus(id, OrderStatus.CONFIRMED);\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(events).toHaveLength(1);\n+    expect(events[0]).toEqual({\n+      orderId: id,\n+      status: OrderStatus.CONFIRMED,\n+      previousStatus: OrderStatus.PENDING,\n+    });\n+  });\n+});\ndiff --git a/src/payment/index.ts b/src/payment/index.ts\nnew file mode 100644\nindex 0000000..191087c\n--- /dev/null\n+++ b/src/payment/index.ts\n@@ -0,0 +1,44 @@\n+import { EventBus } from '../bus.js';\n+import { Events, PaymentStatus, type PaymentService, type PaymentProcessedEvent } from '../types.js';\n+\n+export interface PaymentOptions {\n+  simulateFailure?: boolean;\n+  simulateTimeout?: boolean;\n+}\n+\n+export function createPaymentService(bus: EventBus, options?: PaymentOptions): PaymentService {\n+  const transactions = new Map<string, { orderId: string; amount: number; status: PaymentStatus }>();\n+  let counter = 0;\n+\n+  return {\n+    async processPayment(orderId: string, amount: number) {\n+      let status: PaymentStatus;\n+      let transactionId: string | undefined;\n+      let error: string | undefined;\n+\n+      if (options?.simulateTimeout) {\n+        status = PaymentStatus.TIMEOUT;\n+        error = 'Payment timed out';\n+      } else if (options?.simulateFailure) {\n+        status = PaymentStatus.FAILED;\n+        error = 'Payment failed';\n+      } else {\n+        status = PaymentStatus.SUCCESS;\n+        transactionId = `txn_${++counter}`;\n+        transactions.set(transactionId, { orderId, amount, status });\n+      }\n+\n+      const event: PaymentProcessedEvent = { orderId, status, transactionId, error };\n+      await bus.emit(Events.PAYMENT_PROCESSED, event);\n+\n+      return { status, transactionId, error };\n+    },\n+\n+    async refund(transactionId: string): Promise<boolean> {\n+      const txn = transactions.get(transactionId);\n+      if (!txn || txn.status !== PaymentStatus.SUCCESS) return false;\n+      txn.status = PaymentStatus.FAILED;\n+      return true;\n+    },\n+  };\n+}\ndiff --git a/src/payment/payment.test.ts b/src/payment/payment.test.ts\nnew file mode 100644\nindex 0000000..c03524f\n--- /dev/null\n+++ b/src/payment/payment.test.ts\n@@ -0,0 +1,65 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events, PaymentStatus, type PaymentProcessedEvent } from '../types.js';\n+import { createPaymentService } from './index.js';\n+\n+describe('PaymentService', () => {\n+  let bus: EventBus;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+  });\n+\n+  test('processPayment succeeds by default', async () => {\n+    const payment = createPaymentService(bus);\n+    const result = await payment.processPayment('order1', 100);\n+    expect(result.status).toBe(PaymentStatus.SUCCESS);\n+    expect(result.transactionId).toBeTruthy();\n+  });\n+\n+  test('processPayment can simulate failure', async () => {\n+    const payment = createPaymentService(bus, { simulateFailure: true });\n+    const result = await payment.processPayment('order1', 100);\n+    expect(result.status).toBe(PaymentStatus.FAILED);\n+    expect(result.error).toBeTruthy();\n+  });\n+\n+  test('processPayment can simulate timeout', async () => {\n+    const payment = createPaymentService(bus, { simulateTimeout: true });\n+    const result = await payment.processPayment('order1', 100);\n+    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n+    expect(result.error).toBeTruthy();\n+  });\n+\n+  test('processPayment emits PAYMENT_PROCESSED event', async () => {\n+    const events: PaymentProcessedEvent[] = [];\n+    bus.on(Events.PAYMENT_PROCESSED, (payload) => { events.push(payload as PaymentProcessedEvent); });\n+    const payment = createPaymentService(bus);\n+    const result = await payment.processPayment('order1', 50);\n+    expect(events).toHaveLength(1);\n+    expect(events[0].orderId).toBe('order1');\n+    expect(events[0].status).toBe(PaymentStatus.SUCCESS);\n+    expect(events[0].transactionId).toBe(result.transactionId);\n+  });\n+\n+  test('refund returns true for successful transaction', async () => {\n+    const payment = createPaymentService(bus);\n+    const result = await payment.processPayment('order1', 100);\n+    const refunded = await payment.refund(result.transactionId!);\n+    expect(refunded).toBe(true);\n+  });\n+\n+  test('refund returns false for unknown transaction', async () => {\n+    const payment = createPaymentService(bus);\n+    const refunded = await payment.refund('nonexistent');\n+    expect(refunded).toBe(false);\n+  });\n+\n+  test('refund returns false for failed transaction', async () => {\n+    const payment = createPaymentService(bus, { simulateFailure: true });\n+    await payment.processPayment('order1', 100);\n+    // Failed transactions have no transactionId, so refund with arbitrary id\n+    const refunded = await payment.refund('arbitrary');\n+    expect(refunded).toBe(false);\n+  });\n+});\ndiff --git a/src/pricing/index.ts b/src/pricing/index.ts\nnew file mode 100644\nindex 0000000..6e85a2f\n--- /dev/null\n+++ b/src/pricing/index.ts\n@@ -0,0 +1,42 @@\n+import { EventBus } from '../bus.js';\n+import { Events, type PricingService, type ProductCreatedEvent } from '../types.js';\n+\n+const TAX_RATE = 0.1;\n+\n+export function createPricingService(bus: EventBus): PricingService {\n+  const prices = new Map<string, number>();\n+  const discountCodes = new Map<string, number>();\n+\n+  bus.on(Events.PRODUCT_CREATED, (payload) => {\n+    const event = payload as ProductCreatedEvent;\n+    prices.set(event.productId, event.price);\n+  });\n+\n+  return {\n+    calculateTotal(items: Array<{ productId: string; quantity: number; price: number }>, discountCode?: string) {\n+      const subtotal = items.reduce((sum, item) => sum + item.price * item.quantity, 0);\n+\n+      let discountAmount = 0;\n+      if (discountCode) {\n+        const percentage = discountCodes.get(discountCode);\n+        if (percentage !== undefined) {\n+          discountAmount = subtotal * (percentage / 100);\n+        }\n+      }\n+\n+      const taxable = subtotal - discountAmount;\n+      const tax = taxable * TAX_RATE;\n+      const total = taxable + tax;\n+\n+      return { subtotal, discount: discountAmount, tax, total };\n+    },\n+\n+    addDiscountCode(code: string, percentage: number): void {\n+      discountCodes.set(code, percentage);\n+    },\n+\n+    getPrice(productId: string): number {\n+      return prices.get(productId) ?? 0;\n+    },\n+  };\n+}\ndiff --git a/src/pricing/pricing.test.ts b/src/pricing/pricing.test.ts\nnew file mode 100644\nindex 0000000..6b7e2b7\n--- /dev/null\n+++ b/src/pricing/pricing.test.ts\n@@ -0,0 +1,73 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events } from '../types.js';\n+import { createPricingService } from './index.js';\n+\n+describe('PricingService', () => {\n+  let bus: EventBus;\n+  let pricing: ReturnType<typeof createPricingService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    pricing = createPricingService(bus);\n+  });\n+\n+  test('calculateTotal computes subtotal, tax at 10%, and total', () => {\n+    const result = pricing.calculateTotal([\n+      { productId: 'p1', quantity: 2, price: 10 },\n+      { productId: 'p2', quantity: 1, price: 20 },\n+    ]);\n+    expect(result.subtotal).toBe(40);\n+    expect(result.discount).toBe(0);\n+    expect(result.tax).toBeCloseTo(4);\n+    expect(result.total).toBeCloseTo(44);\n+  });\n+\n+  test('calculateTotal applies discount code before tax', () => {\n+    pricing.addDiscountCode('SAVE10', 10);\n+    const result = pricing.calculateTotal(\n+      [{ productId: 'p1', quantity: 1, price: 100 }],\n+      'SAVE10'\n+    );\n+    expect(result.subtotal).toBe(100);\n+    expect(result.discount).toBe(10); // 10% of 100\n+    expect(result.tax).toBeCloseTo(9); // 10% of (100 - 10) = 9\n+    expect(result.total).toBeCloseTo(99); // 90 + 9\n+  });\n+\n+  test('calculateTotal with unknown discount code applies no discount', () => {\n+    const result = pricing.calculateTotal(\n+      [{ productId: 'p1', quantity: 1, price: 100 }],\n+      'INVALID'\n+    );\n+    expect(result.discount).toBe(0);\n+    expect(result.total).toBeCloseTo(110);\n+  });\n+\n+  test('getPrice returns 0 for unknown product', () => {\n+    expect(pricing.getPrice('unknown')).toBe(0);\n+  });\n+\n+  test('getPrice tracks prices from PRODUCT_CREATED events', async () => {\n+    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 25, category: 'gadgets' });\n+    expect(pricing.getPrice('p1')).toBe(25);\n+  });\n+\n+  test('addDiscountCode registers a discount', () => {\n+    pricing.addDiscountCode('HALF', 50);\n+    const result = pricing.calculateTotal(\n+      [{ productId: 'p1', quantity: 1, price: 200 }],\n+      'HALF'\n+    );\n+    expect(result.discount).toBe(100);\n+    expect(result.total).toBeCloseTo(110); // (200 - 100) + 10% tax\n+  });\n+\n+  test('calculateTotal with empty items', () => {\n+    const result = pricing.calculateTotal([]);\n+    expect(result.subtotal).toBe(0);\n+    expect(result.discount).toBe(0);\n+    expect(result.tax).toBe(0);\n+    expect(result.total).toBe(0);\n+  });\n+});","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
