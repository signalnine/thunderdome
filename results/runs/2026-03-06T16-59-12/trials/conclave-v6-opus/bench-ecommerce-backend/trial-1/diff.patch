+import { describe, test, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { Events, PaymentStatus } from '../types.js';
+import { createAnalyticsService } from './index.js';
+
+describe('AnalyticsService', () => {
+  let bus: EventBus;
+  let analytics: ReturnType<typeof createAnalyticsService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    analytics = createAnalyticsService(bus);
+  });
+
+  test('getEventCount returns 0 for unknown event type', () => {
+    expect(analytics.getEventCount('nonexistent')).toBe(0);
+  });
+
+  test('getEventCount tracks events by type', async () => {
+    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'W', price: 10, category: 'c' });
+    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'X', price: 20, category: 'c' });
+    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);
+  });
+
+  test('getRevenue returns 0 initially', () => {
+    expect(analytics.getRevenue()).toBe(0);
+  });
+
+  test('getRevenue tracks revenue from successful payments', async () => {
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });
+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'txn1' });
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 50 });
+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o2', status: PaymentStatus.SUCCESS, transactionId: 'txn2' });
+    expect(analytics.getRevenue()).toBe(150);
+  });
+
+  test('getRevenue ignores failed payments', async () => {
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });
+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'failed' });
+    expect(analytics.getRevenue()).toBe(0);
+  });
+
+  test('getConversionRate returns 0 when no carts', () => {
+    expect(analytics.getConversionRate()).toBe(0);
+  });
+
+  test('getConversionRate calculates orders / unique carts', async () => {
+    // 2 unique carts created
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 1 }] });
+    // 1 order
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });
+    expect(analytics.getConversionRate()).toBeCloseTo(0.5);
+  });
+
+  test('getConversionRate counts unique carts not total cart events', async () => {
+    // Same cart updated multiple times
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 2 }] });
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });
+    expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 unique cart
+  });
+
+  test('getTopProducts returns empty array initially', () => {
+    expect(analytics.getTopProducts(5)).toEqual([]);
+  });
+
+  test('getTopProducts ranks products by order quantity', async () => {
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 3 }, { productId: 'p2', quantity: 1 }] });
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 50 });
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 5 }] });
+    const top = analytics.getTopProducts(2);
+    expect(top).toHaveLength(2);
+    expect(top[0].productId).toBe('p2'); // 1 + 5 = 6
+    expect(top[0].count).toBe(6);
+    expect(top[1].productId).toBe('p1'); // 3
+    expect(top[1].count).toBe(3);
+  });
+
+  test('getTopProducts respects limit', async () => {
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }, { productId: 'p2', quantity: 2 }, { productId: 'p3', quantity: 3 }] });
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 10 });
+    const top = analytics.getTopProducts(2);
+    expect(top).toHaveLength(2);
+  });
+});
diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..e44de64
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,88 @@
+import { EventBus } from '../bus.js';
+import { Events, PaymentStatus, type AnalyticsService, type CartUpdatedEvent, type OrderCreatedEvent, type PaymentProcessedEvent } from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const uniqueCarts = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>();
+  const orderTotals = new Map<string, number>();
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+  const orderedCarts = new Set<string>(); // cartIds that have been ordered
+  const processedOrderCarts = new Set<string>(); // cartIds whose items have been counted
+
+  const trackedEvents = [
+    Events.PRODUCT_CREATED,
+    Events.INVENTORY_UPDATED,
+    Events.LOW_STOCK_ALERT,
+    Events.CART_UPDATED,
+    Events.PRICE_CALCULATED,
+    Events.ORDER_CREATED,
+    Events.ORDER_STATUS_CHANGED,
+    Events.PAYMENT_PROCESSED,
+    Events.NOTIFICATION_SENT,
+    Events.ANALYTICS_EVENT,
+  ];
+
+  for (const eventName of trackedEvents) {
+    bus.on(eventName, () => {
+      eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);
+    });
+  }
+
+  function countCartItems(cartId: string): void {
+    if (processedOrderCarts.has(cartId)) return;
+    const items = cartItems.get(cartId);
+    if (!items || !orderedCarts.has(cartId)) return;
+    processedOrderCarts.add(cartId);
+    for (const item of items) {
+      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+    }
+  }
+
+  bus.on(Events.CART_UPDATED, (payload) => {
+    const event = payload as CartUpdatedEvent;
+    uniqueCarts.add(event.cartId);
+    cartItems.set(event.cartId, [...event.items]);
+    countCartItems(event.cartId);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const event = payload as OrderCreatedEvent;
+    orderCount++;
+    orderTotals.set(event.orderId, event.total);
+    orderedCarts.add(event.cartId);
+    countCartItems(event.cartId);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      const total = orderTotals.get(event.orderId) ?? 0;
+      revenue += total;
+    }
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return revenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCarts.size === 0) return 0;
+      return orderCount / uniqueCarts.size;
+    },
+
+    getTopProducts(limit: number) {
+      return Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
