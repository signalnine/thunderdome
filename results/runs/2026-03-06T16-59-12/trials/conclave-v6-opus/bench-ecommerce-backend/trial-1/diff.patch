ents, PaymentStatus, type AnalyticsService, type CartUpdatedEvent, type OrderCreatedEvent, type PaymentProcessedEvent } from '../types.js';\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  const eventCounts = new Map<string, number>();\n  let revenue = 0;\n  const uniqueCarts = new Set<string>();\n  let orderCount = 0;\n  const productCounts = new Map<string, number>();\n  const orderTotals = new Map<string, number>();\n  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();\n  const orderedCarts = new Set<string>(); // cartIds that have been ordered\n  const processedOrderCarts = new Set<string>(); // cartIds whose items have been counted\n\n  const trackedEvents = [\n    Events.PRODUCT_CREATED,\n    Events.INVENTORY_UPDATED,\n    Events.LOW_STOCK_ALERT,\n    Events.CART_UPDATED,\n    Events.PRICE_CALCULATED,\n    Events.ORDER_CREATED,\n    Events.ORDER_STATUS_CHANGED,\n    Events.PAYMENT_PROCESSED,\n    Events.NOTIFICATION_SENT,\n    Events.ANALYTICS_EVENT,\n  ];\n\n  for (const eventName of trackedEvents) {\n    bus.on(eventName, () => {\n      eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);\n    });\n  }\n\n  bus.on(Events.CART_UPDATED, (payload) => {\n    const event = payload as CartUpdatedEvent;\n    uniqueCarts.add(event.cartId);\n    cartItems.set(event.cartId, [...event.items]);\n  });\n\n  bus.on(Events.ORDER_CREATED, (payload) => {\n    const event = payload as OrderCreatedEvent;\n    orderCount++;\n    orderTotals.set(event.orderId, event.total);\n    // Track product quantities from the cart associated with this order\n    const items = cartItems.get(event.cartId);\n    if (items) {\n      for (const item of items) {\n        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n      }\n    }\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n    const event = payload as PaymentProcessedEvent;\n    if (event.status === PaymentStatus.SUCCESS) {\n      const total = orderTotals.get(event.orderId) ?? 0;\n      revenue += total;\n    }\n  });\n\n  return {\n    getEventCount(eventType: string): number {\n      return eventCounts.get(eventType) ?? 0;\n    },\n\n    getRevenue(): number {\n      return revenue;\n    },\n\n    getConversionRate(): number {\n      if (uniqueCarts.size === 0) return 0;\n      return orderCount / uniqueCarts.size;\n    },\n\n    getTopProducts(limit: number) {\n      return Array.from(productCounts.entries())\n        .map(([productId, count]) => ({ productId, count }))\n        .sort((a, b) => b.count - a.count)\n        .slice(0, limit);\n    },\n  };\n}\n","structuredPatch":[{"oldStart":31,"oldLines":23,"newStart":31,"newLines":29,"lines":["     });","   }"," ","+  function countCartItems(cartId: string): void {","+    if (processedOrderCarts.has(cartId)) return;","+    const items = cartItems.get(cartId);","+    if (!items || !orderedCarts.has(cartId)) return;","+    processedOrderCarts.add(cartId);","+    for (const item of items) {","+      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);","+    }","+  }","+","   bus.on(Events.CART_UPDATED, (payload) => {","     const event = payload as CartUpdatedEvent;","     uniqueCarts.add(event.cartId);","     cartItems.set(event.cartId, [...event.items]);","+    countCartItems(event.cartId);","   });"," ","   bus.on(Events.ORDER_CREATED, (payload) => {","     const event = payload as OrderCreatedEvent;","     orderCount++;","     orderTotals.set(event.orderId, event.total);","-    // Track product quantities from the cart associated with this order","-    const items = cartItems.get(event.cartId);","-    if (items) {","-      for (const item of items) {","-        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);","-      }","-    }","+    orderedCarts.add(event.cartId);","+    countCartItems(event.cartId);","   });"," ","   bus.