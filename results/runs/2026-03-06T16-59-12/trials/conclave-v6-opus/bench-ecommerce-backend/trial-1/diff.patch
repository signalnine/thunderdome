+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });
+    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.SHIPPED, previousStatus: OrderStatus.CONFIRMED });
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs).toEqual([]);
