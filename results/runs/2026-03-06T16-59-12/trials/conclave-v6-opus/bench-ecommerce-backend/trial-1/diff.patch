+counter}`;\n+      products.set(id, { id, name, price, category });\n+      const event: ProductCreatedEvent = { productId: id, name, price, category };\n+      bus.emit(Events.PRODUCT_CREATED, event);\n+      return id;\n+    },\n+\n+    getProduct(productId: string) {\n+      return products.get(productId) ?? null;\n+    },\n+\n+    listProducts(category?: string) {\n+      const all = Array.from(products.values());\n+      if (category !== undefined) {\n+        return all.filter(p => p.category === category);\n+      }\n+      return all;\n+    },\n+\n+    searchProducts(query: string) {\n+      const lower = query.toLowerCase();\n+      return Array.from(products.values()).filter(p => p.name.toLowerCase().includes(lower));\n+    },\n+\n+    updateProduct(productId: string, updates: Partial<{ name: string; price: number; category: string }>) {\n+      const product = products.get(productId);\n+      if (!product) return;\n+      if (updates.name !== undefined) product.name = updates.name;\n+      if (updates.price !== undefined) product.price = updates.price;\n+      if (updates.category !== undefined) product.category = updates.category;\n+    },\n+\n+    removeProduct(productId: string): boolean {\n+      return products.delete(productId);\n+    },\n+  };\n+}\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..2a6300c\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,8 @@\n+export { createCatalogService } from './catalog/index.js';\n+export { createInventoryService } from './inventory/index.js';\n+export { createCartService } from './cart/index.js';\n+export { createPricingService } from './pricing/index.js';\n+export { createOrderService } from './orders/index.js';\n+export { createPaymentService } from './payment/index.js';\n+export { createNotificationService } from './notifications/index.js';\n+export { createAnalyticsService } from './analytics/index.js';\ndiff --git a/src/inventory/index.ts b/src/inventory/index.ts\nnew file mode 100644\nindex 0000000..9d1c8df\n--- /dev/null\n+++ b/src/inventory/index.ts\n@@ -0,0 +1,46 @@\n+import { EventBus } from '../bus.js';\n+import { Events, type InventoryService, type InventoryUpdatedEvent, type LowStockAlertEvent } from '../types.js';\n+\n+export function createInventoryService(bus: EventBus): InventoryService {\n+  const stock = new Map<string, number>();\n+  const thresholds = new Map<string, number>();\n+\n+  function checkLowStock(productId: string): void {\n+    const threshold = thresholds.get(productId);\n+    if (threshold === undefined) return;\n+    const qty = stock.get(productId) ?? 0;\n+    if (qty < threshold) {\n+      const event: LowStockAlertEvent = { productId, currentQuantity: qty, threshold };\n+      bus.emit(Events.LOW_STOCK_ALERT, event);\n+    }\n+  }\n+\n+  return {\n+    setStock(productId: string, quantity: number): void {\n+      stock.set(productId, quantity);\n+      const event: InventoryUpdatedEvent = { productId, quantity };\n+      bus.emit(Events.INVENTORY_UPDATED, event);\n+    },\n+\n+    getStock(productId: string): number {\n+      return stock.get(productId) ?? 0;\n+    },\n+\n+    reserve(productId: string, quantity: number): boolean {\n+      const current = stock.get(productId) ?? 0;\n+      if (current < quantity) return false;\n+      stock.set(productId, current - quantity);\n+      checkLowStock(productId);\n+      return true;\n+    },\n+\n+    release(productId: string, quantity: number): void {\n+      const current = stock.get(productId) ?? 0;\n+      stock.set(productId, current + quantity);\n+    },\n+\n+    setLowStockThreshold(productId: string, threshold: number): void {\n+      thresholds.set(productId, threshold);\n+    },\n+  };\n+}\ndiff --git a/src/inventory/inventory.test.ts b/src/inventory/inventory.test.ts\nnew file mode 100644\nindex 0000000..79a1dd2\n--- /dev/null\n+++ b/src/inventory/inventory.test.ts\n@@ -0,0 +1,77 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events, type LowStockAlertEvent, type InventoryUpdatedEvent } from '../types.js';\n+import { createInventoryService } from './index.js';\n+\n+describe('InventoryService', () => {\n+  let bus: EventBus;\n+  let inventory: ReturnType<typeof createInventoryService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    inventory = createInventoryService(bus);\n+  });\n+\n+  test('getStock returns 0 for unknown product', () => {\n+    expect(inventory.getStock('unknown')).toBe(0);\n+  });\n+\n+  test('setStock sets the stock level', () => {\n+    inventory.setStock('p1', 100);\n+    expect(inventory.getStock('p1')).toBe(100);\n+  });\n+\n+  test('setStock emits INVENTORY_UPDATED event', async () => {\n+    const events: InventoryUpdatedEvent[] = [];\n+    bus.on(Events.INVENTORY_UPDATED, (payload) => { events.push(payload as InventoryUpdatedEvent); });\n+    inventory.setStock('p1', 50);\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(events).toHaveLength(1);\n+    expect(events[0]).toEqual({ productId: 'p1', quantity: 50 });\n+  });\n+\n+  test('reserve reduces available stock and returns true', () => {\n+    inventory.setStock('p1', 10);\n+    const result = inventory.reserve('p1', 3);\n+    expect(result).toBe(true);\n+    expect(inventory.getStock('p1')).toBe(7);\n+  });\n+\n+  test('reserve returns false if insufficient stock', () => {\n+    inventory.setStock('p1', 2);\n+    const result = inventory.reserve('p1', 5);\n+    expect(result).toBe(false);\n+    expect(inventory.getStock('p1')).toBe(2);\n+  });\n+\n+  test('release increases stock', () => {\n+    inventory.setStock('p1', 5);\n+    inventory.reserve('p1', 3);\n+    inventory.release('p1', 2);\n+    expect(inventory.getStock('p1')).toBe(4);\n+  });\n+\n+  test('setLowStockThreshold triggers LOW_STOCK_ALERT when stock falls below', async () => {\n+    const alerts: LowStockAlertEvent[] = [];\n+    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload as LowStockAlertEvent); });\n+    inventory.setStock('p1', 10);\n+    inventory.setLowStockThreshold('p1', 5);\n+    inventory.reserve('p1', 6); // stock = 4, below threshold of 5\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(alerts.length).toBeGreaterThanOrEqual(1);\n+    const alert = alerts[alerts.length - 1];\n+    expect(alert.productId).toBe('p1');\n+    expect(alert.currentQuantity).toBe(4);\n+    expect(alert.threshold).toBe(5);\n+  });\n+\n+  test('no LOW_STOCK_ALERT when stock stays above threshold', async () => {\n+    const alerts: LowStockAlertEvent[] = [];\n+    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload as LowStockAlertEvent); });\n+    inventory.setStock('p1', 10);\n+    inventory.setLowStockThreshold('p1', 3);\n+    inventory.reserve('p1', 2); // stock = 8, above threshold\n+    await new Promise(r => setTimeout(r, 10));\n+    expect(alerts).toHaveLength(0);\n+  });\n+});\ndiff --git a/src/notifications/index.ts b/src/notifications/index.ts\nnew file mode 100644\nindex 0000000..c2b2cb5\n--- /dev/null\n+++ b/src/notifications/index.ts\n@@ -0,0 +1,47 @@\n+import { EventBus } from '../bus.js';\n+import { Events, type NotificationService, type OrderCreatedEvent, type OrderStatusChangedEvent, type PaymentProcessedEvent } from '../types.js';\n+\n+export function createNotificationService(bus: EventBus): NotificationService {\n+  const subscribers = new Set<string>();\n+  const userNotifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();\n+  const orderToUser = new Map<string, string>();\n+\n+  function addNotification(userId: string, type: string, message: string): void {\n+    if (!subscribers.has(userId)) return;\n+    if (!userNotifications.has(userId)) {\n+      userNotifications.set(userId, []);\n+    }\n+    userNotifications.get(userId)!.push({ type, message, timestamp: Date.now() });\n+  }\n+\n+  bus.on(Events.ORDER_CREATED, (payload) => {\n+    const event = payload as OrderCreatedEvent;\n+    orderToUser.set(event.orderId, event.userId);\n+  });\n+\n+  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {\n+    const event = payload as OrderStatusChangedEvent;\n+    const userId = orderToUser.get(event.orderId);\n+    if (userId) {\n+      addNotification(userId, 'order_status_changed', `Order ${event.orderId} status changed to ${event.status}`);\n+    }\n+  });\n+\n+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {\n+    const event = payload as PaymentProcessedEvent;\n+    const userId = orderToUser.get(event.orderId);\n+    if (userId) {\n+      addNotification(userId, 'payment_processed', `Payment for order ${event.orderId}: ${event.status}`);\n+    }\n+  });\n+\n+  return {\n+    subscribe(userId: string): void {\n+      subscribers.add(userId);\n+    },\n+\n+    getNotifications(userId: string) {\n+      return userNotifications.get(userId) ?? [];\n+    },\n+  };\n+}\ndiff --git a/src/notifications/notifications.test.ts b/src/notifications/notifications.test.ts\nnew file mode 100644\nindex 0000000..e3f9361\n--- /dev/null\n+++ b/src/notifications/notifications.test.ts\n@@ -0,0 +1,63 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events, OrderStatus, PaymentStatus } from '../types.js';\n+import { createNotificationService } from './index.js';\n+\n+describe('NotificationService', () => {\n+  let bus: EventBus;\n+  let notifications: ReturnType<typeof createNotificationService>;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+    notifications = createNotificationService(bus);\n+  });\n+\n+  test('getNotifications returns empty array for unknown user', () => {\n+    expect(notifications.getNotifications('unknown')).toEqual([]);\n+  });\n+\n+  test('subscribe registers a user', () => {\n+    notifications.subscribe('user1');\n+    expect(notifications.getNotifications('user1')).toEqual([]);\n+  });\n+\n+  test('records notification on ORDER_CREATED then ORDER_STATUS_CHANGED for subscribed user', async () => {\n+    notifications.subscribe('user1');\n+    // Emit order created to register the mapping\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n+    // Emit status change\n+    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n+    const notifs = notifications.getNotifications('user1');\n+    expect(notifs.length).toBeGreaterThanOrEqual(1);\n+    // Should have notification about order status change\n+    const statusNotif = notifs.find(n => n.type === 'order_status_changed');\n+    expect(statusNotif).toBeTruthy();\n+    expect(statusNotif!.message).toContain('o1');\n+  });\n+\n+  test('records notification on PAYMENT_PROCESSED for subscribed user', async () => {\n+    notifications.subscribe('user1');\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'txn1' });\n+    const notifs = notifications.getNotifications('user1');\n+    const paymentNotif = notifs.find(n => n.type === 'payment_processed');\n+    expect(paymentNotif).toBeTruthy();\n+    expect(paymentNotif!.message).toContain('o1');\n+  });\n+\n+  test('does not record notifications for unsubscribed users', async () => {\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n+    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.SHIPPED, previousStatus: OrderStatus.CONFIRMED });\n+    const notifs = notifications.getNotifications('user1');\n+    expect(notifs).toEqual([]);\n+  });\n+\n+  test('notifications have timestamps', async () => {\n+    notifications.subscribe('user1');\n+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u