interface PaymentOptions {\n+  simulateFailure?: boolean;\n+  simulateTimeout?: boolean;\n+}\n+\n+export function createPaymentService(bus: EventBus, options?: PaymentOptions): PaymentService {\n+  const transactions = new Map<string, { orderId: string; amount: number; status: PaymentStatus }>();\n+  let counter = 0;\n+\n+  return {\n+    async processPayment(orderId: string, amount: number) {\n+      let status: PaymentStatus;\n+      let transactionId: string | undefined;\n+      let error: string | undefined;\n+\n+      if (options?.simulateTimeout) {\n+        status = PaymentStatus.TIMEOUT;\n+        error = 'Payment timed out';\n+      } else if (options?.simulateFailure) {\n+        status = PaymentStatus.FAILED;\n+        error = 'Payment failed';\n+      } else {\n+        status = PaymentStatus.SUCCESS;\n+        transactionId = `txn_${++counter}`;\n+        transactions.set(transactionId, { orderId, amount, status });\n+      }\n+\n+      const event: PaymentProcessedEvent = { orderId, status, transactionId, error };\n+      await bus.emit(Events.PAYMENT_PROCESSED, event);\n+\n+      return { status, transactionId, error };\n+    },\n+\n+    async refund(transactionId: string): Promise<boolean> {\n+      const txn = transactions.get(transactionId);\n+      if (!txn || txn.status !== PaymentStatus.SUCCESS) return false;\n+      txn.status = PaymentStatus.FAILED;\n+      return true;\n+    },\n+  };\n+}\ndiff --git a/src/payment/payment.test.ts b/src/payment/payment.test.ts\nnew file mode 100644\nindex 0000000..c03524f\n--- /dev/null\n+++ b/src/payment/payment.test.ts\n@@ -0,0 +1,65 @@\n+import { describe, test, expect, beforeEach } from 'vitest';\n+import { EventBus } from '../bus.js';\n+import { Events, PaymentStatus, type PaymentProcessedEvent } from '../types.js';\n+import { createPaymentService } from './index.js';\n+\n+describe('PaymentService', () => {\n+  let bus: EventBus;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+  });\n+\n+  test('processPayment succeeds by default', async () => {\n+    const payment = createPaymentService(bus);\n+    const result = await payment.processPayment('order1', 100);\n+    expect(result.status).toBe(PaymentStatus.SUCCESS);\n+    expect(result.transactionId).toBeTruthy();\n+  });\n+\n+  test('processPayment can simulate failure', async () => {\n+    const payment = createPaymentService(bus, { simulateFailure: true });\n+    const result = await payment.processPayment('order1', 100);\n+    expect(result.status).toBe(PaymentStatus.FAILED);\n+    expect(result.error).toBeTruthy();\n+  });\n+\n+  test('processPayment can simulate timeout', async () => {\n+    const payment = createPaymentService(bus, { simulateTimeout: true });\n+    const result = await payment.processPayment('order1', 100);\n+    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n+    expect(result.error).toBeTruthy();\n+  });\n+\n+  test('processPayment emits PAYMENT_PROCESSED event', async () => {\n+    const events: PaymentProcessedEvent[] = [];\n+    bus.on(Events.PAYMENT_PROCESSED, (payload) => { events.push(payload as PaymentProcessedEvent); });\n+    const payment = createPaymentService(bus);\n+    const result = await payment.processPayment('order1', 50);\n+    expect(events).toHaveLength(1);\n+    expect(events[0].orderId).toBe('order1');\n+    expect(events[0].status).toBe(PaymentStatus.SUCCESS);\n+    expect(events[0].transactionId).toBe(result.transactionId);\n+  });\n+\n+  test('refund returns true for successful transaction', async () => {\n+    const payment = createPaymentService(bus);\n+    const result = await payment.processPayment('order1', 100);\n+    const refunded = await payment.refund(result.transactionId!);\n+    expect(refunded).toBe(true);\n+  });\n+\n+  test('refund returns false for unknown transaction', async () => {\n+    const payment = createPaymentService(bus);\n+    const refunded = await payment.refund('nonexistent');\n+    expect(refunded).toBe(false);\n+  });\n+\n+  test('refund returns false for failed transaction', async () => {\n+    const payment = createPaymentService(bus, { simulateFailure: true });\n+    await payment.processPayment('order1', 100);\n+    // Failed transactions have no transactionId, so refund with arbitrary id\n+    const refunded = await payment.refund('arbitrary');\n+    expect(refunded).toBe(false);\n+  });\n+});\ndiff --git a/src/pricing/index.ts b/src/pricing/index.ts\nnew file mode 100644\nindex 0000000..6e85a2f\n--- /dev/null\n+++ b/src/pricing/index.ts\n@@ -0,0 +1,42 @@\n+import { EventBus } from '../bus.js';\n+import { Events, type PricingService, type ProductCreatedEvent } from '../types.js';\n+\n+const TAX_RATE = 0.1;\n+\n+export function createPricingService(bus: EventBus): PricingService {\n+  const prices = new Map<string, number>();\n+  const discountCodes = new Map<string, number>();\n+\n+  bus.on(Events.PRODUCT_CREATED, (payload) => {\n+    const event = payload as ProductCreatedEvent;\n+    prices.set(event.productId, event.price);\n+  });\n+\n+  return {\n+    calculateTotal(items: Array<{ productId: string; quantity: number; price: number }>, discountCode?: string) {\n+      const subtotal = items.reduce((sum, item) => sum + item.price * item.quantity, 0);\n+\n+      let discountAmount = 0;\n+      if (discountCode) {\n+        const percentage = discountCodes.get(discountCode);\n+        if (percentage !== undefined) {\n+          discountAmount = subtotal * (percentage / 100);\n+        }\n+      }\n+\n+      const taxable = subtotal - discountAmount;\n+      const tax = taxable * TAX_RATE;\n+      const total = taxable + tax;\n+\n+      return { subtotal, discount: discountAmount, tax, total };\n+    },\n+\n+    addDiscountCode(code: string, percentage: number): void {\n+      discountCodes.set(code, percentage);\n+    },\n+\n+    getPrice(productId: string): number {\n+      return prices.get(productId) ?? 0;\n+    },\n+  };\n+}\ndiff --git a/src/pricing/pricing.test.ts b/src/p