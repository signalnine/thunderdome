+  test('processPayment can simulate failure', async () => {
+    const payment = createPaymentService(bus, { simulateFailure: true });
+    const result = await payment.processPayment('order1', 100);
+    expect(result.status).toBe(PaymentStatus.FAILED);
+    expect(result.error).toBeTruthy();
+  });
+
+  test('processPayment can simulate timeout', async () => {
+    const payment = createPaymentService(bus, { simulateTimeout: true });
+    const result = await payment.processPayment('order1', 100);
+    expect(result.status).toBe(PaymentStatus.TIMEOUT);
+    expect(result.error).toBeTruthy();
+  });
+
+  test('processPayment emits PAYMENT_PROCESSED event', async () => {
+    const events: PaymentProcessedEvent[] = [];
+    bus.on(Events.PAYMENT_PROCESSED, (payload) => { events.push(payload as PaymentProcessedEvent); });
+    const payment = createPaymentService(bus);
+    const result = await payment.processPayment('order1', 50);
+    expect(events).toHaveLength(1);
+    expect(events[0].orderId).toBe('order1');
+    expect(events[0].status).toBe(PaymentStatus.SUCCESS);
+    expect(events[0].transactionId).toBe(result.transactionId);
+  });
+
+  test('refund returns true for successful transaction', async () => {
+    const payment = createPaymentService(bus);
+    const result = await payment.processPayment('order1', 100);
+    const refunded = await payment.refund(result.transactionId!);
