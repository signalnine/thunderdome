, total: 50 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o2', status: PaymentStatus.SUCCESS, transactionId: 'txn2' });\n    expect(analytics.getRevenue()).toBe(150);\n  });\n\n  test('getRevenue ignores failed payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'failed' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  test('getConversionRate returns 0 when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  test('getConversionRate calculates orders / unique carts', async () => {\n    // 2 unique carts created\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 1 }] });\n    // 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBeCloseTo(0.5);\n  });\n\n  test('getConversionRate counts unique carts not total cart events', async () => {\n    // Same cart updated multiple times\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 unique cart\n  });\n\n  test('getTopProducts returns empty array initially', () => {\n    expect(analytics.getTopProducts(5)).toEqual([]);\n  });\n\n  test('getTopProducts ranks products by order quantity', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 3 }, { productId: 'p2', quantity: 1 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 50 });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 5 }] });\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p2'); // 1 + 5 = 6\n    expect(top[0].count).toBe(6);\n    expect(top[1].productId).toBe('p1'); // 3\n    expect(top[1].count).toBe(3);\n  });\n\n  test('getTopProducts respects limit', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }, { productId: 'p2', quantity: 2 }, { productId: 'p3', quantity: 3 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 10 });\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":6,"lines":[" import { describe, test, expect, beforeEach } from 'vitest';"," import { EventBus } from '../bus.js';","-import { Events, OrderStatus, PaymentStatus } from '../types.js';","+import { Events, PaymentStatus } from '../types.js';"," import { createAnalyticsService } from './index.js';"," "," describe('AnalyticsService', () => {"]}],"userModified":false,"replaceAll":false}}
