+import { describe, test, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { Events, type CartUpdatedEvent } from '../types.js';
+import { createCartService } from './index.js';
+
+describe('CartService', () => {
+  let bus: EventBus;
+  let cart: ReturnType<typeof createCartService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    cart = createCartService(bus);
+  });
+
+  test('createCart returns a cart id', () => {
+    const id = cart.createCart('user1');
+    expect(id).toBeTruthy();
+    expect(typeof id).toBe('string');
+  });
+
+  test('getCart returns created cart', () => {
+    const id = cart.createCart('user1');
+    const c = cart.getCart(id);
+    expect(c).toEqual({ id, userId: 'user1', items: [] });
+  });
+
+  test('getCart returns null for unknown id', () => {
+    expect(cart.getCart('nonexistent')).toBeNull();
+  });
+
+  test('addItem adds an item to the cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    const c = cart.getCart(id);
+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 2 }]);
+  });
+
+  test('addItem consolidates same product quantities', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p1', 3);
+    const c = cart.getCart(id);
+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);
+  });
+
+  test('removeItem removes product from cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p2', 1);
+    cart.removeItem(id, 'p1');
+    const c = cart.getCart(id);
+    expect(c!.items).toEqual([{ productId: 'p2', quantity: 1 }]);
+  });
+
+  test('updateQuantity changes item quantity', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.updateQuantity(id, 'p1', 5);
+    const c = cart.getCart(id);
+    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);
+  });
+
+  test('clearCart removes all items', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p2', 1);
+    cart.clearCart(id);
+    const c = cart.getCart(id);
+    expect(c!.items).toEqual([]);
+  });
+
+  test('addItem emits CART_UPDATED event', async () => {
+    const events: CartUpdatedEvent[] = [];
+    bus.on(Events.CART_UPDATED, (payload) => { events.push(payload as CartUpdatedEvent); });
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    await new Promise(r => setTimeout(r, 10));
+    expect(events.length).toBeGreaterThanOrEqual(1);
+    const last = events[events.length - 1];
+    expect(last.cartId).toBe(id);
+    expect(last.userId).toBe('user1');
+    expect(last.items).toEqual([{ productId: 'p1', quantity: 2 }]);
+  });
+});
