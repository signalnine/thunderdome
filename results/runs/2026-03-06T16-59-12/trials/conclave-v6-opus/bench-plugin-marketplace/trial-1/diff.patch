+    marketplace.registry.register(makeManifest({
+      name: 'dep-lib',
+      version: '1.0.0',
+      entryPoint: 'result = 1',
+    }));
+    marketplace.registry.register(makeManifest({
+      name: 'dep-lib',
+      version: '1.2.0',
+      entryPoint: 'result = 1',
+    }));
+
+    const manifest = makeManifest({
+      name: 'my-app',
+      dependencies: { 'dep-lib': '^1.0.0' },
