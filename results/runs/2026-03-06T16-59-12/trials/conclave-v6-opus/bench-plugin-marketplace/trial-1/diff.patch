index 0000000..f7a965e
--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,128 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function getLatestManifest(name: string, registry: RegistryService) {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      throw new Error(`Plugin "${name}" not found in registry`);
+    }
+    return manifest;
+  }
+
+  function buildTreeImpl(name: string, registry: RegistryService, visited: Set<string>): DependencyNode {
+    const manifest = getLatestManifest(name, registry);
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    if (visited.has(name)) {
+      return node;
+    }
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      node.dependencies.push(buildTreeImpl(depName, registry, new Set(visited)));
+    }
+
+    return node;
+  }
+
+  function detectCyclesImpl(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    inStack: Set<string>,
+    visited: Set<string>,
+    cycles: string[][]
+  ): void {
+    if (inStack.has(name)) {
+      const cycleStart = path.indexOf(name);
+      cycles.push([...path.slice(cycleStart), name]);
+      return;
+    }
+    if (visited.has(name)) return;
+
+    visited.add(name);
+    inStack.add(name);
+    path.push(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        detectCyclesImpl(depName, registry, path, inStack, visited, cycles);
+      }
+    }
+
+    path.pop();
+    inStack.delete(name);
+  }
+
+  function topoSortImpl(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        topoSortImpl(depName, registry, visited, result);
+      }
+    }
+
+    result.push(name);
+  }
+
+  function flattenImpl(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: Set<string>
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!visited.has(depName)) {
+        visited.add(depName);
+        result.add(depName);
+        flattenImpl(depName, registry, visited, result);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeImpl(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles: string[][] = [];
+      detectCyclesImpl(name, registry, [], new Set(), new Set(), cycles);
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const result: string[] = [];
+      topoSortImpl(name, registry, new Set(), result);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const result = new Set<string>();
+      flattenImpl(name, registry, new Set(), result);
+      return [...result];
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const cycles: string[][] = [];
+      detectCyclesImpl(name, registry, [], new Set(), new Set(), cycles);
+      return cycles.length > 0;
+    },
+  };
+}
