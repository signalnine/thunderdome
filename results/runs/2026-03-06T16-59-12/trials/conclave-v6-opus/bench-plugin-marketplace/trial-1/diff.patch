@@ -0,0 +1,107 @@
+import { describe, test, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { DepsService, RegistryService, PluginManifest } from '../types.js';
+
+function makeManifest(name: string, version: string, deps: Record<string, string> = {}): PluginManifest {
+  return {
+    name,
+    version,
+    description: `${name} plugin`,
+    author: 'tester',
+    dependencies: deps,
+    entryPoint: 'result = 1',
+    permissions: [],
+  };
+}
+
+describe('DepsService', () => {
+  let deps: DepsService;
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    deps = createDepsService();
+    registry = createRegistry();
+  });
+
+  test('buildTree returns node with no dependencies for leaf plugin', () => {
+    registry.register(makeManifest('leaf', '1.0.0'));
+    const tree = deps.buildTree('leaf', registry);
+    expect(tree.name).toBe('leaf');
+    expect(tree.version).toBe('1.0.0');
+    expect(tree.dependencies).toEqual([]);
+  });
+
+  test('buildTree builds nested dependency tree', () => {
+    registry.register(makeManifest('app', '1.0.0', { lib: '^1.0.0' }));
+    registry.register(makeManifest('lib', '1.2.0', { util: '^2.0.0' }));
+    registry.register(makeManifest('util', '2.1.0'));
+
+    const tree = deps.buildTree('app', registry);
+    expect(tree.name).toBe('app');
+    expect(tree.dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].name).toBe('lib');
+    expect(tree.dependencies[0].dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].dependencies[0].name).toBe('util');
+  });
+
+  test('detectCycles returns null when no cycles', () => {
+    registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', '1.0.0'));
+    expect(deps.detectCycles('a', registry)).toBeNull();
+  });
+
+  test('detectCycles detects direct circular dependency', () => {
+    registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', '1.0.0', { a: '^1.0.0' }));
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles!.length).toBeGreaterThan(0);
+  });
+
+  test('detectCycles detects transitive circular dependency', () => {
+    registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', '1.0.0', { c: '^1.0.0' }));
+    registry.register(makeManifest('c', '1.0.0', { a: '^1.0.0' }));
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles!.length).toBeGreaterThan(0);
+  });
+
+  test('hasCircularDependency returns boolean', () => {
+    registry.register(makeManifest('a', '1.0.0', { b: '^1.0.0' }));
+    registry.register(makeManifest('b', '1.0.0', { a: '^1.0.0' }));
+    expect(deps.hasCircularDependency('a', registry)).toBe(true);
+
+    const registry2 = createRegistry();
+    registry2.register(makeManifest('x', '1.0.0', { y: '^1.0.0' }));
+    registry2.register(makeManifest('y', '1.0.0'));
+    expect(deps.hasCircularDependency('x', registry2)).toBe(false);
+  });
+
+  test('topologicalSort returns valid ordering', () => {
+    registry.register(makeManifest('app', '1.0.0', { lib: '^1.0.0', util: '^1.0.0' }));
+    registry.register(makeManifest('lib', '1.0.0', { util: '^1.0.0' }));
+    registry.register(makeManifest('util', '1.0.0'));
+
+    const order = deps.topologicalSort('app', registry);
+    expect(order.indexOf('util')).toBeLessThan(order.indexOf('lib'));
+    expect(order.indexOf('lib')).toBeLessThan(order.indexOf('app'));
+  });
+
+  test('flattenDependencies returns all transitive dependencies', () => {
+    registry.register(makeManifest('app', '1.0.0', { lib: '^1.0.0' }));
+    registry.register(makeManifest('lib', '1.0.0', { util: '^1.0.0' }));
+    registry.register(makeManifest('util', '1.0.0'));
+
+    const flat = deps.flattenDependencies('app', registry);
+    expect(flat).toContain('lib');
+    expect(flat).toContain('util');
+    expect(flat).not.toContain('app');
+  });
+
+  test('flattenDependencies returns empty for leaf plugin', () => {
+    registry.register(makeManifest('leaf', '1.0.0'));
+    expect(deps.flattenDependencies('leaf', registry)).toEqual([]);
+  });
+});
