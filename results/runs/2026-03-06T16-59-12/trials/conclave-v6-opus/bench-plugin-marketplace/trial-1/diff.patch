+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01JP91rAqhK8rPb8Q135oXQF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Pr7XMgyGzBjWJSNnq5Pbnu","name":"Write","input":{"file_path":"/workspace/src/registry/index.test.ts","content":"import { describe, test, expect, beforeEach } from 'vitest';\nimport { createRegistry } from './index.js';\nimport type { RegistryService, PluginManifest } from '../types.js';\n\nfunction makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {\n  return {\n    name: 'test-plugin',\n    version: '1.0.0',\n    description: 'A test plugin',\n    author: 'tester',\n    dependencies: {},\n    entryPoint: 'console.log(\"hello\")',\n    permissions: [],\n    ...overrides,\n  };\n}\n\ndescribe('Registry', () => {\n  let registry: RegistryService;\n\n  beforeEach(() => {\n    registry = createRegistry();\n  });\n\n  test('register and get a plugin', () => {\n    const manifest = makeManifest();\n    registry.register(manifest);\n    const result = registry.get('test-plugin');\n    expect(result).toEqual(manifest);\n  });\n\n  test('get returns null for unknown plugin', () => {\n    expect(registry.get('nonexistent')).toBeNull();\n  });\n\n  test('register multiple versions and get returns latest', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    registry.register(makeManifest({ version: '1.5.0' }));\n    const result = registry.get('test-plugin');\n    expect(result?.version).toBe('2.0.0');\n  });\n\n  test('getVersion returns specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    const result = registry.getVersion('test-plugin', '1.0.0');\n    expect(result?.version).toBe('1.0.0');\n  });\n\n  test('getVersion returns null for unknown version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();\n  });\n\n  test('list returns all registered manifests', () => {\n    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'a', version: '2.0.0' }));\n    const all = registry.list();\n    expect(all).toHaveLength(3);\n  });\n\n  test('search matches name, description, and author', () => {\n    registry.register(makeManifest({ name: 'auth-plugin', description: 'handles auth', author: 'alice' }));\n    registry.register(makeManifest({ name: 'data-plugin', description: 'data stuff', author: 'bob' }));\n\n    expect(registry.search('auth')).toHaveLength(1);\n    expect(registry.search('data stuff')).toHaveLength(1);\n    expect(registry.search('bob')).toHaveLength(1);\n    expect(registry.search('ALICE')).toHaveLength(1); // case-insensitive\n  });\n\n  test('remove deletes specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    const removed = registry.remove('test-plugin', '1.0.0');\n    expect(removed).toBe(true);\n    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n  });\n\n  test('remove returns false for nonexistent', () => {\n    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n  });\n\n  test('listVersions returns sorted versions', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '3.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    expect(registry.listVersions('test-plugin')).toEqual(['1.0.0', '2.0.0', '3.0.0']);\n  });\n\n  test('listVersions returns empty for unknown plugin', () => {\n    expect(registry.listVersions('nonexistent')).toEqual([]);\n  });\n\n  test('update modifies manifest fields', () => {\n    registry.register(makeManifest({ version: '1.0.0', description: 'old' }));\n    registry.update('test-plugin', '1.0.0', { description: 'new' });\n    const result = registry.getVersion('test-plugin', '1.0.0');\n    expect(result?.description).toBe('new');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":318,"cache_read_input_tokens":29411,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":318},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9f177a7f-57a3-4019-872b-6e8bc7211222","uuid":"9e62e73f-cc81-4a45-b496-1d44354c7144"}
