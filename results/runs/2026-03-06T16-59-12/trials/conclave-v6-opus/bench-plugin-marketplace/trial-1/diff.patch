ryPoint: 'throw new Error(\"init failed\")',\n    });\n\n    const result = await marketplace.installPlugin(manifest);\n    // Plugin still gets registered, but sandbox result shows failure\n    expect(result.sandboxResult.success).toBe(false);\n    expect(result.sandboxResult.error).toContain('init failed');\n  });\n});\n","structuredPatch":[],"originalFile":null}}
