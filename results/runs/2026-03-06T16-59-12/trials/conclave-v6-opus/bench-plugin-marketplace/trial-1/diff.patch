+    const avg = reviews.getAverageRating('foo');
+    expect(avg).toBe(4); // (5+3)/2
+  });
+
+  test('getAverageRating returns 0 for no reviews', () => {
+    expect(reviews.getAverageRating('unknown')).toBe(0);
+  });
+
+  test('flagReview marks a review as flagged', () => {
