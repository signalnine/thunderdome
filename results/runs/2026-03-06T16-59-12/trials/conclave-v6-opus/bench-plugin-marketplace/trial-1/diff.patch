e);\n    expect(result).toEqual([\n      { name: 'foo', version: '1.3.0', satisfies: '^1.0.0' },\n      { name: 'bar', version: '2.1.5', satisfies: '~2.1.0' },\n    ]);\n  });\n\n  test('resolve throws when constraint cannot be satisfied', () => {\n    const constraints: VersionConstraint[] = [\n      { name: 'foo', range: '^5.0.0' },\n    ];\n    const available = {\n      foo: ['1.0.0', '2.0.0'],\n    };\n    expect(() => resolver.resolve(constraints, available)).toThrow();\n  });\n\n  test('resolve throws when plugin not in available', () => {\n    const constraints: VersionConstraint[] = [\n      { name: 'missing', range: '^1.0.0' },\n    ];\n    expect(() => resolver.resolve(constraints, {})).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":333,"cache_read_input_tokens":33987,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":333},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9f177a7f-57a3-4019-872b-6e8bc7211222","uuid":"8579dfb3-6a0f-4881-b622-53418b8623c1"}
