+    expect(result.resolvedDependencies).toEqual([
+      { name: 'dep-lib', version: '1.2.0', satisfies: '^1.0.0' },
+    ]);
+  });
+
+  test('installPlugin rejects circular dependencies', async () => {
+    // Set up a cycle: a -> b -> a
+    marketplace.registry.register(makeManifest({
+      name: 'b',
+      version: '1.0.0',
+      dependencies: { 'a': '^1.0.0' },
+      entryPoint: 'result = 1',
+    }));
+
+    const manifest = makeManifest({
+      name: 'a',
+      version: '1.0.0',
+      dependencies: { 'b': '^1.0.0' },
