+import { describe, test, expect } from 'vitest';
+import { createResolver } from './index.js';
+import type { ResolverService, VersionConstraint } from '../types.js';
+
+describe('Resolver', () => {
+  let resolver: ResolverService;
+
+  beforeEach(() => {
+    resolver = createResolver();
+  });
+
+  test('satisfies returns true for matching version', () => {
+    expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+  });
+
+  test('satisfies returns false for non-matching version', () => {
+    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+  });
+
+  test('maxSatisfying returns highest matching version', () => {
+    const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];
+    expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');
+  });
+
+  test('maxSatisfying returns null when none match', () => {
+    const versions = ['1.0.0', '1.2.0'];
+    expect(resolver.maxSatisfying(versions, '^3.0.0')).toBeNull();
+  });
+
+  test('validRange returns true for valid range', () => {
+    expect(resolver.validRange('^1.0.0')).toBe(true);
+    expect(resolver.validRange('~2.3.0')).toBe(true);
+    expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+  });
+
+  test('validRange returns false for invalid range', () => {
+    expect(resolver.validRange('not-a-range')).toBe(false);
+  });
+
+  test('resolve finds max satisfying for each constraint', () => {
+    const constraints: VersionConstraint[] = [
+      { name: 'foo', range: '^1.0.0' },
+      { name: 'bar', range: '~2.1.0' },
+    ];
+    const available = {
+      foo: ['1.0.0', '1.3.0', '2.0.0'],
+      bar: ['2.1.0', '2.1.5', '2.2.0'],
+    };
+    const result = resolver.resolve(constraints, available);
+    expect(result).toEqual([
+      { name: 'foo', version: '1.3.0', satisfies: '^1.0.0' },
+      { name: 'bar', version: '2.1.5', satisfies: '~2.1.0' },
+    ]);
+  });
+
+  test('resolve throws when constraint cannot be satisfied', () => {
+    const constraints: VersionConstraint[] = [
+      { name: 'foo', range: '^5.0.0' },
+    ];
+    const available = {
+      foo: ['1.0.0', '2.0.0'],
+    };
+    expect(() => resolver.resolve(constraints, available)).toThrow();
+  });
+
+  test('resolve throws when plugin not in available', () => {
+    const constraints: VersionConstraint[] = [
+      { name: 'missing', range: '^1.0.0' },
+    ];
+    expect(() => resolver.resolve(constraints, {})).toThrow();
+  });
+});
