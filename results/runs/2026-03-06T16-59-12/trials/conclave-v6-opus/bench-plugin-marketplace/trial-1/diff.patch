istry: RegistryService,\n    visited: Set<string>,\n    result: string[]\n  ): void {\n    if (visited.has(name)) return;\n    visited.add(name);\n\n    const manifest = registry.get(name);\n    if (manifest) {\n      for (const depName of Object.keys(manifest.dependencies)) {\n        topoSortImpl(depName, registry, visited, result);\n      }\n    }\n\n    result.push(name);\n  }\n\n  function flattenImpl(\n    name: string,\n    registry: RegistryService,\n    visited: Set<string>,\n    result: Set<string>\n  ): void {\n    const manifest = registry.get(name);\n    if (!manifest) return;\n\n    for (const depName of Object.keys(manifest.dependencies)) {\n      if (!visited.has(depName)) {\n        visited.add(depName);\n        result.add(depName);\n        flattenImpl(depName, registry, visited, result);\n      }\n    }\n  }\n\n  return {\n    buildTree(name: string, registry: RegistryService): DependencyNode {\n      return buildTreeImpl(name, registry, new Set());\n    },\n\n    detectCycles(name: string, registry: RegistryService): string[][] | null {\n      const cycles: string[][] = [];\n      detectCyclesImpl(name, registry, [], new Set(), new Set(), cycles);\n      return cycles.length > 0 ? cycles : null;\n    },\n\n    topologicalSort(name: string, registry: RegistryService): string[] {\n      const result: string[] = [];\n      topoSortImpl(name, registry, new Set(), result);\n      return result;\n    },\n\n    flattenDependencies(name: string, registry: RegistryService): string[] {\n      const result = new Set<string>();\n      flattenImpl(name, registry, new Set(), result);\n      return [...result];\n    },\n\n    hasCircularDependency(name: string, registry: RegistryService): boolean {\n      const cycles: string[][] = [];\n      detectCyclesImpl(name, registry, [], new Set(), new Set(), cycles);\n      return cycles.length > 0;\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cac