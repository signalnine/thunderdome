+    const result = await runner.execute('result = 2 + 2');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(4);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+  });
+
+  test('captures error from failing code', async () => {
+    const result = await runner.execute('throw new Error("boom")');
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('boom');
+  });
+
+  test('passes context variables into sandbox', async () => {
+    const result = await runner.execute('result = x + y', { x: 10, y: 20 });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(30);
+  });
+
+  test('executeWithTimeout succeeds for fast code', async () => {
+    const result = await runner.executeWithTimeout('result = 42', 5000);
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(42);
+  });
+
+  test('executeWithTimeout rejects code that exceeds timeout', async () => {
+    const result = await runner.executeWithTimeout('while(true) {}', 50);
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  test('sandbox is isolated from host environment', async () => {
+    const result = await runner.execute('result = typeof require');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('undefined');
+  });
+
+  test('returns duration timing', async () => {
+    const result = await runner.execute('result = 1');
+    expect(typeof result.duration).toBe('number');
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  test('returns memory usage', async () => {
+    const result = await runner.execute('result = 1');
+    expect(typeof result.memoryUsed).toBe('number');
+    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+  });
+
+  test('context variables are available in sandbox', async () => {
