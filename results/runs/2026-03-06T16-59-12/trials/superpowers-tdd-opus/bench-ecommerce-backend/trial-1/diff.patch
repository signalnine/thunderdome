w Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n    expect(events[0]).toEqual({ productId: 'prod_1', quantity: 50 });\n  });\n\n  it('should emit low_stock alert when stock falls below threshold', async () => {\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload); });\n    inventory.setLowStockThreshold('prod_1', 5);\n    inventory.setStock('prod_1', 10);\n    inventory.reserve('prod_1', 7);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts.length).toBeGreaterThanOrEqual(1);\n    const alert = alerts[alerts.length - 1] as LowStockAlertEvent;\n    expect(alert.productId).toBe('prod_1');\n    expect(alert.currentQuantity).toBe(3);\n    expect(alert.threshold).toBe(5);\n  });\n\n  it('should not emit low_stock alert when stock is above threshold', async () => {\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload); });\n    inventory.setLowStockThreshold('prod_1', 5);\n    inventory.setStock('prod_1', 10);\n    inventory.reserve('prod_1', 2);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts).toHaveLength(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":433,"cache_read_input_tokens":31879,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":433},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c94e1797-ac3d-45ac-94e3-a03af9176216","uuid":"c58b4c18-e84b-44c6-9539-61217c6523f0"}
