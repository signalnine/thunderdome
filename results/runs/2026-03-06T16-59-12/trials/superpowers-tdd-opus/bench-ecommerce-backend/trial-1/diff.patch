@@ -0,0 +1,50 @@
+import { EventBus } from '../bus.js';
+import { NotificationService, Events, OrderCreatedEvent, OrderStatusChangedEvent, PaymentProcessedEvent } from '../types.js';
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const subscribed = new Set<string>();
+  const notifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();
+  const orderUserMap = new Map<string, string>();
+
+  function addNotification(userId: string, type: string, message: string) {
+    if (!subscribed.has(userId)) return;
+    if (!notifications.has(userId)) {
+      notifications.set(userId, []);
+    }
+    notifications.get(userId)!.push({ type, message, timestamp: Date.now() });
+  }
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const event = payload as OrderCreatedEvent;
+    orderUserMap.set(event.orderId, event.userId);
+    addNotification(event.userId, 'order_created', `Order ${event.orderId} created with total $${event.total}`);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {
+    const event = payload as OrderStatusChangedEvent;
+    const userId = orderUserMap.get(event.orderId);
+    if (userId) {
+      addNotification(userId, 'order_status_changed', `Order ${event.orderId} status changed from ${event.previousStatus} to ${event.status}`);
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const event = payload as PaymentProcessedEvent;
+    const userId = orderUserMap.get(event.orderId);
+    if (userId) {
+      addNotification(userId, 'payment_processed', `Payment for order ${event.orderId}: ${event.status}`);
+    }
+  });
+
+  return {
+    subscribe(userId: string) {
+      subscribed.add(userId);
+      if (!notifications.has(userId)) {
+        notifications.set(userId, []);
+      }
+    },
+    getNotifications(userId: string) {
+      return notifications.get(userId) ?? [];
+    },
+  };
+}
