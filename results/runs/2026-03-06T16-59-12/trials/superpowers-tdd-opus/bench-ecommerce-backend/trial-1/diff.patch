+import { EventBus } from '../bus.js';
+import { OrderService, OrderStatus, Events, OrderCreatedEvent, OrderStatusChangedEvent } from '../types.js';
+
+export function createOrderService(bus: EventBus): OrderService {
+  const orders = new Map<string, { id: string; userId: string; status: OrderStatus; total: number }>();
+  let counter = 0;
+
+  return {
+    createOrder(userId: string, cartId: string, total: number) {
+      const id = `order_${++counter}`;
+      orders.set(id, { id, userId, status: OrderStatus.PENDING, total });
+      bus.emit(Events.ORDER_CREATED, {
+        orderId: id,
+        userId,
+        cartId,
+        total,
+      } satisfies OrderCreatedEvent);
+      return id;
+    },
+    getOrder(orderId: string) {
+      return orders.get(orderId) ?? null;
+    },
+    updateStatus(orderId: string, status: OrderStatus) {
+      const order = orders.get(orderId);
+      if (!order) return;
+      const previousStatus = order.status;
+      order.status = status;
+      bus.emit(Events.ORDER_STATUS_CHANGED, {
+        orderId,
+        status,
+        previousStatus,
+      } satisfies OrderStatusChangedEvent);
+    },
+    listOrders(userId: string) {
+      return [...orders.values()]
+        .filter(o => o.userId === userId)
+        .map(o => ({ id: o.id, status: o.status, total: o.total }));
+    },
+  };
+}
