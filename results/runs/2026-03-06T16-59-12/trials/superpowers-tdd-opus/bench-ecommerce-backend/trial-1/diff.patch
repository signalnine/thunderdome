: 1 }]);\n  });\n\n  it('should update item quantity', () => {\n    const id = cart.createCart('user_1');\n    cart.addItem(id, 'prod_1', 2);\n    cart.updateQuantity(id, 'prod_1', 7);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'prod_1', quantity: 7 }]);\n  });\n\n  it('should clear all items from cart', () => {\n    const id = cart.createCart('user_1');\n    cart.addItem(id, 'prod_1', 2);\n    cart.addItem(id, 'prod_2', 1);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([]);\n  });\n\n  it('should emit cart:updated event when items change', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.CART_UPDATED, (payload) => { events.push(payload); });\n    const id = cart.createCart('user_1');\n    cart.addItem(id, 'prod_1', 2);\n    await new Promise(r => setTimeout(r, 10));\n    expect(events.length).toBeGreaterThanOrEqual(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":409,"cache_read_input_tokens":34567,"cache_creation":{"ephemeral_5m_input_tokens":409,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c94e1797-ac3d-45ac-94e3-a03af9176216","uuid":"c1ce2854-ab00-4678-86ea-cd2cda345a1d"}
