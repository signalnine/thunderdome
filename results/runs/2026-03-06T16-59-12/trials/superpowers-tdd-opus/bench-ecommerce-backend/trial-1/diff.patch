)).toBe(100);\n  });\n\n  it('should not count revenue from failed payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order_1',\n      userId: 'user_1',\n      cartId: 'cart_1',\n      total: 100,\n    });\n    await bus.emit(Events.PAYMENT_PROCESSED, {\n      orderId: 'order_1',\n      status: PaymentStatus.FAILED,\n      error: 'declined',\n    });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate (orders / unique carts)', async () => {\n    // Create 2 carts\n    await bus.emit(Events.CART_UPDATED, { cartId: 'cart_1', userId: 'user_1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'cart_2', userId: 'user_2', items: [] });\n    // Create 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'order_1', userId: 'user_1', cartId: 'cart_1', total: 50 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank products by order quantity', async () => {\n    // We need to track which products are in orders.\n    // Analytics listens to ORDER_CREATED which includes cartId.\n    // It also listens to CART_UPDATED which has item details.\n    // So we emit cart updates first, then order creation.\n    await bus.emit(Events.CART_UPDATED, {\n      cartId: 'cart_1',\n      userId: 'user_1',\n      items: [{ productId: 'prod_1', quantity: 3 }, { productId: 'prod_2', quantity: 1 }],\n    });\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order_1',\n      userId: 'user_1',\n      cartId: 'cart_1',\n      total: 50,\n    });\n    await bus.emit(Events.CART_UPDATED, {\n      cartId: 'cart_2',\n      userId: 'user_2',\n      items: [{ productId: 'prod_2', quantity: 5 }],\n    });\n    await bus.emit(Events.ORDER_CREATED, {\n      orderId: 'order_2',\n      userId: 'user_2',\n      cartId: 'cart_2',\n      total: 75,\n    });\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    // prod_2 = 1 + 5 = 6, prod_1 = 3\n    expect(top[0]).toEqual({ productId: 'prod_2', count: 6 });\n    expect(top[1]).toEqual({ productId: 'prod_1', count: 3 });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":403,"cache_read_input_tokens":47307,"cache_creation":{"ephemeral_5m_input_tokens":403,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c94e1797-ac3d-45ac-94e3-a03af9176216","uuid":"2daa61c1-62eb-403e-8850-eb2c9b9dedb6"}
