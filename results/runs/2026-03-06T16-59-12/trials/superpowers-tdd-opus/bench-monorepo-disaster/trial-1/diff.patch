expect(canDelete('user')).toBe(false);\n    48→  });\n    49→\n    50→  it('requirePermission throws when permission is missing', () => {\n    51→    expect(() => requirePermission('viewer', 'write')).toThrow(\n    52→      \"Role 'viewer' does not have permission 'write'\"\n    53→    );\n    54→  });\n    55→});\n    56→"}]},"parent_tool_use_id":"toolu_01TPQ7difFuj129nqTzXzyej","session_id":"ba73e450-89fb-49bc-b597-3513428b0bcd","uuid":"9dd78dbd-4b66-40f8-b567-30f544bb8fd5"}
