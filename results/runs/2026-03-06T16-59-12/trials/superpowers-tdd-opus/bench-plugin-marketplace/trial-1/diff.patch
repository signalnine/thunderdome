+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from '../src/index.js';
+
+describe('createMarketplace', () => {
+  let marketplace: ReturnType<typeof createMarketplace>;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should expose all service modules', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  it('should install a plugin with no dependencies', async () => {
+    const result = await marketplace.installPlugin({
+      name: 'simple-plugin',
+      version: '1.0.0',
+      description: 'A simple plugin',
+      author: 'test',
+      dependencies: {},
+      entryPoint: '2 + 2',
+      permissions: [],
+    });
+
+    expect(result.resolvedVersions).toEqual([]);
+    expect(result.sandboxResult.success).toBe(true);
+    expect(result.sandboxResult.output).toBe(4);
+
+    // Plugin should be registered
+    const plugin = marketplace.registry.get('simple-plugin');
+    expect(plugin).not.toBeNull();
+  });
+
+  it('should install a plugin and resolve its dependencies', async () => {
+    // Register the dependency first
+    marketplace.registry.register({
+      name: 'dep-lib',
+      version: '1.0.0',
+      description: 'A dependency',
+      author: 'test',
+      dependencies: {},
+      entryPoint: '"dep loaded"',
+      permissions: [],
+    });
+    marketplace.registry.register({
+      name: 'dep-lib',
+      version: '1.1.0',
+      description: 'A dependency',
+      author: 'test',
+      dependencies: {},
+      entryPoint: '"dep loaded"',
+      permissions: [],
+    });
+
+    const result = await marketplace.installPlugin({
+      name: 'my-plugin',
+      version: '1.0.0',
+      description: 'Uses a dep',
+      author: 'test',
+      dependencies: { 'dep-lib': '^1.0.0' },
+      entryPoint: '"installed"',
+      permissions: [],
+    });
+
+    expect(result.resolvedVersions).toHaveLength(1);
+    expect(result.resolvedVersions[0].name).toBe('dep-lib');
+    expect(result.resolvedVersions[0].version).toBe('1.1.0');
+    expect(result.sandboxResult.success).toBe(true);
+  });
+
+  it('should reject plugin with missing name', async () => {
+    await expect(marketplace.installPlugin({
+      name: '',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: {},
+      entryPoint: 'true',
+      permissions: [],
+    })).rejects.toThrow();
+  });
+
+  it('should reject plugin with missing version', async () => {
+    await expect(marketplace.installPlugin({
+      name: 'test',
+      version: '',
+      description: '',
+      author: '',
+      dependencies: {},
+      entryPoint: 'true',
+      permissions: [],
+    })).rejects.toThrow();
+  });
+
+  it('should reject plugin with missing entryPoint', async () => {
+    await expect(marketplace.installPlugin({
+      name: 'test',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: {},
+      entryPoint: '',
+      permissions: [],
+    })).rejects.toThrow();
+  });
+
+  it('should reject plugin with circular dependencies', async () => {
+    // Create a circular dependency: A -> B -> A
+    marketplace.registry.register({
+      name: 'A',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: { B: '^1.0.0' },
+      entryPoint: '',
+      permissions: [],
+    });
+    marketplace.registry.register({
+      name: 'B',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: { 'circ-plugin': '^1.0.0' },
+      entryPoint: '',
+      permissions: [],
+    });
+
+    await expect(marketplace.installPlugin({
+      name: 'circ-plugin',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: { A: '^1.0.0' },
+      entryPoint: '"hello"',
+      permissions: [],
+    })).rejects.toThrow(/circular/i);
+  });
+});
