+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authenticate } from './middleware';
+
+export function createQueriesRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.post('/count', authenticate, (req: Request, res: Response) => {
+    const { eventName } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      query += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    const result = db.prepare(query).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  router.post('/timeseries', authenticate, (req: Request, res: Response) => {
+    const { eventName, startDate, endDate } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let query = `
+      SELECT date(timestamp) as date, COUNT(*) as count
+      FROM events
+      WHERE tenant_id = ?
+    `;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      query += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      query += ' AND date(timestamp) >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      query += ' AND date(timestamp) <= ?';
+      params.push(endDate);
+    }
+
+    query += ' GROUP BY date(timestamp) ORDER BY date(timestamp)';
+
+    const results = db.prepare(query).all(...params) as Array<{ date: string; count: number }>;
+    res.json({ data: results });
+  });
+
+  router.post('/breakdown', authenticate, (req: Request, res: Response) => {
+    const { eventName, property } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: 'property is required' });
+      return;
+    }
+
+    let query = `
+      SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count
+      FROM events
+      WHERE tenant_id = ?
+    `;
+    const params: unknown[] = [property, tenantId];
+
+    if (eventName) {
+      query += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    query += ' GROUP BY value ORDER BY count DESC';
+
+    const results = db.prepare(query).all(...params) as Array<{ value: string; count: number }>;
+    res.json({ data: results });
+  });
+
+  return router;
+}
