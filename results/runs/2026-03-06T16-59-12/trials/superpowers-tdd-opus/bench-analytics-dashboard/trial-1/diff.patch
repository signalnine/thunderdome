db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string }>) => {\n      for (const evt of evts) {\n        const id = uuidv4();\n        const eventTimestamp = evt.timestamp || new Date().toISOString();\n        const eventProperties = JSON.stringify(evt.properties || {});\n        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId);\n      }\n    });\n\n    insertMany(events);\n\n    res.status(201).json({ inserted: events.length });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
