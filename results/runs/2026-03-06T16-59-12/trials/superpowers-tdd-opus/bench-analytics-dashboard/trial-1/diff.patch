@@ -0,0 +1,75 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/app';
+import type { Express } from 'express';
+
+describe('Role Management', () => {
+  let app: Express;
+  let adminToken: string;
+  let viewerToken: string;
+  let viewerUserId: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+
+    // Register admin (first user gets admin role via special param)
+    const adminRes = await request(app)
+      .post('/auth/register')
+      .send({
+        email: 'admin@example.com',
+        password: 'password123',
+        tenantId: 'tenant-1',
+        role: 'admin',
+      });
+    adminToken = adminRes.body.token;
+
+    // Register viewer in same tenant
+    const viewerRes = await request(app)
+      .post('/auth/register')
+      .send({
+        email: 'viewer@example.com',
+        password: 'password123',
+        tenantId: 'tenant-1',
+      });
+    viewerToken = viewerRes.body.token;
+    viewerUserId = viewerRes.body.user.id;
+  });
+
+  it('should allow admin to change user role within same tenant', async () => {
+    const res = await request(app)
+      .put(`/auth/users/${viewerUserId}/role`)
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send({ role: 'editor' });
+
+    expect(res.status).toBe(200);
+    expect(res.body.role).toBe('editor');
+  });
+
+  it('should reject role change from non-admin', async () => {
+    const res = await request(app)
+      .put(`/auth/users/${viewerUserId}/role`)
+      .set('Authorization', `Bearer ${viewerToken}`)
+      .send({ role: 'editor' });
+
+    expect(res.status).toBe(403);
+  });
+
+  it('should reject role change for user in different tenant', async () => {
+    // Register user in different tenant
+    const otherRes = await request(app)
+      .post('/auth/register')
+      .send({
+        email: 'other@example.com',
+        password: 'password123',
+        tenantId: 'tenant-2',
+      });
+    const otherUserId = otherRes.body.user.id;
+
+    const res = await request(app)
+      .put(`/auth/users/${otherUserId}/role`)
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send({ role: 'editor' });
+
+    expect(res.status).toBe(403);
+  });
+});
