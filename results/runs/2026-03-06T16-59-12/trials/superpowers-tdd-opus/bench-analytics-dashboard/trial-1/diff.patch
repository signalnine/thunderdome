+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { authenticate } from './middleware';
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export function createDashboardsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authenticate);
+
+  router.post('/', (req: Request, res: Response) => {
+    const { name, config } = req.body;
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+
+    if (!name) {
+      res.status(400).json({ error: 'name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const configStr = JSON.stringify(config || {});
+    const now = new Date().toISOString();
+
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, ownerId, configStr, now, now);
+
+    res.status(201).json({
+      id,
+      name,
+      tenantId,
+      ownerId,
+      config: config || {},
+      createdAt: now,
+      updatedAt: now,
+    });
+  });
+
+  router.get('/', (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(tenantId) as DashboardRow[];
+
+    res.json(dashboards.map(d => ({
+      id: d.id,
+      name: d.name,
+      tenantId: d.tenant_id,
+      ownerId: d.owner_id,
+      config: JSON.parse(d.config),
+      createdAt: d.created_at,
+      updatedAt: d.updated_at,
+    })));
+  });
+
+  router.get('/:id', (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    res.json({
+      id: dashboard.id,
+      name: dashboard.name,
+      tenantId: dashboard.tenant_id,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+    });
+  });
+
+  router.put('/:id', (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const { name, config } = req.body;
+
+    const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?')
+      .run(updatedName, updatedConfig, now, req.params.id);
+
+    res.json({
+      id: existing.id,
+      name: updatedName,
+      tenantId: existing.tenant_id,
+      ownerId: existing.owner_id,
+      config: JSON.parse(updatedConfig),
+      createdAt: existing.created_at,
+      updatedAt: now,
+    });
+  });
+
+  router.delete('/:id', (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const existing = db.prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId);
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);
+    res.status(204).send();
+  });
+
+  return router;
+}
