@@ -0,0 +1,66 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { authenticate } from './middleware';
+
+export function createEventsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.post('/', authenticate, (req: Request, res: Response) => {
+    const { name, properties, timestamp } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Event name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = JSON.stringify(properties || {});
+
+    db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId);
+
+    res.status(201).json({
+      id,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+      tenantId,
+    });
+  });
+
+  router.post('/batch', authenticate, (req: Request, res: Response) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events)) {
+      res.status(400).json({ error: 'events array is required' });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    const insert = db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+    );
+
+    const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string }>) => {
+      for (const evt of evts) {
+        const id = uuidv4();
+        const eventTimestamp = evt.timestamp || new Date().toISOString();
+        const eventProperties = JSON.stringify(evt.properties || {});
+        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId);
+      }
+    });
+
+    insertMany(events);
+
+    res.status(201).json({ inserted: events.length });
+  });
+
+  return router;
+}
