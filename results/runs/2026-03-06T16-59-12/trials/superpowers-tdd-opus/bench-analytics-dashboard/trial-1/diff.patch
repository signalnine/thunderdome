t(req.params.id, tenantId);\n\n    if (!existing) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);\n    res.status(204).send();\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
