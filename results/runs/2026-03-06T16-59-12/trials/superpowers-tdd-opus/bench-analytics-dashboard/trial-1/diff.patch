 different tenant', async () => {\n    // Register user in different tenant\n    const otherRes = await request(app)\n      .post('/auth/register')\n      .send({\n        email: 'other@example.com',\n        password: 'password123',\n        tenantId: 'tenant-2',\n      });\n    const otherUserId = otherRes.body.user.id;\n\n    const res = await request(app)\n      .put(`/auth/users/${otherUserId}/role`)\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ role: 'editor' });\n\n    expect(res.status).toBe(403);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":465,"cache_read_input_tokens":40682,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":465},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"48707116-463f-4dbd-b959-5ece40f16f30","uuid":"402495a3-3c1d-4f43-b4ec-377b3a55f41b"}
