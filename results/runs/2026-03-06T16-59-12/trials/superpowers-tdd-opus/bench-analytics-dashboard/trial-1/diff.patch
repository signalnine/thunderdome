@@ -0,0 +1,110 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authenticate } from './middleware';
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ['id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+  const rows = events.map(e =>
+    [e.id, e.name, e.properties, e.timestamp, e.user_id || '', e.session_id || '']
+      .map(v => `"${String(v).replace(/"/g, '""')}"`)
+      .join(',')
+  );
+  return [headers.join(','), ...rows].join('\n');
+}
+
+function dashboardToCsv(dashboard: DashboardRow): string {
+  const headers = ['id', 'name', 'config', 'created_at', 'updated_at'];
+  const row = [dashboard.id, dashboard.name, dashboard.config, dashboard.created_at, dashboard.updated_at]
+    .map(v => `"${String(v).replace(/"/g, '""')}"`)
+    .join(',');
+  return [headers.join(','), row].join('\n');
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authenticate);
+
+  router.get('/events/json', (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const events = db.prepare('SELECT * FROM events WHERE tenant_id = ?').all(tenantId) as EventRow[];
+
+    const mapped = events.map(e => ({
+      id: e.id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.json(mapped);
+  });
+
+  router.get('/events/csv', (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const events = db.prepare('SELECT * FROM events WHERE tenant_id = ?').all(tenantId) as EventRow[];
+
+    const csv = eventsToCsv(events);
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(csv);
+  });
+
+  router.get('/dashboards/:id/json', (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    res.json({
+      id: dashboard.id,
+      name: dashboard.name,
+      tenantId: dashboard.tenant_id,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+    });
+  });
+
+  router.get('/dashboards/:id/csv', (req: Request, res: Response) => {
+    const tenantId = req.user!.tenantId;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const csv = dashboardToCsv(dashboard);
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.csv"`);
+    res.send(csv);
+  });
+
+  return router;
+}
