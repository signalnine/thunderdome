--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,21 @@
+import express from 'express';
+import { createDatabase } from './database';
+import { createAuthRouter } from './auth';
+import { createEventsRouter } from './events';
+import { createQueriesRouter } from './queries';
+import { createDashboardsRouter } from './dashboards';
+import { createExportRouter } from './export';
+
+export function createApp(dbPath?: string) {
+  const db = createDatabase(dbPath || ':memory:');
+  const app = express();
+  app.use(express.json());
+
+  app.use('/auth', createAuthRouter(db));
+  app.use('/events', createEventsRouter(db));
+  app.use('/queries', createQueriesRouter(db));
+  app.use('/dashboards', createDashboardsRouter(db));
+  app.use('/export', createExportRouter(db));
+
+  return app;
+}
diff --git a/src/auth.ts b/src/auth.ts
new file mode 100644
index 0000000..864c4f7
--- /dev/null
+++ b/src/auth.ts
@@ -0,0 +1,122 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import jwt from 'jsonwebtoken';
+import { createHash } from 'crypto';
+import { authenticate } from './middleware';
+
+const JWT_SECRET = process.env.JWT_SECRET || 'analytics-dashboard-secret';
+
+function hashPassword(password: string): string {
+  return createHash('sha256').update(password).digest('hex');
+}
+
+function generateToken(userId: string, tenantId: string, role: string): string {
+  return jwt.sign({ userId, tenantId, role }, JWT_SECRET, { expiresIn: '24h' });
+}
+
+export function createAuthRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.post('/register', (req: Request, res: Response) => {
+    const { email, password, tenantId } = req.body;
+
+    if (!email || !password || !tenantId) {
+      res.status(400).json({ error: 'email, password, and tenantId are required' });
+      return;
+    }
+
+    const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);
+    if (existing) {
+      res.status(409).json({ error: 'Email already registered' });
+      return;
+    }
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+    const validRoles = ['admin', 'editor', 'viewer'];
+    const role = req.body.role && validRoles.includes(req.body.role) ? req.body.role as string : 'viewer';
+
+    db.prepare(
+      'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'
+    ).run(id, email, passwordHash, tenantId, role);
+
+    const token = generateToken(id, tenantId, role);
+
+    res.status(201).json({
+      token,
+      user: { id, email, tenantId, role },
+    });
+  });
+
+  router.post('/login', (req: Request, res: Response) => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: 'email and password are required' });
+      return;
+    }
+
+    const user = db.prepare('SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?').get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;
+
+    if (!user || user.password_hash !== hashPassword(password)) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = generateToken(user.id, user.tenant_id, user.role);
+
+    res.json({
+      token,
+      user: { id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role },
+    });
+  });
+
+  router.get('/profile', authenticate, (req: Request, res: Response) => {
+    const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      createdAt: user.created_at,
+    });
+  });
+
+  router.put('/users/:userId/role', authenticate, (req: Request, res: Response) => {
+    const { role } = req.body;
+    const targetUserId = req.params.userId;
+
+    if (req.user!.role !== 'admin') {
+      res.status(403).json({ error: 'Only admins can change roles' });
+      return;
+    }
+
+    const validRoles = ['admin', 'editor', 'viewer'];
+    if (!role || !validRoles.includes(role)) {
+      res.status(400).json({ error: 'Invalid role' });
+      return;
+    }
+
+    const targetUser = db.prepare('SELECT id, tenant_id FROM users WHERE id = ?').get(targetUserId) as { id: string; tenant_id: string } | undefined;
+
+    if (!targetUser || targetUser.tenant_id !== req.user!.tenantId) {
+      res.status(403).json({ error: 'Cannot change role for user outside your tenant' });
+      return;
+    }
+
+    db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, targetUserId);
+
+    res.json({ id: targetUserId, role });
+  });
+
+  return router;
+}
+
+export { JWT_SECRET, hashPassword, generateToken };
