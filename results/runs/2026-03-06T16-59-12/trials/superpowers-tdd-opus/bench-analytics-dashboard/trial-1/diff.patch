+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/app';
+import type { Express } from 'express';
+
+describe('Data Export', () => {
+  let app: Express;
+  let token: string;
+  let otherToken: string;
+  let dashboardId: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+
+    const res = await request(app)
+      .post('/auth/register')
+      .send({
+        email: 'test@example.com',
+        password: 'password123',
+        tenantId: 'tenant-1',
+      });
+    token = res.body.token;
+
+    const otherRes = await request(app)
+      .post('/auth/register')
+      .send({
+        email: 'other@example.com',
+        password: 'password123',
+        tenantId: 'tenant-2',
+      });
+    otherToken = otherRes.body.token;
+
+    // Ingest events for tenant-1
+    await request(app)
+      .post('/events/batch')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        events: [
+          { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-15T10:00:00Z' },
+          { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-15T11:00:00Z' },
+          { name: 'click', properties: { button: 'signup' }, timestamp: '2024-01-15T12:00:00Z' },
+        ],
+      });
+
+    // Ingest event for tenant-2
+    await request(app)
+      .post('/events/batch')
+      .set('Authorization', `Bearer ${otherToken}`)
+      .send({
+        events: [
+          { name: 'page_view', properties: { url: '/other' }, timestamp: '2024-01-15T10:00:00Z' },
+        ],
+      });
+
+    // Create dashboard for tenant-1
+    const dashRes = await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard', config: { widgets: [] } });
+    dashboardId = dashRes.body.id;
+  });
+
+  it('should export events as JSON', async () => {
+    const res = await request(app)
+      .get('/export/events/json')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.headers['content-type']).toMatch(/json/);
+    expect(res.body.length).toBe(3);
+  });
+
+  it('should export events as CSV', async () => {
+    const res = await request(app)
+      .get('/export/events/csv')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.headers['content-type']).toMatch(/csv/);
+    const lines = res.text.trim().split('\n');
+    // Header + 3 data rows
+    expect(lines.length).toBe(4);
+  });
+
+  it('should respect tenant isolation in exports', async () => {
+    const res = await request(app)
+      .get('/export/events/json')
+      .set('Authorization', `Bearer ${otherToken}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.length).toBe(1);
+  });
+
+  it('should export dashboard data as JSON', async () => {
+    const res = await request(app)
+      .get(`/export/dashboards/${dashboardId}/json`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('My Dashboard');
+  });
+
+  it('should export dashboard data as CSV', async () => {
+    const res = await request(app)
+      .get(`/export/dashboards/${dashboardId}/csv`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.headers['content-type']).toMatch(/csv/);
+  });
+
+  it('should require authentication for exports', async () => {
+    const res = await request(app)
+      .get('/export/events/json');
+
+    expect(res.status).toBe(401);
+  });
+
+  it('should not export dashboard from another tenant', async () => {
+    const res = await request(app)
+      .get(`/export/dashboards/${dashboardId}/json`)
+      .set('Authorization', `Bearer ${otherToken}`);
+
+    expect(res.status).toBe(404);
+  });
+});
