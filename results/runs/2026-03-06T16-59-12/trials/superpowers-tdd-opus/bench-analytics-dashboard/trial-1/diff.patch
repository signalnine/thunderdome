+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/app';
+import type { Express } from 'express';
+
+describe('Event Ingestion', () => {
+  let app: Express;
+  let token: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+    const res = await request(app)
+      .post('/auth/register')
+      .send({
+        email: 'test@example.com',
+        password: 'password123',
+        tenantId: 'tenant-1',
+      });
+    token = res.body.token;
+  });
+
+  it('should ingest a single event', async () => {
+    const res = await request(app)
+      .post('/events')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        name: 'page_view',
+        properties: { url: '/home', browser: 'Chrome' },
+        timestamp: '2024-01-15T10:00:00Z',
+      });
+
+    expect(res.status).toBe(201);
+    expect(res.body).toHaveProperty('id');
+    expect(res.body.name).toBe('page_view');
+  });
+
+  it('should reject event without authentication', async () => {
+    const res = await request(app)
+      .post('/events')
+      .send({ name: 'page_view' });
+
+    expect(res.status).toBe(401);
+  });
+
+  it('should ingest event with auto-generated timestamp', async () => {
+    const res = await request(app)
+      .post('/events')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'click' });
+
+    expect(res.status).toBe(201);
+    expect(res.body).toHaveProperty('timestamp');
+  });
+
+  it('should ingest batch events', async () => {
+    const res = await request(app)
+      .post('/events/batch')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        events: [
+          { name: 'page_view', properties: { url: '/home' } },
+          { name: 'page_view', properties: { url: '/about' } },
+          { name: 'click', properties: { button: 'signup' } },
+        ],
+      });
+
+    expect(res.status).toBe(201);
+    expect(res.body.inserted).toBe(3);
+  });
+
+  it('should reject batch without events array', async () => {
+    const res = await request(app)
+      .post('/events/batch')
+      .set('Authorization', `Bearer ${token}`)
+      .send({});
+
+    expect(res.status).toBe(400);
+  });
+});
