+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/app';
+import type { Express } from 'express';
+
+describe('Dashboard CRUD', () => {
+  let app: Express;
+  let token: string;
+  let otherToken: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+
+    const res = await request(app)
+      .post('/auth/register')
+      .send({
+        email: 'test@example.com',
+        password: 'password123',
+        tenantId: 'tenant-1',
+      });
+    token = res.body.token;
+
+    const otherRes = await request(app)
+      .post('/auth/register')
+      .send({
+        email: 'other@example.com',
+        password: 'password123',
+        tenantId: 'tenant-2',
+      });
+    otherToken = otherRes.body.token;
+  });
+
+  it('should create a dashboard', async () => {
+    const res = await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard', config: { layout: 'grid' } });
+
+    expect(res.status).toBe(201);
+    expect(res.body).toHaveProperty('id');
+    expect(res.body.name).toBe('My Dashboard');
+    expect(res.body.config).toEqual({ layout: 'grid' });
+  });
+
+  it('should list dashboards for tenant', async () => {
+    await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Dashboard 1' });
+
+    await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Dashboard 2' });
+
+    // Create dashboard in other tenant
+    await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${otherToken}`)
+      .send({ name: 'Other Dashboard' });
+
+    const res = await request(app)
+      .get('/dashboards')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.length).toBe(2);
+  });
+
+  it('should get a specific dashboard', async () => {
+    const createRes = await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard' });
+
+    const res = await request(app)
+      .get(`/dashboards/${createRes.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('My Dashboard');
+  });
+
+  it('should not access dashboard from another tenant', async () => {
+    const createRes = await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard' });
+
+    const res = await request(app)
+      .get(`/dashboards/${createRes.body.id}`)
+      .set('Authorization', `Bearer ${otherToken}`);
+
+    expect(res.status).toBe(404);
+  });
+
+  it('should update a dashboard', async () => {
+    const createRes = await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard' });
+
+    const res = await request(app)
+      .put(`/dashboards/${createRes.body.id}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Updated Dashboard', config: { layout: 'list' } });
+
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('Updated Dashboard');
+    expect(res.body.config).toEqual({ layout: 'list' });
+  });
+
+  it('should delete a dashboard', async () => {
+    const createRes = await request(app)
+      .post('/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard' });
+
+    const deleteRes = await request(app)
+      .delete(`/dashboards/${createRes.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(deleteRes.status).toBe(204);
+
+    const getRes = await request(app)
+      .get(`/dashboards/${createRes.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(getRes.status).toBe(404);
+  });
+
+  it('should require authentication', async () => {
+    const res = await request(app).get('/dashboards');
+
+    expect(res.status).toBe(401);
+  });
+});
