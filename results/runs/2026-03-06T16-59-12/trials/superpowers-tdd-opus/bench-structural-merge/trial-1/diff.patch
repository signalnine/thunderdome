+++ b/src/__tests__/store.test.ts
@@ -0,0 +1,38 @@
+import { DocumentStore } from '../index';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('create and get', () => {
+    test('creates a document and retrieves it', () => {
+      store.create('doc1', { title: 'Hello' });
+      const result = store.get('doc1');
+      expect(result).toEqual({ title: 'Hello' });
+    });
+
+    test('throws when creating a document with duplicate id', () => {
+      store.create('doc1', { title: 'Hello' });
+      expect(() => store.create('doc1', { title: 'World' })).toThrow();
+    });
+
+    test('throws when getting a non-existent document', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+  });
+
+  describe('update', () => {
+    test('updates a document and retrieves the new content', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.update('doc1', { title: 'Updated' });
+      expect(store.get('doc1')).toEqual({ title: 'Updated' });
+    });
+
+    test('throws when updating a non-existent document', () => {
+      expect(() => store.update('nonexistent', { title: 'X' })).toThrow();
+    });
+  });
+});
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..6b0c2eb
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,37 @@
+export class DocumentStore {
+  private branches: Map<string, Map<string, object | null>> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', new Map());
+  }
+
+  private docs(): Map<string, object | null> {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  create(id: string, content: object): void {
+    const docs = this.docs();
+    if (docs.has(id) && docs.get(id) !== null) {
+      throw new Error(`Document '${id}' already exists`);
+    }
+    docs.set(id, JSON.parse(JSON.stringify(content)));
+  }
+
+  get(id: string): object {
+    const doc = this.docs().get(id);
+    if (doc === undefined || doc === null) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    return JSON.parse(JSON.stringify(doc));
+  }
+
+  update(id: string, content: object): void {
+    const docs = this.docs();
+    const existing = docs.get(id);
+    if (existing === undefined || existing === null) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    docs.set(id, JSON.parse(JSON.stringify(content)));
+  }
+}
