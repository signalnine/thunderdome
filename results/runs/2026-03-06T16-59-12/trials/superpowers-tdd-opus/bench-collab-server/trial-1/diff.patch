+import { describe, it, expect, beforeAll, afterAll } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/server.js';
+
+describe('REST API', () => {
+  let appInstance: ReturnType<typeof createApp>;
+
+  beforeAll(async () => {
+    appInstance = createApp(':memory:');
+    await appInstance.start(0);
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  describe('POST /documents', () => {
+    it('should create a new document', async () => {
+      const res = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'Hello World' })
+        .expect(201);
+
+      expect(res.body.id).toBeDefined();
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello World');
+    });
+
+    it('should require a title', async () => {
+      await request(appInstance.app)
+        .post('/documents')
+        .send({ content: 'no title' })
+        .expect(400);
+    });
+  });
+
+  describe('GET /documents', () => {
+    it('should list all documents', async () => {
+      const res = await request(appInstance.app)
+        .get('/documents')
+        .expect(200);
+
+      expect(Array.isArray(res.body)).toBe(true);
+      expect(res.body.length).toBeGreaterThan(0);
+    });
+  });
+
+  describe('GET /documents/:id', () => {
+    it('should get a document by id', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Get Me', content: 'content' });
+
+      const res = await request(appInstance.app)
+        .get(`/documents/${createRes.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('Get Me');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .get('/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('PUT /documents/:id', () => {
+    it('should update a document', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Original', content: 'old' });
+
+      const res = await request(appInstance.app)
+        .put(`/documents/${createRes.body.id}`)
+        .send({ title: 'Updated', content: 'new' })
+        .expect(200);
+
+      expect(res.body.title).toBe('Updated');
+      expect(res.body.content).toBe('new');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .put('/documents/nonexistent')
+        .send({ title: 'X' })
+        .expect(404);
+    });
+  });
+
+  describe('DELETE /documents/:id', () => {
+    it('should delete a document', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Delete Me', content: '' });
+
+      await request(appInstance.app)
+        .delete(`/documents/${createRes.body.id}`)
+        .expect(204);
+
+      await request(appInstance.app)
+        .get(`/documents/${createRes.body.id}`)
+        .expect(404);
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .delete('/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('GET /documents/:id/versions', () => {
+    it('should return version history', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Versioned', content: 'v1' });
+
+      await request(appInstance.app)
+        .put(`/documents/${createRes.body.id}`)
+        .send({ content: 'v2' });
+
+      const res = await request(appInstance.app)
+        .get(`/documents/${createRes.body.id}/versions`)
+        .expect(200);
+
+      expect(Array.isArray(res.body)).toBe(true);
+      expect(res.body.length).toBe(2);
+      expect(res.body[0].version).toBe(1);
+      expect(res.body[1].version).toBe(2);
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .get('/documents/nonexistent/versions')
+        .expect(404);
+    });
+  });
+});
