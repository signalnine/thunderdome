@@ -0,0 +1,125 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import Database from 'better-sqlite3';
+import { createDb } from '../src/db.js';
+import { createDocument, getDocument, listDocuments, updateDocument, deleteDocument, getVersionHistory } from '../src/db.js';
+
+describe('Database Layer', () => {
+  let db: Database.Database;
+
+  beforeEach(() => {
+    db = createDb(':memory:');
+  });
+
+  afterEach(() => {
+    db.close();
+  });
+
+  describe('createDocument', () => {
+    it('should create a document and return it with an id', () => {
+      const doc = createDocument(db, 'Test Title', 'Test Content');
+      expect(doc).toBeDefined();
+      expect(doc.id).toBeDefined();
+      expect(typeof doc.id).toBe('string');
+      expect(doc.title).toBe('Test Title');
+      expect(doc.content).toBe('Test Content');
+      expect(doc.created_at).toBeDefined();
+      expect(doc.updated_at).toBeDefined();
+    });
+
+    it('should create a version 1 entry for the new document', () => {
+      const doc = createDocument(db, 'Test Title', 'Hello');
+      const versions = getVersionHistory(db, doc.id);
+      expect(versions).toHaveLength(1);
+      expect(versions[0].version).toBe(1);
+      expect(versions[0].content).toBe('Hello');
+      expect(versions[0].document_id).toBe(doc.id);
+    });
+  });
+
+  describe('getDocument', () => {
+    it('should return a document by id', () => {
+      const created = createDocument(db, 'My Doc', 'content');
+      const found = getDocument(db, created.id);
+      expect(found).toBeDefined();
+      expect(found!.id).toBe(created.id);
+      expect(found!.title).toBe('My Doc');
+    });
+
+    it('should return undefined for non-existent id', () => {
+      const found = getDocument(db, 'nonexistent');
+      expect(found).toBeUndefined();
+    });
+  });
+
+  describe('listDocuments', () => {
+    it('should return all documents', () => {
+      createDocument(db, 'Doc 1', 'a');
+      createDocument(db, 'Doc 2', 'b');
+      createDocument(db, 'Doc 3', 'c');
+      const docs = listDocuments(db);
+      expect(docs).toHaveLength(3);
+    });
+
+    it('should return empty array when no documents exist', () => {
+      const docs = listDocuments(db);
+      expect(docs).toHaveLength(0);
+    });
+  });
+
+  describe('updateDocument', () => {
+    it('should update title and content', () => {
+      const doc = createDocument(db, 'Original', 'old content');
+      const updated = updateDocument(db, doc.id, 'New Title', 'new content');
+      expect(updated).toBeDefined();
+      expect(updated!.title).toBe('New Title');
+      expect(updated!.content).toBe('new content');
+    });
+
+    it('should create a new version when content changes', () => {
+      const doc = createDocument(db, 'Doc', 'v1');
+      updateDocument(db, doc.id, undefined, 'v2');
+      const versions = getVersionHistory(db, doc.id);
+      expect(versions).toHaveLength(2);
+      expect(versions[1].version).toBe(2);
+      expect(versions[1].content).toBe('v2');
+    });
+
+    it('should return undefined for non-existent document', () => {
+      const result = updateDocument(db, 'nonexistent', 'title');
+      expect(result).toBeUndefined();
+    });
+  });
+
+  describe('deleteDocument', () => {
+    it('should delete a document and return true', () => {
+      const doc = createDocument(db, 'To Delete', 'content');
+      const result = deleteDocument(db, doc.id);
+      expect(result).toBe(true);
+      expect(getDocument(db, doc.id)).toBeUndefined();
+    });
+
+    it('should return false for non-existent document', () => {
+      const result = deleteDocument(db, 'nonexistent');
+      expect(result).toBe(false);
+    });
+  });
+
+  describe('getVersionHistory', () => {
+    it('should return versions in order', () => {
+      const doc = createDocument(db, 'Doc', 'v1');
+      updateDocument(db, doc.id, undefined, 'v2');
+      updateDocument(db, doc.id, undefined, 'v3');
+      const versions = getVersionHistory(db, doc.id);
+      expect(versions).toHaveLength(3);
+      expect(versions[0].version).toBe(1);
+      expect(versions[1].version).toBe(2);
+      expect(versions[2].version).toBe(3);
+      expect(versions[2].content).toBe('v3');
+    });
+
+    it('should return empty array for non-existent document', () => {
+      const versions = getVersionHistory(db, 'nonexistent');
+      expect(versions).toHaveLength(0);
+    });
+  });
+});
