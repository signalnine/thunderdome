@@ -0,0 +1,116 @@
+import { describe, it, expect } from 'vitest';
+import { applyOperation, transformOperation, validateOperation, type Operation } from '../src/ot.js';
+
+describe('OT Engine', () => {
+  describe('applyOperation', () => {
+    it('should apply an insert operation', () => {
+      const result = applyOperation('hello', { type: 'insert', position: 5, text: ' world' });
+      expect(result).toBe('hello world');
+    });
+
+    it('should apply an insert at the beginning', () => {
+      const result = applyOperation('world', { type: 'insert', position: 0, text: 'hello ' });
+      expect(result).toBe('hello world');
+    });
+
+    it('should apply a delete operation', () => {
+      const result = applyOperation('hello world', { type: 'delete', position: 5, length: 6 });
+      expect(result).toBe('hello');
+    });
+
+    it('should apply a delete at the beginning', () => {
+      const result = applyOperation('hello world', { type: 'delete', position: 0, length: 6 });
+      expect(result).toBe('world');
+    });
+  });
+
+  describe('transformOperation', () => {
+    it('should transform two inserts at different positions (op1 before op2)', () => {
+      const op1: Operation = { type: 'insert', position: 2, text: 'X' };
+      const op2: Operation = { type: 'insert', position: 5, text: 'Y' };
+      const [t1, t2] = transformOperation(op1, op2);
+      // op1 is before op2, so op1 unchanged; op2 shifts right by 1
+      expect(t1).toEqual({ type: 'insert', position: 2, text: 'X' });
+      expect(t2).toEqual({ type: 'insert', position: 6, text: 'Y' });
+    });
+
+    it('should transform two inserts at the same position', () => {
+      const op1: Operation = { type: 'insert', position: 3, text: 'A' };
+      const op2: Operation = { type: 'insert', position: 3, text: 'B' };
+      const [t1, t2] = transformOperation(op1, op2);
+      // Both at same position: op1 wins (goes first), op2 shifts right
+      expect(t1).toEqual({ type: 'insert', position: 3, text: 'A' });
+      expect(t2).toEqual({ type: 'insert', position: 4, text: 'B' });
+    });
+
+    it('should transform insert vs delete (insert before delete)', () => {
+      const op1: Operation = { type: 'insert', position: 2, text: 'X' };
+      const op2: Operation = { type: 'delete', position: 5, length: 3 };
+      const [t1, t2] = transformOperation(op1, op2);
+      expect(t1).toEqual({ type: 'insert', position: 2, text: 'X' });
+      expect(t2).toEqual({ type: 'delete', position: 6, length: 3 });
+    });
+
+    it('should transform delete vs insert (delete before insert)', () => {
+      const op1: Operation = { type: 'delete', position: 2, length: 3 };
+      const op2: Operation = { type: 'insert', position: 8, text: 'Y' };
+      const [t1, t2] = transformOperation(op1, op2);
+      expect(t1).toEqual({ type: 'delete', position: 2, length: 3 });
+      expect(t2).toEqual({ type: 'insert', position: 5, text: 'Y' });
+    });
+
+    it('should transform two deletes at non-overlapping positions', () => {
+      const op1: Operation = { type: 'delete', position: 0, length: 2 };
+      const op2: Operation = { type: 'delete', position: 5, length: 3 };
+      const [t1, t2] = transformOperation(op1, op2);
+      expect(t1).toEqual({ type: 'delete', position: 0, length: 2 });
+      expect(t2).toEqual({ type: 'delete', position: 3, length: 3 });
+    });
+
+    it('should preserve both concurrent inserts when applied to same document', () => {
+      const doc = 'abcde';
+      const op1: Operation = { type: 'insert', position: 1, text: 'X' };
+      const op2: Operation = { type: 'insert', position: 3, text: 'Y' };
+      const [t1, t2] = transformOperation(op1, op2);
+      // Apply op1 then t2
+      const result1 = applyOperation(applyOperation(doc, op1), t2);
+      // Apply op2 then t1
+      const result2 = applyOperation(applyOperation(doc, op2), t1);
+      expect(result1).toBe(result2);
+      expect(result1).toContain('X');
+      expect(result1).toContain('Y');
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should validate a correct insert operation', () => {
+      const op = validateOperation({ type: 'insert', position: 3, text: 'hi' }, 10);
+      expect(op).toEqual({ type: 'insert', position: 3, text: 'hi' });
+    });
+
+    it('should reject insert beyond document length', () => {
+      const op = validateOperation({ type: 'insert', position: 11, text: 'hi' }, 10);
+      expect(op).toBeNull();
+    });
+
+    it('should validate a correct delete operation', () => {
+      const op = validateOperation({ type: 'delete', position: 2, length: 3 }, 10);
+      expect(op).toEqual({ type: 'delete', position: 2, length: 3 });
+    });
+
+    it('should reject delete beyond document length', () => {
+      const op = validateOperation({ type: 'delete', position: 8, length: 5 }, 10);
+      expect(op).toBeNull();
+    });
+
+    it('should reject non-object input', () => {
+      expect(validateOperation('string', 10)).toBeNull();
+      expect(validateOperation(null, 10)).toBeNull();
+      expect(validateOperation(42, 10)).toBeNull();
+    });
+
+    it('should reject unknown operation type', () => {
+      expect(validateOperation({ type: 'replace', position: 0 }, 10)).toBeNull();
+    });
+  });
+});
