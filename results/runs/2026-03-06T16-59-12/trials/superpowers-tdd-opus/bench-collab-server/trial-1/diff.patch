+import { describe, it, expect, beforeAll, afterAll } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp } from '../src/server.js';
+
+interface BufferedWs {
+  ws: WebSocket;
+  nextMessage(): Promise<Record<string, unknown>>;
+}
+
+function connectWs(port: number, docId: string): Promise<BufferedWs> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);
+    const messages: Record<string, unknown>[] = [];
+    const waiters: Array<(msg: Record<string, unknown>) => void> = [];
+
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (waiters.length > 0) {
+        waiters.shift()!(msg);
+      } else {
+        messages.push(msg);
+      }
+    });
+
+    ws.on('open', () => {
+      resolve({
+        ws,
+        nextMessage(): Promise<Record<string, unknown>> {
+          if (messages.length > 0) {
+            return Promise.resolve(messages.shift()!);
+          }
+          return new Promise((res) => {
+            waiters.push(res);
+          });
+        },
+      });
+    });
+    ws.on('error', reject);
+  });
+}
+
+describe('Concurrent Editing Convergence', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+
+  beforeAll(async () => {
+    appInstance = createApp(':memory:');
+    port = await appInstance.start(0);
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  it('should converge when two clients insert at different positions', async () => {
+    const createRes = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Converge Test', content: 'abcde' });
+    const docId = createRes.body.id;
+
+    const client1 = await connectWs(port, docId);
+    const sync1 = await client1.nextMessage();
+
+    const client2 = await connectWs(port, docId);
+    const sync2 = await client2.nextMessage();
+
+    // Client 1 inserts 'X' at position 1 (based on version from sync)
+    client1.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 1, text: 'X' },
+      version: sync1.version,
+    }));
+
+    // Client 2 inserts 'Y' at position 3 (based on version from sync, before seeing client1's op)
+    client2.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 3, text: 'Y' },
+      version: sync2.version,
+    }));
+
+    // Wait for all acks and broadcasts
+    await client1.nextMessage(); // ack for client1's op
+    await client2.nextMessage(); // broadcast of client1's op OR ack for client2's op
+
+    // Drain remaining messages
+    await client1.nextMessage(); // broadcast of client2's op
+    await client2.nextMessage(); // remaining message
+
+    // Check final state via REST - both edits should be present
+    const res = await request(appInstance.app).get(`/documents/${docId}`);
+    const content = res.body.content;
+    expect(content).toContain('X');
+    expect(content).toContain('Y');
+    expect(content).toContain('a');
+    expect(content).toContain('b');
+    expect(content).toContain('c');
+    expect(content).toContain('d');
+    expect(content).toContain('e');
+    expect(content.length).toBe(7); // 'abcde' + 'X' + 'Y'
+
+    client1.ws.close();
+    client2.ws.close();
+  });
+
+  it('should handle 10 concurrent clients without corruption', async () => {
+    const createRes = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Load Test', content: '' });
+    const docId = createRes.body.id;
+
+    const clients: BufferedWs[] = [];
+    for (let i = 0; i < 10; i++) {
+      const client = await connectWs(port, docId);
+      const sync = await client.nextMessage();
+      clients.push(client);
+    }
+
+    // Each client inserts its number at position 0 sequentially
+    for (let i = 0; i < 10; i++) {
+      clients[i].ws.send(JSON.stringify({
+        type: 'operation',
+        operation: { type: 'insert', position: 0, text: String(i) },
+        version: 0, // all based on original empty document
+      }));
+    }
+
+    // Wait for all operations to be processed
+    // Each client gets an ack + broadcasts from other 9 clients = 10 messages
+    for (let i = 0; i < 10; i++) {
+      for (let j = 0; j < 10; j++) {
+        await clients[i].nextMessage();
+      }
+    }
+
+    // Check final state
+    const res = await request(appInstance.app).get(`/documents/${docId}`);
+    const content = res.body.content;
+
+    // All digits 0-9 should be present
+    for (let i = 0; i < 10; i++) {
+      expect(content).toContain(String(i));
+    }
+    expect(content.length).toBe(10);
+
+    for (const client of clients) {
+      client.ws.close();
+    }
+  });
+
+  it('should handle interleaved inserts and deletes', async () => {
+    const createRes = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Mixed Ops', content: 'hello world' });
+    const docId = createRes.body.id;
+
+    const client1 = await connectWs(port, docId);
+    const sync1 = await client1.nextMessage();
+
+    const client2 = await connectWs(port, docId);
+    const sync2 = await client2.nextMessage();
+
+    // Client 1: insert '!' at position 11 (end)
+    client1.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 11, text: '!' },
+      version: sync1.version,
+    }));
+
+    // Client 2: delete 'world' (position 6, length 5) based on original version
+    client2.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'delete', position: 6, length: 5 },
+      version: sync2.version,
+    }));
+
+    // Wait for all messages to be processed
+    await client1.nextMessage(); // ack
+    await client2.nextMessage(); // broadcast/ack
+    await client1.nextMessage(); // broadcast
+    await client2.nextMessage(); // remaining
+
+    const res = await request(appInstance.app).get(`/documents/${docId}`);
+    const content = res.body.content;
+
+    // 'hello ' remains, 'world' is deleted, '!' is inserted
+    // The exact position of '!' depends on OT, but both ops should be applied
+    expect(content).toContain('hello');
+    expect(content).toContain('!');
+    expect(content).not.toContain('world');
+
+    client1.ws.close();
+    client2.ws.close();
+  });
+});
