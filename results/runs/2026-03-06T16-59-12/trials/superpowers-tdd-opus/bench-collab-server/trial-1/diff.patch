t { createApp } from '../src/server.js';\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once('message', (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let appInstance: ReturnType<typeof createApp>;\n  let port: number;\n\n  beforeAll(async () => {\n    appInstance = createApp(':memory:');\n    port = await appInstance.start(0);\n  });\n\n  afterAll(async () => {\n    await appInstance.stop();\n  });\n\n  let docId: string;\n\n  beforeEach(async () => {\n    const res = await request(appInstance.app)\n      .post('/documents')\n      .send({ title: 'WS Test', content: 'hello' });\n    docId = res.body.id;\n  });\n\n  it('should send sync message on connection', async () => {\n    const ws = await connectWs(port, docId);\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBeDefined();\n    expect(msg.clientId).toBeDefined();\n    ws.close();\n  });\n\n  it('should send ack after an operation', async () => {\n    const ws = await connectWs(port, docId);\n    const sync = await waitForMessage(ws);\n\n    const ackPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: sync.version,\n    }));\n    const ack = await ackPromise;\n    expect(ack.type).toBe('ack');\n    expect(typeof ack.version).toBe('number');\n    ws.close();\n  });\n\n  it('should broadcast operation to other clients', async () => {\n    const ws1 = await connectWs(port, docId);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWs(port, docId);\n    await waitForMessage(ws2); // sync\n\n    const broadcastPromise = waitForMessage(ws2);\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: sync1.version,\n    }));\n\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.operation).toEqual({ type: 'insert', position: 5, text: ' world' });\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should persist changes to the database', async () => {\n    const ws = await connectWs(port, docId);\n    const sync = await waitForMessage(ws);\n\n    const ackPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: sync.version,\n    }));\n    await ackPromise;\n\n    // Check database via REST\n    const res = await request(appInstance.app).get(`/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('should return error for invalid JSON', async () => {\n    const ws = await connectWs(port, docId);\n    await waitForMessage(ws); // sync\n\n    const errPromise = waitForMessage(ws);\n    ws.send('not json{{{');\n    const err = await errPromise;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n\n  it('should return error for invalid operation', async () => {\n    const ws = await connectWs(port, docId);\n    const sync = await waitForMessage(ws);\n\n    const errPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: { type: 'insert', position: 999, text: 'bad' },\n      version: sync.version,\n    }));\n    const err = await errPromise;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject non-existent document WebSocket connections', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent/ws`);\n    await new Promise<void>((resolve) => {\n      ws.on('error', () => resolve());\n      ws.on('close', () => resolve());\n    });\n    expect(ws.readyState).not.toBe(WebSocket.OPEN);\n  });\n});\n"}}
