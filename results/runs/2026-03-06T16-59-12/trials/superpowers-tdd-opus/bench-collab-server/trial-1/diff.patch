  app.get('/documents', (_req, res) => {\n    const docs = listDocuments(db);\n    res.json(docs);\n  });\n\n  app.get('/documents/:id', (req, res) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  app.put('/documents/:id', (req, res) => {\n    const { title, content } = req.body;\n    const updated = updateDocument(db, req.params.id, title, content);\n    if (!updated) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(updated);\n  });\n\n  app.delete('/documents/:id', (req, res) => {\n    const success = deleteDocument(db, req.params.id);\n    if (!success) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  app.get('/documents/:id/versions', (req, res) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = getVersionHistory(db, req.params.id);\n    res.json(versions);\n  });\n\n  // --- WebSocket ---\n  function getOrCreateSession(docId: string): DocumentSession | null {\n    if (sessions.has(docId)) return sessions.get(docId)!;\n    const doc = getDocument(db, docId);\n    if (!doc) return null;\n    const versions = getVersionHistory(db, docId);\n    const session: DocumentSession = {\n      clients: new Map(),\n      version: versions.length,\n      content: doc.content,\n      pendingOps: [],\n    };\n    sessions.set(docId, session);\n    return session;\n  }\n\n  server.on('upgrade', (request: IncomingMessage, socket, head) => {\n    const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);\n    const match = url.pathname.match(/^\\/documents\\/([^/]+)\\/ws$/);\n    if (!match) {\n      socket.destroy();\n      return;\n    }\n    const docId = match[1];\n    const doc = getDocument(db, docId);\n    if (!doc) {\n      socket.destroy();\n      return;\n    }\n\n    wss.handleUpgrade(request, socket, head, (ws) => {\n      wss.emit('connection', ws, request, docId);\n    });\n  });\n\n  wss.on('connection', (ws: WebSocket, _request: IncomingMessage, docId: string) => {\n    const session = getOrCreateSession(docId);\n    if (!session) {\n      ws.close(1008, 'Document not found');\n      return;\n    }\n\n    const clientId = crypto.randomUUID();\n    session.clients.set(clientId, ws);\n\n    // Send sync message with current state\n    ws.send(JSON.stringify({\n      type: 'sync',\n      content: session.content,\n      version: session.version,\n      clientId,\n    }));\n\n    ws.on('message', (data) => {\n      let msg: { type: string; operation: unknown; version?: number };\n      try {\n        msg = JSON.parse(data.toString());\n      } catch {\n        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));\n        return;\n      }\n\n      if (msg.type !== 'operation') {\n        ws.send(JSON.stringify({ type: 'error', message: 'Unknown message type' }));\n        return;\n      }\n\n      const clientVersion = typeof msg.version === 'number' ? msg.version : session.version;\n\n      const validatedOp = validateOperation(msg.operation, session.content.length);\n      if (!validatedOp) {\n        ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation' }));\n        return;\n      }\n\n      // Transform against any operations that happened since the client's version\n      let transformedOp = validatedOp;\n      const opsToTransformAgainst = session.pendingOps.filter(o => o.version > clientVersion && o.clientId !== clientId);\n\n      for (const pending of opsToTransformAgainst) {\n        const [, t2] = transformOperation(pending.op, transformedOp);\n        transformedOp = t2;\n      }\n\n      // Re-validate after transform\n      const revalidated = validateOperation(transformedOp, session.content.length);\n      if (!revalidated) {\n        ws.send(JSON.stringify({ type: 'error', message: 'Operation invalid after transform' }));\n        return;\n      }\n      transformedOp = revalidated;\n\n      // Apply\n      session.content = applyOperation(session.content, transformedOp);\n      session.version++;\n      session.pendingOps.push({ version: session.version, op: transformedOp, clientId });\n\n      // Persist to DB\n      db.prepare(\n        `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`\n      ).run(session.content, docId);\n\n      const lastVersion = db.prepare(\n        `SELECT MAX(version) as maxVer FROM versions WHERE document_id = ?`\n      ).get(docId) as { maxVer: number };\n      const nextVersion = (lastVersion.maxVer || 0) + 1;\n      db.prepare(\n        `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`\n      ).run(docId, nextVersion, session.content, JSON.stringify(transformedOp));\n\n      // Send ack to the sender\n      ws.send(JSON.stringify({\n        type: 'ack',\n        version: session.version,\n      }));\n\n      // Broadcast to others\n      for (const [cid, client] of session.clients) {\n        if (cid !== clientId && client.readyState === WebSocket.OPEN) {\n          client.send(JSON.stringify({\n            type: 'operation',\n            operation: transformedOp,\n            version: session.version,\n            clientId,\n          }));\n        }\n      }\n    });\n\n    ws.on('close', () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        sessions.delete(docId);\n      }\n    });\n  });\n\n  return {\n    app: server,\n    start(port: number = 0): Promise<number> {\n      return new Promise((resolve) => {\n        server.listen(port, () => {\n          const addr = server.address();\n          const actualPort = typeof addr === 'object' && addr ? addr.port : port;\n          resolve(a