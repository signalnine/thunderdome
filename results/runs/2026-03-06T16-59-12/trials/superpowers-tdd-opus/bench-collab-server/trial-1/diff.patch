+import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp } from '../src/server.js';
+
+interface BufferedWs {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  nextMessage(): Promise<Record<string, unknown>>;
+}
+
+function connectWs(port: number, docId: string): Promise<BufferedWs> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);
+    const messages: Record<string, unknown>[] = [];
+    const waiters: Array<(msg: Record<string, unknown>) => void> = [];
+
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (waiters.length > 0) {
+        waiters.shift()!(msg);
+      } else {
+        messages.push(msg);
+      }
+    });
+
+    ws.on('open', () => {
+      resolve({
+        ws,
+        messages,
+        nextMessage(): Promise<Record<string, unknown>> {
+          if (messages.length > 0) {
+            return Promise.resolve(messages.shift()!);
+          }
+          return new Promise((res) => {
+            waiters.push(res);
+          });
+        },
+      });
+    });
+    ws.on('error', reject);
+  });
+}
+
+describe('WebSocket Collaboration', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+
+  beforeAll(async () => {
+    appInstance = createApp(':memory:');
+    port = await appInstance.start(0);
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  let docId: string;
+
+  beforeEach(async () => {
+    const res = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'WS Test', content: 'hello' });
+    docId = res.body.id;
+  });
+
+  it('should send sync message on connection', async () => {
+    const client = await connectWs(port, docId);
+    const msg = await client.nextMessage();
+    expect(msg.type).toBe('sync');
+    expect(msg.content).toBe('hello');
+    expect(msg.version).toBeDefined();
+    expect(msg.clientId).toBeDefined();
+    client.ws.close();
+  });
+
+  it('should send ack after an operation', async () => {
+    const client = await connectWs(port, docId);
+    const sync = await client.nextMessage();
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 5, text: ' world' },
+      version: sync.version,
+    }));
+    const ack = await client.nextMessage();
+    expect(ack.type).toBe('ack');
+    expect(typeof ack.version).toBe('number');
+    client.ws.close();
+  });
+
+  it('should broadcast operation to other clients', async () => {
+    const client1 = await connectWs(port, docId);
+    const sync1 = await client1.nextMessage();
+
+    const client2 = await connectWs(port, docId);
+    await client2.nextMessage(); // sync
+
+    client1.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 5, text: ' world' },
+      version: sync1.version,
+    }));
+
+    const broadcast = await client2.nextMessage();
+    expect(broadcast.type).toBe('operation');
+    expect(broadcast.operation).toEqual({ type: 'insert', position: 5, text: ' world' });
+
+    client1.ws.close();
+    client2.ws.close();
+  });
+
+  it('should persist changes to the database', async () => {
+    const client = await connectWs(port, docId);
+    const sync = await client.nextMessage();
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 5, text: ' world' },
+      version: sync.version,
+    }));
+    await client.nextMessage(); // ack
+
+    // Check database via REST
+    const res = await request(appInstance.app).get(`/documents/${docId}`);
+    expect(res.body.content).toBe('hello world');
+
+    client.ws.close();
+  });
+
+  it('should return error for invalid JSON', async () => {
+    const client = await connectWs(port, docId);
+    await client.nextMessage(); // sync
+
+    client.ws.send('not json{{{');
+    const err = await client.nextMessage();
+    expect(err.type).toBe('error');
+    client.ws.close();
+  });
+
+  it('should return error for invalid operation', async () => {
+    const client = await connectWs(port, docId);
+    const sync = await client.nextMessage();
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 999, text: 'bad' },
+      version: sync.version,
+    }));
+    const err = await client.nextMessage();
+    expect(err.type).toBe('error');
+    client.ws.close();
+  });
+
+  it('should reject non-existent document WebSocket connections', async () => {
+    const ws = new WebSocket(`ws://localhost:${port}/documents/nonexistent/ws`);
+    await new Promise<void>((resolve) => {
+      ws.on('error', () => resolve());
+      ws.on('close', () => resolve());
+    });
+    expect(ws.readyState).not.toBe(WebSocket.OPEN);
+  });
+});
