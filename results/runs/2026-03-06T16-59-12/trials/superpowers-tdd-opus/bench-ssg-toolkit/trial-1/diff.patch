@@ -0,0 +1,49 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assetPaths = manifest ? manifest.assets : [];
+
+        const routes: Array<{ path: string; handler: string }> = [];
+
+        // Add asset routes
+        for (const asset of assetPaths) {
+          routes.push({ path: `/assets/${asset}`, handler: 'asset' });
+        }
+
+        // Add content routes for HTML output files
+        for (const path of ctx.output.keys()) {
+          if (path.endsWith('.html')) {
+            routes.push({ path: `/${path}`, handler: 'static' });
+          }
+        }
+
+        const searchIndexPath = ctx.output.has('search-index.json')
+          ? '/search-index.json'
+          : '';
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath,
+        };
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
diff --git a/src/plugins/markdown-ext.ts b/src/plugins/markdown-ext.ts
new file mode 100644
index 0000000..b8989d7
--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,94 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): string {
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  const footnotes: { id: string; text: string }[] = [];
+  let processed = content;
+
+  let match;
+  while ((match = footnoteDefRegex.exec(content)) !== null) {
+    footnotes.push({ id: match[1], text: match[2] });
+  }
+
+  // Remove footnote definitions from content
+  processed = processed.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+  // Replace inline footnote references with sup/a tags
+  processed = processed.replace(/\[\^(\d+)\]/g, '<sup><a href="#fn-$1">$1</a></sup>');
+
+  // Add footnote section at the end if there are footnotes
+  if (footnotes.length > 0) {
+    const items = footnotes.map(f => `<li id="fn-${f.id}">${f.text}</li>`).join('\n');
+    processed += `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+  }
+
+  return processed;
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(/:::(\w+)\n([\s\S]*?):::/g, (_match, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+function processMarkdown(content: string): string {
+  let result = content;
+
+  // Process admonitions before markdown conversion
+  result = processAdmonitions(result);
+
+  // Process footnotes
+  result = processFootnotes(result);
+
+  // Convert headers: # H1, ## H2, etc.
+  result = result.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  result = result.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  result = result.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  result = result.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  result = result.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  result = result.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Convert bold: **text**
+  result = result.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+
+  // Convert italic: *text*
+  result = result.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Convert paragraphs: lines that aren't already HTML tags
+  const lines = result.split('\n');
+  const processed: string[] = [];
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (trimmed === '') {
+      processed.push('');
+    } else if (
+      trimmed.startsWith('<') ||
+      trimmed.startsWith('</') ||
+      trimmed === ''
+    ) {
+      processed.push(line);
+    } else {
+      processed.push(`<p>${trimmed}</p>`);
+    }
+  }
+
+  return processed.join('\n').trim();
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        if (!file.content) {
+          return { ...file, content: '' };
+        }
+
+        const processed = processMarkdown(file.content);
+        return { ...file, content: processed };
+      },
+    },
+  };
+}
diff --git a/src/plugins/rss-feed.ts b/src/plugins/rss-feed.ts
