ategoryTags = '';\n          if (file.tags) {\n            categoryTags = file.tags\n              .map(tag => `      <category>${tag}</category>`)\n              .join('\\n');\n          }\n\n          const pubDate = file.date ? `      <pubDate>${file.date}</pubDate>\\n` : '';\n\n          return `    <item>\n      <title>${file.title}</title>\n      <link>${config.baseUrl}/${file.slug}.html</link>\n${pubDate}      <description><![CDATA[${file.content}]]></description>\n${categoryTags ? categoryTags + '\\n' : ''}    </item>`;\n        }).join('\\n');\n\n        const feed = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>${config.title}</title>\n    <link>${config.baseUrl}</link>\n    <description>${config.title} RSS Feed</description>\n${items}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { Plugin, ContentFile, BuildContext } from '../core/types.js';","+import { Plugin, BuildContext } from '../core/types.js';"," "," export function createRssFeedPlugin(): Plugin {","   return {"]},{"oldStart":8,"oldLines":7,"newStart":8,"newLines":6,"lines":["     hooks: {","       afterBuild(ctx: BuildContext): void {","         const { config, files } = ctx;","-        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;"," ","         // Sort files by date, newest first; files without dates go last","         const sorted = [...files].sort((a, b) => {"]}],"userModified":false,"replaceAll":false}}
