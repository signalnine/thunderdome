content: '<pre><code class=\"language-js\"></code></pre>',\n    93→    });\n    94→    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    95→    expect(result.content).toContain('data-language=\"js\"');\n    96→    expect(result.content).toContain('highlighted');\n    97→  });\n    98→\n    99→  it('does not modify inline code', async () => {\n   100→    const file = makeFile({\n   101→      content: '<p>Use <code>console.log()</code> for debugging.</p>',\n   102→    });\n   103→    const result = await plugin.hooks.transformContent!(file, makeCtx());\n   104→    expect(result.content).toBe('<p>Use <code>console.log()</code> for debugging.</p>');\n   105→    expect(result.content).not.toContain('highlighted');\n   106→  });\n   107→});\n   108→"}]},"parent_tool_use_id":"toolu_01KYhnx26e9RX43zzN4j88Vi","session_id":"d47a8057-048f-474e-93a5-068a7e7639fb","uuid":"e75ea2ae-1a49-4d00-a610-17c2cad3afff"}
