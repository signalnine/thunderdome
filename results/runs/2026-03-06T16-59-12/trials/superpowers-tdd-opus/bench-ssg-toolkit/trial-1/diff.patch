mplate(createDefaultTemplate());\n    const file = makeFile({ title: 'My Post', content: '<p>Content here</p>' });\n    const ctx = await engine.build([file]);\n    const output = ctx.output.get('test-post.html')!;\n    expect(output).toContain('<!DOCTYPE html>');\n    expect(output).toContain('My Post');\n    expect(output).toContain('<p>Content here</p>');\n    expect(output).toContain('Test Site');\n  });\n\n  it('builds with list template and renders list HTML', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createListTemplate());\n    const file = makeFile({ title: 'My List', content: '<ul><li>Item</li></ul>', template: 'list' });\n    const ctx = await engine.build([file]);\n    const output = ctx.output.get('test-post.html')!;\n    expect(output).toContain('<!DOCTYPE html>');\n    expect(output).toContain('My List');\n    expect(output).toContain('<div class=\"list\">');\n    expect(output).toContain('<ul><li>Item</li></ul>');\n  });\n\n  it('outputs raw content when no matching template', async () => {\n    const engine = new BuildEngine(testConfig);\n    const file = makeFile({ content: '<p>Raw content</p>' });\n    const ctx = await engine.build([file]);\n    expect(ctx.output.get('test-post.html')).toBe('<p>Raw content</p>');\n  });\n\n  it('calls plugin beforeBuild hook', async () => {\n    const engine = new BuildEngine(testConfig);\n    let called = false;\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        beforeBuild: () => { called = true; },\n      },\n    }));\n    await engine.build([]);\n    expect(called).toBe(true);\n  });\n\n  it('calls plugin transformContent hook to transform files', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content.toUpperCase(),\n        }),\n      },\n    }));\n    const ctx = await engine.build([makeFile({ content: 'hello' })]);\n    expect(ctx.files[0].content).toBe('HELLO');\n  });\n\n  it('calls plugin afterBuild hook', async () => {\n    const engine = new BuildEngine(testConfig);\n    let called = false;\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        afterBuild: () => { called = true; },\n      },\n    }));\n    await engine.build([]);\n    expect(called).toBe(true);\n  });\n\n  it('executes plugins in dependency order', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: [] }));\n    const order = engine.resolvePluginOrder();\n    expect(order.map(p => p.name)).toEqual(['a', 'b']);\n  });\n\n  it('throws on circular dependency', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['b'] }));\n    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n    expect(() => engine.resolvePluginOrder()).toThrow('Circular dependency');\n  });\n\n  it('throws on missing dependency', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['missing'] }));\n    expect(() => engine.resolvePluginOrder()).toThrow('Missing dependency');\n  });\n\n  it('applies multiple plugins transformContent in order', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      name: 'first',\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content + ' [first]',\n        }),\n      },\n    }));\n    engine.registerPlugin(makePlugin({\n      name: 'second',\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content + ' [second]',\n        }),\n      },\n    }));\n    const ctx = await engine.build([makeFile({ content: 'start' })]);