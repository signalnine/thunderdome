+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_015AXazNXCFYaGfQeD9vafKb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01T9mhrX3mHAvKfrmYHigSwD","name":"Write","input":{"file_path":"/workspace/tests/phase08.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('Phase 8: Concurrency Control', () => {\n  it('should allow setting a concurrency limit on a queue', () => {\n    const queue = new TaskQueue();\n    queue.setConcurrency({ queue: 'default', limit: 2 });\n    expect(queue.getConcurrency()).toEqual({ limit: 2, active: 0 });\n  });\n\n  it('should limit how many tasks can be processing simultaneously', () => {\n    const queue = new TaskQueue();\n    queue.setConcurrency({ limit: 2 });\n    queue.add('task1');\n    queue.add('task2');\n    queue.add('task3');\n\n    expect(queue.next()).not.toBeNull();\n    expect(queue.next()).not.toBeNull();\n    // Third should be null because concurrency limit reached\n    expect(queue.next()).toBeNull();\n  });\n\n  it('should free a concurrency slot when completing a task', () => {\n    const queue = new TaskQueue();\n    queue.setConcurrency({ limit: 1 });\n    queue.add('task1');\n    queue.add('task2');\n\n    const task1 = queue.next()!;\n    expect(queue.next()).toBeNull(); // limit reached\n\n    queue.complete(task1.id);\n    expect(queue.next()).not.toBeNull(); // slot freed\n  });\n\n  it('should free a concurrency slot when failing a task (with no retries)', () => {\n    const queue = new TaskQueue();\n    queue.setConcurrency({ limit: 1 });\n    queue.add('task1', { maxRetries: 0 });\n    queue.add('task2');\n\n    const task1 = queue.next()!;\n    expect(queue.next()).toBeNull();\n\n    queue.fail(task1.id, new Error('fail'));\n    expect(queue.next()).not.toBeNull();\n  });\n\n  it('should have unlimited concurrency by default', () => {\n    const queue = new TaskQueue();\n    queue.add('task1');\n    queue.add('task2');\n    queue.add('task3');\n    queue.add('task4');\n    queue.add('task5');\n\n    // Should be able to get all of them\n    for (let i = 0; i < 5; i++) {\n      expect(queue.next()).not.toBeNull();\n    }\n  });\n\n  it('should report active count', () => {\n    const queue = new TaskQueue();\n    queue.setConcurrency({ limit: 3 });\n    queue.add('task1');\n    queue.add('task2');\n\n    expect(queue.getConcurrency().active).toBe(0);\n    queue.next();\n    expect(queue.getConcurrency().active).toBe(1);\n    const task2 = queue.next()!;\n    expect(queue.getConcurrency().active).toBe(2);\n    queue.complete(task2.id);\n    expect(queue.getConcurrency().active).toBe(1);\n  });\n\n  it('should still respect priority when concurrency limited', () => {\n    const queue = new TaskQueue();\n    queue.setConcurrency({ limit: 1 });\n    queue.add('low', { priority: 10 });\n    queue.add('high', { priority: 1 });\n\n    expect(queue.next()!.payload).toBe('high');\n  });\n\n  it('should operate concurrency per-queue', () => {\n    const queue = new TaskQueue();\n    queue.setConcurrency({ queue: 'q1', limit: 1 });\n    queue.setConcurrency({ queue: 'q2', limit: 1 });\n\n    queue.add('t1', { queue: 'q1' });\n    queue.add('t2', { queue: 'q1' });\n    queue.add('t3', { queue: 'q2' });\n    queue.add('t4', { queue: 'q2' });\n\n    // Each queue allows 1\n    expect(queue.next({ queue: 'q1' })).not.toBeNull();\n    expect(queue.next({ queue: 'q1' })).toBeNull();\n    expect(queue.next({ queue: 'q2' })).not.toBeNull();\n    expect(queue.next({ queue: 'q2' })).toBeNull();\n  });\n\n  it('should query concurrency for specific queue', () => {\n    const queue = new TaskQueue();\n    queue.setConcurrency({ queue: 'myqueue', limit: 5 });\n    expect(queue.getConcurrency({ queue: 'myqueue' })).toEqual({ limit: 5, active: 0 });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation