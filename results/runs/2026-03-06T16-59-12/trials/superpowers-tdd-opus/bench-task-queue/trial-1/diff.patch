+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_017ocphCaU17krVZiDtQwYRy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NtWfTLhX8ubQFaj5pbPMsa","name":"Write","input":{"file_path":"/workspace/tests/phase04.test.ts","content":"import { describe, it, expect, vi, afterEach } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('Phase 4: Delayed and Scheduled Tasks', () => {\n  afterEach(() => {\n    vi.useRealTimers();\n  });\n\n  it('should accept a delay in milliseconds', () => {\n    const queue = new TaskQueue();\n    const task = queue.add('delayed', { delay: 5000 });\n\n    expect(task.availableAt).toBeInstanceOf(Date);\n    expect(task.availableAt!.getTime()).toBeGreaterThan(Date.now());\n  });\n\n  it('should accept a specific future time via processAt', () => {\n    const queue = new TaskQueue();\n    const futureTime = new Date(Date.now() + 10000);\n    const task = queue.add('scheduled', { processAt: futureTime });\n\n    expect(task.availableAt).toEqual(futureTime);\n  });\n\n  it('should not return delayed tasks before their availability time', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add('delayed', { delay: 5000 });\n\n    expect(queue.next()).toBeNull();\n  });\n\n  it('should return delayed tasks after their availability time', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add('delayed', { delay: 5000 });\n\n    vi.advanceTimersByTime(5000);\n    const task = queue.next();\n    expect(task).not.toBeNull();\n    expect(task!.payload).toBe('delayed');\n  });\n\n  it('should prefer non-delayed tasks over delayed tasks that are not yet available', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add('delayed', { delay: 5000 });\n    queue.add('immediate');\n\n    const task = queue.next();\n    expect(task!.payload).toBe('immediate');\n  });\n\n  it('should order available delayed tasks by availability time, then priority, then FIFO', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add('later', { delay: 3000 });\n    queue.add('sooner', { delay: 1000 });\n\n    vi.advanceTimersByTime(3000);\n\n    expect(queue.next()!.payload).toBe('sooner');\n    expect(queue.next()!.payload).toBe('later');\n  });\n\n  it('should handle delayed tasks with priority correctly', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add('delayed-low', { delay: 1000, priority: 10 });\n    queue.add('delayed-high', { delay: 1000, priority: 1 });\n\n    vi.advanceTimersByTime(1000);\n\n    expect(queue.next()!.payload).toBe('delayed-high');\n    expect(queue.next()!.payload).toBe('delayed-low');\n  });\n\n  it('should work with named queues', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add('delayed', { queue: 'emails', delay: 5000 });\n\n    expect(queue.next({ queue: 'emails' })).toBeNull();\n    vi.advanceTimersByTime(5000);\n    expect(queue.next({ queue: 'emails' })!.payload).toBe('delayed');\n  });\n\n  it('should not count delayed unavailable tasks in size', () => {\n    vi.useFakeTimers();\n    const queue = new TaskQueue();\n    queue.add('immediate');\n    queue.add('delayed', { delay: 5000 });\n\n    // size should reflect pending tasks (even delayed ones are pending)\n    expect(queue.size()).toBe(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":566,"cache_read_input_tokens":41807,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":566},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4d41520d-00c6-4a20-9375-7ce9d900f299","uuid":"75e98376-3805-4f11-9b4f-547a01bc1449"}
