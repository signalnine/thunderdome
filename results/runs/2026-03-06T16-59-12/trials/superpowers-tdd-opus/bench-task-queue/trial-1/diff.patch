+++ b/tests/phase10.test.ts
@@ -0,0 +1,158 @@
+import { describe, it, expect, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should create a schedule with a cron expression', () => {
+    const queue = new TaskQueue();
+    const scheduleId = queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: { type: 'cleanup' },
+    });
+
+    expect(typeof scheduleId).toBe('string');
+    expect(scheduleId.length).toBeGreaterThan(0);
+  });
+
+  it('should list active schedules', () => {
+    const queue = new TaskQueue();
+    queue.addSchedule({ cron: '*/5 * * * *', payload: 'job1' });
+    queue.addSchedule({ cron: '0 * * * *', payload: 'job2' });
+
+    const schedules = queue.listSchedules();
+    expect(schedules).toHaveLength(2);
+  });
+
+  it('should remove a schedule', () => {
+    const queue = new TaskQueue();
+    const id = queue.addSchedule({ cron: '*/5 * * * *', payload: 'job1' });
+
+    queue.removeSchedule(id);
+    expect(queue.listSchedules()).toHaveLength(0);
+  });
+
+  it('should enqueue tasks when tick detects a due schedule (every N minutes)', () => {
+    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });
+    const queue = new TaskQueue();
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: { type: 'cleanup' },
+    });
+
+    queue.tick();
+    expect(queue.size()).toBe(1);
+
+    const task = queue.next()!;
+    expect(task.payload).toEqual({ type: 'cleanup' });
+  });
+
+  it('should enqueue tasks for every-hour schedule at the top of the hour', () => {
+    vi.useFakeTimers({ now: new Date('2026-01-01T01:00:00Z') });
+    const queue = new TaskQueue();
+    queue.addSchedule({
+      cron: '0 * * * *',
+      payload: 'hourly',
+    });
+
+    queue.tick();
+    expect(queue.size()).toBe(1);
+  });
+
+  it('should not double-enqueue if tick called multiple times within same minute', () => {
+    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });
+    const queue = new TaskQueue();
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: 'job',
+    });
+
+    queue.tick();
+    queue.tick(); // same minute
+    expect(queue.size()).toBe(1);
+  });
+
+  it('should enqueue again when the next interval arrives', () => {
+    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });
+    const queue = new TaskQueue();
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: 'job',
+    });
+
+    queue.tick();
+    expect(queue.size()).toBe(1);
+
+    vi.advanceTimersByTime(5 * 60 * 1000); // advance 5 minutes
+    queue.tick();
+    expect(queue.size()).toBe(2);
+  });
+
+  it('should support daily at midnight (0 0 * * *)', () => {
+    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });
+    const queue = new TaskQueue();
+    queue.addSchedule({
+      cron: '0 0 * * *',
+      payload: 'midnight',
+    });
+
+    queue.tick();
+    expect(queue.size()).toBe(1);
+
+    // At 1am, should not fire
+    vi.advanceTimersByTime(60 * 60 * 1000);
+    queue.tick();
+    expect(queue.size()).toBe(1);
+  });
+
+  it('should enqueue to a specific queue', () => {
+    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });
+    const queue = new TaskQueue();
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: 'job',
+      queue: 'myqueue',
+    });
+
+    queue.tick();
+    expect(queue.size({ queue: 'myqueue' })).toBe(1);
+    expect(queue.size()).toBe(0);
+  });
+
+  it('should not create new tasks after removing a schedule', () => {
+    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });
+    const queue = new TaskQueue();
+    const id = queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: 'job',
+    });
+
+    queue.tick();
+    expect(queue.size()).toBe(1);
+
+    queue.removeSchedule(id);
+    vi.advanceTimersByTime(5 * 60 * 1000);
+    queue.tick();
+    expect(queue.size()).toBe(1); // no new task
+  });
+
+  it('should treat enqueued recurring tasks as regular tasks', () => {
+    vi.useFakeTimers({ now: new Date('2026-01-01T00:00:00Z') });
+    const queue = new TaskQueue();
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: 'recurring-task',
+      priority: 1,
+    });
+
+    queue.tick();
+    const task = queue.next()!;
+    expect(task.payload).toBe('recurring-task');
+    expect(task.priority).toBe(1);
+
+    queue.complete(task.id);
+    expect(task.status).toBe('completed');
+  });
+});
