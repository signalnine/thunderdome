esults).toEqual(['default-mw', 'default-handler', 'emails-mw', 'emails-handler']);\n  });\n\n  it('should complete the task after successful processing', async () => {\n    const queue = new TaskQueue();\n    queue.registerHandler({ handler: () => {} });\n\n    queue.add('task');\n    const task = queue.next()!;\n    await queue.process(task.id);\n\n    expect(task.status).toBe('completed');\n  });\n\n  it('should mark task as failed if handler throws', async () => {\n    const queue = new TaskQueue();\n    queue.registerHandler({ handler: () => { throw new Error('handler error'); } });\n\n    queue.add('task', { maxRetries: 0 });\n    const task = queue.next()!;\n    await queue.process(task.id);\n\n    expect(task.status).toBe('failed');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":569,"cache_read_input_tokens":115181,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":569},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4d41520d-00c6-4a20-9375-7ce9d900f299","uuid":"211d0eaa-375e-4bd5-ab79-a121684c013e"}
