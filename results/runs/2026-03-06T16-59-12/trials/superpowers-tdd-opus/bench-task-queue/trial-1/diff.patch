@@ -0,0 +1,67 @@
+import { describe, it, expect } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  it('should return a task object with id, status, and createdAt when adding a task', () => {
+    const queue = new TaskQueue();
+    const task = queue.add({ type: 'email', to: 'user@test.com' });
+
+    expect(task.id).toBeDefined();
+    expect(typeof task.id).toBe('string');
+    expect(task.id.length).toBeGreaterThan(0);
+    expect(task.status).toBe('pending');
+    expect(task.payload).toEqual({ type: 'email', to: 'user@test.com' });
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should assign unique IDs to each task', () => {
+    const queue = new TaskQueue();
+    const task1 = queue.add('payload1');
+    const task2 = queue.add('payload2');
+
+    expect(task1.id).not.toBe(task2.id);
+  });
+
+  it('should retrieve the oldest pending task and transition it to processing', () => {
+    const queue = new TaskQueue();
+    const task1 = queue.add('first');
+    queue.add('second');
+
+    const retrieved = queue.next();
+
+    expect(retrieved).not.toBeNull();
+    expect(retrieved!.id).toBe(task1.id);
+    expect(retrieved!.status).toBe('processing');
+    expect(retrieved!.payload).toBe('first');
+  });
+
+  it('should return null when no tasks are available', () => {
+    const queue = new TaskQueue();
+    const retrieved = queue.next();
+    expect(retrieved).toBeNull();
+  });
+
+  it('should return tasks in FIFO order', () => {
+    const queue = new TaskQueue();
+    queue.add('first');
+    queue.add('second');
+    queue.add('third');
+
+    expect(queue.next()!.payload).toBe('first');
+    expect(queue.next()!.payload).toBe('second');
+    expect(queue.next()!.payload).toBe('third');
+    expect(queue.next()).toBeNull();
+  });
+
+  it('should report the number of pending tasks', () => {
+    const queue = new TaskQueue();
+    expect(queue.size()).toBe(0);
+
+    queue.add('task1');
+    queue.add('task2');
+    expect(queue.size()).toBe(2);
+
+    queue.next();
+    expect(queue.size()).toBe(1);
+  });
+});
