+import { describe, it, expect } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  it('should register a handler for a queue', async () => {
+    const queue = new TaskQueue();
+    const results: string[] = [];
+    queue.registerHandler({ handler: (task) => { results.push(task.payload as string); } });
+
+    queue.add('hello');
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(results).toEqual(['hello']);
+  });
+
+  it('should register middleware that runs before the handler', async () => {
+    const queue = new TaskQueue();
+    const order: string[] = [];
+
+    queue.use((task, next) => {
+      order.push('middleware');
+      next();
+    });
+    queue.registerHandler({ handler: () => { order.push('handler'); } });
+
+    queue.add('task');
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(order).toEqual(['middleware', 'handler']);
+  });
+
+  it('should pass through multiple middleware in order', async () => {
+    const queue = new TaskQueue();
+    const order: string[] = [];
+
+    queue.use((_task, next) => { order.push('m1'); next(); });
+    queue.use((_task, next) => { order.push('m2'); next(); });
+    queue.use((_task, next) => { order.push('m3'); next(); });
+    queue.registerHandler({ handler: () => { order.push('handler'); } });
+
+    queue.add('task');
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(order).toEqual(['m1', 'm2', 'm3', 'handler']);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const queue = new TaskQueue();
+    const order: string[] = [];
+
+    queue.use((_task, _next) => { order.push('blocker'); /* not calling next */ });
+    queue.registerHandler({ handler: () => { order.push('handler'); } });
+
+    queue.add('task');
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(order).toEqual(['blocker']);
+  });
+
+  it('should allow middleware to modify the task', async () => {
+    const queue = new TaskQueue();
+    let receivedPayload: unknown;
+
+    queue.use((task, next) => {
+      (task as Record<string, unknown>).payload = (task.payload as string).toUpperCase();
+      next();
+    });
+    queue.registerHandler({ handler: (task) => { receivedPayload = task.payload; } });
+
+    queue.add('hello');
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(receivedPayload).toBe('HELLO');
+  });
+
+  it('should mark the task as failed if middleware throws', async () => {
+    const queue = new TaskQueue();
+
+    queue.use(() => { throw new Error('middleware error'); });
+    queue.registerHandler({ handler: () => {} });
+
+    queue.add('task', { maxRetries: 0 });
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(task.status).toBe('failed');
+    expect(task.lastError?.message).toBe('middleware error');
+  });
+
+  it('should have independent middleware stacks per queue', async () => {
+    const queue = new TaskQueue();
+    const results: string[] = [];
+
+    queue.use((_task, next) => { results.push('default-mw'); next(); }, { queue: 'default' });
+    queue.use((_task, next) => { results.push('emails-mw'); next(); }, { queue: 'emails' });
+    queue.registerHandler({ handler: () => { results.push('default-handler'); } });
+    queue.registerHandler({ queue: 'emails', handler: () => { results.push('emails-handler'); } });
+
+    queue.add('t1');
+    queue.add('t2', { queue: 'emails' });
+
+    await queue.process(queue.next()!.id);
+    await queue.process(queue.next({ queue: 'emails' })!.id);
+
+    expect(results).toEqual(['default-mw', 'default-handler', 'emails-mw', 'emails-handler']);
+  });
+
+  it('should complete the task after successful processing', async () => {
+    const queue = new TaskQueue();
+    queue.registerHandler({ handler: () => {} });
+
+    queue.add('task');
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(task.status).toBe('completed');
+  });
+
+  it('should mark task as failed if handler throws', async () => {
+    const queue = new TaskQueue();
+    queue.registerHandler({ handler: () => { throw new Error('handler error'); } });
+
+    queue.add('task', { maxRetries: 0 });
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(task.status).toBe('failed');
+  });
+});
