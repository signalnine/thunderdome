+import { describe, it, expect, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should reject new tasks after shutdown is initiated', async () => {
+    const queue = new TaskQueue();
+    await queue.shutdown();
+
+    expect(() => queue.add('new-task')).toThrow();
+  });
+
+  it('should complete immediately if no tasks are processing', async () => {
+    const queue = new TaskQueue();
+    const result = await queue.shutdown();
+
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(result.shutdownTime).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should wait for processing tasks to finish', async () => {
+    const queue = new TaskQueue();
+    queue.add('task1');
+    const task = queue.next()!;
+
+    // Start shutdown in background, complete the task, then shutdown resolves
+    const shutdownPromise = queue.shutdown({ timeout: 5000 });
+
+    // Complete the task while shutdown is waiting
+    queue.complete(task.id);
+
+    const result = await shutdownPromise;
+    expect(result.completed).toBe(1);
+    expect(result.forceCancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks that exceed the timeout', async () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1');
+    queue.next(); // start processing
+
+    const shutdownPromise = queue.shutdown({ timeout: 1000 });
+
+    // Advance time past timeout
+    vi.advanceTimersByTime(1001);
+
+    const result = await shutdownPromise;
+    expect(result.forceCancelled).toBe(1);
+    expect(result.completed).toBe(0);
+  });
+
+  it('should call shutdown callbacks', async () => {
+    const queue = new TaskQueue();
+    const callbacks: string[] = [];
+
+    queue.onShutdown(() => { callbacks.push('callback1'); });
+    queue.onShutdown(() => { callbacks.push('callback2'); });
+
+    await queue.shutdown();
+    expect(callbacks).toEqual(['callback1', 'callback2']);
+  });
+
+  it('should return the same result when shutdown is called multiple times', async () => {
+    const queue = new TaskQueue();
+    const result1 = await queue.shutdown();
+    const result2 = await queue.shutdown();
+
+    expect(result1).toEqual(result2);
+  });
+
+  it('should report shutdown time', async () => {
+    const queue = new TaskQueue();
+    const result = await queue.shutdown();
+
+    expect(typeof result.shutdownTime).toBe('number');
+    expect(result.shutdownTime).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should include summary of completed and force-cancelled tasks', async () => {
+    const queue = new TaskQueue();
+    queue.add('task1');
+    queue.add('task2');
+    const task1 = queue.next()!;
+    queue.next()!; // task2 processing
+
+    queue.complete(task1.id);
+    // task2 is still processing when we shutdown with 0 timeout
+
+    const result = await queue.shutdown({ timeout: 0 });
+    expect(result.completed).toBe(1);
+    expect(result.forceCancelled).toBe(1);
+  });
+});
