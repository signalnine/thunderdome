diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..afc61eb
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,532 @@
+import { randomUUID } from 'node:crypto';
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+const DEFAULT_QUEUE = 'default';
+const DEFAULT_PRIORITY = 5;
+const DEFAULT_MAX_RETRIES = 3;
+const DEFAULT_BACKOFF_DELAY = 1000;
+
+export interface Task<T = unknown> {
+  id: string;
+  status: TaskStatus;
+  payload: T;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date | null;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  lastError: Error | null;
+  dependencies: string[];
+}
+
+export interface AddOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface NextOptions {
+  queue?: string;
+}
+
+export interface SizeOptions {
+  queue?: string;
+}
+
+export interface QueueOptions {
+  queue?: string;
+}
+
+export type ProgressListener = (percent: number, message?: string) => void;
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  payload: unknown;
+  queue: string;
+  priority: number;
+  lastFiredAt: string | null; // "YYYY-MM-DD HH:MM" to prevent double-fire
+}
+
+export type MiddlewareFn = (task: Task, next: () => void) => void;
+export type HandlerFn = (task: Task) => void | Promise<void>;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  shutdownTime: number;
+}
+
+export interface ScheduleOptions {
+  cron: string;
+  payload: unknown;
+  queue?: string;
+  priority?: number;
+}
+
+export class TaskQueue {
+  private queues: Map<string, Task[]> = new Map();
+  private taskIndex: Map<string, Task> = new Map();
+  private deadLetterQueues: Map<string, Task[]> = new Map();
+  private concurrencyLimits: Map<string, number> = new Map();
+  private progressData: Map<string, { percent: number; message?: string }> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private middlewareStacks: Map<string, MiddlewareFn[]> = new Map();
+  private handlers: Map<string, HandlerFn> = new Map();
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void> = [];
+  private completionListeners: Array<() => void> = [];
+
+  private getOrCreateQueue(name: string): Task[] {
+    let q = this.queues.get(name);
+    if (!q) {
+      q = [];
+      this.queues.set(name, q);
+    }
+    return q;
+  }
+
+  add<T>(payload: T, options?: AddOptions): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Queue is shut down. Cannot add new tasks.');
+    }
+    const queueName = options?.queue ?? DEFAULT_QUEUE;
+    const priority = options?.priority ?? DEFAULT_PRIORITY;
+    const dependencies = options?.dependencies ?? [];
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Validate dependencies exist
+    for (const depId of dependencies) {
+      if (!this.taskIndex.has(depId)) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    let availableAt: Date | null = null;
+    if (options?.processAt) {
+      availableAt = options.processAt;
+    } else if (options?.delay != null) {
+      availableAt = new Date(Date.now() + options.delay);
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      status: 'pending',
+      payload,
+      createdAt: new Date(),
+      queue: queueName,
+      priority,
+      availableAt,
+      attempts: 0,
+      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,
+      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,
+      lastError: null,
+      dependencies,
+    };
+    const q = this.getOrCreateQueue(queueName);
+    q.push(task as Task);
+    this.taskIndex.set(task.id, task as Task);
+    return task;
+  }
+
+  private areDependenciesMet(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.taskIndex.get(depId);
+      if (!dep || dep.status !== 'completed') return false;
+    }
+    return true;
+  }
+
+  private isAvailable(task: Task): boolean {
+    if (task.status !== 'pending') return false;
+    if (task.availableAt && task.availableAt.getTime() > Date.now()) return false;
+    if (!this.areDependenciesMet(task)) return false;
+    return true;
+  }
+
+  private getActiveCount(queueName: string): number {
+    const q = this.queues.get(queueName);
+    if (!q) return 0;
+    return q.filter(t => t.status === 'processing').length;
+  }
+
+  next(options?: NextOptions): Task | null {
+    const queueName = options?.queue ?? DEFAULT_QUEUE;
+    const q = this.queues.get(queueName);
+    if (!q) return null;
+
+    // Check concurrency limit
+    const limit = this.concurrencyLimits.get(queueName);
+    if (limit != null && this.getActiveCount(queueName) >= limit) {
+      return null;
+    }
+
+    const available = q.filter(t => this.isAvailable(t));
+    if (available.length === 0) return null;
+
+    available.sort((a, b) => {
+      const aTime = a.availableAt?.getTime() ?? 0;
+      const bTime = b.availableAt?.getTime() ?? 0;
+      if (aTime !== bTime) return aTime - bTime;
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = available[0];
+    task.status = 'processing';
+    task.attempts++;
+    return task;
+  }
+
+  complete(taskId: string): void {
+    const task = this.taskIndex.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') throw new Error(`Task is not processing: ${taskId}`);
+    task.status = 'completed';
+    this.notifyCompletionListeners();
+  }
+
+  fail(taskId: string, error: Error): void {
+    const task = this.taskIndex.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') throw new Error(`Task is not processing: ${taskId}`);
+
+    task.lastError = error;
+
+    const retriesUsed = task.attempts - 1;
+    if (retriesUsed < task.maxRetries) {
+      const delay = task.backoffDelay * Math.pow(2, retriesUsed);
+      task.availableAt = new Date(Date.now() + delay);
+      task.status = 'pending';
+    } else {
+      task.status = 'failed';
+      this.addToDeadLetterQueue(task);
+      this.notifyCompletionListeners();
+    }
+  }
+
+  private notifyCompletionListeners(): void {
+    const listeners = this.completionListeners.slice();
+    for (const listener of listeners) {
+      listener();
+    }
+  }
+
+  private addToDeadLetterQueue(task: Task): void {
+    let dlq = this.deadLetterQueues.get(task.queue);
+    if (!dlq) {
+      dlq = [];
+      this.deadLetterQueues.set(task.queue, dlq);
+    }
+    dlq.push(task);
+  }
+
+  getDeadLetterQueue(options?: QueueOptions): Task[] {
+    const queueName = options?.queue ?? DEFAULT_QUEUE;
+    return this.deadLetterQueues.get(queueName) ?? [];
+  }
+
+  requeue(taskId: string): void {
+    const task = this.taskIndex.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'failed') throw new Error(`Task is not failed: ${taskId}`);
+
+    const dlq = this.deadLetterQueues.get(task.queue);
+    if (dlq) {
+      const idx = dlq.indexOf(task);
+      if (idx !== -1) dlq.splice(idx, 1);
+    }
+
+    task.status = 'pending';
+    task.attempts = 0;
+    task.availableAt = null;
+    task.lastError = null;
+  }
+
+  clearDeadLetterQueue(options?: QueueOptions): void {
+    const queueName = options?.queue ?? DEFAULT_QUEUE;
+    const dlq = this.deadLetterQueues.get(queueName);
+    if (dlq) {
+      dlq.length = 0;
+    }
+  }
+
+  getDependencyStatus(taskId: string): Record<string, TaskStatus> {
+    const task = this.taskIndex.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const result: Record<string, TaskStatus> = {};
+    for (const depId of task.dependencies) {
+      const dep = this.taskIndex.get(depId);
+      result[depId] = dep ? dep.status : 'failed';
+    }
+    return result;
+  }
+
+  setConcurrency(options: { queue?: string; limit: number }): void {
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    this.concurrencyLimits.set(queueName, options.limit);
+  }
+
+  getConcurrency(options?: QueueOptions): { limit: number | null; active: number } {
+    const queueName = options?.queue ?? DEFAULT_QUEUE;
+    const limit = this.concurrencyLimits.get(queueName) ?? null;
+    return { limit: limit as number, active: this.getActiveCount(queueName) };
+  }
+
+  updateProgress(taskId: string, percent: number, message?: string): void {
+    const task = this.taskIndex.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    this.progressData.set(taskId, { percent, message });
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(percent, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { percent: number; message?: string } | null {
+    return this.progressData.get(taskId) ?? null;
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    let listeners = this.progressListeners.get(taskId);
+    if (!listeners) {
+      listeners = new Set();
+      this.progressListeners.set(taskId, listeners);
+    }
+    listeners.add(listener);
+    return () => {
+      listeners!.delete(listener);
+    };
+  }
+
+  private cronMatches(cron: string, date: Date): boolean {
+    const parts = cron.split(' ');
+    if (parts.length !== 5) return false;
+
+    const [minutePart, hourPart] = parts;
+    const minute = date.getMinutes();
+    const hour = date.getHours();
+
+    const matchesField = (field: string, value: number): boolean => {
+      if (field === '*') return true;
+      if (field.startsWith('*/')) {
+        const interval = parseInt(field.slice(2), 10);
+        return value % interval === 0;
+      }
+      return parseInt(field, 10) === value;
+    };
+
+    return matchesField(minutePart, minute) && matchesField(hourPart, hour);
+  }
+
+  addSchedule(options: ScheduleOptions): string {
+    const id = randomUUID();
+    const schedule: Schedule = {
+      id,
+      cron: options.cron,
+      payload: options.payload,
+      queue: options.queue ?? DEFAULT_QUEUE,
+      priority: options.priority ?? DEFAULT_PRIORITY,
+      lastFiredAt: null,
+    };
+    this.schedules.set(id, schedule);
+    return id;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(): void {
+    const now = new Date();
+    const timeKey = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')} ${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
+
+    for (const schedule of this.schedules.values()) {
+      if (this.cronMatches(schedule.cron, now) && schedule.lastFiredAt !== timeKey) {
+        schedule.lastFiredAt = timeKey;
+        this.add(schedule.payload, {
+          queue: schedule.queue,
+          priority: schedule.priority,
+        });
+      }
+    }
+  }
+
+  use(middleware: MiddlewareFn, options?: QueueOptions): void {
+    const queueName = options?.queue ?? DEFAULT_QUEUE;
+    let stack = this.middlewareStacks.get(queueName);
+    if (!stack) {
+      stack = [];
+      this.middlewareStacks.set(queueName, stack);
+    }
+    stack.push(middleware);
+  }
+
+  registerHandler(options: { queue?: string; handler: HandlerFn }): void {
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    this.handlers.set(queueName, options.handler);
+  }
+
+  async process(taskId: string): Promise<void> {
+    const task = this.taskIndex.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const middlewares = this.middlewareStacks.get(task.queue) ?? [];
+    const handler = this.handlers.get(task.queue);
+
+    try {
+      let index = 0;
+
+      const runNext = (): void => {
+        if (index < middlewares.length) {
+          const mw = middlewares[index++];
+          mw(task, runNext);
+        } else if (handler) {
+          handler(task);
+        }
+      };
+
+      if (middlewares.length > 0) {
+        const mw = middlewares[index++];
+        mw(task, runNext);
+      } else if (handler) {
+        handler(task);
+      }
+
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (error) {
+      this.fail(task.id, error instanceof Error ? error : new Error(String(error)));
+    }
+  }
+
+  cancel(taskId: string): void {
+    const task = this.taskIndex.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in ${task.status} state`);
+    }
+    task.status = 'cancelled';
+  }
+
+  onShutdown(callback: () => void): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  private getAllProcessingTasks(): Task[] {
+    const processing: Task[] = [];
+    for (const q of this.queues.values()) {
+      for (const task of q) {
+        if (task.status === 'processing') {
+          processing.push(task);
+        }
+      }
+    }
+    return processing;
+  }
+
+  async shutdown(options?: { timeout?: number }): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    const startTime = Date.now();
+    const timeout = options?.timeout ?? 30000;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      cb();
+    }
+
+    this.shutdownPromise = new Promise<ShutdownResult>((resolve) => {
+      const finalize = () => {
+        let completed = 0;
+        let forceCancelled = 0;
+
+        // Count completed tasks across all queues
+        for (const q of this.queues.values()) {
+          for (const task of q) {
+            if (task.status === 'completed') completed++;
+          }
+        }
+
+        // Force-cancel any still processing
+        const stillProcessing = this.getAllProcessingTasks();
+        for (const task of stillProcessing) {
+          task.status = 'cancelled';
+          forceCancelled++;
+        }
+
+        resolve({
+          completed,
+          forceCancelled,
+          shutdownTime: Date.now() - startTime,
+        });
+      };
+
+      const processing = this.getAllProcessingTasks();
+      if (processing.length === 0) {
+        finalize();
+        return;
+      }
+
+      // Set up timeout
+      const timer = setTimeout(() => {
+        // Remove completion listener
+        const idx = this.completionListeners.indexOf(checkDone);
+        if (idx !== -1) this.completionListeners.splice(idx, 1);
+        finalize();
+      }, timeout);
+
+      const checkDone = () => {
+        const remaining = this.getAllProcessingTasks();
+        if (remaining.length === 0) {
+          clearTimeout(timer);
+          const idx = this.completionListeners.indexOf(checkDone);
+          if (idx !== -1) this.completionListeners.splice(idx, 1);
+          finalize();
+        }
+      };
+
+      this.completionListeners.push(checkDone);
+    });
+
+    return this.shutdownPromise;
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.taskIndex.get(taskId);
+  }
+
+  size(options?: SizeOptions): number {
+    const queueName = options?.queue ?? DEFAULT_QUEUE;
+    const q = this.queues.get(queueName);
+    if (!q) return 0;
+    return q.filter(t => t.status === 'pending').length;
+  }
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+}
