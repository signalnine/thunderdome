 queue.complete(task2.id);\n\n    // Now task3 should be available\n    expect(queue.next()!.id).toBe(task3.id);\n  });\n\n  it('should detect direct circular dependencies', () => {\n    const queue = new TaskQueue();\n    const task1 = queue.add('task1');\n\n    // Can't depend on yourself (well, not directly testable since task1 is already added)\n    // Let's test A -> B -> A\n    const task2 = queue.add('task2', { dependencies: [task1.id] });\n    expect(() => queue.add('task3', { dependencies: [task2.id, task1.id] })).not.toThrow();\n  });\n\n  it('should detect circular dependencies', () => {\n    const queue = new TaskQueue();\n    const task1 = queue.add('task1');\n    const task2 = queue.add('task2', { dependencies: [task1.id] });\n\n    // Can't create a task that task1 depends on if task2 depends on task1\n    // Actually, we need to test: task3 depends on task2, then try to make task1 depend on task3\n    // But task1 is already added... So let's build the cycle differently.\n    // A depends on C, B depends on A, C depends on B — C would create cycle\n    const taskA = queue.add('A');\n    const taskB = queue.add('B', { dependencies: [taskA.id] });\n    expect(() => queue.add('C', { dependencies: [taskB.id] })).not.toThrow();\n    const taskC = queue.add('C2', { dependencies: [taskB.id] });\n    // Now if we try to add D that depends on taskC, and taskA depends on taskC — but taskA already exists\n    // Let's just do: A->B->C->A cycle at creation\n  });\n\n  it('should reject circular dependencies at creation time', () => {\n    const queue = new TaskQueue();\n    const taskA = queue.add('A');\n    const taskB = queue.add('B', { dependencies: [taskA.id] });\n    const taskC = queue.add('C', { dependencies: [taskB.id] });\n\n    // Now trying to add a task that taskA depends on taskC would be a cycle\n    // But taskA already exists. So instead: add taskD that depends on taskC,\n    // then add taskE that depends on taskD and taskA — that's not a cycle.\n    // The real cycle test: create three tasks where the last creates a back-edge.\n\n    // Build: X depends on Z, Y depends on X. Now Z depends on Y would be cycle.\n    // But Z is already created. We need to build it differently.\n    // Actually, we just need: task that has deps forming a cycle at creation time.\n    // E.g., A -> B -> C, then D that depends on [C] with a dep back to A?\n    // No. The cycle is: if we add taskD with dependencies including taskC,\n    // and taskC depends (transitively) on something that depends on taskD.\n    // But taskD doesn't exist yet so nothing can depend on it.\n    // Cycles can only form if we allow adding deps to existing tasks.\n\n    // Self-dependency:\n    // We can't add self-dependency directly since task doesn't exist yet.\n    // But we can test: the system properly rejects tasks with deps that form a cycle.\n    // Actually, with immutable deps at creation time, cycles can't form naturally\n    // because you can only depend on tasks that already exist.\n    // Unless we pass a non-existent ID. Let's test that:\n\n    expect(() => queue.add('D', { dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  it('should error when depending on a non-existent task', () => {\n    const queue = new TaskQueue();\n    expect(() => queue.add('task1', { dependencies: ['fake-id'] })).toThrow();\n  });\n\n  it('should not automatically fail dependents when a dependency fails', () => {\n    const queue = new TaskQueue();\n    const task1 = queue.add('task1', { maxRetries: 0 });\n    const task2 = queue.add('task2', { dependencies: [task1.id] });\n\n    queue.next(); // process task1\n    queue.fail(task1.id, new Error('fail'));\n\n    // task2 remains blocked, NOT failed\n    expect(task2.status).toBe('pending');\n    // But it should be blocked - next should return null\n    expect(queue.next()).toBeNull();\n  });\n\n  it('should provide dependency status inspection', () => {\n    const queue = new TaskQueue();\n    const task1 = queue.add('task1');\n    const task2 = queue.add('task2');\n    const task3 = queue.add('task3', { dependencies: [task1.id, task2.id] });\n\n    const depStatus = queue.getDependencyStatus(task3.id);\n    expect(depStatus).toEqual({\n      [task1.id]: 'pending',\n      [task2.id]: 'pending',\n    });\n\n    queue.next();\n    queue.complete(task1.id);\n\n    const depStatus2 = queue.getDependencyStatus(task3.id);\n    expect(depStatus2[task1.id]).toBe('completed');\n    expect(depStatus2[task2.id]).toBe('pending');\n  });\n\n  it('should work with named queues', () => {\n    const queue = new TaskQueue();\n    const task1 = queue.add('task1', { queue: 'myqueue' });\n    const task2 = queue.add('task2', { queue: 'myqueue', dependencies: [task1.id] });\n\n    expect(queue.next({ queue: 'myqueue' })!.id).toBe(task1.id);\n    expect(queue.next({ queue: 'myqueue' })).toBeNull();\n\n    queue.complete(task1.id);\n    expect(queue.next({ queue: 'myqueue' })!.id).toBe(task2.id);\n  });\n\n  it('should allow cross-queue dependencies', () => {\n    const queue = new TaskQueue();\n    const task1 = queue.add('task1', { queue: 'queue1' });\n    const task2 = queue.add('task2', { queue: 'queue2', dependencies: [task1.id] });\n\n    expect(queue.next({ queue: 'queue2' })).toBeNull();\n\n    queue.next({ queue: 'queue1' });\n    queue.complete(task1.id);\n\n    expect(queue.next({ queue: 'queue2' })!.id).toBe(task2.id);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":569,"cache_read_input_tokens":71128,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":569},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4d41520d-00c6-4a20-9375-7ce9d900f299","uuid":"015a4e47-7f76-48c6-9fc8-0461fdbb7529"}
