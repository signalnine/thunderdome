+import { describe, it, expect, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should move a task to DLQ when all retries are exhausted', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 0 });
+
+    const task = queue.next()!;
+    queue.fail(task.id, new Error('permanent failure'));
+
+    const dlq = queue.getDeadLetterQueue();
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].id).toBe(task.id);
+  });
+
+  it('should retain error information on dead-lettered tasks', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 0 });
+
+    const task = queue.next()!;
+    queue.fail(task.id, new Error('permanent failure'));
+
+    const dlq = queue.getDeadLetterQueue();
+    expect(dlq[0].lastError).toBeInstanceOf(Error);
+    expect(dlq[0].lastError!.message).toBe('permanent failure');
+  });
+
+  it('should track failure count on dead-lettered tasks', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 1, backoffDelay: 100 });
+
+    let task = queue.next()!;
+    queue.fail(task.id, new Error('fail 1'));
+    vi.advanceTimersByTime(100);
+
+    task = queue.next()!;
+    queue.fail(task.id, new Error('fail 2'));
+
+    const dlq = queue.getDeadLetterQueue();
+    expect(dlq[0].attempts).toBe(2);
+  });
+
+  it('should have independent DLQ per named queue', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('email', { queue: 'emails', maxRetries: 0 });
+    queue.add('sms', { queue: 'sms', maxRetries: 0 });
+
+    queue.fail(queue.next({ queue: 'emails' })!.id, new Error('fail'));
+    queue.fail(queue.next({ queue: 'sms' })!.id, new Error('fail'));
+
+    const emailDlq = queue.getDeadLetterQueue({ queue: 'emails' });
+    const smsDlq = queue.getDeadLetterQueue({ queue: 'sms' });
+
+    expect(emailDlq).toHaveLength(1);
+    expect(emailDlq[0].payload).toBe('email');
+    expect(smsDlq).toHaveLength(1);
+    expect(smsDlq[0].payload).toBe('sms');
+  });
+
+  it('should allow requeuing a dead-lettered task', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 0 });
+
+    const task = queue.next()!;
+    queue.fail(task.id, new Error('fail'));
+
+    expect(queue.getDeadLetterQueue()).toHaveLength(1);
+    queue.requeue(task.id);
+
+    expect(queue.getDeadLetterQueue()).toHaveLength(0);
+    const requeued = queue.next()!;
+    expect(requeued.id).toBe(task.id);
+    expect(requeued.status).toBe('processing');
+  });
+
+  it('should clear all dead-lettered tasks for a queue', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 0 });
+    queue.add('task2', { maxRetries: 0 });
+
+    queue.fail(queue.next()!.id, new Error('fail'));
+    queue.fail(queue.next()!.id, new Error('fail'));
+
+    expect(queue.getDeadLetterQueue()).toHaveLength(2);
+    queue.clearDeadLetterQueue();
+    expect(queue.getDeadLetterQueue()).toHaveLength(0);
+  });
+
+  it('should clear DLQ only for the specified queue', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('email', { queue: 'emails', maxRetries: 0 });
+    queue.add('sms', { queue: 'sms', maxRetries: 0 });
+
+    queue.fail(queue.next({ queue: 'emails' })!.id, new Error('fail'));
+    queue.fail(queue.next({ queue: 'sms' })!.id, new Error('fail'));
+
+    queue.clearDeadLetterQueue({ queue: 'emails' });
+    expect(queue.getDeadLetterQueue({ queue: 'emails' })).toHaveLength(0);
+    expect(queue.getDeadLetterQueue({ queue: 'sms' })).toHaveLength(1);
+  });
+});
