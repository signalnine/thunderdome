@@ -0,0 +1,155 @@
+import { describe, it, expect, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should mark a processing task as completed', () => {
+    const queue = new TaskQueue();
+    queue.add('task1');
+    const task = queue.next()!;
+
+    queue.complete(task.id);
+    expect(task.status).toBe('completed');
+  });
+
+  it('should mark a processing task as failed', () => {
+    const queue = new TaskQueue();
+    queue.add('task1');
+    const task = queue.next()!;
+
+    queue.fail(task.id, new Error('something broke'));
+    // With default 3 retries, task should be re-queued (pending with a delay)
+    expect(task.status).toBe('pending');
+  });
+
+  it('should retry a failed task with exponential backoff delay', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 3, backoffDelay: 1000 });
+
+    // First attempt
+    const task1 = queue.next()!;
+    queue.fail(task1.id, new Error('fail'));
+
+    // Task should be re-queued with delay = 1000 * 2^0 = 1000
+    expect(task1.status).toBe('pending');
+    expect(task1.attempts).toBe(1);
+    expect(queue.next()).toBeNull(); // still delayed
+
+    vi.advanceTimersByTime(1000);
+    const task2 = queue.next()!;
+    expect(task2.id).toBe(task1.id);
+    expect(task2.status).toBe('processing');
+  });
+
+  it('should use exponential backoff: 1s, 2s, 4s', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 3, backoffDelay: 1000 });
+
+    // Attempt 1
+    let task = queue.next()!;
+    queue.fail(task.id, new Error('fail'));
+    expect(task.attempts).toBe(1);
+
+    // Backoff: 1000 * 2^0 = 1000ms
+    vi.advanceTimersByTime(1000);
+    task = queue.next()!;
+    queue.fail(task.id, new Error('fail'));
+    expect(task.attempts).toBe(2);
+
+    // Backoff: 1000 * 2^1 = 2000ms
+    vi.advanceTimersByTime(1999);
+    expect(queue.next()).toBeNull();
+    vi.advanceTimersByTime(1);
+    task = queue.next()!;
+    queue.fail(task.id, new Error('fail'));
+    expect(task.attempts).toBe(3);
+
+    // Backoff: 1000 * 2^2 = 4000ms
+    vi.advanceTimersByTime(4000);
+    task = queue.next()!;
+    queue.fail(task.id, new Error('fail'));
+
+    // Now all 3 retries are exhausted (4 total attempts), task should be failed
+    expect(task.status).toBe('failed');
+    expect(task.attempts).toBe(4);
+  });
+
+  it('should default to 3 retries', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    const addedTask = queue.add('task1');
+    expect(addedTask.maxRetries).toBe(3);
+  });
+
+  it('should default backoff delay to 1000ms', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1');
+    const task = queue.next()!;
+    queue.fail(task.id, new Error('fail'));
+
+    // With default 1000ms backoff, not available before 1000ms
+    expect(queue.next()).toBeNull();
+    vi.advanceTimersByTime(1000);
+    expect(queue.next()).not.toBeNull();
+  });
+
+  it('should allow configurable maxRetries per task', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 1, backoffDelay: 100 });
+
+    let task = queue.next()!;
+    queue.fail(task.id, new Error('fail'));
+    expect(task.status).toBe('pending'); // retry available
+
+    vi.advanceTimersByTime(100);
+    task = queue.next()!;
+    queue.fail(task.id, new Error('fail again'));
+    expect(task.status).toBe('failed'); // no more retries
+  });
+
+  it('should track attempt count', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 2, backoffDelay: 100 });
+
+    const task = queue.next()!;
+    expect(task.attempts).toBe(1);
+
+    queue.fail(task.id, new Error('fail'));
+    vi.advanceTimersByTime(100);
+    queue.next();
+    expect(task.attempts).toBe(2);
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { queue: 'emails', priority: 2, maxRetries: 1, backoffDelay: 100 });
+
+    const task = queue.next({ queue: 'emails' })!;
+    queue.fail(task.id, new Error('fail'));
+
+    vi.advanceTimersByTime(100);
+    const retried = queue.next({ queue: 'emails' })!;
+    expect(retried.id).toBe(task.id);
+    expect(retried.priority).toBe(2);
+    expect(retried.queue).toBe('emails');
+  });
+
+  it('should remain in failed state when all retries exhausted', () => {
+    vi.useFakeTimers();
+    const queue = new TaskQueue();
+    queue.add('task1', { maxRetries: 0 });
+
+    const task = queue.next()!;
+    queue.fail(task.id, new Error('fail'));
+    expect(task.status).toBe('failed');
+  });
+});
