+describe('Phase 3: Priority', () => {
+  it('should default priority to 5', () => {
+    const queue = new TaskQueue();
+    const task = queue.add('payload');
+    expect(task.priority).toBe(5);
+  });
+
+  it('should accept a priority level from 1-10', () => {
+    const queue = new TaskQueue();
+    const task = queue.add('payload', { priority: 1 });
+    expect(task.priority).toBe(1);
+  });
+
+  it('should reject priority values outside 1-10', () => {
+    const queue = new TaskQueue();
+    expect(() => queue.add('payload', { priority: 0 })).toThrow();
+    expect(() => queue.add('payload', { priority: 11 })).toThrow();
+    expect(() => queue.add('payload', { priority: -1 })).toThrow();
+  });
+
+  it('should return higher-priority tasks first', () => {
+    const queue = new TaskQueue();
+    queue.add('low', { priority: 10 });
+    queue.add('high', { priority: 1 });
+    queue.add('medium', { priority: 5 });
+
+    expect(queue.next()!.payload).toBe('high');
+    expect(queue.next()!.payload).toBe('medium');
+    expect(queue.next()!.payload).toBe('low');
+  });
+
+  it('should use FIFO order for same priority', () => {
+    const queue = new TaskQueue();
+    queue.add('first', { priority: 3 });
+    queue.add('second', { priority: 3 });
+    queue.add('third', { priority: 3 });
+
+    expect(queue.next()!.payload).toBe('first');
+    expect(queue.next()!.payload).toBe('second');
+    expect(queue.next()!.payload).toBe('third');
+  });
+
+  it('should operate priority per-queue', () => {
+    const queue = new TaskQueue();
+    queue.add('email-low', { queue: 'emails', priority: 10 });
+    queue.add('email-high', { queue: 'emails', priority: 1 });
+    queue.add('sms-low', { queue: 'sms', priority: 10 });
+    queue.add('sms-high', { queue: 'sms', priority: 1 });
+
+    expect(queue.next({ queue: 'emails' })!.payload).toBe('email-high');
+    expect(queue.next({ queue: 'sms' })!.payload).toBe('sms-high');
+  });
+});
