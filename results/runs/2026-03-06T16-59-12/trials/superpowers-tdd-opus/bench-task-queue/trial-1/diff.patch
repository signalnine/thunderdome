@@ -0,0 +1,79 @@
+import { describe, it, expect } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 2: Named Queues', () => {
+  it('should add tasks to a named queue', () => {
+    const queue = new TaskQueue();
+    const task = queue.add('payload', { queue: 'emails' });
+
+    expect(task.status).toBe('pending');
+    expect(task.payload).toBe('payload');
+  });
+
+  it('should use a default queue when no name is given', () => {
+    const queue = new TaskQueue();
+    queue.add('default-task');
+    queue.add('email-task', { queue: 'emails' });
+
+    const defaultTask = queue.next();
+    expect(defaultTask!.payload).toBe('default-task');
+  });
+
+  it('should keep named queues independent', () => {
+    const queue = new TaskQueue();
+    queue.add('email1', { queue: 'emails' });
+    queue.add('sms1', { queue: 'sms' });
+
+    const emailTask = queue.next({ queue: 'emails' });
+    expect(emailTask!.payload).toBe('email1');
+
+    const smsTask = queue.next({ queue: 'sms' });
+    expect(smsTask!.payload).toBe('sms1');
+  });
+
+  it('should return null for a non-existent queue', () => {
+    const queue = new TaskQueue();
+    expect(queue.next({ queue: 'nonexistent' })).toBeNull();
+  });
+
+  it('should return null for an empty queue', () => {
+    const queue = new TaskQueue();
+    queue.add('task', { queue: 'myqueue' });
+    queue.next({ queue: 'myqueue' });
+
+    expect(queue.next({ queue: 'myqueue' })).toBeNull();
+  });
+
+  it('should list all queue names', () => {
+    const queue = new TaskQueue();
+    queue.add('t1', { queue: 'emails' });
+    queue.add('t2', { queue: 'sms' });
+    queue.add('t3');
+
+    const names = queue.listQueues();
+    expect(names).toContain('emails');
+    expect(names).toContain('sms');
+    expect(names).toContain('default');
+  });
+
+  it('should be backward-compatible with Phase 1 API', () => {
+    const queue = new TaskQueue();
+    queue.add('task1');
+    queue.add('task2');
+
+    expect(queue.size()).toBe(2);
+    expect(queue.next()!.payload).toBe('task1');
+    expect(queue.size()).toBe(1);
+  });
+
+  it('should report size per queue', () => {
+    const queue = new TaskQueue();
+    queue.add('t1', { queue: 'emails' });
+    queue.add('t2', { queue: 'emails' });
+    queue.add('t3', { queue: 'sms' });
+
+    expect(queue.size({ queue: 'emails' })).toBe(2);
+    expect(queue.size({ queue: 'sms' })).toBe(1);
+    expect(queue.size({ queue: 'nonexistent' })).toBe(0);
+  });
+});
