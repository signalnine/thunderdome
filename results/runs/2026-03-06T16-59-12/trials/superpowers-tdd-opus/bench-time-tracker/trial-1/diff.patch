@@ -0,0 +1,155 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import fs from 'node:fs';
+import os from 'node:os';
+import path from 'node:path';
+import { TimeTracker } from './tracker.js';
+
+let tmpDir: string;
+let filePath: string;
+
+beforeEach(() => {
+  tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'timetracker-test-'));
+  filePath = path.join(tmpDir, 'data.json');
+});
+
+afterEach(() => {
+  fs.rmSync(tmpDir, { recursive: true, force: true });
+});
+
+describe('TimeTracker', () => {
+  it('can be constructed with a file path', () => {
+    const tracker = new TimeTracker(filePath);
+    expect(tracker).toBeInstanceOf(TimeTracker);
+  });
+
+  it('start creates an entry with task name and start time', () => {
+    const tracker = new TimeTracker(filePath);
+    const before = Date.now();
+    tracker.start('coding');
+    const after = Date.now();
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].task).toBe('coding');
+    expect(entries[0].start).toBeGreaterThanOrEqual(before);
+    expect(entries[0].start).toBeLessThanOrEqual(after);
+    expect(entries[0].end).toBeNull();
+  });
+
+  it('start throws error on empty name', () => {
+    const tracker = new TimeTracker(filePath);
+    expect(() => tracker.start('')).toThrow();
+    expect(() => tracker.start('   ')).toThrow();
+  });
+
+  it('stop records end time on the running entry', () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start('coding');
+    const before = Date.now();
+    tracker.stop();
+    const after = Date.now();
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].end).toBeGreaterThanOrEqual(before);
+    expect(entries[0].end).toBeLessThanOrEqual(after);
+  });
+
+  it('stop throws error when nothing is running', () => {
+    const tracker = new TimeTracker(filePath);
+    expect(() => tracker.stop()).toThrow();
+  });
+
+  it('starting a new timer auto-stops the previous one', () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start('task1');
+    tracker.start('task2');
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(2);
+    expect(entries[0].task).toBe('task1');
+    expect(entries[0].end).not.toBeNull();
+    expect(entries[1].task).toBe('task2');
+    expect(entries[1].end).toBeNull();
+  });
+
+  it('persists entries to JSON file and loads them back', () => {
+    const tracker1 = new TimeTracker(filePath);
+    tracker1.start('coding');
+    tracker1.stop();
+    tracker1.save();
+
+    const tracker2 = new TimeTracker(filePath);
+    tracker2.load();
+    const entries = tracker2.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].task).toBe('coding');
+    expect(entries[0].end).not.toBeNull();
+  });
+
+  it('creates parent directories automatically when saving', () => {
+    const nestedPath = path.join(tmpDir, 'a', 'b', 'c', 'data.json');
+    const tracker = new TimeTracker(nestedPath);
+    tracker.start('coding');
+    tracker.stop();
+    tracker.save();
+    expect(fs.existsSync(nestedPath)).toBe(true);
+  });
+
+  it('filters entries by date range', () => {
+    const tracker = new TimeTracker(filePath);
+    // Manually set entries with known timestamps
+    const now = Date.now();
+    const oneHourAgo = now - 3600000;
+    const twoHoursAgo = now - 7200000;
+    const threeHoursAgo = now - 10800000;
+
+    // Write entries directly via file to set specific timestamps
+    const entries = [
+      { task: 'old', start: threeHoursAgo, end: twoHoursAgo },
+      { task: 'recent', start: oneHourAgo, end: now },
+    ];
+    fs.writeFileSync(filePath, JSON.stringify(entries));
+    tracker.load();
+
+    const filtered = tracker.getEntries({ from: twoHoursAgo, to: now });
+    expect(filtered).toHaveLength(1);
+    expect(filtered[0].task).toBe('recent');
+  });
+
+  it('summarizes total time per task in milliseconds', () => {
+    const tracker = new TimeTracker(filePath);
+    const now = Date.now();
+    const entries = [
+      { task: 'coding', start: now - 5000, end: now - 3000 },  // 2000ms
+      { task: 'coding', start: now - 2000, end: now - 1000 },  // 1000ms
+      { task: 'review', start: now - 4000, end: now - 1000 },  // 3000ms
+    ];
+    fs.writeFileSync(filePath, JSON.stringify(entries));
+    tracker.load();
+
+    const summary = tracker.getSummary();
+    expect(summary).toEqual({ coding: 3000, review: 3000 });
+  });
+
+  it('summary includes running tasks using current time', () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start('coding');
+    // The running task should have a duration based on current time
+    const summary = tracker.getSummary();
+    expect(summary['coding']).toBeGreaterThanOrEqual(0);
+  });
+
+  it('supports unicode and emoji task names', () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start('コーディング 🚀');
+    tracker.stop();
+    tracker.save();
+
+    const tracker2 = new TimeTracker(filePath);
+    tracker2.load();
+    const entries = tracker2.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].task).toBe('コーディング 🚀');
+
+    const summary = tracker2.getSummary();
+    expect(summary['コーディング 🚀']).toBeGreaterThanOrEqual(0);
+  });
+});
