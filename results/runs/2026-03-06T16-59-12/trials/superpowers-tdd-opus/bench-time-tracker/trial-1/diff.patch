--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,72 @@
+import fs from 'node:fs';
+import path from 'node:path';
+
+export interface TimeEntry {
+  task: string;
+  start: number;
+  end: number | null;
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[] = [];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+  }
+
+  start(task: string): void {
+    if (!task.trim()) {
+      throw new Error('Task name must not be empty');
+    }
+    const running = this.entries.find(e => e.end === null);
+    if (running) {
+      running.end = Date.now();
+    }
+    this.entries.push({ task, start: Date.now(), end: null });
+  }
+
+  stop(): void {
+    const running = this.entries.find(e => e.end === null);
+    if (!running) {
+      throw new Error('No timer is currently running');
+    }
+    running.end = Date.now();
+  }
+
+  save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), 'utf-8');
+  }
+
+  load(): void {
+    if (fs.existsSync(this.filePath)) {
+      const data = fs.readFileSync(this.filePath, 'utf-8');
+      this.entries = JSON.parse(data) as TimeEntry[];
+    }
+  }
+
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    for (const entry of this.entries) {
+      const end = entry.end ?? Date.now();
+      const duration = end - entry.start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+    return summary;
+  }
+
+  getEntries(filter?: { from?: number; to?: number }): TimeEntry[] {
+    let result = [...this.entries];
+    if (filter) {
+      if (filter.from !== undefined) {
+        result = result.filter(e => e.start >= filter.from!);
+      }
+      if (filter.to !== undefined) {
+        result = result.filter(e => e.start <= filter.to!);
+      }
+    }
+    return result;
+  }
+}
