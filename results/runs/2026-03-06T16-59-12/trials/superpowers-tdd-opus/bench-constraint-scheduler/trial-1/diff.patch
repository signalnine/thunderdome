index 0000000..9675e38
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,78 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+  const gap = options.gap ?? 15;
+
+  // Track next available time per room
+  const roomNextAvailable = new Map<string, number>();
+  for (const room of rooms) {
+    roomNextAvailable.set(room.id, options.startTime);
+  }
+
+  for (const event of events) {
+    const attendees = event.attendees ?? 1;
+    let assigned = false;
+
+    for (const room of rooms) {
+      if (attendees > room.capacity) continue;
+
+      const start = roomNextAvailable.get(room.id)!;
+      const end = start + event.duration;
+
+      if (end > options.endTime) continue;
+
+      assignments.push({
+        eventId: event.id,
+        roomId: room.id,
+        startTime: start,
+        endTime: end,
+      });
+      roomNextAvailable.set(room.id, end + gap);
+      assigned = true;
+      break;
+    }
+
+    if (!assigned) {
+      unscheduled.push(event.id);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
diff --git a/src/scheduler.test.ts b/src/scheduler.test.ts
new file mode 100644
index 0000000..1beb85d
--- /dev/null
+++ b/src/scheduler.test.ts
@@ -0,0 +1,73 @@
+import { describe, it, expect } from 'vitest';
+import { schedule } from './index';
+
+describe('schedule', () => {
+  it('returns assignments and unscheduled arrays for empty input', () => {
+    const result = schedule([], [], { startTime: 540, endTime: 1020 });
+    expect(result).toHaveProperty('assignments');
+    expect(result).toHaveProperty('unscheduled');
+    expect(result.assignments).toEqual([]);
+    expect(result.unscheduled).toEqual([]);
+  });
+
+  it('schedules a single event into a single room', () => {
+    const events = [{ id: 'e1', name: 'Talk', duration: 60 }];
+    const rooms = [{ id: 'r1', name: 'Room A', capacity: 10 }];
+    const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });
+
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toEqual([]);
+
+    const a = result.assignments[0];
+    expect(a.eventId).toBe('e1');
+    expect(a.roomId).toBe('r1');
+    expect(a.startTime).toBe(540);
+    expect(a.endTime).toBe(600);
+  });
+
+  it('rejects event when attendees exceed all room capacities', () => {
+    const events = [{ id: 'e1', name: 'Big Talk', duration: 60, attendees: 50 }];
+    const rooms = [{ id: 'r1', name: 'Small Room', capacity: 10 }];
+    const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });
+
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('assigns event to room with sufficient capacity, skipping too-small rooms', () => {
+    const events = [{ id: 'e1', name: 'Talk', duration: 60, attendees: 20 }];
+    const rooms = [
+      { id: 'r1', name: 'Small', capacity: 10 },
+      { id: 'r2', name: 'Large', capacity: 50 },
+    ];
+    const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });
+
+    expect(result.assignments).toHaveLength(1);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('rejects event that does not fit within time window', () => {
+    // Window is only 30 minutes, event is 60
+    const events = [{ id: 'e1', name: 'Long Talk', duration: 60 }];
+    const rooms = [{ id: 'r1', name: 'Room A', capacity: 10 }];
+    const result = schedule(events, rooms, { startTime: 540, endTime: 570 });
+
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toEqual(['e1']);
+  });
+
+  it('enforces gap between events in the same room', () => {
+    const events = [
+      { id: 'e1', name: 'Talk 1', duration: 30 },
+      { id: 'e2', name: 'Talk 2', duration: 30 },
+    ];
+    const rooms = [{ id: 'r1', name: 'Room A', capacity: 10 }];
+    const result = schedule(events, rooms, { startTime: 540, endTime: 1020, gap: 10 });
+
+    expect(result.assignments).toHaveLength(2);
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    // Second event must start at least gap minutes after first ends
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 10);
+  });
+});
