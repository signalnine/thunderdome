s first 20 results\n  it('Pagination: page=1 returns first 20 results', async () => {\n    // Search for a common term that appears in many notes\n    const res = await request(appCtx.app).get('/notes/search?q=the&page=1');\n    expect(res.status).toBe(200);\n    expect(res.body.results.length).toBeLessThanOrEqual(20);\n    expect(res.body.page).toBe(1);\n    expect(res.body.perPage).toBe(20);\n  });\n\n  // 11. Pagination: page=2 returns next results\n  it('Pagination: page=2 returns next results', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=the&page=2');\n    expect(res.status).toBe(200);\n    expect(res.body.page).toBe(2);\n    // Page 2 may have fewer or no results depending on total count\n    expect(Array.isArray(res.body.results)).toBe(true);\n  });\n\n  // 12. Pagination response includes total count\n  it('Pagination response includes total count', async () => {\n    const res = await request(appCtx.app).get('/notes/search?q=programming');\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty('total');\n    expect(typeof res.body.total).toBe('number');\n    expect(res.body.total).toBeGreaterThan(0);\n  });\n\n  // 13. GET /notes/search/suggest?q=prefix returns up to 5 titles\n  it('GET /notes/search/suggest?q=prefix returns up to 5 titles', async () => {\n    const res = await request(appCtx.app).get('/notes/search/suggest?q=learn');\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.body.results)).toBe(true);\n    expect(res.body.results.length).toBeLessThanOrEqual(5);\n    expect(res.body.results.length).toBeGreaterThan(0);\n  });\n\n  // 14. Suggest results match prefix in title\n  it('Suggest results match prefix in title', async () => {\n    const res = await request(appCtx.app).get('/notes/search/suggest?q=getting');\n    expect(res.status).toBe(200);\n    expect(res.body.results.length).toBeGreaterThan(0);\n    // The result should include the \"Getting Started with TypeScript\" note\n    const titles = res.body.results.map((r: { title: string }) => r.title.toLowerCase());\n    expect(titles.some((t: string) => t.includes('getting'))).toBe(true);\n  });\n\n  // 15. GET /notes/search/suggest?q= returns 400\n  it('GET /notes/search/suggest?q= returns 400', async () => {\n    const res = await request(appCtx.app).get('/notes/search/suggest?q=');\n    expect(res.status).toBe(400);\n  });\n\n  // 16. FTS syncs on create - new note appears in search\n  it('FTS syncs on create - new note appears in search', async () => {\n    // Create a note with a unique term\n    await request(appCtx.app)\n      .post('/notes')\n      .send({ title: 'Zylophone Dynamics', body: 'The zylophone produces unique harmonics and overtones.' });\n\n    const res = await request(appCtx.app).get('/notes/search?q=zylophone');\n    expect(res.status).toBe(200);\n    expect(res.body.results.length).toBe(1);\n    expect(res.body.results[0].title).toBe('Zylophone Dynamics');\n  });\n\n  // 17. FTS syncs on update - updated content appears in search\n  it('FTS syncs on update - updated content appears in search', async () => {\n    // Create a note\n    const createRes = await request(appCtx.app)\n      .post('/notes')\n      .send({ title: 'Original Title', body: 'Original content about elephants.' });\n    const noteId = createRes.body.note.id;\n\n    // Update it with unique content\n    await request(appCtx.app)\n      .put(`/notes/${noteId}`)\n      .send({ title: 'Updated Title', body: 'Updated content about xylographics.' });\n\n    // Search for the new content\n    const searchNew = await request(appCtx.app).get('/notes/search?q=xylographics');\n    expect(searchNew.body.results.length).toBe(1);\n\n    // Search for the old content - should not find it\n    const searchOld = await request(appCtx.app).get('/notes/search?q=elephants');\n    expect(searchOld.body.results.length).toBe(0);\n  });\n\n  // 18. FTS syncs on delete - deleted note disappears from search\n  it('FTS syncs on delete - deleted note disappears from search', async () => {\n    // Create a note with unique content\n    const createRes = await request(appCtx.app)\n      .post('/notes')\n      .send({ title: 'Temporary Note', body: 'Quizzaciously unique content for deletion test.' });\n    const noteId = createRes.body.note.id;\n\n    // Verify it appears in search\n    let searchRes = await request(appCtx.app).get('/notes/search?q=quizzaciously');\n    expect(searchRes.body.results.length).toBe(1);\n\n    // Delete it\n    await request(appCtx.app).delete(`/notes/${noteId}`);\n\n    // Verify it no longer appears in search\n    searchRes = await request(appCtx.app).get('/notes/search?q=quizzaciously');\n    expect(searchRes.body.results.length).toBe(0);\n  });\n\n  // 19. Special characters in query don't crash\n  it(\"Special characters in query don't crash\", async () => {\n    const specialQueries = [\n      '/notes/search?q=hello%20world',\n      '/notes/search?q=test%26test',\n      '/notes/search?q=it%27s',\n      '/notes/search?q=%3Cscript%3E',\n      '/notes/search?q=foo%2Bbar',\n      '/notes/search?q=a%2Fb',\n    ];\n\n    for (const url of specialQueries) {\n      const res = await request(appCtx.app).get(url);\n      // Should return 200 (search endpoint exists and handles special chars gracefully)\n      expect(res.status).toBe(200);\n      expect(Array.isArray(res.body.results)).toBe(true);\n    }\n  });\n\n  // 20. Search response time under 100ms for seeded dataset\n  it('Search response time under 100ms for seeded dataset', async () => {\n    const start = performance.now();\n    const res = await request(appCtx.app).get('/notes/search?q=programming');\n    const elapsed = performance.now() - start;\n\n    expect(res.status).toBe(200);\n    expect(elapsed).toBeLessThan(100);\n  });\n});\n","numLines":234,"startLine":1,"totalLines":234}}}
