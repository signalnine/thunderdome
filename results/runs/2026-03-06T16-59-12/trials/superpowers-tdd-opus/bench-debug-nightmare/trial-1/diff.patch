ecifically tests that we don't double-round\n    48→    const result = calculateOrderTotal(\n    49→      [{ productId: 'A', quantity: 1, unitPrice: 33.33 }],\n    50→      5,\n    51→      0.07\n    52→    );\n    53→    // subtotal = 33.33\n    54→    // discount = 33.33 * 0.05 = 1.6665\n    55→    // after discount = 31.6635\n    56→    // tax = 31.6635 * 0.07 = 2.21644...\n    57→    // total = 33.87994... -> 33.88\n    58→    expect(result.total).toBe(33.88);\n    59→  });\n    60→});\n    61→\n    62→describe('BillingService', () => {\n    63→  let bus: EventBus;\n    64→  let notifications: NotificationService;\n    65→  let billing: BillingService;\n    66→\n    67→  beforeEach(() => {\n    68→    bus = new EventBus();\n    69→    notifications = new NotificationService();\n    70→    billing = new BillingService(bus, notifications);\n    71→    billing.registerHandlers();\n    72→  });\n    73→\n    74→  it('charges payment and records it', async () => {\n    75→    const record = await billing.chargePayment(\n    76→      'O1',\n    77→      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n    78→      0,\n    79→      0.1,\n    80→      'card'\n    81→    );\n    82→    expect(record.amount).toBe(110);\n    83→    expect(record.status).toBe('charged');\n    84→    expect(record.method).toBe('card');\n    85→  });\n    86→\n    87→  it('sends confirmation notification on charge', async () => {\n    88→    await billing.chargePayment(\n    89→      'O1',\n    90→      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n    91→      0,\n    92→      0.1,\n    93→      'card'\n    94→    );\n    95→    const sent = notifications.getSentNotifications();\n    96→    expect(sent).toHaveLength(1);\n    97→    expect(sent[0].type).toBe('confirmation');\n    98→    expect(sent[0].message).toContain('O1');\n    99→  });\n   100→\n   101→  it('issues refund and updates payment status', async () => {\n   102→    await billing.chargePayment(\n   103→      'O1',\n   