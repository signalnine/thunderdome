e event\n    44→    // The order service attaches items to the cancellation event\n    45→    const eventWithItems = data as OrderCancelledEvent & {\n    46→      items?: Array<{ productId: string; quantity: number }>;\n    47→      status?: string;\n    48→    };\n    49→\n    50→    if (eventWithItems.status !== 'cancelled') return;\n    51→\n    52→    if (eventWithItems.items) {\n    53→      for (const item of eventWithItems.items) {\n    54→        this.repo.release(item.productId, item.quantity);\n    55→      }\n    56→    }\n    57→\n    58→    await this.eventBus.emit(ORDER_EVENTS.STOCK_RELEASED, {\n    59→      orderId: event.orderId,\n    60→      timestamp: Date.now(),\n    61→    });\n    62→  }\n    63→\n    64→  setStock(productId: string, quantity: number): void {\n    65→    this.repo.setStock(productId, quantity);\n    66→  }\n    67→\n    68→  getStock(productId: string) {\n    69→    return this.repo.getStock(productId);\n    70→  }\n    71→}\n    72→"}]},"parent_tool_use_id":null,"session_id":"b11b2da2-5630-4014-9d3f-79f8c31df277","uuid":"a347f71c-09a0-425c-a890-69f5e4c4f527","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/inventory/service.ts","content":"import { EventBus } from '../events/bus.js';\nimport { ORDER_EVENTS, OrderCreatedEvent, OrderCancelledEvent } from '../events/types.js';\nimport { InventoryRepository } from './repository.js';\n\nexport class InventoryService {\n  constructor(\n    private repo: InventoryRepository,\n    private eventBus: EventBus\n  ) {}\n\n  registerHandlers(): void {\n    this.eventBus.on(ORDER_EVENTS.CREATED, this.handleOrderCreated.bind(this));\n    this.eventBus.on(ORDER_EVENTS.CANCELLED, this.handleOrderCancelled.bind(this));\n  }\n\n  private async handleOrderCreated(data: unknown): Promise<void> {\n    const event = data as OrderCreatedEvent;\n    const reservations: Array<{ productId: string; quantity: number }> = [];\n\n    for (const item of event.items) {\n      const success =