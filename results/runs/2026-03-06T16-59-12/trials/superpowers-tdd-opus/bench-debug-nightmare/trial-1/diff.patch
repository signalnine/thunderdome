+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U75dPfmS2iXgPXHwtFhbZR","type":"tool_result","content":"     1→export type EventHandler = (data: unknown) => void | Promise<void>;\n     2→\n     3→// Module-level handler registry — shared across all EventBus instances\n     4→const globalHandlers: Map<string, EventHandler[]> = new Map();\n     5→\n     6→export class EventBus {\n     7→  on(event: string, handler: EventHandler): void {\n     8→    const existing = globalHandlers.get(event) ?? [];\n     9→    existing.push(handler);\n    10→    globalHandlers.set(event, existing);\n    11→  }\n    12→\n    13→  off(event: string, handler: EventHandler): void {\n    14→    const existing = globalHandlers.get(event);\n    15→    if (!existing) return;\n    16→    globalHandlers.set(\n    17→      event,\n    18→      existing.filter((h) => h !== handler)\n    19→    );\n    20→  }\n    21→\n    22→  async emit(event: string, data: unknown): Promise<void> {\n    23→    const handlers = globalHandlers.get(event) ?? [];\n    24→    for (const handler of handlers) {\n    25→      await handler(data);\n    26→    }\n    27→  }\n    28→\n    29→  clear(): void {\n    30→    globalHandlers.clear();\n    31→  }\n    32→}\n    33→"}]},"parent_tool_use_id":"toolu_012JudXgUfqkp1KhLssAGUKV","session_id":"b11b2da2-5630-4014-9d3f-79f8c31df277","uuid":"74bb6c1e-c8a7-4b36-88c3-382eab131515"}
