otificationRecord {\n    51→    const template = this.templates.get('order.refunded')!;\n    52→    const message = template\n    53→      .replace('{orderId}', orderId)\n    54→      .replace('{amount}', amount.toFixed(2));\n    55→    const record: NotificationRecord = {\n    56→      type: 'refund',\n    57→      orderId,\n    58→      message,\n    59→      sentAt: Date.now(),\n    60→    };\n    61→    this.sent.push(record);\n    62→    return record;\n    63→  }\n    64→\n    65→  getSentNotifications(): NotificationRecord[] {\n    66→    return [...this.sent];\n    67→  }\n    68→\n    69→  clear(): void {\n    70→    this.sent = [];\n    71→  }\n    72→}\n    73→"}]},"parent_tool_use_id":null,"session_id":"b11b2da2-5630-4014-9d3f-79f8c31df277","uuid":"7b6bc53d-65eb-4017-ab9a-812a721c8daa","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/notifications/service.ts","content":"export interface NotificationRecord {\n  type: string;\n  orderId: string;\n  message: string;\n  sentAt: number;\n}\n\nexport class NotificationService {\n  private templates: Map<string, string>;\n  private sent: NotificationRecord[] = [];\n\n  constructor() {\n    this.templates = new Map([\n      ['order.confirmed', 'Your order {orderId} has been confirmed. Total: ${total}'],\n      ['order.cancelled', 'Your order {orderId} has been cancelled. Reason: {reason}'],\n      ['order.refunded', 'Your refund of ${amount} for order {orderId} has been processed.'],\n    ]);\n  }\n\n  sendConfirmation(orderId: string, total: number): NotificationRecord {\n    const template = this.templates.get('order.confirmed')!;\n    const message = template\n      .replace('{orderId}', orderId)\n      .replace('{total}', total.toFixed(2));\n    const record: NotificationRecord = {\n      type: 'confirmation',\n      orderId,\n      message,\n      sentAt: Date.now(),\n    };\n    this.sent.push(record);\n    return record;\n  }\n\n  sendCancellation(orderId: string, reason: string): NotificationRecord {\n    const template = this.templates.get('order.cancelled')!;\n    const message = template\n      .replace('{orderId}', orderId)\n      .replace('{reason}', reason);\n    const record: NotificationRecord = {\n      type: 'cancellation',\n      orderId,\n      message,\n      sentAt: Date.now(),\n    };\n    this.sent.push(record);\n    return record;\n  }\n\n  sendRefundNotice(orderId: string, amount: number): NotificationRecord {\n    const template = this.templates.get('order.refunded')!;\n    const message = template\n      .replace('{orderId}', orderId)\n      .replace('{amount}', amount.toFixed(2));\n    const record: NotificationRecord = {\n      type: 'refund',\n      orderId,\n      message,\n      sentAt: Date.now(),\n    };\n    this.sent.push(record);\n    return record;\n  }\n\n  getSentNotifications(): NotificationRecord[] {\n    return [...this.sent];\n  }\n\n  clear(): void {\n    this.sent = [];\n  }\n}\n","numLines":73,"startLine":1,"totalLines":73}}}
