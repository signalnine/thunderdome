+++ b/tests/phase07-dependencies.test.ts
@@ -0,0 +1,134 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should block task with unresolved dependencies', () => {
+    const dep = tqs.addTask('dependency');
+    tqs.addTask('dependent', { dependencies: [dep.id] });
+
+    // dependent should not be returned because dep is not completed
+    // First, skip the dependency task
+    const next = tqs.getNextTask();
+    expect(next?.payload).toBe('dependency');
+
+    // Now the dependent is the only pending task but it's blocked
+    expect(tqs.getNextTask()).toBeNull();
+  });
+
+  it('should unblock task when dependencies complete', () => {
+    const dep = tqs.addTask('dependency');
+    tqs.addTask('dependent', { dependencies: [dep.id] });
+
+    const depTask = tqs.getNextTask();
+    tqs.completeTask(depTask!.id);
+
+    const dependent = tqs.getNextTask();
+    expect(dependent?.payload).toBe('dependent');
+  });
+
+  it('should support multiple dependencies', () => {
+    const dep1 = tqs.addTask('dep1');
+    const dep2 = tqs.addTask('dep2');
+    tqs.addTask('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    // Process dep1
+    const d1 = tqs.getNextTask();
+    tqs.completeTask(d1!.id);
+
+    // dependent still blocked
+    const d2 = tqs.getNextTask();
+    expect(d2?.payload).toBe('dep2');
+
+    // Still blocked
+    expect(tqs.getNextTask()).toBeNull();
+
+    // Complete dep2
+    tqs.completeTask(d2!.id);
+
+    // Now dependent is available
+    const dep = tqs.getNextTask();
+    expect(dep?.payload).toBe('dependent');
+  });
+
+  it('should reject circular dependencies', () => {
+    const t1 = tqs.addTask('t1');
+    const t2 = tqs.addTask('t2', { dependencies: [t1.id] });
+
+    expect(() =>
+      tqs.addTask('t3', { dependencies: [t2.id] })
+    ).not.toThrow();
+
+    // Now try to create a circular dependency
+    // t1 has no deps, t2 depends on t1, t3 depends on t2
+    // t4 depends on t3 - that's fine
+    // But if we try to add a task that t1 would depend on something depending on t1...
+    // We can't add deps to existing tasks, but we can detect cycles at creation time
+  });
+
+  it('should reject dependency on non-existent task', () => {
+    expect(() =>
+      tqs.addTask('test', { dependencies: ['nonexistent'] })
+    ).toThrow();
+  });
+
+  it('should keep dependents blocked when dependency fails', () => {
+    const dep = tqs.addTask('dependency', { maxRetries: 0 });
+    tqs.addTask('dependent', { dependencies: [dep.id] });
+
+    const d = tqs.getNextTask();
+    tqs.failTask(d!.id, 'error');
+
+    // Dependent remains blocked because dep is not completed
+    expect(tqs.getNextTask()).toBeNull();
+  });
+
+  it('should inspect dependency status', () => {
+    const dep1 = tqs.addTask('dep1');
+    const dep2 = tqs.addTask('dep2');
+    const dependent = tqs.addTask('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    let status = tqs.getDependencyStatus(dependent.id);
+    expect(status.total).toBe(2);
+    expect(status.completed).toBe(0);
+    expect(status.pending.length).toBe(2);
+
+    // Complete dep1
+    const d1 = tqs.getNextTask();
+    tqs.completeTask(d1!.id);
+
+    status = tqs.getDependencyStatus(dependent.id);
+    expect(status.completed).toBe(1);
+    expect(status.pending.length).toBe(1);
+  });
+
+  it('should handle chain of dependencies', () => {
+    const t1 = tqs.addTask('step1');
+    const t2 = tqs.addTask('step2', { dependencies: [t1.id] });
+    const t3 = tqs.addTask('step3', { dependencies: [t2.id] });
+
+    // Only t1 should be available
+    const s1 = tqs.getNextTask();
+    expect(s1?.payload).toBe('step1');
+    expect(tqs.getNextTask()).toBeNull();
+
+    tqs.completeTask(s1!.id);
+
+    const s2 = tqs.getNextTask();
+    expect(s2?.payload).toBe('step2');
+    expect(tqs.getNextTask()).toBeNull();
+
+    tqs.completeTask(s2!.id);
+
+    const s3 = tqs.getNextTask();
+    expect(s3?.payload).toBe('step3');
+
+    // Verify no cycle detection throws for valid chain
+    expect(t3.dependencies).toEqual([t2.id]);
+  });
+});
