+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should run middleware before handler', async () => {
+    const order: string[] = [];
+
+    tqs.use('default', async (_task, next) => {
+      order.push('middleware1');
+      await next();
+    });
+
+    tqs.process('default', async () => {
+      order.push('handler');
+    });
+
+    tqs.addTask('test');
+    await tqs.processNext();
+
+    expect(order).toEqual(['middleware1', 'handler']);
+  });
+
+  it('should run multiple middleware in order', async () => {
+    const order: string[] = [];
+
+    tqs.use('default', async (_task, next) => {
+      order.push('mw1-before');
+      await next();
+      order.push('mw1-after');
+    });
+
+    tqs.use('default', async (_task, next) => {
+      order.push('mw2-before');
+      await next();
+      order.push('mw2-after');
+    });
+
+    tqs.process('default', async () => {
+      order.push('handler');
+    });
+
+    tqs.addTask('test');
+    await tqs.processNext();
+
+    expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const order: string[] = [];
+
+    tqs.use('default', async () => {
+      order.push('middleware-blocked');
+      // Does NOT call next
+    });
+
+    tqs.process('default', async () => {
+      order.push('handler-should-not-run');
+    });
+
+    tqs.addTask('test');
+    await tqs.processNext();
+
+    expect(order).toEqual(['middleware-blocked']);
+  });
+
+  it('should allow middleware to modify the task', async () => {
+    tqs.use('default', async (task, next) => {
+      (task.payload as Record<string, unknown>).modified = true;
+      await next();
+    });
+
+    let receivedPayload: unknown;
+    tqs.process('default', async (task) => {
+      receivedPayload = task.payload;
+    });
+
+    tqs.addTask({ original: true });
+    await tqs.processNext();
+
+    expect(receivedPayload).toEqual({ original: true, modified: true });
+  });
+
+  it('should fail task if middleware throws', async () => {
+    tqs.use('default', async () => {
+      throw new Error('middleware error');
+    });
+
+    const task = tqs.addTask('test', { maxRetries: 0 });
+    await tqs.processNext();
+
+    const found = tqs.getTask(task.id);
+    expect(found?.status).toBe('failed');
+  });
+
+  it('should fail task if handler throws', async () => {
+    tqs.process('default', async () => {
+      throw new Error('handler error');
+    });
+
+    const task = tqs.addTask('test', { maxRetries: 0 });
+    await tqs.processNext();
+
+    const found = tqs.getTask(task.id);
+    expect(found?.status).toBe('failed');
+  });
+
+  it('should auto-complete task if no error', async () => {
+    tqs.process('default', async () => {
+      // Do nothing, no error
+    });
+
+    const task = tqs.addTask('test');
+    await tqs.processNext();
+
+    expect(task.status).toBe('completed');
+  });
+
+  it('should have independent middleware stacks per queue', async () => {
+    const order: string[] = [];
+
+    tqs.use('q1', async (_task, next) => {
+      order.push('q1-mw');
+      await next();
+    });
+
+    tqs.use('q2', async (_task, next) => {
+      order.push('q2-mw');
+      await next();
+    });
+
+    tqs.process('q1', async () => { order.push('q1-handler'); });
+    tqs.process('q2', async () => { order.push('q2-handler'); });
+
+    tqs.addTask('t1', { queueName: 'q1' });
+    tqs.addTask('t2', { queueName: 'q2' });
+
+    await tqs.processNext('q1');
+    await tqs.processNext('q2');
+
+    expect(order).toEqual(['q1-mw', 'q1-handler', 'q2-mw', 'q2-handler']);
+  });
+
+  it('should return null from processNext when no tasks available', async () => {
+    const result = await tqs.processNext();
+    expect(result).toBeNull();
+  });
+
+  it('should work without a handler', async () => {
+    tqs.use('default', async (task, next) => {
+      (task.payload as Record<string, unknown>).processed = true;
+      await next();
+    });
+
+    const task = tqs.addTask({ data: 'test' });
+    await tqs.processNext();
+
+    // Task should be completed (auto-complete after middleware)
+    expect(task.status).toBe('completed');
+  });
+});
