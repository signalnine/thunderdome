Idx = i;\n        break;\n      }\n    }\n    this.pending.splice(insertIdx, 0, task);\n  }\n\n  private compareTasks(a: TaskData, b: TaskData): number {\n    // Priority: lower number = higher priority\n    if (a.priority !== b.priority) {\n      return a.priority - b.priority;\n    }\n\n    // AvailableAt: null (immediately available) comes first, then by time\n    const aTime = a.availableAt ? a.availableAt.getTime() : 0;\n    const bTime = b.availableAt ? b.availableAt.getTime() : 0;\n    if (aTime !== bTime) {\n      return aTime - bTime;\n    }\n\n    // FIFO: earlier creation time first\n    return a.createdAt.getTime() - b.createdAt.getTime();\n  }\n\n  getNextTask(\n    now: Date,\n    areDependenciesMet: (task: TaskData) => boolean\n  ): TaskData | null {\n    // Check concurrency limit\n    if (this.concurrencyLimit !== null && this.processing.size >= this.concurrencyLimit) {\n      return null;\n    }\n\n    for (let i = 0; i < this.pending.length; i++) {\n      const task = this.pending[i];\n      if (!isTaskAvailable(task, now)) continue;\n      if (task.dependencies.length > 0 && !areDependenciesMet(task)) continue;\n\n      // Found an available task\n      this.pending.splice(i, 1);\n      updateTaskStatus(task, 'processing');\n      task.attempts++;\n      this.processing.set(task.id, task);\n      return task;\n    }\n\n    return null;\n  }\n\n  completeTask(taskId: string): TaskData | null {\n    const task = this.processing.get(taskId);\n    if (!task) return null;\n\n    updateTaskStatus(task, 'completed');\n    this.processing.delete(taskId);\n    return task;\n  }\n\n  failTask(taskId: string, error: Error | string): TaskData | null {\n    const task = this.processing.get(taskId);\n    if (!task) return null;\n\n    const errorMessage = error instanceof Error ? error.message : error;\n    task.errors.push({ message: errorMessage, timestamp: new Date() });\n    task.updatedAt = new Date();\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      updateTaskStatus(task, 'pending');\n      task.progress = 0;\n      task.progressMessage = undefined;\n      this.processing.delete(taskId);\n      this.insertSorted(task);\n      return task;\n    }\n\n    // No more retries - move to dead letter queue\n    updateTaskStatus(task, 'failed');\n    this.processing.delete(taskId);\n    this.deadLetter.push(task);\n    return task;\n  }\n\n  cancelTask(taskId: string): TaskData | null {\n    // Check pending\n    const pendingIdx = this.pending.findIndex(t => t.id === taskId);\n    if (pendingIdx !== -1) {\n      const task = this.pending[pendingIdx];\n      this.pending.splice(pendingIdx, 1);\n      updateTaskStatus(task, 'cancelled');\n      return task;\n    }\n\n    // Check processing\n    const task = this.processing.get(taskId);\n    if (task) {\n      updateTaskStatus(task, 'cancelled');\n      this.processing.delete(taskId);\n      return task;\n    }\n\n    return null;\n  }\n\n  getPendingCount(): number {\n    return this.pending.length;\n  }\n\n  getProcessingCount(): number {\n    return this.processing.size;\n  }\n\n  getProcessingTasks(): TaskData[] {\n    return Array.from(this.processing.values());\n  }\n\n  // Dead letter queue\n  getDeadLetterTasks(): TaskData[] {\n    return [...this.deadLetter];\n  }\n\n  removeFromDeadLetter(taskId: string): TaskData | null {\n    const idx = this.deadLetter.findIndex(t => t.id === taskId);\n    if (idx === -1) return null;\n    return this.deadLetter.splice(idx, 1)[0];\n  }\n\n  clearDeadLetterQueue(): void {\n    this.deadLetter = [];\n  }\n\n  // Concurrency\n  setConcurrencyLimit(limit: number | null): void {\n    this.concurrencyLimit = limit;\n  }\n\n  getConcurrencyLimit(): number | null {\n    return this.concurrencyLimit;\n  }\n\n  // Progress\n  updateProgress(taskId: string, progress: number, message?: string): boolean {\n    const task = this.processing.get(taskId);\n    if (!task) return false;\n\n    task.progress = progress;\n    task.progressMessage = message;\n    task.updatedAt = new Date();\n\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const cb of listeners) {\n        cb(progress, message);\n      }\n    }\n\n    return true;\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(callback);\n\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(callback);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  // Middleware\n  use(middleware: Middleware): void {\n    this.middlewares.push(middleware);\n  }\n\n  setHandler(handler: ProcessHandler): void {\n    this.handler = handler;\n  }\n\n  getMiddlewares(): Middleware[] {\n    return this.middlewares;\n  }\n\n  getHandler(): ProcessHandler | null {\n    return this.handler;\n  }\n\n  hasPendingTask(taskId: string): boolean {\n    return this.pending.some(t => t.id === taskId);\n  }\n\n  hasProcessingTask(taskId: string): boolean {\n    return this.processing.has(taskId);\n  }\n\n  findTask(taskId: string): TaskData | null {\n    const pending = this.pending.find(t => t.id === taskId);\n    if (pending) return pending;\n    const processing = this.processing.get(taskId);\n    if (processing) return processing;\n    const dl = this.deadLetter.find(t => t.id === taskId);\n    if (dl) return dl;\n    return null;\n  }\n}\n","numLines":246,"startLine":1,"totalLines":246}}}
