Tasks().length).toBe(1);\n\n    const retried = tqs.retryDeadLetterTask(task.id);\n    expect(retried.status).toBe('pending');\n    expect(retried.attempts).toBe(0);\n    expect(retried.errors.length).toBe(0);\n\n    expect(tqs.getDeadLetterTasks().length).toBe(0);\n    expect(tqs.getTaskCount()).toBe(1);\n  });\n\n  it('should clear dead letter queue for a queue', () => {\n    const t1 = tqs.addTask('d1', { maxRetries: 1, backoffDelay: 10 });\n    const t2 = tqs.addTask('d2', { maxRetries: 1, backoffDelay: 10 });\n\n    tqs.getNextTask();\n    tqs.failTask(t1.id, 'err');\n    tqs.getNextTask();\n    tqs.failTask(t2.id, 'err');\n\n    expect(tqs.getDeadLetterTasks().length).toBe(2);\n    tqs.clearDeadLetterQueue();\n    expect(tqs.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('should have independent DLQs per named queue', () => {\n    const t1 = tqs.addTask('d1', { queueName: 'q1', maxRetries: 1, backoffDelay: 10 });\n    const t2 = tqs.addTask('d2', { queueName: 'q2', maxRetries: 1, backoffDelay: 10 });\n\n    tqs.getNextTask('q1');\n    tqs.failTask(t1.id, 'err');\n    tqs.getNextTask('q2');\n    tqs.failTask(t2.id, 'err');\n\n    expect(tqs.getDeadLetterTasks('q1').length).toBe(1);\n    expect(tqs.getDeadLetterTasks('q2').length).toBe(1);\n\n    tqs.clearDeadLetterQueue('q1');\n    expect(tqs.getDeadLetterTasks('q1').length).toBe(0);\n    expect(tqs.getDeadLetterTasks('q2').length).toBe(1);\n  });\n\n  it('should return empty array for queue with no DLQ items', () => {\n    expect(tqs.getDeadLetterTasks()).toEqual([]);\n    expect(tqs.getDeadLetterTasks('nonexistent')).toEqual([]);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1603,"cache_read_input_tokens":45928,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1603},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_us