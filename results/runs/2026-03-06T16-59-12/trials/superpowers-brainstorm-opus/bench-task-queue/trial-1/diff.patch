+++ b/tests/phase05-retry.test.ts
@@ -0,0 +1,119 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should complete a processing task', () => {
+    const task = tqs.addTask('test');
+    tqs.getNextTask();
+    tqs.completeTask(task.id);
+    expect(task.status).toBe('completed');
+  });
+
+  it('should fail a processing task', () => {
+    const task = tqs.addTask('test', { maxRetries: 0 });
+    tqs.getNextTask();
+    tqs.failTask(task.id, new Error('oops'));
+    expect(task.status).toBe('failed');
+  });
+
+  it('should retry failed task with retries remaining', () => {
+    const task = tqs.addTask('test', { maxRetries: 3, backoffDelay: 100 });
+    tqs.getNextTask();
+    tqs.failTask(task.id, 'error');
+
+    // Task should be back in pending with a delay
+    expect(task.status).toBe('pending');
+    expect(task.attempts).toBe(1);
+    expect(task.availableAt).toBeInstanceOf(Date);
+  });
+
+  it('should use exponential backoff', () => {
+    const task = tqs.addTask('test', { maxRetries: 3, backoffDelay: 1000 });
+
+    // First attempt
+    tqs.getNextTask();
+    tqs.failTask(task.id, 'err1');
+    const delay1 = task.availableAt!.getTime() - Date.now();
+    expect(delay1).toBeGreaterThanOrEqual(900); // ~1000ms
+    expect(delay1).toBeLessThan(2000);
+
+    // Make available by overriding availableAt
+    task.availableAt = new Date(Date.now() - 1);
+
+    // Second attempt
+    tqs.getNextTask();
+    tqs.failTask(task.id, 'err2');
+    const delay2 = task.availableAt!.getTime() - Date.now();
+    expect(delay2).toBeGreaterThanOrEqual(1900); // ~2000ms
+    expect(delay2).toBeLessThan(3000);
+
+    // Make available
+    task.availableAt = new Date(Date.now() - 1);
+
+    // Third attempt - maxRetries=3, so this is the last
+    tqs.getNextTask();
+    tqs.failTask(task.id, 'err3');
+    expect(task.status).toBe('failed');
+  });
+
+  it('should default maxRetries to 3', () => {
+    const task = tqs.addTask('test');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should default backoffDelay to 1000', () => {
+    const task = tqs.addTask('test');
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  it('should track attempt count', () => {
+    const task = tqs.addTask('test', { maxRetries: 2, backoffDelay: 10 });
+
+    tqs.getNextTask();
+    expect(task.attempts).toBe(1);
+    tqs.failTask(task.id, 'err');
+    task.availableAt = new Date(Date.now() - 1);
+
+    tqs.getNextTask();
+    expect(task.attempts).toBe(2);
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    const task = tqs.addTask('test', {
+      queueName: 'myqueue',
+      priority: 2,
+      maxRetries: 3,
+      backoffDelay: 10,
+    });
+
+    tqs.getNextTask('myqueue');
+    tqs.failTask(task.id, 'err');
+
+    expect(task.queueName).toBe('myqueue');
+    expect(task.priority).toBe(2);
+  });
+
+  it('should record error information', () => {
+    const task = tqs.addTask('test', { maxRetries: 1, backoffDelay: 10 });
+    tqs.getNextTask();
+    tqs.failTask(task.id, new Error('something broke'));
+
+    expect(task.errors.length).toBe(1);
+    expect(task.errors[0].message).toBe('something broke');
+  });
+
+  it('should throw when completing a non-processing task', () => {
+    const task = tqs.addTask('test');
+    expect(() => tqs.completeTask(task.id)).toThrow();
+  });
+
+  it('should throw when completing a non-existent task', () => {
+    expect(() => tqs.completeTask('nonexistent')).toThrow();
+  });
+});
