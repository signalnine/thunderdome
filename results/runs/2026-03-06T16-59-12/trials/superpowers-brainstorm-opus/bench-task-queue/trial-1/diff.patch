+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pho11Pjn7e5itRezv7Njmv","type":"tool_result","content":"     1→import {\n     2→  type TaskData,\n     3→  type TaskOptions,\n     4→  type ProgressCallback,\n     5→  type Middleware,\n     6→  type ProcessHandler,\n     7→  type ScheduleOptions,\n     8→  type Schedule,\n     9→  type ShutdownOptions,\n    10→  type ShutdownResult,\n    11→  type ShutdownCallback,\n    12→  DEFAULT_QUEUE_NAME,\n    13→} from './types.js';\n    14→import { createTask } from './task.js';\n    15→import { Queue } from './queue.js';\n    16→import { Scheduler } from './scheduler.js';\n    17→\n    18→export class TaskQueueSystem {\n    19→  private queues: Map<string, Queue> = new Map();\n    20→  private allTasks: Map<string, TaskData> = new Map();\n    21→  private scheduler: Scheduler = new Scheduler();\n    22→  private isShuttingDown = false;\n    23→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    24→  private shutdownCallbacks: ShutdownCallback[] = [];\n    25→\n    26→  // ─── Phase 1: Basic FIFO Queue ──────────────────────────\n    27→\n    28→  addTask(payload: unknown, options: TaskOptions = {}): TaskData {\n    29→    if (this.isShuttingDown) {\n    30→      throw new Error('Cannot add tasks: system is shutting down.');\n    31→    }\n    32→\n    33→    const queueName = options.queueName ?? DEFAULT_QUEUE_NAME;\n    34→    const task = createTask(payload, { ...options, queueName });\n    35→\n    36→    // Phase 7: Validate dependencies\n    37→    if (task.dependencies.length > 0) {\n    38→      for (const depId of task.dependencies) {\n    39→        const dep = this.allTasks.get(depId);\n    40→        if (!dep) {\n    41→          throw new Error(`Dependency task \"${depId}\" does not exist.`);\n    42→        }\n    43→      }\n    44→      // Check for circular dependencies\n    45→      this.detectCircularDependencies(task.id, task.dependencies);\n    46→    }\n    47→\n    48→    this.allTasks.set(task.id, task);\n    49→    const queue = this.getOrCreateQueue(queueName);\n    50→    queue.addTask(task);\n    51→    return task;\n    52→  }\n    53→\n    54→  getNextTask(queueName?: string): TaskData | null {\n    55→    const name = queueName ?? DEFAULT_QUEUE_NAME;\n    56→    const queue = this.queues.get(name);\n    57→    if (!queue) return null;\n    58→\n    59→    const now = new Date();\n    60→    return queue.getNextTask(now, (task) => this.areDependenciesMet(task));\n    61→  }\n    62→\n    63→  getTaskCount(queueName?: string): number {\n    64→    const name = queueName ?? DEFAULT_QUEUE_NAME;\n    65→    const queue = this.queues.get(name);\n    66→    if (!queue) return 0;\n    67→    return queue.getPendingCount();\n    68→  }\n    69→\n    70→  getTask(taskId: string): TaskData | null {\n    71→    return this.allTasks.get(taskId) ?? null;\n    72→  }\n    73→\n    74→  // ─── Phase 2: Named Queues ──────────────────────────────\n    75→\n    76→  getQueueNames(): string[] {\n    77→    return Array.from(this.queues.keys());\n    78→  }\n    79→\n    80→  // ─── Phase 5: Complete / Fail ───────────────────────────\n    81→\n    82→  completeTask(taskId: string): void {\n    83→    const task = this.allTasks.get(taskId);\n    84→    if (!task) {\n    85→      throw new Error(`Task \"${taskId}\" not found.`);\n    86→    }\n    87→    if (task.status !== 'processing') {\n    88→      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status}).`);\n    89→    }\n    90→\n    91→    const queue = this.queues.get(task.queueName);\n    92→    if (!queue) {\n    93→      throw new Error(`Queue \"${task.queueName}\" not found.`);\n    94→    }\n    95→\n    96→    queue.completeTask(taskId);\n    97→\n    98→    // Phase 7: Check if any blocked tasks are now unblocked\n    99→    // (they remain in their queues but will now pass the dependency check)\n   100→  }\n   101→\n   102→  failTask(taskId: string, error: Error | string): void {\n   103→    const task = this.allTasks.get(taskId);\n   104→    if (!task) {\n   105→      throw new Error(`Task \"${taskId}\" not found.`);\n   106→    }\n   107→    if (task.status !== 'processing') {\n   108→      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status}).`);\n   109→    }\n   110→\n   111→    const queue = this.queues.get(task.queueName);\n   112→    if (!queue) {\n   113→      throw new Error(`Queue \"${task.queueName}\" not found.`);\n   114→    }\n   115→\n   116→    queue.failTask(taskId, error);\n   117→  }\n   118→\n   119→  // ─── Phase 6: Dead Letter Queue ────────────────────────\n   120→\n   121→  getDeadLetterTasks(queueName?: string): TaskData[] {\n   122→    const name = queueName ?? DEFAULT_QUEUE_NAME;\n   123→    const queue = this.queues.get(name);\n   124→    if (!queue) return [];\n   125→    return queue.getDeadLetterTasks();\n   126→  }\n   127→\n   128→  retryDeadLetterTask(taskId: string): TaskData {\n   129→    const task = this.allTasks.get(taskId);\n   130→    if (!task) {\n   131→      throw new Error(`Task \"${taskId}\" not found.`);\n   132→    }\n   133→    if (task.status !== 'failed') {\n   134→      throw new Error(`Task \"${taskId}\" is not in failed state.`);\n   135→    }\n   136→\n   137→    const queue = this.queues.get(task.queueName);\n   138→    if (!queue) {\n   139→      throw new Error(`Queue \"${task.queueName}\" not found.`);\n   140→    }\n   141→\n   142→    const removed = queue.removeFromDeadLetter(taskId);\n   143→    if (!removed) {\n   144→      throw new Error(`Task \"${taskId}\" not found in dead letter queue.`);\n   145→    }\n   146→\n   147→    // Reset for fresh retry\n   148→    task.status = 'pending';\n   149→    task.attempts = 0;\n   150→    task.errors = [];\n   151→    task.progress = 0;\n   152→    task.progressMessage = undefined;\n   153→    task.availableAt = null;\n   154→    task.updatedAt = new Date();\n   155→\n   156→    queue.addTask(task);\n   157→    return task;\n   158→  }\n   159→\n   160→  clearDeadLetterQueue(queueName?: string): void {\n   161→    const name = queueName ?? DEFAULT_QUEUE_NAME;\n   162→    const queue = this.queues.get(name);\n   163→    if (queue) {\n   164→      queue.clearDeadLetterQueue();\n   165→    }\n   166→  }\n   167→\n   168→  // ─── Phase 7: Dependencies ─────────────────────────────\n   169→\n   170→  private areDependenciesMet(task: TaskData): boolean {\n   171→    for (const depId of task.dependencies) {\n   172→      const dep = this.allTasks.get(depId);\n   173→      if (!dep || dep.status !== 'completed') {\n   174→        return false;\n   175→      }\n   176→    }\n   177→    return true;\n   178→  }\n   179→\n   180→  private detectCircularDependencies(newTaskId: string, dependencies: string[]): void {\n   181→    // BFS/DFS to check if any dependency chain leads back to newTaskId\n   182→    const visited = new Set<string>();\n   183→    const stack = [...dependencies];\n   184→\n   185→    while (stack.length > 0) {\n   186→      const currentId = stack.pop()!;\n   187→      if (currentId === newTaskId) {\n   188→        throw new Error('Circular dependency detected.');\n   189→      }\n   190→      if (visited.has(currentId)) continue;\n   191→      visited.add(currentId);\n   192→\n   193→      const currentTask = this.allTasks.get(currentId);\n   194→      if (currentTask) {\n   195→        for (const depId of currentTask.dependencies) {\n   196→          stack.push(depId);\n   197→        }\n   198→      }\n   199→    }\n   200→  }\n   201→\n   202→  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {\n   203→    const task = this.allTasks.get(taskId);\n   204→    if (!task) {\n   205→      throw new Error(`Task \"${taskId}\" not found.`);\n   206→    }\n   207→\n   208→    const pending: string[] = [];\n   209→    let completed = 0;\n   210→    for (const depId of task.dependencies) {\n   211→      const dep = this.allTasks.get(depId);\n   212→      if (dep && dep.status === 'completed') {\n   213→        completed++;\n   214→      } else {\n   215→        pending.push(depId);\n   216→      }\n   217→    }\n   218→\n   219→    return {\n   220→      total: task.dependencies.length,\n   221→      completed,\n   222→      pending,\n   223→    };\n   224→  }\n   225→\n   226→  // ─── Phase 8: Concurrency Control ──────────────────────\n   227→\n   228→  setConcurrency(queueName: string, limit: number | null): void {\n   229→    const queue = this.getOrCreateQueue(queueName);\n   230→    queue.setConcurrencyLimit(limit);\n   231→  }\n   232→\n   233→  getConcurrency(queueName: string): { limit: number | null; active: number } {\n   234→    const queue = this.queues.get(queueName);\n   235→    if (!queue) {\n   236→      return { limit: null, active: 0 };\n   237→    }\n   238→    return {\n   239→      limit: queue.getConcurrencyLimit(),\n   240→      active: queue.getProcessingCount(),\n   241→    };\n   242→  }\n   243→\n   244→  // ─── Phase 9: Progress & Cancellation ──────────────────\n   245→\n   246→  updateProgress(taskId: string, progress: number, message?: string): void {\n   247→    if (progress < 0 || progress > 100) {\n   248→      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);\n   249→    }\n   250→\n   251→    const task = this.allTasks.get(taskId);\n   252→    if (!task) {\n   253→      throw new Error(`Task \"${taskId}\" not found.`);\n   254→    }\n   255→    if (task.status !== 'processing') {\n   256→      throw new Error(`Task \"${taskId}\" is not in processing state.`);\n   257→    }\n   258→\n   259→    const queue = this.queues.get(task.queueName);\n   260→    if (queue) {\n   261→      queue.updateProgress(taskId, progress, message);\n   262→    }\n   263→  }\n   264→\n   265→  onProgress(taskId: string, callback: ProgressCallback): () => void {\n   266→    const task = this.allTasks.get(taskId);\n   267→    if (!task) {\n   268→      throw new Error(`Task \"${taskId}\" not found.`);\n   269→    }\n   270→\n   271→    const queue = this.queues.get(task.queueName);\n   272→    if (!queue) {\n   273→      throw new Error(`Queue \"${task.queueName}\" not found.`);\n   274→    }\n   275→\n   276→    return queue.onProgress(taskId, callback);\n   277→  }\n   278→\n   279→  cancelTask(taskId: string): void {\n   280→    const task = this.allTasks.get(taskId);\n   281→    if (!task) {\n   282→      throw new Error(`Task \"${taskId}\" not found.`);\n   283→    }\n   284→    if (task.status !== 'pending' && task.status !== 'processing') {\n   285→      throw new Error(\n   286→        `Task \"${taskId}\" cannot be cancelled (current status: ${task.status}).`\n   287→      );\n   288→    }\n   289→\n   290→    const queue = this.queues.get(task.queueName);\n   291→    if (queue) {\n   292→      queue.cancelTask(taskId);\n   293→    }\n   294→  }\n   295→\n   296→  // ─── Phase 10: Recurring Tasks ─────────────────────────\n   297→\n   298→  addSchedule(\n   299→    id: string,\n   300→    cronExpression: string,\n   301→    queueName: string,\n   302→    payload: unknown,\n   303→    options: ScheduleOptions = {}\n   304→  ): Schedule {\n   305→    return this.scheduler.addSchedule(id, cronExpression, queueName, payload, options);\n   306→  }\n   307→\n   308→  removeSchedule(id: string): boolean {\n   309→    return this.scheduler.removeSchedule(id);\n   310→  }\n   311→\n   312→  getSchedules(): Schedule[] {\n   313→    return this.scheduler.getSchedules();\n   314→  }\n   315→\n   316→  tick(now?: Date): TaskData[] {\n   317→    const currentTime = now ?? new Date();\n   318→    const dueSchedules = this.scheduler.getDueSchedules(currentTime);\n   319→    const tasks: TaskData[] = [];\n   320→\n   321→    for (const schedule of dueSchedules) {\n   322→      const task = this.addTask(schedule.payload, {\n   323→        queueName: schedule.queueName,\n   324→        priority: schedule.options.priority,\n   325→        maxRetries: schedule.options.maxRetries,\n   326→        backoffDelay: schedule.options.backoffDelay,\n   327→      });\n   328→      task.scheduledBy = schedule.id;\n   329→      tasks.push(task);\n   330→    }\n   331→\n   332→    return tasks;\n   333→  }\n   334→\n   335→  // ─── Phase 11: Middleware ──────────────────────────────\n   336→\n   337→  use(queueName: string, middleware: Middleware): void {\n   338→    const queue = this.getOrCreateQueue(queueName);\n   339→    queue.use(middleware);\n   340→  }\n   341→\n   342→  process(queueName: string, handler: ProcessHandler): void {\n   343→    const queue = this.getOrCreateQueue(queueName);\n   344→    queue.setHandler(handler);\n   345→  }\n   346→\n   347→  async processNext(queueName?: string): Promise<TaskData | null> {\n   348→    const name = queueName ?? DEFAULT_QUEUE_NAME;\n   349→    const task = this.getNextTask(name);\n   350→    if (!task) return null;\n   351→\n   352→    const queue = this.queues.get(name)!;\n   353→    const middlewares = queue.getMiddlewares();\n   354→    const handler = queue.getHandler();\n   355→\n   356→    try {\n   357→      await this.runMiddlewareChain(task, middlewares, handler);\n   358→\n   359→      // If task is still processing after middleware+handler, auto-complete\n   360→      if (task.status === 'processing') {\n   361→        this.completeTask(task.id);\n   362→      }\n   363→    } catch (err) {\n   364→      // If task is still processing, fail it\n   365→      if (task.status === 'processing') {\n   366→        const errorMsg = err instanceof Error ? err : new Error(String(err));\n   367→        this.failTask(task.id, errorMsg);\n   368→      }\n   369→    }\n   370→\n   371→    return task;\n   372→  }\n   373→\n   374→  private async runMiddlewareChain(\n   375→    task: TaskData,\n   376→    middlewares: Middleware[],\n   377→    handler: ProcessHandler | null\n   378→  ): Promise<void> {\n   379→    let index = 0;\n   380→    const next = async (): Promise<void> => {\n   381→      if (index < middlewares.length) {\n   382→        const mw = middlewares[index++];\n   383→        await mw(task, next);\n   384→      } else if (handler) {\n   385→        await handler(task);\n   386→      }\n   387→    };\n   388→    await next();\n   389→  }\n   390→\n   391→  // ─── Phase 12: Graceful Shutdown ──────────────────────\n   392→\n   393→  onShutdown(callback: ShutdownCallback): void {\n   394→    this.shutdownCallbacks.push(callback);\n   395→  }\n   396→\n   397→  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownResult> {\n   398→    if (this.shutdownPromise) {\n   399→      return this.shutdownPromise;\n   400→    }\n   401→\n   402→    this.isShuttingDown = true;\n   403→    this.shutdownPromise = this.executeShutdown(options);\n   404→    return this.shutdownPromise;\n   405→  }\n   406→\n   407→  private async executeShutdown(options: ShutdownOptions): Promise<ShutdownResult> {\n   408→    const timeout = options.timeout ?? 30000;\n   409→    const startTime = Date.now();\n   410→\n   411→    // Run shutdown callbacks\n   412→    for (const cb of this.shutdownCallbacks) {\n   413→      try {\n   414→        await cb();\n   415→      } catch {\n   416→        // Shutdown callbacks shouldn't prevent shutdown\n   417→      }\n   418→    }\n   419→\n   420→    // Gather all processing tasks\n   421→    let processingTasks: TaskData[] = [];\n   422→    for (const queue of this.queues.values()) {\n   423→      processingTasks.push(...queue.getProcessingTasks());\n   424→    }\n   425→\n   426→    let completed = 0;\n   427→    let forceCancelled = 0;\n   428→\n   429→    if (processingTasks.length === 0) {\n   430→      return {\n   431→        completed: 0,\n   432→        forceCancelled: 0,\n   433→        duration: Date.now() - startTime,\n   434→      };\n   435→    }\n   436→\n   437→    // Wait for processing tasks