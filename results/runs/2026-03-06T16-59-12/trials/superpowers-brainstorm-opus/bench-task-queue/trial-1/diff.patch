+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should limit concurrent processing tasks', () => {
+    tqs.setConcurrency('default', 2);
+    tqs.addTask('t1');
+    tqs.addTask('t2');
+    tqs.addTask('t3');
+
+    const p1 = tqs.getNextTask();
+    const p2 = tqs.getNextTask();
+    expect(p1).not.toBeNull();
+    expect(p2).not.toBeNull();
+
+    // Third should be blocked by concurrency
+    expect(tqs.getNextTask()).toBeNull();
+  });
+
+  it('should free slot on task completion', () => {
+    tqs.setConcurrency('default', 1);
+    tqs.addTask('t1');
+    tqs.addTask('t2');
+
+    const p1 = tqs.getNextTask();
+    expect(tqs.getNextTask()).toBeNull();
+
+    tqs.completeTask(p1!.id);
+    const p2 = tqs.getNextTask();
+    expect(p2?.payload).toBe('t2');
+  });
+
+  it('should free slot on task failure', () => {
+    tqs.setConcurrency('default', 1);
+    tqs.addTask('t1', { maxRetries: 0 });
+    tqs.addTask('t2');
+
+    const p1 = tqs.getNextTask();
+    expect(tqs.getNextTask()).toBeNull();
+
+    tqs.failTask(p1!.id, 'err');
+    const p2 = tqs.getNextTask();
+    expect(p2?.payload).toBe('t2');
+  });
+
+  it('should default to unlimited concurrency', () => {
+    tqs.addTask('t1');
+    tqs.addTask('t2');
+    tqs.addTask('t3');
+
+    expect(tqs.getNextTask()).not.toBeNull();
+    expect(tqs.getNextTask()).not.toBeNull();
+    expect(tqs.getNextTask()).not.toBeNull();
+  });
+
+  it('should query concurrency limit and active count', () => {
+    tqs.setConcurrency('myqueue', 3);
+    tqs.addTask('t1', { queueName: 'myqueue' });
+    tqs.addTask('t2', { queueName: 'myqueue' });
+
+    const before = tqs.getConcurrency('myqueue');
+    expect(before.limit).toBe(3);
+    expect(before.active).toBe(0);
+
+    tqs.getNextTask('myqueue');
+    const after = tqs.getConcurrency('myqueue');
+    expect(after.active).toBe(1);
+  });
+
+  it('should still respect priority ordering with concurrency limits', () => {
+    tqs.setConcurrency('default', 1);
+    tqs.addTask('low', { priority: 10 });
+    tqs.addTask('high', { priority: 1 });
+
+    const first = tqs.getNextTask();
+    expect(first?.payload).toBe('high');
+  });
+
+  it('should return null for non-existent queue concurrency', () => {
+    const result = tqs.getConcurrency('nonexistent');
+    expect(result.limit).toBeNull();
+    expect(result.active).toBe(0);
+  });
+});
