@@ -0,0 +1,132 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  describe('Progress', () => {
+    it('should report progress on a processing task', () => {
+      const task = tqs.addTask('test');
+      tqs.getNextTask();
+      tqs.updateProgress(task.id, 50, 'halfway');
+
+      expect(task.progress).toBe(50);
+      expect(task.progressMessage).toBe('halfway');
+    });
+
+    it('should reject invalid progress values', () => {
+      const task = tqs.addTask('test');
+      tqs.getNextTask();
+
+      expect(() => tqs.updateProgress(task.id, -1)).toThrow();
+      expect(() => tqs.updateProgress(task.id, 101)).toThrow();
+    });
+
+    it('should reject progress on non-processing task', () => {
+      const task = tqs.addTask('test');
+      expect(() => tqs.updateProgress(task.id, 50)).toThrow();
+    });
+
+    it('should notify progress listeners', () => {
+      const task = tqs.addTask('test');
+      tqs.getNextTask();
+
+      const updates: Array<{ progress: number; message?: string }> = [];
+      tqs.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));
+
+      tqs.updateProgress(task.id, 25, 'quarter');
+      tqs.updateProgress(task.id, 75, 'three-quarters');
+
+      expect(updates.length).toBe(2);
+      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });
+      expect(updates[1]).toEqual({ progress: 75, message: 'three-quarters' });
+    });
+
+    it('should support unsubscribing from progress', () => {
+      const task = tqs.addTask('test');
+      tqs.getNextTask();
+
+      const updates: number[] = [];
+      const unsubscribe = tqs.onProgress(task.id, (p) => updates.push(p));
+
+      tqs.updateProgress(task.id, 25);
+      unsubscribe();
+      tqs.updateProgress(task.id, 75);
+
+      expect(updates).toEqual([25]);
+    });
+
+    it('should query current progress', () => {
+      const task = tqs.addTask('test');
+      expect(task.progress).toBe(0);
+
+      tqs.getNextTask();
+      tqs.updateProgress(task.id, 42, 'working...');
+
+      const found = tqs.getTask(task.id);
+      expect(found?.progress).toBe(42);
+      expect(found?.progressMessage).toBe('working...');
+    });
+  });
+
+  describe('Cancellation', () => {
+    it('should cancel a pending task', () => {
+      const task = tqs.addTask('cancel-me');
+      tqs.cancelTask(task.id);
+
+      expect(task.status).toBe('cancelled');
+      expect(tqs.getNextTask()).toBeNull();
+    });
+
+    it('should cancel a processing task', () => {
+      const task = tqs.addTask('cancel-me');
+      tqs.getNextTask();
+      tqs.cancelTask(task.id);
+
+      expect(task.status).toBe('cancelled');
+    });
+
+    it('should not cancel completed tasks', () => {
+      const task = tqs.addTask('test');
+      tqs.getNextTask();
+      tqs.completeTask(task.id);
+
+      expect(() => tqs.cancelTask(task.id)).toThrow();
+    });
+
+    it('should not cancel failed tasks', () => {
+      const task = tqs.addTask('test', { maxRetries: 0 });
+      tqs.getNextTask();
+      tqs.failTask(task.id, 'err');
+
+      expect(() => tqs.cancelTask(task.id)).toThrow();
+    });
+
+    it('should never retry cancelled tasks', () => {
+      const task = tqs.addTask('test', { maxRetries: 3 });
+      tqs.getNextTask();
+      tqs.cancelTask(task.id);
+
+      expect(task.status).toBe('cancelled');
+      // No retries should happen
+      expect(tqs.getNextTask()).toBeNull();
+    });
+
+    it('should remove cancelled pending task from queue', () => {
+      tqs.addTask('keep-me');
+      const task = tqs.addTask('cancel-me');
+      tqs.addTask('keep-me-too');
+
+      expect(tqs.getTaskCount()).toBe(3);
+      tqs.cancelTask(task.id);
+      expect(tqs.getTaskCount()).toBe(2);
+
+      expect(tqs.getNextTask()?.payload).toBe('keep-me');
+      expect(tqs.getNextTask()?.payload).toBe('keep-me-too');
+    });
+  });
+});
diff --git a/tests/phase10-recurring.test.ts b/tests/phase10-recurring.test.ts
