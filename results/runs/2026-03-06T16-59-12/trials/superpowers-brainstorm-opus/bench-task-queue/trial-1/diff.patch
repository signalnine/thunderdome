--- /dev/null
+++ b/src/cron.ts
@@ -0,0 +1,95 @@
+export interface CronSchedule {
+  minute: number | null; // null means wildcard, specific number means that minute
+  everyNMinutes: number | null; // for */N patterns
+  hour: number | null;
+}
+
+export function parseCron(expression: string): CronSchedule {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}". Expected 5 fields.`);
+  }
+
+  const [minuteField, hourField, domField, monthField, dowField] = parts;
+
+  // Validate that dom, month, dow are wildcards (we only support simple subset)
+  if (domField !== '*' || monthField !== '*' || dowField !== '*') {
+    throw new Error(
+      `Unsupported cron expression: "${expression}". Only day-of-month=*, month=*, day-of-week=* are supported.`
+    );
+  }
+
+  const schedule: CronSchedule = {
+    minute: null,
+    everyNMinutes: null,
+    hour: null,
+  };
+
+  // Parse minute field
+  if (minuteField === '*') {
+    // every minute - leave as null
+  } else if (minuteField.startsWith('*/')) {
+    const n = parseInt(minuteField.slice(2), 10);
+    if (isNaN(n) || n < 1 || n > 59) {
+      throw new Error(`Invalid cron minute interval: "${minuteField}"`);
+    }
+    schedule.everyNMinutes = n;
+  } else {
+    const m = parseInt(minuteField, 10);
+    if (isNaN(m) || m < 0 || m > 59) {
+      throw new Error(`Invalid cron minute value: "${minuteField}"`);
+    }
+    schedule.minute = m;
+  }
+
+  // Parse hour field
+  if (hourField === '*') {
+    // every hour - leave as null
+  } else if (hourField.startsWith('*/')) {
+    throw new Error(`Unsupported cron hour interval: "${hourField}". Use specific hour values.`);
+  } else {
+    const h = parseInt(hourField, 10);
+    if (isNaN(h) || h < 0 || h > 23) {
+      throw new Error(`Invalid cron hour value: "${hourField}"`);
+    }
+    schedule.hour = h;
+  }
+
+  return schedule;
+}
+
+export function shouldRunAt(schedule: CronSchedule, now: Date, lastRun: Date | null): boolean {
+  const currentMinute = now.getMinutes();
+  const currentHour = now.getHours();
+
+  // Check hour constraint
+  if (schedule.hour !== null && currentHour !== schedule.hour) {
+    return false;
+  }
+
+  // Check minute constraint
+  if (schedule.minute !== null && currentMinute !== schedule.minute) {
+    return false;
+  }
+
+  // Check everyNMinutes
+  if (schedule.everyNMinutes !== null) {
+    if (currentMinute % schedule.everyNMinutes !== 0) {
+      return false;
+    }
+  }
+
+  // Check if already run in this time slot
+  if (lastRun) {
+    const lastRunMinute = lastRun.getMinutes();
+    const lastRunHour = lastRun.getHours();
+    const lastRunDate = lastRun.toDateString();
+    const nowDate = now.toDateString();
+
+    if (nowDate === lastRunDate && lastRunHour === currentHour && lastRunMinute === currentMinute) {
+      return false;
+    }
+  }
+
+  return true;
+}
