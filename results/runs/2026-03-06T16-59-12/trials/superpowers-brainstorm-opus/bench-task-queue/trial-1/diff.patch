oBe('cancelled');\n      // No retries should happen\n      expect(tqs.getNextTask()).toBeNull();\n    });\n\n    it('should remove cancelled pending task from queue', () => {\n      tqs.addTask('keep-me');\n      const task = tqs.addTask('cancel-me');\n      tqs.addTask('keep-me-too');\n\n      expect(tqs.getTaskCount()).toBe(3);\n      tqs.cancelTask(task.id);\n      expect(tqs.getTaskCount()).toBe(2);\n\n      expect(tqs.getNextTask()?.payload).toBe('keep-me');\n      expect(tqs.getNextTask()?.payload).toBe('keep-me-too');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
