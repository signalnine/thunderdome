@@ -0,0 +1,92 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should move task to DLQ when all retries are exhausted', () => {
+    const task = tqs.addTask('doomed', { maxRetries: 1, backoffDelay: 10 });
+
+    // First attempt
+    tqs.getNextTask();
+    tqs.failTask(task.id, 'err1');
+    task.availableAt = new Date(Date.now() - 1);
+
+    // Second attempt (maxRetries=1 means 1 retry after first failure, but
+    // actually maxRetries is the total retries allowed, and attempts starts at 0)
+    // Let me re-check: attempt 1 fails, attempts < maxRetries (1 < 1 is false)
+    // So the task should be in DLQ after first failure with maxRetries=1
+    // Wait - attempts is incremented to 1 on getNextTask, then fail checks 1 < 1 = false
+    // So it goes to DLQ.
+
+    const dlq = tqs.getDeadLetterTasks();
+    expect(dlq.length).toBe(1);
+    expect(dlq[0].id).toBe(task.id);
+  });
+
+  it('should retain error information on dead-lettered tasks', () => {
+    const task = tqs.addTask('doomed', { maxRetries: 1, backoffDelay: 10 });
+    tqs.getNextTask();
+    tqs.failTask(task.id, 'first error');
+
+    const dlq = tqs.getDeadLetterTasks();
+    expect(dlq[0].errors.length).toBe(1);
+    expect(dlq[0].errors[0].message).toBe('first error');
+  });
+
+  it('should move dead-lettered task back to original queue', () => {
+    const task = tqs.addTask('retry-me', { maxRetries: 1, backoffDelay: 10 });
+    tqs.getNextTask();
+    tqs.failTask(task.id, 'err');
+
+    expect(tqs.getDeadLetterTasks().length).toBe(1);
+
+    const retried = tqs.retryDeadLetterTask(task.id);
+    expect(retried.status).toBe('pending');
+    expect(retried.attempts).toBe(0);
+    expect(retried.errors.length).toBe(0);
+
+    expect(tqs.getDeadLetterTasks().length).toBe(0);
+    expect(tqs.getTaskCount()).toBe(1);
+  });
+
+  it('should clear dead letter queue for a queue', () => {
+    const t1 = tqs.addTask('d1', { maxRetries: 1, backoffDelay: 10 });
+    const t2 = tqs.addTask('d2', { maxRetries: 1, backoffDelay: 10 });
+
+    tqs.getNextTask();
+    tqs.failTask(t1.id, 'err');
+    tqs.getNextTask();
+    tqs.failTask(t2.id, 'err');
+
+    expect(tqs.getDeadLetterTasks().length).toBe(2);
+    tqs.clearDeadLetterQueue();
+    expect(tqs.getDeadLetterTasks().length).toBe(0);
+  });
+
+  it('should have independent DLQs per named queue', () => {
+    const t1 = tqs.addTask('d1', { queueName: 'q1', maxRetries: 1, backoffDelay: 10 });
+    const t2 = tqs.addTask('d2', { queueName: 'q2', maxRetries: 1, backoffDelay: 10 });
+
+    tqs.getNextTask('q1');
+    tqs.failTask(t1.id, 'err');
+    tqs.getNextTask('q2');
+    tqs.failTask(t2.id, 'err');
+
+    expect(tqs.getDeadLetterTasks('q1').length).toBe(1);
+    expect(tqs.getDeadLetterTasks('q2').length).toBe(1);
+
+    tqs.clearDeadLetterQueue('q1');
+    expect(tqs.getDeadLetterTasks('q1').length).toBe(0);
+    expect(tqs.getDeadLetterTasks('q2').length).toBe(1);
+  });
+
+  it('should return empty array for queue with no DLQ items', () => {
+    expect(tqs.getDeadLetterTasks()).toEqual([]);
+    expect(tqs.getDeadLetterTasks('nonexistent')).toEqual([]);
+  });
+});
