+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should prevent new tasks after shutdown', async () => {
+    await tqs.shutdown();
+    expect(() => tqs.addTask('test')).toThrow(/shutting down/);
+  });
+
+  it('should complete immediately when no tasks are processing', async () => {
+    const result = await tqs.shutdown();
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should wait for processing tasks to finish', async () => {
+    const task = tqs.addTask('test');
+    tqs.getNextTask();
+
+    // Complete the task shortly after shutdown starts
+    setTimeout(() => {
+      tqs.completeTask(task.id);
+    }, 100);
+
+    const result = await tqs.shutdown({ timeout: 5000 });
+    expect(result.forceCancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks after timeout', async () => {
+    tqs.addTask('stuck');
+    tqs.getNextTask(); // Now processing
+
+    // Don't complete it - let it timeout
+    const result = await tqs.shutdown({ timeout: 200 });
+    expect(result.forceCancelled).toBe(1);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let callbackRan = false;
+    tqs.onShutdown(() => {
+      callbackRan = true;
+    });
+
+    await tqs.shutdown();
+    expect(callbackRan).toBe(true);
+  });
+
+  it('should return same result on multiple shutdown calls', async () => {
+    const r1 = tqs.shutdown();
+    const r2 = tqs.shutdown();
+
+    const result1 = await r1;
+    const result2 = await r2;
+    expect(result1).toBe(result2);
+  });
+
+  it('should report shutdown duration', async () => {
+    const result = await tqs.shutdown();
+    expect(typeof result.duration).toBe('number');
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should report shuttingDown status', async () => {
+    expect(tqs.shuttingDown).toBe(false);
+    const promise = tqs.shutdown();
+    expect(tqs.shuttingDown).toBe(true);
+    await promise;
+    expect(tqs.shuttingDown).toBe(true);
+  });
+
+  it('should handle async shutdown callbacks', async () => {
+    const order: string[] = [];
+    tqs.onShutdown(async () => {
+      await new Promise(resolve => setTimeout(resolve, 50));
+      order.push('callback1');
+    });
+    tqs.onShutdown(() => {
+      order.push('callback2');
+    });
+
+    await tqs.shutdown();
+    expect(order).toEqual(['callback1', 'callback2']);
+  });
+});
