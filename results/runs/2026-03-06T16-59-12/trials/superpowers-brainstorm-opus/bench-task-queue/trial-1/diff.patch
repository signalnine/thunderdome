@@ -0,0 +1,70 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = tqs.addTask({ message: 'hello' });
+    expect(task).toBeDefined();
+    expect(task.id).toBeDefined();
+    expect(task.payload).toEqual({ message: 'hello' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should generate unique IDs for each task', () => {
+    const t1 = tqs.addTask('task1');
+    const t2 = tqs.addTask('task2');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    tqs.addTask('first');
+    tqs.addTask('second');
+    tqs.addTask('third');
+
+    const t1 = tqs.getNextTask();
+    expect(t1?.payload).toBe('first');
+
+    const t2 = tqs.getNextTask();
+    expect(t2?.payload).toBe('second');
+
+    const t3 = tqs.getNextTask();
+    expect(t3?.payload).toBe('third');
+  });
+
+  it('should transition task to processing when retrieved', () => {
+    const task = tqs.addTask('test');
+    const retrieved = tqs.getNextTask();
+    expect(retrieved?.id).toBe(task.id);
+    expect(retrieved?.status).toBe('processing');
+  });
+
+  it('should return null when no tasks are available', () => {
+    expect(tqs.getNextTask()).toBeNull();
+  });
+
+  it('should report the correct pending count', () => {
+    expect(tqs.getTaskCount()).toBe(0);
+    tqs.addTask('a');
+    tqs.addTask('b');
+    expect(tqs.getTaskCount()).toBe(2);
+    tqs.getNextTask();
+    expect(tqs.getTaskCount()).toBe(1);
+  });
+
+  it('should allow looking up a task by ID', () => {
+    const task = tqs.addTask('findme');
+    const found = tqs.getTask(task.id);
+    expect(found).toBe(task);
+  });
+
+  it('should return null for non-existent task ID', () => {
+    expect(tqs.getTask('nonexistent')).toBeNull();
+  });
+});
