@@ -0,0 +1,77 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 4: Delayed Tasks', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should support delay in milliseconds', () => {
+    const task = tqs.addTask('delayed', { delay: 5000 });
+    expect(task.availableAt).toBeInstanceOf(Date);
+    expect(task.availableAt!.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should support a specific future availableAt', () => {
+    const future = new Date(Date.now() + 10000);
+    const task = tqs.addTask('scheduled', { availableAt: future });
+    expect(task.availableAt).toBe(future);
+  });
+
+  it('should not return delayed tasks before their time', () => {
+    tqs.addTask('delayed', { delay: 60000 }); // 60 seconds in the future
+    expect(tqs.getNextTask()).toBeNull();
+  });
+
+  it('should return delayed tasks after their time', () => {
+    const past = new Date(Date.now() - 1000);
+    tqs.addTask('ready', { availableAt: past });
+    const task = tqs.getNextTask();
+    expect(task?.payload).toBe('ready');
+  });
+
+  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {
+    tqs.addTask('delayed', { delay: 60000, priority: 1 });
+    tqs.addTask('immediate', { priority: 5 });
+
+    // The immediate task should be returned even though delayed has higher priority
+    const task = tqs.getNextTask();
+    expect(task?.payload).toBe('immediate');
+  });
+
+  it('should order by availability time, then priority, then FIFO', () => {
+    const t1 = new Date(Date.now() - 3000);
+    const t2 = new Date(Date.now() - 2000);
+    const t3 = new Date(Date.now() - 1000);
+
+    tqs.addTask('third', { availableAt: t3, priority: 1 });
+    tqs.addTask('first', { availableAt: t1, priority: 3 });
+    tqs.addTask('second', { availableAt: t2, priority: 3 });
+
+    // Priority takes precedence, then availability time, then FIFO
+    expect(tqs.getNextTask()?.payload).toBe('third');
+    expect(tqs.getNextTask()?.payload).toBe('first');
+    expect(tqs.getNextTask()?.payload).toBe('second');
+  });
+
+  it('should indicate when task becomes available', () => {
+    const future = new Date(Date.now() + 5000);
+    const task = tqs.addTask('test', { availableAt: future });
+    expect(task.availableAt).toEqual(future);
+  });
+
+  it('should work correctly with named queues', () => {
+    tqs.addTask('delayed', { queueName: 'q1', delay: 60000 });
+    tqs.addTask('immediate', { queueName: 'q1' });
+
+    const task = tqs.getNextTask('q1');
+    expect(task?.payload).toBe('immediate');
+  });
+
+  it('should not have availableAt for non-delayed tasks', () => {
+    const task = tqs.addTask('immediate');
+    expect(task.availableAt).toBeNull();
+  });
+});
