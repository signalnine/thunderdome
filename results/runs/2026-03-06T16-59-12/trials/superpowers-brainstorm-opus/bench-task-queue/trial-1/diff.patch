+++ b/tests/phase10-recurring.test.ts
@@ -0,0 +1,142 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should create a schedule', () => {
+    const schedule = tqs.addSchedule('hourly-report', '0 * * * *', 'reports', { type: 'report' });
+    expect(schedule.id).toBe('hourly-report');
+    expect(schedule.cronExpression).toBe('0 * * * *');
+    expect(schedule.queueName).toBe('reports');
+  });
+
+  it('should list active schedules', () => {
+    tqs.addSchedule('s1', '*/5 * * * *', 'default', {});
+    tqs.addSchedule('s2', '0 * * * *', 'default', {});
+    expect(tqs.getSchedules().length).toBe(2);
+  });
+
+  it('should remove a schedule', () => {
+    tqs.addSchedule('s1', '*/5 * * * *', 'default', {});
+    expect(tqs.removeSchedule('s1')).toBe(true);
+    expect(tqs.getSchedules().length).toBe(0);
+  });
+
+  it('should not remove non-existent schedule', () => {
+    expect(tqs.removeSchedule('nonexistent')).toBe(false);
+  });
+
+  it('should enqueue tasks on tick when schedule is due', () => {
+    tqs.addSchedule('every-5', '*/5 * * * *', 'default', { job: 'cleanup' });
+
+    // Create a date that falls on a multiple of 5 minutes
+    const now = new Date();
+    now.setMinutes(10, 0, 0);
+
+    const tasks = tqs.tick(now);
+    expect(tasks.length).toBe(1);
+    expect(tasks[0].payload).toEqual({ job: 'cleanup' });
+    expect(tasks[0].scheduledBy).toBe('every-5');
+  });
+
+  it('should not enqueue duplicate in same minute', () => {
+    tqs.addSchedule('every-5', '*/5 * * * *', 'default', {});
+
+    const now = new Date();
+    now.setMinutes(10, 0, 0);
+
+    tqs.tick(now);
+    const tasks2 = tqs.tick(now); // Same minute
+    expect(tasks2.length).toBe(0);
+  });
+
+  it('should enqueue at the next matching time', () => {
+    tqs.addSchedule('every-5', '*/5 * * * *', 'default', {});
+
+    const t1 = new Date();
+    t1.setMinutes(10, 0, 0);
+    tqs.tick(t1);
+
+    const t2 = new Date(t1);
+    t2.setMinutes(15, 0, 0);
+    const tasks = tqs.tick(t2);
+    expect(tasks.length).toBe(1);
+  });
+
+  it('should not enqueue at non-matching time', () => {
+    tqs.addSchedule('every-5', '*/5 * * * *', 'default', {});
+
+    const now = new Date();
+    now.setMinutes(13, 0, 0); // Not a multiple of 5
+
+    const tasks = tqs.tick(now);
+    expect(tasks.length).toBe(0);
+  });
+
+  it('should stop creating tasks after schedule removal', () => {
+    tqs.addSchedule('s1', '*/5 * * * *', 'default', {});
+
+    const t1 = new Date();
+    t1.setMinutes(10, 0, 0);
+    tqs.tick(t1);
+    tqs.removeSchedule('s1');
+
+    const t2 = new Date(t1);
+    t2.setMinutes(15, 0, 0);
+    const tasks = tqs.tick(t2);
+    expect(tasks.length).toBe(0);
+  });
+
+  it('should support every hour on the hour', () => {
+    tqs.addSchedule('hourly', '0 * * * *', 'default', { job: 'hourly' });
+
+    const atHour = new Date();
+    atHour.setMinutes(0, 0, 0);
+    const tasks = tqs.tick(atHour);
+    expect(tasks.length).toBe(1);
+
+    const notHour = new Date(atHour);
+    notHour.setMinutes(30, 0, 0);
+    const tasks2 = tqs.tick(notHour);
+    expect(tasks2.length).toBe(0);
+  });
+
+  it('should support every day at midnight', () => {
+    tqs.addSchedule('daily', '0 0 * * *', 'default', { job: 'daily' });
+
+    const midnight = new Date();
+    midnight.setHours(0, 0, 0, 0);
+    const tasks = tqs.tick(midnight);
+    expect(tasks.length).toBe(1);
+
+    const noon = new Date(midnight);
+    noon.setHours(12, 0, 0, 0);
+    const tasks2 = tqs.tick(noon);
+    expect(tasks2.length).toBe(0);
+  });
+
+  it('should apply schedule options to created tasks', () => {
+    tqs.addSchedule('s1', '*/5 * * * *', 'default', {}, { priority: 1, maxRetries: 5 });
+
+    const now = new Date();
+    now.setMinutes(10, 0, 0);
+    const tasks = tqs.tick(now);
+
+    expect(tasks[0].priority).toBe(1);
+    expect(tasks[0].maxRetries).toBe(5);
+  });
+
+  it('should reject duplicate schedule IDs', () => {
+    tqs.addSchedule('s1', '*/5 * * * *', 'default', {});
+    expect(() => tqs.addSchedule('s1', '*/10 * * * *', 'default', {})).toThrow();
+  });
+
+  it('should reject invalid cron expressions', () => {
+    expect(() => tqs.addSchedule('bad', 'invalid', 'default', {})).toThrow();
+  });
+});
