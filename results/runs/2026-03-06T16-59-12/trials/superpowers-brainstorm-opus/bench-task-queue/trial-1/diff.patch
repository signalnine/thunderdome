--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,70 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queueName?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface TaskData {
+  id: string;
+  status: TaskStatus;
+  payload: unknown;
+  queueName: string;
+  priority: number;
+  createdAt: Date;
+  updatedAt: Date;
+  availableAt: Date | null;
+  delay: number | undefined;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  errors: Array<{ message: string; timestamp: Date }>;
+  dependencies: string[];
+  progress: number;
+  progressMessage: string | undefined;
+  scheduledBy: string | undefined;
+}
+
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export type Middleware = (task: TaskData, next: () => Promise<void>) => Promise<void>;
+
+export type ProcessHandler = (task: TaskData) => Promise<void> | void;
+
+export interface ScheduleOptions {
+  priority?: number;
+  maxRetries?: number;
+  backoffDelay?: number;
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queueName: string;
+  payload: unknown;
+  options: ScheduleOptions;
+  lastRun: Date | null;
+  createdAt: Date;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export type ShutdownCallback = () => void | Promise<void>;
+
+export const DEFAULT_QUEUE_NAME = 'default';
+export const DEFAULT_PRIORITY = 5;
+export const DEFAULT_MAX_RETRIES = 3;
+export const DEFAULT_BACKOFF_DELAY = 1000;
