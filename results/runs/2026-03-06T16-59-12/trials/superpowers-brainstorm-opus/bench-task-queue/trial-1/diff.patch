etConcurrency('myqueue', 3);\n    tqs.addTask('t1', { queueName: 'myqueue' });\n    tqs.addTask('t2', { queueName: 'myqueue' });\n\n    const before = tqs.getConcurrency('myqueue');\n    expect(before.limit).toBe(3);\n    expect(before.active).toBe(0);\n\n    tqs.getNextTask('myqueue');\n    const after = tqs.getConcurrency('myqueue');\n    expect(after.active).toBe(1);\n  });\n\n  it('should still respect priority ordering with concurrency limits', () => {\n    tqs.setConcurrency('default', 1);\n    tqs.addTask('low', { priority: 10 });\n    tqs.addTask('high', { priority: 1 });\n\n    const first = tqs.getNextTask();\n    expect(first?.payload).toBe('high');\n  });\n\n  it('should return null for non-existent queue concurrency', () => {\n    const result = tqs.getConcurrency('nonexistent');\n    expect(result.limit).toBeNull();\n    expect(result.active).toBe(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1475,"cache_read_input_tokens":48893,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1475},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"aee493ec-91df-4b3e-8021-5d8430142283","uuid":"6c396c19-d2cd-40b3-a2b6-9391fa045ae4"}
