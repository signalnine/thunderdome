();\n\n    const result1 = await r1;\n    const result2 = await r2;\n    expect(result1).toBe(result2);\n  });\n\n  it('should report shutdown duration', async () => {\n    const result = await tqs.shutdown();\n    expect(typeof result.duration).toBe('number');\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n\n  it('should report shuttingDown status', async () => {\n    expect(tqs.shuttingDown).toBe(false);\n    const promise = tqs.shutdown();\n    expect(tqs.shuttingDown).toBe(true);\n    await promise;\n    expect(tqs.shuttingDown).toBe(true);\n  });\n\n  it('should handle async shutdown callbacks', async () => {\n    const order: string[] = [];\n    tqs.onShutdown(async () => {\n      await new Promise(resolve => setTimeout(resolve, 50));\n      order.push('callback1');\n    });\n    tqs.onShutdown(() => {\n      order.push('callback2');\n    });\n\n    await tqs.shutdown();\n    expect(order).toEqual(['callback1', 'callback2']);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1491,"cache_read_input_tokens":54542,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1491},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"aee493ec-91df-4b3e-8021-5d8430142283","uuid":"976bba0a-fed6-47d7-bb09-ac2ad0ec9326"}
