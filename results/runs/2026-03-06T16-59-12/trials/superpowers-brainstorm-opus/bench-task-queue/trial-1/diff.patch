ct(order).toEqual(['middleware-blocked']);\n  });\n\n  it('should allow middleware to modify the task', async () => {\n    tqs.use('default', async (task, next) => {\n      (task.payload as Record<string, unknown>).modified = true;\n      await next();\n    });\n\n    let receivedPayload: unknown;\n    tqs.process('default', async (task) => {\n      receivedPayload = task.payload;\n    });\n\n    tqs.addTask({ original: true });\n    await tqs.processNext();\n\n    expect(receivedPayload).toEqual({ original: true, modified: true });\n  });\n\n  it('should fail task if middleware throws', async () => {\n    tqs.use('default', async () => {\n      throw new Error('middleware error');\n    });\n\n    const task = tqs.addTask('test', { maxRetries: 0 });\n    await tqs.processNext();\n\n    const found = tqs.getTask(task.id);\n    expect(found?.status).toBe('failed');\n  });\n\n  it('should fail task if handler throws', async () => {\n    tqs.process('default', async () => {\n      throw new Error('handler error');\n    });\n\n    const task = tqs.addTask('test', { maxRetries: 0 });\n    await tqs.processNext();\n\n    const found = tqs.getTask(task.id);\n    expect(found?.status).toBe('failed');\n  });\n\n  it('should auto-complete task if no error', async () => {\n    tqs.process('default', async () => {\n      // Do nothing, no error\n    });\n\n    const task = tqs.addTask('test');\n    await tqs.processNext();\n\n    expect(task.status).toBe('completed');\n  });\n\n  it('should have independent middleware stacks per queue', async () => {\n    const order: string[] = [];\n\n    tqs.use('q1', async (_task, next) => {\n      order.push('q1-mw');\n      await next();\n    });\n\n    tqs.use('q2', async (_task, next) => {\n      order.push('q2-mw');\n      await next();\n    });\n\n    tqs.process('q1', async () => { order.push('q1-handler'); });\n    tqs.process('q2', async () => { order.push('q2-handler'); });\n\n    tqs.addTask('t1', { queueName: 'q1' });\n    tqs.add