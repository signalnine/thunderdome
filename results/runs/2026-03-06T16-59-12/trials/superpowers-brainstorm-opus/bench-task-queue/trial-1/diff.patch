+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 3: Priority', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should default priority to 5', () => {
+    const task = tqs.addTask('test');
+    expect(task.priority).toBe(5);
+  });
+
+  it('should accept priority 1-10', () => {
+    const t1 = tqs.addTask('high', { priority: 1 });
+    const t10 = tqs.addTask('low', { priority: 10 });
+    expect(t1.priority).toBe(1);
+    expect(t10.priority).toBe(10);
+  });
+
+  it('should reject invalid priority values', () => {
+    expect(() => tqs.addTask('bad', { priority: 0 })).toThrow();
+    expect(() => tqs.addTask('bad', { priority: 11 })).toThrow();
+    expect(() => tqs.addTask('bad', { priority: -1 })).toThrow();
+    expect(() => tqs.addTask('bad', { priority: 1.5 })).toThrow();
+  });
+
+  it('should return higher-priority tasks first', () => {
+    tqs.addTask('low', { priority: 10 });
+    tqs.addTask('high', { priority: 1 });
+    tqs.addTask('medium', { priority: 5 });
+
+    expect(tqs.getNextTask()?.payload).toBe('high');
+    expect(tqs.getNextTask()?.payload).toBe('medium');
+    expect(tqs.getNextTask()?.payload).toBe('low');
+  });
+
+  it('should maintain FIFO within same priority', () => {
+    tqs.addTask('first', { priority: 5 });
+    tqs.addTask('second', { priority: 5 });
+    tqs.addTask('third', { priority: 5 });
+
+    expect(tqs.getNextTask()?.payload).toBe('first');
+    expect(tqs.getNextTask()?.payload).toBe('second');
+    expect(tqs.getNextTask()?.payload).toBe('third');
+  });
+
+  it('should operate per-queue', () => {
+    tqs.addTask('q1-low', { queueName: 'q1', priority: 10 });
+    tqs.addTask('q1-high', { queueName: 'q1', priority: 1 });
+    tqs.addTask('q2-low', { queueName: 'q2', priority: 10 });
+
+    expect(tqs.getNextTask('q1')?.payload).toBe('q1-high');
+    expect(tqs.getNextTask('q2')?.payload).toBe('q2-low');
+  });
+
+  it('should expose priority on the task object', () => {
+    const task = tqs.addTask('test', { priority: 3 });
+    expect(task.priority).toBe(3);
+  });
+});
