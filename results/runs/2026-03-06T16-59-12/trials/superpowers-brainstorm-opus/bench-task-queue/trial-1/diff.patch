+import crypto from 'node:crypto';
+import {
+  type TaskData,
+  type TaskStatus,
+  type TaskOptions,
+  DEFAULT_QUEUE_NAME,
+  DEFAULT_PRIORITY,
+  DEFAULT_MAX_RETRIES,
+  DEFAULT_BACKOFF_DELAY,
+} from './types.js';
+
+export function createTask(payload: unknown, options: TaskOptions = {}): TaskData {
+  const now = new Date();
+  let availableAt: Date | null = null;
+
+  if (options.availableAt) {
+    availableAt = options.availableAt;
+  } else if (options.delay !== undefined && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  }
+
+  if (options.priority !== undefined) {
+    if (!Number.isInteger(options.priority) || options.priority < 1 || options.priority > 10) {
+      throw new Error(`Invalid priority: ${options.priority}. Must be an integer between 1 and 10.`);
+    }
+  }
+
+  return {
+    id: crypto.randomUUID(),
+    status: 'pending',
+    payload,
+    queueName: options.queueName ?? DEFAULT_QUEUE_NAME,
+    priority: options.priority ?? DEFAULT_PRIORITY,
+    createdAt: now,
+    updatedAt: now,
+    availableAt,
+    delay: options.delay,
+    attempts: 0,
+    maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,
+    backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,
+    errors: [],
+    dependencies: options.dependencies ? [...options.dependencies] : [],
+    progress: 0,
+    progressMessage: undefined,
+    scheduledBy: undefined,
+  };
+}
+
+export function isTaskAvailable(task: TaskData, now: Date): boolean {
+  if (task.status !== 'pending') return false;
+  if (task.availableAt && task.availableAt.getTime() > now.getTime()) return false;
+  return true;
+}
+
+export function updateTaskStatus(task: TaskData, status: TaskStatus): void {
+  task.status = status;
+  task.updatedAt = new Date();
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
