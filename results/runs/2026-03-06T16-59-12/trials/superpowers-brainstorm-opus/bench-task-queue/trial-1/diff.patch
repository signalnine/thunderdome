@@ -0,0 +1,56 @@
+import { type Schedule, type ScheduleOptions } from './types.js';
+import { parseCron, shouldRunAt, type CronSchedule } from './cron.js';
+
+interface ScheduleEntry {
+  schedule: Schedule;
+  parsed: CronSchedule;
+}
+
+export class Scheduler {
+  private schedules: Map<string, ScheduleEntry> = new Map();
+
+  addSchedule(
+    id: string,
+    cronExpression: string,
+    queueName: string,
+    payload: unknown,
+    options: ScheduleOptions = {}
+  ): Schedule {
+    if (this.schedules.has(id)) {
+      throw new Error(`Schedule with id "${id}" already exists.`);
+    }
+
+    const parsed = parseCron(cronExpression);
+    const schedule: Schedule = {
+      id,
+      cronExpression,
+      queueName,
+      payload,
+      options,
+      lastRun: null,
+      createdAt: new Date(),
+    };
+
+    this.schedules.set(id, { schedule, parsed });
+    return { ...schedule };
+  }
+
+  removeSchedule(id: string): boolean {
+    return this.schedules.delete(id);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values()).map(e => ({ ...e.schedule }));
+  }
+
+  getDueSchedules(now: Date): Schedule[] {
+    const due: Schedule[] = [];
+    for (const entry of this.schedules.values()) {
+      if (shouldRunAt(entry.parsed, now, entry.schedule.lastRun)) {
+        entry.schedule.lastRun = now;
+        due.push({ ...entry.schedule });
+      }
+    }
+    return due;
+  }
+}
diff --git a/src/task-queue-system.ts b/src/task-queue-system.ts
new file mode 100644
index 0000000..a0eee7d
--- /dev/null
+++ b/src/task-queue-system.ts
@@ -0,0 +1,478 @@
+import {
+  type TaskData,
+  type TaskOptions,
+  type ProgressCallback,
+  type Middleware,
+  type ProcessHandler,
+  type ScheduleOptions,
+  type Schedule,
+  type ShutdownOptions,
+  type ShutdownResult,
+  type ShutdownCallback,
+  DEFAULT_QUEUE_NAME,
+} from './types.js';
+import { createTask } from './task.js';
+import { Queue } from './queue.js';
+import { Scheduler } from './scheduler.js';
+
+export class TaskQueueSystem {
+  private queues: Map<string, Queue> = new Map();
+  private allTasks: Map<string, TaskData> = new Map();
+  private scheduler: Scheduler = new Scheduler();
+  private isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: ShutdownCallback[] = [];
+
+  // ─── Phase 1: Basic FIFO Queue ──────────────────────────
+
+  addTask(payload: unknown, options: TaskOptions = {}): TaskData {
+    if (this.isShuttingDown) {
+      throw new Error('Cannot add tasks: system is shutting down.');
+    }
+
+    const queueName = options.queueName ?? DEFAULT_QUEUE_NAME;
+    const task = createTask(payload, { ...options, queueName });
+
+    // Phase 7: Validate dependencies
+    if (task.dependencies.length > 0) {
+      for (const depId of task.dependencies) {
+        const dep = this.allTasks.get(depId);
+        if (!dep) {
+          throw new Error(`Dependency task "${depId}" does not exist.`);
+        }
+      }
+      // Check for circular dependencies
+      this.detectCircularDependencies(task.id, task.dependencies);
+    }
+
+    this.allTasks.set(task.id, task);
+    const queue = this.getOrCreateQueue(queueName);
+    queue.addTask(task);
+    return task;
+  }
+
+  getNextTask(queueName?: string): TaskData | null {
+    const name = queueName ?? DEFAULT_QUEUE_NAME;
+    const queue = this.queues.get(name);
+    if (!queue) return null;
+
+    const now = new Date();
+    return queue.getNextTask(now, (task) => this.areDependenciesMet(task));
+  }
+
+  getTaskCount(queueName?: string): number {
+    const name = queueName ?? DEFAULT_QUEUE_NAME;
+    const queue = this.queues.get(name);
+    if (!queue) return 0;
+    return queue.getPendingCount();
+  }
+
+  getTask(taskId: string): TaskData | null {
+    return this.allTasks.get(taskId) ?? null;
+  }
+
+  // ─── Phase 2: Named Queues ──────────────────────────────
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ─── Phase 5: Complete / Fail ───────────────────────────
+
+  completeTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state (current: ${task.status}).`);
+    }
+
+    const queue = this.queues.get(task.queueName);
+    if (!queue) {
+      throw new Error(`Queue "${task.queueName}" not found.`);
+    }
+
+    queue.completeTask(taskId);
+
+    // Phase 7: Check if any blocked tasks are now unblocked
+    // (they remain in their queues but will now pass the dependency check)
+  }
+
+  failTask(taskId: string, error: Error | string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state (current: ${task.status}).`);
+    }
+
+    const queue = this.queues.get(task.queueName);
+    if (!queue) {
+      throw new Error(`Queue "${task.queueName}" not found.`);
+    }
+
+    queue.failTask(taskId, error);
+  }
+
+  // ─── Phase 6: Dead Letter Queue ────────────────────────
+
+  getDeadLetterTasks(queueName?: string): TaskData[] {
+    const name = queueName ?? DEFAULT_QUEUE_NAME;
+    const queue = this.queues.get(name);
+    if (!queue) return [];
+    return queue.getDeadLetterTasks();
+  }
+
+  retryDeadLetterTask(taskId: string): TaskData {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    if (task.status !== 'failed') {
+      throw new Error(`Task "${taskId}" is not in failed state.`);
+    }
+
+    const queue = this.queues.get(task.queueName);
+    if (!queue) {
+      throw new Error(`Queue "${task.queueName}" not found.`);
+    }
+
+    const removed = queue.removeFromDeadLetter(taskId);
+    if (!removed) {
+      throw new Error(`Task "${taskId}" not found in dead letter queue.`);
+    }
+
+    // Reset for fresh retry
+    task.status = 'pending';
+    task.attempts = 0;
+    task.errors = [];
+    task.progress = 0;
+    task.progressMessage = undefined;
+    task.availableAt = null;
+    task.updatedAt = new Date();
+
+    queue.addTask(task);
+    return task;
+  }
+
+  clearDeadLetterQueue(queueName?: string): void {
+    const name = queueName ?? DEFAULT_QUEUE_NAME;
+    const queue = this.queues.get(name);
+    if (queue) {
+      queue.clearDeadLetterQueue();
+    }
+  }
+
+  // ─── Phase 7: Dependencies ─────────────────────────────
+
+  private areDependenciesMet(task: TaskData): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (!dep || dep.status !== 'completed') {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  private detectCircularDependencies(newTaskId: string, dependencies: string[]): void {
+    // BFS/DFS to check if any dependency chain leads back to newTaskId
+    const visited = new Set<string>();
+    const stack = [...dependencies];
+
+    while (stack.length > 0) {
+      const currentId = stack.pop()!;
+      if (currentId === newTaskId) {
+        throw new Error('Circular dependency detected.');
+      }
+      if (visited.has(currentId)) continue;
+      visited.add(currentId);
+
+      const currentTask = this.allTasks.get(currentId);
+      if (currentTask) {
+        for (const depId of currentTask.dependencies) {
+          stack.push(depId);
+        }
+      }
+    }
+  }
+
+  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+
+    const pending: string[] = [];
+    let completed = 0;
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (dep && dep.status === 'completed') {
+        completed++;
+      } else {
+        pending.push(depId);
+      }
+    }
+
+    return {
+      total: task.dependencies.length,
+      completed,
+      pending,
+    };
+  }
+
+  // ─── Phase 8: Concurrency Control ──────────────────────
+
+  setConcurrency(queueName: string, limit: number | null): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.setConcurrencyLimit(limit);
+  }
+
+  getConcurrency(queueName: string): { limit: number | null; active: number } {
+    const queue = this.queues.get(queueName);
+    if (!queue) {
+      return { limit: null, active: 0 };
+    }
+    return {
+      limit: queue.getConcurrencyLimit(),
+      active: queue.getProcessingCount(),
+    };
+  }
+
+  // ─── Phase 9: Progress & Cancellation ──────────────────
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);
+    }
+
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state.`);
+    }
+
+    const queue = this.queues.get(task.queueName);
+    if (queue) {
+      queue.updateProgress(taskId, progress, message);
+    }
+  }
+
+  onProgress(taskId: string, callback: ProgressCallback): () => void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+
+    const queue = this.queues.get(task.queueName);
+    if (!queue) {
+      throw new Error(`Queue "${task.queueName}" not found.`);
+    }
+
+    return queue.onProgress(taskId, callback);
+  }
+
+  cancelTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(
+        `Task "${taskId}" cannot be cancelled (current status: ${task.status}).`
+      );
+    }
+
+    const queue = this.queues.get(task.queueName);
+    if (queue) {
+      queue.cancelTask(taskId);
+    }
+  }
+
+  // ─── Phase 10: Recurring Tasks ─────────────────────────
+
+  addSchedule(
+    id: string,
+    cronExpression: string,
+    queueName: string,
+    payload: unknown,
+    options: ScheduleOptions = {}
+  ): Schedule {
+    return this.scheduler.addSchedule(id, cronExpression, queueName, payload, options);
+  }
+
+  removeSchedule(id: string): boolean {
+    return this.scheduler.removeSchedule(id);
+  }
+
+  getSchedules(): Schedule[] {
+    return this.scheduler.getSchedules();
+  }
+
+  tick(now?: Date): TaskData[] {
+    const currentTime = now ?? new Date();
+    const dueSchedules = this.scheduler.getDueSchedules(currentTime);
+    const tasks: TaskData[] = [];
+
+    for (const schedule of dueSchedules) {
+      const task = this.addTask(schedule.payload, {
+        queueName: schedule.queueName,
+        priority: schedule.options.priority,
+        maxRetries: schedule.options.maxRetries,
+        backoffDelay: schedule.options.backoffDelay,
+      });
+      task.scheduledBy = schedule.id;
+      tasks.push(task);
+    }
+
+    return tasks;
+  }
+
+  // ─── Phase 11: Middleware ──────────────────────────────
+
+  use(queueName: string, middleware: Middleware): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.use(middleware);
+  }
+
+  process(queueName: string, handler: ProcessHandler): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.setHandler(handler);
+  }
+
+  async processNext(queueName?: string): Promise<TaskData | null> {
+    const name = queueName ?? DEFAULT_QUEUE_NAME;
+    const task = this.getNextTask(name);
+    if (!task) return null;
+
+    const queue = this.queues.get(name)!;
+    const middlewares = queue.getMiddlewares();
+    const handler = queue.getHandler();
+
+    try {
+      await this.runMiddlewareChain(task, middlewares, handler);
+
+      // If task is still processing after middleware+handler, auto-complete
+      if (task.status === 'processing') {
+        this.completeTask(task.id);
+      }
+    } catch (err) {
+      // If task is still processing, fail it
+      if (task.status === 'processing') {
+        const errorMsg = err instanceof Error ? err : new Error(String(err));
+        this.failTask(task.id, errorMsg);
+      }
+    }
+
+    return task;
+  }
+
+  private async runMiddlewareChain(
+    task: TaskData,
+    middlewares: Middleware[],
+    handler: ProcessHandler | null
+  ): Promise<void> {
+    let index = 0;
+    const next = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, next);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+    await next();
+  }
+
+  // ─── Phase 12: Graceful Shutdown ──────────────────────
+
+  onShutdown(callback: ShutdownCallback): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.executeShutdown(options);
+    return this.shutdownPromise;
+  }
+
+  private async executeShutdown(options: ShutdownOptions): Promise<ShutdownResult> {
+    const timeout = options.timeout ?? 30000;
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      try {
+        await cb();
+      } catch {
+        // Shutdown callbacks shouldn't prevent shutdown
+      }
+    }
+
+    // Count initial processing tasks
+    let initialProcessingCount = 0;
+    for (const queue of this.queues.values()) {
+      initialProcessingCount += queue.getProcessingCount();
+    }
+
+    if (initialProcessingCount === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete up to timeout
+    const waitStart = Date.now();
+    while (Date.now() - waitStart < timeout) {
+      let stillProcessingCount = 0;
+      for (const queue of this.queues.values()) {
+        stillProcessingCount += queue.getProcessingCount();
+      }
+      if (stillProcessingCount === 0) break;
+      await new Promise(resolve => setTimeout(resolve, 50));
+    }
+
+    // Force-cancel anything still processing
+    let forceCancelled = 0;
+    for (const queue of this.queues.values()) {
+      const stillProcessing = queue.getProcessingTasks();
+      for (const task of stillProcessing) {
+        queue.cancelTask(task.id);
+        forceCancelled++;
+      }
+    }
+
+    const completed = initialProcessingCount - forceCancelled;
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  get shuttingDown(): boolean {
+    return this.isShuttingDown;
+  }
+
+  // ─── Internal ─────────────────────────────────────────
+
+  private getOrCreateQueue(name: string): Queue {
+    let queue = this.queues.get(name);
+    if (!queue) {
+      queue = new Queue(name);
+      this.queues.set(name, queue);
+    }
+    return queue;
+  }
+}
