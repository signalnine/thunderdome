+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../src/index.js';
+
+describe('Phase 2: Named Queues', () => {
+  let tqs: TaskQueueSystem;
+
+  beforeEach(() => {
+    tqs = new TaskQueueSystem();
+  });
+
+  it('should add tasks to a specific named queue', () => {
+    tqs.addTask('email', { queueName: 'emails' });
+    tqs.addTask('report', { queueName: 'reports' });
+
+    expect(tqs.getTaskCount('emails')).toBe(1);
+    expect(tqs.getTaskCount('reports')).toBe(1);
+  });
+
+  it('should use default queue when no name is given', () => {
+    tqs.addTask('default-task');
+    expect(tqs.getTaskCount()).toBe(1);
+    expect(tqs.getTaskCount('default')).toBe(1);
+  });
+
+  it('should retrieve from the specified queue only', () => {
+    tqs.addTask('email1', { queueName: 'emails' });
+    tqs.addTask('report1', { queueName: 'reports' });
+
+    const task = tqs.getNextTask('emails');
+    expect(task?.payload).toBe('email1');
+    expect(tqs.getTaskCount('reports')).toBe(1);
+  });
+
+  it('should return null for non-existent queue', () => {
+    expect(tqs.getNextTask('nonexistent')).toBeNull();
+  });
+
+  it('should return null for empty queue', () => {
+    tqs.addTask('task', { queueName: 'myqueue' });
+    tqs.getNextTask('myqueue');
+    expect(tqs.getNextTask('myqueue')).toBeNull();
+  });
+
+  it('should create queues implicitly', () => {
+    expect(tqs.getQueueNames()).toEqual([]);
+    tqs.addTask('task', { queueName: 'new-queue' });
+    expect(tqs.getQueueNames()).toContain('new-queue');
+  });
+
+  it('should list all queue names', () => {
+    tqs.addTask('a', { queueName: 'alpha' });
+    tqs.addTask('b', { queueName: 'beta' });
+    tqs.addTask('c', { queueName: 'gamma' });
+
+    const names = tqs.getQueueNames();
+    expect(names).toContain('alpha');
+    expect(names).toContain('beta');
+    expect(names).toContain('gamma');
+  });
+
+  it('should be backward-compatible with Phase 1 (no queue name)', () => {
+    tqs.addTask('first');
+    tqs.addTask('second');
+    const task = tqs.getNextTask();
+    expect(task?.payload).toBe('first');
+    expect(tqs.getTaskCount()).toBe(1);
+  });
+});
