rEqual(aAssignment.endTime + 15);\n    });\n\n    it('should handle chain of prerequisites', () => {\n      const events = [\n        makeEvent('C', 30, { prerequisites: ['B'] }),\n        makeEvent('B', 30, { prerequisites: ['A'] }),\n        makeEvent('A', 30),\n      ];\n      const rooms = [makeRoom('R1', 10)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n      const c = result.assignments.find(x => x.eventId === 'C')!;\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n      expect(c.startTime).toBeGreaterThanOrEqual(b.endTime + 15);\n    });\n\n    it('should apply gap between prerequisite and dependent events', () => {\n      const events = [\n        makeEvent('A', 60),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n      ];\n      const rooms = [makeRoom('R1', 10), makeRoom('R2', 10)];\n      const options: ScheduleOptions = { ...defaultOptions, gap: 20 };\n      const result = schedule(events, rooms, options);\n\n      expect(result.assignments).toHaveLength(2);\n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 20);\n    });\n  });\n\n  describe('cycle detection', () => {\n    it('should throw on self-referencing prerequisite', () => {\n      const events = [makeEvent('A', 60, { prerequisites: ['A'] })];\n      const rooms = [makeRoom('R1', 10)];\n\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);\n    });\n\n    it('should throw on two-event cycle', () => {\n      const events = [\n        makeEvent('A', 60, { prerequisites: ['B'] }),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n      ];\n      const rooms = [makeRoom('R1', 10)];\n\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);\n    });\n\n    it('should throw on multi-event cycle', () => {\n      const events = [\n        makeEvent('A', 60, { prerequisites: ['C'] }),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n        makeEvent('C', 60, { prerequisites: ['B'] }),\n      ];\n      const rooms = [makeRoom('R1', 10)];\n\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);\n    });\n\n    it('should not throw for valid DAG', () => {\n      const events = [\n        makeEvent('A', 60),\n        makeEvent('B', 60, { prerequisites: ['A'] }),\n        makeEvent('C', 60, { prerequisites: ['A'] }),\n        makeEvent('D', 60, { prerequisites: ['B', 'C'] }),\n      ];\n      const rooms = [makeRoom('R1', 10), makeRoom('R2', 10)];\n\n      expect(() => schedule(events, rooms, defaultOptions)).not.toThrow();\n    });\n  });\n\n  describe('room preferences', () => {\n    it('should honor preferred room when possible', () => {\n      const events = [makeEvent('A', 60, { preferredRoom: 'R2' })];\n      const rooms = [makeRoom('R1', 10), makeRoom('R2', 10)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R2');\n    });\n\n    it('should fall back to other room when preferred is not suitable', () => {\n      const events = [makeEvent('A', 60, { attendees: 15, preferredRoom: 'R1' })];\n      const rooms = [makeRoom('R1', 10), makeRoom('R2', 20)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R2');\n    });\n\n    it('should fall back when preferred room is full', () => {\n      const events = [\n        makeEvent('A', 420, { preferredRoom: 'R1' }), // takes most of day\n        makeEvent('B', 60, { preferredRoom: 'R1' }),\n      ];\n      const rooms = [makeRoom('R1', 10), makeRoom('R2', 10)];\n      const options: ScheduleOptions = { startTime: 540, endTime: 1020 }; // 8 hours\n      const result = schedule(events, rooms, options);\n\n      expect(result.assignments).toHaveLength(2);\n      // Both events should be scheduled, B might not be in R1\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize events scheduled', () => {\n      // 3 events, only 2 can fit in the time window in one room\n      const events = [\n        makeEvent('A', 120),\n        makeEvent('B', 120),\n        makeEvent('C', 120),\n      ];\n      const rooms = [makeRoom('R1', 10)];\n      // 540 to 840 = 300 min, fits 2 events with gap (120 + 15 + 120 = 255)\n      const options: ScheduleOptions = { startTime: 540, endTime: 840 };\n      const result = schedule(events, rooms, options);\n\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(1);\n    });\n\n    it('should prefer scheduling more events over fewer', () => {\n      // One big event (200 min) or two smaller ones (90 min each, 90+15+90=195)\n      // Room has 210 minutes\n      const events = [\n        makeEvent('BIG', 200),\n        makeEvent('SMALL1', 90),\n        makeEvent('SMALL2', 90),\n      ];\n      const rooms = [makeRoom('R1', 10)];\n      const options: ScheduleOptions = { startTime: 540, endTime: 750, gap: 15 };\n      const result = schedule(events, rooms, options);\n\n      // Should schedule 2 small events rather than 1 big event\n      expect(result.assignments).toHaveLength(2);\n      const scheduledIds = result.assignments.map(a => a.eventId).sort();\n      expect(scheduledIds).toEqual(['SMALL1', 'SMALL2']);\n    });\n\n    it('should handle all events unschedulable', () => {\n      const events = [\n        makeEvent('A', 60, { attendees: 100 }),\n        makeEvent('B', 60, { attendees: 100 }),\n      ];\n      const rooms = [makeRoom('R1', 10)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(2);\n    });\n  });\n\n  describe('edge cases', () => {\n    it('should handle event with zero gap', () => {\n      const events = [\n        makeEvent('A', 60),\n        makeEvent('B', 60),\n      ];\n      const rooms = [makeRoom('R1', 10)];\n      const options: ScheduleOptions = { ...defaultOptions, gap: 0 };\n      const result = schedule(events, rooms, options);\n\n      expect(result.assignments).toHaveLength(2);\n      const [a, b] = result.assignments.sort((x, y) => x.startTime - y.startTime);\n      expect(b.startTime).toBeGreaterThanOrEqual(a.endTime);\n    });\n\n    it('should handle prerequisite referencing non-existent event', () => {\n      const events = [\n        makeEvent('A', 60, { prerequisites: ['NONEXISTENT'] }),\n      ];\n      const rooms = [makeRoom('R1', 10)];\n      // Should not throw - non-existent prerequisite is ignored\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n\n    it('should handle multiple prerequisites for one event', () => {\n      const events = [\n        makeEvent('A', 30),\n        makeEvent('B', 30),\n        makeEvent('C', 30, { prerequisites: ['A', 'B'] }),\n      ];\n      const rooms = [makeRoom('R1', 10), makeRoom('R2', 10)];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const a = result.assignments.find(x => x.eventId === 'A')!;\n      const b = result.assignments.find(x => x.eventId === 'B')!;\n      const c = result.assignments.find(x => x.eventId === 'C')!;\n      const prereqEnd = Math.max(a.endTime, b.endTime);\n      expect(c.startTime).toBeGreaterThanOrEqual(prereqEnd + 15);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
