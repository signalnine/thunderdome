+++ b/src/scheduler.ts
@@ -0,0 +1,220 @@
+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+import { topologicalSort } from './graph.js';
+
+interface RoomState {
+  assignments: Assignment[];
+}
+
+/**
+ * Find valid start times for an event in a specific room.
+ * Returns start times sorted earliest-first.
+ */
+function findValidStartTimes(
+  event: Event,
+  room: Room,
+  roomState: RoomState,
+  options: ScheduleOptions,
+  gap: number,
+  earliestStart: number
+): number[] {
+  const attendees = event.attendees ?? 1;
+  if (attendees > room.capacity) {
+    return [];
+  }
+
+  const duration = event.duration;
+  const latestStart = options.endTime - duration;
+
+  if (earliestStart > latestStart) {
+    return [];
+  }
+
+  const existing = roomState.assignments.slice().sort((a, b) => a.startTime - b.startTime);
+
+  if (existing.length === 0) {
+    return [earliestStart];
+  }
+
+  // Build list of candidate start times by checking each "free slot" in the room.
+  // Free slots are: [windowStart, first event start), between consecutive events, [last event end, windowEnd)
+  const candidates: number[] = [];
+
+  // Slot before first event
+  {
+    const slotEnd = existing[0].startTime;
+    const start = earliestStart;
+    if (start + duration + gap <= slotEnd) {
+      candidates.push(start);
+    }
+  }
+
+  // Slots between consecutive events
+  for (let i = 0; i < existing.length - 1; i++) {
+    const slotStart = existing[i].endTime + gap;
+    const slotEnd = existing[i + 1].startTime;
+    const start = Math.max(slotStart, earliestStart);
+    if (start + duration + gap <= slotEnd) {
+      candidates.push(start);
+    }
+  }
+
+  // Slot after last event
+  {
+    const last = existing[existing.length - 1];
+    const slotStart = last.endTime + gap;
+    const start = Math.max(slotStart, earliestStart);
+    if (start + duration <= options.endTime) {
+      candidates.push(start);
+    }
+  }
+
+  return candidates;
+}
+
+/**
+ * Schedule events into rooms respecting all constraints.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? 15;
+
+  // Topological sort (throws on cycles)
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  // Order events by topological sort
+  const orderedEvents = topoOrder
+    .filter(id => eventMap.has(id))
+    .map(id => eventMap.get(id)!);
+
+  // Best result found so far
+  let bestResult: ScheduleResult = { assignments: [], unscheduled: events.map(e => e.id) };
+
+  // Room states for backtracking
+  const roomStates = new Map<string, RoomState>();
+  for (const room of rooms) {
+    roomStates.set(room.id, { assignments: [] });
+  }
+
+  // Track assignments for prerequisite lookup
+  const assignmentMap = new Map<string, Assignment>();
+
+  function getEarliestStartForEvent(event: Event): number {
+    let earliest = options.startTime;
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        const prereqAssignment = assignmentMap.get(prereqId);
+        if (prereqAssignment) {
+          earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+        }
+      }
+    }
+    return earliest;
+  }
+
+  function hasUnmetPrerequisites(event: Event): boolean {
+    if (!event.prerequisites) return false;
+    for (const prereqId of event.prerequisites) {
+      if (eventMap.has(prereqId) && !assignmentMap.has(prereqId)) {
+        return true;
+      }
+    }
+    return false;
+  }
+
+  /**
+   * Backtracking search.
+   */
+  function backtrack(
+    idx: number,
+    currentAssignments: Assignment[],
+    currentUnscheduled: string[]
+  ): void {
+    // Pruning: can we possibly beat the best?
+    const remaining = orderedEvents.length - idx;
+    const possibleTotal = currentAssignments.length + remaining;
+    if (possibleTotal <= bestResult.assignments.length) {
+      return;
+    }
+
+    if (idx >= orderedEvents.length) {
+      if (currentAssignments.length > bestResult.assignments.length) {
+        bestResult = {
+          assignments: [...currentAssignments],
+          unscheduled: [...currentUnscheduled]
+        };
+      }
+      return;
+    }
+
+    const event = orderedEvents[idx];
+
+    // If prerequisites were skipped, this event can't be scheduled
+    if (hasUnmetPrerequisites(event)) {
+      currentUnscheduled.push(event.id);
+      backtrack(idx + 1, currentAssignments, currentUnscheduled);
+      currentUnscheduled.pop();
+      return;
+    }
+
+    const earliestStart = getEarliestStartForEvent(event);
+
+    // Order rooms: preferred room first
+    const sortedRooms = [...rooms].sort((a, b) => {
+      if (event.preferredRoom === a.id) return -1;
+      if (event.preferredRoom === b.id) return 1;
+      return 0;
+    });
+
+    for (const room of sortedRooms) {
+      const roomState = roomStates.get(room.id)!;
+      const startTimes = findValidStartTimes(event, room, roomState, options, gap, earliestStart);
+
+      for (const startTime of startTimes) {
+        const assignment: Assignment = {
+          eventId: event.id,
+          roomId: room.id,
+          startTime,
+          endTime: startTime + event.duration
+        };
+
+        // Place the event
+        roomState.assignments.push(assignment);
+        assignmentMap.set(event.id, assignment);
+        currentAssignments.push(assignment);
+
+        backtrack(idx + 1, currentAssignments, currentUnscheduled);
+
+        // Early exit: all events scheduled
+        if (bestResult.unscheduled.length === 0) {
+          return;
+        }
+
+        // Undo placement
+        currentAssignments.pop();
+        assignmentMap.delete(event.id);
+        roomState.assignments.pop();
+      }
+    }
+
+    // Also try skipping this event (may allow more total events)
+    currentUnscheduled.push(event.id);
+    backtrack(idx + 1, currentAssignments, currentUnscheduled);
+    currentUnscheduled.pop();
+  }
+
+  backtrack(0, [], []);
+
+  return bestResult;
+}
