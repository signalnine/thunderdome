+import type { Event } from './types.js';
+
+const WHITE = 0; // unvisited
+const GRAY = 1;  // in progress
+const BLACK = 2; // visited
+
+/**
+ * Detects cycles in the prerequisite graph and returns a topological order.
+ * Throws an Error if a cycle is found (including self-references).
+ */
+export function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const adj = new Map<string, string[]>();
+
+  for (const event of events) {
+    if (!adj.has(event.id)) {
+      adj.set(event.id, []);
+    }
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (prereq === event.id) {
+          throw new Error(`Cycle detected: event "${event.id}" has itself as a prerequisite`);
+        }
+        if (eventIds.has(prereq)) {
+          if (!adj.has(prereq)) {
+            adj.set(prereq, []);
+          }
+          adj.get(prereq)!.push(event.id);
+        }
+      }
+    }
+  }
+
+  const color = new Map<string, number>();
+  for (const id of eventIds) {
+    color.set(id, WHITE);
+  }
+
+  const order: string[] = [];
+
+  function dfs(node: string): void {
+    color.set(node, GRAY);
+
+    const neighbors = adj.get(node) || [];
+    for (const neighbor of neighbors) {
+      const c = color.get(neighbor)!;
+      if (c === GRAY) {
+        throw new Error(`Cycle detected in prerequisites involving event "${neighbor}"`);
+      }
+      if (c === WHITE) {
+        dfs(neighbor);
+      }
+    }
+
+    color.set(node, BLACK);
+    order.push(node);
+  }
+
+  for (const id of eventIds) {
+    if (color.get(id) === WHITE) {
+      dfs(id);
+    }
+  }
+
+  // Reverse post-order gives topological order
+  order.reverse();
+  return order;
+}
