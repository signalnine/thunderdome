+import { describe, it, expect } from 'vitest';
+import { schedule } from './scheduler.js';
+import type { Event, Room, ScheduleOptions } from './types.js';
+
+const defaultOptions: ScheduleOptions = {
+  startTime: 540, // 9:00 AM
+  endTime: 1020,  // 5:00 PM
+};
+
+function makeRoom(id: string, capacity: number): Room {
+  return { id, name: `Room ${id}`, capacity };
+}
+
+function makeEvent(id: string, duration: number, overrides?: Partial<Event>): Event {
+  return { id, name: `Event ${id}`, duration, ...overrides };
+}
+
+describe('schedule', () => {
+  describe('basic scheduling', () => {
+    it('should schedule a single event', () => {
+      const events = [makeEvent('A', 60)];
+      const rooms = [makeRoom('R1', 10)];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0].eventId).toBe('A');
+      expect(result.assignments[0].roomId).toBe('R1');
+      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);
+      expect(result.assignments[0].endTime).toBeLessThanOrEqual(1020);
+      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+    });
+
+    it('should schedule multiple events in one room', () => {
+      const events = [
+        makeEvent('A', 60),
+        makeEvent('B', 60),
+      ];
+      const rooms = [makeRoom('R1', 10)];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should schedule events in different rooms', () => {
+      const events = [
+        makeEvent('A', 60),
+        makeEvent('B', 60),
+      ];
+      const rooms = [makeRoom('R1', 10), makeRoom('R2', 10)];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should return empty results for empty inputs', () => {
+      const result = schedule([], [], defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle events with no rooms available', () => {
+      const events = [makeEvent('A', 60)];
+      const rooms: Room[] = [];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['A']);
+    });
+  });
+
+  describe('capacity constraints', () => {
+    it('should not schedule an event in a room that is too small', () => {
+      const events = [makeEvent('A', 60, { attendees: 20 })];
+      const rooms = [makeRoom('R1', 10)];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['A']);
+    });
+
+    it('should schedule event in room with sufficient capacity', () => {
+      const events = [makeEvent('A', 60, { attendees: 15 })];
+      const rooms = [makeRoom('R1', 10), makeRoom('R2', 20)];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).toBe('R2');
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should default attendees to 1', () => {
+      const events = [makeEvent('A', 60)]; // no attendees specified
+      const rooms = [makeRoom('R1', 1)];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+  });
+
+  describe('time window constraints', () => {
