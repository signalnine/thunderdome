\n\nLet me write the design document."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":633,"cache_read_input_tokens":22421,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":633},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1918217a-00b3-4fb8-b1e8-1186756acdf3","uuid":"73803c82-ef0c-463b-80f5-ea87a3902b72"}
