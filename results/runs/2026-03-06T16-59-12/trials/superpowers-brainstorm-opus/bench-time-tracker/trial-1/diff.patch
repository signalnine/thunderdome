@@ -0,0 +1,137 @@
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+import { randomUUID } from "node:crypto";
+
+export interface TimeEntry {
+  id: string;
+  task: string;
+  startTime: string;
+  endTime: string | null;
+}
+
+interface TrackerData {
+  entries: TimeEntry[];
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  /**
+   * Start a named timer. Auto-stops any currently running timer.
+   * Throws if the task name is empty or whitespace-only.
+   */
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.endTime = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      id: randomUUID(),
+      task,
+      startTime: new Date().toISOString(),
+      endTime: null,
+    };
+
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  /**
+   * Stop the currently running timer.
+   * Throws if no timer is currently running.
+   */
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.endTime = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  /**
+   * Get all entries, optionally filtered by date range.
+   * Filters based on entry startTime falling within the range.
+   */
+  getEntries(options?: { from?: Date; to?: Date }): TimeEntry[] {
+    if (!options) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter((entry) => {
+      const startTime = new Date(entry.startTime);
+
+      if (options.from && startTime < options.from) {
+        return false;
+      }
+      if (options.to && startTime > options.to) {
+        return false;
+      }
+
+      return true;
+    });
+  }
+
+  /**
+   * Get total milliseconds spent per task name.
+   * Running tasks use the current time for their duration.
+   */
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.startTime).getTime();
+      const end = entry.endTime
+        ? new Date(entry.endTime).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((entry) => entry.endTime === null);
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      if (!existsSync(this.filePath)) {
+        return [];
+      }
+      const raw = readFileSync(this.filePath, "utf-8");
+      const data: TrackerData = JSON.parse(raw);
+      return data.entries ?? [];
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+
+    const data: TrackerData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+}
diff --git a/src/tracker.test.ts b/src/tracker.test.ts
new file mode 100644
index 0000000..a65cdd6
--- /dev/null
+++ b/src/tracker.test.ts
@@ -0,0 +1,229 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "./index.js";
+import { existsSync, rmSync, readFileSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+import { randomUUID } from "node:crypto";
+
+function tempFilePath(): string {
+  return join(tmpdir(), `time-tracker-test-${randomUUID()}`, "data.json");
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    filePath = tempFilePath();
+    tracker = new TimeTracker(filePath);
+  });
+
+  afterEach(() => {
+    const dir = join(filePath, "..");
+    if (existsSync(dir)) {
+      rmSync(dir, { recursive: true, force: true });
+    }
+  });
+
+  describe("start", () => {
+    it("should start a timer and return a time entry", () => {
+      const entry = tracker.start("coding");
+      expect(entry.task).toBe("coding");
+      expect(entry.startTime).toBeTruthy();
+      expect(entry.endTime).toBeNull();
+      expect(entry.id).toBeTruthy();
+    });
+
+    it("should throw when task name is empty", () => {
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw when task name is whitespace only", () => {
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      tracker.start("task1");
+      const entry2 = tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].endTime).not.toBeNull();
+      expect(entries[1].endTime).toBeNull();
+      expect(entry2.task).toBe("task2");
+    });
+
+    it("should support unicode task names", () => {
+      const entry = tracker.start("写代码 🚀");
+      expect(entry.task).toBe("写代码 🚀");
+    });
+
+    it("should support emoji-only task names", () => {
+      const entry = tracker.start("🎯🔥💻");
+      expect(entry.task).toBe("🎯🔥💻");
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop the running timer", () => {
+      tracker.start("coding");
+      const stopped = tracker.stop();
+      expect(stopped.task).toBe("coding");
+      expect(stopped.endTime).not.toBeNull();
+    });
+
+    it("should throw when no timer is running", () => {
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to file", () => {
+      tracker.start("coding");
+      tracker.stop();
+
+      expect(existsSync(filePath)).toBe(true);
+      const raw = readFileSync(filePath, "utf-8");
+      const data = JSON.parse(raw);
+      expect(data.entries).toHaveLength(1);
+      expect(data.entries[0].task).toBe("coding");
+    });
+
+    it("should load entries from file on construction", () => {
+      tracker.start("coding");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const deepPath = join(
+        tmpdir(),
+        `time-tracker-test-${randomUUID()}`,
+        "a",
+        "b",
+        "c",
+        "data.json"
+      );
+      const deepTracker = new TimeTracker(deepPath);
+      deepTracker.start("coding");
+      deepTracker.stop();
+      expect(existsSync(deepPath)).toBe(true);
+
+      // cleanup
+      rmSync(join(deepPath, "..", "..", "..", ".."), {
+        recursive: true,
+        force: true,
+      });
+    });
+
+    it("should handle non-existent file gracefully", () => {
+      const t = new TimeTracker("/tmp/nonexistent-" + randomUUID() + "/data.json");
+      expect(t.getEntries()).toEqual([]);
+    });
+
+    it("should persist unicode task names correctly", () => {
+      tracker.start("日本語タスク 🎌");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("日本語タスク 🎌");
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries when no filter is provided", () => {
+      tracker.start("task1");
+      tracker.start("task2");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+    });
+
+    it("should filter entries by from date", () => {
+      tracker.start("task1");
+      tracker.stop();
+
+      const futureDate = new Date(Date.now() + 100000);
+      const entries = tracker.getEntries({ from: futureDate });
+      expect(entries).toHaveLength(0);
+    });
+
+    it("should filter entries by to date", () => {
+      tracker.start("task1");
+      tracker.stop();
+
+      const pastDate = new Date(Date.now() - 100000);
+      const entries = tracker.getEntries({ to: pastDate });
+      expect(entries).toHaveLength(0);
+    });
+
+    it("should filter entries within a date range", () => {
+      tracker.start("task1");
+      tracker.stop();
+
+      const from = new Date(Date.now() - 10000);
+      const to = new Date(Date.now() + 10000);
+      const entries = tracker.getEntries({ from, to });
+      expect(entries).toHaveLength(1);
+    });
+
+    it("should return a copy, not a reference", () => {
+      tracker.start("task1");
+      tracker.stop();
+
+      const entries1 = tracker.getEntries();
+      const entries2 = tracker.getEntries();
+      expect(entries1).not.toBe(entries2);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should return total time per task", () => {
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("meeting");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["meeting"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should sum multiple entries with the same task name", () => {
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      // Only one key for "coding"
+      expect(Object.keys(summary)).toEqual(["coding"]);
+    });
+
+    it("should use current time for running tasks", () => {
+      tracker.start("coding");
+      // Don't stop it
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should return empty object when no entries", () => {
+      const summary = tracker.getSummary();
+      expect(summary).toEqual({});
+    });
+  });
+});
