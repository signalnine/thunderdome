+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HLwTgghfoiXXtFj88j3RLe","type":"tool_result","content":"File created successfully at: /workspace/tests/services.test.ts"}]},"parent_tool_use_id":null,"session_id":"77ff2643-2557-4533-b685-8cb0d94a2540","uuid":"fee0adad-dd57-43d8-a979-54fa3357c015","tool_use_result":{"type":"create","filePath":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\n\ndescribe('Catalog Service', () => {\n  let bus: EventBus;\n  let catalog: ReturnType<typeof createCatalogService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    catalog = createCatalogService(bus);\n  });\n\n  it('should create a product and return an id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeTruthy();\n    expect(typeof id).toBe('string');\n  });\n\n  it('should retrieve a created product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for non-existent product', () => {\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n    catalog.createProduct('Book', 5.99, 'books');\n    expect(catalog.listProducts()).toHaveLength(3);\n  });\n\n  it('should list products by category', () => {\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n    catalog.createProduct('Book', 5.99, 'books');\n    expect(catalog.listProducts('gadgets')).toHaveLength(2);\n    expect(catalog.listProducts('books')).toHaveLength(1);\n  });\n\n  it('should search products by name (case-insensitive)', () => {\n    catalog.createProduct('Widget Pro', 9.99, 'gadgets');\n    catalog.createProduct('Super Widget', 19.99, 'gadgets');\n    catalog.createProduct('Book', 5.99, 'books');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(2);\n  });\n\n  it('should update a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { name: 'Widget Pro', price: 14.99 });\n    const product = catalog.getProduct(id);\n    expect(product!.name).toBe('Widget Pro');\n    expect(product!.price).toBe(14.99);\n    expect(product!.category).toBe('gadgets');\n  });\n\n  it('should remove a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // Give the async emit time to complete\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    const productEvents = log.filter(e => e.event === Events.PRODUCT_CREATED);\n    expect(productEvents).toHaveLength(1);\n    expect((productEvents[0].payload as { name: string }).name).toBe('Widget');\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('should set and get stock', () => {\n    inventory.setStock('prod1', 100);\n    expect(inventory.getStock('prod1')).toBe(100);\n  });\n\n  it('should return 0 for unknown products', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock when sufficient', () => {\n    inventory.setStock('prod1', 100);\n    expect(inventory.reserve('prod1', 50)).toBe(true);\n    expect(inventory.reserve('prod1', 50)).toBe(true);\n    expect(inventory.reserve('prod1', 1)).toBe(false);\n  });\n\n  it('should release reserved stock', () => {\n    inventory.setStock('prod1', 100);\n    inventory.reserve('prod1', 50);\n    inventory.release('prod1', 50);\n    expect(inventory.reserve('prod1', 100)).toBe(true);\n  });\n\n  it('should emit low stock alert', async () => {\n    let alertEmitted = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertEmitted = true; });\n    inventory.setLowStockThreshold('prod1', 10);\n    inventory.setStock('prod1', 5);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alertEmitted).toBe(true);\n  });\n\n  it('should emit low stock alert when threshold is set on already-low stock', async () => {\n    let alertEmitted = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertEmitted = true; });\n    inventory.setStock('prod1', 5);\n    await new Promise(r => setTimeout(r, 10));\n    inventory.setLowStockThreshold('prod1', 10);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alertEmitted).toBe(true);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('should create a cart', () => {\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n  });\n\n  it('should add items to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'prod1', quantity: 2 });\n  });\n\n  it('should consolidate duplicate products', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.addItem(id, 'prod1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items from cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.addItem(id, 'prod2', 1);\n    cart.removeItem(id, 'prod1');\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].productId).toBe('prod2');\n  });\n\n  it('should update quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.updateQuantity(id, 'prod1', 5);\n    expect(cart.getCart(id)!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove item when quantity is set to 0', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.updateQuantity(id, 'prod1', 0);\n    expect(cart.getCart(id)!.items).toHaveLength(0);\n  });\n\n  it('should clear cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.addItem(id, 'prod2', 1);\n    cart.clearCart(id);\n    expect(cart.getCart(id)!.items).toHaveLength(0);\n  });\n\n  it('should return null for non-existent cart', () => {\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('should calculate total with tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n      { productId: 'p2', quantity: 1, price: 20 },\n    ]);\n    expect(result.subtotal).toBe(40);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(4); // 10% of 40\n    expect(result.total).toBe(44);\n  });\n\n  it('should apply discount codes', () => {\n    pricing.addDiscountCode('SAVE20', 20);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE20',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(20);\n    expect(result.tax).toBe(8); // 10% of 80\n    expect(result.total).toBe(88);\n  });\n\n  it('should ignore invalid discount codes', () => {\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID',\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track prices from product:created events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 29.99, category: 'test' });\n    expect(pricing.getPrice('p1')).toBe(29.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('should create an order', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    expect(id).toBeTruthy();\n    const order = orders.getOrder(id);\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('should update order status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order events', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    expect(log.filter(e => e.event === Events.ORDER_CREATED)).toHaveLength(1);\n    expect(log.filter(e => e.event === Events.ORDER_STATUS_CHANGED)).toHaveLength(1);\n    const statusChange = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect((statusChange!.payload as { previousStatus: string }).previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders by user', () => {\n    orders.createOrder('user1', 'cart1', 100);\n    orders.createOrder('user1', 'cart2', 200);\n    orders.createOrder('user2', 'cart3', 50);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for non-existent order', () => {\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true, timeoutMs: 10 });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should emit payment processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    const paymentEvents = log.filter(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(paymentEvents).toHaveLength(1);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund a non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('fake-tx');\n    expect(refunded).toBe(false);\n  });\n\n  it('should not refund an already refunded transaction', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    await payment.refund(result.transactionId!);\n    const refundedAgain = await payment.refund(result.transactionId!);\n    expect(refundedAgain).toBe(false);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n  });\n\n  it('should subscribe users and deliver notifications', async () => {\n    notifications.subscribe('user1');\n    // Simulate order creation to map orderId -> userId\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'order1', userId: 'user1', cartId: 'cart1', total: 100 });\n    // Simulate order status change\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'order1', status: 'confirmed', previousStatus: 'pending' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(1);\n    expect(notifs[0].type).toBe('order_status');\n  });\n\n  it('should not notify unsubscribed users', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'order1', userId: 'user1', cartId: 'cart1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'order1', status: 'confirmed', previousStatus: 'pending' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(0);\n  });\n\n  it('should deliver payment notifications', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'order1', userId: 'user1', cartId: 'cart1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'order1', status: 'success', transactionId: 'tx1' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toHaveLength(1);\n    expect(notifs[0].type).toBe('payment');\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('should count events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Test', price: 10, category: 'test' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Test2', price: 20, category: 'test' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count failed payments as revenue', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'failed' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    // 2 unique carts, 1 order\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 1 }] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products by order quantity', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 10 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe('p2');\n    expect(top[0].count).toBe(12);\n    expect(top[1].productId).toBe('p1');\n    expect(top[1].count).toBe(5);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  let bus: EventBus;\n\n  it('should handle a complete purchase flow', async () => {\n    bus = new EventBus();\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orderService = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notificationService = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // 1. Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    await new Promise(r => setTimeout(r, 10));\n\n    // 2. Set inventory\n    inventory.setStock(productId, 50);\n\n    // 3. Subscribe user to notifications\n    notificationService.subscribe('user1');\n\n    // 4. Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, productId, 2);\n    await new Promise(r => setTimeout(r, 10));\n\n    // 5. Calculate price\n    const price = pricing.getPrice(productId);\n    expect(price).toBe(999.99);\n    const total = pricing.calculateTotal([\n      { productId, quantity: 2, price },\n    ]);\n    expect(total.subtotal).toBe(1999.98);\n    expect(total.tax).toBeCloseTo(200, 1);\n\n    // 6. Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n\n    // 7. Create order\n    const orderId = orderService.createOrder('user1', cartId, total.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    // 8. Process payment\n    const paymentResult = await payment.processPayment(orderId, total.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // 9. Update order status\n    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    // 10. Verify notifications\n    const notifs = notificationService.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(2); // payment + status change\n\n    // 11. Verify analytics\n    expect(analytics.getRevenue()).toBe(total.total);\n    expect(analytics.getConversionRate()).toBe(1);\n    const topProducts = analytics.getTopProducts(1);\n    expect(topProducts[0].productId).toBe(productId);\n    expect(topProducts[0].count).toBe(2);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
