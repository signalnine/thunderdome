cations.set(userId, []);\n    }\n    notifications.get(userId)!.push(notification);\n  });\n\n  return {\n    subscribe(userId: string): void {\n      subscribers.add(userId);\n    },\n\n    getNotifications(userId: string) {\n      return (notifications.get(userId) ?? []).map(n => ({ ...n }));\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":739,"cache_read_input_tokens":31811,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":739},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"77ff2643-2557-4533-b685-8cb0d94a2540","uuid":"dac84874-7239-4b3e-ae1a-34834ecef121"}
