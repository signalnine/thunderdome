index 0000000..f5402f8
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,228 @@
+// Operational Transform engine for collaborative text editing
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+/**
+ * Transform two concurrent operations so they can be applied in either order.
+ * Given opA and opB that were both created against the same document state,
+ * returns [opA', opB'] such that:
+ *   apply(apply(doc, opA), opB') === apply(apply(doc, opB), opA')
+ *
+ * Returns arrays because some cases (insert within delete) require splitting.
+ */
+export function transform(opA: Operation, opB: Operation): [Operation[], Operation[]] {
+  if (opA.type === 'insert' && opB.type === 'insert') {
+    return transformInsertInsert(opA, opB);
+  }
+  if (opA.type === 'insert' && opB.type === 'delete') {
+    return transformInsertDelete(opA, opB);
+  }
+  if (opA.type === 'delete' && opB.type === 'insert') {
+    const [bPrime, aPrime] = transformInsertDelete(opB, opA);
+    return [aPrime, bPrime];
+  }
+  // Both deletes
+  return transformDeleteDelete(opA as DeleteOp, opB as DeleteOp);
+}
+
+function transformInsertInsert(opA: InsertOp, opB: InsertOp): [Operation[], Operation[]] {
+  if (opA.position < opB.position || (opA.position === opB.position && opA.text <= opB.text)) {
+    return [
+      [{ ...opA }],
+      [{ ...opB, position: opB.position + opA.text.length }],
+    ];
+  } else {
+    return [
+      [{ ...opA, position: opA.position + opB.text.length }],
+      [{ ...opB }],
+    ];
+  }
+}
+
+function transformInsertDelete(opA: InsertOp, opB: DeleteOp): [Operation[], Operation[]] {
+  if (opA.position <= opB.position) {
+    // Insert is before or at the delete position
+    return [
+      [{ ...opA }],
+      [{ ...opB, position: opB.position + opA.text.length }],
+    ];
+  } else if (opA.position >= opB.position + opB.count) {
+    // Insert is after the deleted range
+    return [
+      [{ ...opA, position: opA.position - opB.count }],
+      [{ ...opB }],
+    ];
+  } else {
+    // Insert is within the deleted range
+    // A': insert at the delete boundary (since chars before insert point are deleted)
+    // B': split delete into two parts to preserve the inserted text
+    const beforeCount = opA.position - opB.position;
+    const afterCount = (opB.position + opB.count) - opA.position;
+
+    const aPrime: Operation[] = [{ ...opA, position: opB.position }];
+    const bPrime: Operation[] = [];
+
+    // Delete chars before the insert
+    if (beforeCount > 0) {
+      bPrime.push({ type: 'delete', position: opB.position, count: beforeCount });
+    }
+    // Delete chars after the insert (accounting for preceding delete + inserted text)
+    if (afterCount > 0) {
+      const afterPos = opB.position + (beforeCount > 0 ? 0 : 0) + opA.text.length;
+      bPrime.push({ type: 'delete', position: afterPos, count: afterCount });
+    }
+
+    if (bPrime.length === 0) {
+      bPrime.push({ type: 'delete', position: opB.position, count: 0 });
+    }
+
+    return [aPrime, bPrime];
+  }
+}
+
+function transformDeleteDelete(opA: DeleteOp, opB: DeleteOp): [Operation[], Operation[]] {
+  // No overlap cases
+  if (opA.position + opA.count <= opB.position) {
+    return [
+      [{ ...opA }],
+      [{ ...opB, position: opB.position - opA.count }],
+    ];
+  }
+  if (opB.position + opB.count <= opA.position) {
+    return [
+      [{ ...opA, position: opA.position - opB.count }],
+      [{ ...opB }],
+    ];
+  }
+
+  // Overlapping deletes
+  const aStart = opA.position;
+  const aEnd = opA.position + opA.count;
+  const bStart = opB.position;
+  const bEnd = opB.position + opB.count;
+
+  if (aStart <= bStart && aEnd >= bEnd) {
+    // A fully contains B
+    return [
+      [{ ...opA, count: opA.count - opB.count }],
+      [{ type: 'delete', position: aStart, count: 0 }],
+    ];
+  }
+  if (bStart <= aStart && bEnd >= aEnd) {
+    // B fully contains A
+    return [
+      [{ type: 'delete', position: bStart, count: 0 }],
+      [{ ...opB, count: opB.count - opA.count }],
+    ];
+  }
+  if (aStart < bStart) {
+    // A starts first, partial overlap
+    const overlap = aEnd - bStart;
+    return [
+      [{ ...opA, count: opA.count - overlap }],
+      [{ ...opB, position: aStart, count: opB.count - overlap }],
+    ];
+  }
+  // B starts first, partial overlap
+  const overlap = bEnd - aStart;
+  return [
+    [{ ...opA, position: bStart, count: opA.count - overlap }],
+    [{ ...opB, count: opB.count - overlap }],
+  ];
+}
+
+/**
+ * Apply an operation to a document string, returning the new string.
+ * Throws if the operation is invalid for the given document.
+ */
+export function apply(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    if (op.position < 0 || op.position > doc.length) {
+      throw new Error(`Insert position ${op.position} out of bounds for document of length ${doc.length}`);
+    }
+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);
+  } else {
+    if (op.position < 0 || op.position + op.count > doc.length) {
+      throw new Error(`Delete range [${op.position}, ${op.position + op.count}) out of bounds for document of length ${doc.length}`);
+    }
+    if (op.count === 0) {
+      return doc;
+    }
+    return doc.slice(0, op.position) + doc.slice(op.position + op.count);
+  }
+}
+
+/**
+ * Apply a sequence of operations to a document.
+ */
+export function applyOps(doc: string, ops: Operation[]): string {
+  let result = doc;
+  for (const op of ops) {
+    result = apply(result, op);
+  }
+  return result;
+}
+
+/**
+ * Transform an incoming operation against a single already-applied operation.
+ * Returns the transformed operation(s) that can be applied to the current document state.
+ */
+function transformOpAgainstOp(incoming: Operation, applied: Operation): Operation[] {
+  const [incomingPrime] = transform(incoming, applied);
+  return incomingPrime;
+}
+
+/**
+ * Transform an incoming operation against a sequence of already-applied operations.
+ * Returns the transformed operation(s) that can be applied to the current document state.
+ */
+export function transformAgainstAll(incomingOp: Operation, appliedOps: Operation[]): Operation[] {
+  let currentOps: Operation[] = [incomingOp];
+
+  for (const appliedOp of appliedOps) {
+    const nextOps: Operation[] = [];
+    for (const op of currentOps) {
+      const transformed = transformOpAgainstOp(op, appliedOp);
+      nextOps.push(...transformed);
+    }
+    currentOps = nextOps;
+  }
+
+  return currentOps;
+}
+
+/**
+ * Validate that an operation is well-formed (not checking against document state).
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (!op || typeof op !== 'object') return false;
+  const o = op as Record<string, unknown>;
+  if (o.type === 'insert') {
+    return typeof o.position === 'number' &&
+      Number.isInteger(o.position) &&
+      o.position >= 0 &&
+      typeof o.text === 'string' &&
+      o.text.length > 0;
+  }
+  if (o.type === 'delete') {
+    return typeof o.position === 'number' &&
+      Number.isInteger(o.position) &&
+      o.position >= 0 &&
+      typeof o.count === 'number' &&
+      Number.isInteger(o.count) &&
+      o.count > 0;
+  }
+  return false;
+}
