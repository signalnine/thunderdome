wait waitForMessage(ws);\n    47→\n    48→      expect(msg.type).toBe('sync');\n    49→      expect(msg.content).toBe('hello');\n    50→      expect(msg.version).toBe(0);\n    51→      expect(msg.documentId).toBe(createRes.body.id);\n    52→\n    53→      ws.close();\n    54→    });\n    55→\n    56→    it('sends error for non-existent document', async () => {\n    57→      const ws = await connectWs(port, 'fake-doc-id', 'client1');\n    58→      const msg = await waitForMessage(ws);\n    59→      expect(msg.type).toBe('error');\n    60→      ws.close();\n    61→    });\n    62→  });\n    63→\n    64→  describe('single client operations', () => {\n    65→    let docId: string;\n    66→\n    67→    beforeEach(async () => {\n    68→      const createRes = await request(appInstance.app)\n    69→        .post('/documents')\n    70→        .send({ title: 'Op Test', content: 'hello' });\n    71→      docId = createRes.body.id;\n    72→    });\n    73→\n    74→    it('applies insert and receives ack', async () => {\n    75→      const ws = await connectWs(port, docId, 'client1');\n    76→      await waitForMessage(ws); // sync\n    77→\n    78→      const ackPromise = waitForMessage(ws);\n    79→      sendOp(ws, { type: 'insert', position: 5, text: ' world' }, 0);\n    80→      const ack = await ackPromise;\n    81→\n    82→      expect(ack.type).toBe('ack');\n    83→      expect(ack.version).toBe(1);\n    84→\n    85→      // Verify via REST\n    86→      const res = await request(appInstance.app).get(`/documents/${docId}`);\n    87→      expect(res.body.content).toBe('hello world');\n    88→      expect(res.body.version).toBe(1);\n    89→\n    90→      ws.close();\n    91→    });\n    92→\n    93→    it('applies delete and receives ack', async () => {\n    94→      const ws = await connectWs(port, docId, 'client1');\n    95→      await waitForMessage(ws); // sync\n    96→\n    97→      const ackPromise = waitForMessage(ws);\n    98→      sendOp(ws, { type: 'delete', posi