oBe(createRes.body.id);\n\n      ws.close();\n    });\n\n    it('sends error for non-existent document', async () => {\n      const ws = await connectWs(port, 'fake-doc-id', 'client1');\n      const msg = await waitForMessage(ws);\n      expect(msg.type).toBe('error');\n      ws.close();\n    });\n  });\n\n  describe('single client operations', () => {\n    let docId: string;\n\n    beforeEach(async () => {\n      const createRes = await request(appInstance.app)\n        .post('/documents')\n        .send({ title: 'Op Test', content: 'hello' });\n      docId = createRes.body.id;\n    });\n\n    it('applies insert and receives ack', async () => {\n      const ws = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws); // sync\n\n      const ackPromise = waitForMessage(ws);\n      sendOp(ws, { type: 'insert', position: 5, text: ' world' }, 0);\n      const ack = await ackPromise;\n\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(1);\n\n      // Verify via REST\n      const res = await request(appInstance.app).get(`/documents/${docId}`);\n      expect(res.body.content).toBe('hello world');\n      expect(res.body.version).toBe(1);\n\n      ws.close();\n    });\n\n    it('applies delete and receives ack', async () => {\n      const ws = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws); // sync\n\n      const ackPromise = waitForMessage(ws);\n      sendOp(ws, { type: 'delete', position: 0, count: 5 }, 0);\n      const ack = await ackPromise;\n\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(1);\n\n      const res = await request(appInstance.app).get(`/documents/${docId}`);\n      expect(res.body.content).toBe('');\n\n      ws.close();\n    });\n\n    it('returns error for invalid operation', async () => {\n      const ws = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws); // sync\n\n      const errPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: -1, text: 'x' }, baseVersion: 0 }));\n      const err = await errPromise;\n\n      expect(err.type).toBe('error');\n      ws.close();\n    });\n\n    it('returns error for invalid JSON', async () => {\n      const ws = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws); // sync\n\n      const errPromise = waitForMessage(ws);\n      ws.send('not json');\n      const err = await errPromise;\n\n      expect(err.type).toBe('error');\n      ws.close();\n    });\n\n    it('records operation in history', async () => {\n      const ws = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws); // sync\n\n      const ackPromise = waitForMessage(ws);\n      sendOp(ws, { type: 'insert', position: 5, text: '!' }, 0);\n      await ackPromise;\n\n      const res = await request(appInstance.app).get(`/documents/${docId}/history`);\n      expect(res.body.length).toBe(1);\n      expect(res.body[0].type).toBe('insert');\n      expect(res.body[0].position).toBe(5);\n      expect(res.body[0].text).toBe('!');\n\n      ws.close();\n    });\n  });\n\n  describe('multi-client collaboration', () => {\n    it('broadcasts operations to other clients', async () => {\n      const createRes = await request(appInstance.app)\n        .post('/documents')\n        .send({ title: 'Broadcast Test', content: 'hello' });\n      const docId = createRes.body.id;\n\n      const ws1 = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws1); // sync\n\n      const ws2 = await connectWs(port, docId, 'client2');\n      await waitForMessage(ws2); // sync\n\n      // Client 1 sends an operation\n      const broadcastPromise = waitForMessage(ws2);\n      const ackPromise = waitForMessage(ws1);\n      sendOp(ws1, { type: 'insert', position: 5, text: ' world' }, 0);\n\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n\n      const broadcast = await broadcastPromise;\n      expect(broadcast.type).toBe('operation');\n      expect((broadcast.op as Record<string, unknown>).type).toBe('insert');\n      expect(broadcast.version).toBe(1);\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('handles concurrent inserts from two clients', async () => {\n      const createRes = await request(appInstance.app)\n        .post('/documents')\n        .send({ title: 'Concurrent Test', content: 'hello' });\n      const docId = createRes.body.id;\n\n      const ws1 = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws1); // sync\n\n      const ws2 = await connectWs(port, docId, 'client2');\n      await waitForMessage(ws2); // sync\n\n      // Both clients send operations against version 0\n      // Client 1: insert \" world\" at position 5\n      const ack1Promise = waitForMessage(ws1);\n      sendOp(ws1, { type: 'insert', position: 5, text: ' world' }, 0);\n      await ack1Promise;\n\n      // Client 2: insert \"say \" at position 0 (against version 0 still)\n      const ack2Promise = waitForMessage(ws2);\n      // ws2 received the broadcast from ws1, consume it\n      const broadcast1 = await waitForMessage(ws2);\n      expect(broadcast1.type).toBe('operation');\n\n      sendOp(ws2, { type: 'insert', position: 0, text: 'say ' }, 0);\n      const ack2 = await ack2Promise;\n      expect(ack2.type).toBe('ack');\n\n      // Verify final document state via REST\n      const res = await request(appInstance.app).get(`/documents/${docId}`);\n      expect(res.body.content).toBe('say hello world');\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('handles 10 concurrent clients', async () => {\n      const createRes = await request(appInstance.app)\n        .post('/documents')\n        .send({ title: 'Scale Test', content: '' });\n      const docId = createRes.body.id;\n\n      const clients: WebSocket[] = [];\n      for (let i = 0; i < 10; i++) {\n        const ws = await connectWs(port, docId, `client${i}`);\n        await waitForMessage(ws); // sync\n        clients.push(ws);\n      }\n\n      // Each client sends an insert operation sequentially\n      // (to avoid timing issues in test, we wait for each ack)\n      for (let i = 0; i < 10; i++) {\n        const ackPromise = waitForMessage(clients[i]);\n        sendOp(clients[i], { type: 'insert', position: i, text: String(i) }, i);\n        const ack = await ackPromise;\n        expect(ack.type).toBe('ack');\n\n        // Drain broadcast messages from other clients\n        for (let j = 0; j < 10; j++) {\n          if (j !== i) {\n            await waitForMessage(clients[j]);\n          }\n        }\n      }\n\n      // Verify final state\n      const res = await request(appInstance.app).get(`/documents/${docId}`);\n      expect(res.body.content.length).toBe(10);\n      expect(res.body.version).toBe(10);\n\n      // All digits should be present\n      for (let i = 0; i < 10; i++) {\n        expect(res.body.content).toContain(String(i));\n      }\n\n      for (const ws of clients) {\n        ws.close();\n      }\n    });\n  });\n\n  describe('persistence', () => {\n    it('persists data across server restarts', async () => {\n      const dbPath = '/tmp/collab-test-persistence.db';\n\n      // Create first server instance and add a document\n      const app1 = createApp(dbPath);\n      const port1 = await app1.start(0);\n\n      const createRes = await request(app1.app)\n        .post('/documents')\n        .send({ title: 'Persistent Doc', content: 'initial' });\n      const docId = createRes.body.id;\n\n      // Edit via WebSocket\n      const ws = await connectWs(port1, docId, 'client1');\n      await waitForMessage(ws); // sync\n      const ackPromise = waitForMessage(ws);\n      sendOp(ws, { type: 'insert', position: 7, text: ' content' }, 0);\n      await ackPromise;\n      ws.close();\n\n      await app1.stop();\n\n      // Create second server instance with same DB\n      const app2 = createApp(dbPath);\n      await app2.start(0);\n\n      const res = await request(app2.app).get(`/documents/${docId}`);\n      expect(res.body.title).toBe('Persistent Doc');\n      expect(res.body.content).toBe('initial content');\n      expect(res.body.version).toBe(1);\n\n      // Check history persisted\n      const histRes = await request(app2.app).get(`/documents/${docId}/history`);\n      expect(histRes.body.length).toBe(1);\n\n      await app2.stop();\n    });\n  });\n\n  describe('error handling', () => {\n    it('handles out-of-bounds operation', async () => {\n      const createRes = await request(appInstance.app)\n        .post('/documents')\n        .send({ title: 'Error Test', content: 'hi' });\n      const docId = createRes.body.id;\n\n      const ws = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws); // sync\n\n      const errPromise = waitForMessage(ws);\n      sendOp(ws, { type: 'delete', position: 0, count: 100 }, 0);\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('handles unknown message type', async () => {\n      const createRes = await request(appInstance.app)\n        .post('/documents')\n        .send({ title: 'Unknown Type', content: '' });\n      const docId = createRes.body.id;\n\n      const ws = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws); // sync\n\n      const errPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({ type: 'unknown' }));\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('handles baseVersion ahead of server', async () => {\n      const createRes = await request(appInstance.app)\n        .post('/documents')\n        .send({ title: 'Future Version', content: 'test' });\n      const docId = createRes.body.id;\n\n      const ws = await connectWs(port, docId, 'client1');\n      await waitForMessage(ws); // sync\n\n      const errPromise = waitForMessage(ws);\n      sendOp(ws, { type: 'insert', position: 0, text: 'x' }, 999);\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      ws.close();\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1466,"cache_read_input_tokens":39517,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1466},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"274107e4-c876-42cb-bfc4-47a85a37deab","uuid":"995eb6d7-82d9-437e-8105-5c4836373845"}
