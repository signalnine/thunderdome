+import express from 'express';
+import http from 'node:http';
+import { DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const store = new DocumentStore(dbPath);
+  const app = express();
+
+  app.use(express.json());
+  app.use(createRouter(store));
+
+  const server = http.createServer(app);
+  const collab = new CollaborationManager(store);
+  collab.attach(server);
+
+  let listening = false;
+
+  return {
+    app,
+    async start(port = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        server.listen(port, () => {
+          listening = true;
+          const addr = server.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Could not determine server port'));
+          }
+        });
+        server.on('error', reject);
+      });
+    },
+    async stop(): Promise<void> {
+      collab.closeAll();
+      if (listening) {
+        await new Promise<void>((resolve, reject) => {
+          server.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+        listening = false;
+      }
+      store.close();
+    },
+  };
+}
