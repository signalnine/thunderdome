g; [key: string]: unknown }> {\n  const res = await fetch(`${baseUrl}/documents`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ title, content }),\n  });\n  return res.json() as Promise<{ id: string }>;\n}\n\nasync function getDoc(id: string): Promise<Record<string, unknown>> {\n  const res = await fetch(`${baseUrl}/documents/${id}`);\n  return res.json() as Promise<Record<string, unknown>>;\n}\n\nasync function getHistory(id: string): Promise<Record<string, unknown>[]> {\n  const res = await fetch(`${baseUrl}/documents/${id}/history`);\n  return res.json() as Promise<Record<string, unknown>[]>;\n}\n\ninterface BufferedWs {\n  ws: WebSocket;\n  messages: Record<string, unknown>[];\n  waiters: Array<(msg: Record<string, unknown>) => void>;\n}\n\nfunction connectWs(port: number, docId: string, clientId: string): Promise<BufferedWs> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}?clientId=${clientId}`);\n    const bws: BufferedWs = { ws, messages: [], waiters: [] };\n\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (bws.waiters.length > 0) {\n        const waiter = bws.waiters.shift()!;\n        waiter(msg);\n      } else {\n        bws.messages.push(msg);\n      }\n    });\n\n    ws.on('open', () => resolve(bws));\n    ws.on('error', reject);\n    setTimeout(() => reject(new Error('WS connect timeout')), 5000);\n  });\n}\n\nfunction waitForMessage(bws: BufferedWs): Promise<Record<string, unknown>> {\n  if (bws.messages.length > 0) {\n    return Promise.resolve(bws.messages.shift()!);\n  }\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('WS message timeout')), 5000);\n    bws.waiters.push((msg) => {\n      clearTimeout(timer);\n      resolve(msg);\n    });\n  });\n}\n\nfunction sendOp(bws: BufferedWs, op: { type: string; position: number; text?: string; count?: number }, baseVersion: number): void {\n  bws.ws.send(JSON.stringify({ type: 'operation', op, baseVersion }));\n}\n\ndescribe('WebSocket collaboration', () => {\n  let appInstance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    appInstance = createApp(':memory:');\n    port = await appInstance.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterAll(async () => {\n    await appInstance.stop();\n  });\n\n  describe('connection and sync', () => {\n    it('sends sync message on connect', async () => {\n      const doc = await createDoc('WS Test', 'hello');\n\n      const bws = await connectWs(port, doc.id, 'client1');\n      const msg = await waitForMessage(bws);\n\n      expect(msg.type).toBe('sync');\n      expect(msg.content).toBe('hello');\n      expect(msg.version).toBe(0);\n      expect(msg.documentId).toBe(doc.id);\n\n      bws.ws.close();\n    });\n\n    it('sends error for non-existent document', async () => {\n      const bws = await connectWs(port, 'fake-doc-id', 'client1');\n      const msg = await waitForMessage(bws);\n      expect(msg.type).toBe('error');\n      bws.ws.close();\n    });\n  });\n\n  describe('single client operations', () => {\n    let docId: string;\n\n    beforeEach(async () => {\n      const doc = await createDoc('Op Test', 'hello');\n      docId = doc.id;\n    });\n\n    it('applies insert and receives ack', async () => {\n      const bws = await connectWs(port, docId, 'client1');\n      await waitForMessage(bws); // sync\n\n      const ackPromise = waitForMessage(bws);\n      sendOp(bws, { type: 'insert', position: 5, text: ' world' }, 0);\n      const ack = await ackPromise;\n\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(1);\n\n      const doc = await getDoc(docId);\n      expect(doc.content).toBe('hello world');\n      expect(doc.version).toBe(1);\n\n      bws.ws.close();\n    });\n\n    it('applies delete and receives ack', async () => {\n      const bws = await connectWs(port, docId, 'client1');\n      await waitForMessage(bws); // sync\n\n      const ackPromise = waitForMessage(bws);\n      sendOp(bws, { type: 'delete', position: 0, count: 5 }, 0);\n      const ack = await ackPromise;\n\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(1);\n\n      const doc = await getDoc(docId);\n      expect(doc.content).toBe('');\n\n      bws.ws.close();\n    });\n\n    it('returns error for invalid operation', async () => {\n      const bws = await connectWs(port, docId, 'client1');\n      await waitForMessage(bws); // sync\n\n      const errPromise = waitForMessage(bws);\n      bws.ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: -1, text: 'x' }, baseVersion: 0 }));\n      const err = await errPromise;\n\n      expect(err.type).toBe('error');\n      bws.ws.close();\n    });\n\n    it('returns error for invalid JSON', async () => {\n      const bws = await connectWs(port, docId, 'client1');\n      await waitForMessage(bws); // sync\n\n      const errPromise = waitForMessage(bws);\n      bws.ws.send('not json');\n      const err = await errPromise;\n\n      expect(err.type).toBe('error');\n      bws.ws.close();\n    });\n\n    it('records operation in history', async () => {\n      const bws = await connectWs(port, docId, 'client1');\n      await waitForMessage(bws); // sync\n\n      const ackPromise = waitForMessage(bws);\n      sendOp(bws, { type: 'insert', position: 5, text: '!' }, 0);\n      await ackPromise;\n\n      const history = await getHistory(docId);\n      expect(history.length).toBe(1);\n      expect(history[0].type).toBe('insert');\n      expect(history[0].position).toBe(5);\n      expect(history[0].text).toBe('!');\n\n      bws.ws.close();\n    });\n  });\n\n  describe('multi-client collaboration', () => {\n    it('broadcasts operations to other clients', async () => {\n      const doc = await createDoc('Broadcast Test', 'hello');\n\n      const bws1 = await connectWs(port, doc.id, 'client1');\n      await waitForMessage(bws1); // sync\n\n      const bws2 = await connectWs(port, doc.id, 'client2');\n      await waitForMessage(bws2); // sync\n\n      // Client 1 sends an operation\n      const broadcastPromise = waitForMessage(bws2);\n      const ackPromise = waitForMessage(bws1);\n      sendOp(bws1, { type: 'insert', position: 5, text: ' world' }, 0);\n\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n\n      const broadcast = await broadcastPromise;\n      expect(broadcast.type).toBe('operation');\n      expect((broadcast.op as Record<string, unknown>).type).toBe('insert');\n      expect(broadcast.version).toBe(1);\n\n      bws1.ws.close();\n      bws2.ws.close();\n    });\n\n    it('handles concurrent inserts from two clients', async () => {\n      const doc = await createDoc('Concurrent Test', 'hello');\n\n      const bws1 = await connectWs(port, doc.id, 'client1');\n      await waitForMessage(bws1); // sync\n\n      const bws2 = await connectWs(port, doc.id, 'client2');\n      await waitForMessage(bws2); // sync\n\n      // Client 1: insert \" world\" at position 5 (against version 0)\n      const ack1Promise = waitForMessage(bws1);\n      sendOp(bws1, { type: 'insert', position: 5, text: ' world' }, 0);\n      await ack1Promise;\n\n      // bws2 receives broadcast from bws1\n      const broadcast1 = await waitForMessage(bws2);\n      expect(broadcast1.type).toBe('operation');\n\n      // Client 2: insert \"say \" at position 0 (against version 0, server is now at version 1)\n      const ack2Promise = waitForMessage(bws2);\n      sendOp(bws2, { type: 'insert', position: 0, text: 'say ' }, 0);\n      const ack2 = await ack2Promise;\n      expect(ack2.type).toBe('ack');\n\n      // Verify final document state\n      const finalDoc = await getDoc(doc.id);\n      expect(finalDoc.content).toBe('say hello world');\n\n      bws1.ws.close();\n      bws2.ws.close();\n    });\n\n    it('handles 10 concurrent clients', async () => {\n      const doc = await createDoc('Scale Test', '');\n\n      const clients: BufferedWs[] = [];\n      for (let i = 0; i < 10; i++) {\n        const bws = await connectWs(port, doc.id, `client${i}`);\n        await waitForMessage(bws); // sync\n        clients.push(bws);\n      }\n\n      // Each client sends an insert operation sequentially\n      for (let i = 0; i < 10; i++) {\n        const ackPromise = waitForMessage(clients[i]);\n        sendOp(clients[i], { type: 'insert', position: i, text: String(i) }, i);\n        const ack = await ackPromise;\n        expect(ack.type).toBe('ack');\n\n        // Drain broadcast messages from other clients\n        const drainPromises: Promise<unknown>[] = [];\n        for (let j = 0; j < 10; j++) {\n          if (j !== i) {\n            drainPromises.push(waitForMessage(clients[j]));\n          }\n        }\n        await Promise.all(drainPromises);\n      }\n\n      // Verify final state\n      const finalDoc = await getDoc(doc.id);\n      expect((finalDoc.content as string).length).toBe(10);\n      expect(finalDoc.version).toBe(10);\n\n      for (let i = 0; i < 10; i++) {\n        expect(finalDoc.content as string).toContain(String(i));\n      }\n\n      for (const c of clients) {\n        c.ws.close();\n      }\n    });\n  });\n\n  describe('persistence', () => {\n    it('persists data across server restarts', async () => {\n      const dbPath = '/tmp/collab-test-persistence.db';\n\n      try { await import('node:fs').then(fs => fs.unlinkSync(dbPath)); } catch { /* ignore */ }\n\n      const app1 = createApp(dbPath);\n      const port1 = await app1.start(0);\n\n      const createRes = await fetch(`http://localhost:${port1}/documents`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ title: 'Persistent Doc', content: 'initial' }),\n      });\n      const docData = await createRes.json() as { id: string };\n      const docId = docData.id;\n\n      const bws = await connectWs(port1, docId, 'client1');\n      await waitForMessage(bws); // sync\n      const ackPromise = waitForMessage(bws);\n      sendOp(bws, { type: 'insert', position: 7, text: ' content' }, 0);\n      await ackPromise;\n      bws.ws.close();\n\n      await app1.stop();\n\n      const app2 = createApp(dbPath);\n      const port2 = await app2.start(0);\n\n      const docRes = await fetch(`http://localhost:${port2}/documents/${docId}`);\n      const docJson = await docRes.json() as Record<string, unknown>;\n      expect(docJson.title).toBe('Persistent Doc');\n      expect(docJson.content).toBe('initial content');\n      expect(docJson.version).toBe(1);\n\n      const histRes = await fetch(`http://localhost:${port2}/documents/${docId}/history`);\n      const history = await histRes.json() as unknown[];\n      expect(history.length).toBe(1);\n\n      await app2.stop();\n    });\n  });\n\n  describe('error handling', () => {\n    it('handles out-of-bounds operation', async () => {\n      const doc = await createDoc('Error Test', 'hi');\n\n      const bws = await connectWs(port, doc.id, 'client1');\n      await waitForMessage(bws); // sync\n\n      const errPromise = waitForMessage(bws);\n      sendOp(bws, { type: 'delete', position: 0, count: 100 }, 0);\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      bws.ws.close();\n    });\n\n    it('handles unknown message type', async () => {\n      const doc = await createDoc('Unknown Type', '');\n\n      const bws = await connectWs(port, doc.id, 'client1');\n      await waitForMessage(bws); // sync\n\n      const errPromise = waitForMessage(bws);\n      bws.ws.send(JSON.stringify({ type: 'unknown' }));\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      bws.ws.close();\n    });\n\n    it('handles baseVersion ahead of server', async () => {\n      const doc = await createDoc('Future Version', 'test');\n\n      const bws = await connectWs(port, doc.id, 'client1');\n      await waitForMessage(bws); // sync\n\n      const errPromise = waitForMessage(bws);\n      sendOp(bws, { type: 'insert', position: 0, text: 'x' }, 999);\n      const err = await errPromise;\n      expect(err.type).toBe('error');\n\n      bws.ws.close();\n    });\n  });\n});\n","structuredPatch":[{"oldStart":23,"oldLines":27,"newStart":23,"newLines":48,"lines":["   return res.json() as Promise<Record<string, unknown>[]>;"," }"," ","-function connectWs(port: number, docId: string, clientId: string): Promise<WebSocket> {","+interface BufferedWs {","+  ws: WebSocket;","+  messages: Record<string, unknown>[];","+  waiters: Array<(msg: Record<string, unknown>) => void>;","+}","+","+function connectWs(port: number, docId: string, clientId: string): Promise<BufferedWs> {","   return new Promise((resolve, reject) => {","     const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}?clientId=${clientId}`);","-    ws.on('open', () => resolve(ws));","+    const bws: BufferedWs = { ws, messages: [], waiters: [] };","+","+    ws.on('message', (data) => {","+      const msg = JSON.parse(data.toString());","+      if (bws.waiters.length > 0) {","+        const waiter = bws.waiters.shift()!;","+        waiter(msg);","+      } else {","+        bws.messages.push(msg);","+      }","+    });","+","+    ws.on('open', () => resolve(bws));","     ws.on('error', reject);","     setTimeout(() => reject(new Error('WS connect timeout')), 5000);","   });"," }"," ","-function waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {","+function waitForMessage(bws: BufferedWs): Promise<Record<string, unknown>> {","+  if (bws.messages.length > 0) {","+    return Promise.resolve(bws.messages.shift()!);","+  }","   return new Promise((resolve, reject) => {","     const timer = setTimeout(() => reject(new Error('WS message timeout')), 5000);","-    ws.once('message', (data) => {","+    bws.waiters.push((msg) => {","       clearTimeout(timer);","-    