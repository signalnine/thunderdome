@@ -0,0 +1,379 @@
+import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';
+import WebSocket from 'ws';
+import { createApp, type AppInstance } from './server.js';
+
+let baseUrl: string;
+
+async function createDoc(title: string, content = ''): Promise<{ id: string; [key: string]: unknown }> {
+  const res = await fetch(`${baseUrl}/documents`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ title, content }),
+  });
+  return res.json() as Promise<{ id: string }>;
+}
+
+async function getDoc(id: string): Promise<Record<string, unknown>> {
+  const res = await fetch(`${baseUrl}/documents/${id}`);
+  return res.json() as Promise<Record<string, unknown>>;
+}
+
+async function getHistory(id: string): Promise<Record<string, unknown>[]> {
+  const res = await fetch(`${baseUrl}/documents/${id}/history`);
+  return res.json() as Promise<Record<string, unknown>[]>;
+}
+
+interface BufferedWs {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  waiters: Array<(msg: Record<string, unknown>) => void>;
+}
+
+function connectWs(port: number, docId: string, clientId: string): Promise<BufferedWs> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}?clientId=${clientId}`);
+    const bws: BufferedWs = { ws, messages: [], waiters: [] };
+
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (bws.waiters.length > 0) {
+        const waiter = bws.waiters.shift()!;
+        waiter(msg);
+      } else {
+        bws.messages.push(msg);
+      }
+    });
+
+    ws.on('open', () => resolve(bws));
+    ws.on('error', reject);
+    setTimeout(() => reject(new Error('WS connect timeout')), 5000);
+  });
+}
+
+function waitForMessage(bws: BufferedWs): Promise<Record<string, unknown>> {
+  if (bws.messages.length > 0) {
+    return Promise.resolve(bws.messages.shift()!);
+  }
+  return new Promise((resolve, reject) => {
+    const timer = setTimeout(() => reject(new Error('WS message timeout')), 5000);
+    bws.waiters.push((msg) => {
+      clearTimeout(timer);
+      resolve(msg);
+    });
+  });
+}
+
+function sendOp(bws: BufferedWs, op: { type: string; position: number; text?: string; count?: number }, baseVersion: number): void {
+  bws.ws.send(JSON.stringify({ type: 'operation', op, baseVersion }));
+}
+
+describe('WebSocket collaboration', () => {
+  let appInstance: AppInstance;
+  let port: number;
+
+  beforeAll(async () => {
+    appInstance = createApp(':memory:');
+    port = await appInstance.start(0);
+    baseUrl = `http://localhost:${port}`;
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  describe('connection and sync', () => {
+    it('sends sync message on connect', async () => {
+      const doc = await createDoc('WS Test', 'hello');
+
+      const bws = await connectWs(port, doc.id, 'client1');
+      const msg = await waitForMessage(bws);
+
+      expect(msg.type).toBe('sync');
+      expect(msg.content).toBe('hello');
+      expect(msg.version).toBe(0);
+      expect(msg.documentId).toBe(doc.id);
+
+      bws.ws.close();
+    });
+
+    it('sends error for non-existent document', async () => {
+      const bws = await connectWs(port, 'fake-doc-id', 'client1');
+      const msg = await waitForMessage(bws);
+      expect(msg.type).toBe('error');
+      bws.ws.close();
+    });
+  });
+
+  describe('single client operations', () => {
+    let docId: string;
+
+    beforeEach(async () => {
+      const doc = await createDoc('Op Test', 'hello');
+      docId = doc.id;
+    });
+
+    it('applies insert and receives ack', async () => {
+      const bws = await connectWs(port, docId, 'client1');
+      await waitForMessage(bws); // sync
+
+      const ackPromise = waitForMessage(bws);
+      sendOp(bws, { type: 'insert', position: 5, text: ' world' }, 0);
+      const ack = await ackPromise;
+
+      expect(ack.type).toBe('ack');
+      expect(ack.version).toBe(1);
+
+      const doc = await getDoc(docId);
+      expect(doc.content).toBe('hello world');
+      expect(doc.version).toBe(1);
+
+      bws.ws.close();
+    });
+
+    it('applies delete and receives ack', async () => {
+      const bws = await connectWs(port, docId, 'client1');
+      await waitForMessage(bws); // sync
+
+      const ackPromise = waitForMessage(bws);
+      sendOp(bws, { type: 'delete', position: 0, count: 5 }, 0);
+      const ack = await ackPromise;
+
+      expect(ack.type).toBe('ack');
+      expect(ack.version).toBe(1);
+
+      const doc = await getDoc(docId);
+      expect(doc.content).toBe('');
+
+      bws.ws.close();
+    });
+
+    it('returns error for invalid operation', async () => {
+      const bws = await connectWs(port, docId, 'client1');
+      await waitForMessage(bws); // sync
+
+      const errPromise = waitForMessage(bws);
+      bws.ws.send(JSON.stringify({ type: 'operation', op: { type: 'insert', position: -1, text: 'x' }, baseVersion: 0 }));
+      const err = await errPromise;
+
+      expect(err.type).toBe('error');
+      bws.ws.close();
+    });
+
