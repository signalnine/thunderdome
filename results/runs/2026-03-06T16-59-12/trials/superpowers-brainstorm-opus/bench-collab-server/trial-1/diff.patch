tion';\n  op: Operation;\n  baseVersion: number;\n}\n\n// Messages from server to client\ninterface SyncMessage {\n  type: 'sync';\n  content: string;\n  version: number;\n  documentId: string;\n}\n\ninterface ServerOperationMessage {\n  type: 'operation';\n  op: Operation;\n  version: number;\n}\n\ninterface AckMessage {\n  type: 'ack';\n  version: number;\n}\n\ninterface ErrorMessage {\n  type: 'error';\n  message: string;\n}\n\ntype ServerMessage = SyncMessage | ServerOperationMessage | AckMessage | ErrorMessage;\n\nexport class CollaborationManager {\n  private rooms: Map<string, Set<ClientConnection>> = new Map();\n  private wss: WebSocketServer | null = null;\n\n  constructor(private store: DocumentStore) {}\n\n  attach(server: HttpServer): void {\n    this.wss = new WebSocketServer({ noServer: true });\n\n    server.on('upgrade', (request, socket, head) => {\n      const url = new URL(request.url || '', `http://${request.headers.host}`);\n      const pathMatch = url.pathname.match(/^\\/ws\\/([^/]+)$/);\n\n      if (!pathMatch) {\n        socket.destroy();\n        return;\n      }\n\n      const documentId = pathMatch[1];\n      const clientId = url.searchParams.get('clientId') || crypto.randomUUID();\n\n      this.wss!.handleUpgrade(request, socket, head, (ws) => {\n        this.handleConnection(ws, documentId, clientId);\n      });\n    });\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string, clientId: string): void {\n    const doc = this.store.getDocument(documentId);\n    if (!doc) {\n      this.send(ws, { type: 'error', message: 'Document not found' });\n      ws.close();\n      return;\n    }\n\n    const conn: ClientConnection = { ws, clientId, documentId };\n\n    // Add to room\n    if (!this.rooms.has(documentId)) {\n      this.rooms.set(documentId, new Set());\n    }\n    this.rooms.get(documentId)!.add(conn);\n\n    // Send current state\n    this.send(ws, {\n      type: 'sync',\n      content: doc.content,\n      version: doc.version,\n      documentId: doc.id,\n    });\n\n    ws.on('message', (data) => {\n      try {\n        const raw = data.toString();\n        let msg: unknown;\n        try {\n          msg = JSON.parse(raw);\n        } catch {\n          this.send(ws, { type: 'error', message: 'Invalid JSON' });\n          return;\n        }\n        this.handleMessage(conn, msg);\n      } catch {\n        this.send(conn.ws, { type: 'error', message: 'Internal error' });\n      }\n    });\n\n    ws.on('close', () => {\n      const room = this.rooms.get(documentId);\n      if (room) {\n        room.delete(conn);\n        if (room.size === 0) {\n          this.rooms.delete(documentId);\n        }\n      }\n    });\n\n    ws.on('error', () => {\n      // Handled by close event\n    });\n  }\n\n  private handleMessage(conn: ClientConnection, msg: unknown): void {\n    if (!msg || typeof msg !== 'object') {\n      this.send(conn.ws, { type: 'error', message: 'Invalid message format' });\n      return;\n    }\n\n    const message = msg as Record<string, unknown>;\n\n    if (message.type !== 'operation') {\n      this.send(conn.ws, { type: 'error', message: `Unknown message type: ${String(message.type)}` });\n      return;\n    }\n\n    const opMsg = message as unknown as ClientOperationMessage;\n\n    if (typeof opMsg.baseVersion !== 'number' || !Number.isInteger(opMsg.baseVersion) || opMsg.baseVersion < 0) {\n      this.send(conn.ws, { type: 'error', message: 'Invalid baseVersion' });\n      return;\n    }\n\n    if (!validateOperation(opMsg.op)) {\n      this.send(conn.ws, { type: 'error', message: 'Invalid operation' });\n      return;\n    }\n\n    // Get the current document\n    const doc = this.store.getDocument(conn.documentId);\n    if (!doc) {\n      this.send(conn.ws, { type: 'error', message: 'Document not found' });\n      return;\n    }\n\n    if (opMsg.baseVersion > doc.version) {\n      this.send(conn.ws, { type: 'error', message: 'baseVersion is ahead of server version' });\n      return;\n    }\n\n    // Get operations since client's base version\n    const opsSince = this.store.getOperationsSince(conn.documentId, opMsg.baseVersion);\n    const appliedOps: Operation[] = opsSince.map(row => {\n      if (row.type === 'insert') {\n        return { type: 'insert' as const, position: row.position, text: row.text! };\n      } else {\n        return { type: 'delete' as const, position: row.position, count: row.count! };\n      }\n    });\n\n    // Transform the incoming op against all operations that have been applied since baseVersion\n    // transformAgainstAll returns an array of operations (may be split due to insert-within-delete)\n    let transformedOps: Operation[];\n    try {\n      transformedOps = transformAgainstAll(opMsg.op, appliedOps);\n    } catch {\n      this.send(conn.ws, { type: 'error', message: 'Transform failed' });\n      return;\n    }\n\n    // Filter out no-op deletes\n    transformedOps = transformedOps.filter(op => !(op.type === 'delete' && op.count === 0));\n\n    if (transformedOps.length === 0) {\n      // Nothing to apply (all ops were no-ops)\n      this.send(conn.ws, { type: 'ack', version: doc.version });\n      return;\n    }\n\n    // Apply all transformed ops to the document\n    let newContent: string;\n    try {\n      newContent = applyOps(doc.content, transformedOps);\n    } catch (err) {\n      this.send(conn.ws, { type: 'error', message: `Operation invalid: ${(err as Error).message}` });\n      return;\n    }\n\n    // Persist each operation and track the final version\n    let newVersion = doc.version;\n    for (const op of transformedOps) {\n      // Apply incrementally for persistence\n      const currentDoc = this.store.getDocument(conn.documentId)!;\n      const content = apply(currentDoc.content, op);\n      newVersion = this.store.applyOperation(conn.documentId, op, content, conn.clientId);\n    }\n\n    // Ack to sender with final version\n    this.send(conn.ws, { type: 'ack', version: newVersion });\n\n    // Broadcast each transformed operation to other clients\n    const room = this.rooms.get(conn.documentId);\n    if (room) {\n      for (const op of transformedOps) {\n        for (const client of room) {\n          if (client !== conn && client.ws.readyState === WebSocket.OPEN) {\n            this.send(client.ws, {\n              type: 'operation',\n              op,\n              version: newVersion,\n            });\n          }\n        }\n      }\n    }\n  }\n\n  private send(ws: WebSocket, msg: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  closeAll(): void {\n    for (const room of this.rooms.values()) {\n      for (const conn of room) {\n        conn.ws.close();\n      }\n    }\n    this.rooms.clear();\n    if (this.wss) {\n      this.wss.close();\n      this.wss = null;\n    }\n  }\n}\n","structuredPatch":[{"oldStart":1,"oldLines":7,"newStart":1,"newLines":7,"lines":[" import { WebSocketServer, WebSocket } from 'ws';"," import type { Server as HttpServer } from 'node:http';"," import type { DocumentStore } from './db.js';","-import { apply, transformAgainstAll, validateOperation, type Operation } from './ot.js';","+import { apply, applyOps, transformAgainstAll, validateOperation, type Operation } from './ot.js';"," "," interface ClientConnection {","   ws: WebSocket;"]},{"oldStart":104,"oldLines":8,"newStart":104,"newLines":8,"lines":["           return;","         }","         this.handleMessage(conn, msg);","-      } catch (err) {","-        this.send(ws, { type: 'error', message: 'Internal error' });","+      } catch {","+        this.send(conn.ws, { type: 'error', message: 'Internal error' });","       }","     });"," "]},{"oldStart":172,"oldLines":39,"newStart":172,"newLines":57,"lines":["     });"," ","     // Transform the incoming op against all operations that have been applied since baseVersion","-    let transformedOp: Operation;","+    // transformAgai