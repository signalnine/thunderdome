@@ -0,0 +1,156 @@
+import { describe, it, expect, beforeAll, afterAll } from 'vitest';
+import request from 'supertest';
+import { createApp, type AppInstance } from './server.js';
+
+describe('REST API', () => {
+  let appInstance: AppInstance;
+
+  beforeAll(async () => {
+    appInstance = createApp(':memory:');
+    await appInstance.start(0);
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  describe('POST /documents', () => {
+    it('creates a document with title and content', async () => {
+      const res = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'Hello world' })
+        .expect(201);
+
+      expect(res.body.id).toBeDefined();
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello world');
+      expect(res.body.version).toBe(0);
+    });
+
+    it('creates a document with title only', async () => {
+      const res = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Empty Doc' })
+        .expect(201);
+
+      expect(res.body.content).toBe('');
+    });
+
+    it('rejects missing title', async () => {
+      await request(appInstance.app)
+        .post('/documents')
+        .send({ content: 'no title' })
+        .expect(400);
+    });
+  });
+
+  describe('GET /documents', () => {
+    it('lists documents', async () => {
+      const res = await request(appInstance.app)
+        .get('/documents')
+        .expect(200);
+
+      expect(Array.isArray(res.body)).toBe(true);
+      expect(res.body.length).toBeGreaterThanOrEqual(2);
+    });
+  });
+
+  describe('GET /documents/:id', () => {
+    it('returns a specific document', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Get Test', content: 'content' });
+
+      const res = await request(appInstance.app)
+        .get(`/documents/${createRes.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('Get Test');
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .get('/documents/nonexistent-id')
+        .expect(404);
+    });
+  });
+
+  describe('PUT /documents/:id', () => {
+    it('updates document title', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Old Title', content: 'content' });
+
+      const res = await request(appInstance.app)
+        .put(`/documents/${createRes.body.id}`)
+        .send({ title: 'New Title' })
+        .expect(200);
+
+      expect(res.body.title).toBe('New Title');
+      expect(res.body.content).toBe('content');
+    });
+
+    it('updates document content', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'Title', content: 'old' });
+
+      const res = await request(appInstance.app)
+        .put(`/documents/${createRes.body.id}`)
+        .send({ content: 'new content' })
+        .expect(200);
+
+      expect(res.body.content).toBe('new content');
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .put('/documents/nonexistent')
+        .send({ title: 'x' })
+        .expect(404);
+    });
+  });
+
+  describe('DELETE /documents/:id', () => {
+    it('deletes a document', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'To Delete' });
+
+      await request(appInstance.app)
+        .delete(`/documents/${createRes.body.id}`)
+        .expect(204);
+
+      await request(appInstance.app)
+        .get(`/documents/${createRes.body.id}`)
+        .expect(404);
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .delete('/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('GET /documents/:id/history', () => {
+    it('returns empty history for new document', async () => {
+      const createRes = await request(appInstance.app)
+        .post('/documents')
+        .send({ title: 'History Test' });
+
+      const res = await request(appInstance.app)
+        .get(`/documents/${createRes.body.id}/history`)
+        .expect(200);
+
+      expect(Array.isArray(res.body)).toBe(true);
+      expect(res.body.length).toBe(0);
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .get('/documents/nonexistent/history')
+        .expect(404);
+    });
+  });
+});
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..4f02339
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,166 @@
+import Database from 'better-sqlite3';
+import crypto from 'node:crypto';
+import type { Operation } from './ot.js';
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface OperationRow {
+  id: number;
+  document_id: string;
+  version: number;
+  type: string;
+  position: number;
+  text: string | null;
+  count: number | null;
+  client_id: string;
+  created_at: string;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  constructor(dbPath?: string) {
+    this.db = new Database(dbPath || ':memory:');
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('foreign_keys = ON');
+    this.initSchema();
+  }
+
+  private initSchema(): void {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        version INTEGER NOT NULL DEFAULT 0,
+        created_at TEXT NOT NULL,
+        updated_at TEXT NOT NULL
+      );
+
+      CREATE TABLE IF NOT EXISTS operations (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL,
+        version INTEGER NOT NULL,
+        type TEXT NOT NULL,
+        position INTEGER NOT NULL,
+        text TEXT,
+        count INTEGER,
+        client_id TEXT NOT NULL,
+        created_at TEXT NOT NULL,
+        FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE
+      );
+
+      CREATE INDEX IF NOT EXISTS idx_operations_doc_version
+        ON operations(document_id, version);
+    `);
+  }
+
+  createDocument(title: string, content: string = ''): DocumentRow {
+    const id = crypto.randomUUID();
+    const now = new Date().toISOString();
+    this.db.prepare(`
+      INSERT INTO documents (id, title, content, version, created_at, updated_at)
+      VALUES (?, ?, ?, 0, ?, ?)
+    `).run(id, title, content, now, now);
+
+    return { id, title, content, version: 0, created_at: now, updated_at: now };
+  }
+
+  getDocument(id: string): DocumentRow | undefined {
+    return this.db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as DocumentRow | undefined;
+  }
+
+  listDocuments(): DocumentRow[] {
+    return this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as DocumentRow[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): DocumentRow | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+    const now = new Date().toISOString();
+
+    this.db.prepare(`
+      UPDATE documents SET title = ?, content = ?, updated_at = ? WHERE id = ?
+    `).run(title, content, now, id);
+
+    return { ...doc, title, content, updated_at: now };
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+    return result.changes > 0;
+  }
+
+  /**
+   * Apply an operation to a document atomically.
+   * Updates document content and version, stores the operation.
+   * Returns the new version number.
+   */
+  applyOperation(documentId: string, op: Operation, newContent: string, clientId: string): number {
+    const applyTx = this.db.transaction(() => {
+      const doc = this.getDocument(documentId);
+      if (!doc) throw new Error('Document not found');
+
+      const newVersion = doc.version + 1;
+      const now = new Date().toISOString();
+
+      this.db.prepare(`
+        UPDATE documents SET content = ?, version = ?, updated_at = ? WHERE id = ?
+      `).run(newContent, newVersion, now, documentId);
+
+      this.db.prepare(`
+        INSERT INTO operations (document_id, version, type, position, text, count, client_id, created_at)
+        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+      `).run(
+        documentId,
+        newVersion,
+        op.type,
+        op.position,
+        op.type === 'insert' ? op.text : null,
+        op.type === 'delete' ? op.count : null,
+        clientId,
+        now
+      );
+
+      return newVersion;
+    });
+
+    return applyTx();
+  }
+
+  /**
+   * Get all operations for a document since a given version (exclusive).
+   */
+  getOperationsSince(documentId: string, sinceVersion: number): OperationRow[] {
+    return this.db.prepare(`
+      SELECT * FROM operations
+      WHERE document_id = ? AND version > ?
+      ORDER BY version ASC
+    `).all(documentId, sinceVersion) as OperationRow[];
+  }
+
+  /**
+   * Get the full operation history for a document.
+   */
+  getHistory(documentId: string): OperationRow[] {
+    return this.db.prepare(`
+      SELECT * FROM operations
+      WHERE document_id = ?
+      ORDER BY version ASC
+    `).all(documentId) as OperationRow[];
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..ab83164
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,261 @@
+import { describe, it, expect } from 'vitest';
+import { transform, apply, applyOps, transformAgainstAll, validateOperation, type Operation } from './ot.js';
+
+describe('apply', () => {
+  it('inserts text at the beginning', () => {
+    expect(apply('hello', { type: 'insert', position: 0, text: 'say ' })).toBe('say hello');
+  });
+
+  it('inserts text at the end', () => {
+    expect(apply('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+  });
+
+  it('inserts text in the middle', () => {
+    expect(apply('helo', { type: 'insert', position: 2, text: 'l' })).toBe('hello');
+  });
+
+  it('deletes text from the beginning', () => {
+    expect(apply('hello world', { type: 'delete', position: 0, count: 6 })).toBe('world');
+  });
+
+  it('deletes text from the end', () => {
+    expect(apply('hello world', { type: 'delete', position: 5, count: 6 })).toBe('hello');
+  });
+
+  it('deletes text from the middle', () => {
+    expect(apply('hello world', { type: 'delete', position: 5, count: 1 })).toBe('helloworld');
+  });
+
+  it('throws on out-of-bounds insert', () => {
+    expect(() => apply('hi', { type: 'insert', position: 5, text: 'x' })).toThrow();
+  });
+
+  it('throws on out-of-bounds delete', () => {
+    expect(() => apply('hi', { type: 'delete', position: 1, count: 5 })).toThrow();
+  });
+
+  it('handles zero-count delete as no-op', () => {
+    expect(apply('hello', { type: 'delete', position: 0, count: 0 })).toBe('hello');
+  });
+
+  it('inserts into empty doc', () => {
+    expect(apply('', { type: 'insert', position: 0, text: 'hello' })).toBe('hello');
+  });
+});
+
+/**
+ * Helper: verify that transform(opA, opB) produces convergent results.
+ * applyOps(apply(doc, opA), bPrime) === applyOps(apply(doc, opB), aPrime)
+ */
+function verifyConvergence(doc: string, opA: Operation, opB: Operation): string {
+  const [aPrime, bPrime] = transform(opA, opB);
+
+  const r1 = applyOps(apply(doc, opA), bPrime);
+  const r2 = applyOps(apply(doc, opB), aPrime);
+  expect(r1).toBe(r2);
+  return r1;
+}
+
+describe('transform insert-insert', () => {
+  it('transforms two non-overlapping inserts (A before B)', () => {
+    verifyConvergence('hello', { type: 'insert', position: 0, text: 'a' }, { type: 'insert', position: 2, text: 'b' });
+  });
+
+  it('transforms two inserts at the same position', () => {
+    const result = verifyConvergence(
+      'hello',
+      { type: 'insert', position: 3, text: 'a' },
+      { type: 'insert', position: 3, text: 'b' },
+    );
+    expect(result).toContain('a');
+    expect(result).toContain('b');
+  });
+
+  it('transforms two inserts (A after B)', () => {
+    verifyConvergence('hello', { type: 'insert', position: 5, text: 'a' }, { type: 'insert', position: 2, text: 'b' });
+  });
+});
+
+describe('transform insert-delete', () => {
+  it('insert before delete', () => {
+    verifyConvergence(
+      'hello',
+      { type: 'insert', position: 1, text: 'x' },
+      { type: 'delete', position: 3, count: 2 },
+    );
+  });
+
+  it('insert after delete', () => {
+    verifyConvergence(
+      'hello',
+      { type: 'insert', position: 4, text: 'x' },
+      { type: 'delete', position: 0, count: 2 },
+    );
+  });
+
+  it('insert within deleted range', () => {
+    const result = verifyConvergence(
+      'hello',
+      { type: 'insert', position: 2, text: 'x' },
+      { type: 'delete', position: 1, count: 3 },
+    );
+    expect(result).toContain('x');
+  });
+
+  it('insert at start of deleted range', () => {
+    const result = verifyConvergence(
+      'hello',
+      { type: 'insert', position: 1, text: 'x' },
+      { type: 'delete', position: 1, count: 3 },
+    );
+    expect(result).toContain('x');
+  });
+
+  it('insert at end of deleted range', () => {
+    verifyConvergence(
+      'hello',
+      { type: 'insert', position: 4, text: 'x' },
+      { type: 'delete', position: 1, count: 3 },
+    );
+  });
+});
+
+describe('transform delete-insert', () => {
+  it('delete before insert', () => {
+    verifyConvergence(
+      'hello',
+      { type: 'delete', position: 0, count: 2 },
+      { type: 'insert', position: 4, text: 'x' },
+    );
+  });
+
+  it('insert within delete (reversed order)', () => {
+    const result = verifyConvergence(
+      'hello',
+      { type: 'delete', position: 1, count: 3 },
+      { type: 'insert', position: 2, text: 'x' },
+    );
+    expect(result).toContain('x');
+  });
+});
+
+describe('transform delete-delete', () => {
+  it('non-overlapping deletes (A before B)', () => {
+    verifyConvergence(
+      'hello',
+      { type: 'delete', position: 0, count: 2 },
+      { type: 'delete', position: 3, count: 2 },
+    );
+  });
+
+  it('non-overlapping deletes (B before A)', () => {
+    verifyConvergence(
+      'hello',
+      { type: 'delete', position: 3, count: 2 },
+      { type: 'delete', position: 0, count: 2 },
+    );
+  });
+
+  it('fully overlapping deletes (same range)', () => {
+    verifyConvergence(
+      'hello',
+      { type: 'delete', position: 1, count: 3 },
+      { type: 'delete', position: 1, count: 3 },
+    );
+  });
+
+  it('A contains B', () => {
+    verifyConvergence(
+      'hello!',
+      { type: 'delete', position: 1, count: 4 },
+      { type: 'delete', position: 2, count: 2 },
+    );
+  });
+
+  it('B contains A', () => {
+    verifyConvergence(
+      'hello!',
+      { type: 'delete', position: 2, count: 2 },
+      { type: 'delete', position: 1, count: 4 },
+    );
+  });
+
+  it('partial overlap (A starts first)', () => {
+    verifyConvergence(
+      'abcdefg',
+      { type: 'delete', position: 1, count: 3 },
+      { type: 'delete', position: 3, count: 3 },
+    );
+  });
+
+  it('partial overlap (B starts first)', () => {
+    verifyConvergence(
+      'abcdefg',
+      { type: 'delete', position: 3, count: 3 },
+      { type: 'delete', position: 1, count: 3 },
+    );
+  });
+});
+
+describe('transformAgainstAll', () => {
+  it('transforms against a sequence of operations', () => {
+    const ops: Operation[] = [
+      { type: 'insert', position: 0, text: 'say ' },
+      { type: 'insert', position: 9, text: '!' },
+    ];
+
+    const incoming: Operation = { type: 'insert', position: 5, text: ' world' };
+    const transformed = transformAgainstAll(incoming, ops);
+
+    // After ops, doc is "say hello!"
+    let result = 'say hello!';
+    result = applyOps(result, transformed);
+    expect(result).toContain('world');
+  });
+
+  it('handles insert within delete via split operations', () => {
+    const appliedOps: Operation[] = [
+      { type: 'delete', position: 1, count: 3 },
+    ];
+    const incoming: Operation = { type: 'insert', position: 2, text: 'x' };
+    const transformed = transformAgainstAll(incoming, appliedOps);
+
+    // After applied ops, doc was "hello" → "ho"
+    const result = applyOps('ho', transformed);
+    expect(result).toBe('hxo');
+  });
+});
+
+describe('validateOperation', () => {
+  it('validates a correct insert', () => {
+    expect(validateOperation({ type: 'insert', position: 0, text: 'hi' })).toBe(true);
+  });
+
+  it('validates a correct delete', () => {
+    expect(validateOperation({ type: 'delete', position: 0, count: 3 })).toBe(true);
+  });
+
+  it('rejects null', () => {
+    expect(validateOperation(null)).toBe(false);
+  });
+
+  it('rejects empty text insert', () => {
+    expect(validateOperation({ type: 'insert', position: 0, text: '' })).toBe(false);
+  });
+
+  it('rejects zero-count delete', () => {
+    expect(validateOperation({ type: 'delete', position: 0, count: 0 })).toBe(false);
+  });
+
+  it('rejects negative position', () => {
+    expect(validateOperation({ type: 'insert', position: -1, text: 'x' })).toBe(false);
+  });
+
+  it('rejects non-integer position', () => {
+    expect(validateOperation({ type: 'insert', position: 1.5, text: 'x' })).toBe(false);
+  });
+
+  it('rejects unknown type', () => {
+    expect(validateOperation({ type: 'replace', position: 0, text: 'x' })).toBe(false);
+  });
+});
