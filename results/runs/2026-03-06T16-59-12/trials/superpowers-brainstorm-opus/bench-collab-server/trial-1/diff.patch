l(incoming, appliedOps);","+","+    // After applied ops, doc was \"hello\" → \"ho\"","+    const result = applyOps('ho', transformed);","+    expect(result).toBe('hxo');","+  });"," });"," "," describe('validateOperation', () => {"]}],"originalFile":"import { describe, it, expect } from 'vitest';\nimport { transform, apply, transformAgainstAll, validateOperation, type Operation } from './ot.js';\n\ndescribe('apply', () => {\n  it('inserts text at the beginning', () => {\n    expect(apply('hello', { type: 'insert', position: 0, text: 'say ' })).toBe('say hello');\n  });\n\n  it('inserts text at the end', () => {\n    expect(apply('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');\n  });\n\n  it('inserts text in the middle', () => {\n    expect(apply('helo', { type: 'insert', position: 2, text: 'l' })).toBe('hello');\n  });\n\n  it('deletes text from the beginning', () => {\n    expect(apply('hello world', { type: 'delete', position: 0, count: 6 })).toBe('world');\n  });\n\n  it('deletes text from the end', () => {\n    expect(apply('hello world', { type: 'delete', position: 5, count: 6 })).toBe('hello');\n  });\n\n  it('deletes text from the middle', () => {\n    expect(apply('hello world', { type: 'delete', position: 5, count: 1 })).toBe('helloworld');\n  });\n\n  it('throws on out-of-bounds insert', () => {\n    expect(() => apply('hi', { type: 'insert', position: 5, text: 'x' })).toThrow();\n  });\n\n  it('throws on out-of-bounds delete', () => {\n    expect(() => apply('hi', { type: 'delete', position: 1, count: 5 })).toThrow();\n  });\n\n  it('handles zero-count delete as no-op', () => {\n    expect(apply('hello', { type: 'delete', position: 0, count: 0 })).toBe('hello');\n  });\n\n  it('inserts into empty doc', () => {\n    expect(apply('', { type: 'insert', position: 0, text: 'hello' })).toBe('hello');\n  });\n});\n\ndescribe('transform insert-insert', () => {\n  it('transforms two non-overlapping inserts (A before B)', () => {\n 