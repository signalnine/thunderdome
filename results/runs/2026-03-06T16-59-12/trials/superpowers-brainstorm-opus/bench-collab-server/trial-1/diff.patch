ifyConvergence(\n      'abcdefg',\n      { type: 'delete', position: 1, count: 3 },\n      { type: 'delete', position: 3, count: 3 },\n    );\n  });\n\n  it('partial overlap (B starts first)', () => {\n    verifyConvergence(\n      'abcdefg',\n      { type: 'delete', position: 3, count: 3 },\n      { type: 'delete', position: 1, count: 3 },\n    );\n  });\n});\n\ndescribe('transformAgainstAll', () => {\n  it('transforms against a sequence of operations', () => {\n    const ops: Operation[] = [\n      { type: 'insert', position: 0, text: 'say ' },\n      { type: 'insert', position: 9, text: '!' },\n    ];\n\n    const incoming: Operation = { type: 'insert', position: 5, text: ' world' };\n    const transformed = transformAgainstAll(incoming, ops);\n\n    // After ops, doc is \"say hello!\"\n    let result = 'say hello!';\n    result = applyOps(result, transformed);\n    expect(result).toContain('world');\n  });\n\n  it('handles insert within delete via split operations', () => {\n    const appliedOps: Operation[] = [\n      { type: 'delete', position: 1, count: 3 },\n    ];\n    const incoming: Operation = { type: 'insert', position: 2, text: 'x' };\n    const transformed = transformAgainstAll(incoming, appliedOps);\n\n    // After applied ops, doc was \"hello\" → \"ho\"\n    const result = applyOps('ho', transformed);\n    expect(result).toBe('hxo');\n  });\n});\n\ndescribe('validateOperation', () => {\n  it('validates a correct insert', () => {\n    expect(validateOperation({ type: 'insert', position: 0, text: 'hi' })).toBe(true);\n  });\n\n  it('validates a correct delete', () => {\n    expect(validateOperation({ type: 'delete', position: 0, count: 3 })).toBe(true);\n  });\n\n  it('rejects null', () => {\n    expect(validateOperation(null)).toBe(false);\n  });\n\n  it('rejects empty text insert', () => {\n    expect(validateOperation({ type: 'insert', position: 0, text: '' })).toBe(false);\n  });\n\n  it('rejects zero-count delete', () => {\n    expect(validateOperation({ type: 'delete', position: 0, count: 0 })).toBe(false);\n  });\n\n  it('rejects negative position', () => {\n    expect(validateOperation({ type: 'insert', position: -1, text: 'x' })).toBe(false);\n  });\n\n  it('rejects non-integer position', () => {\n    expect(validateOperation({ type: 'insert', position: 1.5, text: 'x' })).toBe(false);\n  });\n\n  it('rejects unknown type', () => {\n    expect(validateOperation({ type: 'replace', position: 0, text: 'x' })).toBe(false);\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":5,"lines":[" import { describe, it, expect } from 'vitest';","-import { transform, apply, transformAgainstAll, validateOperation, type Operation } from './ot.js';","+import { transform, apply, applyOps, transformAgainstAll, validateOperation, type Operation } from './ot.js';"," "," describe('apply', () => {","   it('inserts text at the beginning', () => {"]},{"oldStart":43,"oldLines":178,"newStart":43,"newLines":162,"lines":["   });"," });"," ","+/**","+ * Helper: verify that transform(opA, opB) produces convergent results.","+ * applyOps(apply(doc, opA), bPrime) === applyOps(apply(doc, opB), aPrime)","+ */","+function verifyConvergence(doc: string, opA: Operation, opB: Operation): string {","+  const [aPrime, bPrime] = transform(opA, opB);","+","+  const r1 = applyOps(apply(doc, opA), bPrime);","+  const r2 = applyOps(apply(doc, opB), aPrime);","+  expect(r1).toBe(r2);","+  return r1;","+}","+"," describe('transform insert-insert', () => {","   it('transforms two non-overlapping inserts (A before B)', () => {","-    const opA: Operation = { type: 'insert', position: 0, text: 'a' };","-    const opB: Operation = { type: 'insert', position: 2, text: 'b' };","-    const [aPrime, bPrime] = transform(opA, opB);","-","-    // Apply A then B'","-    const doc = 'hello';","-    const r1 = apply(apply(doc, opA), bPrime);","-    // Apply B then A'","-    const r2 = apply(apply(doc, opB), aPrime);","-    expect(r1).