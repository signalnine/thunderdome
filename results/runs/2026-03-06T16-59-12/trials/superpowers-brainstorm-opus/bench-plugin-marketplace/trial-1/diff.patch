egistry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    const all = registry.list();\n    expect(all).toHaveLength(2);\n  });\n\n  it('should search plugins by name', () => {\n    registry.register(makeManifest({ name: 'auth-plugin', description: 'Authentication' }));\n    registry.register(makeManifest({ name: 'data-plugin', description: 'Data processing' }));\n    const results = registry.search('auth');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('auth-plugin');\n  });\n\n  it('should search plugins by description', () => {\n    registry.register(makeManifest({ name: 'plugin-a', description: 'Handles authentication' }));\n    registry.register(makeManifest({ name: 'plugin-b', description: 'Data store' }));\n    const results = registry.search('authentication');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('plugin-a');\n  });\n\n  it('should remove a plugin version', () => {\n    registry.register(makeManifest());\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    expect(registry.get('test-plugin')).toBeNull();\n  });\n\n  it('should return false when removing non-existent plugin', () => {\n    expect(registry.remove('nope', '1.0.0')).toBe(false);\n  });\n\n  it('should list all versions of a plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '1.1.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toHaveLength(3);\n    expect(versions).toContain('1.0.0');\n    expect(versions).toContain('1.1.0');\n    expect(versions).toContain('2.0.0');\n  });\n\n  it('should return empty array for non-existent plugin versions', () => {\n    expect(registry.listVersions('nonexistent')).toEqual([]);\n  });\n\n  it('should update a plugin', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n    const updated = registry.getVersion('test-plugin', '1.0.0');\n    expect(updated!.description).toBe('Updated description');\n  });\n\n  it('should throw when updating non-existent plugin', () => {\n    expect(() => registry.update('nope', '1.0.0', { description: 'x' }))\n      .toThrow('not found');\n  });\n\n  it('should handle multiple versions correctly with get()', () => {\n    registry.register(makeManifest({ version: '1.0.0', description: 'v1' }));\n    registry.register(makeManifest({ version: '2.0.0', description: 'v2' }));\n    const latest = registry.get('test-plugin');\n    expect(latest).not.toBeNull();\n    // get() returns one of them (ORDER BY version DESC, so \"2.0.0\" comes first)\n    expect(latest!.version).toBe('2.0.0');\n  });\n\n  it('should store and retrieve dependencies correctly', () => {\n    const manifest = makeManifest({\n      dependencies: { 'dep-a': '^1.0.0', 'dep-b': '~2.3.0' },\n    });\n    registry.register(manifest);\n    const retrieved = registry.get('test-plugin');\n    expect(retrieved!.dependencies).toEqual({ 'dep-a': '^1.0.0', 'dep-b': '~2.3.0' });\n  });\n\n  it('should store and retrieve permissions correctly', () => {\n    const manifest = makeManifest({ permissions: ['read', 'write', 'network'] });\n    registry.register(manifest);\n    const retrieved = registry.get('test-plugin');\n    expect(retrieved!.permissions).toEqual(['read', 'write', 'network']);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":143,"cache_read_input_tokens":32812,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":143},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b1bde93f-8fbf-439d-a578-0efe1d081cfe","uuid":"6e