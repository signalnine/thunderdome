ed).toBe(true);\n    });\n  });\n\n  describe('getFlaggedReviews', () => {\n    it('should return only flagged reviews', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'good' });\n      const r2 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 1, comment: 'spam' });\n      reviews.flagReview(r2.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].id).toBe(r2.id);\n    });\n  });\n\n  describe('removeReview', () => {\n    it('should remove a review', () => {\n      const review = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n      expect(reviews.removeReview(review.id)).toBe(true);\n      expect(reviews.getReviews('p1')).toHaveLength(0);\n    });\n\n    it('should return false for non-existent review', () => {\n      expect(reviews.removeReview(999)).toBe(false);\n    });\n  });\n\n  describe('getReviewsByUser', () => {\n    it('should return reviews by a specific user', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: 'a' });\n      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: 'b' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: 'c' });\n      const userReviews = reviews.getReviewsByUser('user1');\n      expect(userReviews).toHaveLength(2);\n      expect(userReviews.every(r => r.userId === 'user1')).toBe(true);\n    });\n  });\n\n  describe('getReviewCount', () => {\n    it('should return correct count', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: 'b' });\n      expect(reviews.ge