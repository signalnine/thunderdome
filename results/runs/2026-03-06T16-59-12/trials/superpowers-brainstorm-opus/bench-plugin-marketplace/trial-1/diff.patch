uginVersion: '1.0.0',\n        userId: 'user1',\n        rating: 5,\n        comment: 'Great plugin!',\n      });\n      expect(review.id).toBeDefined();\n      expect(review.pluginName).toBe('test-plugin');\n      expect(review.rating).toBe(5);\n      expect(review.flagged).toBe(false);\n      expect(review.createdAt).toBeDefined();\n    });\n\n    it('should throw for invalid rating', () => {\n      expect(() =>\n        reviews.addReview({\n          pluginName: 'test-plugin',\n          pluginVersion: '1.0.0',\n          userId: 'user1',\n          rating: 0,\n          comment: 'Bad',\n        }),\n      ).toThrow('Rating must be between 1 and 5');\n\n      expect(() =>\n        reviews.addReview({\n          pluginName: 'test-plugin',\n          pluginVersion: '1.0.0',\n          userId: 'user1',\n          rating: 6,\n          comment: 'Bad',\n        }),\n      ).toThrow('Rating must be between 1 and 5');\n    });\n  });\n\n  describe('getReviews', () => {\n    it('should return reviews for a plugin', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'Great' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: 'Good' });\n      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'OK' });\n      const p1Reviews = reviews.getReviews('p1');\n      expect(p1Reviews).toHaveLength(2);\n    });\n\n    it('should return empty array for plugin with no reviews', () => {\n      expect(reviews.getReviews('nonexistent')).toEqual([]);\n    });\n  });\n\n  describe('getAverageRating', () => {\n    it('should compute average rating', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'b' });\n      expect(reviews.getAverageRating('p1')).toBe(4);\n    });\n\n    it('should exclude flagged reviews from average', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'b' });\n      const r3 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'spam' });\n      reviews.flagReview(r3.id);\n      // Average of 5 and 3 = 4\n      expect(reviews.getAverageRating('p1')).toBe(4);\n    });\n\n    it('should return 0 for plugin with no reviews', () => {\n      expect(reviews.getAverageRating('nonexistent')).toBe(0);\n    });\n  });\n\n  describe('flagReview', () => {\n    it('should flag a review', () => {\n      const review = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam' });\n      reviews.flagReview(review.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].id).toBe(review.id);\n      expect(flagged[0].flagged).toBe(true);\n    });\n  });\n\n  describe('getFlaggedReviews', () => {\n    it('should return only flagged reviews', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'good' });\n      const r2 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 1, comment: 'spam' });\n      reviews.flagReview(r2.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].id).toBe(r2.id);\n    });\n  });\n\n  describe('removeReview', () => {\n    it('should remove a review', () => {\n      const review = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n      expect(reviews.removeReview(review.id)).toBe(true);\n      expect(reviews.getReviews('p1')).toHaveLength(0);\