+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { Marketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '__output = "installed"',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should create a marketplace with all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin successfully', async () => {
+      const result = await marketplace.installPlugin(makeManifest());
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe('installed');
+      expect(result.resolvedDependencies).toEqual([]);
+    });
+
+    it('should register plugin in registry during install', async () => {
+      await marketplace.installPlugin(makeManifest());
+      const plugin = marketplace.registry.get('test-plugin');
+      expect(plugin).not.toBeNull();
+      expect(plugin!.name).toBe('test-plugin');
+    });
+
+    it('should resolve dependencies during install', async () => {
+      // Register a dependency first
+      marketplace.registry.register(makeManifest({
+        name: 'dep-a',
+        version: '1.0.0',
+        entryPoint: '1',
+      }));
+      marketplace.registry.register(makeManifest({
+        name: 'dep-a',
+        version: '1.1.0',
+        entryPoint: '1',
+      }));
+
+      const result = await marketplace.installPlugin(makeManifest({
+        dependencies: { 'dep-a': '^1.0.0' },
+      }));
+
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.resolvedDependencies[0].version).toBe('1.1.0');
+    });
+
+    it('should reject plugin with circular dependencies', async () => {
+      // Create a cycle: a -> b -> a
+      marketplace.registry.register(makeManifest({
+        name: 'b',
+        version: '1.0.0',
+        dependencies: { 'a': '^1.0.0' },
+        entryPoint: '1',
+      }));
+
+      // Now install 'a' which depends on 'b' (creating cycle)
+      await expect(
+        marketplace.installPlugin(makeManifest({
+          name: 'a',
+          version: '1.0.0',
+          dependencies: { 'b': '^1.0.0' },
+        })),
+      ).rejects.toThrow('Circular dependency');
+
+      // Plugin should be removed from registry after cycle detection
+      expect(marketplace.registry.get('a')).toBeNull();
+    });
+
+    it('should throw for missing name', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ name: '' })),
+      ).rejects.toThrow('name');
+    });
+
+    it('should throw for missing version', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ version: '' })),
+      ).rejects.toThrow('version');
+    });
+
+    it('should throw for missing entryPoint', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ entryPoint: '' })),
+      ).rejects.toThrow('entryPoint');
+    });
+
+    it('should handle plugin with execution error', async () => {
+      const result = await marketplace.installPlugin(makeManifest({
+        entryPoint: 'throw new Error("plugin crash")',
+      }));
+      expect(result.executionResult.success).toBe(false);
+      expect(result.executionResult.error).toContain('plugin crash');
+    });
+
+    it('should handle plugin with complex entry point', async () => {
+      const result = await marketplace.installPlugin(makeManifest({
+        entryPoint: `
+          const sum = [1, 2, 3, 4, 5].reduce((a, b) => a + b, 0);
+          __output = sum;
+        `,
+      }));
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe(15);
+    });
+  });
+});
