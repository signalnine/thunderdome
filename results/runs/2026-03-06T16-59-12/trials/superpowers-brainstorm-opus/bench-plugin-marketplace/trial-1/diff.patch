@@ -0,0 +1,49 @@
+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+const DEFAULT_TIMEOUT = 5000;
+
+export function createRunner(): RunnerService {
+  function run(code: string, timeoutMs: number, context: Record<string, unknown> = {}): SandboxResult {
+    const sandbox = { ...context, __output: undefined as unknown };
+    const vmContext = vm.createContext(sandbox);
+
+    const memBefore = process.memoryUsage().heapUsed;
+    const start = performance.now();
+
+    try {
+      const script = new vm.Script(code);
+      const result = script.runInContext(vmContext, { timeout: timeoutMs });
+      const duration = performance.now() - start;
+      const memAfter = process.memoryUsage().heapUsed;
+
+      return {
+        success: true,
+        output: sandbox.__output !== undefined ? sandbox.__output : result,
+        duration,
+        memoryUsed: Math.max(0, memAfter - memBefore),
+      };
+    } catch (err) {
+      const duration = performance.now() - start;
+      const memAfter = process.memoryUsage().heapUsed;
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed: Math.max(0, memAfter - memBefore),
+        error: (err && typeof err === 'object' && 'message' in err) ? String((err as {message: unknown}).message) : String(err),
+      };
+    }
+  }
+
+  return {
+    async execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+      return run(code, DEFAULT_TIMEOUT, context);
+    },
+
+    async executeWithTimeout(code: string, timeoutMs: number, context?: Record<string, unknown>): Promise<SandboxResult> {
+      return run(code, timeoutMs, context);
+    },
+  };
+}
