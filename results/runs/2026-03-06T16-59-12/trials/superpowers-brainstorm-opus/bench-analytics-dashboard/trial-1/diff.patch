me: 'page_view' });\n    expect(res.status).toBe(401);\n  });\n\n  it('should ingest a single event', async () => {\n    const res = await request(app)\n      .post('/api/events')\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({\n        name: 'page_view',\n        properties: { url: '/home', browser: 'chrome' },\n        timestamp: '2024-01-15T10:00:00Z',\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.id).toBeDefined();\n    expect(res.body.name).toBe('page_view');\n  });\n\n  it('should ingest batch events', async () => {\n    const events = [\n      { name: 'page_view', properties: { url: '/about', browser: 'firefox' }, timestamp: '2024-01-15T11:00:00Z' },\n      { name: 'page_view', properties: { url: '/home', browser: 'chrome' }, timestamp: '2024-01-16T10:00:00Z' },\n      { name: 'click', properties: { element: 'button', url: '/home' }, timestamp: '2024-01-16T10:05:00Z' },\n      { name: 'page_view', properties: { url: '/pricing', browser: 'safari' }, timestamp: '2024-01-17T09:00:00Z' },\n    ];\n\n    const res = await request(app)\n      .post('/api/events/batch')\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ events });\n    expect(res.status).toBe(201);\n    expect(res.body.inserted).toBe(4);\n  });\n\n  it('should count events', async () => {\n    const res = await request(app)\n      .post('/api/events/query')\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ type: 'count', eventName: 'page_view' });\n    expect(res.status).toBe(200);\n    expect(res.body.type).toBe('count');\n    expect(res.body.count).toBe(4);\n  });\n\n  it('should count all events', async () => {\n    const res = await request(app)\n      .post('/api/events/query')\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ type: 'count' });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(5);\n  });\n\n  it('should return timeseries data', async () => {\n    const res = await request(app)\n      .post('/api/events/query')\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ type: 'timeseries', eventName: 'page_view' });\n    expect(res.status).toBe(200);\n    expect(res.body.type).toBe('timeseries');\n    expect(res.body.data.length).toBeGreaterThan(0);\n  });\n\n  it('should return breakdown data', async () => {\n    const res = await request(app)\n      .post('/api/events/query')\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ type: 'breakdown', eventName: 'page_view', property: 'url' });\n    expect(res.status).toBe(200);\n    expect(res.body.type).toBe('breakdown');\n    expect(res.body.data.length).toBeGreaterThan(0);\n  });\n\n  it('should enforce tenant isolation in queries', async () => {\n    // Register user in different tenant\n    const otherRes = await request(app)\n      .post('/api/auth/register')\n      .send({ email: 'other@test.com', password: 'password123' });\n    const otherToken = otherRes.body.token;\n\n    // Should see 0 events for the other tenant\n    const res = await request(app)\n      .post('/api/events/query')\n      .set('Authorization', `Bearer ${otherToken}`)\n      .send({ type: 'count' });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(0);\n  });\n});\n\ndescribe('Dashboards', () => {\n  let dashboardId: string;\n\n  it('should reject unauthenticated dashboard access', async () => {\n    const res = await request(app).get('/api/dashboards');\n    expect(res.status).toBe(401);\n  });\n\n  it('should create a dashboard', async () => {\n    const res = await request(app)\n      .post('/api/dashboards')\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ name: 'Overview Dashboard', config: { theme: 'dark' } });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('Overview Dashboard');\n    expect(res.body.tenantId).toBe(tenantId);\n    dashboardId = res.body.id;\n  });\n\n  it('should list dashboards', async () => {\n    const res = await request(app)\n      .get('/api/dashboards')\n      .set('Authorization', `Bearer ${adminToken}`);\n    expect(res.status).toBe(200);\n    expect(res.body.length).toBeGreaterThan(0);\n  });\n\n  it('should get a dashboard by id', async () => {\n    const res = await request(app)\n      .get(`/api/dashboards/${dashboardId}`)\n      .set('Authorization', `Bearer ${adminToken}`);\n    expect(res.status).toBe(200);\n    expect(res.body.id).toBe(dashboardId);\n    expect(res.body.widgets).toBeDefined();\n  });\n\n  it('should update a dashboard', async () => {\n    const res = await request(app)\n      .put(`/api/dashboards/${dashboardId}`)\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ name: 'Updated Dashboard' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Updated Dashboard');\n  });\n\n  it('should add widget to dashboard', async () => {\n    const res = await request(app)\n      .post(`/api/dashboards/${dashboardId}/widgets`)\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({\n        type: 'counter',\n        config: { eventName: 'page_view' },\n        positionX: 0,\n        positionY: 0,\n        width: 2,\n        height: 1,\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.type).toBe('counter');\n  });\n\n  it('should delete a dashboard', async () => {\n    // Create another to delete\n    const createRes = await request(app)\n      .post('/api/dashboards')\n      .set('Authorization', `Bearer ${adminToken}`)\n      .send({ name: 'To Delete' });\n    const deleteId = createRes.body.id;\n\n    const res = await request(app)\n      .delete(`/api/dashboards/${deleteId}`)\n      .set('Authorization', `Bearer ${adminToken}`);\n    expect(res.status).toBe(204);\n  });\n\n  it('should enforce tenant isolation for dashboards', async () => {\n    // Use the other tenant's token from events test\n    const otherRes = await request(app)\n      .post('/api/auth/login')\n      .send({ email: 'other@test.com', password: 'password123' });\n    const otherToken = otherRes.body.token;\n\n    const res = await request(app)\n      .get(`/api/dashboards/${dashboardId}`)\n      .set('Authorization', `Bearer ${otherToken}`);\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Export', () => {\n  it('should reject unauthenticated export', async () => {\n    const res = await request(app).get('/api/export/events');\n    expect(res.status).toBe(401);\n  });\n\n  it('should export events as JSON', async () => {\n    const res = await request(app)\n      .get('/api/export/events?format=json')\n      .set('Authorization', `Bearer ${adminToken}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events).toBeDefined();\n    expect(res.body.count).toBeGreaterThan(0);\n  });\n\n  it('should export events as CSV', async () => {\n    const res = await request(app)\n      .get('/api/export/events?format=csv')\n      .set('Authorization', `Bearer ${adminToken}`);\n    expect(res.status).toBe(200);\n    expect(res.headers['content-type']).toContain('text/csv');\n    expect(res.text).toContain('id,name,properties,timestamp');\n  });\n\n  it('should export events filtered by name', async () => {\n    const res = await request(app)\n      .get('/api/export/events?format=json&eventName=click')\n      .set('Authorization', `Bearer ${adminToken}`);\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(1);\n  });\n\n  it('should export dashboard as JSON', async () => {\n    // Get dashboard id\n    const dashRes = await request(app)\n      .get('/api/dashboards')\n      .set('Authorization', `Bearer ${adminToken}`);\n    const dashId = dashRes.body[0].id;\n\n    const res = await request(app)\n      .get(`/api/export/dashboards/${dashId}?format=json`)\n      .set('Authorization', `Bearer ${adminToken}`);\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBeDefined();\n    expect(res.body.widgets).toBeDefined();\n  });\n\n  it('should export dashboard as CSV', async () => {\n    const dashRes = await request(app)\n      .get('/api/dashboards')\n      .set('Authorization', `Bearer ${adminToken}`);\n    const dashId = dashRes.body[0].id;\n\n    const res = await request(app)\n      .get(`/api/export/dashboards/${dashId}?format=csv`)\n      .set('Authorization', `Bearer ${adminToken}`);\n    expect(res.status).toBe(200);\n    expect(res.headers['content-type']).toContain('text/csv');\n  });\n\n  it('should enforce tenant isolation in exports', async () => {\n    const otherRes = await request(app)\n      .post('/api/auth/login')\n      .send({ email: 'other@test.com', password: 'password123' });\n    const otherToken = otherRes.body.token;\n\n    const res = await request(app)\n      .get('/api/export/events?format=json')\n      .set('Authorization', `Bearer ${otherToken}`);\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
