+
+// POST /api/dashboards - create dashboard
+router.post('/', (req: Request, res: Response): void => {
+  const { name, config } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: 'Dashboard name is required' });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const now = new Date().toISOString();
+
+  db.prepare(
