.status(404).json({ error: 'Widget not found' });\n    return;\n  }\n\n  db.prepare('DELETE FROM widgets WHERE id = ?').run(req.params.widgetId);\n  res.status(204).send();\n});\n\nexport default router;\n","structuredPatch":[],"originalFile":null}}
