+import { authMiddleware } from '../middleware/auth.js';
+
+const router = Router();
+
+// All dashboard routes require authentication
+router.use(authMiddleware);
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function formatDashboard(row: DashboardRow) {
+  return {
+    id: row.id,
+    tenantId: row.tenant_id,
+    name: row.name,
+    ownerId: row.owner_id,
+    config: JSON.parse(row.config),
+    createdAt: row.created_at,
+    updatedAt: row.updated_at,
+  };
+}
+
+function formatWidget(row: WidgetRow) {
+  return {
+    id: row.id,
+    dashboardId: row.dashboard_id,
+    type: row.type,
+    config: JSON.parse(row.config),
+    positionX: row.position_x,
+    positionY: row.position_y,
+    width: row.width,
+    height: row.height,
+  };
+}
+
+// GET /api/dashboards - list dashboards for tenant
+router.get('/', (req: Request, res: Response): void => {
+  const db = getDb();
+  const rows = db.prepare(
+    'SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC'
+  ).all(req.user!.tenantId) as DashboardRow[];
+
+  res.json(rows.map(formatDashboard));
