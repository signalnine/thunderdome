@@ -0,0 +1,156 @@
+import { Router, Request, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { authMiddleware } from '../middleware/auth.js';
+
+const router = Router();
+
+// All event routes require authentication
+router.use(authMiddleware);
+
+interface EventInput {
+  name: string;
+  properties?: Record<string, unknown>;
+  timestamp?: string;
+  userId?: string;
+  sessionId?: string;
+}
+
+// POST /api/events - ingest single event
+router.post('/', (req: Request, res: Response): void => {
+  const { name, properties, timestamp, userId, sessionId } = req.body as EventInput;
+
+  if (!name) {
+    res.status(400).json({ error: 'Event name is required' });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const tenantId = req.user!.tenantId;
+  const eventTimestamp = timestamp || new Date().toISOString();
+  const eventProperties = JSON.stringify(properties || {});
+
+  db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, tenantId, name, eventProperties, eventTimestamp, userId || null, sessionId || null);
+
+  res.status(201).json({ id, name, tenantId, timestamp: eventTimestamp });
+});
+
+// POST /api/events/batch - ingest batch of events
+router.post('/batch', (req: Request, res: Response): void => {
+  const { events } = req.body as { events: EventInput[] };
+
+  if (!events || !Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: 'Events array is required and must not be empty' });
+    return;
+  }
+
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const insert = db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  );
+
+  const insertMany = db.transaction((eventList: EventInput[]) => {
+    const results: { id: string; name: string }[] = [];
+    for (const event of eventList) {
+      if (!event.name) continue;
+      const id = uuidv4();
+      const eventTimestamp = event.timestamp || new Date().toISOString();
+      const eventProperties = JSON.stringify(event.properties || {});
+      insert.run(id, tenantId, event.name, eventProperties, eventTimestamp, event.userId || null, event.sessionId || null);
+      results.push({ id, name: event.name });
+    }
+    return results;
+  });
+
+  const results = insertMany(events);
+  res.status(201).json({ inserted: results.length, events: results });
+});
+
+// POST /api/events/query - query events
+router.post('/query', (req: Request, res: Response): void => {
+  const { type, eventName, property, startDate, endDate, interval, filters } = req.body as {
+    type: 'count' | 'timeseries' | 'breakdown';
+    eventName?: string;
+    property?: string;
+    startDate?: string;
+    endDate?: string;
+    interval?: string;
+    filters?: Record<string, string>;
+  };
+
+  if (!type) {
+    res.status(400).json({ error: 'Query type is required (count, timeseries, breakdown)' });
+    return;
+  }
+
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const params: unknown[] = [tenantId];
+  let whereClause = 'WHERE tenant_id = ?';
+
+  if (eventName) {
+    whereClause += ' AND name = ?';
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    whereClause += ' AND timestamp >= ?';
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    whereClause += ' AND timestamp <= ?';
+    params.push(endDate);
+  }
+
+  if (filters) {
+    for (const [key, value] of Object.entries(filters)) {
+      whereClause += ` AND json_extract(properties, ?) = ?`;
+      params.push(`$.${key}`, value);
+    }
+  }
+
+  try {
+    if (type === 'count') {
+      const result = db.prepare(
+        `SELECT COUNT(*) as count FROM events ${whereClause}`
+      ).get(...params) as { count: number };
+
+      res.json({ type: 'count', count: result.count });
+    } else if (type === 'timeseries') {
+      const bucket = interval === 'hour' ? '%Y-%m-%dT%H:00:00'
+        : interval === 'month' ? '%Y-%m'
+        : '%Y-%m-%d'; // default daily
+
+      const rows = db.prepare(
+        `SELECT strftime('${bucket}', timestamp) as period, COUNT(*) as count FROM events ${whereClause} GROUP BY period ORDER BY period`
+      ).all(...params) as { period: string; count: number }[];
+
+      res.json({ type: 'timeseries', interval: interval || 'day', data: rows });
+    } else if (type === 'breakdown') {
+      if (!property) {
+        res.status(400).json({ error: 'Property is required for breakdown queries' });
+        return;
+      }
+
+      const rows = db.prepare(
+        `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events ${whereClause} AND json_extract(properties, ?) IS NOT NULL GROUP BY value ORDER BY count DESC`
+      ).all(`$.${property}`, ...params, `$.${property}`) as { value: string; count: number }[];
+
+      res.json({ type: 'breakdown', property, data: rows });
+    } else {
+      res.status(400).json({ error: 'Invalid query type. Must be count, timeseries, or breakdown' });
+    }
+  } catch (err: unknown) {
+    const message = err instanceof Error ? err.message : 'Unknown error';
+    res.status(500).json({ error: 'Query failed', details: message });
+  }
+});
+
+export default router;
