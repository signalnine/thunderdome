+  if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+    res.status(400).json({ error: 'Valid widget type is required (counter, timeseries, breakdown, funnel)' });
+    return;
+  }
+
+  const id = uuidv4();
+
+  db.prepare(
+    'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, req.params.id, type, JSON.stringify(config || {}), positionX || 0, positionY || 0, width || 1, height || 1);
+
+  const row = db.prepare('SELECT * FROM widgets WHERE id = ?').get(id) as WidgetRow;
+  res.status(201).json(formatWidget(row));
+});
+
+// PUT /api/dashboards/:dashboardId/widgets/:widgetId - update widget
+router.put('/:dashboardId/widgets/:widgetId', (req: Request, res: Response): void => {
