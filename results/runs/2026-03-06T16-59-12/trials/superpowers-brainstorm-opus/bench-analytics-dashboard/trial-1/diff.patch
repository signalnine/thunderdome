+  const row = db.prepare('SELECT * FROM widgets WHERE id = ?').get(req.params.widgetId) as WidgetRow;
+  res.json(formatWidget(row));
+});
+
+// DELETE /api/dashboards/:dashboardId/widgets/:widgetId - delete widget
+router.delete('/:dashboardId/widgets/:widgetId', (req: Request, res: Response): void => {
