+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HGJa1ReCMWt5EaaeRQr313","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createDevServerPlugin } from '../../src/plugins/dev-server.js';\n     3→import { BuildContext, SiteConfig } from '../../src/core/types.js';\n     4→\n     5→const testConfig: SiteConfig = {\n     6→  title: 'Test Site',\n     7→  baseUrl: 'https://example.com',\n     8→  outputDir: './dist',\n     9→  contentDir: './content',\n    10→  templateDir: './templates',\n    11→};\n    12→\n    13→interface DevServerConfig {\n    14→  port: number;\n    15→  routes: Array<{ path: string; handler: string }>;\n    16→  assetPaths: string[];\n    17→  searchIndexPath: string;\n    18→}\n    19→\n    20→function makeCtx(\n    21→  output?: Map<string, string>,\n    22→  data?: Map<string, unknown>\n    23→): BuildContext {\n    24→  return {\n    25→    config: testConfig,\n    26→    files: [],\n    27→    output: output || new Map(),\n    28→    assets: new Map(),\n    29→    data: data || new Map(),\n    30→  };\n    31→}\n    32→\n    33→describe('dev-server plugin', () => {\n    34→  const plugin = createDevServerPlugin();\n    35→\n    36→  it('stores dev-server-config in ctx.data', async () => {\n    37→    const ctx = makeCtx();\n    38→    await plugin.hooks.afterBuild!(ctx);\n    39→    expect(ctx.data.has('dev-server-config')).toBe(true);\n    40→  });\n    41→\n    42→  it('config includes port setting', async () => {\n    43→    const ctx = makeCtx();\n    44→    await plugin.hooks.afterBuild!(ctx);\n    45→    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    46→    expect(config.port).toBeDefined();\n    47→    expect(typeof config.port).toBe('number');\n    48→  });\n    49→\n    50→  it('config includes asset routes from asset-pipeline', async () => {\n    51→    const data = new Map<string, unknown>();\n    52→    data.set('asset-manife