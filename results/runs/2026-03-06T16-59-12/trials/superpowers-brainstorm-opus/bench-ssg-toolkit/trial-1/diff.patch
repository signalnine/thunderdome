ries}\n    </item>`;\n        }).join('\\n');\n\n        const feed = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>${escapeXml(config.title)}</title>\n    <link>${config.baseUrl}</link>\n    <description>${escapeXml(config.title)} RSS Feed</description>\n${items}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { Plugin, ContentFile, BuildContext } from '../core/types.js';","+import { Plugin, BuildContext } from '../core/types.js';"," "," function escapeXml(str: string): string {","   return str"]}],"userModified":false,"replaceAll":false}}
