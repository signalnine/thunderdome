+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+        // Get or initialize the asset manifest
+        let manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (!manifest) {
+          manifest = { assets: [] };
+          ctx.data.set('asset-manifest', manifest);
+        }
+
+        // Match src="./..." and href="./..." (relative URLs)
+        const relativeUrlRegex = /(src|href)="\.\/([^"]+)"/g;
+        let content = file.content;
+        let match: RegExpExecArray | null;
+
+        // Collect assets first
+        const foundAssets: string[] = [];
+        while ((match = relativeUrlRegex.exec(content)) !== null) {
+          foundAssets.push(match[2]);
+        }
+
+        // Rewrite URLs
+        content = content.replace(/(src|href)="\.\/([^"]+)"/g, '$1="/assets/$2"');
+
+        // Add found assets to manifest (avoiding duplicates)
+        for (const asset of foundAssets) {
+          if (!manifest.assets.includes(asset)) {
+            manifest.assets.push(asset);
+          }
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
