\ninterface DevServerConfig {\n  port: number;\n  routes: Array<{ path: string; handler: string }>;\n  assetPaths: string[];\n  searchIndexPath: string;\n}\n\nfunction makeCtx(\n  output?: Map<string, string>,\n  data?: Map<string, unknown>\n): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: output || new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\ndescribe('dev-server plugin', () => {\n  const plugin = createDevServerPlugin();\n\n  it('stores dev-server-config in ctx.data', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.data.has('dev-server-config')).toBe(true);\n  });\n\n  it('config includes port setting', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBeDefined();\n    expect(typeof config.port).toBe('number');\n  });\n\n  it('config includes asset routes from asset-pipeline', async () => {\n    const data = new Map<string, unknown>();\n    data.set('asset-manifest', { assets: ['image.png', 'style.css'] });\n    const ctx = makeCtx(new Map(), data);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toContain('image.png');\n    expect(config.assetPaths).toContain('style.css');\n    const assetRoutes = config.routes.filter(r => r.handler === 'asset');\n    expect(assetRoutes.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('config includes search index path', async () => {\n    const output = new Map<string, string>();\n    output.set('search-index.json', '[]');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.searchIndexPath).toBe('/search-index.json');\n  });\n\n  it('config includes content routes',