+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013yTAPfnUvdr8Qd1tb1qDfY","type":"tool_result","content":"     1→export type EventHandler = (data: unknown) => void | Promise<void>;\n     2→\n     3→// Module-level handler registry — shared across all EventBus instances\n     4→const globalHandlers: Map<string, EventHandler[]> = new Map();\n     5→\n     6→export class EventBus {\n     7→  on(event: string, handler: EventHandler): void {\n     8→    const existing = globalHandlers.get(event) ?? [];\n     9→    existing.push(handler);\n    10→    globalHandlers.set(event, existing);\n    11→  }\n    12→\n    13→  off(event: string, handler: EventHandler): void {\n    14→    const existing = globalHandlers.get(event);\n    15→    if (!existing) return;\n    16→    globalHandlers.set(\n    17→      event,\n    18→      existing.filter((h) => h !== handler)\n    19→    );\n    20→  }\n    21→\n    22→  async emit(event: string, data: unknown): Promise<void> {\n    23→    const handlers = globalHandlers.get(event) ?? [];\n    24→    for (const handler of handlers) {\n    25→      await handler(data);\n    26→    }\n    27→  }\n    28→\n    29→  clear(): void {\n    30→    globalHandlers.clear();\n    31→  }\n    32→}\n    33→"}]},"parent_tool_use_id":"toolu_01C8jhPVzY5F8to79Skef7Ke","session_id":"b51607b8-49ee-45e0-91aa-5308df462f0a","uuid":"5660b7ba-9dbf-4774-a573-ff3348f38d24"}
