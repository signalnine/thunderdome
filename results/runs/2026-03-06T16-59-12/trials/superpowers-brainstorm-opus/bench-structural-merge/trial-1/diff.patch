diff --git a/src/document-store.ts b/src/document-store.ts
new file mode 100644
index 0000000..14d886b
--- /dev/null
+++ b/src/document-store.ts
@@ -0,0 +1,307 @@
+import type { Version, MergeResult, Conflict, DocumentRecord, BranchState, BranchSnapshot } from './types.js';
+import { threeWayMerge } from './merge.js';
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranchName: string = 'main';
+  private versionCounter: number = 0;
+  // forkPoints[childBranch][parentBranch] = snapshot of parent at fork time
+  private forkPoints: Map<string, Map<string, BranchSnapshot>> = new Map();
+
+  constructor() {
+    this.branches.set('main', { documents: new Map() });
+  }
+
+  private get currentBranchState(): BranchState {
+    return this.branches.get(this.currentBranchName)!;
+  }
+
+  private nextVersionId(): string {
+    this.versionCounter++;
+    return `v${this.versionCounter}`;
+  }
+
+  private snapshotBranch(branchName: string): BranchSnapshot {
+    const branch = this.branches.get(branchName)!;
+    const snapshot: BranchSnapshot = new Map();
+    for (const [docId, record] of branch.documents) {
+      snapshot.set(docId, {
+        content: record.content !== null ? structuredClone(record.content) : null,
+        deleted: record.deleted,
+      });
+    }
+    return snapshot;
+  }
+
+  private cloneBranchState(branchName: string): BranchState {
+    const source = this.branches.get(branchName)!;
+    const newDocs: Map<string, DocumentRecord> = new Map();
+    for (const [docId, record] of source.documents) {
+      newDocs.set(docId, {
+        versions: record.versions.map(v => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: structuredClone(v.content),
+        })),
+        content: record.content !== null ? structuredClone(record.content) : null,
+        deleted: record.deleted,
+      });
+    }
+    return { documents: newDocs };
+  }
+
+  // --- Document CRUD ---
+
+  create(id: string, content: object): void {
+    const branch = this.currentBranchState;
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: this.nextVersionId(),
+      timestamp: Date.now(),
+      content: structuredClone(content),
+    };
+
+    branch.documents.set(id, {
+      versions: existing ? [...existing.versions, version] : [version],
+      content: structuredClone(content),
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.currentBranchState;
+    const record = branch.documents.get(id);
+    if (!record || record.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return structuredClone(record.content!);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.currentBranchState;
+    const record = branch.documents.get(id);
+    if (!record || record.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    const version: Version = {
+      id: this.nextVersionId(),
+      timestamp: Date.now(),
+      content: structuredClone(content),
+    };
+
+    record.versions.push(version);
+    record.content = structuredClone(content);
+  }
+
+  delete(id: string): void {
+    const branch = this.currentBranchState;
+    const record = branch.documents.get(id);
+    if (!record || record.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    record.deleted = true;
+    record.content = null;
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const branch = this.currentBranchState;
+    const record = branch.documents.get(id);
+    if (!record) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return record.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: structuredClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.currentBranchState;
+    const record = branch.documents.get(id);
+    if (!record) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = record.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return structuredClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceBranch = fromBranch ?? this.currentBranchName;
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    // Clone the branch state
+    this.branches.set(name, this.cloneBranchState(sourceBranch));
+
+    // Store fork point snapshot
+    if (!this.forkPoints.has(name)) {
+      this.forkPoints.set(name, new Map());
+    }
+    this.forkPoints.get(name)!.set(sourceBranch, this.snapshotBranch(sourceBranch));
+
+    // Also store reverse mapping so we can merge in either direction
+    if (!this.forkPoints.has(sourceBranch)) {
+      this.forkPoints.set(sourceBranch, new Map());
+    }
+    this.forkPoints.get(sourceBranch)!.set(name, this.snapshotBranch(sourceBranch));
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranchName = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranchName;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  merge(sourceBranch: string): MergeResult {
+    const targetBranch = this.currentBranchName;
+
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    if (sourceBranch === targetBranch) {
+      throw new Error('Cannot merge a branch into itself');
+    }
+
+    // Find the fork point
+    const forkPoint = this.findForkPoint(targetBranch, sourceBranch);
+
+    // Get current states as simple maps for the merge algorithm
+    const oursDocuments = this.getDocumentStates(targetBranch);
+    const theirsDocuments = this.getDocumentStates(sourceBranch);
+
+    const { merged, conflicts } = threeWayMerge(forkPoint, oursDocuments, theirsDocuments);
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      this.applyMerge(targetBranch, merged, forkPoint, theirsDocuments);
+      // Update fork point so subsequent merges work correctly
+      this.updateForkPointAfterMerge(targetBranch, sourceBranch);
+    }
+
+    return { merged, conflicts, applied };
+  }
+
+  private findForkPoint(targetBranch: string, sourceBranch: string): BranchSnapshot {
+    // Check direct fork points
+    const targetForks = this.forkPoints.get(targetBranch);
+    if (targetForks && targetForks.has(sourceBranch)) {
+      return targetForks.get(sourceBranch)!;
+    }
+
+    const sourceForks = this.forkPoints.get(sourceBranch);
+    if (sourceForks && sourceForks.has(targetBranch)) {
+      return sourceForks.get(targetBranch)!;
+    }
+
+    // No fork point found — assume empty base (all docs are new)
+    return new Map();
+  }
+
+  private getDocumentStates(branchName: string): Map<string, { content: object | null; deleted: boolean }> {
+    const branch = this.branches.get(branchName)!;
+    const states: Map<string, { content: object | null; deleted: boolean }> = new Map();
+    for (const [docId, record] of branch.documents) {
+      states.set(docId, {
+        content: record.content !== null ? structuredClone(record.content) : null,
+        deleted: record.deleted,
+      });
+    }
+    return states;
+  }
+
+  private applyMerge(
+    targetBranch: string,
+    merged: Record<string, object>,
+    baseSnapshot: BranchSnapshot,
+    theirsDocuments: Map<string, { content: object | null; deleted: boolean }>
+  ): void {
+    const branch = this.branches.get(targetBranch)!;
+
+    // Apply merged documents
+    for (const [docId, content] of Object.entries(merged)) {
+      const existing = branch.documents.get(docId);
+      const version: Version = {
+        id: this.nextVersionId(),
+        timestamp: Date.now(),
+        content: structuredClone(content),
+      };
+
+      if (existing) {
+        existing.versions.push(version);
+        existing.content = structuredClone(content);
+        existing.deleted = false;
+      } else {
+        branch.documents.set(docId, {
+          versions: [version],
+          content: structuredClone(content),
+          deleted: false,
+        });
+      }
+    }
+
+    // Handle deletions: docs that existed in the base or theirs but are not in the merged result
+    // These are documents that the merge decided should be deleted
+    const mergedIds = new Set(Object.keys(merged));
+    for (const [docId, record] of branch.documents) {
+      if (!mergedIds.has(docId) && !record.deleted) {
+        // This doc exists on our branch but isn't in the merge result.
+        // It should be deleted if it was part of the merge consideration
+        // (i.e., it existed in base or in theirs)
+        const inBase = baseSnapshot.has(docId);
+        const inTheirs = theirsDocuments.has(docId);
+        if (inBase || inTheirs) {
+          record.deleted = true;
+          record.content = null;
+        }
+      }
+    }
+  }
+
+  private updateForkPointAfterMerge(targetBranch: string, sourceBranch: string): void {
+    // After a successful merge, update the fork point to the current state
+    // so subsequent merges don't re-apply the same changes
+    const snapshot = this.snapshotBranch(targetBranch);
+
+    if (!this.forkPoints.has(targetBranch)) {
+      this.forkPoints.set(targetBranch, new Map());
+    }
+    this.forkPoints.get(targetBranch)!.set(sourceBranch, snapshot);
+
+    if (!this.forkPoints.has(sourceBranch)) {
+      this.forkPoints.set(sourceBranch, new Map());
+    }
+    this.forkPoints.get(sourceBranch)!.set(targetBranch, snapshot);
+  }
+}
