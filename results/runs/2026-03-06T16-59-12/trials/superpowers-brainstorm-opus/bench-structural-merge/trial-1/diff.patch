+import type { Conflict, BranchSnapshot } from './types.js';
+
+interface FieldMergeResult {
+  value: unknown;
+  conflicts: Conflict[];
+}
+
+function isPlainObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (typeof a !== typeof b) return false;
+
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((item, i) => deepEqual(item, b[i]));
+  }
+
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    return keysA.every(key => key in b && deepEqual(a[key], b[key]));
+  }
+
+  return false;
+}
+
+function mergeFields(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  documentId: string,
+  pathPrefix: string
+): FieldMergeResult {
+  const allKeys = new Set([
+    ...Object.keys(base),
+    ...Object.keys(ours),
+    ...Object.keys(theirs),
+  ]);
+
+  const result: Record<string, unknown> = {};
+  const conflicts: Conflict[] = [];
+
+  for (const key of allKeys) {
+    const path = pathPrefix ? `${pathPrefix}.${key}` : key;
+    const baseVal = base[key];
+    const oursVal = ours[key];
+    const theirsVal = theirs[key];
+
+    const baseHas = key in base;
+    const oursHas = key in ours;
+    const theirsHas = key in theirs;
+
+    const oursChanged = !baseHas && oursHas || baseHas && !oursHas || (baseHas && oursHas && !deepEqual(baseVal, oursVal));
+    const theirsChanged = !baseHas && theirsHas || baseHas && !theirsHas || (baseHas && theirsHas && !deepEqual(baseVal, theirsVal));
+
+    if (!oursChanged && !theirsChanged) {
+      // Neither changed — keep base value (if it exists)
+      if (baseHas) {
+        result[key] = structuredClone(baseVal);
+      }
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      // Only ours changed
+      if (oursHas) {
+        result[key] = structuredClone(oursVal);
+      }
+      // If ours deleted the key, don't include it
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      // Only theirs changed
+      if (theirsHas) {
+        result[key] = structuredClone(theirsVal);
+      }
+      // If theirs deleted the key, don't include it
+      continue;
+    }
+
+    // Both changed
+    if (deepEqual(oursVal, theirsVal)) {
+      // Both changed to the same value
+      if (oursHas) {
+        result[key] = structuredClone(oursVal);
+      }
+      continue;
+    }
+
+    // Both changed to different values — check if we can recurse
+    if (isPlainObject(baseVal) && isPlainObject(oursVal) && isPlainObject(theirsVal)) {
+      const sub = mergeFields(baseVal, oursVal, theirsVal, documentId, path);
+      result[key] = sub.value;
+      conflicts.push(...sub.conflicts);
+      continue;
+    }
+
+    // Conflict — use ours for merged output
+    conflicts.push({
+      documentId,
+      path,
+      base: baseHas ? structuredClone(baseVal) : undefined,
+      ours: oursHas ? structuredClone(oursVal) : undefined,
+      theirs: theirsHas ? structuredClone(theirsVal) : undefined,
+    });
+    if (oursHas) {
+      result[key] = structuredClone(oursVal);
+    }
+  }
+
+  return { value: result, conflicts };
+}
+
+export interface DocumentMergeInput {
+  documentId: string;
+  base: { content: object | null; deleted: boolean } | undefined;
+  ours: { content: object | null; deleted: boolean } | undefined;
+  theirs: { content: object | null; deleted: boolean } | undefined;
+}
+
+export interface MergeOutput {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+}
+
+export function threeWayMerge(
+  baseSnapshot: BranchSnapshot,
+  oursDocuments: Map<string, { content: object | null; deleted: boolean }>,
+  theirsDocuments: Map<string, { content: object | null; deleted: boolean }>
+): MergeOutput {
+  const allDocIds = new Set([
+    ...baseSnapshot.keys(),
+    ...oursDocuments.keys(),
+    ...theirsDocuments.keys(),
+  ]);
+
+  const merged: Record<string, object> = {};
+  const conflicts: Conflict[] = [];
+
+  for (const docId of allDocIds) {
+    const base = baseSnapshot.get(docId);
+    const ours = oursDocuments.get(docId);
+    const theirs = theirsDocuments.get(docId);
+
+    const baseExists = base !== undefined && !base.deleted && base.content !== null;
+    const oursExists = ours !== undefined && !ours.deleted && ours.content !== null;
+    const theirsExists = theirs !== undefined && !theirs.deleted && theirs.content !== null;
+
+    // Document didn't exist at base
+    if (!baseExists) {
+      if (oursExists && !theirsExists) {
+        // Created only on ours
+        merged[docId] = structuredClone(ours!.content!) as object;
+        continue;
+      }
+      if (!oursExists && theirsExists) {
+        // Created only on theirs
+        merged[docId] = structuredClone(theirs!.content!) as object;
+        continue;
+      }
+      if (oursExists && theirsExists) {
+        // Created on both sides — merge their contents
+        const result = mergeFields(
+          {} as Record<string, unknown>,
+          ours!.content as Record<string, unknown>,
+          theirs!.content as Record<string, unknown>,
+          docId,
+          ''
+        );
+        merged[docId] = result.value as object;
+        conflicts.push(...result.conflicts);
+        continue;
+      }
+      // Neither side has it — skip
+      continue;
+    }
+
+    // Document existed at base
+    if (oursExists && theirsExists) {
+      // Both have it — standard three-way field merge
+      const oursChanged = !deepEqual(base!.content, ours!.content);
+      const theirsChanged = !deepEqual(base!.content, theirs!.content);
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes on either side — keep as is (fast-forward)
+        merged[docId] = structuredClone(ours!.content!) as object;
+        continue;
+      }
+
+      const result = mergeFields(
+        base!.content as Record<string, unknown>,
+        ours!.content as Record<string, unknown>,
+        theirs!.content as Record<string, unknown>,
+        docId,
+        ''
+      );
+      merged[docId] = result.value as object;
+      conflicts.push(...result.conflicts);
+      continue;
+    }
+
+    if (!oursExists && !theirsExists) {
+      // Both deleted — no conflict, doc stays deleted
+      continue;
+    }
+
+    if (oursExists && !theirsExists) {
+      // Theirs deleted, ours still has it
+      const oursChanged = !deepEqual(base!.content, ours!.content);
+      if (!oursChanged) {
+        // Ours didn't change, theirs deleted — accept deletion
+        continue;
+      }
+      // Ours changed and theirs deleted — conflict
+      conflicts.push({
+        documentId: docId,
+        path: '',
+        base: structuredClone(base!.content),
+        ours: structuredClone(ours!.content),
+        theirs: undefined,
+      });
+      // Use ours in merged output
+      merged[docId] = structuredClone(ours!.content!) as object;
+      continue;
+    }
+
+    if (!oursExists && theirsExists) {
+      // Ours deleted, theirs still has it
+      const theirsChanged = !deepEqual(base!.content, theirs!.content);
+      if (!theirsChanged) {
+        // Theirs didn't change, ours deleted — accept deletion
+        continue;
+      }
+      // Theirs changed and ours deleted — conflict
+      conflicts.push({
+        documentId: docId,
+        path: '',
+        base: structuredClone(base!.content),
+        ours: undefined,
+        theirs: structuredClone(theirs!.content),
+      });
+      // Use ours (deleted) — don't include in merged
+      continue;
+    }
+  }
+
+  return { merged, conflicts };
+}
