+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface DocumentRecord {
+  versions: Version[];
+  content: object | null;
+  deleted: boolean;
+}
+
+export interface BranchState {
+  documents: Map<string, DocumentRecord>;
+}
+
+export type BranchSnapshot = Map<string, { content: object | null; deleted: boolean }>;
