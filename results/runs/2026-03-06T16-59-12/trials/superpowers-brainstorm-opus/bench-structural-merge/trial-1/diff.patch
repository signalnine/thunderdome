mic values', () => {\n      store.create('doc1', { items: [1, 2, 3] });\n      store.createBranch('feature');\n\n      store.update('doc1', { items: [1, 2, 3, 4] }); // main adds 4\n\n      store.switchBranch('feature');\n      store.update('doc1', { items: [1, 2, 3, 5] }); // feature adds 5\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      // Arrays are atomic — both changed, so conflict\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('items');\n    });\n\n    it('should handle mixed conflict and non-conflict fields in same document', () => {\n      store.create('doc1', { a: 1, b: 2, c: 3 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 10, b: 2, c: 30 }); // main changes a and c\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20, c: 300 }); // feature changes b and c\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('c');\n      // merged should show ours for conflicts, theirs for non-conflicts\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 30 });\n    });\n\n    it('should create version entries when merge is applied', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('main');\n      const beforeHistory = store.getHistory('doc1');\n      store.merge('feature');\n      const afterHistory = store.getHistory('doc1');\n\n      expect(afterHistory.length).toBe(beforeHistory.length + 1);\n    });\n\n    it('should handle document created on both branches independently', () => {\n      store.createBranch('feature');\n\n      store.create('doc1', { a: 1 }); //