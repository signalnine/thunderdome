});\n  });\n\n  describe('update', () => {\n    it('should replace document content', () => {\n      store.create('doc1', { x: 1 });\n      store.update('doc1', { x: 2, y: 3 });\n      expect(store.get('doc1')).toEqual({ x: 2, y: 3 });\n    });\n\n    it('should throw if document does not exist', () => {\n      expect(() => store.update('nonexistent', { x: 1 })).toThrow();\n    });\n\n    it('should throw if document has been deleted', () => {\n      store.create('doc1', { x: 1 });\n      store.delete('doc1');\n      expect(() => store.update('doc1', { x: 2 })).toThrow();\n    });\n\n    it('should deep clone content on update', () => {\n      store.create('doc1', { x: 1 });\n      const content = { x: 2, nested: { value: 10 } };\n      store.update('doc1', content);\n      content.nested.value = 999;\n      expect(store.get('doc1')).toEqual({ x: 2, nested: { value: 10 } });\n    });\n  });\n\n  describe('delete', () => {\n    it('should remove a document', () => {\n      store.create('doc1', { x: 1 });\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should throw if document does not exist', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    it('should throw if document already deleted', () => {\n      store.create('doc1', { x: 1 });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n  });\n\n  // ========== Version History ==========\n\n  describe('getHistory', () => {\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    it('should have unique version IDs', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n\n    it('should include timestamps', () => {\n      store.create('doc1', { v: 1 });\n      const history = store.getHistory('doc1');\n      expect(typeof history[0].timestamp).toBe('number');\n      expect(history[0].timestamp).toBeGreaterThan(0);\n    });\n\n    it('should throw for nonexistent document', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should return deep-cloned content', () => {\n      store.create('doc1', { nested: { val: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).nested.val = 999;\n      expect(store.get('doc1')).toEqual({ nested: { val: 1 } });\n    });\n  });\n\n  describe('getVersion', () => {\n    it('should return content at a specific version', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });\n    });\n\n    it('should throw for nonexistent document', () => {\n      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();\n    });\n\n    it('should throw for nonexistent version', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'invalid')).toThrow();\n    });\n  });\n\n  // ========== Branching ==========\n\n  describe('branching', () => {\n    it('should default to main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should list branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n    });\n\n    it('should create a new branch from current branch', () => {\n      store.createBranch('feature');\n      expect(store.listBranches()).toContain('feature');\n    });\n\n    it('should create a branch from a specific branch', () => {\n      store.create('doc1', { x: 1 });\n      store.createBranch('feature', 'main');\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ x: 1 });\n    });\n\n    it('should throw when creating duplicate branch', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when creating branch from nonexistent source', () => {\n      expect(() => store.createBranch('feature', 'nonexistent')).toThrow();\n    });\n\n    it('should switch branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should throw when switching to nonexistent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { x: 1 });\n      store.createBranch('feature');\n\n      // Modify on main\n      store.update('doc1', { x: 2 });\n\n      // Feature should still see the old value\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ x: 1 });\n    });\n\n    it('should isolate new documents between branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { x: 1 });\n\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should isolate deletions between branches', () => {\n      store.create('doc1', { x: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ x: 1 });\n    });\n  });\n\n  // ========== Merging ==========\n\n  describe('merge', () => {\n    it('should merge non-conflicting changes from source branch', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      // Modify different fields on each branch\n      store.update('doc1', { a: 10, b: 2 }); // main changes 'a'\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20 }); // feature changes 'b'\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 20 });\n    });\n\n    it('should detect conflicts when both sides change same field differently', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 2 }); // main changes 'a' to 2\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 3 }); // feature changes 'a' to 3\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'a',\n        base: 1,\n        ours: 2,\n        theirs: 3,\n      });\n      // Merged uses \"ours\" for conflicts\n      expect(result.merged['doc1']).toEqual({ a: 2 });\n      // Current branch should remain unchanged\n      expect(store.get('doc1')).toEqual({ a: 2 });\n    });\n\n    it('should not conflict when both sides change same field to same value', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 42 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 42 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 42 });\n    });\n\n    it('should handle new document on source branch only', () => {\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.create('doc1', { x: 1 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ x: 1 });\n      expect(store.get('doc1')).toEqual({ x: 1 });\n    });\n\n    it('should handle new document on current branch only', () => {\n      store.createBranch('feature');\n\n      store.create('doc1', { x: 1 }); // on main\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ x: 1 });\n    });\n\n    it('should handle deletion on source when target did not modify', () => {\n      store.create('doc1', { x: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      // doc1 should not be in merged (deleted)\n      expect(result.merged['doc1']).toBeUndefined();\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should handle deletion on current when source did not modify', () => {\n      store.create('doc1', { x: 1 });\n      store.createBranch('feature');\n\n      store.delete('doc1'); // delete on main\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toBeUndefined();\n    });\n\n    it('should merge multiple documents independently', () => {\n      store.create('doc1', { a: 1 });\n      store.create('doc2', { b: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: 10 }); // main changes doc1\n\n      store.switchBranch('feature');\n      store.update('doc2', { b: 20 }); // feature changes doc2\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ a: 10 });\n      expect(store.get('doc2')).toEqual({ b: 20 });\n    });\n\n    it('should handle deep nested object merging', () => {\n      store.create('doc1', {\n        level1: {\n          level2: {\n            a: 1,\n            b: 2,\n          },\n        },\n      });\n      store.createBranch('feature');\n\n      store.update('doc1', {\n        level1: {\n          level2: {\n            a: 10,\n            b: 2,\n          },\n        },\n      });\n\n      store.switchBranch('feature');\n      store.update('doc1', {\n        level1: {\n          level2: {\n            a: 1,\n            b: 20,\n          },\n        },\n      });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({\n        level1: {\n          level2: {\n            a: 10,\n            b: 20,\n          },\n        },\n      });\n    });\n\n    it('should report deep nested conflicts with dot-separated path', () => {\n      store.create('doc1', { a: { b: { c: 1 } } });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: { b: { c: 2 } } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 3 } } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('a.b.c');\n      expect(result.conflicts[0].base).toBe(1);\n      expect(result.conflicts[0].ours).toBe(2);\n      expect(result.conflicts[0].theirs).toBe(3);\n    });\n\n    it('should handle no changes (fast-forward)