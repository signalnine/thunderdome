'doc1');\n      })();\n\n      const featureHistory = (() => {\n        store.switchBranch('feature');\n        return store.getHistory('doc1');\n      })();\n\n      expect(mainHistory).toHaveLength(3); // create + 2 updates\n      expect(featureHistory).toHaveLength(2); // create + 1 update\n    });\n\n    it('should allow re-creating a deleted document', () => {\n      store.create('doc1', { x: 1 });\n      store.delete('doc1');\n      store.create('doc1', { x: 2 });\n      expect(store.get('doc1')).toEqual({ x: 2 });\n    });\n\n    it('should support multiple merges', () => {\n      store.create('doc1', { a: 1, b: 1 });\n      store.createBranch('feature');\n\n      // First merge\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 2 });\n      store.switchBranch('main');\n      let result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ a: 1, b: 2 });\n\n      // Second merge — additional changes on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 3 });\n      store.switchBranch('main');\n      result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ a: 1, b: 3 });\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":110,"cache_read_input_tokens":32001,"cache_creation":{"ephemeral_5m_input_tokens":110,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"57ab5114-d69f-4d18-bbfc-b60090973393","uuid":"632c2d63-6da6-4413-89fd-0ff91bf2c0b9"}
