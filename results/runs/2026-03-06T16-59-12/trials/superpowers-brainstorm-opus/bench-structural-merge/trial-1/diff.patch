@@ -0,0 +1,663 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  // ========== Document CRUD ==========
+
+  describe('create', () => {
+    it('should create a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('should throw if document already exists', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(() => store.create('doc1', { name: 'Bob' })).toThrow();
+    });
+
+    it('should deep clone content on storage', () => {
+      const content = { name: 'Alice', nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { value: 1 } });
+    });
+  });
+
+  describe('get', () => {
+    it('should return the current content', () => {
+      store.create('doc1', { x: 1 });
+      expect(store.get('doc1')).toEqual({ x: 1 });
+    });
+
+    it('should throw if document does not exist', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should throw if document has been deleted', () => {
+      store.create('doc1', { x: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should deep clone content on retrieval', () => {
+      store.create('doc1', { nested: { value: 1 } });
