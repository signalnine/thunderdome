+describe('Integration: full e-commerce flow', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should handle a complete purchase flow', async () => {
+    // Create all services
+    const catalog = createCatalogService(bus);
+    const inventory = createInventoryService(bus);
+    const cart = createCartService(bus);
+    const pricing = createPricingService(bus);
+    const orders = createOrderService(bus);
+    const payment = createPaymentService(bus);
+    const notifications = createNotificationService(bus);
+    const analytics = createAnalyticsService(bus);
+
+    // Subscribe user for notifications
+    notifications.subscribe('user_1');
+
+    // Create products
+    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');
+    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');
+
+    // Wait for product created events to propagate
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    // Set inventory
+    inventory.setStock(p1, 50);
+    inventory.setStock(p2, 200);
+    inventory.setLowStockThreshold(p1, 5);
+
+    // Create cart and add items
+    const cartId = cart.createCart('user_1');
+    cart.addItem(cartId, p1, 1);
+    cart.addItem(cartId, p2, 2);
+
+    // Wait for cart events
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    // Calculate total
+    const priceResult = pricing.calculateTotal([
+      { productId: p1, quantity: 1, price: pricing.getPrice(p1) },
+      { productId: p2, quantity: 2, price: pricing.getPrice(p2) },
+    ]);
+
+    expect(priceResult.subtotal).toBe(1059.97);
+    expect(priceResult.tax).toBeCloseTo(105.997, 1);
+
+    // Reserve inventory
+    expect(inventory.reserve(p1, 1)).toBe(true);
+    expect(inventory.reserve(p2, 2)).toBe(true);
+
+    // Create order
+    const orderId = orders.createOrder('user_1', cartId, priceResult.total);
+
+    // Wait for order events
+    await new Promise(resolve => setTimeout(resolve, 10));
+
+    // Process payment
+    const paymentResult = await payment.processPayment(orderId, priceResult.total);
+    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);
+
+    // Confirm order
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+
+    // Wait for all events
+    await new Promise(resolve => setTimeout(resolve, 50));
+
+    // Verify notifications were sent
+    const userNotifs = notifications.getNotifications('user_1');
+    expect(userNotifs.length).toBeGreaterThanOrEqual(3);
+
+    // Verify analytics
+    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBeGreaterThanOrEqual(1);
+    expect(analytics.getRevenue()).toBeGreaterThan(0);
+    expect(analytics.getConversionRate()).toBeGreaterThan(0);
+
+    // Check inventory
+    expect(inventory.getStock(p1)).toBe(49);
+    expect(inventory.getStock(p2)).toBe(198);
+  });
+});
