+import { createAnalyticsService } from '../src/analytics/index.js';
+
+describe('Catalog Service', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should create a product and return an id', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    expect(id).toBeTruthy();
+    expect(typeof id).toBe('string');
+  });
+
+  it('should get a product by id', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    const product = catalog.getProduct(id);
+    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });
+  });
+
+  it('should return null for unknown product', () => {
+    const catalog = createCatalogService(bus);
+    expect(catalog.getProduct('nonexistent')).toBeNull();
+  });
+
+  it('should list products, optionally filtering by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.createProduct('Gizmo', 19.99, 'gadgets');
+    catalog.createProduct('Book', 14.99, 'books');
+
+    expect(catalog.listProducts()).toHaveLength(3);
+    expect(catalog.listProducts('gadgets')).toHaveLength(2);
+    expect(catalog.listProducts('books')).toHaveLength(1);
+  });
+
+  it('should search products by name or category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.createProduct('Super Widget', 19.99, 'gadgets');
+    catalog.createProduct('Book', 14.99, 'books');
+
+    expect(catalog.searchProducts('widget')).toHaveLength(2);
+    expect(catalog.searchProducts('books')).toHaveLength(1);
+  });
+
+  it('should update a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.updateProduct(id, { price: 12.99, name: 'Super Widget' });
+    const product = catalog.getProduct(id);
+    expect(product?.price).toBe(12.99);
+    expect(product?.name).toBe('Super Widget');
+  });
+
+  it('should remove a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    expect(catalog.removeProduct(id)).toBe(true);
+    expect(catalog.getProduct(id)).toBeNull();
+    expect(catalog.removeProduct(id)).toBe(false);
+  });
+
+  it('should emit product:created event', async () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    // Wait for async emit
+    await new Promise(resolve => setTimeout(resolve, 10));
+    const log = bus.getLog();
+    const createdEvents = log.filter(e => e.event === Events.PRODUCT_CREATED);
+    expect(createdEvents).toHaveLength(1);
+    expect(createdEvents[0].payload).toMatchObject({
+      name: 'Widget',
+      price: 9.99,
+      category: 'gadgets',
+    });
+  });
+});
+
+describe('Inventory Service', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should set and get stock', () => {
+    const inventory = createInventoryService(bus);
+    inventory.setStock('prod_1', 100);
+    expect(inventory.getStock('prod_1')).toBe(100);
+  });
+
+  it('should return 0 for unknown product stock', () => {
