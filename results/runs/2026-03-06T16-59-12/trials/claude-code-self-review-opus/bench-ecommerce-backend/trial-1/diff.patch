+    inventory.setStock('prod_1', 10);
+    inventory.reserve('prod_1', 5);
+    inventory.release('prod_1', 3);
+    expect(inventory.getStock('prod_1')).toBe(8);
+  });
+
+  it('should emit low stock alert', async () => {
+    const inventory = createInventoryService(bus);
+    const alerts: unknown[] = [];
+    bus.on(Events.LOW_STOCK_ALERT, (payload) => { alerts.push(payload); });
+
+    inventory.setStock('prod_1', 10);
+    inventory.setLowStockThreshold('prod_1', 5);
+    // Stock is 10, threshold 5 - no alert yet
+    expect(alerts).toHaveLength(0);
+
+    inventory.reserve('prod_1', 6);
+    // Stock now 4, below threshold 5
+    await new Promise(resolve => setTimeout(resolve, 10));
+    expect(alerts.length).toBeGreaterThanOrEqual(1);
+  });
+});
