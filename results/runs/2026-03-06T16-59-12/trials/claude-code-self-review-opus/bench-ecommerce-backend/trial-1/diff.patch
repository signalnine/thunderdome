Notification Service', () => {\n+  let bus: EventBus;\n+\n+  beforeEach(() => {\n+    bus = new EventBus();\n+  });\n+\n+  it('should deliver notifications to subscribed users', async () => {\n+    const notifications = createNotificationService(bus);\n+    notifications.subscribe('user_1');\n+\n+    // Simulate order creation\n+    await bus.emit(Events.ORDER_CREATED, {\n+      orderId: 'order_1',\n+      userId: 'user_1',\n+      cartId: 'cart_1',\n+      total: 50,\n+    });\n+\n+    const notifs = notifications.getNotifications('user_1');\n+    expect(notifs).toHaveLength(1);\n+    expect(notifs[0].type).toBe('order_created');\n+  });\n+\n+  it('should not deliver to unsubscribed users', async () => {\n+    const notifications = createNotificationService(bus);\n+\n+    await bus.emit(Events.ORDER_CREATED, {\n+      orderId: 'order_1',\n+      userId: 'user_1',\n+      cartId: 'cart_1',\n+      total: 50,\n+    });\n+\n+    const notifs = notifications.getNotifications('user_1');\n+    expect(notifs).toHaveLength(0);\n+  });\n+\n+  it('should track order-user mapping and notify on status changes', async () => {\n+    const notifications = createNotificationService(bus);\n+    notifications.subscribe('user_1');\n+\n+    await bus.emit(Events.ORDER_CREATED, {\n+      orderId: 'order_1',\n+      userId: 'user_1',\n+      cartId: 'cart_1',\n+      total: 50,\n+    });\n+\n+    await bus.emit(Events.ORDER_STATUS_CHANGED, {\n+      orderId: 'order_1',\n+      status: OrderStatus.CONFIRMED,\n+      previousStatus: OrderStatus.PENDING,\n+    });\n+\n+    const notifs = notifications.getNotifications('user_1');\n+    expect(notifs).toHaveLength(2);\n+    expect(notifs[1].type).toBe('order_status_changed');\n+  });\n+\n+  it('should notify on payment events', async () => {\n+    const notifications = createNotificationService(bus);\n+    notifications.subscribe('user_1');\n+\n+    await bus.emit(Events.ORDER_CREATED, {\n+      orderId: 'order_1',\n+      userId: 'user_1',\