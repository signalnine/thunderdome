+export { TaskQueue } from './TaskQueue.js';
+export type {
+  Task,
+  TaskStatus,
+  AddTaskOptions,
+  Schedule,
+  Middleware,
+  TaskHandler,
+  ProgressListener,
+  ShutdownResult,
+} from './types.js';
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..ca1f326
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,48 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface AddTaskOptions<T = unknown> {
+  payload: T;
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  lastRun?: Date;
+  active: boolean;
+}
+
+export type Middleware = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type TaskHandler = (task: Task) => Promise<void>;
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
