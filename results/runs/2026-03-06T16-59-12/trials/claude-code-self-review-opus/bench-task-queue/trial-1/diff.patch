+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 3: Priority', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should default priority to 5', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(task.priority).toBe(5);
+  });
+
+  it('should return higher-priority tasks first', () => {
+    queue.add({ payload: 'low', priority: 10 });
+    queue.add({ payload: 'high', priority: 1 });
+    queue.add({ payload: 'medium', priority: 5 });
+
+    expect(queue.next()!.payload).toBe('high');
+    expect(queue.next()!.payload).toBe('medium');
+    expect(queue.next()!.payload).toBe('low');
+  });
+
+  it('should maintain FIFO order within the same priority', () => {
+    queue.add({ payload: 'first', priority: 3 });
+    queue.add({ payload: 'second', priority: 3 });
+    queue.add({ payload: 'third', priority: 3 });
+
