@@ -0,0 +1,66 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should reject new tasks after shutdown', async () => {
+    await queue.shutdown();
+    expect(() => queue.add({ payload: 'test' })).toThrow(/shutting down/);
+  });
+
+  it('should complete immediately when no tasks are processing', async () => {
+    const result = await queue.shutdown();
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(result.durationMs).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should wait for processing tasks to finish', async () => {
+    queue.add({ payload: 'test' });
+    const task = queue.next()!;
+
+    // Start shutdown
+    const shutdownPromise = queue.shutdown(5000);
+
+    // Complete the task while shutdown is waiting
+    setTimeout(() => {
+      queue.complete(task.id);
+    }, 100);
+
+    const result = await shutdownPromise;
+    expect(result.completed).toBe(1);
+    expect(result.forceCancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks that do not finish within timeout', async () => {
+    queue.add({ payload: 'slow' });
+    queue.next(); // start processing but never complete
+
+    const result = await queue.shutdown(100);
+    expect(result.forceCancelled).toBe(1);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    const callback = vi.fn();
+    queue.onShutdown(callback);
+    await queue.shutdown();
+    expect(callback).toHaveBeenCalled();
+  });
+
+  it('should return the same result when called multiple times', async () => {
+    const result1 = queue.shutdown();
+    const result2 = queue.shutdown();
+    expect(await result1).toEqual(await result2);
+  });
+
+  it('should report shutdown duration', async () => {
+    const result = await queue.shutdown();
+    expect(typeof result.durationMs).toBe('number');
+    expect(result.durationMs).toBeGreaterThanOrEqual(0);
+  });
+});
