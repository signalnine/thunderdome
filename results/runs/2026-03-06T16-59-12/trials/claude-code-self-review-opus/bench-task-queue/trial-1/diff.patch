\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private processingPromises: Map<string, Promise<void>> = new Map();\n\n  // --- Phase 1: Basic FIFO Queue ---\n\n  add<T = unknown>(options: AddTaskOptions<T>): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Queue system is shutting down, cannot add new tasks');\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n    const priority = options.priority ?? 5;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      const taskId = randomUUID();\n      this.detectCircularDeps(taskId, dependencies);\n    }\n\n    let availableAt: Date;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    } else {\n      availableAt = new Date();\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload: options.payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: new Date(),\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      dependencies,\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n\n    return task;\n  }\n\n  next(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueState = this.queues.get(name);\n\n    // Check concurrency limit\n    if (queueState && queueState.concurrencyLimit !== null) {\n      if (queueState.activeCount >= queueState.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = Date.now();\n\n    // Find all eligible pending tasks for this queue\n    const candidates: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (\n        task.queue === name &&\n        task.status === 'pending' &&\n        task.availableAt.getTime() <= now &&\n        this.areDependenciesMet(task)\n      ) {\n        candidates.push(task);\n      }\n    }\n\n    if (candidates.length === 0) {\n      return null;\n    }\n\n    // Sort by priority (lower number = higher priority), then by availableAt, then by createdAt (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempts++;\n\n    if (queueState) {\n      queueState.activeCount++;\n    }\n\n    return task;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // --- Phase 2: Named Queues ---\n\n  private ensureQueue(name: string): void {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, {\n        concurrencyLimit: null,\n        activeCount: 0,\n        middlewares: [],\n        handler: null,\n      });\n    }\n  }\n\n  listQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // --- Phase 5: Retry