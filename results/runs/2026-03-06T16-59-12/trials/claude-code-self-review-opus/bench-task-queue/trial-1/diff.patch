@@ -0,0 +1,58 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 2: Named Queues', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should add tasks to a specific named queue', () => {
+    const task = queue.add({ payload: 'test', queue: 'emails' });
+    expect(task.queue).toBe('emails');
+  });
+
+  it('should use default queue when no name is given', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(task.queue).toBe('default');
+  });
+
+  it('should keep queues independent', () => {
+    queue.add({ payload: 'email1', queue: 'emails' });
+    queue.add({ payload: 'log1', queue: 'logs' });
+
+    expect(queue.size('emails')).toBe(1);
+    expect(queue.size('logs')).toBe(1);
+
+    const emailTask = queue.next('emails');
+    expect(emailTask!.payload).toBe('email1');
+    expect(queue.size('emails')).toBe(0);
+    expect(queue.size('logs')).toBe(1);
+  });
+
+  it('should return null from a non-existent queue', () => {
+    expect(queue.next('nonexistent')).toBeNull();
+  });
+
+  it('should return null from an empty queue', () => {
+    queue.add({ payload: 'test', queue: 'emails' });
+    queue.next('emails');
+    expect(queue.next('emails')).toBeNull();
+  });
+
+  it('should list all queue names', () => {
+    queue.add({ payload: 'a', queue: 'q1' });
+    queue.add({ payload: 'b', queue: 'q2' });
+    const names = queue.listQueues();
+    expect(names).toContain('q1');
+    expect(names).toContain('q2');
+  });
+
+  it('should be backward-compatible with Phase 1 (no queue name)', () => {
+    queue.add({ payload: 'test' });
+    const task = queue.next();
+    expect(task).toBeDefined();
+    expect(task!.payload).toBe('test');
+  });
+});
