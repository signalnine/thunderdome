@@ -0,0 +1,129 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should execute middleware in order', async () => {
+    const order: number[] = [];
+
+    queue.use('default', async (_task, next) => {
+      order.push(1);
+      await next();
+      order.push(4);
+    });
+    queue.use('default', async (_task, next) => {
+      order.push(2);
+      await next();
+      order.push(3);
+    });
+
+    queue.setHandler('default', async () => {
+      order.push(99);
+    });
+
+    queue.add({ payload: 'test' });
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(order).toEqual([1, 2, 99, 3, 4]);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const handlerCalled = vi.fn();
+
+    queue.use('default', async (_task, _next) => {
+      // intentionally not calling next
+    });
+
+    queue.setHandler('default', async () => {
+      handlerCalled();
+    });
+
+    queue.add({ payload: 'test' });
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(handlerCalled).not.toHaveBeenCalled();
+  });
+
+  it('should allow middleware to modify the task', async () => {
+    queue.use('default', async (task, next) => {
+      (task.payload as Record<string, unknown>).modified = true;
+      await next();
+    });
+
+    let receivedPayload: unknown;
+    queue.setHandler('default', async (task) => {
+      receivedPayload = task.payload;
+    });
+
+    queue.add({ payload: { original: true } });
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(receivedPayload).toEqual({ original: true, modified: true });
+  });
+
+  it('should mark task as failed if middleware throws', async () => {
+    queue.use('default', async (_task, _next) => {
+      throw new Error('middleware error');
+    });
+
+    queue.add({ payload: 'test', maxRetries: 0 });
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(queue.getTask(task.id)!.status).toBe('failed');
+    expect(queue.getTask(task.id)!.error).toBe('middleware error');
+  });
+
+  it('should mark task as failed if handler throws', async () => {
+    queue.setHandler('default', async () => {
+      throw new Error('handler error');
+    });
+
+    queue.add({ payload: 'test', maxRetries: 0 });
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(queue.getTask(task.id)!.status).toBe('failed');
+  });
+
+  it('should auto-complete the task if processing succeeds', async () => {
+    queue.setHandler('default', async () => {
+      // success
+    });
+
+    queue.add({ payload: 'test' });
+    const task = queue.next()!;
+    await queue.process(task.id);
+
+    expect(queue.getTask(task.id)!.status).toBe('completed');
+  });
+
+  it('should have independent middleware stacks per queue', async () => {
+    const q1Handler = vi.fn();
+    const q2Handler = vi.fn();
+
+    queue.use('q1', async (_task, next) => {
+      q1Handler();
+      await next();
+    });
+    queue.use('q2', async (_task, next) => {
+      q2Handler();
+      await next();
+    });
+
+    queue.add({ payload: 'test', queue: 'q1' });
+    const task = queue.next('q1')!;
+    await queue.process(task.id);
+
+    expect(q1Handler).toHaveBeenCalled();
+    expect(q2Handler).not.toHaveBeenCalled();
+  });
+});
