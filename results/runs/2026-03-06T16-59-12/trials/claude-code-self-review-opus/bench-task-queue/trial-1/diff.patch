+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should create a schedule', () => {
+    const schedule = queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: { type: 'cleanup' },
+    });
+    expect(schedule.id).toBeDefined();
+    expect(schedule.cron).toBe('*/5 * * * *');
+    expect(schedule.active).toBe(true);
+  });
+
+  it('should enqueue tasks on tick when schedule is due', () => {
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: { type: 'cleanup' },
+    });
+
+    // Tick at a time that matches */5 (e.g., minute 0)
+    const matchingTime = new Date(2024, 0, 1, 12, 0, 0);
+    const tasks = queue.tick(matchingTime);
+    expect(tasks).toHaveLength(1);
+    expect(tasks[0].payload).toEqual({ type: 'cleanup' });
+  });
+
+  it('should not enqueue tasks when schedule is not due', () => {
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: { type: 'cleanup' },
+    });
+
+    // Tick at minute 3 - not a multiple of 5
+    const nonMatchingTime = new Date(2024, 0, 1, 12, 3, 0);
+    const tasks = queue.tick(nonMatchingTime);
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should not duplicate tasks for the same matching minute', () => {
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: 'cleanup',
+    });
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    queue.tick(time);
+    const tasks = queue.tick(time); // tick again at same time
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should support every hour on the hour', () => {
+    queue.addSchedule({
+      cron: '0 * * * *',
+      payload: 'hourly',
+    });
+
+    const onHour = new Date(2024, 0, 1, 13, 0, 0);
+    const offHour = new Date(2024, 0, 1, 13, 30, 0);
+
+    expect(queue.tick(onHour)).toHaveLength(1);
+    expect(queue.tick(offHour)).toHaveLength(0);
+  });
+
+  it('should support every day at midnight', () => {
+    queue.addSchedule({
+      cron: '0 0 * * *',
+      payload: 'daily',
+    });
+
+    const midnight = new Date(2024, 0, 1, 0, 0, 0);
+    const noon = new Date(2024, 0, 1, 12, 0, 0);
+
+    expect(queue.tick(midnight)).toHaveLength(1);
+    expect(queue.tick(noon)).toHaveLength(0);
+  });
+
+  it('should remove a schedule', () => {
+    const schedule = queue.addSchedule({
+      cron: '*/5 * * * *',
+      payload: 'cleanup',
+    });
+
+    queue.removeSchedule(schedule.id);
+    expect(queue.listSchedules()).toHaveLength(0);
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    expect(queue.tick(time)).toHaveLength(0);
+  });
+
+  it('should list active schedules', () => {
+    queue.addSchedule({ cron: '*/5 * * * *', payload: 'a' });
+    queue.addSchedule({ cron: '0 * * * *', payload: 'b' });
+
+    const schedules = queue.listSchedules();
+    expect(schedules).toHaveLength(2);
+  });
+
+  it('should use specified queue for recurring tasks', () => {
+    queue.addSchedule({
+      cron: '*/5 * * * *',
+      queue: 'cron-jobs',
+      payload: 'test',
+    });
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    const tasks = queue.tick(time);
+    expect(tasks[0].queue).toBe('cron-jobs');
+  });
+
+  it('should reject invalid cron expressions', () => {
+    expect(() => queue.addSchedule({ cron: 'invalid', payload: 'test' })).toThrow();
+    expect(() => queue.addSchedule({ cron: '* * *', payload: 'test' })).toThrow();
+  });
+});
