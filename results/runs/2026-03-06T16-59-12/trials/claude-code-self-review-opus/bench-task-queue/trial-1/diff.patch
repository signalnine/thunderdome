@@ -0,0 +1,80 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  it('should not return a delayed task before its available time', () => {
+    queue.add({ payload: 'delayed', delay: 5000 });
+    expect(queue.next()).toBeNull();
+  });
+
+  it('should return a delayed task after its available time', () => {
+    queue.add({ payload: 'delayed', delay: 5000 });
+    vi.advanceTimersByTime(5000);
+    const task = queue.next();
+    expect(task).toBeDefined();
+    expect(task!.payload).toBe('delayed');
+  });
+
+  it('should prefer non-delayed tasks over delayed ones not yet available', () => {
+    queue.add({ payload: 'delayed', delay: 5000 });
+    queue.add({ payload: 'immediate' });
+
+    const task = queue.next();
+    expect(task!.payload).toBe('immediate');
+    expect(queue.next()).toBeNull(); // delayed not yet available
+  });
+
+  it('should order by availability time, then priority, then FIFO', () => {
+    const now = Date.now();
+    queue.add({ payload: 'later', delay: 2000, priority: 1 });
+    queue.add({ payload: 'sooner', delay: 1000, priority: 5 });
+    queue.add({ payload: 'same-as-sooner', delay: 1000, priority: 1 });
+
+    vi.advanceTimersByTime(2000);
+
+    // All available now. Order: priority first, then availableAt, then FIFO
+    // same-as-sooner: priority 1, available at now+1000
+    // later: priority 1, available at now+2000
+    // sooner: priority 5, available at now+1000
+    const t1 = queue.next();
+    const t2 = queue.next();
+    const t3 = queue.next();
+    expect(t1!.payload).toBe('same-as-sooner');
+    expect(t2!.payload).toBe('later');
+    expect(t3!.payload).toBe('sooner');
+  });
+
+  it('should support availableAt option', () => {
+    const futureTime = new Date(Date.now() + 3000);
+    const task = queue.add({ payload: 'future', availableAt: futureTime });
+    expect(task.availableAt).toEqual(futureTime);
+    expect(queue.next()).toBeNull();
+
+    vi.advanceTimersByTime(3000);
+    expect(queue.next()!.payload).toBe('future');
+  });
+
+  it('should expose availableAt on the task object', () => {
+    const task = queue.add({ payload: 'test', delay: 1000 });
+    expect(task.availableAt).toBeInstanceOf(Date);
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);
+  });
+
+  it('should work with named queues', () => {
+    queue.add({ payload: 'delayed', queue: 'q1', delay: 1000 });
+    expect(queue.next('q1')).toBeNull();
+    vi.advanceTimersByTime(1000);
+    expect(queue.next('q1')!.payload).toBe('delayed');
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+});
diff --git a/tests/phase05-retry.test.ts b/tests/phase05-retry.test.ts
new file mode 100644
index 0000000..25816b4
--- /dev/null
+++ b/tests/phase05-retry.test.ts
@@ -0,0 +1,114 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should mark a task as completed', () => {
+    queue.add({ payload: 'test' });
+    const task = queue.next()!;
+    queue.complete(task.id);
+    expect(queue.getTask(task.id)!.status).toBe('completed');
+  });
+
+  it('should mark a task as failed and retry', () => {
+    queue.add({ payload: 'test', maxRetries: 3, backoffDelay: 1000 });
+    const task = queue.next()!;
+    queue.fail(task.id, 'oops');
+
+    // Task should be back to pending with delay
+    expect(queue.getTask(task.id)!.status).toBe('pending');
+    expect(queue.getTask(task.id)!.attempts).toBe(1);
+
+    // Not yet available
+    expect(queue.next()).toBeNull();
+
+    // After backoff delay (1000ms for first retry)
+    vi.advanceTimersByTime(1000);
+    const retry = queue.next();
+    expect(retry).toBeDefined();
+    expect(retry!.id).toBe(task.id);
+    expect(retry!.attempts).toBe(2);
+  });
+
+  it('should use exponential backoff', () => {
+    queue.add({ payload: 'test', maxRetries: 3, backoffDelay: 1000 });
+
+    // Attempt 1 (original)
+    const t1 = queue.next()!;
+    queue.fail(t1.id, 'fail 1');
+    // Backoff: 1000 * 2^0 = 1000ms
+    vi.advanceTimersByTime(1000);
+
+    // Attempt 2 (retry 1)
+    const t2 = queue.next()!;
+    queue.fail(t2.id, 'fail 2');
+    // Backoff: 1000 * 2^1 = 2000ms
+    vi.advanceTimersByTime(2000);
+
+    // Attempt 3 (retry 2)
+    const t3 = queue.next()!;
+    queue.fail(t3.id, 'fail 3');
+    // Backoff: 1000 * 2^2 = 4000ms
+    vi.advanceTimersByTime(4000);
+
+    // Attempt 4 (retry 3) - last retry
+    const t4 = queue.next()!;
+    queue.fail(t4.id, 'fail 4');
+    // All retries exhausted - should be failed
+    expect(queue.getTask(t4.id)!.status).toBe('failed');
+    expect(t4.attempts).toBe(4);
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    queue.add({ payload: 'test', queue: 'emails', priority: 2, maxRetries: 3, backoffDelay: 100 });
+    const task = queue.next('emails')!;
+    queue.fail(task.id, 'err');
+
+    vi.advanceTimersByTime(100);
+    const retried = queue.next('emails')!;
+    expect(retried.queue).toBe('emails');
+    expect(retried.priority).toBe(2);
+  });
+
+  it('should track attempt count', () => {
+    queue.add({ payload: 'test', maxRetries: 2, backoffDelay: 100 });
+    const t = queue.next()!;
+    expect(t.attempts).toBe(1);
+    queue.fail(t.id, 'err');
+    vi.advanceTimersByTime(100);
+    const t2 = queue.next()!;
+    expect(t2.attempts).toBe(2);
+  });
+
+  it('should error when completing a non-processing task', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(() => queue.complete(task.id)).toThrow();
+  });
+
+  it('should store error information', () => {
+    queue.add({ payload: 'test', maxRetries: 0, backoffDelay: 100 });
+    const task = queue.next()!;
+    queue.fail(task.id, 'something broke');
+    expect(queue.getTask(task.id)!.error).toBe('something broke');
+  });
+
+  it('should default maxRetries to 3', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should default backoffDelay to 1000ms', () => {
+    const task = queue.add({ payload: 'test' });
+    expect(task.backoffDelay).toBe(1000);
+  });
+});
