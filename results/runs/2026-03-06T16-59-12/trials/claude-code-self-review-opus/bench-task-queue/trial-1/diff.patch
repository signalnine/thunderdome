@@ -0,0 +1,112 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  describe('Progress', () => {
+    it('should update and query task progress', () => {
+      queue.add({ payload: 'test' });
+      const task = queue.next()!;
+
+      queue.updateProgress(task.id, 50, 'halfway');
+      const progress = queue.getProgress(task.id);
+      expect(progress.progress).toBe(50);
+      expect(progress.message).toBe('halfway');
+    });
+
+    it('should reject invalid progress values', () => {
+      queue.add({ payload: 'test' });
+      const task = queue.next()!;
+      expect(() => queue.updateProgress(task.id, -1)).toThrow();
+      expect(() => queue.updateProgress(task.id, 101)).toThrow();
+    });
+
+    it('should notify progress listeners', () => {
+      queue.add({ payload: 'test' });
+      const task = queue.next()!;
+
+      const listener = vi.fn();
+      queue.onProgress(task.id, listener);
+
+      queue.updateProgress(task.id, 25, 'quarter');
+      expect(listener).toHaveBeenCalledWith(25, 'quarter');
+
+      queue.updateProgress(task.id, 75, 'three quarters');
+      expect(listener).toHaveBeenCalledTimes(2);
+    });
+
+    it('should allow unsubscribing from progress', () => {
+      queue.add({ payload: 'test' });
+      const task = queue.next()!;
+
+      const listener = vi.fn();
+      const unsubscribe = queue.onProgress(task.id, listener);
+
+      queue.updateProgress(task.id, 25);
+      expect(listener).toHaveBeenCalledTimes(1);
+
+      unsubscribe();
+      queue.updateProgress(task.id, 50);
+      expect(listener).toHaveBeenCalledTimes(1); // no new calls
+    });
+
+    it('should only allow progress on processing tasks', () => {
+      const task = queue.add({ payload: 'test' });
+      expect(() => queue.updateProgress(task.id, 50)).toThrow();
+    });
+  });
+
+  describe('Cancellation', () => {
+    it('should cancel a pending task', () => {
+      const task = queue.add({ payload: 'test' });
+      queue.cancel(task.id);
+      expect(queue.getTask(task.id)!.status).toBe('cancelled');
+      expect(queue.next()).toBeNull(); // removed from queue
+    });
+
+    it('should cancel a processing task', () => {
+      queue.add({ payload: 'test' });
+      const task = queue.next()!;
+      queue.cancel(task.id);
+      expect(queue.getTask(task.id)!.status).toBe('cancelled');
+    });
+
+    it('should not cancel a completed task', () => {
+      queue.add({ payload: 'test' });
+      const task = queue.next()!;
+      queue.complete(task.id);
+      expect(() => queue.cancel(task.id)).toThrow();
+    });
+
+    it('should not retry cancelled tasks', () => {
+      vi.useFakeTimers();
+      queue.add({ payload: 'test', maxRetries: 3, backoffDelay: 100 });
+      const task = queue.next()!;
+      queue.cancel(task.id);
+
+      expect(queue.getTask(task.id)!.status).toBe('cancelled');
+      vi.advanceTimersByTime(10000);
+      expect(queue.next()).toBeNull();
+      vi.useRealTimers();
+    });
+
+    it('should free concurrency slot when cancelling processing task', () => {
+      queue.setConcurrency('default', 1);
+      queue.add({ payload: 'a' });
+      queue.add({ payload: 'b' });
+
+      const t1 = queue.next()!;
+      expect(queue.next()).toBeNull(); // limit reached
+
+      queue.cancel(t1.id);
+      const t2 = queue.next();
+      expect(t2).toBeDefined();
+      expect(t2!.payload).toBe('b');
+    });
+  });
+});
