@@ -0,0 +1,95 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should block tasks with unresolved dependencies', () => {
+    const dep = queue.add({ payload: 'dependency' });
+    queue.add({ payload: 'dependent', dependencies: [dep.id] });
+
+    // The dependency should be retrieved first
+    const task = queue.next();
+    expect(task!.payload).toBe('dependency');
+
+    // The dependent should not be available yet
+    expect(queue.next()).toBeNull();
+  });
+
+  it('should unblock tasks when dependencies complete', () => {
+    const dep = queue.add({ payload: 'dependency' });
+    queue.add({ payload: 'dependent', dependencies: [dep.id] });
+
+    const depTask = queue.next()!;
+    queue.complete(depTask.id);
+
+    const dependent = queue.next();
+    expect(dependent).toBeDefined();
+    expect(dependent!.payload).toBe('dependent');
+  });
+
+  it('should handle multiple dependencies', () => {
+    const dep1 = queue.add({ payload: 'dep1' });
+    const dep2 = queue.add({ payload: 'dep2' });
+    queue.add({ payload: 'dependent', dependencies: [dep1.id, dep2.id] });
+
+    // Process dep1
+    const t1 = queue.next()!;
+    queue.complete(t1.id);
+
+    // Dependent still blocked (dep2 not done)
+    const next1 = queue.next();
+    expect(next1!.payload).toBe('dep2');
+
+    // Dependent still blocked
+    expect(queue.next()).toBeNull();
+
+    // Complete dep2
+    queue.complete(next1!.id);
+
+    // Now dependent is available
+    const dependent = queue.next();
+    expect(dependent!.payload).toBe('dependent');
+  });
+
+  it('should error when depending on a non-existent task', () => {
+    expect(() =>
+      queue.add({ payload: 'test', dependencies: ['nonexistent'] })
+    ).toThrow();
+  });
+
+  it('should keep dependents blocked when a dependency fails', () => {
+    const dep = queue.add({ payload: 'dep', maxRetries: 1 });
+    queue.add({ payload: 'dependent', dependencies: [dep.id] });
+
+    const task = queue.next()!;
+    queue.fail(task.id, 'err');
+
+    // Dependent remains blocked since dep is failed (not completed)
+    expect(queue.next()).toBeNull();
+  });
+
+  it('should provide dependency status', () => {
+    const dep1 = queue.add({ payload: 'dep1' });
+    const dep2 = queue.add({ payload: 'dep2' });
+    const dependent = queue.add({ payload: 'dependent', dependencies: [dep1.id, dep2.id] });
+
+    const status = queue.getDependencyStatus(dependent.id);
+    expect(status.total).toBe(2);
+    expect(status.completed).toBe(0);
+    expect(status.pending).toContain(dep1.id);
+    expect(status.pending).toContain(dep2.id);
+
+    // Complete one dependency
+    const t1 = queue.next()!;
+    queue.complete(t1.id);
+
+    const status2 = queue.getDependencyStatus(dependent.id);
+    expect(status2.completed).toBe(1);
+    expect(status2.pending).toHaveLength(1);
+  });
+});
