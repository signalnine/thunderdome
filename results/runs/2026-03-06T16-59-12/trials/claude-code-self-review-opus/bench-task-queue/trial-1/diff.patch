+    expect(() => queue.add({ payload: 'test', priority: 0 })).toThrow();
+    expect(() => queue.add({ payload: 'test', priority: 11 })).toThrow();
+    expect(() => queue.add({ payload: 'test', priority: -1 })).toThrow();
+    expect(() => queue.add({ payload: 'test', priority: 1.5 })).toThrow();
+  });
+
+  it('should handle priority per queue independently', () => {
+    queue.add({ payload: 'q1-low', queue: 'q1', priority: 10 });
+    queue.add({ payload: 'q1-high', queue: 'q1', priority: 1 });
+    queue.add({ payload: 'q2-only', queue: 'q2', priority: 5 });
+
+    expect(queue.next('q1')!.payload).toBe('q1-high');
+    expect(queue.next('q2')!.payload).toBe('q2-only');
+  });
+
+  it('should expose priority on the task object', () => {
+    const task = queue.add({ payload: 'test', priority: 3 });
+    expect(task.priority).toBe(3);
