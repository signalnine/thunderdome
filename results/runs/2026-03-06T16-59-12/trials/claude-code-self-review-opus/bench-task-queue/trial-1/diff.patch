167→  }\n   168→\n   169→  listQueues(): string[] {\n   170→    return Array.from(this.queues.keys());\n   171→  }\n   172→\n   173→  // --- Phase 5: Retry with Backoff / Phase 6: DLQ ---\n   174→\n   175→  complete(taskId: string): void {\n   176→    const task = this.tasks.get(taskId);\n   177→    if (!task) {\n   178→      throw new Error(`Task not found: ${taskId}`);\n   179→    }\n   180→    if (task.status !== 'processing') {\n   181→      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n   182→    }\n   183→\n   184→    task.status = 'completed';\n   185→    this.decrementActive(task.queue);\n   186→\n   187→    // Check if any blocked tasks can now proceed\n   188→    this.checkDependents(taskId);\n   189→  }\n   190→\n   191→  fail(taskId: string, error?: string): void {\n   192→    const task = this.tasks.get(taskId);\n   193→    if (!task) {\n   194→      throw new Error(`Task not found: ${taskId}`);\n   195→    }\n   196→    if (task.status !== 'processing') {\n   197→      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n   198→    }\n   199→\n   200→    task.error = error;\n   201→    this.decrementActive(task.queue);\n   202→\n   203→    if (task.attempts <= task.maxRetries) {\n   204→      // Retry with exponential backoff\n   205→      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n   206→      task.status = 'pending';\n   207→      task.availableAt = new Date(Date.now() + delay);\n   208→      task.progress = 0;\n   209→      task.progressMessage = undefined;\n   210→    } else {\n   211→      // All retries exhausted\n   212→      task.status = 'failed';\n   213→      this.addToDeadLetterQueue(task);\n   214→    }\n   215→  }\n   216→\n   217→  private decrementActive(queueName: string): void {\n   218→    const queueState = this.queues.get(queueName);\n   219→    if (queueState && queueState.activeCount > 0) {\n   220→      queueState.activeCount--