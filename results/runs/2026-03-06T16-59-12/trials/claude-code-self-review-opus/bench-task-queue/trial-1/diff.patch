+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_012799GVd7VxojtG4DnU9RSN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015HZk569ezu9SJGcUTxu2gS","name":"Write","input":{"file_path":"/workspace/tests/phase09-progress.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('Phase 9: Progress Tracking and Cancellation', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  describe('Progress', () => {\n    it('should update and query task progress', () => {\n      queue.add({ payload: 'test' });\n      const task = queue.next()!;\n\n      queue.updateProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add({ payload: 'test' });\n      const task = queue.next()!;\n      expect(() => queue.updateProgress(task.id, -1)).toThrow();\n      expect(() => queue.updateProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      queue.add({ payload: 'test' });\n      const task = queue.next()!;\n\n      const listener = vi.fn();\n      queue.onProgress(task.id, listener);\n\n      queue.updateProgress(task.id, 25, 'quarter');\n      expect(listener).toHaveBeenCalledWith(25, 'quarter');\n\n      queue.updateProgress(task.id, 75, 'three quarters');\n      expect(listener).toHaveBeenCalledTimes(2);\n    });\n\n    it('should allow unsubscribing from progress', () => {\n      queue.add({ payload: 'test' });\n      const task = queue.next()!;\n\n      const listener = vi.fn();\n      const unsubscribe = queue.onProgress(task.id, listener);\n\n      queue.updateProgress(task.id, 25);\n      expect(listener).toHaveBeenCalledTimes(1);\n\n      unsubscribe();\n   