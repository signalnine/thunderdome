+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should limit concurrent processing tasks', () => {
+    queue.setConcurrency('default', 2);
+    queue.add({ payload: 'a' });
+    queue.add({ payload: 'b' });
+    queue.add({ payload: 'c' });
+
+    const t1 = queue.next();
+    const t2 = queue.next();
+    const t3 = queue.next();
+
+    expect(t1).toBeDefined();
+    expect(t2).toBeDefined();
+    expect(t3).toBeNull(); // limit reached
+  });
+
+  it('should free a slot when a task completes', () => {
+    queue.setConcurrency('default', 1);
+    queue.add({ payload: 'a' });
+    queue.add({ payload: 'b' });
+
+    const t1 = queue.next()!;
+    expect(queue.next()).toBeNull(); // limit reached
+
+    queue.complete(t1.id);
+    const t2 = queue.next();
+    expect(t2).toBeDefined();
+    expect(t2!.payload).toBe('b');
+  });
+
+  it('should free a slot when a task fails', () => {
+    queue.setConcurrency('default', 1);
+    queue.add({ payload: 'a', maxRetries: 0 });
+    queue.add({ payload: 'b' });
+
+    const t1 = queue.next()!;
+    expect(queue.next()).toBeNull();
+
+    queue.fail(t1.id, 'err');
+    const t2 = queue.next();
+    expect(t2).toBeDefined();
+  });
+
+  it('should have no concurrency limit by default', () => {
+    const info = queue.getConcurrency('default');
+    expect(info.limit).toBeNull();
+    expect(info.active).toBe(0);
+  });
+
+  it('should report active count', () => {
+    queue.setConcurrency('default', 5);
+    queue.add({ payload: 'a' });
+    queue.add({ payload: 'b' });
+
+    queue.next();
+    expect(queue.getConcurrency().active).toBe(1);
+
+    queue.next();
+    expect(queue.getConcurrency().active).toBe(2);
+  });
+
+  it('should still respect priority when concurrency-limited', () => {
+    queue.setConcurrency('default', 1);
+    queue.add({ payload: 'low', priority: 10 });
+    queue.add({ payload: 'high', priority: 1 });
+
+    const task = queue.next()!;
+    expect(task.payload).toBe('high');
+  });
+});
diff --git a/tests/phase09-progress.test.ts b/tests/phase09-progress.test.ts
new file mode 100644
