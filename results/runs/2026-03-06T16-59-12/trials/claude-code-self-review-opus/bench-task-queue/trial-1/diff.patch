if (!schedule) {\n   441→      throw new Error(`Schedule not found: ${scheduleId}`);\n   442→    }\n   443→    schedule.active = false;\n   444→    this.schedules.delete(scheduleId);\n   445→  }\n   446→\n   447→  listSchedules(): Schedule[] {\n   448→    return Array.from(this.schedules.values()).filter(s => s.active);\n   449→  }\n   450→\n   451→  tick(now?: Date): Task[] {\n   452→    const currentTime = now ?? new Date();\n   453→    const created: Task[] = [];\n   454→\n   455→    for (const schedule of this.schedules.values()) {\n   456→      if (!schedule.active) continue;\n   457→\n   458→      if (this.shouldRunSchedule(schedule, currentTime)) {\n   459→        const task = this.add({\n   460→          payload: schedule.payload,\n   461→          queue: schedule.queue,\n   462→        });\n   463→        created.push(task);\n   464→        schedule.lastRun = currentTime;\n   465→      }\n   466→    }\n   467→\n   468→    return created;\n   469→  }\n   470→\n   471→  private validateCron(expr: string): void {\n   472→    const parts = expr.trim().split(/\\s+/);\n   473→    if (parts.length !== 5) {\n   474→      throw new Error(`Invalid cron expression: ${expr}. Must have exactly 5 fields.`);\n   475→    }\n   476→\n   477→    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n   478→\n   479→    // Validate minute field: number, *, or */N\n   480→    if (!this.isValidCronField(minute, 0, 59)) {\n   481→      throw new Error(`Invalid cron minute field: ${minute}`);\n   482→    }\n   483→    // Validate hour field\n   484→    if (!this.isValidCronField(hour, 0, 23)) {\n   485→      throw new Error(`Invalid cron hour field: ${hour}`);\n   486→    }\n   487→    // Remaining fields must be *\n   488→    if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {\n   489→      throw new Error(`Only *, */N, and numeric values are supported for minute/hour. Day/month/weekday must be *.`);\n   490→    }\n   491→  }\n   492→\n   493→  private isValidC