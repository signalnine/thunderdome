@@ -0,0 +1,65 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = queue.add({ payload: { message: 'hello' } });
+    expect(task).toBeDefined();
+    expect(task.id).toBeDefined();
+    expect(task.payload).toEqual({ message: 'hello' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should generate unique IDs for each task', () => {
+    const t1 = queue.add({ payload: 'a' });
+    const t2 = queue.add({ payload: 'b' });
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    queue.add({ payload: 'first' });
+    queue.add({ payload: 'second' });
+    queue.add({ payload: 'third' });
+
+    const t1 = queue.next();
+    const t2 = queue.next();
+    const t3 = queue.next();
+
+    expect(t1!.payload).toBe('first');
+    expect(t2!.payload).toBe('second');
+    expect(t3!.payload).toBe('third');
+  });
+
+  it('should transition tasks from pending to processing', () => {
+    queue.add({ payload: 'test' });
+    const task = queue.next();
+    expect(task!.status).toBe('processing');
+  });
+
+  it('should return null when no tasks are available', () => {
+    expect(queue.next()).toBeNull();
+  });
+
+  it('should track the number of pending tasks', () => {
+    expect(queue.size()).toBe(0);
+    queue.add({ payload: 'a' });
+    queue.add({ payload: 'b' });
+    expect(queue.size()).toBe(2);
+    queue.next();
+    expect(queue.size()).toBe(1);
+  });
+
+  it('should allow looking up a task by ID', () => {
+    const task = queue.add({ payload: 'find me' });
+    const found = queue.getTask(task.id);
+    expect(found).toBeDefined();
+    expect(found!.payload).toBe('find me');
+  });
+});
