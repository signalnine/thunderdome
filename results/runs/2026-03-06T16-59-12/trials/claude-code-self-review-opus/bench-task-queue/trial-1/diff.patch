lay (1000ms for first retry)\n    vi.advanceTimersByTime(1000);\n    const retry = queue.next();\n    expect(retry).toBeDefined();\n    expect(retry!.id).toBe(task.id);\n    expect(retry!.attempts).toBe(2);\n  });\n\n  it('should use exponential backoff', () => {\n    queue.add({ payload: 'test', maxRetries: 3, backoffDelay: 1000 });\n\n    // Attempt 1 (original)\n    const t1 = queue.next()!;\n    queue.fail(t1.id, 'fail 1');\n    // Backoff: 1000 * 2^0 = 1000ms\n    vi.advanceTimersByTime(1000);\n\n    // Attempt 2 (retry 1)\n    const t2 = queue.next()!;\n    queue.fail(t2.id, 'fail 2');\n    // Backoff: 1000 * 2^1 = 2000ms\n    vi.advanceTimersByTime(2000);\n\n    // Attempt 3 (retry 2)\n    const t3 = queue.next()!;\n    queue.fail(t3.id, 'fail 3');\n    // Backoff: 1000 * 2^2 = 4000ms\n    vi.advanceTimersByTime(4000);\n\n    // Attempt 4 (retry 3) - last retry\n    const t4 = queue.next()!;\n    queue.fail(t4.id, 'fail 4');\n    // All retries exhausted - should be failed\n    expect(queue.getTask(t4.id)!.status).toBe('failed');\n    expect(t4.attempts).toBe(4);\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    queue.add({ payload: 'test', queue: 'emails', priority: 2, maxRetries: 3, backoffDelay: 100 });\n    const task = queue.next('emails')!;\n    queue.fail(task.id, 'err');\n\n    vi.advanceTimersByTime(100);\n    const retried = queue.next('emails')!;\n    expect(retried.queue).toBe('emails');\n    expect(retried.priority).toBe(2);\n  });\n\n  it('should track attempt count', () => {\n    queue.add({ payload: 'test', maxRetries: 2, backoffDelay: 100 });\n    const t = queue.next()!;\n    expect(t.attempts).toBe(1);\n    queue.fail(t.id, 'err');\n    vi.advanceTimersByTime(100);\n    const t2 = queue.next()!;\n    expect(t2.attempts).toBe(2);\n  });\n\n  it('should error when completing a non-processing task', () => {\n    const task = queue.add({ payload: 'test' });\n    expect(() => queue.complete(task.id)).toThrow();\n  });\n\n  it('should store error information', () => {\n    queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 100 });\n    const task = queue.next()!;\n    queue.fail(task.id, 'something broke');\n    expect(queue.getTask(task.id)!.error).toBe('something broke');\n  });\n\n  it('should default maxRetries to 3', () => {\n    const task = queue.add({ payload: 'test' });\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default backoffDelay to 1000ms', () => {\n    const task = queue.add({ payload: 'test' });\n    expect(task.backoffDelay).toBe(1000);\n  });\n});\n","structuredPatch":[{"oldStart":96,"oldLines":7,"newStart":96,"newLines":7,"lines":["   });"," ","   it('should store error information', () => {","-    queue.add({ payload: 'test', maxRetries: 1, backoffDelay: 100 });","+    queue.add({ payload: 'test', maxRetries: 0, backoffDelay: 100 });","     const task = queue.next()!;","     queue.fail(task.id, 'something broke');","     expect(queue.getTask(task.id)!.error).toBe('something broke');"]}],"userModified":false,"replaceAll":false}}
