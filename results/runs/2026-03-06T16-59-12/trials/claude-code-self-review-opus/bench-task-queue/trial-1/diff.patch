ll): void {\n   330→    this.ensureQueue(queueName);\n   331→    const state = this.queues.get(queueName)!;\n   332→    state.concurrencyLimit = limit;\n   333→  }\n   334→\n   335→  getConcurrency(queueName?: string): { limit: number | null; active: number } {\n   336→    const name = queueName ?? DEFAULT_QUEUE;\n   337→    const state = this.queues.get(name);\n   338→    if (!state) {\n   339→      return { limit: null, active: 0 };\n   340→    }\n   341→    return { limit: state.concurrencyLimit, active: state.activeCount };\n   342→  }\n   343→\n   344→  // --- Phase 9: Progress and Cancellation ---\n   345→\n   346→  updateProgress(taskId: string, progress: number, message?: string): void {\n   347→    const task = this.tasks.get(taskId);\n   348→    if (!task) {\n   349→      throw new Error(`Task not found: ${taskId}`);\n   350→    }\n   351→    if (task.status !== 'processing') {\n   352→      throw new Error(`Task ${taskId} is not in processing state`);\n   353→    }\n   354→    if (progress < 0 || progress > 100) {\n   355→      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n   356→    }\n   357→\n   358→    task.progress = progress;\n   359→    task.progressMessage = message;\n   360→\n   361→    const listeners = this.progressListeners.get(taskId);\n   362→    if (listeners) {\n   363→      for (const listener of listeners) {\n   364→        listener(progress, message);\n   365→      }\n   366→    }\n   367→  }\n   368→\n   369→  getProgress(taskId: string): { progress: number; message?: string } {\n   370→    const task = this.tasks.get(taskId);\n   371→    if (!task) {\n   372→      throw new Error(`Task not found: ${taskId}`);\n   373→    }\n   374→    return { progress: task.progress, message: task.progressMessage };\n   375→  }\n   376→\n   377→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   378→    if (!this.progressListeners.has(taskId)) {\n   379→      this.progressListeners.set(taskId, n