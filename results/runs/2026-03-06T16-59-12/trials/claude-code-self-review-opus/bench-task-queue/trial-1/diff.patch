@@ -0,0 +1,100 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should move tasks to DLQ after exhausting retries', () => {
+    queue.add({ payload: 'fragile', maxRetries: 0, backoffDelay: 100 });
+    const task = queue.next()!;
+    queue.fail(task.id, 'error 1');
+
+    expect(queue.getDeadLetterQueue()).toHaveLength(1);
+    expect(queue.getDeadLetterQueue()[0].id).toBe(task.id);
+  });
+
+  it('should only DLQ after all retries are exhausted', () => {
+    queue.add({ payload: 'fragile', maxRetries: 1, backoffDelay: 100 });
+    const task = queue.next()!;
+    queue.fail(task.id, 'error 1');
+
+    // Should retry, not DLQ
+    expect(queue.getDeadLetterQueue()).toHaveLength(0);
+    expect(queue.getTask(task.id)!.status).toBe('pending');
+
+    vi.advanceTimersByTime(100);
+    const retry = queue.next()!;
+    queue.fail(retry.id, 'error 2');
+
+    // Now should be in DLQ
+    expect(queue.getDeadLetterQueue()).toHaveLength(1);
+  });
+
+  it('should retain error information in DLQ', () => {
+    queue.add({ payload: 'fragile', maxRetries: 0, backoffDelay: 100 });
+    const task = queue.next()!;
+    queue.fail(task.id, 'fatal error');
+
+    const dlq = queue.getDeadLetterQueue();
+    expect(dlq[0].error).toBe('fatal error');
+  });
+
+  it('should track attempt count in DLQ', () => {
+    queue.add({ payload: 'fragile', maxRetries: 0, backoffDelay: 100 });
+    const task = queue.next()!;
+    queue.fail(task.id, 'err');
+
+    const dlq = queue.getDeadLetterQueue();
+    expect(dlq[0].attempts).toBe(1);
+  });
+
+  it('should support retrying a dead-lettered task', () => {
+    queue.add({ payload: 'retry-me', maxRetries: 0, backoffDelay: 100 });
+    const task = queue.next()!;
+    queue.fail(task.id, 'err');
+
+    expect(queue.getDeadLetterQueue()).toHaveLength(1);
+
+    const retried = queue.retryDeadLetter(task.id);
+    expect(retried.status).toBe('pending');
+    expect(retried.attempts).toBe(0);
+    expect(queue.getDeadLetterQueue()).toHaveLength(0);
+
+    // Should be available for processing again
+    const retrieved = queue.next();
+    expect(retrieved).toBeDefined();
+    expect(retrieved!.id).toBe(task.id);
+  });
+
+  it('should clear all dead-lettered tasks', () => {
+    queue.add({ payload: 'a', maxRetries: 0 });
+    queue.add({ payload: 'b', maxRetries: 0 });
+    queue.fail(queue.next()!.id, 'err');
+    queue.fail(queue.next()!.id, 'err');
+
+    expect(queue.getDeadLetterQueue()).toHaveLength(2);
+    queue.clearDeadLetterQueue();
+    expect(queue.getDeadLetterQueue()).toHaveLength(0);
+  });
+
+  it('should have independent DLQs per named queue', () => {
+    queue.add({ payload: 'a', queue: 'q1', maxRetries: 0 });
+    queue.add({ payload: 'b', queue: 'q2', maxRetries: 0 });
+    queue.fail(queue.next('q1')!.id, 'err');
+    queue.fail(queue.next('q2')!.id, 'err');
+
+    expect(queue.getDeadLetterQueue('q1')).toHaveLength(1);
+    expect(queue.getDeadLetterQueue('q2')).toHaveLength(1);
+    expect(queue.getDeadLetterQueue('q1')[0].payload).toBe('a');
+    expect(queue.getDeadLetterQueue('q2')[0].payload).toBe('b');
+  });
+});
