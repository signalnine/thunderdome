LQ\n    for (const [queueName, dlq] of this.deadLetterQueues.entries()) {\n      const index = dlq.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const task = dlq[index];\n        dlq.splice(index, 1);\n\n        // Reset for fresh retries\n        task.status = 'pending';\n        task.attempts = 0;\n        task.error = undefined;\n        task.availableAt = new Date();\n        task.progress = 0;\n        task.progressMessage = undefined;\n\n        this.ensureQueue(queueName);\n        return task;\n      }\n    }\n    throw new Error(`Task not found in any dead letter queue: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    this.deadLetterQueues.set(name, []);\n  }\n\n  // --- Phase 7: Task Dependencies ---\n\n  private areDependenciesMet(task: Task): boolean {\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  private checkDependents(_completedTaskId: string): void {\n    // Dependencies are checked at retrieval time via areDependenciesMet,\n    // so no explicit unblocking is needed. This method exists for clarity.\n  }\n\n  private detectCircularDeps(_newTaskId: string, dependencies: string[]): void {\n    // Since tasks can only depend on already-existing tasks, and IDs are generated\n    // at creation time, true circular dependencies are structurally impossible.\n    // However, we verify the dependency chain is valid (no loops among existing deps).\n    const visited = new Set<string>();\n    const stack = [...dependencies];\n\n    while (stack.length > 0) {\n      const depId = stack.pop()!;\n      if (visited.has(depId)) continue;\n      visited.add(depId);\n\n      const depTask = this.tasks.get(depId);\n      if (depTask) {\n        for (const transitiveDep of depTask.dependencies) {\n          stack.push(transitiveDep);\n        }\n      }\n    }\n  }\n\n  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    const pending: string[] = [];\n    let completed = 0;\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        completed++;\n      } else {\n        pending.push(depId);\n      }\n    }\n\n    return {\n      total: task.dependencies.length,\n      completed,\n      pending,\n    };\n  }\n\n  // --- Phase 8: Concurrency Control ---\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    this.ensureQueue(queueName);\n    const state = this.queues.get(queueName)!;\n    state.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): { limit: number | null; active: number } {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const state = this.queues.get(name);\n    if (!state) {\n      return { limit: null, active: 0 };\n    }\n    return { limit: state.concurrencyLimit, active: state.activeCount };\n  }\n\n  // --- Phase 9: Progress and Cancellation ---\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancel(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task ${taskId} cannot be cancelled (current: ${task.status})`);\n    }\n\n    const wasProcessing = task.status === 'processing';\n    task.status = 'cancelled';\n    // Ensure cancelled tasks cannot be retried\n    task.maxRetries = 0;\n\n    if (wasProcessing) {\n      this.decrementActive(task.queue);\n    }\n  }\n\n  // --- Phase 10: Recurring Tasks ---\n\n  addSchedule(options: {\n    cron: string;\n    queue?: string;\n    payload: unknown;\n  }): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Queue system is shutting down');\n    }\n\n    this.validateCron(options.cron);\n\n    const schedule: Schedule = {\n      id: randomUUID(),\n      cron: options.cron,\n      queue: options.queue ?? DEFAULT_QUEUE,\n      payload: options.payload,\n      active: true,\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    const schedule = this.schedules.get(scheduleId);\n    if (!schedule) {\n      throw new Error(`Schedule not found: ${scheduleId}`);\n    }\n    schedule.active = false;\n    this.schedules.delete(scheduleId);\n  }\n\n  listSchedules(): Schedule[] {\n    return Array.from(this.schedules.values()).filter(s => s.active);\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (!schedule.active) continue;\n\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.add({\n          payload: schedule.payload,\n          queue: schedule.queue,\n        });\n        created.push(task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return created;\n  }\n\n  private validateCron(expr: string): void {\n    const parts = expr.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${expr}. Must have exactly 5 fields.`);\n    }\n\n    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Validate minute field: number, *, or */N\n    if (!this.isValidCronField(minute, 0, 59)) {\n      throw new Error(`Invalid cron minute field: ${minute}`);\n    }\n    // Validate hour field\n    if (!this.isValidCronField(hour, 0, 23)) {\n      throw new Error(`Invalid cron hour field: ${hour}`);\n    }\n    // Remaining fields must be *\n    if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {\n      throw new Error(`Only *, */N, and numeric values are supported for minute/hour. Day/month/weekday must be *.`);\n    }\n  }\n\n  private isValidCronField(field: string, min: number, max: number): boolean {\n    if (field === '*') return true;\n    if (field.startsWith('*/')) {\n      const n = parseInt(field.slice(2), 10);\n      return !isNaN(n) && n >= 1 && n <= max;\n    }\n    const n = parseInt(field, 10);\n    return !isNaN(n) && n >= min && n <= max;\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cron.trim().split(/\\s+/);\n    const [minuteField, hourField] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    if (!this.matchesCronField(minuteField, currentMinute)) return false;\n    if (!this.matchesCronField(hourField, currentHour)) return false;\n\n    // Prevent duplicate runs in the same matching window\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  private matchesCronField(field: string, value: number): boolean {\n    if (field === '*') return true;\n    if (field.startsWith('*/')) {\n      const n = parseInt(field.slice(2), 10);\n      return value % n === 0;\n    }\n    return parseInt(field, 10) === value;\n  }\n\n  // --- Phase 11: Middleware Pipeline ---\n\n  use(queueName: string, middleware: Middleware): void {\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: TaskHandler): void {\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.handler = handler;\n  }\n\n  async process(taskId: string): Promise<void> {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n\n    const queueState = this.queues.get(task.queue);\n    const middlewares = queueState?.middlewares ?? [];\n    const handler = queueState?.handler ?? null;\n\n    const executeChain = async (index: number): Promise<void> => {\n      if (index < middlewares.length) {\n        await middlewares[index](task, () => executeChain(index + 1));\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    try {\n      const promise = executeChain(0);\n      this.processingPromises.set(taskId, promise);\n      await promise;\n    } catch (err) {\n      const errorMessage = err instanceof Error ? err.message : String(err);\n      this.fail(taskId, errorMessage);\n      return;\n    } finally {\n      this.processingPromises.delete(taskId);\n    }\n\n    // If still processing (middleware/handler didn't change status), mark complete\n    if (task.status === 'processing') {\n      this.complete(taskId);\n    }\n  }\n\n  // --- Phase 12: Graceful Shutdown ---\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout?: number): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(timeout ?? 30000);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(timeout: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Find all currently processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to complete, up to timeout\n    const waitForCompletion = new Promise<void>((resolve) => {\n      const checkInterval = setInterval(() => {\n        let allDone = true;\n        for