+import { describe, it, expect, beforeEach } from "vitest";
+import { DocumentStore } from "./index";
+
+describe("DocumentStore", () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe("Document CRUD", () => {
+    it("should create and get a document", () => {
+      store.create("doc1", { title: "Hello" });
+      expect(store.get("doc1")).toEqual({ title: "Hello" });
+    });
+
+    it("should throw when creating a document with an existing ID", () => {
+      store.create("doc1", { title: "Hello" });
+      expect(() => store.create("doc1", { title: "World" })).toThrow();
+    });
+
+    it("should throw when getting a non-existent document", () => {
+      expect(() => store.get("nonexistent")).toThrow();
+    });
+
+    it("should update a document", () => {
+      store.create("doc1", { title: "Hello" });
+      store.update("doc1", { title: "Updated" });
+      expect(store.get("doc1")).toEqual({ title: "Updated" });
+    });
+
+    it("should throw when updating a non-existent document", () => {
+      expect(() => store.update("nonexistent", { title: "x" })).toThrow();
+    });
+
+    it("should delete a document", () => {
+      store.create("doc1", { title: "Hello" });
+      store.delete("doc1");
+      expect(() => store.get("doc1")).toThrow();
+    });
+
+    it("should throw when deleting a non-existent document", () => {
+      expect(() => store.delete("nonexistent")).toThrow();
+    });
+
+    it("should throw when deleting an already deleted document", () => {
+      store.create("doc1", { title: "Hello" });
+      store.delete("doc1");
+      expect(() => store.delete("doc1")).toThrow();
+    });
+
+    it("should deep clone on create and get to prevent mutation", () => {
+      const content = { nested: { value: 1 } };
+      store.create("doc1", content);
+      content.nested.value = 999;
+      const retrieved = store.get("doc1") as { nested: { value: number } };
+      expect(retrieved.nested.value).toBe(1);
+      retrieved.nested.value = 888;
+      expect((store.get("doc1") as { nested: { value: number } }).nested.value).toBe(1);
+    });
+
+    it("should deep clone on update", () => {
+      store.create("doc1", { value: 1 });
+      const newContent = { value: 2 };
+      store.update("doc1", newContent);
+      newContent.value = 999;
+      expect((store.get("doc1") as { value: number }).value).toBe(2);
+    });
+
+    it("should allow re-creating a deleted document", () => {
+      store.create("doc1", { title: "First" });
+      store.delete("doc1");
+      store.create("doc1", { title: "Second" });
+      expect(store.get("doc1")).toEqual({ title: "Second" });
+    });
+  });
+
+  describe("Version History", () => {
+    it("should track versions on create", () => {
+      store.create("doc1", { title: "Hello" });
+      const history = store.getHistory("doc1");
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ title: "Hello" });
+      expect(history[0].id).toBeDefined();
+      expect(history[0].timestamp).toBeDefined();
+    });
+
+    it("should track versions on update", () => {
+      store.create("doc1", { title: "V1" });
+      store.update("doc1", { title: "V2" });
+      store.update("doc1", { title: "V3" });
+      const history = store.getHistory("doc1");
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ title: "V1" });
+      expect(history[1].content).toEqual({ title: "V2" });
+      expect(history[2].content).toEqual({ title: "V3" });
+    });
+
+    it("should return versions in chronological order", () => {
+      store.create("doc1", { v: 1 });
+      store.update("doc1", { v: 2 });
+      const history = store.getHistory("doc1");
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it("should get a specific version", () => {
+      store.create("doc1", { title: "V1" });
+      store.update("doc1", { title: "V2" });
+      const history = store.getHistory("doc1");
+      expect(store.getVersion("doc1", history[0].id)).toEqual({ title: "V1" });
+      expect(store.getVersion("doc1", history[1].id)).toEqual({ title: "V2" });
+    });
+
+    it("should throw for non-existent version", () => {
+      store.create("doc1", { title: "V1" });
+      expect(() => store.getVersion("doc1", "nonexistent")).toThrow();
+    });
+
+    it("should throw getHistory for non-existent document", () => {
+      expect(() => store.getHistory("nonexistent")).toThrow();
+    });
+
+    it("should deep clone version content", () => {
+      store.create("doc1", { nested: { value: 1 } });
+      const history = store.getHistory("doc1");
+      (history[0].content as { nested: { value: number } }).nested.value = 999;
+      expect(
+        (store.getHistory("doc1")[0].content as { nested: { value: number } }).nested.value
+      ).toBe(1);
+    });
+  });
+
+  describe("Branching", () => {
+    it("should default to main branch", () => {
+      expect(store.getBranch()).toBe("main");
+    });
+
+    it("should list branches", () => {
+      expect(store.listBranches()).toEqual(["main"]);
+    });
+
+    it("should create and switch branches", () => {
+      store.createBranch("feature");
+      expect(store.listBranches()).toContain("feature");
+      store.switchBranch("feature");
+      expect(store.getBranch()).toBe("feature");
+    });
+
+    it("should throw when creating a branch that already exists", () => {
+      store.createBranch("feature");
+      expect(() => store.createBranch("feature")).toThrow();
+    });
+
+    it("should throw when switching to a non-existent branch", () => {
+      expect(() => store.switchBranch("nonexistent")).toThrow();
+    });
+
+    it("should isolate changes between branches", () => {
+      store.create("doc1", { title: "Original" });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { title: "Feature change" });
+      expect(store.get("doc1")).toEqual({ title: "Feature change" });
+      store.switchBranch("main");
+      expect(store.get("doc1")).toEqual({ title: "Original" });
+    });
+
+    it("should copy documents when creating a branch", () => {
+      store.create("doc1", { title: "Hello" });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      expect(store.get("doc1")).toEqual({ title: "Hello" });
+    });
+
+    it("should create a branch from a specific branch", () => {
+      store.create("doc1", { title: "Main doc" });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { title: "Feature doc" });
+      store.switchBranch("main");
+      store.createBranch("from-feature", "feature");
+      store.switchBranch("from-feature");
+      expect(store.get("doc1")).toEqual({ title: "Feature doc" });
+    });
+
+    it("should isolate creates on branches", () => {
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.create("doc1", { title: "Feature only" });
+      store.switchBranch("main");
+      expect(() => store.get("doc1")).toThrow();
+    });
+
+    it("should isolate deletes on branches", () => {
+      store.create("doc1", { title: "Hello" });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.delete("doc1");
+      expect(() => store.get("doc1")).toThrow();
+      store.switchBranch("main");
+      expect(store.get("doc1")).toEqual({ title: "Hello" });
+    });
+  });
+
+  describe("Merging", () => {
+    it("should merge changes from source branch with no conflicts", () => {
+      store.create("doc1", { a: 1, b: 2 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { a: 1, b: 3 }); // change b
+      store.switchBranch("main");
+      const result = store.merge("feature");
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged["doc1"]).toEqual({ a: 1, b: 3 });
+      expect(store.get("doc1")).toEqual({ a: 1, b: 3 });
+    });
+
+    it("should merge when both branches change different fields", () => {
+      store.create("doc1", { a: 1, b: 2, c: 3 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { a: 1, b: 20, c: 3 }); // change b
+      store.switchBranch("main");
+      store.update("doc1", { a: 10, b: 2, c: 3 }); // change a
+      const result = store.merge("feature");
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged["doc1"]).toEqual({ a: 10, b: 20, c: 3 });
+      expect(store.get("doc1")).toEqual({ a: 10, b: 20, c: 3 });
+    });
+
+    it("should detect conflicts when both branches change the same field differently", () => {
+      store.create("doc1", { a: 1, b: 2 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { a: 1, b: 30 }); // change b to 30
+      store.switchBranch("main");
+      store.update("doc1", { a: 1, b: 20 }); // change b to 20
+      const result = store.merge("feature");
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe("doc1");
+      expect(result.conflicts[0].path).toBe("b");
+      expect(result.conflicts[0].base).toBe(2);
+      expect(result.conflicts[0].ours).toBe(20);
+      expect(result.conflicts[0].theirs).toBe(30);
+      // Current branch should be unchanged
+      expect(store.get("doc1")).toEqual({ a: 1, b: 20 });
+    });
+
+    it("should not conflict when both branches change a field to the same value", () => {
+      store.create("doc1", { a: 1, b: 2 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { a: 1, b: 42 }); // change b to 42
+      store.switchBranch("main");
+      store.update("doc1", { a: 1, b: 42 }); // also change b to 42
+      const result = store.merge("feature");
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged["doc1"]).toEqual({ a: 1, b: 42 });
+    });
+
+    it("should handle no-op merge (no changes on either branch)", () => {
+      store.create("doc1", { a: 1 });
+      store.createBranch("feature");
+      const result = store.merge("feature");
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it("should handle document created only on source branch", () => {
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.create("doc1", { title: "New doc" });
+      store.switchBranch("main");
+      const result = store.merge("feature");
+      expect(result.applied).toBe(true);
+      expect(result.merged["doc1"]).toEqual({ title: "New doc" });
+      expect(store.get("doc1")).toEqual({ title: "New doc" });
