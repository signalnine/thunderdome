1052→+    };\n  1053→+  }\n  1054→+\n  1055→+  /**\n  1056→+   * Find the common ancestor state between two branches.\n  1057→+   * The common ancestor is the state at the point where the branches diverged.\n  1058→+   */\n  1059→+  private findCommonAncestor(\n  1060→+    branchA: string,\n  1061→+    branchB: string\n  1062→+  ): Map<string, DocumentState> {\n  1063→+    // Build ancestry chains for both branches\n  1064→+    const ancestryA = this.getAncestryChain(branchA);\n  1065→+    const ancestryB = this.getAncestryChain(branchB);\n  1066→+\n  1067→+    // Find the first common ancestor\n  1068→+    for (const ancestor of ancestryA) {\n  1069→+      if (ancestryB.includes(ancestor)) {\n  1070→+        // The common ancestor is found.\n  1071→+        // The fork point is the snapshot at the time the more derived branch was created.\n  1072→+        // We need to find which branch was forked from the common ancestor path.\n  1073→+\n  1074→+        // If branchA was forked from a chain that includes the common ancestor,\n  1075→+        // find the fork point snapshot closest to the divergence.\n  1076→+        const forkPointA = this.getForkPointSnapshot(branchA, ancestor);\n  1077→+        const forkPointB = this.getForkPointSnapshot(branchB, ancestor);\n  1078→+\n  1079→+        // Use whichever fork point is available\n  1080→+        if (forkPointA) return forkPointA;\n  1081→+        if (forkPointB) return forkPointB;\n  1082→+\n  1083→+        // If neither has a fork point (e.g., both are main), return empty\n  1084→+        return new Map();\n  1085→+      }\n  1086→+    }\n  1087→+\n  1088→+    // No common ancestor found - return empty map\n  1089→+    return new Map();\n  1090→+  }\n  1091→+\n  1092→+  private getAncestryChain(branchName: string): string[] {\n  1093→+    const chain: string[] = [branchName];\n  1094→+    let current = this.branches.get(branchName);\n  1095→+    while (current?.parent) {\n  1096→+      chain.push(current.parent);\n  1097→+      current = this.branches.get(current.parent);\n  1098→+    }\n  1099→+    return chain;\n  1100→+  }\n  1101→+\n  1102→+  private getForkPointSnapshot(\n  1103→+    branchName: string,\n  1104→+    ancestorName: string\n  1105→+  ): Map<string, DocumentState> | null {\n  1106→+    // Walk from branchName up to ancestorName, collecting fork points\n  1107→+    let current = branchName;\n  1108→+    while (current !== ancestorName) {\n  1109→+      const branchData = this.branches.get(current);\n  1110→+      if (!branchData) return null;\n  1111→+      if (branchData.parent === ancestorName && branchData.forkPoint) {\n  1112→+        return cloneDocMap(branchData.forkPoint);\n  1113→+      }\n  1114→+      if (!branchData.parent) return null;\n  1115→+      current = branchData.parent;\n  1116→+    }\n  1117→+    return null;\n  1118→+  }\n  1119→+}\n  1120→diff --git a/tsconfig.json b/tsconfig.json\n  1121→index 87fcd6d..aada37c 100644\n  1122→--- a/tsconfig.json\n  1123→+++ b/tsconfig.json\n  1124→@@ -15,5 +15,5 @@\n  1125→     \"sourceMap\": true\n  1126→   },\n  1127→   \"include\": [\"src/**/*\"],\n  1128→-  \"exclude\": [\"node_modules\", \"dist\", \"tests\"]\n  1129→+  \"exclude\": [\"node_modules\", \"dist\", \"tests\", \"src/**/*.test.ts\"]\n  1130→ }"}]},"parent_tool_use_id":null,"session_id":"a72ba7b9-c0f2-4c31-a322-9d7dd340cea6","uuid":"85df6da0-078f-4928-9700-32ce050bb55d","tool_use_result":{"type":"text","file":{"filePath":"/tmp/.claude/projects/-workspace/a72ba7b9-c0f2-4c31-a322-9d7dd340cea6/tool-results/toolu_011PYsZF2opcjxQK5yqNnt5F.txt","content":"+    it(\"should throw when getting a non-existent document\", () => {\n+      expect(() => store.get(\"nonexistent\")).toThrow();\n+    });\n+\n+    it(\"should update a document\", () => {\n+      store.create(\"doc1\", { title: \"Hello\" });\n+      store.update(\"doc1\", { title: \"Updated\" });\n+      expect(store.get(\"doc1\")).toEqual({ title: \"Updated\" });\n+    });\n+\n+    it(\"should throw when updating a non-existent document\", () => {\n+      expect(() => store.update(\"nonexistent\", { title: \"x\" })).toThrow();\n+    });\n+\n+    it(\"should delete a document\", () => {\n+      store.create(\"doc1\", { title: \"Hello\" });\n+      store.delete(\"doc1\");\n+      expect(() => store.get(\"doc1\")).toThrow();\n+    });\n+\n+    it(\"should throw when deleting a non-existent document\", () => {\n+      expect(() => store.delete(\"nonexistent\")).toThrow();\n+    });\n+\n+    it(\"should throw when deleting an already deleted document\", () => {\n+      store.create(\"doc1\", { title: \"Hello\" });\n+      store.delete(\"doc1\");\n+      expect(() => store.delete(\"doc1\")).toThrow();\n+    });\n+\n+    it(\"should deep clone on create and get to prevent mutation\", () => {\n+      const content = { nested: { value: 1 } };\n+      store.create(\"doc1\", content);\n+      content.nested.value = 999;\n+      const retrieved = store.get(\"doc1\") as { nested: { value: number } };\n+      expect(retrieved.nested.value).toBe(1);\n+      retrieved.nested.value = 888;\n+      expect((store.get(\"doc1\") as { nested: { value: number } }).nested.value).toBe(1);\n+    });\n+\n+    it(\"should deep clone on update\", () => {\n+      store.create(\"doc1\", { value: 1 });\n+      const newContent = { value: 2 };\n+      store.update(\"doc1\", newContent);\n+      newContent.value = 999;\n+      expect((store.get(\"doc1\") as { value: number }).value).toBe(2);\n+    });\n+\n+    it(\"should allow re-creating a deleted document\", () => {\n+      store.create(\"doc1\", { title: \"First\" });\n+      store.delete(\"doc1\");\n+      store.create(\"doc1\", { title: \"Second\" });\n+      expect(store.get(\"doc1\")).toEqual({ title: \"Second\" });\n+    });\n+  });\n+\n+  describe(\"Version History\", () => {\n+    it(\"should track versions on create\", () => {\n+      store.create(\"doc1\", { title: \"Hello\" });\n+      const history = store.getHistory(\"