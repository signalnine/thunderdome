+++ b/src/index.ts
@@ -0,0 +1,618 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+interface DocumentState {
+  content: object;
+  deleted: boolean;
+  versions: Version[];
+}
+
+interface BranchData {
+  documents: Map<string, DocumentState>;
+  /** The snapshot of the parent branch's documents at the time this branch was created */
+  forkPoint: Map<string, DocumentState> | null;
+  /** The branch this was forked from */
+  parent: string | null;
+}
+
+let versionCounter = 0;
+
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function deepClone<T>(obj: T): T {
+  if (obj === null || obj === undefined || typeof obj !== "object") {
+    return obj;
+  }
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function cloneDocState(state: DocumentState): DocumentState {
+  return {
+    content: deepClone(state.content),
+    deleted: state.deleted,
+    versions: state.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+  };
+}
+
+function cloneDocMap(
+  map: Map<string, DocumentState>
+): Map<string, DocumentState> {
+  const result = new Map<string, DocumentState>();
+  for (const [key, value] of map) {
+    result.set(key, cloneDocState(value));
+  }
+  return result;
+}
+
+/**
+ * Collect all scalar leaf paths from an object.
+ * Returns a map of dot-separated paths to their values.
+ */
+function collectPaths(
+  obj: unknown,
+  prefix: string
+): Map<string, unknown> {
+  const result = new Map<string, unknown>();
+  if (obj === null || obj === undefined || typeof obj !== "object") {
+    result.set(prefix, obj);
+    return result;
+  }
+  if (Array.isArray(obj)) {
+    // Treat arrays as atomic values
+    result.set(prefix, obj);
+    return result;
+  }
+  const record = obj as Record<string, unknown>;
+  const keys = Object.keys(record);
+  if (keys.length === 0 && prefix !== "") {
+    result.set(prefix, obj);
+    return result;
+  }
+  for (const key of keys) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    const val = record[key];
+    if (val !== null && val !== undefined && typeof val === "object" && !Array.isArray(val)) {
+      const nested = collectPaths(val, path);
+      for (const [k, v] of nested) {
+        result.set(k, v);
+      }
+    } else {
+      result.set(path, val);
+    }
+  }
+  return result;
+}
+
+function valuesEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null || a === undefined || b === undefined) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== "object") return a === b;
+  return JSON.stringify(a) === JSON.stringify(b);
+}
+
+/**
+ * Set a value at a dot-separated path in an object, creating intermediate objects as needed.
+ */
+function setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {
+  const parts = path.split(".");
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (
+      current[part] === undefined ||
+      current[part] === null ||
+      typeof current[part] !== "object" ||
+      Array.isArray(current[part])
+    ) {
+      current[part] = {};
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+/**
+ * Delete a value at a dot-separated path in an object.
+ */
+function deleteAtPath(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split(".");
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (
+      current[part] === undefined ||
+      current[part] === null ||
+      typeof current[part] !== "object"
+    ) {
+      return;
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  delete current[parts[parts.length - 1]];
+}
+
+/**
+ * Three-way merge of two objects against a common base.
+ * Returns the merged object and any conflicts.
+ */
+function threeWayMerge(
+  base: object | null,
+  ours: object | null,
+  theirs: object | null,
+  documentId: string
+): { merged: object; conflicts: Conflict[] } {
+  const basePaths = collectPaths(base ?? {}, "");
+  const ourPaths = collectPaths(ours ?? {}, "");
+  const theirPaths = collectPaths(theirs ?? {}, "");
+
+  const allPaths = new Set<string>();
+  for (const k of basePaths.keys()) allPaths.add(k);
+  for (const k of ourPaths.keys()) allPaths.add(k);
+  for (const k of theirPaths.keys()) allPaths.add(k);
+
+  const conflicts: Conflict[] = [];
+  const merged: Record<string, unknown> = deepClone(ours ?? {}) as Record<string, unknown>;
+
+  for (const path of allPaths) {
+    const baseVal = basePaths.has(path) ? basePaths.get(path) : undefined;
+    const ourVal = ourPaths.has(path) ? ourPaths.get(path) : undefined;
+    const theirVal = theirPaths.has(path) ? theirPaths.get(path) : undefined;
+
+    const baseHas = basePaths.has(path);
+    const ourHas = ourPaths.has(path);
+    const theirHas = theirPaths.has(path);
+
+    const ourChanged = !baseHas && ourHas
+      ? true
+      : baseHas && !ourHas
+        ? true
+        : baseHas && ourHas
+          ? !valuesEqual(baseVal, ourVal)
+          : false;
+
+    const theirChanged = !baseHas && theirHas
+      ? true
+      : baseHas && !theirHas
+        ? true
+        : baseHas && theirHas
+          ? !valuesEqual(baseVal, theirVal)
+          : false;
+
+    if (!ourChanged && !theirChanged) {
+      // No changes from base on this path - keep as is
+      continue;
+    }
+
+    if (ourChanged && !theirChanged) {
+      // Only our side changed - already in merged (which starts from ours)
+      continue;
+    }
+
+    if (!ourChanged && theirChanged) {
+      // Only their side changed - apply their change
+      if (theirHas) {
+        setAtPath(merged, path, deepClone(theirVal));
+      } else {
+        deleteAtPath(merged, path);
+      }
+      continue;
+    }
+
+    // Both sides changed
+    if (valuesEqual(ourVal, theirVal) && ourHas === theirHas) {
+      // Both changed to the same thing - no conflict
+      continue;
+    }
+
+    // Conflict! merged keeps "ours" value (already there)
+    conflicts.push({
+      documentId,
+      path,
+      base: baseHas ? deepClone(baseVal) : undefined,
+      ours: ourHas ? deepClone(ourVal) : undefined,
+      theirs: theirHas ? deepClone(theirVal) : undefined,
+    });
+  }
+
+  return { merged, conflicts };
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = "main";
+
+  constructor() {
+    this.branches.set("main", {
+      documents: new Map(),
+      forkPoint: null,
+      parent: null,
+    });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branchName = name ?? this.currentBranch;
+    const branch = this.branches.get(branchName);
+    if (!branch) {
+      throw new Error(`Branch "${branchName}" does not exist`);
+    }
+    return branch;
+  }
+
+  // --- Document CRUD ---
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    if (existing && existing.deleted) {
+      // Re-creating a deleted document: start fresh versions
+      branch.documents.set(id, {
+        content: deepClone(content),
+        deleted: false,
+        versions: [version],
+      });
+    } else {
+      branch.documents.set(id, {
+        content: deepClone(content),
+        deleted: false,
+        versions: [version],
+      });
+    }
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+    doc.content = {};
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceBranchName = fromBranch ?? this.currentBranch;
+    const sourceBranch = this.getBranchData(sourceBranchName);
+
+    const clonedDocs = cloneDocMap(sourceBranch.documents);
+
+    this.branches.set(name, {
+      documents: clonedDocs,
+      forkPoint: cloneDocMap(sourceBranch.documents),
+      parent: sourceBranchName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  merge(sourceBranch: string): MergeResult {
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    const targetBranch = this.getBranchData();
+    const source = this.getBranchData(sourceBranch);
+
+    // Find the common ancestor: the fork point of the source branch
+    // We need to find where the two branches diverged.
+    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    // Collect all document IDs across base, ours (target), theirs (source)
+    const allDocIds = new Set<string>();
+    for (const k of base.keys()) allDocIds.add(k);
+    for (const k of targetBranch.documents.keys()) allDocIds.add(k);
+    for (const k of source.documents.keys()) allDocIds.add(k);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseDoc = base.get(docId);
+      const ourDoc = targetBranch.documents.get(docId);
+      const theirDoc = source.documents.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : null;
+      const ourContent = ourDoc && !ourDoc.deleted ? ourDoc.content : null;
+      const theirContent = theirDoc && !theirDoc.deleted ? theirDoc.content : null;
+
+      const baseExists = baseDoc ? !baseDoc.deleted : false;
+      const ourExists = ourDoc ? !ourDoc.deleted : false;
+      const theirExists = theirDoc ? !theirDoc.deleted : false;
+
+      // Determine if each side changed relative to base
+      const ourChanged = !valuesEqual(baseContent, ourContent) || baseExists !== ourExists;
+      const theirChanged = !valuesEqual(baseContent, theirContent) || baseExists !== theirExists;
+
+      if (!ourChanged && !theirChanged) {
+        // No changes - keep current state (fast-forward / no-op for this doc)
+        if (ourExists) {
+          merged[docId] = deepClone(ourContent!);
+        }
+        continue;
+      }
+
+      if (!ourChanged && theirChanged) {
+        // Only source changed - take theirs
+        if (theirExists) {
+          merged[docId] = deepClone(theirContent!);
+        }
+        // If they deleted it, it won't be in merged
+        continue;
+      }
+
+      if (ourChanged && !theirChanged) {
+        // Only target changed - keep ours
+        if (ourExists) {
+          merged[docId] = deepClone(ourContent!);
+        }
+        continue;
+      }
+
+      // Both changed - need three-way merge at field level
+      // Handle deletion cases
+      if (!ourExists && !theirExists) {
+        // Both deleted - no conflict, doc is gone
+        continue;
+      }
+
+      if (!ourExists && theirExists) {
+        // We deleted, they modified - conflict at document level
+        allConflicts.push({
+          documentId: docId,
+          path: "",
+          base: baseContent ? deepClone(baseContent) : undefined,
+          ours: undefined,
+          theirs: deepClone(theirContent!),
+        });
+        // "ours" wins for merged display: document stays deleted (not in merged)
+        continue;
+      }
+
+      if (ourExists && !theirExists) {
+        // We modified, they deleted - conflict at document level
+        allConflicts.push({
+          documentId: docId,
+          path: "",
+          base: baseContent ? deepClone(baseContent) : undefined,
+          ours: deepClone(ourContent!),
+          theirs: undefined,
+        });
+        // "ours" wins for merged display
+        merged[docId] = deepClone(ourContent!);
+        continue;
+      }
+
+      // Both exist and both changed - structural merge
+      const result = threeWayMerge(
+        baseContent,
+        ourContent,
+        theirContent,
+        docId
+      );
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existing = targetBranch.documents.get(docId);
+          const newContent = deepClone(merged[docId]);
+          if (existing && !existing.deleted) {
+            // Check if content actually changed
+            if (!valuesEqual(existing.content, newContent)) {
+              const version: Version = {
+                id: generateVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(newContent),
+              };
+              existing.content = newContent;
+              existing.versions.push(version);
+            }
+          } else {
+            // Document was created on the source branch, or re-created
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(newContent),
+            };
+            targetBranch.documents.set(docId, {
+              content: newContent,
+              deleted: false,
+              versions: [version],
+            });
+          }
+        } else {
+          // Document should be deleted (not in merged means it was removed)
+          const existing = targetBranch.documents.get(docId);
+          if (existing && !existing.deleted) {
+            existing.deleted = true;
+            existing.content = {};
+          }
+        }
+      }
+    }
+
+    return {
+      merged,
+      conflicts: allConflicts,
+      applied,
+    };
+  }
+
+  /**
+   * Find the common ancestor state between two branches.
+   * The common ancestor is the state at the point where the branches diverged.
+   */
+  private findCommonAncestor(
+    branchA: string,
+    branchB: string
+  ): Map<string, DocumentState> {
+    // Build ancestry chains for both branches
+    const ancestryA = this.getAncestryChain(branchA);
+    const ancestryB = this.getAncestryChain(branchB);
+
+    // Find the first common ancestor
+    for (const ancestor of ancestryA) {
+      if (ancestryB.includes(ancestor)) {
+        // The common ancestor is found.
+        // The fork point is the snapshot at the time the more derived branch was created.
+        // We need to find which branch was forked from the common ancestor path.
+
+        // If branchA was forked from a chain that includes the common ancestor,
+        // find the fork point snapshot closest to the divergence.
+        const forkPointA = this.getForkPointSnapshot(branchA, ancestor);
+        const forkPointB = this.getForkPointSnapshot(branchB, ancestor);
+
+        // Use whichever fork point is available
+        if (forkPointA) return forkPointA;
+        if (forkPointB) return forkPointB;
+
+        // If neither has a fork point (e.g., both are main), return empty
+        return new Map();
+      }
+    }
+
+    // No common ancestor found - return empty map
+    return new Map();
+  }
+
+  private getAncestryChain(branchName: string): string[] {
+    const chain: string[] = [branchName];
+    let current = this.branches.get(branchName);
+    while (current?.parent) {
+      chain.push(current.parent);
+      current = this.branches.get(current.parent);
+    }
+    return chain;
+  }
+
+  private getForkPointSnapshot(
+    branchName: string,
+    ancestorName: string
+  ): Map<string, DocumentState> | null {
+    // Walk from branchName up to ancestorName, collecting fork points
+    let current = branchName;
+    while (current !== ancestorName) {
+      const branchData = this.branches.get(current);
+      if (!branchData) return null;
+      if (branchData.parent === ancestorName && branchData.forkPoint) {
+        return cloneDocMap(branchData.forkPoint);
+      }
+      if (!branchData.parent) return null;
+      current = branchData.parent;
+    }
+    return null;
+  }
+}
