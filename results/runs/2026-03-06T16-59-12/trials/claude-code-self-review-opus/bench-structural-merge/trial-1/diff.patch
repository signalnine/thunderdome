ted.value = 999;\n+      expect(\n+        (store.getHistory(\"doc1\")[0].content as { nested: { value: number } }).nested.value\n+      ).toBe(1);\n+    });\n+  });\n+\n+  describe(\"Branching\", () => {\n+    it(\"should default to main branch\", () => {\n+      expect(store.getBranch()).toBe(\"main\");\n+    });\n+\n+    it(\"should list branches\", () => {\n+      expect(store.listBranches()).toEqual([\"main\"]);\n+    });\n+\n+    it(\"should create and switch branches\", () => {\n+      store.createBranch(\"feature\");\n+      expect(store.listBranches()).toContain(\"feature\");\n+      store.switchBranch(\"feature\");\n+      expect(store.getBranch()).toBe(\"feature\");\n+    });\n+\n+    it(\"should throw when creating a branch that already exists\", () => {\n+      store.createBranch(\"feature\");\n+      expect(() => store.createBranch(\"feature\")).toThrow();\n+    });\n+\n+    it(\"should throw when switching to a non-existent branch\", () => {\n+      expect(() => store.switchBranch(\"nonexistent\")).toThrow();\n+    });\n+\n+    it(\"should isolate changes between branches\", () => {\n+      store.create(\"doc1\", { title: \"Original\" });\n+      store.createBranch(\"feature\");\n+      store.switchBranch(\"feature\");\n+      store.update(\"doc1\", { title: \"Feature change\" });\n+      expect(store.get(\"doc1\")).toEqual({ title: \"Feature change\" });\n+      store.switchBranch(\"main\");\n+      expect(store.get(\"doc1\")).toEqual({ title: \"Original\" });\n+    });\n+\n+    it(\"should copy documents when creating a branch\", () => {\n+      store.create(\"doc1\", { title: \"Hello\" });\n+      store.createBranch(\"feature\");\n+      store.switchBranch(\"feature\");\n+      expect(store.get(\"doc1\")).toEqual({ title: \"Hello\" });\n+    });\n+\n+    it(\"should create a branch from a specific branch\", () => {\n+      store.create(\"doc1\", { title: \"Main doc\" });\n+      store.createBranch(\"feature\");\n+      store.switchBranch(\"feature\");\n+      store.update(\"doc1\", { title: \"Feature doc\" });\n+      store.switchBranch(\"main\");\n+      store.createBranch(\"from-feature\", \"feature\");\n+      store.switchBranch(\"from-feature\");\n+      expect(store.get(\"doc1\")).toEqual({ title: \"Feature doc\" });\n+    });\n+\n+    it(\"should isolate creates on branches\", () => {\n+      store.createBranch(\"feature\");\n+      store.switchBranch(\"feature\");\n+      store.create(\"doc1\", { title: \"Feature only\" });\n+      store.switchBranch(\"main\");\n+      expect(() => store.get(\"doc1\")).toThrow();\n+    });\n+\n+    it(\"should isolate deletes on branches\", () => {\n+      store.create(\"doc1\", { title: \"Hello\" });\n+      store.createBranch(\"feature\");\n+      store.switchBranch(\"feature\");\n+      store.delete(\"doc1\");\n+      expect(() => store.get(\"doc1\")).toThrow();\n+      store.switchBranch(\"main\");\n+      expect(store.get(\"doc1\")).toEqual({ title: \"Hello\" });\n+    });\n+  });\n+\n+  describe(\"Merging\", () => {\n+    it(\"should merge changes from source branch with no conflicts\", () => {\n+      store.create(\"doc1\", { a: 1, b: 2 });\n+      store.createBranch(\"feature\");\n+      store.switchBranch(\"feature\");\n+      store.update(\"doc1\", { a: 1, b: 3 }); // change b\n+      store.switchBranch(\"main\");\n+      const result = store.merge(\"feature\");\n+      expect(result.applied).toBe(true);\n+      expect(result.conflicts).toHaveLength(0);\n+      expect(result.merged[\"doc1\"]).toEqual({ a: 1, b: 3 });\n+      expect(store.get(\"doc1\")).toEqual({ a: 1, b: 3 });\n+    });\n+\n+    it(\"should merge when both branches change different fields\", () => {\n+      store.create(\"doc1\", { a: 1, b: 2, c: 3 });\n+      store.createBranch(\"feature\");\n+      store.switchBranch(\"feature\");\n+      store.update(\"doc1\", { a: 1, b: 20, c: 3 }); // change b\n+      store.switchBranch(\"main\");\n+      store.update(\"doc1\", { a: 10, b: 2, c: 3 }); //