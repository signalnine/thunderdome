e creates on branches\", () => {\n   245→+      store.createBranch(\"feature\");\n   246→+      store.switchBranch(\"feature\");\n   247→+      store.create(\"doc1\", { title: \"Feature only\" });\n   248→+      store.switchBranch(\"main\");\n   249→+      expect(() => store.get(\"doc1\")).toThrow();\n   250→+    });\n   251→+\n   252→+    it(\"should isolate deletes on branches\", () => {\n   253→+      store.create(\"doc1\", { title: \"Hello\" });\n   254→+      store.createBranch(\"feature\");\n   255→+      store.switchBranch(\"feature\");\n   256→+      store.delete(\"doc1\");\n   257→+      expect(() => store.get(\"doc1\")).toThrow();\n   258→+      store.switchBranch(\"main\");\n   259→+      expect(store.get(\"doc1\")).toEqual({ title: \"Hello\" });\n   260→+    });\n   261→+  });\n   262→+\n   263→+  describe(\"Merging\", () => {\n   264→+    it(\"should merge changes from source branch with no conflicts\", () => {\n   265→+      store.create(\"doc1\", { a: 1, b: 2 });\n   266→+      store.createBranch(\"feature\");\n   267→+      store.switchBranch(\"feature\");\n   268→+      store.update(\"doc1\", { a: 1, b: 3 }); // change b\n   269→+      store.switchBranch(\"main\");\n   270→+      const result = store.merge(\"feature\");\n   271→+      expect(result.applied).toBe(true);\n   272→+      expect(result.conflicts).toHaveLength(0);\n   273→+      expect(result.merged[\"doc1\"]).toEqual({ a: 1, b: 3 });\n   274→+      expect(store.get(\"doc1\")).toEqual({ a: 1, b: 3 });\n   275→+    });\n   276→+\n   277→+    it(\"should merge when both branches change different fields\", () => {\n   278→+      store.create(\"doc1\", { a: 1, b: 2, c: 3 });\n   279→+      store.createBranch(\"feature\");\n   280→+      store.switchBranch(\"feature\");\n   281→+      store.update(\"doc1\", { a: 1, b: 20, c: 3 }); // change b\n   282→+      store.switchBranch(\"main\");\n   283→+      store.update(\"doc1\", { a: 10, b: 2, c: 3 }); // change a\n   284→+      const result = stor