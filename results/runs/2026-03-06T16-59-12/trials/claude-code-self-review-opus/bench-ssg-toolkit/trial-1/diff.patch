aragraphLines.push(trimmed);\n+  }\n+  flushParagraph();\n+\n+  return result.join('\\n');\n+}\n+\n+function transformMarkdown(file: ContentFile, _ctx: BuildContext): ContentFile {\n+  let content = file.content;\n+\n+  if (!content || content.trim() === '') {\n+    return { ...file, content: content };\n+  }\n+\n+  // Process admonitions before markdown conversion\n+  content = processAdmonitions(content);\n+\n+  // Process footnotes\n+  const { content: contentWithRefs, footnotes } = processFootnotes(content);\n+  content = contentWithRefs;\n+\n+  // Check if content is already HTML (starts with an HTML tag)\n+  const isAlreadyHtml = /^\\s*</.test(content);\n+\n+  if (!isAlreadyHtml) {\n+    content = markdownToHtml(content);\n+  }\n+\n+  // Append footnote section\n+  content += buildFootnoteSection(footnotes);\n+\n+  return { ...file, content };\n+}\n+\n+export function createMarkdownExtPlugin(): Plugin {\n+  return {\n+    name: 'markdown-ext',\n+    version: '1.0.0',\n+    dependencies: [],\n+    hooks: {\n+      transformContent: transformMarkdown,\n+    },\n+  };\n+}\ndiff --git a/src/plugins/rss-feed.ts b/src/plugins/rss-feed.ts\nnew file mode 100644\nindex 0000000..f9952a5\n--- /dev/null\n+++ b/src/plugins/rss-feed.ts\n@@ -0,0 +1,75 @@\n+import { Plugin, BuildContext, ContentFile } from '../core/types.js';\n+\n+function escapeXml(str: string): string {\n+  return str\n+    .replace(/&/g, '&amp;')\n+    .replace(/</g, '&lt;')\n+    .replace(/>/g, '&gt;')\n+    .replace(/\"/g, '&quot;')\n+    .replace(/'/g, '&apos;');\n+}\n+\n+function generateRssFeed(ctx: BuildContext): void {\n+  const { config, files } = ctx;\n+  const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;\n+\n+  // Build a reverse lookup: slug -> tags\n+  const slugToTags = new Map<string, string[]>();\n+  if (tagMap) {\n+    for (const [tag, tagFiles] of tagMap) {\n+      for (const f of tagFiles) {\n+        const existing = slugToTags.get(f.slug) || [];\n+  