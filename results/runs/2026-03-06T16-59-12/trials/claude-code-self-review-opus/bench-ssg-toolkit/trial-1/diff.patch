--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,122 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(content: string): string {
+  return content.replace(
+    /^:::(note|warning|tip)\n([\s\S]*?)^:::/gm,
+    (_match, type: string, body: string) => {
+      return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+    }
+  );
+}
+
+function processFootnotes(content: string): { content: string; footnotes: Map<string, string> } {
+  const footnotes = new Map<string, string>();
+
+  // Extract footnote definitions: [^N]: text
+  const withoutDefs = content.replace(
+    /^\[\^(\d+)\]:\s*(.+)$/gm,
+    (_match, id: string, text: string) => {
+      footnotes.set(id, text);
+      return '';
+    }
+  );
+
+  // Replace inline footnote references: [^N] -> <sup><a href="#fn-N">N</a></sup>
+  const withRefs = withoutDefs.replace(
+    /\[\^(\d+)\]/g,
+    (_match, id: string) => `<sup><a href="#fn-${id}">${id}</a></sup>`
+  );
+
+  return { content: withRefs, footnotes };
+}
+
+function buildFootnoteSection(footnotes: Map<string, string>): string {
+  if (footnotes.size === 0) return '';
+  const items = Array.from(footnotes.entries())
+    .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+    .join('\n');
+  return `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+}
+
+function markdownToHtml(text: string): string {
+  // Process headings
+  let html = text.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Process bold and italic
+  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Process paragraphs - wrap non-empty lines that aren't already HTML block elements
+  const lines = html.split('\n');
+  const result: string[] = [];
+  let paragraphLines: string[] = [];
+
+  const flushParagraph = () => {
+    if (paragraphLines.length > 0) {
+      result.push(`<p>${paragraphLines.join(' ')}</p>`);
+      paragraphLines = [];
+    }
+  };
+
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (trimmed === '') {
+      flushParagraph();
+      continue;
+    }
+    // Check if this line is already an HTML block element
+    if (/^<(?:h[1-6]|div|section|ol|ul|li|p|pre|blockquote|table|hr|sup|a\s)/i.test(trimmed) ||
+        /^<\//.test(trimmed)) {
+      flushParagraph();
+      result.push(line);
+      continue;
+    }
+    paragraphLines.push(trimmed);
+  }
+  flushParagraph();
+
+  return result.join('\n');
+}
+
+function transformMarkdown(file: ContentFile, _ctx: BuildContext): ContentFile {
+  let content = file.content;
+
+  if (!content || content.trim() === '') {
+    return { ...file, content: content };
+  }
+
+  // Process admonitions before markdown conversion
+  content = processAdmonitions(content);
+
+  // Process footnotes
+  const { content: contentWithRefs, footnotes } = processFootnotes(content);
+  content = contentWithRefs;
+
+  // Check if content is already HTML (starts with an HTML tag)
+  const isAlreadyHtml = /^\s*</.test(content);
+
+  if (!isAlreadyHtml) {
+    content = markdownToHtml(content);
+  }
+
+  // Append footnote section
+  content += buildFootnoteSection(footnotes);
+
+  return { ...file, content };
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: transformMarkdown,
+    },
+  };
+}
