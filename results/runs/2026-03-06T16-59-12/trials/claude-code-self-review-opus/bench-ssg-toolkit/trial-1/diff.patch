\n\n  const rss = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>${escapeXml(config.title)}</title>\n    <link>${config.baseUrl}</link>\n    <description>${escapeXml(config.title)} RSS Feed</description>\n${items}\n  </channel>\n</rss>`;\n\n  ctx.output.set('feed.xml', rss);\n}\n\nexport function createRssFeedPlugin(): Plugin {\n  return {\n    name: 'rss-feed',\n    version: '1.0.0',\n    dependencies: ['markdown-ext', 'taxonomy'],\n    hooks: {\n      afterBuild: generateRssFeed,\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":348,"cache_read_input_tokens":40756,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":348},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8d72ee18-876f-4ac5-9b4e-e758f8087036","uuid":"57636156-c905-4372-8752-2c136b9a49f5"}
