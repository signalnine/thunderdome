ldContext) => Promise<ContentFile> | ContentFile;\n  afterBuild?: (ctx: BuildContext) => Promise<void> | void;\n}\n\nexport interface Plugin {\n  name: string;\n  version: string;\n  dependencies: string[];  // names of plugins this depends on\n  hooks: PluginHooks;\n}\n\nexport interface Template {\n  name: string;\n  render: (content: string, data: Record<string, unknown>) => string;\n}\n```\n\n#### **src/core/index.ts** - Exports\n\n```typescript\nexport { BuildEngine } from './engine.js';\nexport { createDefaultTemplate, createListTemplate } from './templates.js';\nexport type { BuildContext, ContentFile, Plugin, PluginHooks, SiteConfig, Template } from './types.js';\n```\n\n#### **src/core/engine.ts** - BuildEngine Class\n\n```typescript\nexport class BuildEngine {\n  private plugins: Plugin[] = [];\n  private templates: Map<string, Template> = new Map();\n\n  constructor(private config: SiteConfig) {}\n\n  // Registers a plugin\n  registerPlugin(plugin: Plugin): void\n\n  // Registers a template\n  registerTemplate(template: Template): void\n\n  // Topological sort - resolves plugin execution order\n  // Throws on circular dependency or missing dependency\n  resolvePluginOrder(): Plugin[]\n\n  // Main build method - orchestrates entire build process\n  async build(files: ContentFile[]): Promise<BuildContext> {\n    // 1. Creates BuildContext with input files\n    // 2. Gets ordered plugins via resolvePluginOrder()\n    // 3. Calls beforeBuild hooks in order\n    // 4. Calls transformContent hooks on each file in order\n    // 5. Renders files using templates\n    // 6. Calls afterBuild hooks in order\n    // 7. Returns final BuildContext\n  }\n\n  getPlugins(): Plugin[]\n  getTemplates(): Map<string, Template>\n}\n```\n\n#### **src/core/templates.ts** - Template Factories\n\n```typescript\n// Creates 'default' template - renders full article page\nexport function createDefaultTemplate(): Template {\n  // Returns template that renders:\n  // <!DOCTYPE html>\n  