+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function transformSyntax(file: ContentFile, _ctx: BuildContext): ContentFile {
+  // Match <pre><code class="language-xxx">...</code></pre> blocks
+  const newContent = file.content.replace(
+    /<pre>([\s\S]*?)<code class="language-(\w+)">([\s\S]*?)<\/code>([\s\S]*?)<\/pre>/g,
+    (_match, preBefore: string, lang: string, code: string, preAfter: string) => {
+      return `<pre data-language="${lang}">${preBefore}<code class="language-${lang} highlighted">${code}</code>${preAfter}</pre>`;
+    }
+  );
+
+  return { ...file, content: newContent };
+}
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: transformSyntax,
+    },
+  };
+}
