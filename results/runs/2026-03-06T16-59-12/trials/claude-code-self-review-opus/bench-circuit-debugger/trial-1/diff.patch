ecomes the MSB of z.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Helper: find a gate by op and inputs (order-independent)\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1))\n    );\n  }\n\n  // Helper: check if a wire name is an input wire (xNN or yNN)\n  function isInputWire(name: string): boolean {\n    return /^[xy]\\d{2}$/.test(name);\n  }\n\n  // Find the number of input bits by looking at x-wires in gates\n  let maxBit = 0;\n  for (const g of gates) {\n    const mx = g.in1.match(/^x(\\d+)$/);\n    const my = g.in2.match(/^x(\\d+)$/);\n    if (mx) maxBit = Math.max(maxBit, parseInt(mx[1]));\n    if (my) maxBit = Math.max(maxBit, parseInt(my[1]));\n  }\n  const numBits = maxBit + 1;\n\n  // Structural analysis approach:\n  // We verify the expected ripple-carry adder pattern and detect anomalies.\n\n  // Rule-based detection of swaps:\n  // 1. Any XOR gate with two x/y inputs must output either z00 or a non-z wire (partial sum)\n  // 2. Any XOR gate that outputs zNN (N>0) must have inputs that are NOT both x/y wires\n  // 3. Any non-XOR gate that outputs zNN (except the final carry z[numBits]) is wrong\n  // 4. OR gates should output carry wires, not z-wires\n  // 5. AND gates should not output z-wires\n  // 6. For XOR gates with x/y inputs, the output should feed into another XOR and an AND\n  // 7. For AND gates with x/y inputs (i>0), the output should feed into an OR\n  // 8. The final z wire (z[numBits]) should come from an OR gate (the last carry)\n\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  for (const g of gates) {\n    const