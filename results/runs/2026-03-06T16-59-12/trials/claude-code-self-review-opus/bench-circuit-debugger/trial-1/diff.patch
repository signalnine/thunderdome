+          const feedsAnd = consumers.some((c) => c.op === 'AND');
+          if (!feedsXor || !feedsAnd) {
+            swapped.add(g.out);
+          }
+        }
+      } else {
+        // Second-level XOR: internal inputs -> must output z
+        if (!zOut) {
+          swapped.add(g.out);
+        }
+      }
+    } else if (g.op === 'AND') {
+      // AND gates (except bit 0's) should feed into an OR gate
+      if (!(g.in1 === 'x00' && g.in2 === 'y00') &&
+          !(g.in1 === 'y00' && g.in2 === 'x00')) {
+        const consumers = getConsumers(g.out);
+        if (!consumers.some((c) => c.op === 'OR')) {
+          swapped.add(g.out);
+        }
+      }
+    } else if (g.op === 'OR') {
+      // OR gates produce carry wires
+      // Should NOT output z (except possibly lastZ)
+      if (zOut && g.out !== lastZ) {
+        swapped.add(g.out);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
