"update","filePath":"/workspace/src/index.ts","content":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a circuit of logic gates given initial wire values.\n * Returns the final value of every wire.\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  let changed = true;\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires (4 pairs) that have been swapped in a binary adder circuit.\n * Returns them sorted alphabetically.\n *\n * Uses structural pattern analysis of a ripple-carry adder:\n *\n * Bit 0 (half adder):\n *   x00 XOR y00 -> z00\n *   x00 AND y00 -> c00\n *\n * Bit i (i >= 1, full adder):\n *   xNN XOR yNN -> tNN          (partial sum via XOR of inputs)\n *   tNN XOR carry_in -> zNN     (final sum)\n *   xNN AND yNN -> aNN          (generate carry)\n *   tNN AND carry_in -> bNN     (propagate carry)\n *   aNN OR bNN -> cNN           (carry out)\n *\n * Last carry -> z[N+1]\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const wire of [g.in1, g.in2]) {\n      const m = wire.match(/^x(\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  // Build helper structures\n  function hasInputPair(g: Gate, a: string, b: string): boolean {\n    return (\n      (g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a)\n    );\n  }\n\n  function isInputWire(name: string): boolean {\n    return /^[xy]\\d{2}$/.test(name);\n  }\n\n  function inputsAreXY(g: Gate): boolean {\n    return isInputWire(g.in1) && isInputWire(g.in2);\n  }\n\n  function isZWire(name: string): boolean {\n    return /^z\\d{2}$/.test(name);\n  }\n\n  function findGateByOpAndInputs(\n    op: Gate['op'],\n    a: string,\n    b: string\n  ): Gate | undefined {\n    return gates.find((g) => g.op === op && hasInputPair(g, a, b));\n  }\n\n  function getConsumers(wire: string): Gate[] {\n    return gates.filter((g) => g.in1 === wire || g.in2 === wire);\n  }\n\n  // Structural rules for a ripple-carry adder:\n  //\n  // 1. All z-outputs (except lastZ) must come from XOR gates\n  // 2. XOR gates with x/y inputs (except bit 0) must NOT output z directly\n  // 3. XOR gates without x/y inputs must output z\n  // 4. AND gates (except bit 0's AND) must feed into an OR gate\n  // 5. OR gates must not output z (except lastZ)\n\n  for (const g of gates) {\n    const xy = inputsAreXY(g);\n    const zOut = isZWire(g.out);\n\n    // Rule 1: z-wires (except lastZ) must be produced by XOR gates\n    if (zOut && g.out !== lastZ && g.op !== 'XOR') {\n      swapped.add(g.out);\n    }\n\n    // Rule 2: XOR with x/y inputs should not output z (except z00)\n    if (g.op === 'XOR' && xy && zOut && g.out !== 'z00') {\n      swapped.add(g.out);\n    }\n\n    // Rule 3: XOR without x/y inputs must output z\n    if (g.op === 'XOR' && !xy && !zOut) {\n      swapped.add(g.out);\n    }\n\n    // Rule 4: AND (except bit 0) must feed into OR\n    if (g.op =