+      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: '' });
+      reviews.addReview({ pluginName: 'p3', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: '' });
+
+      const aliceReviews = reviews.getReviewsByUser('alice');
+      expect(aliceReviews).toHaveLength(2);
