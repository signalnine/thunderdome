new file mode 100644
index 0000000..d36199b
--- /dev/null
+++ b/src/deps/deps.test.ts
@@ -0,0 +1,179 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { DepsService, RegistryService, PluginManifest } from '../types.js';
+
+function makeManifest(
+  name: string,
+  deps: Record<string, string> = {},
+): PluginManifest {
+  return {
+    name,
+    version: '1.0.0',
+    description: `${name} plugin`,
+    author: 'test',
+    dependencies: deps,
+    entryPoint: '1 + 1',
+    permissions: [],
+  };
+}
+
+describe('DependencyGraph', () => {
+  let deps: DepsService;
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    deps = createDepsService();
+    registry = createRegistry();
+  });
+
+  describe('buildTree', () => {
+    it('should build a tree for a plugin with no dependencies', () => {
+      registry.register(makeManifest('root'));
+      const tree = deps.buildTree('root', registry);
+      expect(tree.name).toBe('root');
+      expect(tree.version).toBe('1.0.0');
+      expect(tree.dependencies).toEqual([]);
+    });
+
+    it('should build a tree with dependencies', () => {
+      registry.register(makeManifest('root', { child: '^1.0.0' }));
+      registry.register(makeManifest('child'));
+
+      const tree = deps.buildTree('root', registry);
+      expect(tree.name).toBe('root');
+      expect(tree.dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].name).toBe('child');
+    });
+
+    it('should build a deep dependency tree', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { c: '^1.0.0' }));
+      registry.register(makeManifest('c'));
+
+      const tree = deps.buildTree('a', registry);
+      expect(tree.dependencies[0].name).toBe('b');
+      expect(tree.dependencies[0].dependencies[0].name).toBe('c');
+    });
+
+    it('should handle unknown plugin gracefully', () => {
+      const tree = deps.buildTree('unknown', registry);
+      expect(tree.name).toBe('unknown');
+      expect(tree.version).toBe('unknown');
+    });
+  });
+
+  describe('detectCycles', () => {
+    it('should return null for acyclic graph', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b'));
+
+      expect(deps.detectCycles('a', registry)).toBeNull();
+    });
+
+    it('should detect simple cycle', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { a: '^1.0.0' }));
+
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles!.length).toBeGreaterThan(0);
+    });
+
+    it('should detect self-referencing cycle', () => {
+      registry.register(makeManifest('a', { a: '^1.0.0' }));
+
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+    });
+
+    it('should detect indirect cycle', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { c: '^1.0.0' }));
+      registry.register(makeManifest('c', { a: '^1.0.0' }));
+
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+    });
+  });
+
+  describe('hasCircularDependency', () => {
+    it('should return false for acyclic graph', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b'));
+
+      expect(deps.hasCircularDependency('a', registry)).toBe(false);
+    });
+
+    it('should return true for cyclic graph', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { a: '^1.0.0' }));
+
+      expect(deps.hasCircularDependency('a', registry)).toBe(true);
+    });
+  });
+
+  describe('topologicalSort', () => {
+    it('should return correct order for simple chain', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { c: '^1.0.0' }));
+      registry.register(makeManifest('c'));
+
+      const sorted = deps.topologicalSort('a', registry);
+      expect(sorted).toEqual(['c', 'b', 'a']);
+    });
+
+    it('should handle single node', () => {
+      registry.register(makeManifest('solo'));
+      const sorted = deps.topologicalSort('solo', registry);
+      expect(sorted).toEqual(['solo']);
+    });
+
+    it('should handle diamond dependency', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));
+      registry.register(makeManifest('b', { d: '^1.0.0' }));
+      registry.register(makeManifest('c', { d: '^1.0.0' }));
+      registry.register(makeManifest('d'));
+
+      const sorted = deps.topologicalSort('a', registry);
+      // d should come before b and c, and all before a
+      expect(sorted.indexOf('d')).toBeLessThan(sorted.indexOf('b'));
+      expect(sorted.indexOf('d')).toBeLessThan(sorted.indexOf('c'));
+      expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));
+      expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('a'));
+    });
+  });
+
+  describe('flattenDependencies', () => {
+    it('should return all transitive dependencies', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { c: '^1.0.0' }));
+      registry.register(makeManifest('c'));
+
+      const flat = deps.flattenDependencies('a', registry);
+      expect(flat).toContain('b');
+      expect(flat).toContain('c');
+      expect(flat).not.toContain('a');
+    });
+
+    it('should return empty array for plugin with no dependencies', () => {
+      registry.register(makeManifest('solo'));
+      const flat = deps.flattenDependencies('solo', registry);
+      expect(flat).toEqual([]);
+    });
+
+    it('should not have duplicates for diamond dependency', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));
+      registry.register(makeManifest('b', { d: '^1.0.0' }));
+      registry.register(makeManifest('c', { d: '^1.0.0' }));
+      registry.register(makeManifest('d'));
+
+      const flat = deps.flattenDependencies('a', registry);
+      const uniqueFlat = [...new Set(flat)];
+      expect(flat).toEqual(uniqueFlat);
+      expect(flat).toContain('b');
+      expect(flat).toContain('c');
+      expect(flat).toContain('d');
+    });
+  });
+});
