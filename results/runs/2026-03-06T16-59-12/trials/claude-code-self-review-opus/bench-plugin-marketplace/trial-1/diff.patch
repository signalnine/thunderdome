+  });
+
+  it('should search by author', () => {
+    registry.register(makeManifest({ name: 'plugin-a', author: 'alice' }));
+    registry.register(makeManifest({ name: 'plugin-b', author: 'bob' }));
+
+    const results = registry.search('alice');
+    expect(results).toHaveLength(1);
