+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KvDq5zR7939YXewFpQayr8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AbBBNRN97fh1BoKYqXW2Si","name":"Write","input":{"file_path":"/workspace/src/registry/registry.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { createRegistry } from './index.js';\nimport type { PluginManifest, RegistryService } from '../types.js';\n\nfunction makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {\n  return {\n    name: 'test-plugin',\n    version: '1.0.0',\n    description: 'A test plugin',\n    author: 'tester',\n    dependencies: {},\n    entryPoint: 'module.exports = 42;',\n    permissions: [],\n    ...overrides,\n  };\n}\n\ndescribe('PluginRegistry', () => {\n  let registry: RegistryService;\n\n  beforeEach(() => {\n    registry = createRegistry();\n  });\n\n  it('should register and retrieve a plugin', () => {\n    const manifest = makeManifest();\n    registry.register(manifest);\n\n    const result = registry.get('test-plugin');\n    expect(result).not.toBeNull();\n    expect(result!.name).toBe('test-plugin');\n    expect(result!.version).toBe('1.0.0');\n  });\n\n  it('should return null for unknown plugin', () => {\n    expect(registry.get('nonexistent')).toBeNull();\n  });\n\n  it('should register multiple versions of the same plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toEqual(['1.0.0', '2.0.0']);\n  });\n\n  it('should get specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    const v1 = registry.getVersion('test-plugin', '1.0.0');\n    expect(v1).not.toBeNull();\n    expect(v1!.version).toBe('1.0.0');\n\n    const v2 = registry.getVersion('test-plugin', '2.0.0');\n    expect(v2).not.toBeNull();\n    expect(v2!.version).toBe('2.0.0');\n  });\n\n  it('should return null for unknown version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();\n    expect(registry.getVersion('unknown', '1.0.0')).toBeNull();\n  });\n\n  it('should list all plugins', () => {\n    registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'plugin-b', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'plugin-a', version: '2.0.0' }));\n\n    const all = registry.list();\n    expect(all).toHaveLength(3);\n  });\n\n  it('should search by name', () => {\n    registry.register(makeManifest({ name: 'auth-plugin' }));\n    registry.register(makeManifest({ name: 'logging-plugin' }));\n\n    const results = registry.search('auth');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('auth-plugin');\n  });\n\n  it('should search by description', () => {\n    registry.register(makeManifest({ name: 'plugin-a', description: 'Handles authentication' }));\n    registry.register(makeManifest({ name: 'plugin-b', description: 'Handles logging' }));\n\n    const results = registry.search('authentication');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('plugin-a');\n  });\n\n  it('should search by author', () => {\n    registry.register(makeManifest({ name: 'plugin-a', author: 'alice' }));\n    registry.register(makeManifest({ name: 'plugin-b', author: 'bob' }));\n\n    const results = registry.search('alice');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should search case-insensitively', () => {\n    registry.register(makeManifest({ name: 'MyPlugin' }));\n\n    const results = registry.search('myplugin');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should remove a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    const removed = registry.remove('test-plugin', '1.0.0');\n    expect(removed).toBe(true);\n    expect(registry.listVersions('test-plugin')).toEqual(['2.0.0']);\n  });\n\n  it('should return false when removing nonexistent version', () => {\n    expect(registry.remove('unknown', '1.0.0')).toBe(false);\n  });\n\n  it('should update a plugin manifest', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n\n    const plugin = registry.getVersion('test-plugin', '1.0.0');\n    expect(plugin!.description).toBe('Updated description');\n  });\n\n  it('should throw when updating nonexistent plugin', () => {\n    expect(() => registry.update('unknown', '1.0.0', {})).toThrow();\n  });\n\n  it('should throw when updating nonexistent version', () => {\n    registry.register(makeManifest());\n    expect(() => registry.update('test-plugin', '9.9.9', {})).toThrow();\n  });\n\n  it('should return empty array for listVersions of unknown plugin', () => {\n    expect(registry.listVersions('unknown')).toEqual([]);\n  });\n\n  it('should return copies, not references', () => {\n    registry.register(makeManifest());\n    const a = registry.get('test-plugin');\n    const b = registry.get('test-plugin');\n    expect(a).toEqual(b);\n    a!.description = 'modified';\n    expect(registry.get('test-plugin')!.description).not.toBe('modified');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":381,"cache_read_input_tokens":26212,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":381},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"99e5c99f-d24b-4621-b02b-9e2be05c3d12","uuid":"cab67569-71c6-4e7b-ace4-4d3c33b47bf4"}
