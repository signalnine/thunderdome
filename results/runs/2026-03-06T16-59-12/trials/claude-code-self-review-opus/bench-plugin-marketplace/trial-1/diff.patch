@@ -0,0 +1,138 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeInner(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    if (visited.has(name)) {
+      // Circular — return leaf to prevent infinite recursion
+      return node;
+    }
+
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      node.dependencies.push(buildTreeInner(depName, registry, new Set(visited)));
+    }
+
+    return node;
+  }
+
+  function detectCyclesInner(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    allCycles: string[][],
+    visited: Set<string>,
+  ): void {
+    const idx = path.indexOf(name);
+    if (idx !== -1) {
+      // Found a cycle: extract the cycle portion
+      allCycles.push(path.slice(idx).concat(name));
+      return;
+    }
+
+    if (visited.has(name)) return;
+
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    path.push(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      detectCyclesInner(depName, registry, [...path], allCycles, visited);
+    }
+
+    visited.add(name);
+  }
+
+  function topoSortInner(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[],
+  ): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        topoSortInner(depName, registry, visited, result);
+      }
+    }
+
+    result.push(name);
+  }
+
+  function flattenInner(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[],
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!visited.has(depName)) {
+        visited.add(depName);
+        result.push(depName);
+        flattenInner(depName, registry, visited, result);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeInner(name, registry, new Set());
+    },
+
+    detectCycles(
+      name: string,
+      registry: RegistryService,
+    ): string[][] | null {
+      const cycles: string[][] = [];
+      detectCyclesInner(name, registry, [], cycles, new Set());
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      topoSortInner(name, registry, visited, result);
+      return result;
+    },
+
+    flattenDependencies(
+      name: string,
+      registry: RegistryService,
+    ): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      flattenInner(name, registry, visited, result);
+      return result;
+    },
+
+    hasCircularDependency(
+      name: string,
+      registry: RegistryService,
+    ): boolean {
+      const cycles = this.detectCycles(name, registry);
+      return cycles !== null;
+    },
+  };
+}
