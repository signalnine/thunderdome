t(results).toHaveLength(1);\n+    expect(results[0].name).toBe('plugin-a');\n+  });\n+\n+  it('should search by author', () => {\n+    registry.register(makeManifest({ name: 'plugin-a', author: 'alice' }));\n+    registry.register(makeManifest({ name: 'plugin-b', author: 'bob' }));\n+\n+    const results = registry.search('alice');\n+    expect(results).toHaveLength(1);\n+  });\n+\n+  it('should search case-insensitively', () => {\n+    registry.register(makeManifest({ name: 'MyPlugin' }));\n+\n+    const results = registry.search('myplugin');\n+    expect(results).toHaveLength(1);\n+  });\n+\n+  it('should remove a specific version', () => {\n+    registry.register(makeManifest({ version: '1.0.0' }));\n+    registry.register(makeManifest({ version: '2.0.0' }));\n+\n+    const removed = registry.remove('test-plugin', '1.0.0');\n+    expect(removed).toBe(true);\n+    expect(registry.listVersions('test-plugin')).toEqual(['2.0.0']);\n+  });\n+\n+  it('should return false when removing nonexistent version', () => {\n+    expect(registry.remove('unknown', '1.0.0')).toBe(false);\n+  });\n+\n+  it('should update a plugin manifest', () => {\n+    registry.register(makeManifest());\n+    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n+\n+    const plugin = registry.getVersion('test-plugin', '1.0.0');\n+    expect(plugin!.description).toBe('Updated description');\n+  });\n+\n+  it('should throw when updating nonexistent plugin', () => {\n+    expect(() => registry.update('unknown', '1.0.0', {})).toThrow();\n+  });\n+\n+  it('should throw when updating nonexistent version', () => {\n+    registry.register(makeManifest());\n+    expect(() => registry.update('test-plugin', '9.9.9', {})).toThrow();\n+  });\n+\n+  it('should return empty array for listVersions of unknown plugin', () => {\n+    expect(registry.listVersions('unknown')).toEqual([]);\n+  });\n+\n+  it('should return copies, not references', () => {\n+    registry.register(makeManifes