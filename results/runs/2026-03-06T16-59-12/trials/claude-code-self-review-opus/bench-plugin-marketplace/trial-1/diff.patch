',\n          userId: 'user1',\n          rating: 6,\n          comment: 'Too good',\n        }),\n      ).toThrow('Rating must be between 1 and 5');\n    });\n  });\n\n  describe('getReviews', () => {\n    it('should return reviews for a plugin', () => {\n      reviews.addReview({\n        pluginName: 'p1',\n        pluginVersion: '1.0.0',\n        userId: 'user1',\n        rating: 5,\n        comment: 'Great',\n      });\n      reviews.addReview({\n        pluginName: 'p2',\n        pluginVersion: '1.0.0',\n        userId: 'user1',\n        rating: 3,\n        comment: 'OK',\n      });\n      reviews.addReview({\n        pluginName: 'p1',\n        pluginVersion: '2.0.0',\n        userId: 'user2',\n        rating: 4,\n        comment: 'Good',\n      });\n\n      const p1Reviews = reviews.getReviews('p1');\n      expect(p1Reviews).toHaveLength(2);\n    });\n\n    it('should return empty array for plugin with no reviews', () => {\n      expect(reviews.getReviews('nonexistent')).toEqual([]);\n    });\n  });\n\n  describe('getAverageRating', () => {\n    it('should compute average rating', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u3', rating: 4, comment: '' });\n\n      expect(reviews.getAverageRating('p1')).toBe(4);\n    });\n\n    it('should return 0 for plugin with no reviews', () => {\n      expect(reviews.getAverageRating('nonexistent')).toBe(0);\n    });\n\n    it('should exclude flagged reviews from average', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n      reviews.flagReview(r1.id);\n\n      expect(reviews.getAverageRating('p1')).toBe(3);\n    });\n\n    it('should return 0 if all reviews are flagged', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.flagReview(r1.id);\n\n      expect(reviews.getAverageRating('p1')).toBe(0);\n    });\n  });\n\n  describe('flagReview', () => {\n    it('should flag a review', () => {\n      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.flagReview(r.id);\n\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].id).toBe(r.id);\n    });\n\n    it('should throw when flagging nonexistent review', () => {\n      expect(() => reviews.flagReview(999)).toThrow();\n    });\n  });\n\n  describe('getFlaggedReviews', () => {\n    it('should return only flagged reviews', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 5, comment: 'great' });\n      reviews.flagReview(r1.id);\n\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].comment).toBe('spam');\n    });\n  });\n\n  describe('removeReview', () => {\n    it('should remove a review', () => {\n      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      expect(reviews.removeReview(r.id)).toBe(true);\n      expect(reviews.getReviews('p1')).toHaveLength(0);\n    });\n\n    it('should return false for nonexistent review', () => {\n      expect(reviews.removeReview(999)).toBe(false);\n    });\n  });\n\n  describe('getReviewsByUser', () => {\n    it('should return reviews by a specific user', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', u