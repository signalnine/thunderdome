(\"写代码 🚀\");\n      expect(entry.task).toBe(\"写代码 🚀\");\n    });\n\n    it(\"should support emoji-only task names\", () => {\n      const entry = tracker.start(\"🎯🔥💻\");\n      expect(entry.task).toBe(\"🎯🔥💻\");\n    });\n  });\n\n  describe(\"stop\", () => {\n    it(\"should stop the running timer\", () => {\n      tracker.start(\"coding\");\n      const stopped = tracker.stop();\n      expect(stopped.task).toBe(\"coding\");\n      expect(stopped.end).not.toBeNull();\n    });\n\n    it(\"should throw when no timer is running\", () => {\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n\n    it(\"should throw when stopping after already stopped\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n  });\n\n  describe(\"getRunningEntry\", () => {\n    it(\"should return null when nothing is running\", () => {\n      expect(tracker.getRunningEntry()).toBeNull();\n    });\n\n    it(\"should return the running entry\", () => {\n      tracker.start(\"coding\");\n      const running = tracker.getRunningEntry();\n      expect(running).not.toBeNull();\n      expect(running!.task).toBe(\"coding\");\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should persist entries to disk\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const tracker2 = new TimeTracker({ filePath });\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"coding\");\n    });\n\n    it(\"should create parent directories automatically\", () => {\n      const deepPath = path.join(os.tmpdir(), `tt-test-${Date.now()}`, \"nested\", \"dir\", \"data.json\");\n      const t = new TimeTracker({ filePath: deepPath });\n      t.start(\"test\");\n      t.stop();\n      expect(fs.existsSync(deepPath)).toBe(true);\n\n      // cleanup\n      fs.rmSync(path.join(os.tmpdir(), `tt-test-${Date.now()}`), { recursive: true, force: true });\n    });\n\n    it(\"should handle corrupted file gracefully\", () => {\n      fs.writeFileSync(filePath, \"not valid json!!!\", \"utf-8\");\n      const t = new TimeTracker({ filePath });\n      expect(t.getEntries()).toHaveLength(0);\n    });\n\n    it(\"should persist unicode task names correctly\", () => {\n      tracker.start(\"café ☕ 日本語\");\n      tracker.stop();\n\n      const tracker2 = new TimeTracker({ filePath });\n      expect(tracker2.getEntries()[0].task).toBe(\"café ☕ 日本語\");\n    });\n  });\n\n  describe(\"getEntries\", () => {\n    it(\"should return empty array initially\", () => {\n      expect(tracker.getEntries()).toEqual([]);\n    });\n\n    it(\"should return a copy of entries\", () => {\n      tracker.start(\"coding\");\n      const entries = tracker.getEntries();\n      entries.pop();\n      expect(tracker.getEntries()).toHaveLength(1);\n    });\n  });\n\n  describe(\"getEntriesByDateRange\", () => {\n    it(\"should filter entries by date range\", () => {\n      // Manually create entries with known dates via persistence\n      const entries: TimeEntry[] = [\n        { task: \"task1\", start: \"2024-01-15T10:00:00.000Z\", end: \"2024-01-15T11:00:00.000Z\" },\n        { task: \"task2\", start: \"2024-02-15T10:00:00.000Z\", end: \"2024-02-15T11:00:00.000Z\" },\n        { task: \"task3\", start: \"2024-03-15T10:00:00.000Z\", end: \"2024-03-15T11:00:00.000Z\" },\n      ];\n      fs.writeFileSync(filePath, JSON.stringify(entries), \"utf-8\");\n      const t = new TimeTracker({ filePath });\n\n      const result = t.getEntriesByDateRange(\n        new Date(\"2024-02-01T00:00:00.000Z\"),\n        new Date(\"2024-02-28T23:59:59.999Z\")\n      );\n      expect(result).toHaveLength(1);\n      expect(result[0].task).toBe(\"task2\");\n    });\n\n    it(\"should return empty array when no entries match\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n      const result = tracker.getEntriesByDateRange(\n        new Date(\"2020-01-01\"),\n        new Date(\"2020-12-31\")\n      );\n      expect(result).toHaveLength(0);\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should return empty object when no entries\", () => {\n      expect(tracker.getSummary()).toEqual({});\n    });\n\n    it(\"should sum durations for same task name\", () => {\n      const entries: TimeEntry[] = [\n        { task: \"coding\", start: \"2024-01-01T10:00:00.000Z\", end: \"2024-01-01T11:00:00.000Z\" },\n        { task: \"coding\", start: \"2024-01-01T14:00:00.000Z\", end: \"2024-01-01T15:00:00.000Z\" },\n        { task: \"meeting\", start: \"2024-01-01T12:00:00.000Z\", end: \"2024-01-01T12:30:00.000Z\" },\n      ];\n      fs.writeFileSync(filePath, JSON.stringify(entries), \"utf-8\");\n      const t = new TimeTracker({ filePath });\n      const summary = t.getSummary();\n\n      expect(summary[\"coding\"]).toBe(2 * 60 * 60 * 1000); // 2 hours\n      expect(summary[\"meeting\"]).toBe(30 * 60 * 1000); // 30 minutes\n    });\n\n    it(\"should use current time for running tasks\", () => {\n      tracker.start(\"coding\");\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThan(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":146,"cache_read_input_tokens":21310,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":146},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"54ed9d16-e61e-4693-8764-3220c5a74113","uuid":"609102e2-31d3-4e9e-ba8d-2ae9a2fe192c"}
