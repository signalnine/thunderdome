diff --git a/src/tracker.ts b/src/tracker.ts
new file mode 100644
index 0000000..1dbfd93
--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,113 @@
+import fs from "node:fs";
+import path from "node:path";
+import type { TimeEntry, TimeTrackerOptions } from "./types.js";
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private readonly filePath: string;
+
+  constructor(options: TimeTrackerOptions) {
+    this.filePath = options.filePath;
+    this.load();
+  }
+
+  private load(): void {
+    try {
+      const data = fs.readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (Array.isArray(parsed)) {
+        this.entries = parsed as TimeEntry[];
+      }
+    } catch {
+      // File doesn't exist or is invalid — start fresh
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+
+  /**
+   * Start a new timer. If another timer is running, it will be stopped first.
+   */
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.end = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      end: null,
+    };
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+    running.end = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  /**
+   * Get the currently running entry, or null if none.
+   */
+  getRunningEntry(): TimeEntry | null {
+    return this.entries.find((e) => e.end === null) ?? null;
+  }
+
+  /**
+   * Get all entries.
+   */
+  getEntries(): TimeEntry[] {
+    return [...this.entries];
+  }
+
+  /**
+   * Get entries filtered by date range.
+   * Both `from` and `to` are inclusive. An entry is included if its start time
+   * falls within the range.
+   */
+  getEntriesByDateRange(from: Date, to: Date): TimeEntry[] {
+    const fromTime = from.getTime();
+    const toTime = to.getTime();
+    return this.entries.filter((e) => {
+      const startTime = new Date(e.start).getTime();
+      return startTime >= fromTime && startTime <= toTime;
+    });
+  }
+
+  /**
+   * Get a summary of total time (in milliseconds) per task name.
+   * Running tasks use the current time for duration calculation.
+   */
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    const now = new Date();
+    for (const entry of this.entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.end ? new Date(entry.end).getTime() : now.getTime();
+      const duration = end - start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+    return summary;
+  }
+}
