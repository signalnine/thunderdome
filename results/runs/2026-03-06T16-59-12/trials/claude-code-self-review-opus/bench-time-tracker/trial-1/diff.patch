w Date().toISOString();\n    this.save();\n    return running;\n  }\n\n  /**\n   * Get the currently running entry, or null if none.\n   */\n  getRunningEntry(): TimeEntry | null {\n    return this.entries.find((e) => e.end === null) ?? null;\n  }\n\n  /**\n   * Get all entries.\n   */\n  getEntries(): TimeEntry[] {\n    return [...this.entries];\n  }\n\n  /**\n   * Get entries filtered by date range.\n   * Both `from` and `to` are inclusive. An entry is included if its start time\n   * falls within the range.\n   */\n  getEntriesByDateRange(from: Date, to: Date): TimeEntry[] {\n    const fromTime = from.getTime();\n    const toTime = to.getTime();\n    return this.entries.filter((e) => {\n      const startTime = new Date(e.start).getTime();\n      return startTime >= fromTime && startTime <= toTime;\n    });\n  }\n\n  /**\n   * Get a summary of total time (in milliseconds) per task name.\n   * Running tasks use the current time for duration calculation.\n   */\n  getSummary(): Record<string, number> {\n    const summary: Record<string, number> = {};\n    const now = new Date();\n    for (const entry of this.entries) {\n      const start = new Date(entry.start).getTime();\n      const end = entry.end ? new Date(entry.end).getTime() : now.getTime();\n      const duration = end - start;\n      summary[entry.task] = (summary[entry.task] ?? 0) + duration;\n    }\n    return summary;\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":178,"cache_read_input_tokens":19494,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":178},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"54ed9d16-e61e-4693-8764-3220c5a74113","uuid":"b07008d6-98a0-4184-a5dc-cc75b88011a2"}
