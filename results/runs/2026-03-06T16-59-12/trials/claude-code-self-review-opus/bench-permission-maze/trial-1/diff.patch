--- /dev/null
+++ b/src/auth.ts
@@ -0,0 +1,91 @@
+import { Request, Response, NextFunction, Router } from 'express';
+import { Store, generateId } from './store.js';
+import crypto from 'crypto';
+
+export interface AuthRequest extends Request {
+  userId?: string;
+}
+
+export function authMiddleware(store: Store) {
+  return (req: AuthRequest, _res: Response, next: NextFunction) => {
+    const authHeader = req.headers.authorization;
+    if (authHeader && authHeader.startsWith('Bearer ')) {
+      const token = authHeader.slice(7);
+      for (const user of store.users.values()) {
+        if (user.token === token) {
+          req.userId = user.id;
+          break;
+        }
+      }
+    }
+    next();
+  };
+}
+
+export function requireAuth(req: AuthRequest, res: Response, next: NextFunction) {
+  if (!req.userId) {
+    res.status(401).json({ error: 'Authentication required' });
+    return;
+  }
+  next();
+}
+
+export function createAuthRouter(store: Store): Router {
+  const router = Router();
+
+  router.post('/register', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    if (typeof username !== 'string' || typeof password !== 'string') {
+      res.status(400).json({ error: 'Username and password must be strings' });
+      return;
+    }
+
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const user = { id, username, password, token: null };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  router.post('/login', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    let foundUser = null;
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        foundUser = user;
+        break;
+      }
+    }
+
+    if (!foundUser || foundUser.password !== password) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = crypto.randomBytes(32).toString('hex');
+    foundUser.token = token;
+
+    res.status(200).json({ token, userId: foundUser.id });
+  });
+
+  return router;
+}
diff --git a/src/documents.ts b/src/documents.ts
new file mode 100644
index 0000000..b782b13
--- /dev/null
+++ b/src/documents.ts
@@ -0,0 +1,161 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+import { getEffectiveRole, canRead, canEdit, canDelete } from './permissions.js';
+import { addActivity } from './activity.js';
+
+export function createDocumentRouter(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    if (!folderId) {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(String(folderId));
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Check user has at least editor access to the folder
+    const folderRole = getEffectiveRole(store, userId, 'folder', String(folderId));
+    if (!canEdit(folderRole)) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId: String(folderId),
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    addActivity(store, {
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', docId);
+    if (!canRead(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.status(200).json({ ...doc, role });
+  });
+
+  // Update document
+  router.put('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', docId);
+    if (!canEdit(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    if (title !== undefined) {
+      if (typeof title !== 'string' || title.length === 0) {
+        res.status(400).json({ error: 'Invalid document title' });
+        return;
+      }
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    addActivity(store, {
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: docId,
+    });
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', docId);
+    if (!canDelete(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Remove shares for this document
+    store.shares = store.shares.filter(
+      (s) => !(s.resourceType === 'document' && s.resourceId === docId)
+    );
+
+    store.documents.delete(docId);
+
+    addActivity(store, {
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: docId,
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
