 as 'folder' | 'document';\n\n    // Check user has access\n    const role = getEffectiveRole(store, userId, rtype, rid);\n    if (!role) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const shares = store.shares.filter(\n      (s) => s.resourceType === rtype && s.resourceId === rid\n    );\n\n    res.status(200).json(shares);\n  });\n\n  // Remove a share\n  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n    const userId = req.userId!;\n    const shareId = req.params.id;\n\n    const shareIndex = store.shares.findIndex((s) => s.id === shareId);\n    if (shareIndex < 0) {\n      res.status(404).json({ error: 'Share not found' });\n      return;\n    }\n\n    const share = store.shares[shareIndex];\n\n    // Check permissions - only owner can remove shares\n    const role = getEffectiveRole(store, userId, share.resourceType, share.resourceId);\n    if (!canManageRoles(role)) {\n      res.status(403).json({ error: 'Only owners can remove shares' });\n      return;\n    }\n\n    store.shares.splice(shareIndex, 1);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":545,"cache_read_input_tokens":25491,"cache_creation":{"ephemeral_5m_input_tokens":545,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"53285c5d-812c-468c-9025-1598714cc576","uuid":"89f92d23-482e-4733-86d3-fb438af7e8df"}
