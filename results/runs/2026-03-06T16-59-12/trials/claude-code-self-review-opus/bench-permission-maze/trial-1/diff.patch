new file mode 100644
index 0000000..72e9445
--- /dev/null
+++ b/src/folders.ts
@@ -0,0 +1,183 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+import { getEffectiveRole, canRead, canEdit, canDelete } from './permissions.js';
+
+export function createFolderRouter(store: Store): Router {
+  const router = Router();
+
+  // Create folder
+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // If parentId is provided, verify it exists and user has access
+    if (parentId !== undefined && parentId !== null) {
+      const parentFolder = store.folders.get(String(parentId));
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      const role = getEffectiveRole(store, userId, 'folder', String(parentId));
+      if (!canEdit(role)) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId ? String(parentId) : null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folderId);
+    if (!canRead(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get child folders and documents
+    const children: string[] = [];
+    for (const [, f] of store.folders) {
+      if (f.parentId === folderId) {
+        children.push(f.id);
+      }
+    }
+
+    const documents: string[] = [];
+    for (const [, d] of store.documents) {
+      if (d.folderId === folderId) {
+        documents.push(d.id);
+      }
+    }
+
+    res.status(200).json({ ...folder, children, documents, role });
+  });
+
+  // Update folder
+  router.put('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folderId);
+    if (!canEdit(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+    if (name !== undefined) {
+      if (typeof name !== 'string' || name.length === 0) {
+        res.status(400).json({ error: 'Invalid folder name' });
+        return;
+      }
+      folder.name = name;
+    }
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(String(parentId));
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular references
+        if (String(parentId) === folderId) {
+          res.status(400).json({ error: 'Folder cannot be its own parent' });
+          return;
+        }
+      }
+      folder.parentId = parentId ? String(parentId) : null;
+    }
+
+    res.status(200).json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folderId);
+    if (!canDelete(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete folder and all its contents recursively
+    deleteFolderRecursive(store, folderId);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string) {
+  // Collect child folder IDs first to avoid modifying map during iteration
+  const childFolderIds: string[] = [];
+  for (const [id, folder] of store.folders) {
+    if (folder.parentId === folderId) {
+      childFolderIds.push(id);
+    }
+  }
+  for (const childId of childFolderIds) {
+    deleteFolderRecursive(store, childId);
+  }
+
+  // Collect document IDs first to avoid modifying map during iteration
+  const docIds: string[] = [];
+  for (const [id, doc] of store.documents) {
+    if (doc.folderId === folderId) {
+      docIds.push(id);
+    }
+  }
+  for (const docId of docIds) {
+    store.documents.delete(docId);
+    store.shares = store.shares.filter(
+      (s) => !(s.resourceType === 'document' && s.resourceId === docId)
+    );
+  }
+
+  // Remove shares for this folder
+  store.shares = store.shares.filter(
+    (s) => !(s.resourceType === 'folder' && s.resourceId === folderId)
+  );
+
+  store.folders.delete(folderId);
+}
diff --git a/src/permissions.ts b/src/permissions.ts
new file mode 100644
index 0000000..4e1c4e2
--- /dev/null
+++ b/src/permissions.ts
@@ -0,0 +1,128 @@
+import { Store } from './store.js';
+import { Role } from './types.js';
+
+const ROLE_HIERARCHY: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function higherRole(a: Role, b: Role): Role {
+  return ROLE_HIERARCHY[a] >= ROLE_HIERARCHY[b] ? a : b;
+}
+
+/**
+ * Get effective role for a user on a resource.
+ * Checks direct shares and, for documents, folder-level shares.
+ * Also traverses parent folders for inherited permissions.
+ */
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check if user is the owner of the resource
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.ownerId === userId) {
+      return 'owner';
+    }
+  } else {
+    const doc = store.documents.get(resourceId);
+    if (doc && doc.ownerId === userId) {
+      return 'owner';
+    }
+  }
+
+  // Check direct shares on the resource
+  for (const share of store.shares) {
+    if (
+      share.resourceType === resourceType &&
+      share.resourceId === resourceId &&
+      share.userId === userId
+    ) {
+      bestRole = bestRole ? higherRole(bestRole, share.role) : share.role;
+    }
+  }
+
+  // For documents, also check folder-level shares (including parent folders)
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getFolderRole(store, userId, doc.folderId);
+      if (folderRole) {
+        bestRole = bestRole ? higherRole(bestRole, folderRole) : folderRole;
+      }
+    }
+  }
+
+  // For folders, also check parent folder shares
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getFolderRole(store, userId, folder.parentId);
+      if (parentRole) {
+        bestRole = bestRole ? higherRole(bestRole, parentRole) : parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+/**
+ * Get effective role on a folder, including inherited from parent folders.
+ */
+function getFolderRole(store: Store, userId: string, folderId: string): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check if user is the folder owner
+  const folder = store.folders.get(folderId);
+  if (folder && folder.ownerId === userId) {
+    return 'owner';
+  }
+
+  // Check direct shares on this folder
+  for (const share of store.shares) {
+    if (
+      share.resourceType === 'folder' &&
+      share.resourceId === folderId &&
+      share.userId === userId
+    ) {
+      bestRole = bestRole ? higherRole(bestRole, share.role) : share.role;
+    }
+  }
+
+  // Recurse up to parent folders
+  if (folder && folder.parentId) {
+    const parentRole = getFolderRole(store, userId, folder.parentId);
+    if (parentRole) {
+      bestRole = bestRole ? higherRole(bestRole, parentRole) : parentRole;
+    }
+  }
+
+  return bestRole;
+}
+
+export function canRead(role: Role | null): boolean {
+  return role !== null;
+}
+
+export function canEdit(role: Role | null): boolean {
+  return role === 'editor' || role === 'owner';
+}
+
+export function canDelete(role: Role | null): boolean {
+  return role === 'owner';
+}
+
+export function canShare(role: Role | null): boolean {
+  return role === 'editor' || role === 'owner';
+}
+
+export function canManageRoles(role: Role | null): boolean {
+  return role === 'owner';
+}
diff --git a/src/sharing.ts b/src/sharing.ts
new file mode 100644
index 0000000..a5b615f
--- /dev/null
+++ b/src/sharing.ts
@@ -0,0 +1,158 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+import { getEffectiveRole, canShare, canManageRoles } from './permissions.js';
+import { addActivity } from './activity.js';
+import { Role } from './types.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function createShareRouter(store: Store): Router {
+  const router = Router();
+
+  // Share a resource with a user
+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId, role } = req.body;
+
+    // Validate inputs
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'role must be viewer, editor, or owner' });
+      return;
+    }
+
+    // Verify the target user exists
+    const targetUser = store.users.get(String(targetUserId));
+    if (!targetUser) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Verify the resource exists
+    const rid = String(resourceId);
+    if (resourceType === 'folder') {
+      if (!store.folders.has(rid)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(rid)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check permissions
+    const effectiveRole = getEffectiveRole(store, userId, resourceType, rid);
+    if (!canShare(effectiveRole)) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    // Only owners can assign owner role
+    if (role === 'owner' && !canManageRoles(effectiveRole)) {
+      res.status(403).json({ error: 'Only owners can assign owner role' });
+      return;
+    }
+
+    // Check if there's already a share for this user on this resource
+    const existingShareIndex = store.shares.findIndex(
+      (s) =>
+        s.resourceType === resourceType &&
+        s.resourceId === rid &&
+        s.userId === String(targetUserId)
+    );
+
+    let share;
+    if (existingShareIndex >= 0) {
+      // Update existing share
+      store.shares[existingShareIndex].role = role;
+      share = store.shares[existingShareIndex];
+    } else {
+      // Create new share
+      const id = generateId(store);
+      share = {
+        id,
+        resourceType: resourceType as 'folder' | 'document',
+        resourceId: rid,
+        userId: String(targetUserId),
+        role: role as Role,
+      };
+      store.shares.push(share);
+    }
+
+    addActivity(store, {
+      action: 'shared',
+      userId,
+      resourceType: resourceType as 'folder' | 'document',
+      resourceId: rid,
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(200).json(share);
+  });
+
+  // Get shares for a resource
+  router.get('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.query;
+
+    if (!resourceType || !resourceId) {
+      res.status(400).json({ error: 'resourceType and resourceId are required' });
+      return;
+    }
+
+    const rid = String(resourceId);
+    const rtype = String(resourceType) as 'folder' | 'document';
+
+    // Check user has access
+    const role = getEffectiveRole(store, userId, rtype, rid);
+    if (!role) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const shares = store.shares.filter(
+      (s) => s.resourceType === rtype && s.resourceId === rid
+    );
+
+    res.status(200).json(shares);
+  });
+
+  // Remove a share
+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const shareId = req.params.id;
+
+    const shareIndex = store.shares.findIndex((s) => s.id === shareId);
+    if (shareIndex < 0) {
+      res.status(404).json({ error: 'Share not found' });
+      return;
+    }
+
+    const share = store.shares[shareIndex];
+
+    // Check permissions - only owner can remove shares
+    const role = getEffectiveRole(store, userId, share.resourceType, share.resourceId);
+    if (!canManageRoles(role)) {
+      res.status(403).json({ error: 'Only owners can remove shares' });
+      return;
+    }
+
+    store.shares.splice(shareIndex, 1);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
