pp.use(authMiddleware(store));\n  1108→+\n  1109→+  app.use('/auth', createAuthRouter(store));\n  1110→+  app.use('/folders', createFolderRouter(store));\n  1111→+  app.use('/documents', createDocumentRouter(store));\n  1112→+  app.use('/shares', createShareRouter(store));\n  1113→+  app.use('/activity', createActivityRouter(store));\n  1114→+\n  1115→+  return app;\n  1116→+}\n  1117→diff --git a/src/auth.ts b/src/auth.ts\n  1118→new file mode 100644\n  1119→index 0000000..62766a2\n  1120→--- /dev/null\n  1121→+++ b/src/auth.ts\n  1122→@@ -0,0 +1,91 @@\n  1123→+import { Request, Response, NextFunction, Router } from 'express';\n  1124→+import { Store, generateId } from './store.js';\n  1125→+import crypto from 'crypto';\n  1126→+\n  1127→+export interface AuthRequest extends Request {\n  1128→+  userId?: string;\n  1129→+}\n  1130→+\n  1131→+export function authMiddleware(store: Store) {\n  1132→+  return (req: AuthRequest, _res: Response, next: NextFunction) => {\n  1133→+    const authHeader = req.headers.authorization;\n  1134→+    if (authHeader && authHeader.startsWith('Bearer ')) {\n  1135→+      const token = authHeader.slice(7);\n  1136→+      for (const user of store.users.values()) {\n  1137→+        if (user.token === token) {\n  1138→+          req.userId = user.id;\n  1139→+          break;\n  1140→+        }\n  1141→+      }\n  1142→+    }\n  1143→+    next();\n  1144→+  };\n  1145→+}\n  1146→+\n  1147→+export function requireAuth(req: AuthRequest, res: Response, next: NextFunction) {\n  1148→+  if (!req.userId) {\n  1149→+    res.status(401).json({ error: 'Authentication required' });\n  1150→+    return;\n  1151→+  }\n  1152→+  next();\n  1153→+}\n  1154→+\n  1155→+export function createAuthRouter(store: Store): Router {\n  1156→+  const router = Router();\n  1157→+\n  1158→+  router.post('/register', (req: Request, res: Response) => {\n  1159→+    const { username, password } = req.body;\n  1160→+\n  1161→+    if (!username || !password) {\n  1162→+      res.status(400).json({ error: 'Username and password are required' });\n  1163→+      return;\n  1164→+    }\n  1165→+\n  1166→+    if (typeof username !== 'string' || typeof password !== 'string') {\n  1167→+      res.status(400).json({ error: 'Username and password must be strings' });\n  1168→+      return;\n  1169→+    }\n  1170→+\n  1171→+    for (const user of store.users.values()) {\n  1172→+      if (user.username === username) {\n  1173→+        res.status(409).json({ error: 'Username already exists' });\n  1174→+        return;\n  1175→+      }\n  1176→+    }\n  1177→+\n  1178→+    const id = generateId(store);\n  1179→+    const user = { id, username, password, token: null };\n  1180→+    store.users.set(id, user);\n  1181→+\n  1182→+    res.status(201).json({ id, username });\n  1183→+  });\n  1184→+\n  1185→+  router.post('/login', (req: Request, res: Response) => {\n  1186→+    const { username, password } = req.body;\n  1187→+\n  1188→+    if (!username || !password) {\n  1189→+      res.status(400).json({ error: 'Username and password are required' });\n  1190→+      return;\n  1191→+    }\n  1192→+\n  1193→+    let foundUser = null;\n  1194→+    for (const user of store.users.values()) {\n  1195→+      if (user.username === username) {\n  1196→+        foundUser = user;\n  1197→+        break;\n  1198→+      }\n  1199→+    }\n  1200→+\n  1201→+    if (!foundUser || foundUser.password !== password) {\n  1202→+      res.status(401).json({ error: 'Invalid credentials' });\n  1203→+      return;\n  1204→+    }\n  1205→+\n  1206→+    const token = crypto.randomBytes(32).toString('hex');\n  1207→+    foundUser.token = token;\n  1208→+\n  1209→+    res.status(200).json({ token, userId: foundUser.id });\n  1210→+  });\n  1211→+\n  1212→+  return router;\n  1213→+}\n  1214→diff --git a/src/documents.ts b/src/documents.ts\n  1215→new file mode 100644\n  1216→index 0000000..b782b13\n  1217→--- /dev/null\n  1218→+++ b/src/documents.ts\n  1219→@@ -0,0 +1,161 @@\n  1220→+import { Router, Response } from 'express';\n  1221→+import { Store, generateId } from './store.js';\n  1222→+import { AuthRequest, requireAuth } from './auth.js';\n  1223→+import { getEffectiveRole, canRead, canEdit, canDelete } from './permissions.js';\n  1224→+import { addActivity } from './activity.js';\n  1225→+\n  1226→+export function createDocumentRouter(store: Store): Router {\n  1227→+  const router = Router();\n  1228→+\n  1229→+  // Create document\n  1230→+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {\n  1231→+    const userId = req.userId!;\n  1232→+    const { title, content, folderId } = req.body;\n  1233→+\n  1234→+    if (!title || typeof title !== 'string') {\n  1235→+      res.status(400).json({ error: 'Document title is required' });\n  1236→+      return;\n  1237→+    }\n  1238→+\n  1239→+    if (content === undefined || content === null) {\n  1240→+      res.status(400).json({ error: 'Document content is required' });\n  1241→+      return;\n  1242→+    }\n  1243→+\n  1244→+    if (!folderId) {\n  1245→+      res.status(400).json({ error: 'Folder ID is required' });\n  1246→+      return;\n  1247→+    }\n  1248→+\n  1249→+    const folder = store.folders.get(String(folderId));\n  1250→+    if (!folder) {\n  1251→+      res.status(404).json({ error: 'Folder not found' });\n  1252→+      return;\n  1253→+    }\n  1254→+\n  1255→+    // Check user has at least editor access to the folder\n  1256→+    const folderRole = getEffectiveRole(store, userId, 'folder', String(folderId));\n  1257→+    if (!canEdit(folderRole)) {\n  1258→+      res.status(403).json({ error: 'Insufficient permissions on folder' });\n  1259→+      return;\n  1260→+    }\n  1261→+\n  1262→+    const id = generateId(store);\n  1263→+    const now = new Date().toISOString();\n  1264→+    const doc = {\n  1265→+      id,\n  1266→+      title,\n  1267→+      content: String(content),\n  1268→+      folderId: String(folderId),\n  1269→+      ownerId: userId,\n  1270→+      createdAt: now,\n  1271→+      updatedAt: now,\n  1272→+    };\n  1273→+    store.documents.set(id, doc);\n  1274→+\n  1275→+    addActivity(store, {\n  1276→+      action: 'document_created',\n  1277→+      userId,\n  1278→+      resourceType: 'document',\n  1279→+      resourceId: id,\n  1280→+    });\n  1281→+\n  1282→+    res.status(201).json(doc);\n  1283→+  });\n  1284→+\n  1285→+  // Get document\n  1286→+  router.get('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n  1287→+    const userId = req.userId!;\n  1288→+    const docId = req.params.id;\n  1289→+\n  1290→+    const doc = store.documents.get(docId);\n  1291→+    if (!doc) {\n  1292→+      res.status(404).json({ error: 'Document not found' });\n  1293→+      return;\n  1294→+    }\n  1295→+\n  1296→+    const role = getEffectiveRole(store, userId, 'document', docId);\n  1297→+    if (!canRead(role)) {\n  1298→+      res.status(403).json({ error: 'Insufficient permissions' });\n  1299→+      return;\n  1300→+    }\n  1301→+\n  1302→+    res.status(200).json({ ...doc, role });\n  1303→+  });\n  1304→+\n  1305→+  // Update document\n  1306→+  router.put('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n  1307→+    const userId = req.userId!;\n  1308→+    const docId = req.params.id;\n  1309→+\n  1310→+    const doc = store.documents.get(docId);\n  1311→+    if (!doc) {\n  1312→+      res.status(404).json({ error: 'Document not found' });\n  1313→+      return;\n  1314→+    }\n  1315→+\n  1316→+    const role = getEffectiveRole(store, userId, 'document', docId);\n  1317→+    if (!canEdit(role)) {\n  1318→+      res.status(403).json({ error: 'Insufficient permissions' });\n  1319→+      return;\n  1320→+    }\n  1321→+\n  1322→+    const { title, content } = req.body;\n  1323→+    if (title !== undefined) {\n  1324→+      if (typeof title !== 'string' || title.length === 0) {\n  1325→+        res.status(400).json({ error: 'Invalid document title' });\