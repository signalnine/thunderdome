rateId } from './store.js';\n  1389→+import { AuthRequest, requireAuth } from './auth.js';\n  1390→+import { getEffectiveRole, canRead, canEdit, canDelete } from './permissions.js';\n  1391→+\n  1392→+export function createFolderRouter(store: Store): Router {\n  1393→+  const router = Router();\n  1394→+\n  1395→+  // Create folder\n  1396→+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {\n  1397→+    const userId = req.userId!;\n  1398→+    const { name, parentId } = req.body;\n  1399→+\n  1400→+    if (!name || typeof name !== 'string') {\n  1401→+      res.status(400).json({ error: 'Folder name is required' });\n  1402→+      return;\n  1403→+    }\n  1404→+\n  1405→+    // If parentId is provided, verify it exists and user has access\n  1406→+    if (parentId !== undefined && parentId !== null) {\n  1407→+      const parentFolder = store.folders.get(String(parentId));\n  1408→+      if (!parentFolder) {\n  1409→+        res.status(404).json({ error: 'Parent folder not found' });\n  1410→+        return;\n  1411→+      }\n  1412→+      const role = getEffectiveRole(store, userId, 'folder', String(parentId));\n  1413→+      if (!canEdit(role)) {\n  1414→+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n  1415→+        return;\n  1416→+      }\n  1417→+    }\n  1418→+\n  1419→+    const id = generateId(store);\n  1420→+    const folder = {\n  1421→+      id,\n  1422→+      name,\n  1423→+      parentId: parentId ? String(parentId) : null,\n  1424→+      ownerId: userId,\n  1425→+      createdAt: new Date().toISOString(),\n  1426→+    };\n  1427→+    store.folders.set(id, folder);\n  1428→+\n  1429→+    res.status(201).json(folder);\n  1430→+  });\n  1431→+\n  1432→+  // Get folder\n  1433→+  router.get('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n  1434→+    const userId = req.userId!;\n  1435→+    const folderId = req.params.id;\n  1436→+\n  1437→+    const folder = store.folders.get(folderId);\n  1438→+    if (!folder) {\n  1439→+      res.status(404).json({ error: 'Folder not found' });\n  1440→+      return;\n  1441→+    }\n  1442→+\n  1443→+    const role = getEffectiveRole(store, userId, 'folder', folderId);\n  1444→+    if (!canRead(role)) {\n  1445→+      res.status(403).json({ error: 'Insufficient permissions' });\n  1446→+      return;\n  1447→+    }\n  1448→+\n  1449→+    // Get child folders and documents\n  1450→+    const children: string[] = [];\n  1451→+    for (const [, f] of store.folders) {\n  1452→+      if (f.parentId === folderId) {\n  1453→+        children.push(f.id);\n  1454→+      }\n  1455→+    }\n  1456→+\n  1457→+    const documents: string[] = [];\n  1458→+    for (const [, d] of store.documents) {\n  1459→+      if (d.folderId === folderId) {\n  1460→+        documents.push(d.id);\n  1461→+      }\n  1462→+    }\n  1463→+\n  1464→+    res.status(200).json({ ...folder, children, documents, role });\n  1465→+  });\n  1466→+\n  1467→+  // Update folder\n  1468→+  router.put('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n  1469→+    const userId = req.userId!;\n  1470→+    const folderId = req.params.id;\n  1471→+\n  1472→+    const folder = store.folders.get(folderId);\n  1473→+    if (!folder) {\n  1474→+      res.status(404).json({ error: 'Folder not found' });\n  1475→+      return;\n  1476→+    }\n  1477→+\n  1478→+    const role = getEffectiveRole(store, userId, 'folder', folderId);\n  1479→+    if (!canEdit(role)) {\n  1480→+      res.status(403).json({ error: 'Insufficient permissions' });\n  1481→+      return;\n  1482→+    }\n  1483→+\n  1484→+    const { name, parentId } = req.body;\n  1485→+    if (name !== undefined) {\n  1486→+      if (typeof name !== 'string' || name.length === 0) {\n  1487→+        res.status(400).json({ error: 'Invalid folder name' });\n  1488→+        return;\n  1489→+      }\n  1490→+      folder.name = name;\n  1491→+    }\n  1492→+    if (parentId !== undefined) {\n  1493→+      if (parentId !== null) {\n  1494→+        const parentFolder = store.folders.get(String(parentId));\n  1495→+        if (!parentFolder) {\n  1496→+          res.status(404).json({ error: 'Parent folder not found' });\n  1497→+          return;\n  1498→+        }\n  1499→+        // Prevent circular references\n  1500→+        if (String(parentId) === folderId) {\n  1501→+          res.status(400).json({ error: 'Folder cannot be its own parent' });\n  1502→+          return;\n  1503→+        }\n  1504→+      }\n  1505→+      folder.parentId = parentId ? String(parentId) : null;\n  1506→+    }\n  1507→+\n  1508→+    res.status(200).json(folder);\n  1509→+  });\n  1510→+\n  1511→+  // Delete folder\n  1512→+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n  1513→+    const userId = req.userId!;\n  1514→+    const folderId = req.params.id;\n  1515→+\n  1516→+    const folder = store.folders.get(folderId);\n  1517→+    if (!folder) {\n  1518→+      res.status(404).json({ error: 'Folder not found' });\n  1519→+      return;\n  1520→+    }\n  1521→+\n  1522→+    const role = getEffectiveRole(store, userId, 'folder', folderId);\n  1523→+    if (!canDelete(role)) {\n  1524→+      res.status(403).json({ error: 'Insufficient permissions' });\n  1525→+      return;\n  1526→+    }\n  1527→+\n  1528→+    // Delete folder and all its contents recursively\n  1529→+    deleteFolderRecursive(store, folderId);\n  1530→+\n  1531→+    res.status(204).send();\n  1532→+  });\n  1533→+\n  1534→+  return router;\n  1535→+}\n  1536→+\n  1537→+function deleteFolderRecursive(store: Store, folderId: string) {\n  1538→+  // Delete child folders\n  1539→+  for (const [id, folder] of store.folders) {\n  1540→+    if (folder.parentId === folderId) {\n  1541→+      deleteFolderRecursive(store, id);\n  1542→+    }\n  1543→+  }\n  1544→+\n  1545→+  // Delete documents in this folder\n  1546→+  for (const [id, doc] of store.documents) {\n  1547→+    if (doc.folderId === folderId) {\n  1548→+      store.documents.delete(id);\n  1549→+      // Remove shares for this document\n  1550→+      store.shares = store.shares.filter(\n  1551→+        (s) => !(s.resourceType === 'document' && s.resourceId === id)\n  1552→+      );\n  1553→+    }\n  1554→+  }\n  1555→+\n  1556→+  // Remove shares for this folder\n  1557→+  store.shares = store.shares.filter(\n  1558→+    (s) => !(s.resourceType === 'folder' && s.resourceId === folderId)\n  1559→+  );\n  1560→+\n  1561→+  store.folders.delete(folderId);\n  1562→+}\n  1563→diff --git a/src/permissions.ts b/src/permissions.ts\n  1564→new file mode 100644\n  1565→index 0000000..4e1c4e2\n  1566→--- /dev/null\n  1567→+++ b/src/permissions.ts\n  1568→@@ -0,0 +1,128 @@\n  1569→+import { Store } from './store.js';\n  1570→+import { Role } from './types.js';\n  1571→+\n  1572→+const ROLE_HIERARCHY: Record<Role, number> = {\n  1573→+  viewer: 1,\n  1574→+  editor: 2,\n  1575→+  owner: 3,\n  1576→+};\n  1577→+\n  1578→+export function higherRole(a: Role, b: Role): Role {\n  1579→+  return ROLE_HIERARCHY[a] >= ROLE_HIERARCHY[b] ? a : b;\n  1580→+}\n  1581→+\n  1582→+/**\n  1583→+ * Get effective role for a user on a resource.\n  1584→+ * Checks direct shares and, for documents, folder-level shares.\n  1585→+ * Also traverses parent folders for inherited permissions.\n  1586→+ */\n  1587→+export function getEffectiveRole(\n  1588→+  store: Store,\n  1589→+  userId: string,\n  1590→+  resourceType: 'folder' | 'document',\n  1591→+  resourceId: string\n  1592→+): Role | null {\n  1593→+  let bestRole: Role | null = null;\n  1594→+\n  1595→+  // Check if user is the owner of the resource\n  1596→+  if (resourceType === 'folder') {\n  1597→+    const folder = store.folders.get(resourceId);\n  1598→+    if (folder && folder.ownerId === userId) {\n  1599→+      return 'owner';\n  1600→+    }\n  1601→+  } else {\n  1602→+    const doc = store.documents.get(resourceId);\n  1603→+    if (doc && doc.ownerId === userId) {\n  1604→+      return 'owner';\n  1605→+    }\n  1606→+  }\n  1607→+\n  1608→+  // Check direct shares on the resource\n  1609→+  for (const share of store.shares) {\n  1610→+    if (\n  1611→+      share.resourceType === resourceType &&\n  1612→+      share.resourceId === resourceId &&\n  1613→+      share.userId === userId\n  1614→+    ) {\n  1615→+      bestRole = bestRole ? higherRole(bestRole, share.role) : share.role;\n  1616→+    }\n  1617→+  }\n  1618→+\n  1619→+  // For documents, also check folder-level shares (including parent folders)\n  1620→+  if (resourceType === 'document') {\n  1621→+    const doc = store.documents.get(resourceId);\n  1622→+    if (doc) {\n  1623→+      const folderRole = getFolderRole(store, userId, doc.folderId);\n  1624→+      if (folderRole) {\n  1625→+        bestRole = bestRole ? higherRole(bestRole, folderRole) : folderRole;\n  1626→+      }\n  1627→+    }\n  1628→+  }\n  1629→+\n  1630→+  // For folders, also check parent folder shares\n  1631→+  if (resourceType === 'folder') {\n  1632→+    const folder = store.folders.get(resourceId);\n  1633→+    if (folder && folder.parentId) {\n  1634→+      const parentRole = getFolderRole(store, userId, folder.parentId);\n  1635→+      if (parentRole) {\n  1636→+        bestRole = bestRole ? higherRole(bestRole, parentRole) : parentRole;\n  1637→+      }\n  1638→+    }\n  1639→+  }\n  1640→+\n  1641→+  return bestRole;\n  1642→+}\n  1643→+\n  1644→+/**\n  1645→+ * Get effective role on a folder, including inherited from parent folders.\n  1646→+ */\n  1647→+function getFolderRole(store: Store, userId: string, folderId: string): Role | null {\n  1648→+  let bestRole: Role | null = null;\n  1649→+\n  1650→+  // Check if user is the folder owner\n  1651→+  const folder = store.folders.get(folderId);\n  1652→+  if (folder && folder.ownerId === userId) {\n  1653→+    return 'owner';\n  1654→+  }\n  1655→+\n  1656→+  // Check direct shares on this folder\n  1657→+  for (const share of store.shares) {\n  1658→+    if (\n  1659→+      share.resourceType === 'folder' &&\n  1660→+      share.resourceId === folderId &&\n  1661→+      share.userId === userId\n  1662→+    ) {\n  1663→+      bestRole = bestRole ? higherRole(bestRole, share.role) : share.role;\n  1664→+    }\n  1665→+  }\n  1666→+\n  1667→+  // Recurse up to parent folders\n  1668→+  if (folder && folder.parentId) {\n  1669→+    const parentRole = getFolderRole(store, userId, folder.parentId);\n  1670→+    if (parentRole) {\n  1671→+      bestRole = bestRole ? higherRole(bestRole, parentRole) : parentRole;\n  1672→+    }\n  1673→+  }\n  1674→+\n  1675→+  return bestRole;\n  1676→+}\n  1677→+\n  1678→+export function canRead(role: Role | null): boolean {\n  1679→+  return role !== null;\n  1680→+}\n  1681→+\n  1682→+export function canEdit(role: Role | null): boolean {\n  1683→+  return role === 'editor' || role === 'owner';\n  1684→+}\n  1685→+\n  1686→+export function canDelete(role: Role | null): boolean {\n  1687→+  return role === 'owner';\n  1688→+}\n  1689→+\n  1690→+export function canShare(role: Role | null): boolean {\n  1691→+  return role === 'editor' || role === 'owner';\n  1692→+}\n  1693→+\n  1694→+export function canManageRoles(role: Role | null): boolean {\n  1695→+  return role === 'owner';\n  1696→+}\n  1697→diff --git a/src/sharing.ts b/src/sharing.ts\n  1698→new file mode 100644\n  1699→index 0000000..a5b615f\n  1700→--- /dev/null\n  1701→+++ b/src/sharing.ts\n  1702→@@ -0,0 +1,158 @@\n  1703→+import { Router, Response } from 'express';\n  1704→+import { Store, generateId } from './store.js';\n  1705→+import { AuthRequest, requireAuth } from './auth.js';\n  1706→+import { getEffectiveRole, canShare, canManageRoles } from './permissions.js';\n  1707→+import { addActivity } from './activity.js';\n  1708→+import { Role } from './types.js';\n  1709→+\n  1710→+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];\n  1711→+\n  1712→+export function createShareRouter(store: Store): Router {\n  1713→+  const router = Router();\n  1714→+\n  1715→+  // Share a resource with a user\n  1716→+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {\n  1717→+    const userId = req.userId!;\n  1718→+    const { resourceType, resourceId, targetUserId, role } = req.body;\n  1719→+\n  1720→+    // Validate inputs\n  1721→+    if (!resourceType || !resourceId || !targetUserId || !role) {\n  1722→+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });\n  1723→+      return;\n  1724→+    }\n  1725→+\n  1726→+    if (resourceType !== 'folder' && resourceType !== 'document') {\n  1727→+      res.status(400).json({ error: 'resourceType must be folder or document' });\n  1728→+      return;\n  1729→+    }\n  1730→+\n  1731→+    if (!VALID_ROLES.includes(role)) {\n  1732→+      res.status(400).json({ error: 'role must be viewer, editor, or owner' });\n  1733→+      return;\n  1734→+    }\n  1735→+\n  1736→+    // Verify the target user exists\n  1737→+    const targetUser = store.users.get(String(targetUserId));\n  1738→+    if (!targetUser) {\n  1739→+      res.status(404).json({ error: 'Target user not found' });\n  1740→+      return;\n  1741→+    }\n  1742→+\n  1743→+    // Verify the resource exists\n  1744→+    const rid = String(resourceId);\n  1745→+    if (resourceType === 'folder') {\n  1746→+      if (!store.folders.has(rid)) {\n  1747→+        res.status(404).json({ error: 'Folder not found' });\n  1748→+        return;\n  1749→+      }\n  1750→+    } else {\n  1751→+      if (!store.documents.has(rid)) {\n  1752→+        res.status(404).json({ error: 'Document not found' });\n  1753→+        return;\n  1754→+      }\n  1755→+    }\n  1756→+\n  1757→+    // Check permissions\n  1758→+    const effectiveRole = getEffectiveRole(store, userId, resourceType, rid);\n  1759→+    if (!canShare(effectiveRole)) {\n  1760→+      res.status(403).json({ error: 'Insufficient permissions to share' });\n  1761→+      return;\n  1762→+    }\n  1763→+\n  1764→+    // Only owners can assign owner role\n  1765→+    if (role === 'owner' && !canManageRoles(effectiveRole)) {\n  1766→+      res.status(403).json({ error: 'Only owners can assign owner role' });\n  1767→+      return;\n  1768→+    }\n  1769→+\n  1770→+    // Check if there's already a share for this user on this resource\n  1771→+    const existingShareIndex = store.shares.findIndex(\n  1772→+      (s) =>\n  1773→+        s.resourceType === resourceType &&\n  1774→+        s.resourceId === rid &&\n  1775→+        s.userId === String(targetUserId)\n  1776→+    );\n  1777→+\n  1778→+    let share;\n  1779→+    if (existingShareIndex >= 0) {\n  1780→+      // Update existing share\n  1781→+      store.shares[existingShareIndex].role = role;\n  1782→+      share = store.shares[existingShareIndex];\n  1783→+    } else {\n  1784→+      // Create new share\n  1785→+      const id = generateId(store);\n  1786→+      share = {\n  1787→+        id,\n  1788→+        resourceType: resourceType as 'folder' | 'document',\n  1789→+        resourceId: rid,\n  1790→+        userId: String(targetUserId),\n  1791→+        role: role as Role,\n  1792→+      };\n  1793→+      store.shares.push(share);\n  1794→+    }\n  1795→+\n  1796→+    addActivity(store, {\n  1797→+      action: 'shared',\n  1798→+      userId,\n  1799→+      resourceType: resourceType as 'folder' | 'document',\n  1800→+      resourceId: rid,\n  1801→+      details: `Shared with user ${targetUserId} as ${role}`,\n  1802→+    });\n  1803→+\n  1804→+    res.status(200).json(share);\n  1805→+  });\n  1806→+\n  1807→+  // Get shares for a resource\n  1808→+  router.get('/', requireAuth, (req: AuthRequest, res: Response) => {\n  1809→+    const userId = req.userId!;\n  1810→+    const { resourceType, resourceId } = req.query;\n  1811→+\n  1812→+    if (!resourceType || !resourceId) {\n  1813→+      res.status(400).json({ error: 'resourceType and resourceId are required' });\n  1814→+      return;\n  1815→+    }\n  1816→+\n  1817→+    const rid = String(resourceId);\n  1818→+    const rtype = String(resourceType) as 'folder' | 'document';\n  1819→+\n  1820→+    // Check user has access\n  1821→+    const role = getEffectiveRole(store, userId, rtype, rid);\n  1822→+    if (!role) {\n  1823→+      res.status(403).json({ error: 'Insufficient permissions' });\n  1824→+      return;\n  1825→+    }\n  1826→+\n  1827→+    const shares = store.shares.filter(\n  1828→+      (s) => s.resourceType === rtype && s.resourceId === rid\n  1829→+    );\n  1830→+\n  1831→+    res.status(200).json(shares);\n  1832→+  });\n  1833→+\n  1834→+  // Remove a share\n  1835→+  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n  1836→+    const userId = req.userId!;\n  1837→+    const shareId = req.params.id;\n  1838→+\n  1839→+    const shareIndex = store.shares.findIndex((s) => s.id === shareId);\n  1840→+    if (shareIndex < 0) {\n  1841→+      res.status(404).json({ error: 'Share not found' });\n  1842→+      return;\n  1843→+    }\n  1844→+\n  1845→+    const share = store.shares[shareIndex];\n  1846→+\n  1847→+    // Check permissions - only owner can remove shares\n  1848→+    const role = getEffectiveRole(store, userId, share.resourceType, share.resourceId);\n  1849→+    if (!canManageRoles(role)) {\n  1850→+      res.status(403).json({ error: 'Only owners can remove shares' });\n  1851→+      return;\n  1852→+    }\n  1853→+\n  1854→+    store.shares.splice(shareIndex, 1);\n  1855→+\n  1856→+    res.status(204).send();\n  1857→+  });\n  1858→+\n  1859→+  return router;\n  1860→+}\n  1861→diff --git a/src/store.ts b/src/store.ts\n  1862→new file mode 100644\n  1863→index 0000000..273ee68\n  1864→--- /dev/null\n  1865→+++ b/src/store.ts\n  1866→@@ -0,0 +1,25 @@\n  1867→+import { User, Folder, Document, Share, ActivityLogEntry } from './types.js';\n  1868→+\n  1869→+export interface Store {\n  1870→+  users: Map<string, User>;\n  1871→+  folders: Map<string, Folder>;\n  1872→+  documents: Map<string, Document>;\n  1873→+  shares: Share[];\n  1874→+  activityLog: ActivityLogEntry[];\n  1875→+  nextId: number;\n  1876→+}\n  1877→+\n  1878→+export function createStore(): Store {\n  1879→+  return {\n  1880→+    users: new Map(),\n  1881→+    folders: new Map(),\n  1882→+    documents: new Map(),\n  1883→+    shares: [],\n  1884→+    activityLog: [],\n  1885→+    nextId: 1,\n  1886→+  };\n  1887→+}\n  1888→+\n  1889→+export function generateId(store: Store): string {\n  1890→+  return String(store.nextId++);\n  1891→+}\n  1892→diff --git a/src/types.ts b/src/types.ts\n  1893→new file mode 100644\n  1894→index 0000000..04f82fc\n  1895→--- /dev/null\n  1896→+++ b/src/types.ts\n  1897→@@ -0,0 +1,44 @@\n  1898→+export type Role = 'viewer' | 'editor' | 'owner';\n  1899→+\n  1900→+export interface User {\n  1901→+  id: string;\n  1902→+  username: string;\n  1903→+  password: string;\n  1904→+  token: string | null;\n  1905→+}\n  1906→+\n  1907→+export interface Folder {\n  1908→+  id: string;\n  1909→+  name: string;\n  1910→+  parentId: string | null;\n  1911→+  ownerId: string;\n  1912→+  createdAt: string;\n  1913→+}\n  1914→+\n  1915→+export interface Document {\n  1916→+  id: string;\n  1917→+  title: string;\n  1918→+  content: string;\n  1919→+  folderId: string;\n  1920→+  ownerId: string;\n  1921→+  createdAt: string;\n  1922→+  updatedAt: string;\n  1923→+}\n  1924→+\n  1925→+export interface Share {\n  1926→+  id: string;\n  1927→+  resourceType: 'folder' | 'document';\n  1928→+  resourceId: string;\n  1929→+  userId: string;\n  1930→+  role: Role;\n  1931→+}\n  1932→+\n  1933→+export interface ActivityLogEntry {\n  1934→+  id: string;\n  1935→+  action: string;\n  1936→+  userId: string;\n  1937→+  resourceType: 'folder' | 'document';\n  1938→+  resourceId: string;\n  1939→+  timestamp: string;\n  1940→+  details?: string;\n  1941→+}"}]},"parent_tool_use_id":null,"session_id":"53285c5d-812c-468c-9025-1598714cc576","uuid":"5464b7d4-7b46-42a8-9d4e-9d29690fee16","tool_use_result":{"type":"text","file":{"filePath":"/tmp/.claude/projects/-workspace/53285c5d-812c-468c-9025-1598714cc576/tool-results/toolu_01BNwNSHMFqa6tsZAV6isU5s.txt","content":"diff --git a/src/.gitkeep b/src/.gitkeep\ndeleted file mode 100644\nindex e69de29..0000000\ndiff --git a/src/activity.ts b/src/activity.ts\nnew file mode 100644\nindex 0000000..6285ead\n--- /dev/null\n+++ b/src/activity.ts\n@@ -0,0 +1,56 @@\n+import { Router, Response } from 'express';\n+import { Store, generateId } from './store.js';\n+import { AuthRequest, requireAuth } from './auth.js';\n+\n+export function addActivity(\n+  store: Store,\n+  entry: {\n+    action: string;\n+    userId: string;\n+    resourceType: 'folder' | 'document';\n+    resourceId: string;\n+    details?: string;\n+  }\n+) {\n+  const id = generateId(store);\n+  store.activityLog.push({\n+    id,\n+    action: entry.action,\n+    userId: entry.userId,\n+    resourceType: entry.resourceType,\n+    resourceId: entry.resourceId,\n+    timestamp: new Date().toISOString(),\n+    details: entry.details,\n+  });\n+}\n+\n+export function createActivityRouter(store: Store): Router {\n+  const router = Router();\n+\n+  router.get('/', requireAuth, (req: AuthRequest, res: Response) => {\n+    const userId = req.userId!;\n+    const { resourceType, resourceId } = req.query;\n+\n+    let logs = [...store.activityLog];\n+\n+    // Filter by resource if specified\n+    if (resourceType && resourceId) {\n+      logs = logs.filter(\n+        (l) => l.resourceType === resourceType && l.resourceId === String(resourceId)\n+      );\n+    }\n+\n+    // Users can see activity for resources they have access to\n+    // For simplicity, return all activity for authenticated users\n+    // In a real system, we'd filter by permission\n+    // But we return userId so consumers can identify who did what\n+    void userId;\n+\n+    // Sort by most recent first\n+    logs.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());\n+\n+    res.status(200).json(logs);\n+  });\n+\n+  return router;\n+}\ndiff --git a/src/app.test.ts b/src/app.test.ts\nnew file mode 100644\nindex 0000000..8b63010\n--- /dev/null\n+++ b/src/app.test.ts\n@@ -0,0 +1,1016 @@\n+import { describe, it, expect, beforeEach } from 'vitest';\n+import request from 'supertest';\n+import { createApp } from './app.js';\n+import type { Express } from 'express';\n+\n+describe('Permission Maze API', () => {\n+  let app: Express;\n+\n+  beforeEach(() => {\n+    app = createApp();\n+  });\n+\n+  // Helper functions\n+  async function registerUser(username: string, password: string) {\n+    const res = await request(app)\n+      .post('/auth/register')\n+      .send({ username, password });\n+    return res;\n+  }\n+\n+  async function loginUser(username: string, password: string) {\n+    const res = await request(app)\n+      .post('/auth/login')\n+      .send({ username, password });\n+    return res;\n+  }\n+\n+  async function registerAndLogin(username: string, password: string) {\n+    await registerUser(username, password);\n+    const loginRes = await loginUser(username, password);\n+    return { token: loginRes.body.token, userId: loginRes.body.userId };\n+  }\n+\n+  describe('Auth', () => {\n+    it('should register a new user', async () => {\n+      const res = await registerUser('alice', 'password123');\n+      expect(res.status).toBe(201);\n+      expect(res.body).toHaveProperty('id');\n+      expect(res.body.username).toBe('alice');\n+    });\n+\n+    it('should reject duplicate username', async () => {\n+      await registerUser('alice', 'password123');\n+      const res = await registerUser('alice', 'password456');\n+      expect(res.status).toBe(409);\n+    });\n+\n+    it('should reject registration without username or password', async () => {\n+      const res1 = await request(app).post('/auth/register').send({ username: 'alice' });\n+      expect(res1.status).toBe(400);\n+\n+      const res2 = await request(app).post('/auth/register').send({ password: 'pass' });\n+      expect(res2.status).toBe(400);\n+    });\n+\n+    it('should login and return token', async () => {\n+      await registerUser('alice', 'password123');\n+      const res = await loginUser('alice', 'password123');\n+      expect(res.status).toBe(200);\n+      expect(res.body).toHaveProperty('token');\n+      expect(res.body).toHaveProperty('userId');\n+    });\n+\n+    it('should reject login with wrong password', async () => {\n+      await registerUser('alice', 'password123');\n+      const res = await loginUser('alice', 'wrongpass');\n+      expect(res.status).toBe(401);\n+    });\n+\n+    it('should reject login with non-existent user', async () => {\n+      const res = await loginUser('ghost', 'password');\n+      expect(res.status).toBe(401);\n+    });\n+\n+    it('should require auth for protected routes', async () => {\n+      const res = await request(app).get('/folders/1');\n+      expect(res.status).toBe(401);\n+    });\n+  });\n+\n+  describe('Folders', () => {\n+    let token: string;\n+\n+    beforeEach(async () => {\n+      const auth = await registerAndLogin('alice', 'pass');\n+      token = auth.token;\n+    });\n+\n+    it('should create a folder', async () => {\n+      const res = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'My Folder' });\n+\n+      expect(res.status).toBe(201);\n+      expect(res.body.name).toBe('My Folder');\n+      expect(res.body).toHaveProperty('id');\n+      expect(res.body.parentId).toBeNull();\n+    });\n+\n+    it('should create a nested folder', async () => {\n+      const parent = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'Parent' });\n+\n+      const child = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'Child', parentId: parent.body.id });\n+\n+      expect(child.status).toBe(201);\n+      expect(child.body.parentId).toBe(parent.body.id);\n+    });\n+\n+    it('should get a folder with children and documents', async () => {\n+      const folder = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'Root' });\n+\n+      const res = await request(app)\n+        .get(`/folders/${folder.body.id}`)\n+        .set('Authorization', `Bearer ${token}`);\n+\n+      expect(res.status).toBe(200);\n+      expect(res.body.name).toBe('Root');\n+      expect(res.body).toHaveProperty('children');\n+      expect(res.body).toHaveProperty('documents');\n+      expect(res.body.role).toBe('owner');\n+    });\n+\n+    it('should update a folder', async () => {\n+      const folder = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'Old Name' });\n+\n+      const res = await request(app)\n+        .put(`/folders/${folder.body.id}`)\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'New Name' });\n+\n+      expect(res.status).toBe(200);\n+      expect(res.body.name).toBe('New Name');\n+    });\n+\n+    it('should delete a folder', async () => {\n+      const folder = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'To Delete' });\n+\n+      const res = await request(app)\n+        .delete(`/folders/${folder.body.id}`)\n+        .set('Authorization', `Bearer ${token}`);\n+\n+      expect(res.status).toBe(204);\n+\n+      const getRes = await request(app)\n+        .get(`/folders/${folder.body.id}`)\n+        .set('Authorization', `Bearer ${token}`);\n+\n+      expect(getRes.status).toBe(404);\n+    });\n+\n+    it('should reject folder creation without name', async () => {\n+      const res = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({});\n+\n+      expect(res.status).toBe(400);\n+    });\n+\n+    it('should return 404 for non-existent folder', async () => {\n+      const res = await request(app)\n+        .get('/folders/999')\n+        .set('Authorization', `Bearer ${token}`);\n+\n+      expect(res.status).toBe(404);\n+    });\n+\n+    it('should reject folder creation with non-existent parent', async () => {\n+      const res = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'Child', parentId: '999' });\n+\n+      expect(res.status).toBe(404);\n+    });\n+\n+    it('should delete folder recursively with children and documents', async () => {\n+      const parent = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'Parent' });\n+\n+      const child = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'Child', parentId: parent.body.id });\n+\n+      await request(app)\n+        .post('/documents')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ title: 'Doc', content: 'text', folderId: child.body.id });\n+\n+      const delRes = await request(app)\n+        .delete(`/folders/${parent.body.id}`)\n+        .set('Authorization', `Bearer ${token}`);\n+\n+      expect(delRes.status).toBe(204);\n+\n+      const childRes = await request(app)\n+        .get(`/folders/${child.body.id}`)\n+        .set('Authorization', `Bearer ${token}`);\n+      expect(childRes.status).toBe(404);\n+    });\n+  });\n+\n+  describe('Documents', () => {\n+    let token: string;\n+    let folderId: string;\n+\n+    beforeEach(async () => {\n+      const auth = await registerAndLogin('alice', 'pass');\n+      token = auth.token;\n+\n+      const folder = await request(app)\n+        .post('/folders')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ name: 'Docs Folder' });\n+      folderId = folder.body.id;\n+    });\n+\n+    it('should create a document', async () => {\n+      const res = await request(app)\n+        .post('/documents')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ title: 'My Doc', content: 'Hello world', folderId });\n+\n+      expect(res.status).toBe(201);\n+      expect(res.body.title).toBe('My Doc');\n+      expect(res.body.content).toBe('Hello world');\n+      expect(res.body.folderId).toBe(folderId);\n+    });\n+\n+    it('should get a document', async () => {\n+      const doc = await request(app)\n+        .post('/documents')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ title: 'My Doc', content: 'Content', folderId });\n+\n+      const res = await request(app)\n+        .get(`/documents/${doc.body.id}`)\n+        .set('Authorization', `Bearer ${token}`);\n+\n+      expect(res.status).toBe(200);\n+      expect(res.body.title).toBe('My Doc');\n+      expect(res.body.role).toBe('owner');\n+    });\n+\n+    it('should update a document', async () => {\n+      const doc = await request(app)\n+        .post('/documents')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ title: 'Old Title', content: 'Old Content', folderId });\n+\n+      const res = await request(app)\n+        .put(`/documents/${doc.body.id}`)\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ title: 'New Title', content: 'New Content' });\n+\n+      expect(res.status).toBe(200);\n+      expect(res.body.title).toBe('New Title');\n+      expect(res.body.content).toBe('New Content');\n+    });\n+\n+    it('should delete a document', async () => {\n+      const doc = await request(app)\n+        .post('/documents')\n+        .set('Authorization', `Bearer ${token}`)\n+        .send({ title: 'To Delete', content: 'bye', folderId });\n+\n+    