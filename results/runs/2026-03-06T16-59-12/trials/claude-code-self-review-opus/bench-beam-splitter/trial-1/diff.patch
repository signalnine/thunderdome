+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example 2: two splitters in chain', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('beam goes straight down with no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('no source', () => {
+    const grid = [
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it('source on edge, beam exits immediately after one row', () => {
+    const grid = [
+      ['S'],
+    ];
+    // Source at (0,0), beam goes to (1,0) which is out of bounds
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('splitter at edge absorbs one beam', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Source (0,0) → (1,0) hits splitter
+    // down-left: (2,-1) absorbed
+    // down-right: (2,1) in bounds
+    // Visited: (0,0), (1,0), (2,1) → 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('multiple beams converge on same cell', () => {
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '^', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // (0,2) S → (1,2) ^ → (2,1,dl) and (2,3,dr)
+    // (2,1) . dl → (3,0) . dl → (4,-1) out
+    // (2,3) . dr → (3,4) . dr → (4,5) out
+    // Visited: (0,2), (1,2), (2,1), (2,3), (3,0), (3,4) → 6
+    expect(countBeamCells(grid)).toBe(6);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example 2: two splitters in chain', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters - single path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('no source', () => {
+    const grid = [
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it('source only, single row', () => {
+    const grid = [['S']];
+    // Beam starts at (0,0) and immediately exits downward
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('splitter at edge absorbs one beam', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // S(0,0) → (1,0) ^ → (2,-1) absorbed + (2,1) exits at row 3
+    // Paths: 2 (one absorbed left, one exits bottom)
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('large number of splitters produces big result', () => {
+    // Build a grid where beam hits many splitters in sequence
+    // Each splitter doubles paths, but we need a specific configuration
+    // Create a tall narrow grid: source at top, splitter below, converging beams
+    const rows = 100;
+    const cols = 201; // wide enough to not lose beams
+    const grid: string[][] = [];
+    for (let r = 0; r < rows; r++) {
+      grid.push(new Array(cols).fill('.'));
+    }
+    grid[0][100] = 'S';
+    // Place a splitter right below source
+    grid[1][100] = '^';
+    // Both beams go to (2,99) and (2,101)
+    // Place splitters there too
+    grid[2][99] = '^';
+    grid[2][101] = '^';
+    // After 3 levels of splitters: 2^3 = 8 potential paths... but some beams merge
+    // Actually each splitter on a unique position creates independent splits
+    // After row 1 splitter: 2 beams
+    // After row 2 splitters: 4 beams
+    // Total paths: 4
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('handles performance with many splitters', () => {
+    // Create a grid with splitters arranged so no merging happens
+    // Place splitters in a triangle pattern
+    const size = 200;
+    const grid: string[][] = [];
+    for (let r = 0; r < size; r++) {
+      grid.push(new Array(size).fill('.'));
+    }
+    grid[0][100] = 'S';
+
+    // Place ~20 splitters in a chain where each splits independently
+    let col = 100;
+    for (let i = 1; i <= 20; i += 2) {
+      grid[i][col] = '^';
+      col--; // follow the down-left branch
+    }
+    // This should complete in reasonable time
+    const result = countBeamPaths(grid);
+    expect(result).toBeGreaterThan(0n);
+  });
+});
