+type Direction = 'down' | 'down-left' | 'down-right';
+
+function findSource(grid: string[][]): [number, number] | null {
+  if (grid.length === 0) return null;
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') {
+      return [0, col];
+    }
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+function getNextMoves(
+  grid: string[][],
+  row: number,
+  col: number,
+  dir: Direction,
+): Array<[number, number, Direction]> {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const cell = grid[row][col];
+  const results: Array<[number, number, Direction]> = [];
+
+  if (cell === '^') {
+    // Splitter: always splits into down-left and down-right
+    for (const nextDir of ['down-left', 'down-right'] as Direction[]) {
+      const [nr, nc] = advance(row, col, nextDir);
+      if (inBounds(nr, nc, rows, cols)) {
+        results.push([nr, nc, nextDir]);
+      }
+    }
+  } else {
+    // Source or empty: continue in current direction
+    // For source, the initial direction is 'down'
+    const [nr, nc] = advance(row, col, dir);
+    if (inBounds(nr, nc, rows, cols)) {
+      results.push([nr, nc, dir]);
+    }
+  }
+
+  return results;
+}
+
+function countExits(
+  grid: string[][],
+  row: number,
+  col: number,
+  dir: Direction,
+): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const cell = grid[row][col];
+  let count = 0;
+
+  if (cell === '^') {
+    for (const nextDir of ['down-left', 'down-right'] as Direction[]) {
+      const [nr, nc] = advance(row, col, nextDir);
+      if (!inBounds(nr, nc, rows, cols)) {
+        count++;
+      }
+    }
+  } else {
+    const [nr, nc] = advance(row, col, dir);
+    if (!inBounds(nr, nc, rows, cols)) {
+      count++;
+    }
+  }
+
+  return count;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ * Uses state deduplication: (row, col, dir) to avoid exponential blowup.
+ */
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  const stateVisited = new Set<string>();
+
+  const queue: Array<[number, number, Direction]> = [[source[0], source[1], 'down']];
+  stateVisited.add(`${source[0]},${source[1]},down`);
+  visited.add(`${source[0]},${source[1]}`);
+
+  while (queue.length > 0) {
+    const [row, col, dir] = queue.pop()!;
+    const moves = getNextMoves(grid, row, col, dir);
+
+    for (const [nr, nc, nd] of moves) {
+      visited.add(`${nr},${nc}`);
+      const stateKey = `${nr},${nc},${nd}`;
+      if (!stateVisited.has(stateKey)) {
+        stateVisited.add(stateKey);
+        queue.push([nr, nc, nd]);
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count the total number of distinct source-to-exit paths.
+ * Uses path counting with state aggregation to handle exponential path counts.
+ *
+ * We process beams row by row. For each unique (row, col, dir) state,
+ * we track how many paths reach that state. When a beam exits, we add
+ * its path count to the total.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0) return 0n;
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  let totalPaths = 0n;
+
+  // Map from state key "row,col,dir" to path count
+  // Process row by row for efficiency
+  let currentBeams = new Map<string, bigint>();
+  const startKey = `${source[0]},${source[1]},down`;
+  currentBeams.set(startKey, 1n);
+
+  // Process all beams until none remain
+  while (currentBeams.size > 0) {
+    const nextBeams = new Map<string, bigint>();
+
+    for (const [key, pathCount] of currentBeams) {
+      const parts = key.split(',');
+      const row = parseInt(parts[0]);
+      const col = parseInt(parts[1]);
+      const dir = parts[2] as Direction;
+
+      // Count exits from this state
+      const exits = countExits(grid, row, col, dir);
+      totalPaths += pathCount * BigInt(exits);
+
+      // Get next moves
+      const moves = getNextMoves(grid, row, col, dir);
+      for (const [nr, nc, nd] of moves) {
+        const nextKey = `${nr},${nc},${nd}`;
+        const existing = nextBeams.get(nextKey) ?? 0n;
+        nextBeams.set(nextKey, existing + pathCount);
+      }
+    }
+
+    currentBeams = nextBeams;
+  }
+
+  return totalPaths;
+}
