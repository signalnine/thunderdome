   const res = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\", config: { widgets: [] } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"My Dashboard\");\n    });\n\n    it(\"lists dashboards\", async () => {\n      await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n      await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 2\" });\n\n      const res = await request(app)\n        .get(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(2);\n    });\n\n    it(\"gets a single dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n\n      const res = await request(app)\n        .get(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"My Dashboard\");\n    });\n\n    it(\"updates a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n\n      const res = await request(app)\n        .put(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Updated Dashboard\" });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Updated Dashboard\");\n    });\n\n    it(\"deletes a dashboard\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n\n      const del = await request(app)\n        .delete(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(del.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(get.status).toBe(404);\n    });\n\n    it(\"tenant isolation for dashboards\", async () => {\n      const created = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\" });\n\n      const other = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"other@other.com\", password: \"pass\", tenant_id: \"t2\" });\n\n      const res = await request(app)\n        .get(`/dashboards/${created.body.id}`)\n        .set(\"Authorization\", `Bearer ${other.body.token}`);\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe(\"Export\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"user@acme.com\", password: \"pass\", tenant_id: \"t1\" });\n      token = reg.body.token;\n\n      await request(app)\n        .post(\"/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n          ],\n        });\n    });\n\n    it(\"exports events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(2);\n    });\n\n    it(\"exports events as CSV\", async () => {\n      const res = await request(app)\n       