!password || !tenant_id) {\n+      res.status(400).json({ error: \"email, password, and tenant_id are required\", code: \"BAD_REQUEST\" });\n+      return;\n+    }\n+\n+    const existing = db.prepare(\"SELECT id FROM users WHERE email = ?\").get(email) as UserRow | undefined;\n+    if (existing) {\n+      res.status(409).json({ error: \"Email already registered\", code: \"CONFLICT\" });\n+      return;\n+    }\n+\n+    const id = uuidv4();\n+    const password_hash = hashPassword(password);\n+    const userRole = role && [\"admin\", \"viewer\", \"editor\"].includes(role) ? role : \"viewer\";\n+\n+    db.prepare(\n+      \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n+    ).run(id, email, password_hash, tenant_id, userRole);\n+\n+    const token = jwt.sign(\n+      { sub: id, tid: tenant_id, role: userRole },\n+      JWT_SECRET,\n+      { expiresIn: \"24h\" }\n+    );\n+\n+    res.status(201).json({ id, email, tenant_id, role: userRole, token });\n+  });\n+\n+  // Login\n+  router.post(\"/login\", (req: AuthRequest, res: Response): void => {\n+    const { email, password } = req.body;\n+\n+    if (!email || !password) {\n+      res.status(400).json({ error: \"email and password are required\", code: \"BAD_REQUEST\" });\n+      return;\n+    }\n+\n+    const user = db.prepare(\"SELECT * FROM users WHERE email = ?\").get(email) as UserRow | undefined;\n+    if (!user || !verifyPassword(password, user.password_hash)) {\n+      res.status(401).json({ error: \"Invalid credentials\", code: \"UNAUTHORIZED\" });\n+      return;\n+    }\n+\n+    const token = jwt.sign(\n+      { sub: user.id, tid: user.tenant_id, role: user.role },\n+      JWT_SECRET,\n+      { expiresIn: \"24h\" }\n+    );\n+\n+    res.json({ id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role, token });\n+  });\n+\n+  // Get profile\n+  router.get(\"/profile\", authenticate, (req: AuthRequest, res: Response): void => {\n+    const user = db.prepare(\"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\").get(req.user!.sub) as Omit<UserRow, \"password_hash\"> | undefined;\n+    if (!user) {\n+      res.status(404).json({ error: \"User not found\", code: \"NOT_FOUND\" });\n+      return;\n+    }\n+    res.json(user);\n+  });\n+\n+  // Change user role (admin only)\n+  router.put(\"/users/:userId/role\", authenticate, requireRole(\"admin\"), (req: AuthRequest, res: Response): void => {\n+    const { userId } = req.params;\n+    const { role } = req.body;\n+\n+    if (!role || ![\"admin\", \"viewer\", \"editor\"].includes(role)) {\n+      res.status(400).json({ error: \"Valid role is required (admin, viewer, editor)\", code: \"BAD_REQUEST\" });\n+      return;\n+    }\n+\n+    const targetUser = db.prepare(\"SELECT * FROM users WHERE id = ?\").get(userId) as UserRow | undefined;\n+    if (!targetUser) {\n+      res.status(404).json({ error: \"User not found\", code: \"NOT_FOUND\" });\n+      return;\n+    }\n+\n+    // Tenant isolation: admin can only change roles within their tenant\n+    if (targetUser.tenant_id !== req.user!.tid) {\n+      res.status(403).json({ error: \"Cannot modify users outside your tenant\", code: \"FORBIDDEN\" });\n+      return;\n+    }\n+\n+    db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, userId);\n+    res.json({ id: targetUser.id, email: targetUser.email, tenant_id: targetUser.tenant_id, role });\n+  });\n+\n+  return router;\n+}\ndiff --git a/src/routes/dashboards.ts b/src/routes/dashboards.ts\nnew file mode 100644\nindex 0000000..4ec716b\n--- /dev/null\n+++ b/src/routes/dashboards.ts\n@@ -0,0 +1,119 @@\n+import { Router, Response } from \"express\";\n+import Database from \"better-sqlite3\";\n+import { v4 as uuidv4 } from \"uuid\";\n+import { AuthRequest, DashboardRow } from \"../types.js\";\n+import { authenticate } from \"../middleware.js\";\n+\n+export function createDashboardsRouter(db: Database.Database): Router {\n+  const router = Router();\n+\n+  // Create dashboard\n+  router.post(\"/\", authenticate, (req: AuthRequest, res: Response): void => {\n+    const { name, config } = req.body;\n+\n+    if (!name) {\n+      res.status(400).json({ error: \"Dashboard name is required\", code: \"BAD_REQUEST\" });\n+      return;\n+    }\n+\n+    const id = uuidv4();\n+    const tenantId = req.user!.tid;\n+    const ownerId = req.user!.sub;\n+    const dashConfig = JSON.stringify(config || {});\n+    const now = new Date().toISOString();\n+\n+    db.prepare(\n+      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n+    ).run(id, tenantId, name, ownerId, dashConfig, now, now);\n+\n+    res.status(201).json({\n+      id,\n+      tenant_id: tenantId,\n+      name,\n+      owner_id: ownerId,\n+      config: config || {},\n+      created_at: now,\n+      updated_at: now,\n+    });\n+  });\n+\n+  // List dashboards for tenant\n+  router.get(\"/\", authenticate, (req: AuthRequest, res: Response): void => {\n+    const tenantId = req.user!.tid;\n+    const rows = db.prepare(\n+      \"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\"\n+    ).all(tenantId) as DashboardRow[];\n+\n+    const dashboards = rows.map((d) => ({\n+      ...d,\n+      config: JSON.parse(d.config),\n+    }));\n+\n+    res.json({ dashboards });\n+  });\n+\n+  // Get single dashboard\n+  router.get(\"/:id\", authenticate, (req: AuthRequest, res: Response): void => {\n+    const tenantId = req.user!.tid;\n+    const row = db.prepare(\n+      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n+    ).get(req.params.id, tenantId) as DashboardRow | undefined;\n+\n+    if (!row) {\n+      res.status(404).json({ error: \"Dashboard not found\", code: \"NOT_FOUND\" });\n+      return;\n+    }\n+\n+    res.json({ ...row, config: JSON.parse(row.config) });\n+  });\n+\n+  // Update dashboard\n+  router.put(\"/:id\", authenticate, (req: AuthRequest, res: Response): void => {\n+    const tenantId = req.user!.tid;\n+    const existing = db.prepare(\n+      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n+    ).get(req.params.id, tenantId) as DashboardRow | undefined;\n+\n+    if (!existing) {\n+      res.status(404).json({ error: \"Dashboard not found\", code: \"NOT_FOUND\" });\n+      return;\n+    }\n+\n+    const { name, config } = req.body;\n+    const updatedName = name || existing.name;\n+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;\n+    const now = new Date().toISOString();\n+\n+    db.prepare(\n+      \"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ? AND tenant_id = ?\"\n+    ).run(updatedName, updatedConfig, now, req.params.id, tenantId);\n+\n+    res.json({\n+      id: existing.id,\n+      tenant_id: tenantId,\n+      name: updatedName,\n+      owner_id: existing.owner_id,\n+      config: config !== undefined ? config : JSON.parse(existing.config),\n+      created_at: existing.created_at,\n+      updated_at: now,\n+    });\n+  });\n+\n+  // Delete dashboard\n+  router.delete(\"/:id\", authenticate, (req: AuthRequest, res: Response): void => {\n+    const tenantId = req.user!.tid;\n+    const existing = db.prepare(\n+      \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n+    ).get(req.params.id, tenantId) as DashboardRow | undefined;\n+\n+    if (!existing) {\n+      res.status(404).json({ error: \"Dashboard not found\", code: \"NOT_FOUND\" });\n+      return;\n+    }\n+\n+    db.prepare(\"DELETE FROM dashboards WHERE id = ? AND tenant_id = ?\").run(req.params.id, tenantId);\n+    res.status(204).send();\n+  });\n+\n+  return router;\n+}\ndiff --git a/src/routes/events.ts b/src/routes/events.ts\nnew file mode 100644\nindex 0000000..f7d37f0\n--- /dev/null\n+++ b/src/routes/events.ts\n@@ -0,0 +1,73 @@\n+import { Router, Response } from \"express\";\n+import Database from \"better-sqlite3\";\n+import { v4 as uuidv4 } from \"uuid\";\n+import { AuthRequest } from \"../types.js\";\n+import { authenticate } from \"../middleware.js\";\n+\n+interface EventInput {\n+  name: string;\n+  properties?: Record<string, unknown>;\n+  timestamp?: string;\n+  session_id?: string;\n+}\n+\n+export function createEventsRouter(db: Database.Database): Router {\n+  const router = Router();\n+\n+  // Ingest single event\n+  router.post(\"/\", authenticate, (req: AuthRequest, res: Response): void => {\n+    const { name, properties, timestamp, session_id } = req.body as EventInput;\n+\n+    if (!name) {\n+      res.status(400).json({ error: \"Event name is required\", code: \"BAD_REQUEST\" });\n+      return;\n+    }\n+\n+    const id = uuidv4();\n+    const tenantId = req.user!.tid;\n+    const userId = req.user!.sub;\n+    const ts = timestamp || new Date().toISOString();\n+    const props = JSON.stringify(properties || {});\n+\n+    db.prepare(\n+      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n+    ).run(id, tenantId, name, props, ts, userId, session_id || null);\n+\n+    res.status(201).json({ id, tenant_id: tenantId, name, properties: properties || {}, timestamp: ts });\n+  });\n+\n+  // Ingest batch events\n+  router.post(\"/batch\", authenticate, (req: AuthRequest, res: Response): void => {\n+    const { events } = req.body as { events: EventInput[] };\n+\n+    if (!events || !Array.isArray(events) || events.length === 0) {\n+      res.status(400).json({ error: \"events array is required and must not be empty\", code: \"BAD_REQUEST\" });\n+      return;\n+    }\n+\n+    const tenantId = req.user!.tid;\n+    const userId = req.user!.sub;\n+\n+    const insert = db.prepare(\n+      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n+    );\n+\n+    const results: Array<{ id: string; name: string }> = [];\n+\n+    const insertMany = db.transaction((evts: EventInput[]) => {\n+      for (const evt of evts) {\n+        if (!evt.name) continue;\n+        const id = uuidv4();\n+        const ts = evt.timestamp || new Date().toISOString();\n+        const props = JSON.stringify(evt.properties || {});\n+        insert.run(id, tenantId, evt.name, props, ts, userId, evt.session_id || null);\n+        results.push({ id, name: evt.name });\n+      }\n+    });\n+\n+    insertMany(events);\n+    res.status(201).json({ inserted: results.length, events: results });\n+  });\n+\n+  return router;\n+}\ndiff --git a/src/routes/export.ts b/src/routes/export.ts\nnew file mode 100644\nindex 0000000..e5ad3d1\n--- /dev/null\n+++ b/src/routes/export.ts\n@@ -0,0 +1,130 @@\n+import { Router, Response } from \"express\";\n+import Database from \"better-sqlite3\";\n+import { AuthRequest, EventRow, DashboardRow } from \"../types.js\";\n+import { authenticate } from \"../middleware.js\";\n+\n+function eventsToCsv(events: EventRow[]): string {\n+  const headers = [\"id\", \"tenant_id\", \"name\", \"properties\", \"timestamp\", \"user_id\", \"session_id\"];\n+  const rows = events.map((e) =>\n+    headers.map((h) => {\n+      const val = e[h as keyof EventRow];\n+      if (val === null || val === undefined) return \"\";\n+      const str = String(val);\n+      if (str.includes(\",\") || str.includes('\"') || str.includes(\"\\n\")) {\n+        return `\"${str.replace(/\"/g, '\"\"')}\"`;\n+      }\n+      return str;\n+    }).join(\",\")\n+  );\n+  return [headers.join(\",\"), ...rows].join(\"\\n\");\n+}\n+\n+function dashboardsToCsv(dashboards: DashboardRow[]): string {\n+  const headers = [\"id\", \"tenant_id\", \"name\", \"owner_id\", \"config\", \"created_at\", \"updated_at\"];\n+  const rows = dashboards.map((d) =>\n+    headers.map((h) => {\n+      const val = d[h as keyof DashboardRow];\n+      if (val === null || val === undefined) return \"\";\n+      const str = String(val);\n+      if (str.includes(\",\") || str.includes('\"') || str.