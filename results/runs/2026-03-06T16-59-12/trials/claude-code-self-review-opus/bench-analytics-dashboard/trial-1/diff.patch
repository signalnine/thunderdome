@@ -0,0 +1,73 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthRequest } from "../types.js";
+import { authenticate } from "../middleware.js";
+
+interface EventInput {
+  name: string;
+  properties?: Record<string, unknown>;
+  timestamp?: string;
+  session_id?: string;
+}
+
+export function createEventsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authenticate, (req: AuthRequest, res: Response): void => {
+    const { name, properties, timestamp, session_id } = req.body as EventInput;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tid;
+    const userId = req.user!.sub;
+    const ts = timestamp || new Date().toISOString();
+    const props = JSON.stringify(properties || {});
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, props, ts, userId, session_id || null);
+
+    res.status(201).json({ id, tenant_id: tenantId, name, properties: properties || {}, timestamp: ts });
+  });
+
+  // Ingest batch events
+  router.post("/batch", authenticate, (req: AuthRequest, res: Response): void => {
+    const { events } = req.body as { events: EventInput[] };
+
+    if (!events || !Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const tenantId = req.user!.tid;
+    const userId = req.user!.sub;
+
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const results: Array<{ id: string; name: string }> = [];
+
+    const insertMany = db.transaction((evts: EventInput[]) => {
+      for (const evt of evts) {
+        if (!evt.name) continue;
+        const id = uuidv4();
+        const ts = evt.timestamp || new Date().toISOString();
+        const props = JSON.stringify(evt.properties || {});
+        insert.run(id, tenantId, evt.name, props, ts, userId, evt.session_id || null);
+        results.push({ id, name: evt.name });
+      }
+    });
+
+    insertMany(events);
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
new file mode 100644
index 0000000..e5ad3d1
--- /dev/null
+++ b/src/routes/export.ts
@@ -0,0 +1,130 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, EventRow, DashboardRow } from "../types.js";
+import { authenticate } from "../middleware.js";
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "tenant_id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const rows = events.map((e) =>
+    headers.map((h) => {
+      const val = e[h as keyof EventRow];
+      if (val === null || val === undefined) return "";
+      const str = String(val);
+      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+        return `"${str.replace(/"/g, '""')}"`;
+      }
+      return str;
+    }).join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const headers = ["id", "tenant_id", "name", "owner_id", "config", "created_at", "updated_at"];
+  const rows = dashboards.map((d) =>
+    headers.map((h) => {
+      const val = d[h as keyof DashboardRow];
+      if (val === null || val === undefined) return "";
+      const str = String(val);
+      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+        return `"${str.replace(/"/g, '""')}"`;
+      }
+      return str;
+    }).join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (req.query.event_name) {
+      sql += " AND name = ?";
+      params.push(req.query.event_name);
+    }
+    if (req.query.start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(req.query.start_date);
+    }
+    if (req.query.end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(req.query.end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (req.query.event_name) {
+      sql += " AND name = ?";
+      params.push(req.query.event_name);
+    }
+    if (req.query.start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(req.query.start_date);
+    }
+    if (req.query.end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(req.query.end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+    const csv = eventsToCsv(events);
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(csv);
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const dashboards = db.prepare(
+      "SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+    ).all(tenantId) as DashboardRow[];
+
+    const parsed = dashboards.map((d) => ({
+      ...d,
+      config: JSON.parse(d.config),
+    }));
+
+    res.json({ dashboards: parsed });
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const dashboards = db.prepare(
+      "SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+    ).all(tenantId) as DashboardRow[];
+
+    const csv = dashboardsToCsv(dashboards);
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(csv);
+  });
+
+  return router;
+}
diff --git a/src/routes/query.ts b/src/routes/query.ts
new file mode 100644
index 0000000..8ccaec7
--- /dev/null
+++ b/src/routes/query.ts
@@ -0,0 +1,144 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest } from "../types.js";
+import { authenticate } from "../middleware.js";
+
+interface CountQuery {
+  event_name?: string;
+  start_date?: string;
+  end_date?: string;
+  filters?: Record<string, string>;
+}
+
+interface TimeseriesQuery extends CountQuery {
+  interval?: "hour" | "day" | "week" | "month";
+}
+
+interface BreakdownQuery extends CountQuery {
+  property: string;
+}
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", authenticate, (req: AuthRequest, res: Response): void => {
+    const { event_name, start_date, end_date, filters } = req.body as CountQuery;
+    const tenantId = req.user!.tid;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", authenticate, (req: AuthRequest, res: Response): void => {
+    const { event_name, start_date, end_date, interval, filters } = req.body as TimeseriesQuery;
+    const tenantId = req.user!.tid;
+
+    let dateFormat: string;
+    switch (interval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "month":
+        dateFormat = "%Y-%m";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += ` GROUP BY bucket ORDER BY bucket ASC`;
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ interval: interval || "day", data: results });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", authenticate, (req: AuthRequest, res: Response): void => {
+    const { event_name, start_date, end_date, property, filters } = req.body as BreakdownQuery;
+    const tenantId = req.user!.tid;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries", code: "BAD_REQUEST" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;
+    res.json({ property, data: results });
+  });
+
+  return router;
+}
