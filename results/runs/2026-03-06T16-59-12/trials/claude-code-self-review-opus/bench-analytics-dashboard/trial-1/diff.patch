entials\", async () => {\n      await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"test@acme.com\", password: \"pass123\", tenant_id: \"t1\" });\n      const res = await request(app)\n        .post(\"/auth/login\")\n        .send({ email: \"test@acme.com\", password: \"pass123\" });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it(\"rejects wrong password\", async () => {\n      await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"test@acme.com\", password: \"pass123\", tenant_id: \"t1\" });\n      const res = await request(app)\n        .post(\"/auth/login\")\n        .send({ email: \"test@acme.com\", password: \"wrong\" });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"gets user profile\", async () => {\n      const reg = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"test@acme.com\", password: \"pass123\", tenant_id: \"t1\" });\n      const res = await request(app)\n        .get(\"/auth/profile\")\n        .set(\"Authorization\", `Bearer ${reg.body.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"test@acme.com\");\n      expect(res.body.password_hash).toBeUndefined();\n    });\n\n    it(\"rejects unauthenticated profile request\", async () => {\n      const res = await request(app).get(\"/auth/profile\");\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Auth - Role Management\", () => {\n    it(\"admin can change user role within tenant\", async () => {\n      const admin = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"admin@acme.com\", password: \"pass\", tenant_id: \"t1\", role: \"admin\" });\n      const viewer = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"viewer@acme.com\", password: \"pass\", tenant_id: \"t1\" });\n\n      const res = await request(app)\n        .put(`/auth/users/${viewer.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${admin.body.token}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"admin cannot change role of user in other tenant\", async () => {\n      const admin = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"admin@acme.com\", password: \"pass\", tenant_id: \"t1\", role: \"admin\" });\n      const other = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"other@other.com\", password: \"pass\", tenant_id: \"t2\" });\n\n      const res = await request(app)\n        .put(`/auth/users/${other.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${admin.body.token}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(403);\n    });\n\n    it(\"non-admin cannot change roles\", async () => {\n      const viewer = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"viewer@acme.com\", password: \"pass\", tenant_id: \"t1\" });\n      const other = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"other@acme.com\", password: \"pass\", tenant_id: \"t1\" });\n\n      const res = await request(app)\n        .put(`/auth/users/${other.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${viewer.body.token}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Events - Ingestion\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"user@acme.com\", password: \"pass\", tenant_id: \"t1\" });\n      token = reg.body.token;\n    });\n\n    it(\"ingests a single event\", async () => {\n      const res = await request(app)\n        .post(\"/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n      expect(res.body.id).toBeDefined();\n    });\n\n    it(\"ingests batch events\", async () => {\n      const res = await request(app)\n        .post(\"/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n            { name: \"page_view\", properties: { url: \"/about\" } },\n          ],\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it(\"rejects unauthenticated event ingestion\", async () => {\n      const res = await request(app)\n        .post(\"/events\")\n        .send({ name: \"page_view\" });\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post(\"/auth/register\")\n        .send({ email: \"user@acme.com\", password: \"pass\", tenant_id: \"t1\" });\n      token = reg.body.token;\n\n      // Ingest test events\n      await request(app)\n        .post(\"/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-15T10:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-15T14:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n            { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-16T11:00:00Z\" },\n          ],\n        });\n    });\n\n    it(\"counts events\", async () => {\n      const res = await request(app)\n        .post(\"/query/count\")\n       