+
+      sheet.set('A2', 50);
+      expect(sheet.get('B1')).toBe(90);
+    });
+
+    it('should update IF when condition changes', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('small');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('B1')).toBe('big');
+    });
+
+    it('should handle updating a formula cell', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+
+      sheet.set('A2', '=A1*3');
+      expect(sheet.get('A2')).toBe(30);
+    });
+
+    it('should handle replacing a formula with a value', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+
+      sheet.set('A2', 99);
+      expect(sheet.get('A2')).toBe(99);
+    });
+
+    it('should handle multiple cells depending on the same cell', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      sheet.set('C1', '=A1+2');
+      sheet.set('D1', '=A1+3');
+
+      sheet.set('A1', 20);
+      expect(sheet.get('B1')).toBe(21);
+      expect(sheet.get('C1')).toBe(22);
+      expect(sheet.get('D1')).toBe(23);
+    });
+  });
+
+  describe('circular reference detection', () => {
+    it('should detect direct circular reference', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+
+    it('should detect self-reference', () => {
+      const sheet = new Spreadsheet();
+      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+
+    it('should detect indirect circular reference', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      sheet.set('B1', '=C1');
+      expect(() => sheet.set('C1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+
+    it('should allow non-circular references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1');
+      sheet.set('C1', '=B1');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should allow re-setting a cell to break a chain', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1');
+      sheet.set('C1', '=B1');
+      // Setting B1 to a value breaks the A1->B1 link
+      sheet.set('B1', 42);
+      expect(sheet.get('B1')).toBe(42);
+      expect(sheet.get('C1')).toBe(42);
+      // Now A1 -> B1 is no longer a dependency, so we can set A1 = C1
+      sheet.set('A1', '=C1');
+      expect(sheet.get('A1')).toBe(42);
+    });
+  });
+
+  describe('column references', () => {
+    it('should handle multi-letter columns (AA, AB, etc.)', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('AA1', 100);
+      expect(sheet.get('AA1')).toBe(100);
+    });
+
+    it('should handle formulas with multi-letter columns', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('AA1', 10);
+      sheet.set('AB1', 20);
+      sheet.set('AC1', '=AA1+AB1');
+      expect(sheet.get('AC1')).toBe(30);
+    });
+
+    it('should handle ranges with multi-letter columns', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('AA1', 1);
+      sheet.set('AB1', 2);
+      sheet.set('AC1', 3);
+      sheet.set('AD1', '=SUM(AA1:AC1)');
+      expect(sheet.get('AD1')).toBe(6);
+    });
+  });
+
+  describe('example usage from spec', () => {
+    it('should match the example usage', () => {
+      const sheet = new Spreadsheet();
+
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+      expect(sheet.getDisplay('A3')).toBe('30');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(70);
+
+      sheet.set('C1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('C1')).toBe('big');
+    });
+  });
+
+  describe('edge cases', () => {
+    it('should handle division by zero', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 0);
+      expect(() => sheet.set('A3', '=A1/A2')).toThrow(/[Dd]ivision/);
+    });
+
+    it('should handle formulas referencing empty cells in functions', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('B1', '=SUM(A1:A5)');
+      expect(sheet.get('B1')).toBe(0);
+    });
+
+    it('should handle large row numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('Z100', 42);
+      expect(sheet.get('Z100')).toBe(42);
+    });
+
+    it('should handle overwriting a cell value', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A1', 20);
+      expect(sheet.get('A1')).toBe(20);
+    });
+
+    it('should handle formula with constant expression', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=2+3*4');
+      expect(sheet.get('A1')).toBe(14);
+    });
+
+    it('should handle nested parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=((2+3)*4)');
+      expect(sheet.get('A1')).toBe(20);
+    });
+  });
+});
