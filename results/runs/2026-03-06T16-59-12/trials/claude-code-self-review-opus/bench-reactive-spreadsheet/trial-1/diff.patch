new file mode 100644
index 0000000..8e63efc
--- /dev/null
+++ b/src/cellref.ts
@@ -0,0 +1,79 @@
+/**
+ * Parse a cell reference string like "A1", "AA100" into column and row.
+ * Column is 0-based, row is 0-based internally.
+ */
+export function parseCellRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) {
+    throw new Error(`Invalid cell reference: ${ref}`);
+  }
+  const colStr = match[1];
+  const rowStr = match[2];
+  const col = columnLetterToIndex(colStr);
+  const row = parseInt(rowStr, 10) - 1; // convert to 0-based
+  if (row < 0) {
+    throw new Error(`Invalid row number in cell reference: ${ref}`);
+  }
+  return { col, row };
+}
+
+/**
+ * Convert column letter(s) to 0-based index.
+ * A=0, B=1, ..., Z=25, AA=26, AB=27, ...
+ */
+export function columnLetterToIndex(letters: string): number {
+  let index = 0;
+  for (let i = 0; i < letters.length; i++) {
+    index = index * 26 + (letters.charCodeAt(i) - 64);
+  }
+  return index - 1; // make 0-based
+}
+
+/**
+ * Convert 0-based column index to letter(s).
+ * 0=A, 1=B, ..., 25=Z, 26=AA, 27=AB, ...
+ */
+export function columnIndexToLetter(index: number): string {
+  let result = '';
+  let n = index + 1; // make 1-based
+  while (n > 0) {
+    n--;
+    result = String.fromCharCode(65 + (n % 26)) + result;
+    n = Math.floor(n / 26);
+  }
+  return result;
+}
+
+/**
+ * Build a cell reference string from 0-based column and row.
+ */
+export function buildCellRef(col: number, row: number): string {
+  return columnIndexToLetter(col) + (row + 1);
+}
+
+/**
+ * Normalize a cell reference to uppercase.
+ */
+export function normalizeCellRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+/**
+ * Expand a range like A1:C3 into a list of individual cell references.
+ */
+export function expandRange(startRef: string, endRef: string): string[] {
+  const start = parseCellRef(startRef);
+  const end = parseCellRef(endRef);
+  const minCol = Math.min(start.col, end.col);
+  const maxCol = Math.max(start.col, end.col);
+  const minRow = Math.min(start.row, end.row);
+  const maxRow = Math.max(start.row, end.row);
+
+  const cells: string[] = [];
+  for (let row = minRow; row <= maxRow; row++) {
+    for (let col = minCol; col <= maxCol; col++) {
+      cells.push(buildCellRef(col, row));
+    }
+  }
+  return cells;
+}
