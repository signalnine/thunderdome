+import { Token, TokenType } from './types.js';
+
+/**
+ * Tokenize a formula string (without the leading '=').
+ */
+export function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let pos = 0;
+
+  while (pos < input.length) {
+    const ch = input[pos];
+
+    // Skip whitespace
+    if (ch === ' ' || ch === '\t') {
+      pos++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      pos++;
+      let str = '';
+      while (pos < input.length && input[pos] !== '"') {
+        str += input[pos];
+        pos++;
+      }
+      if (pos >= input.length) {
+        throw new Error('Unterminated string literal');
+      }
+      pos++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    // Number
+    if (ch >= '0' && ch <= '9') {
+      let num = '';
+      while (pos < input.length && ((input[pos] >= '0' && input[pos] <= '9') || input[pos] === '.')) {
+        num += input[pos];
+        pos++;
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
+
+    // Identifiers, cell references, booleans, function names
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let ident = '';
+      while (pos < input.length && (
+        (input[pos] >= 'A' && input[pos] <= 'Z') ||
+        (input[pos] >= 'a' && input[pos] <= 'z') ||
+        (input[pos] >= '0' && input[pos] <= '9')
+      )) {
+        ident += input[pos];
+        pos++;
+      }
+
+      const upper = ident.toUpperCase();
+
+      // Check for booleans
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: TokenType.Boolean, value: upper });
+        continue;
+      }
+
+      // Check if it looks like a cell reference (letters followed by digits)
+      if (/^[A-Za-z]+\d+$/.test(ident)) {
+        tokens.push({ type: TokenType.CellRef, value: upper });
+        continue;
+      }
+
+      // Otherwise it's an identifier (function name)
+      tokens.push({ type: TokenType.Ident, value: upper });
+      continue;
+    }
+
+    // Operators and punctuation
+    switch (ch) {
+      case '+':
+        tokens.push({ type: TokenType.Plus, value: '+' });
+        pos++;
+        break;
+      case '-':
+        tokens.push({ type: TokenType.Minus, value: '-' });
+        pos++;
+        break;
+      case '*':
+        tokens.push({ type: TokenType.Star, value: '*' });
+        pos++;
+        break;
+      case '/':
+        tokens.push({ type: TokenType.Slash, value: '/' });
+        pos++;
+        break;
+      case '(':
+        tokens.push({ type: TokenType.LParen, value: '(' });
+        pos++;
+        break;
+      case ')':
+        tokens.push({ type: TokenType.RParen, value: ')' });
+        pos++;
+        break;
+      case ',':
+        tokens.push({ type: TokenType.Comma, value: ',' });
+        pos++;
+        break;
+      case ':':
+        tokens.push({ type: TokenType.Colon, value: ':' });
+        pos++;
+        break;
+      case '>':
+        if (pos + 1 < input.length && input[pos + 1] === '=') {
+          tokens.push({ type: TokenType.Gte, value: '>=' });
+          pos += 2;
+        } else {
+          tokens.push({ type: TokenType.Gt, value: '>' });
+          pos++;
+        }
+        break;
+      case '<':
+        if (pos + 1 < input.length && input[pos + 1] === '=') {
+          tokens.push({ type: TokenType.Lte, value: '<=' });
+          pos += 2;
+        } else if (pos + 1 < input.length && input[pos + 1] === '>') {
+          tokens.push({ type: TokenType.Neq, value: '<>' });
+          pos += 2;
+        } else {
+          tokens.push({ type: TokenType.Lt, value: '<' });
+          pos++;
+        }
+        break;
+      case '=':
+        tokens.push({ type: TokenType.Eq, value: '=' });
+        pos++;
+        break;
+      default:
+        throw new Error(`Unexpected character: '${ch}' at position ${pos}`);
+    }
+  }
+
+  tokens.push({ type: TokenType.EOF, value: '' });
+  return tokens;
+}
diff --git a/src/parser.ts b/src/parser.ts
new file mode 100644
index 0000000..c2a0ed5
--- /dev/null
+++ b/src/parser.ts
@@ -0,0 +1,173 @@
+import { Token, TokenType, ASTNode } from './types.js';
+import { tokenize } from './lexer.js';
+
+/**
+ * Parse a formula string (without leading '=') into an AST.
+ */
+export function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  const ast = parser.parseExpression();
+  if (parser.peek().type !== TokenType.EOF) {
+    throw new Error(`Unexpected token: ${parser.peek().value}`);
+  }
+  return ast;
+}
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  advance(): Token {
+    const token = this.tokens[this.pos];
+    this.pos++;
+    return token;
+  }
+
+  expect(type: TokenType): Token {
+    const token = this.peek();
+    if (token.type !== type) {
+      throw new Error(`Expected ${type} but got ${token.type} (${token.value})`);
+    }
+    return this.advance();
+  }
+
+  // Expression: comparison
+  parseExpression(): ASTNode {
+    return this.parseComparison();
+  }
+
+  // Comparison: addition (('>' | '<' | '>=' | '<=' | '=' | '<>') addition)*
+  parseComparison(): ASTNode {
+    let left = this.parseAddition();
+
+    while (
+      this.peek().type === TokenType.Gt ||
+      this.peek().type === TokenType.Lt ||
+      this.peek().type === TokenType.Gte ||
+      this.peek().type === TokenType.Lte ||
+      this.peek().type === TokenType.Eq ||
+      this.peek().type === TokenType.Neq
+    ) {
+      const op = this.advance();
+      const right = this.parseAddition();
+      left = { type: 'binary', op: op.value, left, right };
+    }
+
+    return left;
+  }
+
+  // Addition: multiplication (('+' | '-') multiplication)*
+  parseAddition(): ASTNode {
+    let left = this.parseMultiplication();
+
+    while (
+      this.peek().type === TokenType.Plus ||
+      this.peek().type === TokenType.Minus
+    ) {
+      const op = this.advance();
+      const right = this.parseMultiplication();
+      left = { type: 'binary', op: op.value, left, right };
+    }
+
+    return left;
+  }
+
+  // Multiplication: unary (('*' | '/') unary)*
+  parseMultiplication(): ASTNode {
+    let left = this.parseUnary();
+
+    while (
+      this.peek().type === TokenType.Star ||
+      this.peek().type === TokenType.Slash
+    ) {
+      const op = this.advance();
+      const right = this.parseUnary();
+      left = { type: 'binary', op: op.value, left, right };
+    }
+
+    return left;
+  }
+
+  // Unary: ('-' | '+') unary | primary
+  parseUnary(): ASTNode {
+    if (this.peek().type === TokenType.Minus) {
+      this.advance();
+      const operand = this.parseUnary();
+      return { type: 'unary', op: '-', operand };
+    }
+    if (this.peek().type === TokenType.Plus) {
+      this.advance();
+      return this.parseUnary();
+    }
+    return this.parsePrimary();
+  }
+
+  // Primary: number | string | boolean | cellref (possibly range) | function call | '(' expr ')'
+  parsePrimary(): ASTNode {
+    const token = this.peek();
+
+    switch (token.type) {
+      case TokenType.Number: {
+        this.advance();
+        return { type: 'number', value: parseFloat(token.value) };
+      }
+
+      case TokenType.String: {
+        this.advance();
+        return { type: 'string', value: token.value };
+      }
+
+      case TokenType.Boolean: {
+        this.advance();
+        return { type: 'boolean', value: token.value === 'TRUE' };
+      }
+
+      case TokenType.CellRef: {
+        this.advance();
+        // Check if this is a range (cellref:cellref)
+        if (this.peek().type === TokenType.Colon) {
+          this.advance(); // consume ':'
+          const endToken = this.expect(TokenType.CellRef);
+          return { type: 'range', start: token.value, end: endToken.value };
+        }
+        return { type: 'cellref', ref: token.value };
+      }
+
+      case TokenType.Ident: {
+        // Function call: IDENT '(' args ')'
+        this.advance();
+        this.expect(TokenType.LParen);
+        const args: ASTNode[] = [];
+        if (this.peek().type !== TokenType.RParen) {
+          args.push(this.parseExpression());
+          while (this.peek().type === TokenType.Comma) {
+            this.advance();
+            args.push(this.parseExpression());
+          }
+        }
+        this.expect(TokenType.RParen);
+        return { type: 'function', name: token.value, args };
+      }
+
+      case TokenType.LParen: {
+        this.advance();
+        const expr = this.parseExpression();
+        this.expect(TokenType.RParen);
+        return expr;
+      }
+
+      default:
+        throw new Error(`Unexpected token: ${token.type} (${token.value})`);
+    }
+  }
+}
