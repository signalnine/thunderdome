anges', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n    });\n\n    it('should handle chain of dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', '=A1*2');\n      sheet.set('A3', '=A2+10');\n      expect(sheet.get('A2')).toBe(10);\n      expect(sheet.get('A3')).toBe(20);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('A2')).toBe(20);\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('should handle diamond dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=A1+2');\n      sheet.set('D1', '=B1+C1');\n      expect(sheet.get('D1')).toBe(23);\n\n      sheet.set('A1', 20);\n      expect(sheet.get('B1')).toBe(21);\n      expect(sheet.get('C1')).toBe(22);\n      expect(sheet.get('D1')).toBe(43);\n    });\n\n    it('should update SUM when a cell in the range changes', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(60);\n\n      sheet.set('A2', 50);\n      expect(sheet.get('B1')).toBe(90);\n    });\n\n    it('should update IF when condition changes', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('small');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('B1')).toBe('big');\n    });\n\n    it('should handle updating a formula cell', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', '=A1+5');\n      expect(sheet.get('A2')).toBe(15);\n\n      sheet.set('A2', '=A1*3');\n   