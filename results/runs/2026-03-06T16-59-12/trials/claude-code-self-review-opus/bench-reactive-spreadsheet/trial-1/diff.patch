new file mode 100644
index 0000000..a836ae7
--- /dev/null
+++ b/src/evaluator.ts
@@ -0,0 +1,181 @@
+import { ASTNode, CellValue } from './types.js';
+import { expandRange } from './cellref.js';
+
+export type CellGetter = (ref: string) => CellValue;
+
+/**
+ * Evaluate an AST node, using the provided cell getter for cell references.
+ */
+export function evaluate(node: ASTNode, getCell: CellGetter): CellValue {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+
+    case 'string':
+      return node.value;
+
+    case 'boolean':
+      return node.value;
+
+    case 'cellref':
+      return getCell(node.ref);
+
+    case 'range':
+      throw new Error('Range can only be used as a function argument');
+
+    case 'unary': {
+      const operand = evaluate(node.operand, getCell);
+      if (node.op === '-') {
+        return -(toNumber(operand));
+      }
+      return toNumber(operand);
+    }
+
+    case 'binary':
+      return evaluateBinaryOp(node.op, node.left, node.right, getCell);
+
+    case 'function':
+      return evaluateFunction(node.name, node.args, getCell);
+  }
+}
+
+function toNumber(value: CellValue): number {
+  if (typeof value === 'number') return value;
+  if (typeof value === 'boolean') return value ? 1 : 0;
+  if (typeof value === 'string') {
+    const n = parseFloat(value);
+    if (!isNaN(n)) return n;
+    return 0;
+  }
+  return 0;
+}
+
+function evaluateBinaryOp(op: string, left: ASTNode, right: ASTNode, getCell: CellGetter): CellValue {
+  const leftVal = evaluate(left, getCell);
+  const rightVal = evaluate(right, getCell);
+
+  switch (op) {
+    case '+':
+      return toNumber(leftVal) + toNumber(rightVal);
+    case '-':
+      return toNumber(leftVal) - toNumber(rightVal);
+    case '*':
+      return toNumber(leftVal) * toNumber(rightVal);
+    case '/': {
+      const divisor = toNumber(rightVal);
+      if (divisor === 0) {
+        throw new Error('Division by zero');
+      }
+      return toNumber(leftVal) / divisor;
+    }
+    case '>':
+      return toNumber(leftVal) > toNumber(rightVal);
+    case '<':
+      return toNumber(leftVal) < toNumber(rightVal);
+    case '>=':
+      return toNumber(leftVal) >= toNumber(rightVal);
+    case '<=':
+      return toNumber(leftVal) <= toNumber(rightVal);
+    case '=':
+      return leftVal === rightVal;
+    case '<>':
+      return leftVal !== rightVal;
+    default:
+      throw new Error(`Unknown operator: ${op}`);
+  }
+}
+
+/**
+ * Resolve a function argument that could be a range into an array of values.
+ */
+function resolveRangeValues(arg: ASTNode, getCell: CellGetter): CellValue[] {
+  if (arg.type === 'range') {
+    const cells = expandRange(arg.start, arg.end);
+    return cells.map(ref => getCell(ref));
+  }
+  return [evaluate(arg, getCell)];
+}
+
+function evaluateFunction(name: string, args: ASTNode[], getCell: CellGetter): CellValue {
+  switch (name) {
+    case 'SUM': {
+      if (args.length === 0) throw new Error('SUM requires at least one argument');
+      let sum = 0;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCell);
+        for (const v of values) {
+          if (typeof v === 'number') sum += v;
+          else if (typeof v === 'boolean') sum += v ? 1 : 0;
+        }
+      }
+      return sum;
+    }
+
+    case 'AVERAGE': {
+      if (args.length === 0) throw new Error('AVERAGE requires at least one argument');
+      let sum = 0;
+      let count = 0;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCell);
+        for (const v of values) {
+          if (typeof v === 'number') {
+            sum += v;
+            count++;
+          }
+        }
+      }
+      if (count === 0) return 0;
+      return sum / count;
+    }
+
+    case 'MIN': {
+      if (args.length === 0) throw new Error('MIN requires at least one argument');
+      let min = Infinity;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCell);
+        for (const v of values) {
+          if (typeof v === 'number' && v < min) min = v;
+        }
+      }
+      return min === Infinity ? 0 : min;
+    }
+
+    case 'MAX': {
+      if (args.length === 0) throw new Error('MAX requires at least one argument');
+      let max = -Infinity;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCell);
+        for (const v of values) {
+          if (typeof v === 'number' && v > max) max = v;
+        }
+      }
+      return max === -Infinity ? 0 : max;
+    }
+
+    case 'COUNT': {
+      if (args.length === 0) throw new Error('COUNT requires at least one argument');
+      let count = 0;
+      for (const arg of args) {
+        const values = resolveRangeValues(arg, getCell);
+        for (const v of values) {
+          if (typeof v === 'number') count++;
+        }
+      }
+      return count;
+    }
+
+    case 'IF': {
+      if (args.length !== 3) throw new Error('IF requires exactly 3 arguments');
+      const condition = evaluate(args[0], getCell);
+      const isTruthy = typeof condition === 'boolean' ? condition : !!condition;
+      if (isTruthy) {
+        return evaluate(args[1], getCell);
+      } else {
+        return evaluate(args[2], getCell);
+      }
+    }
+
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
