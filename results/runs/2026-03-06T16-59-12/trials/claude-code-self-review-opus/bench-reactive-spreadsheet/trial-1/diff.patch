+import { CellValue, CellInput, ASTNode } from './types.js';
+import { parseFormula } from './parser.js';
+import { evaluate } from './evaluator.js';
+import { normalizeCellRef, expandRange } from './cellref.js';
+
+interface CellData {
+  raw: CellInput;
+  formula: ASTNode | null;
+  value: CellValue;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Maps a cell to the set of cells it depends on
+  private dependencies: Map<string, Set<string>> = new Map();
+  // Maps a cell to the set of cells that depend on it (reverse index)
+  private dependents: Map<string, Set<string>> = new Map();
+
+  /**
+   * Set a cell's value. Can be a raw value or a formula string starting with '='.
+   */
+  set(cell: string, value: CellInput): void {
+    const ref = normalizeCellRef(cell);
+
+    // Parse formula if it's a formula string
+    let formula: ASTNode | null = null;
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.substring(1));
+    }
+
+    // Compute new dependencies before setting
+    const newDeps = formula ? this.collectDependencies(formula) : new Set<string>();
+
+    // Check for circular references before applying
+    this.checkCircular(ref, newDeps);
+
+    // Remove old reverse dependency entries
+    const oldDeps = this.dependencies.get(ref);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        const revDeps = this.dependents.get(dep);
+        if (revDeps) {
+          revDeps.delete(ref);
+        }
+      }
+    }
+
+    // Set new dependencies
+    this.dependencies.set(ref, newDeps);
+
+    // Add new reverse dependency entries
+    for (const dep of newDeps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Compute value
+    const computed = formula
+      ? this.evaluateFormula(formula)
+      : (typeof value === 'string' && !value.startsWith('=') ? value : value);
+
+    // Store cell data
+    this.cells.set(ref, {
+      raw: value,
+      formula,
+      value: computed as CellValue,
+    });
+
+    // Propagate updates to dependent cells
+    this.propagateUpdates(ref);
+  }
+
+  /**
+   * Get a cell's computed value. Returns null for empty cells.
+   */
+  get(cell: string): CellValue {
+    const ref = normalizeCellRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  /**
+   * Get the display string for a cell's computed value.
+   */
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';
+    return String(value);
+  }
+
+  /**
+   * Get all non-empty cells as a Map from cell reference to computed value.
+   */
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  /**
+   * Collect all cell references that a formula depends on.
+   */
+  private collectDependencies(node: ASTNode): Set<string> {
+    const deps = new Set<string>();
+    this.collectDepsRecursive(node, deps);
+    return deps;
+  }
+
+  private collectDepsRecursive(node: ASTNode, deps: Set<string>): void {
+    switch (node.type) {
+      case 'cellref':
+        deps.add(node.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(node.start, node.end);
+        for (const ref of cells) {
+          deps.add(ref);
+        }
+        break;
+      }
+      case 'binary':
+        this.collectDepsRecursive(node.left, deps);
+        this.collectDepsRecursive(node.right, deps);
+        break;
+      case 'unary':
+        this.collectDepsRecursive(node.operand, deps);
+        break;
+      case 'function':
+        for (const arg of node.args) {
+          this.collectDepsRecursive(arg, deps);
+        }
+        break;
+      // number, string, boolean have no dependencies
+    }
+  }
+
+  /**
+   * Check if setting a cell with the given dependencies would create a cycle.
+   * Uses DFS through the dependents graph starting from each dependency.
+   */
+  private checkCircular(targetRef: string, newDeps: Set<string>): void {
+    // Check if targetRef is in its own dependencies (direct self-reference)
+    if (newDeps.has(targetRef)) {
+      throw new Error(`Circular reference detected: ${targetRef} references itself`);
+    }
+
+    // For each dependency, check if targetRef can be reached through the dependents graph
+    // i.e., if any dependency transitively depends on targetRef
+    const visited = new Set<string>();
+
+    const hasCycle = (current: string): boolean => {
+      if (current === targetRef) return true;
+      if (visited.has(current)) return false;
+      visited.add(current);
+
+      const deps = this.dependencies.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (hasCycle(dep)) return true;
+        }
+      }
+      return false;
+    };
+
+    for (const dep of newDeps) {
+      visited.clear();
+      if (hasCycle(dep)) {
+        throw new Error(`Circular reference detected involving ${targetRef}`);
+      }
+    }
+  }
+
+  /**
+   * Evaluate a formula AST using current cell values.
+   */
+  private evaluateFormula(formula: ASTNode): CellValue {
+    return evaluate(formula, (ref: string) => {
+      const data = this.cells.get(ref);
+      return data ? data.value : null;
+    });
+  }
+
+  /**
+   * Recompute all cells that directly or transitively depend on the changed cell.
+   * Uses topological ordering to ensure correct evaluation order.
+   */
+  private propagateUpdates(changedRef: string): void {
+    // Collect all affected cells in topological order using BFS
+    const order = this.topologicalSort(changedRef);
+
+    // Recompute each cell in order (skip the changed cell itself)
+    for (const ref of order) {
+      if (ref === changedRef) continue;
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        data.value = this.evaluateFormula(data.formula);
+      }
+    }
+  }
+
+  /**
+   * Topological sort of all cells that depend on the given cell.
+   */
+  private topologicalSort(startRef: string): string[] {
+    const visited = new Set<string>();
+    const order: string[] = [];
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      order.push(ref);
+
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+    };
+
+    visit(startRef);
+    return order;
+  }
+}
