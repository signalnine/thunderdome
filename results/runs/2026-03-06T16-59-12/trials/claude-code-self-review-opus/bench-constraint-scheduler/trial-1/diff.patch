@@ -0,0 +1,153 @@
+/**
+ * Discovery layer for the constraint scheduler implementation.
+ *
+ * Dynamically imports from ../src/ and tries to find the schedule function
+ * regardless of how the implementor exported it. Supports:
+ *   - Named export `schedule` function
+ *   - Default export function
+ *   - `Scheduler` class with a `schedule` method
+ *   - Factory functions like `createScheduler`
+ */
+
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+export type ScheduleFn = (events: Event[], rooms: Room[], options: ScheduleOptions) => ScheduleResult;
+
+/**
+ * Try multiple import paths until one works.
+ */
+async function tryImport(): Promise<any> {
+  const paths = [
+    '../src/index.js',
+    '../src/scheduler.js',
+    '../src/index.ts',
+    '../src/scheduler.ts',
+  ];
+  for (const p of paths) {
+    try {
+      return await import(p);
+    } catch {
+      // try next
+    }
+  }
+  throw new Error('Could not import scheduler from any of: ' + paths.join(', '));
+}
+
+export async function discover(): Promise<ScheduleFn> {
+  const mod = await tryImport();
+
+  // 1. Named export `schedule`
+  if (typeof mod.schedule === 'function') {
+    return mod.schedule as ScheduleFn;
+  }
+
+  // 2. Scheduler class with schedule method
+  const classNames = ['Scheduler', 'EventScheduler', 'ConstraintScheduler', 'RoomScheduler'];
+  for (const name of classNames) {
+    if (mod[name] && typeof mod[name] === 'function') {
+      try {
+        const instance = new mod[name]();
+        if (typeof instance.schedule === 'function') {
+          return (events: Event[], rooms: Room[], options: ScheduleOptions) =>
+            instance.schedule(events, rooms, options);
+        }
+      } catch {
+        // not a constructor, try as factory
+        try {
+          const instance = mod[name]();
+          if (instance && typeof instance.schedule === 'function') {
+            return (events: Event[], rooms: Room[], options: ScheduleOptions) =>
+              instance.schedule(events, rooms, options);
+          }
+        } catch {
+          // skip
+        }
+      }
+    }
+  }
+
+  // 3. Factory functions
+  const factoryNames = ['createScheduler', 'createEventScheduler', 'makeScheduler', 'scheduler'];
+  for (const name of factoryNames) {
+    if (typeof mod[name] === 'function') {
+      const result = mod[name]();
+      if (typeof result === 'function') {
+        return result as ScheduleFn;
+      }
+      if (result && typeof result.schedule === 'function') {
+        return (events: Event[], rooms: Room[], options: ScheduleOptions) =>
+          result.schedule(events, rooms, options);
+      }
+    }
+  }
+
+  // 4. Default export
+  const def = mod.default;
+  if (def) {
+    // Default is the schedule function itself
+    if (typeof def === 'function') {
+      // Check if it's a class with a schedule method
+      try {
+        const instance = new def();
+        if (typeof instance.schedule === 'function') {
+          return (events: Event[], rooms: Room[], options: ScheduleOptions) =>
+            instance.schedule(events, rooms, options);
+        }
+      } catch {
+        // It's a plain function, use it directly
+        return def as ScheduleFn;
+      }
+    }
+    // Default is an object with a schedule method
+    if (typeof def === 'object' && typeof def.schedule === 'function') {
+      return (events: Event[], rooms: Room[], options: ScheduleOptions) =>
+        def.schedule(events, rooms, options);
+    }
+  }
+
+  // 5. Look for any exported function that could be the scheduler
+  for (const key of Object.keys(mod)) {
+    if (typeof mod[key] === 'function' && key !== 'default') {
+      // Heuristic: function that takes 3 args
+      if (mod[key].length >= 2) {
+        return mod[key] as ScheduleFn;
+      }
+    }
+  }
+
+  throw new Error(
+    'Could not find a schedule function. Tried: named export "schedule", ' +
+    'Scheduler/EventScheduler classes, createScheduler factory, and default export.'
+  );
+}
