  });\n   539→\n   540→  it('test 18: prerequisites + capacity constraints together', () => {\n   541→    // Chain: Setup -> Demo -> Review\n   542→    // Setup needs small room (5 attendees), Demo needs big room (30), Review needs small (5).\n   543→    // Only R1 (capacity 50) fits Demo.\n   544→    const events: Event[] = [\n   545→      { id: 'setup', name: 'Setup', duration: 45, attendees: 5 },\n   546→      { id: 'demo', name: 'Demo', duration: 90, attendees: 30 },\n   547→      { id: 'review', name: 'Review', duration: 45, attendees: 5, prerequisites: ['demo'] },\n   548→      { id: 'prep', name: 'Prep', duration: 45, attendees: 5, prerequisites: ['setup'] },\n   549→    ];\n   550→    // demo depends on nothing, but prep depends on setup\n   551→    // Rewrite: setup -> prep, setup -> demo (parallel), demo -> review\n   552→    const eventsFixed: Event[] = [\n   553→      { id: 'setup', name: 'Setup', duration: 45, attendees: 5 },\n   554→      { id: 'demo', name: 'Demo', duration: 90, attendees: 30, prerequisites: ['setup'] },\n   555→      { id: 'review', name: 'Review', duration: 45, attendees: 5, prerequisites: ['demo'] },\n   556→      { id: 'prep', name: 'Prep', duration: 45, attendees: 5 },\n   557→    ];\n   558→    const rooms: Room[] = [\n   559→      { id: 'R1', name: 'Auditorium', capacity: 50 },\n   560→      { id: 'R2', name: 'Huddle Room', capacity: 8 },\n   561→    ];\n   562→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n   563→\n   564→    const result = schedule(eventsFixed, rooms, opts);\n   565→\n   566→    expect(result.assignments).toHaveLength(4);\n   567→    expect(result.unscheduled).toHaveLength(0);\n   568→    assertPrerequisites(result, eventsFixed, 15);\n   569→    assertCapacity(result, eventsFixed, rooms);\n   570→    assertInWindow(result, opts);\n   571→\n   572→    // Verify demo is in R1 (only room big enough)\n   573→    const demoAssignment = result.assignments.find(a => a.eventId === 'demo');\n   574→    expect(demoAssignment).toBeDefined();\n   575→    expect(demoAssignment!.roomId).toBe('R1');\n   576→  });\n   577→\n   578→  it('test 19: preferred room honored when possible', () => {\n   579→    const events: Event[] = [\n   580→      { id: 'E1', name: 'Preferred Event', duration: 60, attendees: 5, preferredRoom: 'R2' },\n   581→      { id: 'E2', name: 'Other Event', duration: 60, attendees: 5 },\n   582→    ];\n   583→    const rooms: Room[] = [\n   584→      { id: 'R1', name: 'Room 1', capacity: 20 },\n   585→      { id: 'R2', name: 'Room 2', capacity: 20 },\n   586→    ];\n   587→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n   588→\n   589→    const result = schedule(events, rooms, opts);\n   590→\n   591→    expect(result.assignments).toHaveLength(2);\n   592→    expect(result.unscheduled).toHaveLength(0);\n   593→\n   594→    const e1Assign = result.assignments.find(a => a.eventId === 'E1');\n   595→    expect(e1Assign).toBeDefined();\n   596→    expect(e1Assign!.roomId).toBe('R2');\n   597→  });\n   598→\n   599→  it('test 20: gap applies between prerequisite events', () => {\n   600→    // A -> B. Even if different rooms, B can't start until A finishes + gap.\n   601→    const events: Event[] = [\n   602→      { id: 'A', name: 'First', duration: 60, attendees: 5 },\n   603→      { id: 'B', name: 'Second', duration: 60, attendees: 5, prerequisites: ['A'] },\n   604→    ];\n   605→    const rooms: Room[] = [\n   606→      { id: 'R1', name: 'Room 1', capacity: 20 },\n   607→      { id: 'R2', name: 'Room 2', capacity: 20 },\n   608→    ];\n   609→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };\n   610→\n   611→    const result = schedule(events, rooms, opts);\n   612→\n   613→    expect(result.assignments).toHaveLength(2);\n   614→    expect(result.unscheduled).toHaveLength(0);\n   615→\n   616→    const aAssign = result.assignments.find(a => a.eventId === 'A')!;\n   617→    const bAssign = result.assignments.find(a => a.eventId === 'B')!;\n   618→\n   619→    // B must start at least gap (30 min) after A ends\n   620→    expect(bAssign.startTime).toBeGreaterThanOrEqual(aAssign.endTime + 30);\n   621→  });\n   622→});\n   623→\n   624→// ============================================================\n   625→// Group 5: Hard tests — scaling, optimality, edge precision\n   626→// ============================================================\n   627→describe('Group 5: Hard tests', () => {\n   628→\n   629→  it('test 21: scaling stress — 30 events, 5 rooms, prerequisite chains (must complete < 5s)', () => {\n   630→    // 5 chains of 3 events each (15 chain events) + 15 independent \"filler\" events.\n   631→    // Chains require sequential ordering; fillers go wherever they fit.\n   632→    // 5 rooms with varying capacity: only R1 (cap 50) fits the \"big\" chain heads.\n   633→    // Each chain: head (big, 50 attendees), step2 (medium, 15 attendees), step3 (small, 5 attendees).\n   634→    // Fillers: 5 attendees each, 40 min each.\n   635→    // Window: 540-1080 (540 min), gap 10.\n   636→    //\n   637→    // Chain events: 60 min each. Chain timing: 60+10+60+10+60 = 200 min per chain.\n   638→    // 5 chains can interleave across rooms since chain members can go in different rooms\n   639→    // (only heads need R1, and R1 has 540 min: 5 x 60 + 4 x 10 = 340, fits).\n   640→    // Filler events: 15 events x 40 min. With gap 10: each room slot is 50 min.\n   641→    // Across 5 rooms after chain events are placed, plenty of space.\n   642→    //\n   643→    // Key test: algorithm must handle 30 events without exponential blowup.\n   644→\n   645→    const events: Event[] = [];\n   646→\n   647→    // 5 prerequisite chains\n   648→    for (let c = 1; c <= 5; c++) {\n   649→      events.push({ id: `C${c}A`, name: `Chain ${c} Head`, duration: 60, attendees: 50 });\n   650→      events.push({ id: `C${c}B`, name: `Chain ${c} Step 2`, duration: 60, attendees: 15, prerequisites: [`C${c}A`] });\n   651→      events.push({ id: `C${c}C`, name: `Chain ${c} Step 3`, duration: 60, attendees: 5, prerequisites: [`C${c}B`] });\n   652→    }\n   653→\n   654→    // 15 independent filler events\n   655→    for (let f = 1; f <= 15; f++) {\n   656→      events.push({ id: `F${f}`, name: `Filler ${f}`, duration: 40, attendees: 5 });\n   657→    }\n   658→\n   659→    const rooms: Room[] = [\n   660→      { id: 'R1', name: 'Grand Hall', capacity: 50 },\n   661→      { id: 'R2', name: 'Conference A', capacity: 20 },\n   662→      { id: 'R3', name: 'Conference B', capacity: 20 },\n   663→      { id: 'R4', name: 'Meeting Room A', capacity: 10 },\n   664→      { id: 'R5', name: 'Meeting Room B', capacity: 10 },\n   665→    ];\n   666→    const opts: ScheduleOptions = { startTime: 540, endTime: 1080, gap: 10 };\n   667→\n   668→    const t0 = performance.now();\n   669→    const result = schedule(events, rooms, opts);\n   670→    const elapsed = performance.now() - t0;\n   671→\n   672→    // Must complete in under 5 seconds\n   673→    expect(elapsed, `Took ${elapsed.toFixed(0)}ms, must be < 5000ms`).toBeLessThan(5000);\n   674→\n   675→    // All 30 events should be schedulable\n   676→    expect(result.assignments.length).toBe(30);\n   677→    expect(result.unscheduled).toHaveLength(0);\n   678→    assertInWindow(result, opts);\n   679→    assertNoOverlap(result, 10);\n   680→    assertCapacity(result, events, rooms);\n   681→    assertPrerequisites(result, events, 10);\n   682→\n   683→    // Verify chain heads are in R1 (only room with capacity 50)\n   684→    for (let c = 1; c <= 5; c++) {\n   685→      const headAssign = result.assignments.find(a => a.eventId === `C${c}A`);\n   686→      expect(headAssign, `Chain ${c} head should be assigned`).toBeDefined();\n   687→      expect(headAssign!.roomId, `Chain ${c} head must be in R1 (only room cap >= 50)`).toBe('R1');\n   688→    }\n   689→  });\n   690→\n   691→  it('test 22: optimality — 8 events, 3 rooms, greedy gets 6 but optimal gets 8', () => {\n   692→    // Setup: 3 rooms, 8 events. A naive approach that greedily assigns events by ID order\n   693→    // will waste room capacity, leaving 2 events unscheduled.\n   694→    //\n   695→    // R1 (cap 40): only room for XL events (30 attendees)\n   696→    // R2 (cap 15): fits medium events (12 attendees) and small (5)\n   697→    // R3 (cap 8):  fits small events only (5 attendees)\n   698→    //\n   699→    // Events:\n   700→    //   A1, A2: XL (30 attendees, 120 min) — MUST go in R1\n   701→    //   B1, B2: medium (12 attendees, 120 min) — R1 or R2\n   702→    //   C1, C2, C3, C4: small (5 attendees, 120 min) — any room\n   703→    //\n   704→    // Window: 540-810 (270 min), gap 15. Each room fits 2 events: 120+15+120 = 255 <= 270.\n   705→    //\n   706→    // Greedy by ID (A1, A2, B1, B2, C1-C4):\n   707→    //   A1 -> R1(540-660), A2 -> R1(675-795). R1 full.\n   708→    //   B1 -> R2(540-660), B2 -> R2(675-795). R2 full.\n   709→    //   C1 -> R3(540-660), C2 -> R3(675-795). R3 full.\n   710→    //   C3 -> no room. Unscheduled!\n   711→    //   C4 -> no room. Unscheduled!\n   712→    //   Result: 6/8.\n   713→    //\n   714→    // Optimal:\n   715→    //   R1: A1(540-660), A2(675-795) — XL events in the only room that fits them\n   716→    //   R2: B1(540-660), B2(675-795) — medium events\n   717→    //   R3: C1(540-660), C2(675-795) — small events\n   718→    //   Wait, that's still 6. We need to rethink...\n   719→    //\n   720→    // Revised: make it so the greedy assigns B events to R1 first, wasting R1 for XL events.\n   721→    // Events in alphabetical order: B1, B2, C1, C2, C3, C4, X1, X2\n   722→    // B events come first alphabetically, get placed in R1.\n   723→    // Then X1, X2 (XL, 30 attendees) can't fit anywhere.\n   724→    //\n   725→    // Actually, let me reconsider. Greedy by ID order:\n   726→    //   B1 (12 att) -> R1(540-660) [first room that fits]\n   727→    //   B2 (12 att) -> R1(675-795) [R1 still has slot]\n   728→    //   C1 (5 att) -> R2(540-660)\n   729→    //   C2 (5 att) -> R2(675-795)\n   730→    //   C3 (5 att) -> R3(540-660)\n   731→    //   C4 (5 att) -> R3(675-795)\n   732→    //   X1 (30 att) -> R1 full. R2 cap 15 < 30. R3 cap 8 < 30. Unscheduled!\n   733→    //   X2 (30 att) -> same. Unscheduled!\n   734→    //   Result: 6/8.\n   735→    //\n   736→    // Optimal:\n   737→    //   R1: X1(540-660), X2(675-795)\n   738→    //   R2: B1(540-660), B2(675-795)\n   739→    //   R3: C1(540-660), C2(675-795)\n   740→    //   Remaining: C3, C4 — wait, 8 events total. R1 has 2, R2 has 2, R3 has 2 = 6. Still 6!\n   741→    //\n   742→    // Need more room capacity. Let's use 4 rooms with 2 slots each = 8 slots total.\n   743→    // R1 (cap 40), R2 (cap 15), R3 (cap 8), R4 (cap 8). Each fits 2 events.\n   744→    //   Optimal: R1: X1, X2. R2: B1, B2. R3: C1, C2. R4: C3, C4. All 8!\n   745→    //   Greedy: B1->R1, B2->R1, C1->R2, C2->R2, C3->R3, C4->R3, X1->R4(cap 8 < 30: fail!), X2 fail.\n   746→    //   Greedy: 6/8.\n   747→\n   748→    const events: Event[] = [\n   749→      { id: 'B1', name: 'Medium Talk 1', duration: 120, attendees: 12 },\n   750→      { id: 'B2', name: 'Medium Talk 2', duration: 120, attendees: 12 },\n   751→      { id: 'C1', name: 'Small Talk 1', duration: 120, attendees: 5 },\n   752→      { id: 'C2', name: 'Small Talk 2', duration: 120, attendees: 5 },\n   753→      { id: 'C3', name: 'Small Talk 3', duration: 120, attendees: 5 },\n   754→      { id: 'C4', name: 'Small Talk 4', duration: 120, attendees: 5 },\n   755→      { id: 'X1', name: 'Keynote 1', duration: 120, attendees: 30 },\n   756→      { id: 'X2', name: 'Keynote 2', duration: 120, attendees: 30 },\n   757→    ];\n   758→    const rooms: Room[] = [\n   759→      { id: 'R1', name: 'Grand Hall', capacity: 40 },\n   760→      { id: 'R2', name: 'Conference Room', capacity: 15 },\n   761→      { id: 'R3', name: 'Meeting Room A', capacity: 8 },\n   762→      { id: 'R4', name: 'Meeting Room B', capacity: 8 },\n   763→    ];\n   764→    // 270 min window, 15 gap: each room fits exactly 2 events (120+15+120=255<=270)\n   765→    const opts: ScheduleOptions = { startTime: 540, endTime: 810, gap: 15 };\n   766→\n   767→    const result = schedule(events, rooms, opts);\n   768→\n   769→    // ALL 8 must be scheduled\n   770→    expect(result.assignments.length).toBe(8);\n   771→    expect(result.unscheduled).toHaveLength(0);\n   772→    assertCapacity(result, events, rooms);\n   773→    assertInWindow(result, opts);\n   774→    assertNoOverlap(result, 15);\n   775→\n   776→    // Keynotes MUST be in R1 (only room with capacity >= 30)\n   777→    const x1 = result.assignments.find(a => a.eventId === 'X1');\n   778→    const x2 = result.assignments.find(a => a.eventId === 'X2');\n   779→    expect(x1!.roomId).toBe('R1');\n   780→    expect(x2!.roomId).toBe('R1');\n   781→  });\n   782→\n   783→  it('test 23: tight packing with gaps — 3 events in room with exact-fit window', () => {\n   784→    // Room has exactly enough time for 3 events if gaps are minimized to configured value.\n   785→    // 3 events of 80 min each, gap 10 min.\n   786→    // Total: 80 + 10 + 80 + 10 + 80 = 260 min.\n   787→    // Window: exactly 260 min (540-800).\n   788→    // Must schedule all 3. If the scheduler adds even 1 extra minute of gap, one won't fit.\n   789→\n   790→    const events: Event[] = [\n   791→      { id: 'P1', name: 'Pack 1', duration: 80, attendees: 5 },\n   792→      { id: 'P2', name: 'Pack 2', duration: 80, attendees: 5 },\n   793→      { id: 'P3', name: 'Pack 3', duration: 80, attendees: 5 },\n   794→    ];\n   795→    const rooms: Room[] = [\n   796→      { id: 'R1', name: 'Tight Room', capacity: 10 },\n   797→    ];\n   798→    // Exact fit: 80+10+80+10+80 = 260 min window\n   799→    const opts: ScheduleOptions = { startTime: 540, endTime: 800, gap: 10 };\n   800→\n   801→    const result = schedule(events, rooms, opts);\n   802→\n   803→    expect(result.assignments.length).toBe(3);\n   804→    expect(result.unscheduled).toHaveLength(0);\n   805→    assertInWindow(result, opts);\n   806→    assertNoOverlap(result, 10);\n   807→\n   808→    // Verify the packing is exact\n   809→    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n   810→    expect(sorted[0].startTime).toBe(540);\n   811→    expect(sorted[0].endTime).toBe(620);\n   812→    expect(sorted[1].startTime).toBe(630); // 620 + 10\n   813→    expect(sorted[1].endTime).toBe(710);\n   814→    expect(sorted[2].startTime).toBe(720); // 710 + 10\n   815→    expect(sorted[2].endTime).toBe(800);\n   816→  });\n   817→\n   818→  it('test 24: prerequisite chain with room capacity mismatch — A(big)->B(small)->C(big)', () => {\n   819→    // Chain A -> B -> C.\n   820→    // A needs big room (20 attendees), B needs small room (3 attendees), C needs big room (20 attendees).\n   821→    // Only 1 big room (R1, cap 25) and 1 small room (R2, cap 5).\n   822→    // The scheduler must assign A->R1, B->R2 (or R1), C->R1, respecting prerequisites.\n   823→    //\n   824→    // Timing: each 60 min, gap 15.\n   825→    // A in R1: 540-600.\n   826→    // B must start >= 615 (600 + 15). B in R2: 615-675. Or B in R1: 615-675.\n   827→    // C must start >= 690 (675 + 15). C in R1: needs 690-750.\n   828→    //   If B was in R1 at 615-675, R1 next slot after gap: 675+15=690. C at 690-750. Works!\n   829→    //   If B was in R2 at 615-675, R1 next slot after A: 600+15=615. C at 615-675. But prereq B ends 675, C needs >= 690. So C in R1 at 690-750. Works!\n   830→    //\n   831→    // Window 540-750 (210 min). 3 events of 60 + 2 gaps of 15 = 210. Exact fit.\n   832→    // Add a filler event D (20 attendees, 60 min) that competes for R1 time.\n   833→    // D has no prereqs, needs R1 (20 > 5).\n   834→    // If D goes in R1 at 540-600, that's A's slot. Conflict!\n   835→    // If D goes in R1 at 615-675, that could block C.\n   836→    //\n   837→    // With window 540-810 (270 min), R1 can fit:\n   838→    //   A(540-600), B or D(615-675), C(690-750), and maybe D(765-825) if window allows to 825.\n   839→    // Window to 810: D at 765-825 exceeds 810. So 4 events need careful arrangement.\n   840→    //\n   841→    // Simpler: window 540-810 (270 min). R1 fits 3 events (60+15+60+15+60=210 <= 270).\n   842→    // A must be in R1 (20 att). C must be in R1 (20 att). D must be in R1 (20 att).\n   843→    // B can go in R2. So R1 has A, C, D = 3 events. B in R2.\n   844→    // Prereq: A before B, B before C. A in R1 at 540-600. B in R2 at 615-675.\n   845→    // C in R1 at 690-750 (after B at 675+15=690). D in R1 at 615-675 (gap after A: 600+15=615).\n   846→    // Check: R1 has A(540-600), D(615-675), C(690-750). No overlap? 600+15=615<=615, 675+15=690<=690. Yes!\n   847→    // All 4 scheduled.\n   848→    //\n   849→    // A greedy might put B in R1 at 615-675 (it fits there), then D can't fit R1\n   850→    // (next R1 slot after B: 690, D at 690-750, C needs R1 after 690 too. C prereq B ends 675+15=690.\n   851→    // C at 690-750 if D not there. But D also at 690-750 = overlap. D at 765-825 > 810. Unscheduled!\n   852→\n   853→    const events: Event[] = [\n   854→      { id: 'A', name: 'Opening Ceremony', duration: 60, attendees: 20 },\n   855→      { id: 'B', name: 'Breakout Session', duration: 60, attendees: 3, prerequisites: ['A'] },\n   856→      { id: 'C', name: 'Closing Ceremony', duration: 60, attendees: 20, prerequisites: ['B'] },\n   857→      { id: 'D', name: 'Exhibition', duration: 60, attendees: 20 },\n   858→    ];\n   859→    const rooms: Room[] = [\n   860→      { id: 'R1', name: 'Main Hall', capacity: 25 },\n   861→      { id: 'R2', name: 'Breakout Room', capacity: 5 },\n   862→    ];\n   863→    // R1 fits 3 events: 60+15+60+15+60 = 210 <= 270\n   864→    const opts: ScheduleOptions = { startTime: 540, endTime: 810, gap: 15 };\n   865→\n   866→    const result = schedule(events, rooms, opts);\n   867→\n   868→    expect(result.assignments.length).toBe(4);\n   869→    expect(result.unscheduled).toHaveLength(0);\n   870→    assertPrerequisites(result, events, 15);\n   871→    assertCapacity(result, events, rooms);\n   872→    assertInWindow(result, opts);\n   873→    assertNoOverlap(result, 15);\n   874→\n   875→    // A, C, D must be in R1 (only room with capacity >= 20)\n   876→    const aAssign = result.assignments.find(a => a.eventId === 'A');\n   877→    const cAssign = result.assignments.find(a => a.eventId === 'C');\n   878→    const dAssign = result.assignments.find(a => a.eventId === 'D');\n   879→    expect(aAssign!.roomId).toBe('R1');\n   880→    expect(cAssign!.roomId).toBe('R1');\n   881→    expect(dAssign!.roomId).toBe('R1');\n   882→\n   883→    // B must be in R2 (to free R1 space for D)\n   884→    const bAssign = result.assignments.find(a => a.eventId === 'B');\n   885→    expect(bAssign!.roomId).toBe('R2');\n   886→  });\n   887→\n   888→  it('test 25: multiple independent groups — 3 clusters with no cross-dependencies', () => {\n   889→    // 3 independent clusters of events with their own prerequisite chains.\n   890→    // Cluster 1: Alpha1 -> Alpha2 -> Alpha3 (big events, 20 att)\n   891→    // Cluster 2: Beta1 -> Beta2 (medium events, 10 att)\n   892→    // Cluster 3: Gamma1, Gamma2, Gamma3 (independent small events, 3 att)\n   893→    //\n   894→    // Rooms: R1 (cap 25), R2 (cap 12), R3 (cap 5).\n   895→    // Alpha cluster must use R1. Beta must use R1 or R2. Gamma can use any room.\n   896→    //\n   897→    // Window: 540-1020 (480 min), gap 15.\n   898→    // R1: Alpha1(540-630), Alpha2(645-735), Alpha3(750-840) = 300 min.\n   899→    //   Still has 840-1020 = 180 min free.\n   900→    // R2: Beta1(540-630), Beta2(645-735) = 195 min. Still has 735-1020 = 285 min free.\n   901→    // R3: Gamma1(540-630), Gamma2(645-735), Gamma3(750-840).\n   902→    //\n   903→    // All 8 events fit easily. The key test is that independent groups don't interfere.\n   904→\n   905→    const events: Event[] = [\n   906→      // Cluster 1: big chain\n   907→      { id: 'Alpha1', name: 'Alpha Step 1', duration: 90, attendees: 20 },\n   908→      { id: 'Alpha2', name: 'Alpha Step 2', duration: 90, attendees: 20, prerequisites: ['Alpha1'] },\n   909→      { id: 'Alpha3', name: 'Alpha Step 3', duration: 90, attendees: 20, prerequisites: ['Alpha2'] },\n   910→      // Cluster 2: medium chain\n   911→      { id: 'Beta1', name: 'Beta Step 1', duration: 90, attendees: 10 },\n   912→      { id: 'Beta2', name: 'Beta Step 2', duration: 90, attendees: 10, prerequisites: ['Beta1'] },\n   913→      // Cluster 3: independent small events\n   914→      { id: 'Gamma1', name: 'Gamma Event 1', duration: 90, attendees: 3 },\n   915→      { id: 'Gamma2', name: 'Gamma Event 2', duration: 90, attendees: 3 },\n   916→      { id: 'Gamma3', name: 'Gamma Event 3', duration: 90, attendees: 3 },\n   917→    ];\n   918→    const rooms: Room[] = [\n   919→      { id: 'R1', name: 'Auditorium', capacity: 25 },\n   920→      { id: 'R2', name: 'Seminar Room', capacity: 12 },\n   921→      { id: 'R3', name: 'Small Room', capacity: 5 },\n   922→    ];\n   923→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n   924→\n   925→    const result = schedule(events, rooms, opts);\n   926→\n   927→    expect(result.assignments.length).toBe(8);\n   928→    expect(result.unscheduled).toHaveLength(0);\n   929→    assertPrerequisites(result, events, 15);\n   930→    assertCapacity(result, events, rooms);\n   931→    assertInWindow(result, opts);\n   932→    assertNoOverlap(result, 15);\n   933→\n   934→    // Verify each cluster's events don't break each other's prerequisites\n   935→    // Alpha chain: Alpha1 before Alpha2 before Alpha3\n   936→    const a1 = result.assignments.find(a => a.eventId === 'Alpha1')!;\n   937→    const a2 = result.assignments.find(a => a.eventId === 'Alpha2')!;\n   938→    const a3 = result.assignments.find(a => a.eventId === 'Alpha3')!;\n   939→    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n   940→    expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n   941→\n   942→    // Beta chain: Beta1 before Beta2\n   943→    const b1 = result.assignments.find(a => a.eventId === 'Beta1')!;\n   944→    const b2 = result.assignments.find(a => a.eventId === 'Beta2')!;\n   945→    expect(b2.startTime).toBeGreaterThanOrEqual(b1.endTime + 15);\n   946→\n   947→    // Alpha events must be in R1 (only room with cap >= 20)\n   948→    expect(a1.roomId).toBe('R1');\n   949→    expect(a2.roomId).toBe('R1');\n   950→    expect(a3.roomId).toBe('R1');\n   951→  });\n   952→\n   953→  it('test 26: preference vs feasibility with prerequisites', () => {\n   954→    // Events prefer rooms they can't actually use due to prerequisite timing constraints.\n   955→    //\n   956→    // Setup: A -> B -> C chain. All prefer R1.\n   957→    // D is independent, large (25 att), MUST use R1.\n   958→    // D is 180 min, takes most of R1's time.\n   959→    //\n   960→    // R1 (cap 30): D fills most of it.\n   961→    // R2 (cap 10): can hold A, B, C (5 att each).\n   962→    //\n   963→    // Window: 540-840 (300 min), gap 15.\n   964→    // D in R1: 540-720 (180 min). R1 remaining after gap: 735-840 = 105 min.\n   965→    // A, B, C are each 60 min. Chain: 60+15+60+15+60 = 210 min. Won't fit in R1's 105 min remainder.\n   966→    // So A, B, C must go to R2 despite preferring R1.\n   967→    // R2: A(540-600), B(615-675), C(690-750). Fits in 300 min window.\n   968→    //\n   969→    // Or: A in R1 first at 540-600. Then D in R1 at 615-795. Then B after A at 615+...\n   970→    // B needs A done at 600+15=615. B in R2 at 615-675. C in R2 at 690-750.\n   971→    // D in R1 at 615-795: fits (795 <= 840). R1 has A(540-600), D(615-795).\n   972→    // That works too: A in R1 (preferred!), B, C in R2. But we need all 4 scheduled.\n   973→    //\n   974→    // Let's make it so all chain events genuinely can't fit in R1.\n   975→    // D is 240 min. R1: D(540-780). Remaining: 780+15=795 to 840 = 45 min. Too short for 60 min events.\n   976→    // Chain events prefer R1 but can't use it (no space after D).\n   977→\n   978→    const events: Event[] = [\n   979→      { id: 'A', name: 'Phase 1', duration: 60, attendees: 5, preferredRoom: 'R1' },\n   980→      { id: 'B', name: 'Phase 2', duration: 60, attendees: 5, preferredRoom: 'R1', prerequisites: ['A'] },\n   981→      { id: 'C', name: 'Phase 3', duration: 60, attendees: 5, preferredRoom: 'R1', prerequisites: ['B'] },\n   982→      { id: 'D', name: 'All-Day Workshop', duration: 240, attendees: 25 },\n   983→    ];\n   984→    const rooms: Room[] = [\n   985→      { id: 'R1', name: 'Main Hall', capacity: 30 },\n   986→      { id: 'R2', name: 'Side Room', capacity: 10 },\n   987→    ];\n   988→    // 300 min window. D takes 240 min of R1. Chain needs 210 min.\n   989→    const opts: ScheduleOptions = { startTime: 540, endTime: 840, gap: 15 };\n   990→\n   991→    const result = schedule(events, rooms, opts);\n   992→\n   993→    expect(result.assignments.length).toBe(4);\n   994→    expect(result.unscheduled).toHaveLength(0);\n   995→    assertPrerequisites(result, events, 15);\n   996→    assertCapacity(result, events, rooms);\n   997→    assertInWindow(result, opts);\n   998→    assertNoOverlap(result, 15);\n   999→"}]},"parent_tool_use_id":null,"session_id":"16c4dab3-ce65-410c-95a2-392b088bde39","uuid":"f987df6f-2f55-452f-aac8-a00a56e78819","tool_use_result":{"type":"text","file":{"filePath":"/tmp/.claude/projects/-workspace/16c4dab3-ce65-410c-95a2-392b088bde39/tool-results/toolu_01555NESpKHpmZNcdJVA6EUW.txt","content":"    // Actually: 120+15 = 135 per slot. 540/135 = 4 events per room. So R1 fits 4, R2 fits the 5th.\n    expect(result.assignments.length).toBe(5);\n    expect(result.unscheduled).toHaveLength(0);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n});\n\n// ============================================================\n// Group 4: Constraint combinations\n// ============================================================\ndescribe('Group 4: Constraint combinations', () => {\n\n  it('test 17: custom gap (30 min) between events in same room', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Session 1', duration: 60, attendees: 5 },\n      { id: 'E2', name: 'Session 2', duration: 60, attendees: 5 },\n      { id: 'E3', name: 'Session 3', duration: 60, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room', capacity: 20 },\n    ];\n    // With 30 min gap: 60+30+60+30+60 = 240 min. Window is 240 min. Exact fit.\n    const opts: ScheduleOptions = { startTime: 540, endTime: 780, gap: 30 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(3);\n    expect(result.unscheduled).toHaveLength(0);\n    assertNoOverlap(result, 30);\n    assertInWindow(result, opts);\n\n    // Verify actual gaps are >= 30\n    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n    for (let i = 0; i < sorted.length - 1; i++) {\n      const actualGap = sorted[i + 1].startTime - sorted[i].endTime;\n      expect(actualGap).toBeGreaterThanOrEqual(30);\n    }\n  });\n\n  it('test 18: prerequisites + capacity constraints together', () => {\n    // Chain: Setup -> Demo -> Review\n    // Setup needs small room (5 attendees), Demo needs big room (30), Review needs small (5).\n    // Only R1 (capacity 50) fits Demo.\n    const events: Event[] = [\n      { id: 'setup', name: 'Setup', duration: 45, attendees: 5 },\n      { id: 'demo', name: 'Demo', duration: 90, attendees: 30 },\n      { id: 'review', name: 'Review', duration: 45, attendees: 5, prerequisites: ['demo'] },\n      { id: 'prep', name: 'Prep', duration: 45, attendees: 5, prerequisites: ['setup'] },\n    ];\n    // demo depends on nothing, but prep depends on setup\n    // Rewrite: setup -> prep, setup -> demo (parallel), demo -> review\n    const eventsFixed: Event[] = [\n      { id: 'setup', name: 'Setup', duration: 45, attendees: 5 },\n      { id: 'demo', name: 'Demo', duration: 90, attendees: 30, prerequisites: ['setup'] },\n      { id: 'review', name: 'Review', duration: 45, attendees: 5, prerequisites: ['demo'] },\n      { id: 'prep', name: 'Prep', duration: 45, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Auditorium', capacity: 50 },\n      { id: 'R2', name: 'Huddle Room', capacity: 8 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(eventsFixed, rooms, opts);\n\n    expect(result.assignments).toHaveLength(4);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, eventsFixed, 15);\n    assertCapacity(result, eventsFixed, rooms);\n    assertInWindow(result, opts);\n\n    // Verify demo is in R1 (only room big enough)\n    const demoAssignment = result.assignments.find(a => a.eventId === 'demo');\n    expect(demoAssignment).toBeDefined();\n    expect(demoAssignment!.roomId).toBe('R1');\n  });\n\n  it('test 19: preferred room honored when possible', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Preferred Event', duration: 60, attendees: 5, preferredRoom: 'R2' },\n      { id: 'E2', name: 'Other Event', duration: 60, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 20 },\n      { id: 'R2', name: 'Room 2', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n\n    const e1Assign = result.assignments.find(a => a.eventId === 'E1');\n    expect(e1Assign).toBeDefined();\n    expect(e1Assign!.roomId).toBe('R2');\n  });\n\n  it('test 20: gap applies between prerequisite events', () => {\n    // A -> B. Even if different rooms, B can't start until A finishes + gap.\n    const events: Event[] = [\n      { id: 'A', name: 'First', duration: 60, attendees: 5 },\n      { id: 'B', name: 'Second', duration: 60, attendees: 5, prerequisites: ['A'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 20 },\n      { id: 'R2', name: 'Room 2', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n\n    const aAssign = result.assignments.find(a => a.eventId === 'A')!;\n    const bAssign = result.assignments.find(a => a.eventId === 'B')!;\n\n    // B must start at least gap (30 min) after A ends\n    expect(bAssign.startTime).toBeGreaterThanOrEqual(aAssign.endTime + 30);\n  });\n});\n\n// ============================================================\n// Group 5: Hard tests — scaling, optimality, edge precision\n// ============================================================\ndescribe('Group 5: Hard tests', () => {\n\n  it('test 21: scaling stress — 30 events, 5 rooms, prerequisite chains (must complete < 5s)', () => {\n    // 5 chains of 3 events each (15 chain events) + 15 independent \"filler\" events.\n    // Chains require sequential ordering; fillers go wherever they fit.\n    // 5 rooms with varying capacity: only R1 (cap 50) fits the \"big\" chain heads.\n    // Each chain: head (big, 50 attendees), step2 (medium, 15 attendees), step3 (small, 5 attendees).\n    // Fillers: 5 attendees each, 40 min each.\n    // Window: 540-1080 (540 min), gap 10.\n    //\n    // Chain events: 60 min each. Chain timing: 60+10+60+10+60 = 200 min per chain.\n    // 5 chains can interleave across rooms since chain members can go in different rooms\n    // (only heads need R1, and R1 has 540 min: 5 x 60 + 4 x 10 = 340, fits).\n    // Filler events: 15 events x 40 min. With gap 10: each room slot is 50 min.\n    // Across 5 rooms after chain events are placed, plenty of space.\n    //\n    // Key test: algorithm must handle 30 events without exponential blowup.\n\n    const events: Event[] = [];\n\n    // 5 prerequisite chains\n    for (let c = 1; c <= 5; c++) {\n      events.push({ id: `C${c}A`, name: `Chain ${c} Head`, duration: 60, attendees: 50 });\n      events.push({ id: `C${c}B`, name: `Chain ${c} Step 2`, duration: 60, attendees: 15, prerequisites: [`C${c}A`] });\n      events.push({ id: `C${c}C`, name: `Chain ${c} Step 3`, duration: 60, attendees: 5, prerequisites: [`C${c}B`] });\n    }\n\n    // 15 independent filler events\n    for (let f = 1; f <= 15; f++) {\n      events.push({ id: `F${f}`, name: `Filler ${f}`, duration: 40, attendees: 5 });\n    }\n\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Grand Hall', capacity: 50 },\n      { id: 'R2', name: 'Conference A', capacity: 20 },\n      { id: 'R3', name: 'Conference B', capacity: 20 },\n      { id: 'R4', name: 'Meeting Room A', capacity: 10 },\n      { id: 'R5', name: 'Meeting Room B', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1080, gap: 10 };\n\n    const t0 = performance.now();\n    const result = schedule(events, rooms, opts);\n    const elapsed = performance.now() - t0;\n\n    // Must complete in under 5 seconds\n    expect(elapsed, `Took ${elapsed.toFixed(0)}ms, must be < 5000ms`).toBeLessThan(5000);\n\n    // All 30 events should be schedulable\n    expect(result.assignments.length).toBe(30);\n    expect(result.unscheduled).toHaveLength(0);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 10);\n    assertCapacity(result, events, rooms);\n    assertPrerequisites(result, events, 10);\n\n    // Verify chain heads are in R1 (only room with capacity 50)\n    for (let c = 1; c <= 5; c++) {\n      const headAssign = result.assignments.find(a => a.eventId === `C${c}A`);\n      expect(headAssign, `Chain ${c} head should be assigned`).toBeDefined();\n      expect(headAssign!.roomId, `Chain ${c} head must be in R1 (only room cap >= 50)`).toBe('R1');\n    }\n  });\n\n  it('test 22: optimality — 8 events, 3 rooms, greedy gets 6 but optimal gets 8', () => {\n    // Setup: 3 rooms, 8 events. A naive approach that greedily assigns events by ID order\n    // will waste room capacity, leaving 2 events unscheduled.\n    //\n    // R1 (cap 40): only room for XL events (30 attendees)\n    // R2 (cap 15): fits medium events (12 attendees) and small (5)\n    // R3 (cap 8):  fits small events only (5 attendees)\n    //\n    // Events:\n    //   A1, A2: XL (30 attendees, 120 min) — MUST go in R1\n    //   B1, B2: medium (12 attendees, 120 min) — R1 or R2\n    //   C1, C2, C3, C4: small (5 attendees, 120 min) — any room\n    //\n    // Window: 540-810 (270 min), gap 15. Each room fits 2 events: 120+15+120 = 255 <= 270.\n    //\n    // Greedy by ID (A1, A2, B1, B2, C1-C4):\n    //   A1 -> R1(540-660), A2 -> R1(675-795). R1 full.\n    //   B1 -> R2(540-660), B2 -> R2(675-795). R2 full.\n    //   C1 -> R3(540-660), C2 -> R3(675-795). R3 full.\n    //   C3 -> no room. Unscheduled!\n    //   C4 -> no room. Unscheduled!\n    //   Result: 6/8.\n    //\n    // Optimal:\n    //   R1: A1(540-660), A2(675-795) — XL events in the only room that fits them\n    //   R2: B1(540-660), B2(675-795) — medium events\n    //   R3: C1(540-660), C2(675-795) — small events\n    //   Wait, that's still 6. We need to rethink...\n    //\n    // Revised: make it so the greedy assigns B events to R1 first, wasting R1 for XL events.\n    // Events in alphabetical order: B1, B2, C1, C2, C3, C4, X1, X2\n    // B events come first alphabetically, get placed in R1.\n    // Then X1, X2 (XL, 30 attendees) can't fit anywhere.\n    //\n    // Actually, let me reconsider. Greedy by ID order:\n    //   B1 (12 att) -> R1(540-660) [first room that fits]\n    //   B2 (12 att) -> R1(675-795) [R1 still has slot]\n    //   C1 (5 att) -> R2(540-660)\n    //   C2 (5 att) -> R2(675-795)\n    //   C3 (5 att) -> R3(540-660)\n    //   C4 (5 att) -> R3(675-795)\n    //   X1 (30 att) -> R1 full. R2 cap 15 < 30. R3 cap 8 < 30. Unscheduled!\n    //   X2 (30 att) -> same. Unscheduled!\n    //   Result: 6/8.\n    //\n    // Optimal:\n    //   R1: X1(540-660), X2(675-795)\n    //   R2: B1(540-660), B2(675-795)\n    //   R3: C1(540-660), C2(675-795)\n    //   Remaining: C3, C4 — wait, 8 events total. R1 has 2, R2 has 2, R3 has 2 = 6. Still 6!\n    //\n    // Need more room capacity. Let's use 4 rooms with 2 slots each = 8 slots total.\n    // R1 (cap 40), R2 (cap 15), R3 (cap 8), R4 (cap 8). Each fits 2 events.\n    //   Optimal: R1: X1, X2. R2: B1, B2. R3: C1, C2. R4: C3, C4. All 8!\n    //   Greedy: B1->R1, B2->R1, C1->R2, C2->R2, C3->R3, C4->R3, X1->R4(cap 8 < 30: fail!), X2 fail.\n    //   Greedy: 6/8.\n\n    const events: Event[] = [\n      { id: 'B1', name: 'Medium Talk 1', duration: 120, attendees: 12 },\n      { id: 'B2', name: 'Medium Talk 2', duration: 120, attendees: 12 },\n      { id: 'C1', name: 'Small Talk 1', duration: 120, attendees: 5 },\n      { id: 'C2', name: 'Small Talk 2', duration: 120, attendees: 5 },\n      { id: 'C3', name: 'Small Talk 3', duration: 120, attendees: 5 },\n      { id: 'C4', name: 'Small Talk 4', duration: 120, attendees: 5 },\n      { id: 'X1', name: 'Keynote 1', duration: 120, attendees: 30 },\n      { id: 'X2', name: 'Keynote 2', duration: 120, attendees: 30 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Grand Hall', capacity: 40 },\n      { id: 'R2', name: 'Conference Room', capacity: 15 },\n      { id: 'R3', name: 'Meeting Room A', capacity: 8 },\n      { id: 'R4', name: 'Meeting Room B', capacity: 8 },\n    ];\n    // 270 min window, 15 gap: each room fits exactly 2 events (120+15+120=255<=270)\n    const opts: ScheduleOptions = { startTime: 540, endTime: 810, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    // ALL 8 must be scheduled\n    expect(result.assignments.length).toBe(8);\n    expect(result.unscheduled).toHaveLength(0);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n\n    // Keynotes MUST be in R1 (only room with capacity >= 30)\n    const x1 = result.assignments.find(a => a.eventId === 'X1');\n    const x2 = result.assignments.find(a => a.eventId === 'X2');\n    expect(x1!.roomId).toBe('R1');\n    expect(x2!.roomId).toBe('R1');\n  });\n\n  it('test 23: tight packing with gaps — 3 events in room with exact-fit window', () => {\n    // Room has exactly enough time for 3 events if gaps are minimized to configured value.\n    // 3 events of 80 min each, gap 10 min.\n    // Total: 80 + 10 + 80 + 10 + 80 = 260 min.\n    // Window: exactly 260 min (540-800).\n    // Must schedule all 3. If the scheduler adds even 1 extra minute of gap, one won't fit.\n\n    const events: Event[] = [\n      { id: 'P1', name: 'Pack 1', duration: 80, attendees: 5 },\n      { id: 'P2', name: 'Pack 2', duration: 80, attendees: 5 },\n      { id: 'P3', name: 'Pack 3', duration: 80, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Tight Room', capacity: 10 },\n    ];\n    // Exact fit: 80+10+80+10+80 = 260 min window\n    const opts: ScheduleOptions = { startTime: 540, endTime: 800, gap: 10 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(3);\n    expect(result.unscheduled).toHaveLength(0);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 10);\n\n    // Verify the packing is exact\n    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n    expect(sorted[0].startTime).toBe(540);\n    expect(sorted[0].endTime).toBe(620);\n    expect(sorted[1].startTime).toBe(630); // 620 + 10\n    expect(sorted[1].endTime).toBe(710);\n    expect(sorted[2].startTime).toBe(720); // 710 + 10\n    expect(sorted[2].endTime).toBe(800);\n  });\n\n  it('test 24: prerequisite chain with room capacity mismatch — A(big)->B(small)->C(big)', () => {\n    // Chain A -> B -> C.\n    // A needs big room (20 attendees), B needs small room (3 attendees), C needs big room (20 attendees).\n    // Only 1 big room (R1, cap 25) and 1 small room (R2, cap 5).\n    // The scheduler must assign A->R1, B->R2 (or R1), C->R1, respecting prerequisites.\n    //\n    // Timing: each 60 min, gap 15.\n    // A in R1: 540-600.\n    // B must start >= 615 (600 + 15). B in R2: 615-675. Or B in R1: 615-675.\n    // C must start >= 690 (675 + 15). C in R1: needs 690-750.\n    //   If B was in R1 at 615-675, R1 next slot after gap: 675+15=690. C at 690-750. Works!\n    //   If B was in R2 at 615-675, R1 next slot after A: 600+15=615. C at 615-675. But prereq B ends 675, C needs >= 690. So C in R1 at 690-750. Works!\n    //\n    // Window 540-750 (210 min). 3 events of 60 + 2 gaps of 15 = 210. Exact fit.\n    // Add a filler event D (20 attendees, 60 min) that competes for R1 time.\n    // D has no prereqs, needs R1 (20 > 5).\n    // If D goes in R1 at 540-600, that's A's slot. Conflict!\n    // If D goes in R1 at 615-675, that could block C.\n    //\n    // With window 540-810 (270 min), R1 can fit:\n    //   A(540-600), B or D(615-675), C(690-750), and maybe D(765-825) if window allows to 825.\n    // Window to 810: D at 765-825 exceeds 810. So 4 events need careful arrangement.\n    //\n    // Simpler: window 540-810 (270 min). R1 fits 3 events (60+15+60+15+60=210 <= 270).\n    // A must be in R1 (20 att). C must be in R1 (20 att). D must be in R1 (20 att).\n    // B can go in R2. So R1 has A, C, D = 3 events. B in R2.\n    // Prereq: A before B, B before C. A in R1 at 540-600. B in R2 at 615-675.\n    // C in R1 at 690-750 (after B at 675+15=690). D in R1 at 615-675 (gap after A: 600+15=615).\n    // Check: R1 has A(540-600), D(615-675), C(690-750). No overlap? 600+15=615<=615, 675+15=690<=690. Yes!\n    // All 4 scheduled.\n    //\n    // A greedy might put B in R1 at 615-675 (it fits there), then D can't fit R1\n    // (next R1 slot after B: 690, D at 690-750, C needs R1 after 690 too. C prereq B ends 675+15=690.\n    // C at 690-750 if D not there. But D also at 690-750 = overlap. D at 765-825 > 810. Unscheduled!\n\n    const events: Event[] = [\n      { id: 'A', name: 'Opening Ceremony', duration: 60, attendees: 20 },\n      { id: 'B', name: 'Breakout Session', duration: 60, attendees: 3, prerequisites: ['A'] },\n      { id: 'C', name: 'Closing Ceremony', duration: 60, attendees: 20, prerequisites: ['B'] },\n      { id: 'D', name: 'Exhibition', duration: 60, attendees: 20 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Main Hall', capacity: 25 },\n      { id: 'R2', name: 'Breakout Room', capacity: 5 },\n    ];\n    // R1 fits 3 events: 60+15+60+15+60 = 210 <= 270\n    const opts: ScheduleOptions = { startTime: 540, endTime: 810, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(4);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n\n    // A, C, D must be in R1 (only room with capacity >= 20)\n    const aAssign = result.assignments.find(a => a.eventId === 'A');\n    const cAssign = result.assignments.find(a => a.eventId === 'C');\n    const dAssign = result.assignments.find(a => a.eventId === 'D');\n    expect(aAssign!.roomId).toBe('R1');\n    expect(cAssign!.roomId).toBe('R1');\n    expect(dAssign!.roomId).toBe('R1');\n\n    // B must be in R2 (to free R1 space for D)\n    const bAssign = result.assignments.find(a => a.eventId === 'B');\n    expect(bAssign!.roomId).toBe('R2');\n  });\n\n  it('test 25: multiple independent groups — 3 clusters with no cross-dependencies', () => {\n    // 3 independent clusters of events with their own prerequisite chains.\n    // Cluster 1: Alpha1 -> Alpha2 -> Alpha3 (big events, 20 att)\n    // Cluster 2: Beta1 -> Beta2 (medium events, 10 att)\n    // Cluster 3: Gamma1, Gamma2, Gamma3 (independent small events, 3 att)\n    //\n    // Rooms: R1 (cap 25), R2 (cap 12), R3 (cap 5).\n    // Alpha cluster must use R1. Beta must use R1 or R2. Gamma can use any room.\n    //\n    // Window: 540-1020 (480 min), gap 15.\n    // R1: Alpha1(540-630), Alpha2(645-735), Alpha3(750-840) = 300 min.\n    //   Still has 840-1020 = 180 min free.\n    // R2: Beta1(540-630), Beta2(645-735) = 195 min. Still has 735-1020 = 285 min free.\n    // R3: Gamma1(540-630), Gamma2(645-735), Gamma3(750-840).\n    //\n    // All 8 events fit easily. The key test is that independent groups don't interfere.\n\n    const events: Event[] = [\n      // Cluster 1: big chain\n      { id: 'Alpha1', name: 'Alpha Step 1', duration: 90, attendees: 20 },\n      { id: 'Alpha2', name: 'Alpha Step 2', duration: 90, attendees: 20, prerequisites: ['Alpha1'] },\n      { id: 'Alpha3', name: 'Alpha Step 3', duration: 90, attendees: 20, prerequisites: ['Alpha2'] },\n      // Cluster 2: medium chain\n      { id: 'Beta1', name: 'Beta Step 1', duration: 90, attendees: 10 },\n      { id: 'Beta2', name: 'Beta Step 2', duration: 90, attendees: 10, prerequisites: ['Beta1'] },\n      // Cluster 3: independent small events\n      { id: 'Gamma1', name: 'Gamma Event 1', duration: 90, attendees: 3 },\n      { id: 'Gamma2', name: 'Gamma Event 2', duration: 90, attendees: 3 },\n      { id: 'Gamma3', name: 'Gamma Event 3', duration: 90, attendees: 3 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Auditorium', capacity: 25 },\n      { id: 'R2', name: 'Seminar Room', capacity: 12 },\n      { id: 'R3', name: 'Small Room', capacity: 5 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(8);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n\n    // Verify each cluster's events don't break each other's prerequisites\n    // Alpha chain: Alpha1 before Alpha2 before Alpha3\n    const a1 = result.assignments.find(a => a.eventId === 'Alpha1')!;\n    const a2 = result.assignments.find(a => a.eventId === 'Alpha2')!;\n    const a3 = result.assignments.find(a => a.eventId === 'Alpha3')!;\n    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n    expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n\n    // Beta chain: Beta1 before Beta2\n    const b1 = result.assignments.find(a => a.eventId === 'Beta1')!;\n    const b2 = result.assignments.find(a => a.eventId === 'Beta2')!;\n    expect(b2.startTime).toBeGreaterThanOrEqual(b1.endTime + 15);\n\n    // Alpha events must be in R1 (only room with cap >= 20)\n    expect(a1.roomId).toBe('R1');\n    expect(a2.roomId).toBe('R1');\n    expect(a3.roomId).toBe('R1');\n  });\n\n  it('test 26: preference vs feasibility with prerequisites', () => {\n    // Events prefer rooms they can't actually use due to prerequisite timing constraints.\n    //\n    // Setup: A -> B -> C chain. All prefer R1.\n    // D is independent, large (25 att), MUST use R1.\n    // D is 180 min, takes most of R1's time.\n    //\n    // R1 (cap 30): D fills most of it.\n    // R2 (cap 10): can hold A, B, C (5 att each).\n    //\n    // Window: 540-840 (300 min), gap 15.\n    // D in R1: 540-720 (180 min). R1 remaining after gap: 735-840 = 105 min.\n    // A, B, C are each 60 min. Chain: 60+15+60+15+60 = 210 min. Won't fit in R1's 105 min remainder.\n    // So A, B, C must go to R2 despite preferring R1.\n    // R2: A(540-600), B(615-675), C(690-750). Fits in 300 min window.\n    //\n    // Or: A in R1 first at 540-600. Then D in R1 at 615-795. Then B after A at 615+...\n    // B needs A done at 600+15=615. B in R2 at 615-675. C in R2 at 690-750.\n    // D in R1 at 615-795: fits (795 <= 840). R1 has A(540-600), D(615-795).\n    // That works too: A in R1 (preferred!), B, C in R2. But we need all 4 scheduled.\n    //\n    // Let's make it so all chain events genuinely can't fit in R1.\n    // D is 240 min. R1: D(540-780). Remaining: 780+15=795 to 840 = 45 min. Too short for 60 min events.\n    // Chain events prefer R1 but can't use it (no space after D).\n\n    const events: Event[] = [\n      { id: 'A', name: 'Phase 1', duration: 60, attendees: 5, preferredRoom: 'R1' },\n      { id: 'B', name: 'Phase 2', duration: 60, attendees: 5, preferredRoom: 'R1', prerequisites: ['A'] },\n      { id: 'C', name: 'Phase 3', duration: 60, attendees: 5, preferredRoom: 'R1', prerequisites: ['B'] },\n      { id: 'D', name: 'All-Day Workshop', duration: 240, attendees: 25 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Main Hall', capacity: 30 },\n      { id: 'R2', name: 'Side Room', capacity: 10 },\n    ];\n    // 300 min window. D takes 240 min of R1. Chain needs 210 min.\n    const opts: ScheduleOptions = { startTime: 540, endTime: 840, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(4);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n","numLines":500,"startLine":500,"totalLines":1486}}}
