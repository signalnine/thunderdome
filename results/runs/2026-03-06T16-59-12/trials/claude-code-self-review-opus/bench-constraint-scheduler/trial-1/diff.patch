omId) ?? [];\n  const sorted = [...slots].sort((a, b) => a.start - b.start);\n\n  // Try placing at earliestStart, checking for conflicts\n  let candidateStart = earliestStart;\n\n  // Check each existing slot for conflicts and find valid placement\n  for (const slot of sorted) {\n    const candidateEnd = candidateStart + duration;\n    // Check if candidate overlaps with this slot (considering gap)\n    if (candidateEnd + gap <= slot.start || candidateStart >= slot.end + gap) {\n      // No conflict with this slot at this position\n      continue;\n    }\n    // Conflict: move candidateStart to after this slot + gap\n    candidateStart = slot.end + gap;\n  }\n\n  const candidateEnd = candidateStart + duration;\n  if (candidateEnd <= endTime) {\n    return candidateStart;\n  }\n  return null;\n}\n\n/**\n * Find all valid (room, startTime) placements for an event.\n */\nfunction findPlacements(\n  event: Event,\n  rooms: Room[],\n  assignments: Map<string, Assignment>,\n  roomSchedules: Map<string, { start: number; end: number }[]>,\n  gap: number,\n  windowStart: number,\n  windowEnd: number\n): { roomId: string; startTime: number }[] {\n  const attendees = event.attendees ?? 1;\n  const earliestStart = getEarliestStart(event, assignments, gap, windowStart);\n  const placements: { roomId: string; startTime: number }[] = [];\n\n  for (const room of rooms) {\n    if (room.capacity < attendees) continue;\n    const startTime = findEarliestSlot(\n      room.id,\n      event.duration,\n      earliestStart,\n      windowEnd,\n      gap,\n      roomSchedules\n    );\n    if (startTime !== null) {\n      placements.push({ roomId: room.id, startTime });\n    }\n  }\n\n  return placements;\n}\n\n/**\n * Assign an event to a room at a specific time.\n */\nfunction assignEvent(\n  event: Event,\n  roomId: string,\n  startTime: number,\n  assignments: Map<string, Assignment>,\n  roomSchedules: Map<string, { start: number; end: number }[]>\n): void {\n  const endTime = startTime + event.duration;\n  assignments.set(event.id, { eventId: event.id, roomId, startTime, endTime });\n  if (!roomSchedules.has(roomId)) roomSchedules.set(roomId, []);\n  roomSchedules.get(roomId)!.push({ start: startTime, end: endTime });\n}\n\n/**\n * Remove an event's assignment.\n */\nfunction unassignEvent(\n  eventId: string,\n  assignments: Map<string, Assignment>,\n  roomSchedules: Map<string, { start: number; end: number }[]>\n): void {\n  const assignment = assignments.get(eventId);\n  if (!assignment) return;\n  assignments.delete(eventId);\n  const slots = roomSchedules.get(assignment.roomId);\n  if (slots) {\n    const idx = slots.findIndex(\n      s => s.start === assignment.startTime && s.end === assignment.endTime\n    );\n    if (idx !== -1) slots.splice(idx, 1);\n  }\n}\n\n/**\n * For each event, determine which rooms can possibly hold it (capacity-wise).\n */\nfunction getFeasibleRooms(events: Event[], rooms: Room[]): Map<string, Room[]> {\n  const result = new Map<string, Room[]>();\n  for (const event of events) {\n    const attendees = event.attendees ?? 1;\n    const feasible = rooms.filter(r => r.capacity >= attendees);\n    result.set(event.id, feasible);\n  }\n  return result;\n}\n\n/**\n * Main schedule function.\n *\n * Strategy:\n * 1. Detect prerequisite cycles (throws)\n * 2. Filter out events that can never fit (too long, no room with enough capacity)\n * 3. Sort events by most-constrained-first (fewest feasible rooms, then longest duration)\n * 4. Use a smart assignment strategy that reserves scarce rooms for events that need them\n * 5. Backtrack if initial placement doesn't maximize scheduled events\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime: windowStart, endTime: windowEnd } = options;\n  const windowLength = windowEnd - windowStart;\n\n  // Step 0: Handle empty inputs\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // Step 1: Detect prerequisite cycles\n  detectCycles(events);\n\n  // Step 2: Filter events that can never be scheduled\n  const feasibleRoomsMap = getFeasibleRooms(events, rooms);\n  const schedulable: Event[] = [];\n  const neverSchedulable: string[] = [];\n\n  for (const event of events) {\n    const feasibleRooms = feasibleRoomsMap.get(event.id)!;\n    if (feasibleRooms.length === 0 || event.duration > windowLength) {\n      neverSchedulable.push(event.id);\n    } else {\n      schedulable.push(event);\n    }\n  }\n\n  // Step 3: Get topological order of schedulable events\n  const topoOrder = topologicalSort(schedulable);\n\n  // Step 4: Use constraint-propagation-based scheduling\n  // Strategy: Sort events by \"most constrained first\" within topological levels.\n  // Events with fewer feasible rooms should be scheduled first.\n  // Events that MUST use a specific room get priority.\n\n  // Group events by their topological level\n  const eventMap = new Map<string, Event>();\n  for (const e of schedulable) eventMap.set(e.id, e);\n\n  // Compute topological levels\n  const levels = new Map<string, number>();\n  for (const e of topoOrder) {\n    let level = 0;\n    for (const prereq of e.prerequisites ?? []) {\n      if (levels.has(prereq)) {\n        level = Math.max(level, levels.get(prereq)! + 1);\n      }\n    }\n    levels.set(e.id, level);\n  }\n\n  // Sort events: by topo level, then by number of feasible rooms (ascending),\n  // then by duration (descending) to place harder-to-fit events first\n  const sortedEvents = [...topoOrder].sort((a, b) => {\n    const levelDiff = levels.get(a.id)! - levels.get(b.id)!;\n    if (levelDiff !== 0) return levelDiff;\n    const feasibleA = feasibleRoomsMap.get(a.id)!.length;\n    const feasibleB = feasibleRoomsMap.get(b.id)!.length;\n    if (feasibleA !== feasibleB) return feasibleA - feasibleB;\n    return b.duration - a.duration;\n  });\n\n  // Try scheduling with the main strategy, then try to improve\n  const bestResult = solveWithBacktracking(\n    sortedEvents,\n    rooms,\n    feasibleRoomsMap,\n    gap,\n    windowStart,\n    windowEnd,\n    eventMap\n  );\n\n  const assignments = [...bestResult.values()];\n  const scheduledIds = new Set(assignments.map(a => a.eventId));\n  const unscheduled = [\n    ...neverSchedulable,\n    ...schedulable.filter(e => !scheduledIds.has(e.id)).map(e => e.id),\n  ];\n\n  return { assignments, unscheduled };\n}\n\n/**\n * Solve the scheduling problem with intelligent assignment and limited backtracking.\n *\n * Uses iterative deepening / multi-pass approach:\n * 1. First pass: greedy assignment with most-constrained-first ordering\n * 2. If some events are unscheduled, try different orderings and room assignments\n */\nfunction solveWithBacktracking(\n  sortedEvents: Event[],\n  rooms: Room[],\n  feasibleRoomsMap: Map<string, Room[]>,\n  gap: number,\n  windowStart: number,\n  windowEnd: number,\n  eventMap: Map<string, Event>\n): Map<string, Assignment> {\n  // For performance with large inputs, we limit backtracking depth\n  const n = sortedEvents.length;\n\n  // First pass: smart greedy with \"tightest room first\" heuristic\n  const result1 = greedySchedule(\n    sortedEvents, rooms, feasibleRoomsMap, gap, windowStart, windowEnd, 'tightest'\n  );\n\n  if (result1.size === n) return result1;\n\n  // Second pass: try with preferred rooms prioritized\n  const result2 = greedySchedule(\n    sortedEvents, rooms, feasibleRoomsMap, gap, windowStart, windowEnd, 'preferred'\n  );\n\n  if (result2.size === n) return result2;\n\n  // Third pass: try scheduling only the \"must-have\" events first\n  // (events with exactly 1 feasible room), then fill in the rest\n  const result3 = constraintPropagationSchedule(\n    sortedEvents, rooms, feasibleRoomsMap, gap, windowStart, windowEnd, eventMap\n  );\n\n  if (result3.size === n) return result3;\n\n  // Pick best result so far\n  let best = result1;\n  if (result2.size > best.size) best = result2;\n  if (result3.size > best.size) best = result3;\n\n  // If we still haven't scheduled everything, try backtracking search\n  // but limit it for performance\n  if (best.size < n && n <= 50) {\n    const result4 = backtrackingSearch(\n      sortedEvents, rooms, feasibleRoomsMap, gap, windowStart, windowEnd, eventMap, best.size\n    );\n    if (result4.size > best.size) best = result4;\n  }\n\n  return best;\n}\n\n/**\n * Greedy scheduling with configurable room selection heuristic.\n */\nfunction greedySchedule(\n  sortedEvents: Event[],\n  rooms: Room[],\n  feasibleRoomsMap: Map<string, Room[]>,\n  gap: number,\n  windowStart: number,\n  windowEnd: number,\n  strategy: 'tightest' | 'preferred'\n): Map<string, Assignment> {\n  const assignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, { start: number; end: number }[]>();\n  for (const room of rooms) roomSchedules.set(room.id, []);\n\n  for (const event of sortedEvents) {\n    const attendees = event.attendees ?? 1;\n    const earliestStart = getEarliestStart(event, assignments, gap, windowStart);\n\n    // Check if prerequisites are all scheduled\n    let prereqsSatisfied = true;\n    for (const prereqId of event.prerequisites ?? []) {\n      if (!assignments.has(prereqId)) {\n        prereqsSatisfied = false;\n        break;\n      }\n    }\n    if (!prereqsSatisfied) continue;\n\n    const feasibleRooms = feasibleRoomsMap.get(event.id)!;\n\n    // Order rooms by strategy\n    let orderedRooms: Room[];\n    if (strategy === 'tightest') {\n      // Use the room with smallest sufficient capacity (best fit)\n      orderedRooms = [...feasibleRooms].sort((a, b) => a.capacity - b.capacity);\n    } else {\n      // Preferred room first, then tightest fit\n      orderedRooms = [...feasibleRooms].sort((a, b) => {\n        const aPref = a.id === event.preferredRoom ? 0 : 1;\n        const bPref = b.id === event.preferredRoom ? 0 : 1;\n        if (aPref !== bPref) return aPref - bPref;\n        return a.capacity - b.capacity;\n      });\n    }\n\n    let placed = false;\n    for (const room of orderedRooms) {\n      if (room.capacity < attendees) continue;\n      const startTime = findEarliestSlot(\n        room.id,\n        event.duration,\n        earliestStart,\n        windowEnd,\n        gap,\n        roomSchedules\n      );\n      if (startTime !== null) {\n        assignEvent(event, room.id, startTime, assignments, roomSchedules);\n        placed = true;\n        break;\n      }\n    }\n  }\n\n  return assignments;\n}\n\n/**\n * Constraint propagation approach: schedule most-constrained events first,\n * particularly events that have only one feasible room.\n */\nfunction constraintPropagationSchedule(\n  sortedEvents: Event[],\n  rooms: Room[],\n  feasibleRoomsMap: Map<string, Room[]>,\n  gap: number,\n  windowStart: number,\n  windowEnd: number,\n  eventMap: Map<string, Event>\n): Map<string, Assignment> {\n  // Categorize events by constraint level\n  const singleRoom: Event[] = []; // Events that can only go in 1 room\n  const fewRooms: Event[] = [];   // Events with 2-3 feasible rooms\n  const manyRooms: Event[] = [];  // Events with 4+ feasible rooms\n\n  for (const event of sortedEvents) {\n    const numFeasible = feasibleRoomsMap.get(event.id)!.length;\n    if (numFeasible === 1) {\n      singleRoom.push(event);\n    } else if (numFeasible <= 3) {\n      fewRooms.push(event);\n    } else {\n      manyRooms.push(event);\n    }\n  }\n\n  // Compute room demand: how many events MUST use each room\n  const roomDemand = new Map<string, number>();\n  for (const room of rooms) roomDemand.set(room.id, 0);\n  for (const event of singleRoom) {\n    const roomId = feasibleRoomsMap.get(event.id)![0].id;\n    roomDemand.set(roomId, (roomDemand.get(roomId) ?? 0) + 1);\n  }\n\n  // For events with few rooms, compute which rooms are \"scarcest\"\n  // A room is scarce if it's the only option for many events\n  const roomScarcity = new Map<string, number>();\n  for (const room of rooms) {\n    roomScarcity.set(room.id, 0);\n  }\n  for (const event of sortedEvents) {\n    for (const room of feasibleRoomsMap.get(event.id)!) {\n      roomScarcity.set(room.id, (roomScarcity.get(room.id) ?? 0) + 1);\n    }\n  }\n\n  const assignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, { start: number; end: number }[]>();\n  for (const room of rooms) roomSchedules.set(room.id, []);\n\n  // Schedule all events in priority order, respecting topological constraints\n  // We need to schedule in topological order, but within each level,\n  // prioritize by constraint level\n\n  // Compute levels for topological ordering\n  const levels = new Map<string, number>();\n  const computeLevel = (e: Event): number => {\n    if (levels.has(e.id)) return levels.get(e.id)!;\n    let level = 0;\n    for (const prereqId of e.prerequisites ?? []) {\n      if (eventMap.has(prereqId)) {\n        level = Math.max(level, computeLevel(eventMap.get(prereqId)!) + 1);\n      }\n    }\n    levels.set(e.id, level);\n    return level;\n  };\n  for (const e of sortedEvents) computeLevel(e);\n\n  // Create scheduling order: by level, then by constraint (fewest rooms first),\n  // then by duration (longest first)\n  const schedulingOrder = [...sortedEvents].sort((a, b) => {\n    const levelDiff = levels.get(a.id)! - levels.get(b.id)!;\n    if (levelDiff !== 0) return levelDiff;\n    const feasA = feasibleRoomsMap.get(a.id)!.length;\n    const feasB = feasibleRoomsMap.get(b.id)!.length;\n    if (feasA !== feasB) return feasA - feasB;\n    return b.duration - a.duration;\n  });\n\n  for (const event of schedulingOrder) {\n    // Check prerequisites\n    let prereqsSatisfied = true;\n    for (const prereqId of event.prerequisites ?? []) {\n      if (eventMap.has(prereqId) && !assignments.has(prereqId)) {\n        prereqsSatisfied = false;\n        break;\n      }\n    }\n    if (!prereqsSatisfied) continue;\n\n    const earliestStart = getEarliestStart(event, assignments, gap, windowStart);\n    const feasibleRooms = feasibleRoomsMap.get(event.id)!;\n\n    // Order rooms: prefer the room with smallest capacity that fits (tightest fit)\n    // But avoid rooms that are scarce unless this event must use them\n    const orderedRooms = [...feasibleRooms].sort((a, b) => {\n      // If event has preferred room, give it a small bonus but not decisive\n      const aPref = a.id === event.preferredRoom ? -0.5 : 0;\n      const bPref = b.id === event.preferredRoom ? -0.5 : 0;\n      // Prefer rooms with less scarcity (more available capacity)\n      // But strongly prefer rooms that are just the right size\n      const aScore = a.capacity + aPref;\n      const bScore = b.capacity + bPref;\n      return aScore - bScore;\n    });\n\n    for (const room of orderedRooms) {\n      const startTime = findEarliestSlot(\n        room.id,\n        event.duration,\n        earliestStart,\n        windowEnd,\n        gap,\n        roomSchedules\n      );\n      if (startTime !== null) {\n        assignEvent(event, room.id, startTime, assignments, roomSchedules);\n        break;\n      }\n    }\n  }\n\n  return assignments;\n}\n\n/**\n * Backtracking search for optimal scheduling.\n * Tries different room assignments for events to maximize scheduled count.\n */\nfunction backtrackingSearch(\n  sortedEvents: Event[],\n  rooms: Room[],\n  feasibleRoomsMap: Map<string, Room[]>,\n  gap: number,\n  windowStart: number,\n  windowEnd: number,\n  eventMap: Map<string, Event>,\n  currentBest: number\n): Map<string, Assignment> {\n  let bestAssignments = new Map<string, Assignment>();\n  let bestCount = currentBest;\n  const target = sortedEvents.length;\n  let iterations = 0;\n  const maxIterations = 500000;\n\n  // Compute levels\n  const levels = new Map<string, number>();\n  const computeLevel = (e: Event): number => {\n    if (levels.has(e.id)) return levels.get(e.id)!;\n    let level = 0;\n    for (const prereqId of e.prerequisites ?? []) {\n      if (eventMap.has(prereqId)) {\n        level = Math.max(level, computeLevel(eventMap.get(prereqId)!) + 1);\n      }\n    }\n    levels.set(e.id, level);\n    return level;\n  };\n  for (const e of sortedEvents) computeLevel(e);\n\n  // Sort by level, then fewest rooms, then longest duration\n  const orderedEvents = [...sortedEvents].sort((a, b) => {\n    const levelDiff = levels.get(a.id)! - levels.get(b.id)!;\n    if (levelDiff !== 0) return levelDiff;\n    const feasA = feasibleRoomsMap.get(a.id)!.length;\n    const feasB = feasibleRoomsMap.get(b.id)!.length;\n    if (feasA !== feasB) return feasA - feasB;\n    return b.duration - a.duration;\n  });\n\n  const assignments = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, { start: number; end: number }[]>();\n  for (const room of rooms) roomSchedules.set(room.id, []);\n\n  function search(idx: number, scheduled: number, skipped: number): boolean {\n    iterations++;\n    if (iterations > maxIterations) return false;\n    if (scheduled === target) return true;\n\n    // Pruning: if even scheduling all remaining can't beat best, stop\n    const remaining = orderedEvents.length - idx;\n    if (scheduled + remaining <= bestCount) return false;\n\n    if (idx >= orderedEvents.length) {\n      if (scheduled > bestCount) {\n        bestCount = scheduled;\n        bestAssignments = new Map(assignments);\n      }\n      return scheduled === target;\n    }\n\n    const event = orderedEvents[idx];\n\n    // Check prerequisites\n    let prereqsSatisfied = true;\n    for (const prereqId of event.prerequisites ?? []) {\n      if (eventMap.has(prereqId) && !assignments.has(prereqId)) {\n        prereqsSatisfied = false;\n        break;\n      }\n    }\n\n    if (!prereqsSatisfied) {\n      // Can't schedule this event, skip it\n      if (search(idx + 1, scheduled, skipped + 1)) return true;\n      return false;\n    }\n\n    const earliestStart = getEarliestStart(event, assignments, gap, windowStart);\n    const feasibleRooms = feasibleRoomsMap.get(event.id)!;\n\n    // Order rooms: tightest fit first, preferred room gets a bonus\n    const orderedRooms = [...feasibleRooms].sort((a, b) => {\n      const aPref = a.id === event.preferredRoom ? 0 : 1;\n      const bPref = b.id === event.preferredRoom ? 0 : 1;\n      if (aPref !== bPref) return aPref - bPref;\n      return a.capacity - b.capacity;\n    });\n\n    // Try placing in each room\n    for (const room of orderedRooms) {\n      const startTime = findEarliestSlot(\n        room.id,\n        event.duration,\n        earliestStart,\n        windowEnd,\n        gap,\n        roomSchedules\n      );\n      if (startTime !== null) {\n        assignEvent(event, room.id, startTime, assignments, roomSchedules);\n        if (search(idx + 1, scheduled + 1, skipped)) return true;\n        unassignEvent(event.id, assignments, roomSchedules);\n      }\n    }\n\n    // Try skipping this event\n    if (search(idx + 1, scheduled, skipped + 1)) return true;\n\n    return false;\n  }\n\n  search(0, 0, 0);\n\n  return bestAssignments;\n}\n","structuredPatch":[],"originalFile":null}}
