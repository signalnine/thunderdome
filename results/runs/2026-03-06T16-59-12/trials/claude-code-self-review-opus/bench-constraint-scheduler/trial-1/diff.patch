BeLessThanOrEqual(opts.endTime);\n  }\n}\n\nfunction assertPrerequisites(result: { assignments: { eventId: string; startTime: number; endTime: number }[] }, events: Event[], gap: number) {\n  const startMap = new Map<string, number>();\n  const endMap = new Map<string, number>();\n  for (const a of result.assignments) {\n    startMap.set(a.eventId, a.startTime);\n    endMap.set(a.eventId, a.endTime);\n  }\n  for (const e of events) {\n    if (!startMap.has(e.id)) continue; // unscheduled\n    for (const pre of e.prerequisites ?? []) {\n      if (!endMap.has(pre)) continue; // prerequisite unscheduled\n      expect(\n        startMap.get(e.id)!,\n        `${e.id} should start after prerequisite ${pre} ends (${endMap.get(pre)}) + gap (${gap})`\n      ).toBeGreaterThanOrEqual(endMap.get(pre)! + gap);\n    }\n  }\n}\n\nfunction assertCapacity(result: { assignments: { eventId: string; roomId: string }[] }, events: Event[], rooms: Room[]) {\n  const roomCap = new Map<string, number>();\n  for (const r of rooms) roomCap.set(r.id, r.capacity);\n  const eventAtt = new Map<string, number>();\n  for (const e of events) eventAtt.set(e.id, e.attendees ?? 1);\n\n  for (const a of result.assignments) {\n    const cap = roomCap.get(a.roomId)!;\n    const att = eventAtt.get(a.eventId)!;\n    expect(att, `${a.eventId} (${att} attendees) in room ${a.roomId} (capacity ${cap})`).toBeLessThanOrEqual(cap);\n  }\n}\n\n// ============================================================\n// Group 1: Basic scheduling (greedy passes these)\n// ============================================================\ndescribe('Group 1: Basic scheduling', () => {\n\n  it('test 1: schedule single event into single room', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Kickoff', duration: 60, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Main Hall', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0].eventId).toBe('E1');\n    expect(result.assignments[0].roomId).toBe('R1');\n    expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);\n    assertInWindow(result, opts);\n  });\n\n  it('test 2: schedule 2 non-overlapping events in same room', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Morning Talk', duration: 60, attendees: 10 },\n      { id: 'E2', name: 'Afternoon Talk', duration: 60, attendees: 10 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room A', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n    assertNoOverlap(result, 15);\n    assertInWindow(result, opts);\n  });\n\n  it('test 3: respect room capacity — reject oversized event', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Small Meeting', duration: 30, attendees: 5 },\n      { id: 'E2', name: 'Huge Gathering', duration: 30, attendees: 100 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Small Room', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].eventId).toBe('E1');\n    expect(result.unscheduled).toContain('E2');\n    assertCapacity(result, events, rooms);\n  });\n\n  it('test 4: respect time window boundaries', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Long Event', duration: 120, attendees: 5 },\n      { id: 'E2', name: 'Another Long Event', duration: 120, attendees: 5 },\n      { id: 'E3', name: 'Third Long Event', duration: 120, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room A', capacity: 20 },\n    ];\n    // Only 300 min window. 3 events of 120 min + 2 gaps of 15 = 390 > 300. Only 2 fit.\n    const opts: ScheduleOptions = { startTime: 540, endTime: 840, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(2);\n    expect(result.unscheduled).toHaveLength(1);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n\n  it('test 5: simple prerequisite — A before B', () => {\n    const events: Event[] = [\n      { id: 'A', name: 'Setup', duration: 60, attendees: 5 },\n      { id: 'B', name: 'Main Event', duration: 60, attendees: 5, prerequisites: ['A'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room A', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertInWindow(result, opts);\n  });\n});\n\n// ============================================================\n// Group 2: Greedy killers (first-fit FAILS these)\n// ============================================================\ndescribe('Group 2: Greedy killers', () => {\n\n  it('test 6: room packing — greedy wastes large room on small events', () => {\n    // R1 (capacity 20) is the only room big enough for E5-E6 (10 attendees each).\n    // E1-E4 are small (3 attendees) and fit in R2 or R3 (capacity 5).\n    // A greedy that assigns E1-E4 to R1 first will fill R1's time slots,\n    // leaving E5-E6 with no valid room.\n    // Optimal: E1-E4 go to R2/R3, E5-E6 go to R1.\n    const events: Event[] = [\n      { id: 'E1', name: 'Small 1', duration: 105, attendees: 3 },\n      { id: 'E2', name: 'Small 2', duration: 105, attendees: 3 },\n      { id: 'E3', name: 'Small 3', duration: 105, attendees: 3 },\n      { id: 'E4', name: 'Small 4', duration: 105, attendees: 3 },\n      { id: 'E5', name: 'Large 1', duration: 225, attendees: 10 },\n      { id: 'E6', name: 'Large 2', duration: 225, attendees: 10 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Grand Hall', capacity: 20 },\n      { id: 'R2', name: 'Side Room A', capacity: 5 },\n      { id: 'R3', name: 'Side Room B', capacity: 5 },\n    ];\n    // 480 min window, 15 min gap\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    // Greedy by ID, first-fit room:\n    //   E1 -> R1(540-645), E2 -> R1(660-765), E3 -> R1(780-885), E4 -> R1(900-1005)\n    //   E5 -> R1 full, R2/R3 too small (10>5). Unscheduled!\n    //   E6 -> same. Unscheduled!\n    //   Greedy: 4/6 scheduled.\n    //\n    // Optimal:\n    //   R1: E5(540-765), E6(780-1005) -- 225+15+225 = 465 <= 480\n    //   R2: E1(540-645), E2(660-765) -- 2 events, 3<=5\n    //   R3: E3(540-645), E4(660-765) -- 2 events, 3<=5\n    //   All 6 scheduled!\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(6);\n    expect(result.unscheduled).toHaveLength(0);\n    assertNoOverlap(result, 15);\n    assertInWindow(result, opts);\n    assertCapacity(result, events, rooms);\n  });\n\n  it('test 7: prerequisite chain + room constraint — greedy room choice blocks dependents', () => {\n    // A -> B chain. D only fits R1. Greedy puts A in R1, then C in R1, blocking D.\n    // Optimal puts A and B in R2, C in R2, D in R1.\n    const events: Event[] = [\n      { id: 'A', name: 'Setup', duration: 60, attendees: 3 },\n      { id: 'B', name: 'Main', duration: 60, attendees: 3, prerequisites: ['A'] },\n      { id: 'C', name: 'Workshop', duration: 150, attendees: 3 },\n      { id: 'D', name: 'Keynote', duration: 150, attendees: 10 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Large Room', capacity: 20 },\n      { id: 'R2', name: 'Small Room', capacity: 5 },\n    ];\n    // 360 min window\n    const opts: ScheduleOptions = { startTime: 540, endTime: 900, gap: 15 };\n\n    // Optimal:\n    //   R2: A(540-600), B(615-675), C(690-840)  -- all fit, 3 <= 5\n    //   R1: D(540-690) -- 10 <= 20\n    //   All 4 scheduled!\n\n    // Greedy (topo order: A, then B/C/D by ID):\n    //   A -> R1(540-600) [first room, fits]\n    //   B -> R1(615-675) [prereq A done at 600+15=615, fits R1]\n    //   C -> R1(690-840) [fits R1]\n    //   D -> R1(855-1005) -- exceeds 900! R2: capacity 5 < 10. Unscheduled!\n    //   Only 3 scheduled.\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(4);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n\n  it('test 8: preferred room — greedy fills preferred room, blocks event that needs it', () => {\n    // E1 and E2 prefer R1. E3 MUST use R1 (only room with enough capacity).\n    // E1 and E2 can also fit in R2.\n    // Greedy honors preferences and fills R1 with E1+E2, blocking E3.\n    // Optimal: E1 in R2, E2 in R2, E3 in R1.\n    const events: Event[] = [\n      { id: 'E1', name: 'Team Sync', duration: 120, attendees: 5, preferredRoom: 'R1' },\n      { id: 'E2', name: 'Planning', duration: 120, attendees: 5, preferredRoom: 'R1' },\n      { id: 'E3', name: 'All Hands', duration: 120, attendees: 25 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Big Room', capacity: 50 },\n      { id: 'R2', name: 'Medium Room', capacity: 10 },\n    ];\n    // 270 min window: only 2 events per room (120+15+120=255 fits in 270)\n    const opts: ScheduleOptions = { startTime: 540, endTime: 810, gap: 15 };\n\n    // Greedy:\n    //   E1 -> R1(540-660) [preferred]\n    //   E2 -> R1(675-795) [preferred]\n    //   E3 -> R1(810-930) exceeds 810! R2: capacity 10 < 25. Unscheduled!\n    //   Only 2 scheduled.\n\n    // Optimal:\n    //   E1 -> R2(540-660) -- 5 <= 10\n    //   E2 -> R2(675-795) -- 5 <= 10\n    //   E3 -> R1(540-660) -- 25 <= 50\n    //   All 3 scheduled!\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(3);\n    expect(result.unscheduled).toHaveLength(0);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n\n  it('test 9: interleaving prerequisite chains across rooms', () => {\n    // Two chains: A1->A2->A3 and B1->B2->B3\n    // All events are 90 min. 2 rooms.\n    // Window: 540-1020 (480 min). With gap 15:\n    //   3 events per room: 90+15+90+15+90 = 300 min, fits in 480.\n    // But chains need sequential ordering, so each chain must span time.\n    // The two chains must interleave across rooms to fit all 6 events.\n    const events: Event[] = [\n      { id: 'A1', name: 'Chain A Step 1', duration: 90, attendees: 5 },\n      { id: 'A2', name: 'Chain A Step 2', duration: 90, attendees: 5, prerequisites: ['A1'] },\n      { id: 'A3', name: 'Chain A Step 3', duration: 90, attendees: 5, prerequisites: ['A2'] },\n      { id: 'B1', name: 'Chain B Step 1', duration: 90, attendees: 5 },\n      { id: 'B2', name: 'Chain B Step 2', duration: 90, attendees: 5, prerequisites: ['B1'] },\n      { id: 'B3', name: 'Chain B Step 3', duration: 90, attendees: 5, prerequisites: ['B2'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 20 },\n      { id: 'R2', name: 'Room 2', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    // All 6 should fit since chains can interleave across 2 rooms.\n    // E.g. R1: A1(540-630), B2(645-735), A3(750-840)\n    //      R2: B1(540-630), A2(645-735), B3(750-840)\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(6);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n\n  it('test 10: backtracking — first-fit event 1 placement blocks event 3', () => {\n    // 2 rooms, tight window. Event placement order matters.\n    // E1 (long) and E3 (long) compete for R1 (only room big enough for both).\n    // E2 (short) and E4 (short, prereq E2) fit in R2.\n    // Greedy puts E1 in R1 at 540. E2 in R1 at next slot.\n    // Then E3 can't fit in R1, and can't fit R2 (capacity).\n    const events: Event[] = [\n      { id: 'E1', name: 'Long Talk A', duration: 180, attendees: 8 },\n      { id: 'E2', name: 'Short Talk', duration: 60, attendees: 3 },\n      { id: 'E3', name: 'Long Talk B', duration: 180, attendees: 8 },\n      { id: 'E4', name: 'Follow-up', duration: 60, attendees: 3, prerequisites: ['E2'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Main Room', capacity: 15 },\n      { id: 'R2', name: 'Side Room', capacity: 5 },\n    ];\n    // 420 min window: 2 x 180 + 15 gap = 375, fits in 420.\n    // But E2 (60 min) placed in R1 between them could block.\n    const opts: ScheduleOptions = { startTime: 540, endTime: 960, gap: 15 };\n\n    // Greedy (by ID):\n    //   E1 -> R1(540-720) [8 attendees, only R1 fits]\n    //   E2 -> R1(735-795) [3 attendees, fits R1 and R2, greedy picks R1]\n    //   E3 -> R1(810-990) exceeds 960! R2: 8 > 5. Unscheduled!\n    //   E4 -> R2(615-675) wait, prereq E2 ends 795. R2(810-870). fits.\n    //   3 scheduled, E3 unscheduled.\n\n    // Optimal:\n    //   E1 -> R1(540-720)\n    //   E2 -> R2(540-600)\n    //   E3 -> R1(735-915)  [720+15=735, ends 915 <= 960]\n    //   E4 -> R2(615-675)  [prereq E2 ends 600, 600+15=615]\n    //   All 4 scheduled!\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(4);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n\n  it('test 11: medium scale — 15 events, 4 rooms, greedy suboptimal', () => {\n    // 4 rooms with different capacities. Mix of event sizes.\n    // Large events (L1-L4) need room R1 (capacity 30).\n    // Medium events (M1-M4) need R1 or R2 (capacity 15).\n    // Small events (S1-S7) fit anywhere.\n    //\n    // Time window: 540-1020 (480 min), gap 15.\n    // R1 can fit 4 large events: 4 x 100 + 3 x 15 = 445, fits in 480.\n    // But greedy puts small events in R1 first, blocking large ones.\n\n    const events: Event[] = [\n      // Small events (attendees: 3, fit in all rooms)\n      { id: 'S1', name: 'Small 1', duration: 55, attendees: 3 },\n      { id: 'S2', name: 'Small 2', duration: 55, attendees: 3 },\n      { id: 'S3', name: 'Small 3', duration: 55, attendees: 3 },\n      { id: 'S4', name: 'Small 4', duration: 55, attendees: 3 },\n      { id: 'S5', name: 'Small 5', duration: 55, attendees: 3 },\n      { id: 'S6', name: 'Small 6', duration: 55, attendees: 3 },\n      { id: 'S7', name: 'Small 7', duration: 55, attendees: 3 },\n      // Medium events (attendees: 12, only R1 or R2)\n      { id: 'M1', name: 'Medium 1', duration: 100, attendees: 12 },\n      { id: 'M2', name: 'Medium 2', duration: 100, attendees: 12 },\n      { id: 'M3', name: 'Medium 3', duration: 100, attendees: 12 },\n      { id: 'M4', name: 'Medium 4', duration: 100, attendees: 12 },\n      // Large events (attendees: 20, only R1)\n      { id: 'L1', name: 'Large 1', duration: 100, attendees: 20 },\n      { id: 'L2', name: 'Large 2', duration: 100, attendees: 20 },\n      { id: 'L3', name: 'Large 3', duration: 100, attendees: 20 },\n      { id: 'L4', name: 'Large 4', duration: 100, attendees: 20 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Grand Ballroom', capacity: 30 },\n      { id: 'R2', name: 'Conference Room', capacity: 15 },\n      { id: 'R3', name: 'Meeting Room A', capacity: 8 },\n      { id: 'R4', name: 'Meeting Room B', capacity: 8 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    // Capacity to fit per room (each event 100min or 55min):\n    //   R1: 4 x 100 + 3 x 15 = 445 (fits 4 large) or mix\n    //   R2: 4 x 100 + 3 x 15 = 445 (fits 4 medium)\n    //   R3: ~6 x 55 + 5 x 15 = 405 (fits ~6 small)\n    //   R4: ~6 x 55 + 5 x 15 = 405 (fits ~6 small)\n    //\n    // Optimal assignment:\n    //   R1: L1, L2, L3, L4 (4 events, 445 min)\n    //   R2: M1, M2, M3, M4 (4 events, 445 min)\n    //   R3: S1, S2, S3, S4 (4 events, 4*55 + 3*15 = 265 min)\n    //   R4: S5, S6, S7 (3 events, 3*55 + 2*15 = 195 min)\n    //   All 15 scheduled!\n\n    const result = schedule(events, rooms, opts);\n\n    // The key assertion: all 15 events must be scheduled\n    expect(result.assignments.length).toBe(15);\n    expect(result.unscheduled).toHaveLength(0);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n});\n\n// ============================================================\n// Group 3: Edge cases\n// ============================================================\ndescribe('Group 3: Edge cases', () => {\n\n  it('test 12: detect prerequisite cycle (A->B->C->A)', () => {\n    const events: Event[] = [\n      { id: 'A', name: 'Event A', duration: 30, prerequisites: ['C'] },\n      { id: 'B', name: 'Event B', duration: 30, prerequisites: ['A'] },\n      { id: 'C', name: 'Event C', duration: 30, prerequisites: ['B'] },\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n\n    expect(() => schedule(events, rooms, opts)).toThrow();\n  });\n\n  it('test 13: self-referencing prerequisite (A->A)', () => {\n    const events: Event[] = [\n      { id: 'A', name: 'Self Ref', duration: 30, prerequisites: ['A'] },\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n\n    expect(() => schedule(events, rooms, opts)).toThrow();\n  });\n\n  it('test 14: event longer than time window — should be unscheduled', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Marathon', duration: 600, attendees: 5 },\n      { id: 'E2', name: 'Quick Talk', duration: 30, attendees: 5 },\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n    // 480 min window, E1 needs 600 min\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.unscheduled).toContain('E1');\n    expect(result.assignments.some(a => a.eventId === 'E2')).toBe(true);\n  });\n\n  it('test 15: empty events list', () => {\n    const events: Event[] = [];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n\n  it('test 16: all events prefer same room but cannot all fit — reassign', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Talk 1', duration: 120, attendees: 5, preferredRoom: 'R1' },\n      { id: 'E2', name: 'Talk 2', duration: 120, attendees: 5, preferredRoom: 'R1' },\n      { id: 'E3', name: 'Talk 3', duration: 120, attendees: 5, preferredRoom: 'R1' },\n      { id: 'E4', name: 'Talk 4', duration: 120, attendees: 5, preferredRoom: 'R1' },\n      { id: 'E5', name: 'Talk 5', duration: 120, attendees: 5, preferredRoom: 'R1' },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Preferred Room', capacity: 20 },\n      { id: 'R2', name: 'Other Room', capacity: 20 },\n    ];\n    // 540 min window: each room fits 3 events (120+15+120+15+120=390 < 540)\n    const opts: ScheduleOptions = { startTime: 480, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    // All 5 should be scheduled even though they all prefer R1\n    // R1 can hold 3: (480-600, 615-735, 750-870) or 4 with tight packing\n    // Actually: 120+15 = 135 per slot. 540/135 = 4 events per room. So R1 fits 4, R2 fits the 5th.\n    expect(result.assignments.length).toBe(5);\n    expect(result.unscheduled).toHaveLength(0);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n});\n\n// ============================================================\n// Group 4: Constraint combinations\n// ============================================================\ndescribe('Group 4: Constraint combinations', () => {\n\n  it('test 17: custom gap (30 min) between events in same room', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Session 1', duration: 60, attendees: 5 },\n      { id: 'E2', name: 'Session 2', duration: 60, attendees: 5 },\n      { id: 'E3', name: 'Session 3', duration: 60, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room', capacity: 20 },\n    ];\n    // With 30 min gap: 60+30+60+30+60 = 240 min. Window is 240 min. Exact fit.\n    const opts: ScheduleOptions = { startTime: 540, endTime: 780, gap: 30 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(3);\n    expect(result.unscheduled).toHaveLength(0);\n    assertNoOverlap(result, 30);\n    assertInWindow(result, opts);\n\n    // Verify actual gaps are >= 30\n    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n    for (let i = 0; i < sorted.length - 1; i++) {\n      const actualGap = sorted[i + 1].startTime - sorted[i].endTime;\n      expect(actualGap).toBeGreaterThanOrEqual(30);\n    }\n  });\n\n  it('test 18: prerequisites + capacity constraints together', () => {\n    // Chain: Setup -> Demo -> Review\n    // Setup needs small room (5 attendees), Demo needs big room (30), Review needs small (5).\n    // Only R1 (capacity 50) fits Demo.\n    const events: Event[] = [\n      { id: 'setup', name: 'Setup', duration: 45, attendees: 5 },\n      { id: 'demo', name: 'Demo', duration: 90, attendees: 30 },\n      { id: 'review', name: 'Review', duration: 45, attendees: 5, prerequisites: ['demo'] },\n      { id: 'prep', name: 'Prep', duration: 45, attendees: 5, prerequisites: ['setup'] },\n    ];\n    // demo depends on nothing, but prep depends on setup\n    // Rewrite: setup -> prep, setup -> demo (parallel), demo -> review\n    const eventsFixed: Event[] = [\n      { id: 'setup', name: 'Setup', duration: 45, attendees: 5 },\n      { id: 'demo', name: 'Demo', duration: 90, attendees: 30, prerequisites: ['setup'] },\n      { id: 'review', name: 'Review', duration: 45, attendees: 5, prerequisites: ['demo'] },\n      { id: 'prep', name: 'Prep', duration: 45, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Auditorium', capacity: 50 },\n      { id: 'R2', name: 'Huddle Room', capacity: 8 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(eventsFixed, rooms, opts);\n\n    expect(result.assignments).toHaveLength(4);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, eventsFixed, 15);\n    assertCapacity(result, eventsFixed, rooms);\n    assertInWindow(result, opts);\n\n    // Verify demo is in R1 (only room big enough)\n    const demoAssignment = result.assignments.find(a => a.eventId === 'demo');\n    expect(demoAssignment).toBeDefined();\n    expect(demoAssignment!.roomId).toBe('R1');\n  });\n\n  it('test 19: preferred room honored when possible', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Preferred Event', duration: 60, attendees: 5, preferredRoom: 'R2' },\n      { id: 'E2', name: 'Other Event', duration: 60, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 20 },\n      { id: 'R2', name: 'Room 2', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n\n    const e1Assign = result.assignments.find(a => a.eventId === 'E1');\n    expect(e1Assign).toBeDefined();\n    expect(e1Assign!.roomId).toBe('R2');\n  });\n\n  it('test 20: gap applies between prerequisite events', () => {\n    // A -> B. Even if different rooms, B can't start until A finishes + gap.\n    const events: Event[] = [\n      { id: 'A', name: 'First', duration: 60, attendees: 5 },\n      { id: 'B', name: 'Second', duration: 60, attendees: 5, prerequisites: ['A'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 20 },\n      { id: 'R2', name: 'Room 2', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n\n    const aAssign = result.assignments.find(a => a.eventId === 'A')!;\n    const bAssign = result.assignments.find(a => a.eventId === 'B')!;\n\n    // B must start at least gap (30 min) after A ends\n    expect(bAssign.startTime).toBeGreaterThanOrEqual(aAssign.endTime + 30);\n  });\n});\n\n// ============================================================\n// Group 5: Hard tests — scaling, optimality, edge precision\n// ============================================================\ndescribe('Group 5: Hard tests', () => {\n\n  it('test 21: scaling stress — 30 events, 5 rooms, prerequisite chains (must complete < 5s)', () => {\n    // 5 chains of 3 events each (15 chain events) + 15 independent \"filler\" events.\n    // Chains require sequential ordering; fillers go wherever they fit.\n    // 5 rooms with varying capacity: only R1 (cap 50) fits the \"big\" chain heads.\n    // Each chain: head (big, 50 attendees), step2 (medium, 15 attendees), step3 (small, 5 attendees).\n    // Fillers: 5 attendees each, 40 min each.\n    // Window: 540-1080 (540 min), gap 10.\n    //\n    // Chain events: 60 min each. Chain timing: 60+10+60+10+60 = 200 min per chain.\n    // 5 chains can interleave across rooms since chain members can go in different rooms\n    // (only heads need R1, and R1 has 540 min: 5 x 60 + 4 x 10 = 340, fits).\n    // Filler events: 15 events x 40 min. With gap 10: each room slot is 50 min.\n    // Across 5 rooms after chain events are placed, plenty of space.\n    //\n    // Key test: algorithm must handle 30 events without exponential blowup.\n\n    const events: Event[] = [];\n\n    // 5 prerequisite chains\n    for (let c = 1; c <= 5; c++) {\n      events.push({ id: `C${c}A`, name: `Chain ${c} Head`, duration: 60, attendees: 50 });\n      events.push({ id: `C${c}B`, name: `Chain ${c} Step 2`, duration: 60, attendees: 15, prerequisites: [`C${c}A`] });\n      events.push({ id: `C${c}C`, name: `Chain ${c} Step 3`, duration: 60, attendees: 5, prerequisites: [`C${c}B`] });\n    }\n\n    // 15 independent filler events\n    for (let f = 1; f <= 15; f++) {\n      events.push({ id: `F${f}`, name: `Filler ${f}`, duration: 40, attendees: 5 });\n    }\n\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Grand Hall', capacity: 50 },\n      { id: 'R2', name: 'Conference A', capacity: 20 },\n      { id: 'R3', name: 'Conference B', capacity: 20 },\n      { id: 'R4', name: 'Meeting Room A', capacity: 10 },\n      { id: 'R5', name: 'Meeting Room B', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1080, gap: 10 };\n\n    const t0 = performance.now();\n    const result = schedule(events, rooms, opts);\n    const elapsed = performance.now() - t0;\n\n    // Must complete in under 5 seconds\n    expect(elapsed, `Took ${elapsed.toFixed(0)}ms, must be < 5000ms`).toBeLessThan(5000);\n\n    // All 30 events should be schedulable\n    expect(result.assignments.length).toBe(30);\n    expect(result.unscheduled).toHaveLength(0);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 10);\n    assertCapacity(result, events, rooms);\n    assertPrerequisites(result, events, 10);\n\n    // Verify chain heads are in R1 (only room with capacity 50)\n    for (let c = 1; c <= 5; c++) {\n      const headAssign = result.assignments.find(a => a.eventId === `C${c}A`);\n      expect(headAssign, `Chain ${c} head should be assigned`).toBeDefined();\n      expect(headAssign!.roomId, `Chain ${c} head must be in R1 (only room cap >= 50)`).toBe('R1');\n    }\n  });\n\n  it('test 22: optimality — 8 events, 3 rooms, greedy gets 6 but optimal gets 8', () => {\n    // Setup: 3 rooms, 8 events. A naive approach that greedily assigns events by ID order\n    // will waste room capacity, leaving 2 events unscheduled.\n    //\n    // R1 (cap 40): only room for XL events (30 attendees)\n    // R2 (cap 15): fits medium events (12 attendees) and small (5)\n    // R3 (cap 8):  fits small events only (5 attendees)\n    //\n    // Events:\n    //   A1, A2: XL (30 attendees, 120 min) — MUST go in R1\n    //   B1, B2: medium (12 attendees, 120 min) — R1 or R2\n    //   C1, C2, C3, C4: small (5 attendees, 120 min) — any room\n    //\n    // Window: 540-810 (270 min), gap 15. Each room fits 2 events: 120+15+120 = 255 <= 270.\n    //\n    // Greedy by ID (A1, A2, B1, B2, C1-C4):\n    //   A1 -> R1(540-660), A2 -> R1(675-795). R1 full.\n    //   B1 -> R2(540-660), B2 -> R2(675-795). R2 full.\n    //   C1 -> R3(540-660), C2 -> R3(675-795). R3 full.\n    //   C3 -> no room. Unscheduled!\n    //   C4 -> no room. Unscheduled!\n    //   Result: 6/8.\n    //\n    // Optimal:\n    //   R1: A1(540-660), A2(675-795) — XL events in the only room that fits them\n    //   R2: B1(540-660), B2(675-795) — medium events\n    //   R3: C1(540-660), C2(675-795) — small events\n    //   Wait, that's still 6. We need to rethink...\n    //\n    // Revised: make it so the greedy assigns B events to R1 first, wasting R1 for XL events.\n    // Events in alphabetical order: B1, B2, C1, C2, C3, C4, X1, X2\n    // B events come first alphabetically, get placed in R1.\n    // Then X1, X2 (XL, 30 attendees) can't fit anywhere.\n    //\n    // Actually, let me reconsider. Greedy by ID order:\n    //   B1 (12 att) -> R1(540-660) [first room that fits]\n    //   B2 (12 att) -> R1(675-795) [R1 still has slot]\n    //   C1 (5 att) -> R2(540-660)\n    //   C2 (5 att) -> R2(675-795)\n    //   C3 (5 att) -> R3(540-660)\n    //   C4 (5 att) -> R3(675-795)\n    //   X1 (30 att) -> R1 full. R2 cap 15 < 30. R3 cap 8 < 30. Unscheduled!\n    //   X2 (30 att) -> same. Unscheduled!\n    //   Result: 6/8.\n    //\n    // Optimal:\n    //   R1: X1(540-660), X2(675-795)\n    //   R2: B1(540-660), B2(675-795)\n    //   R3: C1(540-660), C2(675-795)\n    //   Remaining: C3, C4 — wait, 8 events total. R1 has 2, R2 has 2, R3 has 2 = 6. Still 6!\n    //\n    // Need more room capacity. Let's use 4 rooms with 2 slots each = 8 slots total.\n    // R1 (cap 40), R2 (cap 15), R3 (cap 8), R4 (cap 8). Each fits 2 events.\n    //   Optimal: R1: X1, X2. R2: B1, B2. R3: C1, C2. R4: C3, C4. All 8!\n    //   Greedy: B1->R1, B2->R1, C1->R2, C2->R2, C3->R3, C4->R3, X1->R4(cap 8 < 30: fail!), X2 fail.\n    //   Greedy: 6/8.\n\n    const events: Event[] = [\n      { id: 'B1', name: 'Medium Talk 1', duration: 120, attendees: 12 },\n      { id: 'B2', name: 'Medium Talk 2', duration: 120, attendees: 12 },\n      { id: 'C1', name: 'Small Talk 1', duration: 120, attendees: 5 },\n      { id: 'C2', name: 'Small Talk 2', duration: 120, attendees: 5 },\n      { id: 'C3', name: 'Small Talk 3', duration: 120, attendees: 5 },\n      { id: 'C4', name: 'Small Talk 4', duration: 120, attendees: 5 },\n      { id: 'X1', name: 'Keynote 1', duration: 120, attendees: 30 },\n      { id: 'X2', name: 'Keynote 2', duration: 120, attendees: 30 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Grand Hall', capacity: 40 },\n      { id: 'R2', name: 'Conference Room', capacity: 15 },\n      { id: 'R3', name: 'Meeting Room A', capacity: 8 },\n      { id: 'R4', name: 'Meeting Room B', capacity: 8 },\n    ];\n    // 270 min window, 15 gap: each room fits exactly 2 events (120+15+120=255<=270)\n    const opts: ScheduleOptions = { startTime: 540, endTime: 810, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    // ALL 8 must be scheduled\n    expect(result.assignments.length).toBe(8);\n    expect(result.unscheduled).toHaveLength(0);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n\n    // Keynotes MUST be in R1 (only room with capacity >= 30)\n    const x1 = result.assignments.find(a => a.eventId === 'X1');\n    const x2 = result.assignments.find(a => a.eventId === 'X2');\n    expect(x1!.roomId).toBe('R1');\n    expect(x2!.roomId).toBe('R1');\n  });\n\n  it('test 23: tight packing with gaps — 3 events in room with exact-fit window', () => {\n    // Room has exactly enough time for 3 events if gaps are minimized to configured value.\n    // 3 events of 80 min each, gap 10 min.\n    // Total: 80 + 10 + 80 + 10 + 80 = 260 min.\n    // Window: exactly 260 min (540-800).\n    // Must schedule all 3. If the scheduler adds even 1 extra minute of gap, one won't fit.\n\n    const events: Event[] = [\n      { id: 'P1', name: 'Pack 1', duration: 80, attendees: 5 },\n      { id: 'P2', name: 'Pack 2', duration: 80, attendees: 5 },\n      { id: 'P3', name: 'Pack 3', duration: 80, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Tight Room', capacity: 10 },\n    ];\n    // Exact fit: 80+10+80+10+80 = 260 min window\n    const opts: ScheduleOptions = { startTime: 540, endTime: 800, gap: 10 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(3);\n    expect(result.unscheduled).toHaveLength(0);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 10);\n\n    // Verify the packing is exact\n    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n    expect(sorted[0].startTime).toBe(540);\n    expect(sorted[0].endTime).toBe(620);\n    expect(sorted[1].startTime).toBe(630); // 620 + 10\n    expect(sorted[1].endTime).toBe(710);\n    expect(sorted[2].startTime).toBe(720); // 710 + 10\n    expect(sorted[2].endTime).toBe(800);\n  });\n\n  it('test 24: prerequisite chain with room capacity mismatch — A(big)->B(small)->C(big)', () => {\n    // Chain A -> B -> C.\n    // A needs big room (20 attendees), B needs small room (3 attendees), C needs big room (20 attendees).\n    // Only 1 big room (R1, cap 25) and 1 small room (R2, cap 5).\n    // The scheduler must assign A->R1, B->R2 (or R1), C->R1, respecting prerequisites.\n    //\n    // Timing: each 60 min, gap 15.\n    // A in R1: 540-600.\n    // B must start >= 615 (600 + 15). B in R2: 615-675. Or B in R1: 615-675.\n    // C must start >= 690 (675 + 15). C in R1: needs 690-750.\n    //   If B was in R1 at 615-675, R1 next slot after gap: 675+15=690. C at 690-750. Works!\n    //   If B was in R2 at 615-675, R1 next slot after A: 600+15=615. C at 615-675. But prereq B ends 675, C needs >= 690. So C in R1 at 690-750. Works!\n    //\n    // Window 540-750 (210 min). 3 events of 60 + 2 gaps of 15 = 210. Exact fit.\n    // Add a filler event D (20 attendees, 60 min) that competes for R1 time.\n    // D has no prereqs, needs R1 (20 > 5).\n    // If D goes in R1 at 540-600, that's A's slot. Conflict!\n    // If D goes in R1 at 615-675, that could block C.\n    //\n    // With window 540-810 (270 min), R1 can fit:\n    //   A(540-600), B or D(615-675), C(690-750), and maybe D(765-825) if window allows to 825.\n    // Window to 810: D at 765-825 exceeds 810. So 4 events need careful arrangement.\n    //\n    // Simpler: window 540-810 (270 min). R1 fits 3 events (60+15+60+15+60=210 <= 270).\n    // A must be in R1 (20 att). C must be in R1 (20 att). D must be in R1 (20 att).\n    // B can go in R2. So R1 has A, C, D = 3 events. B in R2.\n    // Prereq: A before B, B before C. A in R1 at 540-600. B in R2 at 615-675.\n    // C in R1 at 690-750 (after B at 675+15=690). D in R1 at 615-675 (gap after A: 600+15=615).\n    // Check: R1 has A(540-600), D(615-675), C(690-750). No overlap? 600+15=615<=615, 675+15=690<=690. Yes!\n    // All 4 scheduled.\n    //\n    // A greedy might put B in R1 at 615-675 (it fits there), then D can't fit R1\n    // (next R1 slot after B: 690, D at 690-750, C needs R1 after 690 too. C prereq B ends 675+15=690.\n    // C at 690-750 if D not there. But D also at 690-750 = overlap. D at 765-825 > 810. Unscheduled!\n\n    const events: Event[] = [\n      { id: 'A', name: 'Opening Ceremony', duration: 60, attendees: 20 },\n      { id: 'B', name: 'Breakout Session', duration: 60, attendees: 3, prerequisites: ['A'] },\n      { id: 'C', name: 'Closing Ceremony', duration: 60, attendees: 20, prerequisites: ['B'] },\n      { id: 'D', name: 'Exhibition', duration: 60, attendees: 20 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Main Hall', capacity: 25 },\n      { id: 'R2', name: 'Breakout Room', capacity: 5 },\n    ];\n    // R1 fits 3 events: 60+15+60+15+60 = 210 <= 270\n    const opts: ScheduleOptions = { startTime: 540, endTime: 810, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(4);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n\n    // A, C, D must be in R1 (only room with capacity >= 20)\n    const aAssign = result.assignments.find(a => a.eventId === 'A');\n    const cAssign = result.assignments.find(a => a.eventId === 'C');\n    const dAssign = result.assignments.find(a => a.eventId === 'D');\n    expect(aAssign!.roomId).toBe('R1');\n    expect(cAssign!.roomId).toBe('R1');\n    expect(dAssign!.roomId).toBe('R1');\n\n    // B must be in R2 (to free R1 space for D)\n    const bAssign = result.assignments.find(a => a.eventId === 'B');\n    expect(bAssign!.roomId).toBe('R2');\n  });\n\n  it('test 25: multiple independent groups — 3 clusters with no cross-dependencies', () => {\n    // 3 independent clusters of events with their own prerequisite chains.\n    // Cluster 1: Alpha1 -> Alpha2 -> Alpha3 (big events, 20 att)\n    // Cluster 2: Beta1 -> Beta2 (medium events, 10 att)\n    // Cluster 3: Gamma1, Gamma2, Gamma3 (independent small events, 3 att)\n    //\n    // Rooms: R1 (cap 25), R2 (cap 12), R3 (cap 5).\n    // Alpha cluster must use R1. Beta must use R1 or R2. Gamma can use any room.\n    //\n    // Window: 540-1020 (480 min), gap 15.\n    // R1: Alpha1(540-630), Alpha2(645-735), Alpha3(750-840) = 300 min.\n    //   Still has 840-1020 = 180 min free.\n    // R2: Beta1(540-630), Beta2(645-735) = 195 min. Still has 735-1020 = 285 min free.\n    // R3: Gamma1(540-630), Gamma2(645-735), Gamma3(750-840).\n    //\n    // All 8 events fit easily. The key test is that independent groups don't interfere.\n\n    const events: Event[] = [\n      // Cluster 1: big chain\n      { id: 'Alpha1', name: 'Alpha Step 1', duration: 90, attendees: 20 },\n      { id: 'Alpha2', name: 'Alpha Step 2', duration: 90, attendees: 20, prerequisites: ['Alpha1'] },\n      { id: 'Alpha3', name: 'Alpha Step 3', duration: 90, attendees: 20, prerequisites: ['Alpha2'] },\n      // Cluster 2: medium chain\n      { id: 'Beta1', name: 'Beta Step 1', duration: 90, attendees: 10 },\n      { id: 'Beta2', name: 'Beta Step 2', duration: 90, attendees: 10, prerequisites: ['Beta1'] },\n      // Cluster 3: independent small events\n      { id: 'Gamma1', name: 'Gamma Event 1', duration: 90, attendees: 3 },\n      { id: 'Gamma2', name: 'Gamma Event 2', duration: 90, attendees: 3 },\n      { id: 'Gamma3', name: 'Gamma Event 3', duration: 90, attendees: 3 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Auditorium', capacity: 25 },\n      { id: 'R2', name: 'Seminar Room', capacity: 12 },\n      { id: 'R3', name: 'Small Room', capacity: 5 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(8);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n\n    // Verify each cluster's events don't break each other's prerequisites\n    // Alpha chain: Alpha1 before Alpha2 before Alpha3\n    const a1 = result.assignments.find(a => a.eventId === 'Alpha1')!;\n    const a2 = result.assignments.find(a => a.eventId === 'Alpha2')!;\n    const a3 = result.assignments.find(a => a.eventId === 'Alpha3')!;\n    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n    expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n\n    // Beta chain: Beta1 before Beta2\n    const b1 = result.assignments.find(a => a.eventId === 'Beta1')!;\n    const b2 = result.assignments.find(a => a.eventId === 'Beta2')!;\n    expect(b2.startTime).toBeGreaterThanOrEqual(b1.endTime + 15);\n\n    // Alpha events must be in R1 (only room with cap >= 20)\n    expect(a1.roomId).toBe('R1');\n    expect(a2.roomId).toBe('R1');\n    expect(a3.roomId).toBe('R1');\n  });\n\n  it('test 26: preference vs feasibility with prerequisites', () => {\n    // Events prefer rooms they can't actually use due to prerequisite timing constraints.\n    //\n    // Setup: A -> B -> C chain. All prefer R1.\n    // D is independent, large (25 att), MUST use R1.\n    // D is 180 min, takes most of R1's time.\n    //\n    // R1 (cap 30): D fills most of it.\n    // R2 (cap 10): can hold A, B, C (5 att each).\n    //\n    // Window: 540-840 (300 min), gap 15.\n    // D in R1: 540-720 (180 min). R1 remaining after gap: 735-840 = 105 min.\n    // A, B, C are each 60 min. Chain: 60+15+60+15+60 = 210 min. Won't fit in R1's 105 min remainder.\n    // So A, B, C must go to R2 despite preferring R1.\n    // R2: A(540-600), B(615-675), C(690-750). Fits in 300 min window.\n    //\n    // Or: A in R1 first at 540-600. Then D in R1 at 615-795. Then B after A at 615+...\n    // B needs A done at 600+15=615. B in R2 at 615-675. C in R2 at 690-750.\n    // D in R1 at 615-795: fits (795 <= 840). R1 has A(540-600), D(615-795).\n    // That works too: A in R1 (preferred!), B, C in R2. But we need all 4 scheduled.\n    //\n    // Let's make it so all chain events genuinely can't fit in R1.\n    // D is 240 min. R1: D(540-780). Remaining: 780+15=795 to 840 = 45 min. Too short for 60 min events.\n    // Chain events prefer R1 but can't use it (no space after D).\n\n    const events: Event[] = [\n      { id: 'A', name: 'Phase 1', duration: 60, attendees: 5, preferredRoom: 'R1' },\n      { id: 'B', name: 'Phase 2', duration: 60, attendees: 5, preferredRoom: 'R1', prerequisites: ['A'] },\n      { id: 'C', name: 'Phase 3', duration: 60, attendees: 5, preferredRoom: 'R1', prerequisites: ['B'] },\n      { id: 'D', name: 'All-Day Workshop', duration: 240, attendees: 25 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Main Hall', capacity: 30 },\n      { id: 'R2', name: 'Side Room', capacity: 10 },\n    ];\n    // 300 min window. D takes 240 min of R1. Chain needs 210 min.\n    const opts: ScheduleOptions = { startTime: 540, endTime: 840, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(4);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n\n    // D must be in R1 (25 attendees, only R1 has cap 30)\n    const dAssign = result.assignments.find(a => a.eventId === 'D');\n    expect(dAssign!.roomId).toBe('R1');\n  });\n\n  it('test 27: near-impossible packing — 10 events, 2 rooms, exactly 9 fit', () => {\n    // 10 events of 60 min each. 2 rooms. Gap 10 min.\n    // Window: 540-855 (315 min).\n    // Per room: floor((315 + 10) / (60 + 10)) = floor(325/70) = 4.64... → 4 events.\n    //   4 events: 60+10+60+10+60+10+60 = 270 <= 315. Fits!\n    //   5 events: 60+10+60+10+60+10+60+10+60 = 340 > 315. Doesn't fit!\n    // 2 rooms x 4 events = 8 events max.\n    //\n    // Hmm, that gives 8 not 9. Let me adjust.\n    // Want 9 fit, 1 doesn't.\n    // Per room: need one room to hold 5 events, other holds 4. Total 9.\n    // 5 events: 5*60 + 4*10 = 340 min. Window needs >= 340.\n    // 4 events: 4*60 + 3*10 = 270 min.\n    // Set window to 340 min (540-880).\n    // Room 1: 5 events (340 min, exact fit).\n    // Room 2: 4 events (270 <= 340). 5th would need 340 = exact fit too.\n    // Actually both rooms fit 5 events = 10 total. That's not what we want.\n    //\n    // Different approach: make events different sizes. Or use capacity constraints.\n    // 10 events. 5 \"big\" (15 att) must go to R1 (cap 20). 5 \"small\" (5 att) go to R2 (cap 8).\n    // Window: 540-880 (340 min), gap 10.\n    // R1 fits 5 big events: 5*60 + 4*10 = 340. Exact!\n    // R2 fits 4 small events: 4*60 + 3*10 = 270 <= 340. 5th: 5*60+4*10=340. Also exact!\n    // Wait, R2 also fits 5. So all 10 fit. Not what we want.\n    //\n    // Let me make R1 hold 5, R2 hold only 4.\n    // R2 window: shorter capacity via making one small event longer.\n    // Or: 5 big events for R1, 5 small for R2, but window is 330 min.\n    // R1: 5*60+4*10=340 > 330. Only 4 fit: 4*60+3*10=270<=330.\n    // That gives 4+4=8. Need 9.\n    //\n    // OK, different approach: 10 events all same size, 3 rooms.\n    // 10 events of 55 min, gap 10. Window 540-800 (260 min).\n    // Per room: 55+10+55+10+55+10+55 = 250 <= 260 → 4 events.\n    //   5 events: 55*5+10*4 = 315 > 260. No.\n    // 3 rooms x 4 = 12 max. But we want exactly 9 to fit and 10th not.\n    //\n    // Simplest: 10 events, 3 rooms. Make 9 fit exactly, 10th has no room.\n    // Use capacity: 5 big (att 15), 5 small (att 5).\n    // R1 (cap 20): big events.\n    // R2 (cap 8): small events.\n    // R3 (cap 8): small events.\n    // Window: 540-880 (340 min), gap 10.\n    // R1: 5 big events: 5*60+4*10=340. Exact!\n    // R2: 4 small events: 4*60+3*10=270<=340. (5th: 5*60+4*10=340, also fits.)\n    // R3: 1 remaining small event.\n    // But that's 5+5 = 10 all fit.\n    //\n    // Revised: Use just 2 rooms. 10 events of 60 min each, all 5 attendees.\n    // R1 (cap 10), R2 (cap 10). Window: 540-855 (315 min), gap 10.\n    // Each room: 4 events (4*60+3*10=270<=315). 5th: 5*60+4*10=340>315.\n    // 2 rooms x 4 = 8. Want 9.\n    //\n    // Window: 540-870 (330 min), gap 10.\n    // 4 events: 270 <= 330. 5th: 340 > 330.\n    // Still 8 max.\n    //\n    // Increase to 5 per room: window needs 340 min.\n    // Window 340 (540-880): 5 per room = 10 total. All fit.\n    // Window 339 (540-879): 4 per room = 8 total.\n    //\n    // To get 9: one room fits 5, other fits 4.\n    // Make one room bigger in capacity? No, capacity isn't the constraint here, time is.\n    // Make events different durations!\n    //\n    // 5 events of 60 min + 5 events of 50 min. 2 rooms, gap 10.\n    // Window: 540-880 (340 min).\n    // Room can fit: 60+10+60+10+60+10+60+10+60 = 340. 5 events of 60 min exact.\n    //   Or: 50+10+50+10+50+10+50+10+50 = 290. 5 events of 50 min in 290 min.\n    //   Or mix: 60+10+50+10+60+10+50+10+60 = 320. 5 mixed events in 320 <= 340.\n    //\n    // 2 rooms x 5 = 10 events all fit. Still too many.\n    //\n    // Simplest approach: 2 rooms, window that fits exactly 9.\n    // R1 fits 5 events: window = 340 for 60-min events with gap 10.\n    // R2 fits 4 events only: make R2 smaller capacity-wise? No, that doesn't help with time.\n    // Make R2 have a different schedule? The window applies to both rooms equally.\n    //\n    // Use 3 rooms: R1 fits 4, R2 fits 3, R3 fits 2. Total = 9.\n    // 10 events of 90 min each, gap 10. Window: 540-940 (400 min).\n    // Per room: 4 events: 4*90+3*10=390<=400. 5 events: 5*90+4*10=490>400.\n    // 3 rooms x 4 = 12 max, but we only have 10 events. All fit!\n    //\n    // Alright, let me just use a simpler design with capacity constraints to force exactly 9.\n    // 5 big events (20 att) + 5 small events (5 att).\n    // R1 (cap 25): fits big and small.\n    // R2 (cap 8): fits small only.\n    // Window: 540-850 (310 min), gap 10.\n    // R1: can hold 4 events of 60 min: 4*60+3*10=270<=310. 5 events: 340>310. Max 4.\n    // R2: can hold 4 events of 60 min: same math. Max 4.\n    // Total max: 8. Still not 9.\n    //\n    // 3 rooms: R1 (cap 25), R2 (cap 25), R3 (cap 8).\n    // Window: 540-810 (270 min), gap 10. Per room max: 3 events (3*60+2*10=200<=270),\n    //   4th: 4*60+3*10=270 = exact fit! So 4 per room.\n    // 3 rooms x 4 = 12 max. 10 events all fit.\n    //\n    // I'll use a more constrained approach: different durations + capacity.\n    // 10 events. Room R1 (cap 20), R2 (cap 8).\n    // 6 big events (att 15, dur 60): must go in R1.\n    // 4 small events (att 5, dur 60): can go in either room.\n    // Window: 540-880 (340 min), gap 10.\n    // R1: max 5 events (5*60+4*10=340, exact). Can hold 5 big or mix.\n    //   Need to hold all 6 big events but only 5 fit → 1 big event unscheduled? No, small events\n    //   can go in R2, freeing R1 for big events. But only 5 big events fit in R1.\n    //   6th big event → R1 full, R2 cap 8 < 15. Unscheduled!\n    // R2: max 5 events of small. 4 small events all fit.\n    // Total: 5 big + 4 small = 9. 1 big unscheduled.\n    // This works!\n\n    const events: Event[] = [\n      { id: 'BIG1', name: 'Big Event 1', duration: 60, attendees: 15 },\n      { id: 'BIG2', name: 'Big Event 2', duration: 60, attendees: 15 },\n      { id: 'BIG3', name: 'Big Event 3', duration: 60, attendees: 15 },\n      { id: 'BIG4', name: 'Big Event 4', duration: 60, attendees: 15 },\n      { id: 'BIG5', name: 'Big Event 5', duration: 60, attendees: 15 },\n      { id: 'BIG6', name: 'Big Event 6', duration: 60, attendees: 15 },\n      { id: 'SML1', name: 'Small Event 1', duration: 60, attendees: 5 },\n      { id: 'SML2', name: 'Small Event 2', duration: 60, attendees: 5 },\n      { id: 'SML3', name: 'Small Event 3', duration: 60, attendees: 5 },\n      { id: 'SML4', name: 'Small Event 4', duration: 60, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Large Room', capacity: 20 },\n      { id: 'R2', name: 'Small Room', capacity: 8 },\n    ];\n    // R1 fits exactly 5: 5*60 + 4*10 = 340. R2 fits 5: 5*60 + 4*10 = 340.\n    // But big events (15 att) can only go in R1 (cap 20). 6 big events, only 5 R1 slots.\n    const opts: ScheduleOptions = { startTime: 540, endTime: 880, gap: 10 };\n\n    const result = schedule(events, rooms, opts);\n\n    // Exactly 9 events should be scheduled (5 big in R1 + 4 small in R2)\n    expect(result.assignments.length).toBe(9);\n    expect(result.unscheduled).toHaveLength(1);\n\n    // The unscheduled event must be a BIG event (one of BIG1-BIG6)\n    expect(result.unscheduled[0]).toMatch(/^BIG/);\n\n    assertCapacity(result, events, rooms);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 10);\n\n    // All small events should be scheduled\n    for (let i = 1; i <= 4; i++) {\n      expect(result.assignments.some(a => a.eventId === `SML${i}`), `SML${i} should be scheduled`).toBe(true);\n    }\n\n    // Exactly 5 big events should be scheduled\n    const scheduledBig = result.assignments.filter(a => a.eventId.startsWith('BIG'));\n    expect(scheduledBig.length).toBe(5);\n  });\n\n  it('test 28: long prerequisite chain forces sequential — A->B->C->D->E in 5h window', () => {\n    // A -> B -> C -> D -> E, each 60 min, gap 15 min.\n    // Total: 5*60 + 4*15 = 360 min.\n    // Window: exactly 360 min (540-900).\n    // Only 1 room. Must schedule all 5 sequentially. Exact fit.\n\n    const events: Event[] = [\n      { id: 'A', name: 'Step A', duration: 60, attendees: 5 },\n      { id: 'B', name: 'Step B', duration: 60, attendees: 5, prerequisites: ['A'] },\n      { id: 'C', name: 'Step C', duration: 60, attendees: 5, prerequisites: ['B'] },\n      { id: 'D', name: 'Step D', duration: 60, attendees: 5, prerequisites: ['C'] },\n      { id: 'E', name: 'Step E', duration: 60, attendees: 5, prerequisites: ['D'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room', capacity: 10 },\n    ];\n    // Exact fit: 5*60 + 4*15 = 360 min\n    const opts: ScheduleOptions = { startTime: 540, endTime: 900, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(5);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n\n    // Verify exact sequential order\n    const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n    expect(sorted[0].eventId).toBe('A');\n    expect(sorted[1].eventId).toBe('B');\n    expect(sorted[2].eventId).toBe('C');\n    expect(sorted[3].eventId).toBe('D');\n    expect(sorted[4].eventId).toBe('E');\n\n    // Verify exact timing (only one valid schedule)\n    expect(sorted[0].startTime).toBe(540);\n    expect(sorted[0].endTime).toBe(600);\n    expect(sorted[1].startTime).toBe(615);\n    expect(sorted[1].endTime).toBe(675);\n    expect(sorted[2].startTime).toBe(690);\n    expect(sorted[2].endTime).toBe(750);\n    expect(sorted[3].startTime).toBe(765);\n    expect(sorted[3].endTime).toBe(825);\n    expect(sorted[4].startTime).toBe(840);\n    expect(sorted[4].endTime).toBe(900);\n  });\n});\n\n// ============================================================\n// Group 6: Gemini edge-case gauntlet\n// ============================================================\ndescribe('Group 6: Gemini edge-case gauntlet', () => {\n\n  it('test 29: cross-room prerequisite gap — tight window forces one unscheduled', () => {\n    // Two 60-min events, E2 depends on E1. Gap = 15.\n    // Even if placed in different rooms, E2 can't start until E1 ends + gap.\n    // E1 at 0 ends at 60. E2 starts at 75, ends at 135 > 130. Doesn't fit.\n    // Only one event can be scheduled.\n    const events: Event[] = [\n      { id: 'E1', name: 'Foundation', duration: 60, attendees: 5 },\n      { id: 'E2', name: 'Follow-up', duration: 60, attendees: 5, prerequisites: ['E1'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 10 },\n      { id: 'R2', name: 'Room 2', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 0, endTime: 130, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.unscheduled).toHaveLength(1);\n    expect(result.assignments).toHaveLength(1);\n    // E1 should be the one scheduled (E2 depends on it and can't fit after)\n    expect(result.assignments[0].eventId).toBe('E1');\n    expect(result.unscheduled).toContain('E2');\n    assertInWindow(result, opts);\n    assertPrerequisites(result, events, 15);\n  });\n\n  it('test 30: sacrifice for greater good — skip long event to fit two short ones', () => {\n    // 1 room. 1 long event (90 min) vs 2 short events (30 min each). Gap = 10.\n    // Long event: 90 min uses entire window (90 <= 100). Schedules 1 event.\n    // Two short events: 30 + 10 + 30 = 70 <= 100. Schedules 2 events.\n    // Optimal scheduler maximizes count → skips the long event.\n    const events: Event[] = [\n      { id: 'LONG', name: 'Marathon Session', duration: 90, attendees: 5 },\n      { id: 'SHORT1', name: 'Quick Talk 1', duration: 30, attendees: 5 },\n      { id: 'SHORT2', name: 'Quick Talk 2', duration: 30, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Only Room', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 0, endTime: 100, gap: 10 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toContain('LONG');\n    expect(result.assignments.some(a => a.eventId === 'SHORT1')).toBe(true);\n    expect(result.assignments.some(a => a.eventId === 'SHORT2')).toBe(true);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 10);\n  });\n\n  it('test 31: non-existent preferred room — event uses available room instead', () => {\n    // Event prefers \"Narnia\" but only \"Real\" exists. Preference is a hint, not a hard constraint.\n    const events: Event[] = [\n      { id: 'E1', name: 'Misguided Event', duration: 60, attendees: 5, preferredRoom: 'Narnia' },\n    ];\n    const rooms: Room[] = [\n      { id: 'Real', name: 'Real Room', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 0, endTime: 120 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0].eventId).toBe('E1');\n    expect(result.assignments[0].roomId).toBe('Real');\n    assertInWindow(result, opts);\n  });\n\n  it('test 32: exact boundary fit — event fills window precisely', () => {\n    // Event of 60 min in window [0, 60]. endTime === 60 === window endTime.\n    const events: Event[] = [\n      { id: 'E1', name: 'Exact Fit', duration: 60, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 0, endTime: 60 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0].startTime).toBe(0);\n    expect(result.assignments[0].endTime).toBe(60);\n    assertInWindow(result, opts);\n  });\n\n  it('test 33: transitive gap accumulation — chain end exceeds window', () => {\n    // A -> B -> C, each 10 min. Gap = 15. 3 rooms (so room conflicts aren't the issue).\n    // A: 0-10. B starts at 10+15=25, ends at 35. C starts at 35+15=50, ends at 60.\n    // Window [0, 55]: C's end (60) > 55. C is unscheduled.\n    const events: Event[] = [\n      { id: 'A', name: 'Step A', duration: 10, attendees: 5 },\n      { id: 'B', name: 'Step B', duration: 10, attendees: 5, prerequisites: ['A'] },\n      { id: 'C', name: 'Step C', duration: 10, attendees: 5, prerequisites: ['B'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 10 },\n      { id: 'R2', name: 'Room 2', capacity: 10 },\n      { id: 'R3', name: 'Room 3', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 0, endTime: 55, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    // A and B fit, C does not\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toContain('C');\n    expect(result.assignments.some(a => a.eventId === 'A')).toBe(true);\n    expect(result.assignments.some(a => a.eventId === 'B')).toBe(true);\n    assertInWindow(result, opts);\n    assertPrerequisites(result, events, 15);\n  });\n\n  it('test 34: large gap pruning — gap dwarfs event duration', () => {\n    // 1 room. 2 events of 10 min each. Gap = 100. Window [0, 120].\n    // First event: 0-10. Second needs to start at 10+100=110, ends at 120.\n    // 120 <= 120: exact fit! But if window were [0, 119], second wouldn't fit.\n    // Use window [0, 115] so only 1 fits.\n    const events: Event[] = [\n      { id: 'E1', name: 'Quick 1', duration: 10, attendees: 5 },\n      { id: 'E2', name: 'Quick 2', duration: 10, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 0, endTime: 115, gap: 100 };\n\n    const result = schedule(events, rooms, opts);\n\n    // Only 1 event fits: 10 + 100 + 10 = 120 > 115\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(1);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 100);\n  });\n\n  it('test 35: zero-duration event with gap — dependent pushed out of window', () => {\n    // E1 has duration 0. E2 (30 min) depends on E1. Gap = 15. Window [0, 40].\n    // E1 at time 0, ends at 0. E2 must start at 0 + 15 = 15, ends at 45 > 40.\n    // E2 cannot be scheduled.\n    const events: Event[] = [\n      { id: 'E1', name: 'Instant Kickoff', duration: 0, attendees: 5 },\n      { id: 'E2', name: 'Real Work', duration: 30, attendees: 5, prerequisites: ['E1'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 0, endTime: 40, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    // E1 (0 duration) should be scheduled; E2 can't fit after gap\n    expect(result.assignments.some(a => a.eventId === 'E1')).toBe(true);\n    expect(result.unscheduled).toContain('E2');\n    assertInWindow(result, opts);\n    assertPrerequisites(result, events, 15);\n  });\n\n  it('test 36: all rooms too small — every event unscheduled due to capacity', () => {\n    // Every room has capacity 5, every event needs 10 attendees.\n    // No event fits any room. All should be unscheduled (not an error).\n    const events: Event[] = [\n      { id: 'E1', name: 'Oversized 1', duration: 30, attendees: 10 },\n      { id: 'E2', name: 'Oversized 2', duration: 30, attendees: 10 },\n      { id: 'E3', name: 'Oversized 3', duration: 30, attendees: 10 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Tiny Room A', capacity: 5 },\n      { id: 'R2', name: 'Tiny Room B', capacity: 5 },\n    ];\n    const opts: ScheduleOptions = { startTime: 0, endTime: 480 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toHaveLength(3);\n    expect(result.unscheduled).toContain('E1');\n    expect(result.unscheduled).toContain('E2');\n    expect(result.unscheduled).toContain('E3');\n  });\n\n  // ==========================================================================\n  // Group 7: Performance constraints (2 tests)\n  // ==========================================================================\n\n  it('test 37: large under-capacity scheduling — 100 events across 30 rooms with prerequisite chains', () => {\n    const durations = [30, 60, 90];\n    const attendeeCounts = [5, 10, 15, 20, 25];\n\n    const events: Event[] = [];\n    for (let i = 0; i < 100; i++) {\n      const ev: Event = {\n        id: `E${i}`,\n        name: `Event ${i}`,\n        duration: durations[i % durations.length],\n        attendees: attendeeCounts[i % attendeeCounts.length],\n      };\n      events.push(ev);\n    }\n\n    // 20 prerequisite chains of length 3: events 0-2, 3-5, 6-8, ..., 57-59\n    for (let chain = 0; chain < 20; chain++) {\n      const base = chain * 3;\n      events[base + 1].prerequisites = [`E${base}`];\n      events[base + 2].prerequisites = [`E${base + 1}`];\n    }\n\n    const capacities = [10, 20, 30, 40, 50];\n    const rooms: Room[] = [];\n    for (let i = 0; i < 30; i++) {\n      rooms.push({\n        id: `R${i}`,\n        name: `Room ${i}`,\n        capacity: capacities[i % capacities.length],\n      });\n    }\n\n    const opts: ScheduleOptions = { startTime: 0, endTime: 600, gap: 10 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(100);\n    expect(result.unscheduled).toHaveLength(0);\n    assertNoOverlap(result, 10);\n    assertInW