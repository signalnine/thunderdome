nus(a) - prefBonus(b);\n      });\n      break;\n\n    case 'preferred':\n      // Preferred room first, then smallest capacity\n      sorted.sort((a, b) => {\n        const pd = prefBonus(a) - prefBonus(b);\n        if (pd !== 0) return pd;\n        return a.capacity - b.capacity;\n      });\n      break;\n\n    case 'balanced':\n      // Tightest capacity fit, preferred room as tiebreaker\n      sorted.sort((a, b) => {\n        const att = event.attendees ?? 1;\n        const aWaste = a.capacity - att;\n        const bWaste = b.capacity - att;\n        if (aWaste !== bWaste) return aWaste - bWaste;\n        return prefBonus(a) - prefBonus(b);\n      });\n      break;\n\n    case 'spread':\n      // Fewest existing events, preferred room as tiebreaker\n      sorted.sort((a, b) => {\n        const aSlots = rs.getSlots(a.id).length;\n        const bSlots = rs.getSlots(b.id).length;\n        if (aSlots !== bSlots) return aSlots - bSlots;\n        const pd = prefBonus(a) - prefBonus(b);\n        if (pd !== 0) return pd;\n        return a.capacity - b.capacity;\n      });\n      break;\n  }"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":345,"cache_read_input_tokens":77839,"cache_creation":{"ephemeral_5m_input_tokens":345,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"16c4dab3-ce65-410c-95a2-392b088bde39","uuid":"b25778f9-f0d2-4ab8-bb4b-303048654b3c"}
