@@ -0,0 +1,1486 @@
+import { describe, it, expect, beforeAll } from 'vitest';
+import { discover, type ScheduleFn, type Event, type Room, type ScheduleOptions } from './_discovery.js';
+
+let schedule: ScheduleFn;
+
+beforeAll(async () => {
+  schedule = await discover();
+});
+
+// ---- Helpers ----
+
+function assertNoOverlap(result: { assignments: { eventId: string; roomId: string; startTime: number; endTime: number }[] }, gap: number) {
+  const byRoom = new Map<string, { eventId: string; start: number; end: number }[]>();
+  for (const a of result.assignments) {
+    if (!byRoom.has(a.roomId)) byRoom.set(a.roomId, []);
+    byRoom.get(a.roomId)!.push({ eventId: a.eventId, start: a.startTime, end: a.endTime });
+  }
+  for (const [roomId, slots] of byRoom) {
+    slots.sort((a, b) => a.start - b.start);
+    for (let i = 0; i < slots.length - 1; i++) {
+      const gapActual = slots[i + 1].start - slots[i].end;
+      expect(gapActual, `Room ${roomId}: gap between ${slots[i].eventId} and ${slots[i + 1].eventId} is ${gapActual}, need ${gap}`).toBeGreaterThanOrEqual(gap);
+    }
+  }
+}
+
+function assertInWindow(result: { assignments: { eventId: string; startTime: number; endTime: number }[] }, opts: ScheduleOptions) {
+  for (const a of result.assignments) {
+    expect(a.startTime, `${a.eventId} starts before window`).toBeGreaterThanOrEqual(opts.startTime);
+    expect(a.endTime, `${a.eventId} ends after window`).toBeLessThanOrEqual(opts.endTime);
+  }
+}
+
+function assertPrerequisites(result: { assignments: { eventId: string; startTime: number; endTime: number }[] }, events: Event[], gap: number) {
+  const startMap = new Map<string, number>();
+  const endMap = new Map<string, number>();
+  for (const a of result.assignments) {
+    startMap.set(a.eventId, a.startTime);
+    endMap.set(a.eventId, a.endTime);
+  }
+  for (const e of events) {
+    if (!startMap.has(e.id)) continue; // unscheduled
+    for (const pre of e.prerequisites ?? []) {
+      if (!endMap.has(pre)) continue; // prerequisite unscheduled
+      expect(
+        startMap.get(e.id)!,
+        `${e.id} should start after prerequisite ${pre} ends (${endMap.get(pre)}) + gap (${gap})`
+      ).toBeGreaterThanOrEqual(endMap.get(pre)! + gap);
+    }
+  }
+}
+
+function assertCapacity(result: { assignments: { eventId: string; roomId: string }[] }, events: Event[], rooms: Room[]) {
+  const roomCap = new Map<string, number>();
+  for (const r of rooms) roomCap.set(r.id, r.capacity);
+  const eventAtt = new Map<string, number>();
+  for (const e of events) eventAtt.set(e.id, e.attendees ?? 1);
+
+  for (const a of result.assignments) {
+    const cap = roomCap.get(a.roomId)!;
+    const att = eventAtt.get(a.eventId)!;
+    expect(att, `${a.eventId} (${att} attendees) in room ${a.roomId} (capacity ${cap})`).toBeLessThanOrEqual(cap);
+  }
+}
