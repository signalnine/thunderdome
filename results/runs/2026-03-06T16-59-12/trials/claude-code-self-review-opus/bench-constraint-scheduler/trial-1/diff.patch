n      return (events: Event[], rooms: Room[], options: ScheduleOptions) =>\n        def.schedule(events, rooms, options);\n    }\n  }\n\n  // 5. Look for any exported function that could be the scheduler\n  for (const key of Object.keys(mod)) {\n    if (typeof mod[key] === 'function' && key !== 'default') {\n      // Heuristic: function that takes 3 args\n      if (mod[key].length >= 2) {\n        return mod[key] as ScheduleFn;\n      }\n    }\n  }\n\n  throw new Error(\n    'Could not find a schedule function. Tried: named export \"schedule\", ' +\n    'Scheduler/EventScheduler classes, createScheduler factory, and default export.'\n  );\n}","is_error":false}]},"parent_tool_use_id":null,"session_id":"16c4dab3-ce65-410c-95a2-392b088bde39","uuid":"833e7b7b-84e2-40ae-9d02-9b87f7e313ae","tool_use_result":{"stdout":"/**\n * Discovery layer for the constraint scheduler implementation.\n *\n * Dynamically imports from ../src/ and tries to find the schedule function\n * regardless of how the implementor exported it. Supports:\n *   - Named export `schedule` function\n *   - Default export function\n *   - `Scheduler` class with a `schedule` method\n *   - Factory functions like `createScheduler`\n */\n\nexport interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\nexport type ScheduleFn = (events: Event[], rooms: Room[], options: ScheduleOptions) => ScheduleResult;\n\n/**\n * Try multiple import paths until one works.\n */\nasync function tryImport(): Promise<any> {\n  const paths = [