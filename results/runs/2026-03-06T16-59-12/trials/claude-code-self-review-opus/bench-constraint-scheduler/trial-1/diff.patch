ILS these)\n   167→// ============================================================\n   168→describe('Group 2: Greedy killers', () => {\n   169→\n   170→  it('test 6: room packing — greedy wastes large room on small events', () => {\n   171→    // R1 (capacity 20) is the only room big enough for E5-E6 (10 attendees each).\n   172→    // E1-E4 are small (3 attendees) and fit in R2 or R3 (capacity 5).\n   173→    // A greedy that assigns E1-E4 to R1 first will fill R1's time slots,\n   174→    // leaving E5-E6 with no valid room.\n   175→    // Optimal: E1-E4 go to R2/R3, E5-E6 go to R1.\n   176→    const events: Event[] = [\n   177→      { id: 'E1', name: 'Small 1', duration: 105, attendees: 3 },\n   178→      { id: 'E2', name: 'Small 2', duration: 105, attendees: 3 },\n   179→      { id: 'E3', name: 'Small 3', duration: 105, attendees: 3 },\n   180→      { id: 'E4', name: 'Small 4', duration: 105, attendees: 3 },\n   181→      { id: 'E5', name: 'Large 1', duration: 225, attendees: 10 },\n   182→      { id: 'E6', name: 'Large 2', duration: 225, attendees: 10 },\n   183→    ];\n   184→    const rooms: Room[] = [\n   185→      { id: 'R1', name: 'Grand Hall', capacity: 20 },\n   186→      { id: 'R2', name: 'Side Room A', capacity: 5 },\n   187→      { id: 'R3', name: 'Side Room B', capacity: 5 },\n   188→    ];\n   189→    // 480 min window, 15 min gap\n   190→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n   191→\n   192→    // Greedy by ID, first-fit room:\n   193→    //   E1 -> R1(540-645), E2 -> R1(660-765), E3 -> R1(780-885), E4 -> R1(900-1005)\n   194→    //   E5 -> R1 full, R2/R3 too small (10>5). Unscheduled!\n   195→    //   E6 -> same. Unscheduled!\n   196→    //   Greedy: 4/6 scheduled.\n   197→    //\n   198→    // Optimal:\n   199→    //   R1: E5(540-765), E6(780-1005) -- 225+15+225 = 465 <= 480\n   200→    //   R2: E1(540-645), E2(660-765) -- 2 events, 3<=5\n   201→    //   R3: E3(540-645), E4(660-765) -- 2 events, 3<=5\n   202→    //   All 6 scheduled!\n   203→\n   204→    const result = schedule(events, rooms, opts);\n   205→\n   206→    expect(result.assignments.length).toBe(6);\n   207→    expect(result.unscheduled).toHaveLength(0);\n   208→    assertNoOverlap(result, 15);\n   209→    assertInWindow(result, opts);\n   210→    assertCapacity(result, events, rooms);\n   211→  });\n   212→\n   213→  it('test 7: prerequisite chain + room constraint — greedy room choice blocks dependents', () => {\n   214→    // A -> B chain. D only fits R1. Greedy puts A in R1, then C in R1, blocking D.\n   215→    // Optimal puts A and B in R2, C in R2, D in R1.\n   216→    const events: Event[] = [\n   217→      { id: 'A', name: 'Setup', duration: 60, attendees: 3 },\n   218→      { id: 'B', name: 'Main', duration: 60, attendees: 3, prerequisites: ['A'] },\n   219→      { id: 'C', name: 'Workshop', duration: 150, attendees: 3 },\n   220→      { id: 'D', name: 'Keynote', duration: 150, attendees: 10 },\n   221→    ];\n   222→    const rooms: Room[] = [\n   223→      { id: 'R1', name: 'Large Room', capacity: 20 },\n   224→      { id: 'R2', name: 'Small Room', capacity: 5 },\n   225→    ];\n   226→    // 360 min window\n   227→    const opts: ScheduleOptions = { startTime: 540, endTime: 900, gap: 15 };\n   228→\n   229→    // Optimal:\n   230→    //   R2: A(540-600), B(615-675), C(690-840)  -- all fit, 3 <= 5\n   231→    //   R1: D(540-690) -- 10 <= 20\n   232→    //   All 4 scheduled!\n   233→\n   234→    // Greedy (topo order: A, then B/C/D by ID):\n   235→    //   A -> R1(540-600) [first room, fits]\n   236→    //   B -> R1(615-675) [prereq A done at 600+15=615, fits R1]\n   237→    //   C -> R1(690-840) [fits R1]\n   238→    //   D -> R1(855-1005) -- exceeds 900! R2: capacity 5 < 10. Unscheduled!\n   239→    //   Only 3 scheduled.\n   240→\n   241→    const result = schedule(events, rooms, opts);\n   242→\n   243→    expect(result.assignments.length).toBe(4);\n   244→    expect(result.unscheduled).toHaveLength(0);\n   245→    assertPrerequisites(result, events, 15);\n   246→    assertCapacity(result, events, rooms);\n   247→    assertInWindow(result, opts);\n   248→    assertNoOverlap(result, 15);\n   249→  });\n   250→\n   251→  it('test 8: preferred room — greedy fills preferred room, blocks event that needs it', () => {\n   252→    // E1 and E2 prefer R1. E3 MUST use R1 (only room with enough capacity).\n   253→    // E1 and E2 can also fit in R2.\n   254→    // Greedy honors preferences and fills R1 with E1+E2, blocking E3.\n   255→    // Optimal: E1 in R2, E2 in R2, E3 in R1.\n   256→    const events: Event[] = [\n   257→      { id: 'E1', name: 'Team Sync', duration: 120, attendees: 5, preferredRoom: 'R1' },\n   258→      { id: 'E2', name: 'Planning', duration: 120, attendees: 5, preferredRoom: 'R1' },\n   259→      { id: 'E3', name: 'All Hands', duration: 120, attendees: 25 },\n   260→    ];\n   261→    const rooms: Room[] = [\n   262→      { id: 'R1', name: 'Big Room', capacity: 50 },\n   263→      { id: 'R2', name: 'Medium Room', capacity: 10 },\n   264→    ];\n   265→    // 270 min window: only 2 events per room (120+15+120=255 fits in 270)\n   266→    const opts: ScheduleOptions = { startTime: 540, endTime: 810, gap: 15 };\n   267→\n   268→    // Greedy:\n   269→    //   E1 -> R1(540-660) [preferred]\n   270→    //   E2 -> R1(675-795) [preferred]\n   271→    //   E3 -> R1(810-930) exceeds 810! R2: capacity 10 < 25. Unscheduled!\n   272→    //   Only 2 scheduled.\n   273→\n   274→    // Optimal:\n   275→    //   E1 -> R2(540-660) -- 5 <= 10\n   276→    //   E2 -> R2(675-795) -- 5 <= 10\n   277→    //   E3 -> R1(540-660) -- 25 <= 50\n   278→    //   All 3 scheduled!\n   279→\n   280→    const result = schedule(events, rooms, opts);\n   281→\n   282→    expect(result.assignments.length).toBe(3);\n   283→    expect(result.unscheduled).toHaveLength(0);\n   284→    assertCapacity(result, events, rooms);\n   285→    assertInWindow(result, opts);\n   286→    assertNoOverlap(result, 15);\n   287→  });\n   288→\n   289→  it('test 9: interleaving prerequisite chains across rooms', () => {\n   290→    // Two chains: A1->A2->A3 and B1->B2->B3\n   291→    // All events are 90 min. 2 rooms.\n   292→    // Window: 540-1020 (480 min). With gap 15:\n   293→    //   3 events per room: 90+15+90+15+90 = 300 min, fits in 480.\n   294→    // But chains need sequential ordering, so each chain must span time.\n   295→    // The two chains must interleave across rooms to fit all 6 events.\n   296→    const events: Event[] = [\n   297→      { id: 'A1', name: 'Chain A Step 1', duration: 90, attendees: 5 },\n   298→      { id: 'A2', name: 'Chain A Step 2', duration: 90, attendees: 5, prerequisites: ['A1'] },\n   299→      { id: 'A3', name: 'Chain A Step 3', duration: 90, attendees: 5, prerequisites: ['A2'] },\n   300→      { id: 'B1', name: 'Chain B Step 1', duration: 90, attendees: 5 },\n   301→      { id: 'B2', name: 'Chain B Step 2', duration: 90, attendees: 5, prerequisites: ['B1'] },\n   302→      { id: 'B3', name: 'Chain B Step 3', duration: 90, attendees: 5, prerequisites: ['B2'] },\n   303→    ];\n   304→    const rooms: Room[] = [\n   305→      { id: 'R1', name: 'Room 1', capacity: 20 },\n   306→      { id: 'R2', name: 'Room 2', capacity: 20 },\n   307→    ];\n   308→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n   309→\n   310→    // All 6 should fit since chains can interleave across 2 rooms.\n   311→    // E.g. R1: A1(540-630), B2(645-735), A3(750-840)\n   312→    //      R2: B1(540-630), A2(645-735), B3(750-840)\n   313→    const result = schedule(events, rooms, opts);\n   314→\n   315→    expect(result.assignments.length).toBe(6);\n   316→    expect(result.unscheduled).toHaveLength(0);\n   317→    assertPrerequisites(result, events, 15);\n   318→    assertInWindow(result, opts);\n   319→    assertNoOverlap(result, 15);\n   320→  });\n   321→\n   322→  it('test 10: backtracking — first-fit event 1 placement blocks event 3', () => {\n   323→    // 2 rooms, tight window. Event placement order matters.\n   324→    // E1 (long) and E3 (long) compete for R1 (only room big enough for both).\n   325→    // E2 (short) and E4 (short, prereq E2) fit in R2.\n   326→    // Greedy puts E1 in R1 at 540. E2 in R1 at next slot.\n   327→    // Then E3 can't fit in R1, and can't fit R2 (capacity).\n   328→    const events: Event[] = [\n   329→      { id: 'E1', name: 'Long Talk A', duration: 180, attendees: 8 },\n   330→      { id: 'E2', name: 'Short Talk', duration: 60, attendees: 3 },\n   331→      { id: 'E3', name: 'Long Talk B', duration: 180, attendees: 8 },\n   332→      { id: 'E4', name: 'Follow-up', duration: 60, attendees: 3, prerequisites: ['E2'] },\n   333→    ];\n   334→    const rooms: Room[] = [\n   335→      { id: 'R1', name: 'Main Room', capacity: 15 },\n   336→      { id: 'R2', name: 'Side Room', capacity: 5 },\n   337→    ];\n   338→    // 420 min window: 2 x 180 + 15 gap = 375, fits in 420.\n   339→    // But E2 (60 min) placed in R1 between them could block.\n   340→    const opts: ScheduleOptions = { startTime: 540, endTime: 960, gap: 15 };\n   341→\n   342→    // Greedy (by ID):\n   343→    //   E1 -> R1(540-720) [8 attendees, only R1 fits]\n   344→    //   E2 -> R1(735-795) [3 attendees, fits R1 and R2, greedy picks R1]\n   345→    //   E3 -> R1(810-990) exceeds 960! R2: 8 > 5. Unscheduled!\n   346→    //   E4 -> R2(615-675) wait, prereq E2 ends 795. R2(810-870). fits.\n   347→    //   3 scheduled, E3 unscheduled.\n   348→\n   349→    // Optimal:\n   350→    //   E1 -> R1(540-720)\n   351→    //   E2 -> R2(540-600)\n   352→    //   E3 -> R1(735-915)  [720+15=735, ends 915 <= 960]\n   353→    //   E4 -> R2(615-675)  [prereq E2 ends 600, 600+15=615]\n   354→    //   All 4 scheduled!\n   355→\n   356→    const result = schedule(events, rooms, opts);\n   357→\n   358→    expect(result.assignments.length).toBe(4);\n   359→    expect(result.unscheduled).toHaveLength(0);\n   360→    assertPrerequisites(result, events, 15);\n   361→    assertCapacity(result, events, rooms);\n   362→    assertInWindow(result, opts);\n   363→    assertNoOverlap(result, 15);\n   364→  });\n   365→\n   366→  it('test 11: medium scale — 15 events, 4 rooms, greedy suboptimal', () => {\n   367→    // 4 rooms with different capacities. Mix of event sizes.\n   368→    // Large events (L1-L4) need room R1 (capacity 30).\n   369→    // Medium events (M1-M4) need R1 or R2 (capacity 15).\n   370→    // Small events (S1-S7) fit anywhere.\n   371→    //\n   372→    // Time window: 540-1020 (480 min), gap 15.\n   373→    // R1 can fit 4 large events: 4 x 100 + 3 x 15 = 445, fits in 480.\n   374→    // But greedy puts small events in R1 first, blocking large ones.\n   375→\n   376→    const events: Event[] = [\n   377→      // Small events (attendees: 3, fit in all rooms)\n   378→      { id: 'S1', name: 'Small 1', duration: 55, attendees: 3 },\n   379→      { id: 'S2', name: 'Small 2', duration: 55, attendees: 3 },\n   380→      { id: 'S3', name: 'Small 3', duration: 55, attendees: 3 },\n   381→      { id: 'S4', name: 'Small 4', duration: 55, attendees: 3 },\n   382→      { id: 'S5', name: 'Small 5', duration: 55, attendees: 3 },\n   383→      { id: 'S6', name: 'Small 6', duration: 55, attendees: 3 },\n   384→      { id: 'S7', name: 'Small 7', duration: 55, attendees: 3 },\n   385→      // Medium events (attendees: 12, only R1 or R2)\n   386→      { id: 'M1', name: 'Medium 1', duration: 100, attendees: 12 },\n   387→      { id: 'M2', name: 'Medium 2', duration: 100, attendees: 12 },\n   388→      { id: 'M3', name: 'Medium 3', duration: 100, attendees: 12 },\n   389→      { id: 'M4', name: 'Medium 4', duration: 100, attendees: 12 },\n   390→      // Large events (attendees: 20, only R1)\n   391→      { id: 'L1', name: 'Large 1', duration: 100, attendees: 20 },\n   392→      { id: 'L2', name: 'Large 2', duration: 100, attendees: 20 },\n   393→      { id: 'L3', name: 'Large 3', duration: 100, attendees: 20 },\n   394→      { id: 'L4', name: 'Large 4', duration: 100, attendees: 20 },\n   395→    ];\n   396→    const rooms: Room[] = [\n   397→      { id: 'R1', name: 'Grand Ballroom', capacity: 30 },\n   398→      { id: 'R2', name: 'Conference Room', capacity: 15 },\n   399→      { id: 'R3', name: 'Meeting Room A', capacity: 8 },\n   400→      { id: 'R4', name: 'Meeting Room B', capacity: 8 },\n   401→    ];\n   402→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n   403→\n   404→    // Capacity to fit per room (each event 100min or 55min):\n   405→    //   R1: 4 x 100 + 3 x 15 = 445 (fits 4 large) or mix\n   406→    //   R2: 4 x 100 + 3 x 15 = 445 (fits 4 medium)\n   407→    //   R3: ~6 x 55 + 5 x 15 = 405 (fits ~6 small)\n   408→    //   R4: ~6 x 55 + 5 x 15 = 405 (fits ~6 small)\n   409→    //\n   410→    // Optimal assignment:\n   411→    //   R1: L1, L2, L3, L4 (4 events, 445 min)\n   412→    //   R2: M1, M2, M3, M4 (4 events, 445 min)\n   413→    //   R3: S1, S2, S3, S4 (4 events, 4*55 + 3*15 = 265 min)\n   414→    //   R4: S5, S6, S7 (3 events, 3*55 + 2*15 = 195 min)\n   415→    //   All 15 scheduled!\n   416→\n   417→    const result = schedule(events, rooms, opts);\n   418→\n   419→    // The key assertion: all 15 events must be scheduled\n   420→    expect(result.assignments.length).toBe(15);\n   421→    expect(result.unscheduled).toHaveLength(0);\n   422→    assertCapacity(result, events, rooms);\n   423→    assertInWindow(result, opts);\n   424→    assertNoOverlap(result, 15);\n   425→  });\n   426→});\n   427→\n   428→// ============================================================\n   429→// Group 3: Edge cases\n   430→// ============================================================\n   431→describe('Group 3: Edge cases', () => {\n   432→\n   433→  it('test 12: detect prerequisite cycle (A->B->C->A)', () => {\n   434→    const events: Event[] = [\n   435→      { id: 'A', name: 'Event A', duration: 30, prerequisites: ['C'] },\n   436→      { id: 'B', name: 'Event B', duration: 30, prerequisites: ['A'] },\n   437→      { id: 'C', name: 'Event C', duration: 30, prerequisites: ['B'] },\n   438→    ];\n   439→    const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n   440→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n   441→\n   442→    expect(() => schedule(events, rooms, opts)).toThrow();\n   443→  });\n   444→\n   445→  it('test 13: self-referencing prerequisite (A->A)', () => {\n   446→    const events: Event[] = [\n   447→      { id: 'A', name: 'Self Ref', duration: 30, prerequisites: ['A'] },\n   448→    ];\n   449→    const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n   450→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n   451→\n   452→    expect(() => schedule(events, rooms, opts)).toThrow();\n   453→  });\n   454→\n   455→  it('test 14: event longer than time window — should be unscheduled', () => {\n   456→    const events: Event[] = [\n   457→      { id: 'E1', name: 'Marathon', duration: 600, attendees: 5 },\n   458→      { id: 'E2', name: 'Quick Talk', duration: 30, attendees: 5 },\n   459→    ];\n   460→    const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n   461→    // 480 min window, E1 needs 600 min\n   462→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n   463→\n   464→    const result = schedule(events, rooms, opts);\n   465→\n   466→    expect(result.unscheduled).toContain('E1');\n   467→    expect(result.assignments.some(a => a.eventId === 'E2')).toBe(true);\n   468→  });\n   469→\n   470→  it('test 15: empty events list', () => {\n   471→    const events: Event[] = [];\n   472→    const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n   473→    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n   474→\n   475→    const result = schedule(events, rooms, opts);\n   476→\n   477→    expect(result.assignments).toHaveLength(0);\n   478→    expect(result.unscheduled).toHaveLength(0);\n   479→  });\n   480→\n   481→  it('test 16: all events prefer same room but cannot all fit — reassign', () => {\n   482→    const events: Event[] = [\n   483→      { id: 'E1', name: 'Talk 1', duration: 120, attendees: 5, preferredRoom: 'R1' },\n   484→      { id: 'E2', name: 'Talk 2', duration: 120, attendees: 5, preferredRoom: 'R1' },\n   485→      { id: 'E3', name: 'Talk 3', duration: 120, attendees: 5, preferredRoom: 'R1' },\n   486→      { id: 'E4', name: 'Talk 4', duration: 120, attendees: 5, preferredRoom: 'R1' },\n   487→      { id: 'E5', name: 'Talk 5', duration: 120, attendees: 5, preferredRoom: 'R1' },\n   488→    ];\n   489→    const rooms: Room[] = [\n   490→      { id: 'R1', name: 'Preferred Room', capacity: 20 },\n   491→      { id: 'R2', name: 'Other Room', capacity: 20 },\n   492→    ];\n   493→    // 540 min window: each room fits 3 events (120+15+120+15+120=390 < 540)\n   494→    const opts: ScheduleOptions = { startTime: 480, endTime: 1020, gap: 15 };\n   495→\n   496→    const result = schedule(events, rooms, opts);\n   497→\n   498→    // All 5 should be scheduled even though they all prefer R1\n   499→    // R1 can hold 3: (480-600, 615-735, 750-870) or 4 with tight packing\n   500→    // Actually: 120+15 = 135 per slot. 540/135 = 4 events per room. So R1 fits 4, R2 fits the 5th."}]},"parent_tool_use_id":null,"session_id":"16c4dab3-ce65-410c-95a2-392b088bde39","uuid":"8493f0c2-7c6c-418a-a17d-78ad7bd9de52","tool_use_result":{"type":"text","file":{"filePath":"/tmp/.claude/projects/-workspace/16c4dab3-ce65-410c-95a2-392b088bde39/tool-results/toolu_01555NESpKHpmZNcdJVA6EUW.txt","content":"import { describe, it, expect, beforeAll } from 'vitest';\nimport { discover, type ScheduleFn, type Event, type Room, type ScheduleOptions } from './_discovery.js';\n\nlet schedule: ScheduleFn;\n\nbeforeAll(async () => {\n  schedule = await discover();\n});\n\n// ---- Helpers ----\n\nfunction assertNoOverlap(result: { assignments: { eventId: string; roomId: string; startTime: number; endTime: number }[] }, gap: number) {\n  const byRoom = new Map<string, { eventId: string; start: number; end: number }[]>();\n  for (const a of result.assignments) {\n    if (!byRoom.has(a.roomId)) byRoom.set(a.roomId, []);\n    byRoom.get(a.roomId)!.push({ eventId: a.eventId, start: a.startTime, end: a.endTime });\n  }\n  for (const [roomId, slots] of byRoom) {\n    slots.sort((a, b) => a.start - b.start);\n    for (let i = 0; i < slots.length - 1; i++) {\n      const gapActual = slots[i + 1].start - slots[i].end;\n      expect(gapActual, `Room ${roomId}: gap between ${slots[i].eventId} and ${slots[i + 1].eventId} is ${gapActual}, need ${gap}`).toBeGreaterThanOrEqual(gap);\n    }\n  }\n}\n\nfunction assertInWindow(result: { assignments: { eventId: string; startTime: number; endTime: number }[] }, opts: ScheduleOptions) {\n  for (const a of result.assignments) {\n    expect(a.startTime, `${a.eventId} starts before window`).toBeGreaterThanOrEqual(opts.startTime);\n    expect(a.endTime, `${a.eventId} ends after window`).toBeLessThanOrEqual(opts.endTime);\n  }\n}\n\nfunction assertPrerequisites(result: { assignments: { eventId: string; startTime: number; endTime: number }[] }, events: Event[], gap: number) {\n  const startMap = new Map<string, number>();\n  const endMap = new Map<string, number>();\n  for (const a of result.assignments) {\n    startMap.set(a.eventId, a.startTime);\n    endMap.set(a.eventId, a.endTime);\n  }\n  for (const e of events) {\n    if (!startMap.has(e.id)) continue; // unscheduled\n    for (const pre of e.prerequisites ?? []) {\n      if (!endMap.has(pre)) continue; // prerequisite unscheduled\n      expect(\n        startMap.get(e.id)!,\n        `${e.id} should start after prerequisite ${pre} ends (${endMap.get(pre)}) + gap (${gap})`\n      ).toBeGreaterThanOrEqual(endMap.get(pre)! + gap);\n    }\n  }\n}\n\nfunction assertCapacity(result: { assignments: { eventId: string; roomId: string }[] }, events: Event[], rooms: Room[]) {\n  const roomCap = new Map<string, number>();\n  for (const r of rooms) roomCap.set(r.id, r.capacity);\n  const eventAtt = new Map<string, number>();\n  for (const e of events) eventAtt.set(e.id, e.attendees ?? 1);\n\n  for (const a of result.assignments) {\n    const cap = roomCap.get(a.roomId)!;\n    const att = eventAtt.get(a.eventId)!;\n    expect(att, `${a.eventId} (${att} attendees) in room ${a.roomId} (capacity ${cap})`).toBeLessThanOrEqual(cap);\n  }\n}\n\n// ============================================================\n// Group 1: Basic scheduling (greedy passes these)\n// ============================================================\ndescribe('Group 1: Basic scheduling', () => {\n\n  it('test 1: schedule single event into single room', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Kickoff', duration: 60, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Main Hall', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0].eventId).toBe('E1');\n    expect(result.assignments[0].roomId).toBe('R1');\n    expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);\n    assertInWindow(result, opts);\n  });\n\n  it('test 2: schedule 2 non-overlapping events in same room', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Morning Talk', duration: 60, attendees: 10 },\n      { id: 'E2', name: 'Afternoon Talk', duration: 60, attendees: 10 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room A', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n    assertNoOverlap(result, 15);\n    assertInWindow(result, opts);\n  });\n\n  it('test 3: respect room capacity — reject oversized event', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Small Meeting', duration: 30, attendees: 5 },\n      { id: 'E2', name: 'Huge Gathering', duration: 30, attendees: 100 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Small Room', capacity: 10 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].eventId).toBe('E1');\n    expect(result.unscheduled).toContain('E2');\n    assertCapacity(result, events, rooms);\n  });\n\n  it('test 4: respect time window boundaries', () => {\n    const events: Event[] = [\n      { id: 'E1', name: 'Long Event', duration: 120, attendees: 5 },\n      { id: 'E2', name: 'Another Long Event', duration: 120, attendees: 5 },\n      { id: 'E3', name: 'Third Long Event', duration: 120, attendees: 5 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room A', capacity: 20 },\n    ];\n    // Only 300 min window. 3 events of 120 min + 2 gaps of 15 = 390 > 300. Only 2 fit.\n    const opts: ScheduleOptions = { startTime: 540, endTime: 840, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments.length).toBe(2);\n    expect(result.unscheduled).toHaveLength(1);\n    assertInWindow(result, opts);\n    assertNoOverlap(result, 15);\n  });\n\n  it('test 5: simple prerequisite — A before B', () => {\n    const events: Event[] = [\n      { id: 'A', name: 'Setup', duration: 60, attendees: 5 },\n      { id: 'B', name: 'Main Event', duration: 60, attendees: 5, prerequisites: ['A'] },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room A', capacity: 20 },\n    ];\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    const result = schedule(events, rooms, opts);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n    assertPrerequisites(result, events, 15);\n    assertInWindow(result, opts);\n  });\n});\n\n// ============================================================\n// Group 2: Greedy killers (first-fit FAILS these)\n// ============================================================\ndescribe('Group 2: Greedy killers', () => {\n\n  it('test 6: room packing — greedy wastes large room on small events', () => {\n    // R1 (capacity 20) is the only room big enough for E5-E6 (10 attendees each).\n    // E1-E4 are small (3 attendees) and fit in R2 or R3 (capacity 5).\n    // A greedy that assigns E1-E4 to R1 first will fill R1's time slots,\n    // leaving E5-E6 with no valid room.\n    // Optimal: E1-E4 go to R2/R3, E5-E6 go to R1.\n    const events: Event[] = [\n      { id: 'E1', name: 'Small 1', duration: 105, attendees: 3 },\n      { id: 'E2', name: 'Small 2', duration: 105, attendees: 3 },\n      { id: 'E3', name: 'Small 3', duration: 105, attendees: 3 },\n      { id: 'E4', name: 'Small 4', duration: 105, attendees: 3 },\n      { id: 'E5', name: 'Large 1', duration: 225, attendees: 10 },\n      { id: 'E6', name: 'Large 2', duration: 225, attendees: 10 },\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Grand Hall', capacity: 20 },\n      { id: 'R2', name: 'Side Room A', capacity: 5 },\n      { id: 'R3', name: 'Side Room B', capacity: 5 },\n    ];\n    // 480 min window, 15 min gap\n    const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\n    // Greedy by ID, first-fit room:\n    //   E1 -> R1(540-645), E2 -> R1(660-765), E3 -> R1(780-885), E4 -> R1(900-1005)\n    //   E5 -> R1 full, R2/R3 too small (10>5). Unscheduled!\n    //   E6 -> same. Unscheduled!\n    //   Greedy: 4/6 scheduled.\n    //\n    // 