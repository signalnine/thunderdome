diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..2089758
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,162 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import fs from 'fs';
+import path from 'path';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export class DocumentDB {
+  private db: Database.Database;
+
+  constructor(dbPath?: string) {
+    this.db = new Database(dbPath || ':memory:');
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('foreign_keys = ON');
+    this.init();
+  }
+
+  private init(): void {
+    const schemaPath = path.resolve(
+      path.dirname(new URL(import.meta.url).pathname),
+      '..',
+      'schema.sql',
+    );
+    let schema: string;
+    try {
+      schema = fs.readFileSync(schemaPath, 'utf-8');
+    } catch {
+      // Fallback inline schema if file not found
+      schema = `
+        CREATE TABLE IF NOT EXISTS documents (
+          id TEXT PRIMARY KEY,
+          title TEXT NOT NULL,
+          content TEXT NOT NULL DEFAULT '',
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+        CREATE TABLE IF NOT EXISTS versions (
+          id INTEGER PRIMARY KEY AUTOINCREMENT,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          version INTEGER NOT NULL,
+          content TEXT NOT NULL,
+          operation TEXT,
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          UNIQUE(document_id, version)
+        );
+        CREATE TABLE IF NOT EXISTS active_connections (
+          id TEXT PRIMARY KEY,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+      `;
+    }
+    this.db.exec(schema);
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`,
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version
+    this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, ?)`,
+    ).run(id, content, JSON.stringify({ type: 'init' }));
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    const stmt = this.db.prepare(`SELECT * FROM documents WHERE id = ?`);
+    return stmt.get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare(
+      `SELECT * FROM documents ORDER BY updated_at DESC`,
+    );
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(
+    id: string,
+    updates: { title?: string; content?: string },
+  ): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    this.db.prepare(
+      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`,
+    ).run(title, content, id);
+
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.db.prepare(`DELETE FROM documents WHERE id = ?`).run(
+      id,
+    );
+    return result.changes > 0;
+  }
+
+  updateDocumentContent(id: string, content: string, operation: string): number {
+    const currentVersion = this.getLatestVersion(id);
+    const newVersion = currentVersion + 1;
+
+    const update = this.db.transaction(() => {
+      this.db.prepare(
+        `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`,
+      ).run(content, id);
+
+      this.db.prepare(
+        `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`,
+      ).run(id, newVersion, content, operation);
+    });
+
+    update();
+    return newVersion;
+  }
+
+  getLatestVersion(documentId: string): number {
+    const row = this.db.prepare(
+      `SELECT MAX(version) as max_version FROM versions WHERE document_id = ?`,
+    ).get(documentId) as { max_version: number | null } | undefined;
+    return row?.max_version ?? 0;
+  }
+
+  getVersionHistory(documentId: string): Version[] {
+    return this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`,
+    ).all(documentId) as Version[];
+  }
+
+  getVersion(documentId: string, version: number): Version | undefined {
+    return this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? AND version = ?`,
+    ).get(documentId, version) as Version | undefined;
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..698d1b4
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,319 @@
+import { describe, it, expect } from 'vitest';
+import {
+  apply,
+  transform,
+  compose,
+  normalize,
+  insertAt,
+  deleteAt,
+  validate,
+  inputLength,
+  outputLength,
+  type Operation,
+} from './ot.js';
+
+describe('OT: apply', () => {
+  it('should apply insert at beginning', () => {
+    const doc = 'hello';
+    const op: Operation = [
+      { type: 'insert', text: 'say ' },
+      { type: 'retain', count: 5 },
+    ];
+    expect(apply(doc, op)).toBe('say hello');
+  });
+
+  it('should apply insert at end', () => {
+    const doc = 'hello';
+    const op: Operation = [
+      { type: 'retain', count: 5 },
+      { type: 'insert', text: ' world' },
+    ];
+    expect(apply(doc, op)).toBe('hello world');
+  });
+
+  it('should apply insert in middle', () => {
+    const doc = 'helo';
+    const op: Operation = [
+      { type: 'retain', count: 2 },
+      { type: 'insert', text: 'l' },
+      { type: 'retain', count: 2 },
+    ];
+    expect(apply(doc, op)).toBe('hello');
+  });
+
+  it('should apply delete', () => {
+    const doc = 'hello world';
+    const op: Operation = [
+      { type: 'retain', count: 5 },
+      { type: 'delete', count: 6 },
+    ];
+    expect(apply(doc, op)).toBe('hello');
+  });
+
+  it('should apply to empty document', () => {
+    expect(apply('', [{ type: 'insert', text: 'hi' }])).toBe('hi');
+  });
+
+  it('should apply empty operation to empty document', () => {
+    expect(apply('', [])).toBe('');
+  });
+
+  it('should throw on retain past end', () => {
+    expect(() => apply('hi', [{ type: 'retain', count: 5 }])).toThrow();
+  });
+
+  it('should throw if operation does not consume entire document', () => {
+    expect(() => apply('hello', [{ type: 'retain', count: 3 }])).toThrow();
+  });
+});
+
+describe('OT: transform', () => {
+  it('should transform two inserts at different positions', () => {
+    // Doc: "abc" (length 3)
+    // A inserts "X" at position 1: retain(1), insert("X"), retain(2)
+    // B inserts "Y" at position 2: retain(2), insert("Y"), retain(1)
+    const a: Operation = [
+      { type: 'retain', count: 1 },
+      { type: 'insert', text: 'X' },
+      { type: 'retain', count: 2 },
+    ];
+    const b: Operation = [
+      { type: 'retain', count: 2 },
+      { type: 'insert', text: 'Y' },
+      { type: 'retain', count: 1 },
+    ];
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const doc = 'abc';
+    const afterA = apply(doc, a);   // "aXbc"
