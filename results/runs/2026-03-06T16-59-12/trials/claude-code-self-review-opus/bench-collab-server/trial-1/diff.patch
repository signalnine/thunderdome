ed();\n  });\n\n  it('should reject document creation without title', async () => {\n    await request(app.app)\n      .post('/api/documents')\n      .send({ content: 'Hello' })\n      .expect(400);\n  });\n\n  it('should list documents', async () => {\n    await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 1' });\n    await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 2' });\n\n    const res = await request(app.app).get('/api/documents').expect(200);\n    expect(res.body.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'My Doc', content: 'content here' });\n\n    const res = await request(app.app)\n      .get(`/api/documents/${created.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.content).toBe('content here');\n  });\n\n  it('should return 404 for missing document', async () => {\n    await request(app.app)\n      .get('/api/documents/nonexistent')\n      .expect(404);\n  });\n\n  it('should update a document', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Old Title', content: 'old' });\n\n    const res = await request(app.app)\n      .put(`/api/documents/${created.body.id}`)\n      .send({ title: 'New Title', content: 'new' })\n      .expect(200);\n\n    expect(res.body.title).toBe('New Title');\n    expect(res.body.content).toBe('new');\n  });\n\n  it('should delete a document', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'To Delete' });\n\n    await request(app.app)\n      .delete(`/api/documents/${created.body.id}`)\n      .expect(204);\n\n    await request(app.app)\n      .get(`/api/documents/${created.body.id}`)\n      .expect(404);\n  });\n\n  it('should return 404 when deleting nonexistent document', async () => {\n    await request(app.app)\n      .delete('/api/documents/nonexistent')\n      .expect(404);\n  });\n\n  it('should get version history', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Versioned', content: 'v1' });\n\n    const res = await request(app.app)\n      .get(`/api/documents/${created.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0].version).toBe(1);\n  });\n\n  it('should get a specific version', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Versioned', content: 'initial' });\n\n    const res = await request(app.app)\n      .get(`/api/documents/${created.body.id}/versions/1`)\n      .expect(200);\n\n    expect(res.body.version).toBe(1);\n    expect(res.body.content).toBe('initial');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('should receive sync message on connect', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'WS Test', content: 'hello' });\n\n    const { ws, sync } = await connectWs(created.body.id);\n    expect(sync.content).toBe('hello');\n    expect(sync.version).toBe(1);\n    expect(sync.clientId).toBeDefined();\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Collab', content: 'hello' });\n\n    const docId = created.body.id;\n    const { ws: ws1 } = await connectWs(docId);\n    const { ws: ws2 } = await connectWs(docId);\n\n    // ws2 listens for operations\n    const opPromise = waitForMessage(ws2, 'operation');\n\n    // ws1 sends an insert operation\n    const op: Operation = [\n      { type: 'retain', count: 5 },\n      { type: 'insert', text: ' world' },\n    ];\n    ws1.send(JSON.stringify({ 