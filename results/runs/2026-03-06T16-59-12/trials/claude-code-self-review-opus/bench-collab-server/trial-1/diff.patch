      .get(`/api/documents/${created.body.id}`)\n      .expect(404);\n  });\n\n  it('should return 404 when deleting nonexistent document', async () => {\n    await request(app.app)\n      .delete('/api/documents/nonexistent')\n      .expect(404);\n  });\n\n  it('should get version history', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Versioned', content: 'v1' });\n\n    const res = await request(app.app)\n      .get(`/api/documents/${created.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0].version).toBe(1);\n  });\n\n  it('should get a specific version', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Versioned', content: 'initial' });\n\n    const res = await request(app.app)\n      .get(`/api/documents/${created.body.id}/versions/1`)\n      .expect(200);\n\n    expect(res.body.version).toBe(1);\n    expect(res.body.content).toBe('initial');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('should receive sync message on connect', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'WS Test', content: 'hello' });\n\n    const { ws, sync } = await connectWs(created.body.id);\n    expect(sync.content).toBe('hello');\n    expect(sync.version).toBe(1);\n    expect(sync.clientId).toBeDefined();\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Collab', content: 'hello' });\n\n    const docId = created.body.id;\n    const { ws: ws1 } = await connectWs(docId);\n    const { ws: ws2 } = await connectWs(docId);\n\n    // ws2 listens for operations\n    const opPromise = waitForMessage(ws2, 'operation');\n\n    // ws1 sends an insert operation\n    const op: Operation = [\n      { type: 'retain', count: 5 },\n      { type: 'insert', text: ' world' },\n    ];\n    ws1.send(JSON.stringify({ type: 'operation', version: 1, operation: op }));\n\n    const received = await opPromise;\n    expect(received.type).toBe('operation');\n    expect(received.version).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should ack operations to sender', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Ack Test', content: 'abc' });\n\n    const { ws } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n\n    const op: Operation = [\n      { type: 'retain', count: 3 },\n      { type: 'insert', text: 'def' },\n    ];\n    ws.send(JSON.stringify({ type: 'operation', version: 1, operation: op }));\n\n    const ack = await ackPromise;\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    ws.close();\n  });\n\n  it('should persist changes via WebSocket to REST', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Persist', content: 'hello' });\n\n    const docId = created.body.id;\n    const { ws } = await connectWs(docId);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n\n    const op: Operation = [\n      { type: 'retain', count: 5 },\n      { type: 'insert', text: ' world' },\n    ];\n    ws.send(JSON.stringify({ type: 'operation', version: 1, operation: op }));\n\n    await ackPromise;\n    ws.close();\n\n    // Verify via REST\n    const res = await request(app.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    expect(res.body.content).toBe('hello world');\n  });\n\n  it('should handle invalid operations gracefully', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Error Test', content: 'abc' });\n\n    const { ws } = await connectWs(created.body.id);\n\n    const errorPromise = waitForMessage(ws, 'error');\n\n    // Send operation with wrong base length\n    ws.send(JSON.stringify({\n      type: 'operation',\n      version: 1,\n      operation: [{ type: 'retain', count: 999 }],\n    }));\n\n    const errMsg = await errorPromise;\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle malformed JSON gracefully', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Malformed', content: '' });\n\n    const { ws } = await connectWs(created.body.id);\n\n    const errorPromise = waitForMessage(ws, 'error');\n\n    ws.send('not json at all{{{');\n\n    const errMsg = await errorPromise;\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should transform concurrent operations (OT convergence)', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'OT Test', content: 'abc' });\n\n    const docId = created.body.id;\n    const { ws: ws1 } = await connectWs(docId);\n    const { ws: ws2 } = await connectWs(docId);\n\n    // Both clients send operations concurrently based on version 1\n    // Client 1: insert \"X\" at position 0\n    const op1: Operation = [\n      { type: 'insert', text: 'X' },\n      { type: 'retain', count: 3 },\n    ];\n\n    // Client 2: insert \"Y\" at position 3 (end)\n    const op2: Operation = [\n      { type: 'retain', count: 3 },\n      { type: 'insert', text: 'Y' },\n    ];\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    ws1.send(JSON.stringify({ type: 'operation', version: 1, operation: op1 }));\n    await ack1Promise;\n\n    // Client 2 sends based on version 1 (before seeing client 1's change)\n    const ack2Promise = waitForMessage(ws2, 'ack');\n    ws2.send(JSON.stringify({ type: 'operation', version: 1, operation: op2 }));\n    await ack2Promise;\n\n    // Check document via REST - both operations should be applied\n    const res = await request(app.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    expect(res.body.content).toBe('XabcY');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const created = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Stress Test', content: '' });\n\n    const docId = created.body.id;\n\n    // Connect 10 clients\n    const clients: { ws: WebSocket; sync: { version: number; clientId: string } }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(docId);\n      clients.push(client);\n    }\n\n    // Each client appends a character sequentially\n    let currentVersion = 1;\n    for (let i = 0; i < 10; i++) {\n      const ws = clients[i].ws;\n      const op: Operation = [\n        { type: 'retain', count: i },\n        { type: 'insert', text: String(i) },\n      ];\n\n      const ackPromise = waitForMessage(ws, 'ack');\n      ws.send(JSON.stringify({\n        type: 'operation',\n        version: currentVersion,\n        operation: op,\n      }));\n\n      const ack = await ackPromise;\n      currentVersion = ack.version as number;\n    }\n\n    // Check final state\n    const res = await request(app.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    expect(res.body.content).toBe('0123456789');\n\n    // Close all clients\n    for (const c of clients) {\n      c.ws.close();\n    }\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across server restarts (using file DB)', async () => {\n    const fs = await import('fs');\n    const os = await import('os');\n    const path = await import('path');\n\n    const dbPath = path.join(os.tmpdir(), `test-collab-${Date.now()}.db`);\n\n    try {\n      // Start first server\n      const app1 = createApp(dbPath);\n      await app1.start(0);\n\n      const created = await request(app1.app)\n        .post('/api/documents')\n        .send({ title: 'Persistent', content: 'saved data' });\n\n      const docId = created.body.id;\n      await app1.stop();\n\n      // Start second server with same DB\n      const app2 = createApp(dbPath);\n      await app2.start(0);\n\n      const res = await request(app2.app)\n        .get(`/api/documents/${docId}`)\n        .expect(200);\n\n      expect(res.body.title).toBe('Persistent');\n      expect(res.body.content).toBe('saved data');\n\n      await app2.stop();\n    } finally {\n      // Cleanup\n      try { fs.unlinkSync(dbPath); } catch { /* ignore */ }\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null}}
