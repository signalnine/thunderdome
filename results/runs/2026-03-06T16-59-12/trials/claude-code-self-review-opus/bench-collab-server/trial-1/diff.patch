+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BpU6vFyqydoEx6DhjEEhvt","type":"tool_result","content":"     1ŌåÆCREATE TABLE IF NOT EXISTS documents (\n     2ŌåÆ  id TEXT PRIMARY KEY,\n     3ŌåÆ  title TEXT NOT NULL,\n     4ŌåÆ  content TEXT NOT NULL DEFAULT '',\n     5ŌåÆ  created_at TEXT NOT NULL DEFAULT (datetime('now')),\n     6ŌåÆ  updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n     7ŌåÆ);\n     8ŌåÆ\n     9ŌåÆCREATE TABLE IF NOT EXISTS versions (\n    10ŌåÆ  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    11ŌåÆ  document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    12ŌåÆ  version INTEGER NOT NULL,\n    13ŌåÆ  content TEXT NOT NULL,\n    14ŌåÆ  operation TEXT, -- JSON of the operation that produced this version\n    15ŌåÆ  created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    16ŌåÆ  UNIQUE(document_id, version)\n    17ŌåÆ);\n    18ŌåÆ\n    19ŌåÆCREATE TABLE IF NOT EXISTS active_connections (\n    20ŌåÆ  id TEXT PRIMARY KEY,\n    21ŌåÆ  document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    22ŌåÆ  connected_at TEXT NOT NULL DEFAULT (datetime('now'))\n    23ŌåÆ);\n    24ŌåÆ"}]},"parent_tool_use_id":"toolu_0181nc6hH9zC741q719EjCjv","session_id":"f1200fcd-d534-41e0-a6ea-ae485dd4b49b","uuid":"f14549af-ae7a-4e41-a872-e8c78a5ffc03"}
