p(dbPath);\n  1395ŌåÆ+      await app1.start(0);\n  1396ŌåÆ+\n  1397ŌåÆ+      const created = await request(app1.app)\n  1398ŌåÆ+        .post('/api/documents')\n  1399ŌåÆ+        .send({ title: 'Persistent', content: 'saved data' });\n  1400ŌåÆ+\n  1401ŌåÆ+      const docId = created.body.id;\n  1402ŌåÆ+      await app1.stop();\n  1403ŌåÆ+\n  1404ŌåÆ+      // Start second server with same DB\n  1405ŌåÆ+      const app2 = createApp(dbPath);\n  1406ŌåÆ+      await app2.start(0);\n  1407ŌåÆ+\n  1408ŌåÆ+      const res = await request(app2.app)\n  1409ŌåÆ+        .get(`/api/documents/${docId}`)\n  1410ŌåÆ+        .expect(200);\n  1411ŌåÆ+\n  1412ŌåÆ+      expect(res.body.title).toBe('Persistent');\n  1413ŌåÆ+      expect(res.body.content).toBe('saved data');\n  1414ŌåÆ+\n  1415ŌåÆ+      await app2.stop();\n  1416ŌåÆ+    } finally {\n  1417ŌåÆ+      // Cleanup\n  1418ŌåÆ+      try { fs.unlinkSync(dbPath); } catch { /* ignore */ }\n  1419ŌåÆ+    }\n  1420ŌåÆ+  });\n  1421ŌåÆ+});\n  1422ŌåÆdiff --git a/src/server.ts b/src/server.ts\n  1423ŌåÆnew file mode 100644\n  1424ŌåÆindex 0000000..8746e4b\n  1425ŌåÆ--- /dev/null\n  1426ŌåÆ+++ b/src/server.ts\n  1427ŌåÆ@@ -0,0 +1,67 @@\n  1428ŌåÆ+import express from 'express';\n  1429ŌåÆ+import { createServer, type Server as HttpServer } from 'http';\n  1430ŌåÆ+import { DocumentDB } from './db.js';\n  1431ŌåÆ+import { createRouter } from './routes.js';\n  1432ŌåÆ+import { CollaborationServer } from './ws.js';\n  1433ŌåÆ+\n  1434ŌåÆ+export interface AppInstance {\n  1435ŌåÆ+  app: express.Express;\n  1436ŌåÆ+  start(port?: number): Promise<number>;\n  1437ŌåÆ+  stop(): Promise<void>;\n  1438ŌåÆ+}\n  1439ŌåÆ+\n  1440ŌåÆ+export function createApp(dbPath?: string): AppInstance {\n  1441ŌåÆ+  const db = new DocumentDB(dbPath);\n  1442ŌåÆ+  const app = express();\n  1443ŌåÆ+  const httpServer: HttpServer = createServer(app);\n  1444ŌåÆ+\n  1445ŌåÆ+  // Set up REST routes\n  1446ŌåÆ+  const router = createRouter(db);\n  1447ŌåÆ+  app.use('/api', router);\n  1448ŌåÆ+\n  1449ŌåÆ+  // Set up WebSocket collaboration\n  1450ŌåÆ+  const collab = new CollaborationServer(httpServer, db);\n  1451ŌåÆ+\n  1452ŌåÆ+  let started = false;\n  1453ŌåÆ+\n  1454ŌåÆ+  return {\n  1455ŌåÆ+    app,\n  1456ŌåÆ+\n  1457ŌåÆ+    start(port = 0): Promise<number> {\n  1458ŌåÆ+      return new Promise((resolve, reject) => {\n  1459ŌåÆ+        if (started) {\n  1460ŌåÆ+          const addr = httpServer.address();\n  1461ŌåÆ+          if (addr && typeof addr === 'object') {\n  1462ŌåÆ+            resolve(addr.port);\n  1463ŌåÆ+          } else {\n  1464ŌåÆ+            reject(new Error('Server already started but address not available'));\n  1465ŌåÆ+          }\n  1466ŌåÆ+          return;\n  1467ŌåÆ+        }\n  1468ŌåÆ+\n  1469ŌåÆ+        httpServer.listen(port, () => {\n  1470ŌåÆ+          started = true;\n  1471ŌåÆ+          const addr = httpServer.address();\n  1472ŌåÆ+          if (addr && typeof addr === 'object') {\n  1473ŌåÆ+            resolve(addr.port);\n  1474ŌåÆ+          } else {\n  1475ŌåÆ+            reject(new Error('Failed to get server address'));\n  1476ŌåÆ+          }\n  1477ŌåÆ+        });\n  1478ŌåÆ+\n  1479ŌåÆ+        httpServer.on('error', reject);\n  1480ŌåÆ+      });\n  1481ŌåÆ+    },\n  1482ŌåÆ+\n  1483ŌåÆ+    stop(): Promise<void> {\n  1484ŌåÆ+      return new Promise((resolve, reject) => {\n  1485ŌåÆ+        collab.closeAll();\n  1486ŌåÆ+        httpServer.close((err) => {\n  1487ŌåÆ+          db.close();\n  1488ŌåÆ+          if (err) reject(err);\n  1489ŌåÆ+          else resolve();\n  1490ŌåÆ+        });\n  1491ŌåÆ+      });\n  1492ŌåÆ+    },\n  1493ŌåÆ+  };\n  1494ŌåÆ+}\n  1495ŌåÆdiff --git a/src/ws.ts b/src/ws.ts\n  1496ŌåÆnew file mode 100644\n  1497ŌåÆindex 0000000..f3b3a93\n  1498ŌåÆ--- /dev/null\n  1499ŌåÆ+++ b/src/ws.ts\n  1500ŌåÆ@@ -0,0 +1,258 @@\n  1501ŌåÆ+import { WebSocketServer, WebSocket } from 'ws';\n  1502ŌåÆ+import type { Server as HttpServer } from 'http';\n  1503ŌåÆ+import type { DocumentDB } from './db.js';\n  1504ŌåÆ+import { apply, transform, validate, type Operation } from './ot.js';\n  1505ŌåÆ+import { randomUUID } from 'crypto';\n  1506ŌåÆ+\n  1507ŌåÆ+/**\n  1508ŌåÆ+ * Message types from client to server:\n  1509ŌåÆ+ * - { type: 'operation', version: number, operation: Operation }\n  1510ŌåÆ+ *\n  1511ŌåÆ+ * Message types from server to client:\n  1512ŌåÆ+ * - { type: 'sync', content: string, version: number }\n  1513ŌåÆ+ * - { type: 'operation', operation: Operation, version: number, clientId: string }\n  1514ŌåÆ+ * - { type: 'ack', version: number }\n  1515ŌåÆ+ * - { type: 'error', message: string }\n  1516ŌåÆ+ */\n  1517ŌåÆ+\n  1518ŌåÆ+interface ClientConnection {\n  1519ŌåÆ+  ws: WebSocket;\n  1520ŌåÆ+  clientId: string;\n  1521ŌåÆ+  documentId: string;\n  1522ŌåÆ+}\n  1523ŌåÆ+\n  1524ŌåÆ+interface DocumentState {\n  1525ŌåÆ+  version: number;\n  1526ŌåÆ+  content: string;\n  1527ŌåÆ+  /** Operations since version 1. Index i = operation that produced version i+1. */\n  1528ŌåÆ+  operations: Operation[];\n  1529ŌåÆ+  clients: Map<string, ClientConnection>;\n  1530ŌåÆ+}\n  1531ŌåÆ+\n  1532ŌåÆ+export class CollaborationServer {\n  1533ŌåÆ+  private wss: WebSocketServer;\n  1534ŌåÆ+  private documents: Map<string, DocumentState> = new Map();\n  1535ŌåÆ+  private db: DocumentDB;\n  1536ŌåÆ+\n  1537ŌåÆ+  constructor(server: HttpServer, db: DocumentDB) {\n  1538ŌåÆ+    this.db = db;\n  1539ŌåÆ+    this.wss = new WebSocketServer({ noServer: true });\n  1540ŌåÆ+\n  1541ŌåÆ+    server.on('upgrade', (request, socket, head) => {\n  1542ŌåÆ+      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);\n  1543ŌåÆ+      const match = url.pathname.match(/^\\/documents\\/([^/]+)\\/ws$/);\n  1544ŌåÆ+\n  1545ŌåÆ+      if (!match) {\n  1546ŌåÆ+        socket.destroy();\n  1547ŌåÆ+        return;\n  1548ŌåÆ+      }\n  1549ŌåÆ+\n  1550ŌåÆ+      const documentId = match[1];\n  1551ŌåÆ+      const doc = this.db.getDocument(documentId);\n  1552ŌåÆ+      if (!doc) {\n  1553ŌåÆ+        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n  1554ŌåÆ+        socket.destroy();\n  1555ŌåÆ+        return;\n  1556ŌåÆ+      }\n  1557ŌåÆ+\n  1558ŌåÆ+      this.wss.handleUpgrade(request, socket, head, (ws) => {\n  1559ŌåÆ+        this.handleConnection(ws, documentId);\n  1560ŌåÆ+      });\n  1561ŌåÆ+    });\n  1562ŌåÆ+  }\n  1563ŌåÆ+\n  1564ŌåÆ+  private getOrCreateDocumentState(documentId: string): DocumentState {\n  1565ŌåÆ+    let state = this.documents.get(documentId);\n  1566ŌåÆ+    if (!state) {\n  1567ŌåÆ+      const doc = this.db.getDocument(documentId);\n  1568ŌåÆ+      if (!doc) throw new Error(`Document ${documentId} not found`);\n  1569ŌåÆ+\n  1570ŌåÆ+      const version = this.db.getLatestVersion(documentId);\n  1571ŌåÆ+      // Load stored operations for transformation\n  1572ŌåÆ+      const versions = this.db.getVersionHistory(documentId);\n  1573ŌåÆ+      const operations: Operation[] = [];\n  1574ŌåÆ+      for (const v of versions) {\n  1575ŌåÆ+        if (v.operation) {\n  1576ŌåÆ+          try {\n  1577ŌåÆ+            const parsed = JSON.parse(v.operation);\n  1578ŌåÆ+            if (Array.isArray(parsed)) {\n  1579ŌåÆ+              operations.push(parsed);\n  1580ŌåÆ+            }\n  1581ŌåÆ+          } catch {\n  1582ŌåÆ+            // Skip malformed operations\n  1583ŌåÆ+          }\n  1584ŌåÆ+        }\n  1585ŌåÆ+      }\n  1586ŌåÆ+\n  1587ŌåÆ+      state = {\n  1588ŌåÆ+        version,\n  1589ŌåÆ+        content: doc.content,\n  1590ŌåÆ+        operations,\n  1591ŌåÆ+        clients: new Map(),\n  1592ŌåÆ+      };\n  1593ŌåÆ+      this.documents.set(documentId, state);\n  1594ŌåÆ+    }\n  1595ŌåÆ+    return state;\n  1596ŌåÆ+  }\n  1597ŌåÆ+\n  1598ŌåÆ+  private handleConnection(ws: WebSocket, documentId: string): void {\n  1599ŌåÆ+    const clientId = randomUUID();\n  1600ŌåÆ+    const state = this.getOrCreateDocumentState(documentId);\n  1601ŌåÆ+\n  1602ŌåÆ+    const conn: ClientConnection = { ws, clientId, documentId };\n  1603ŌåÆ+    state.clients.set(clientId, conn);\n  1604ŌåÆ+\n  1605ŌåÆ+    // Send sync message with current state\n  1606ŌåÆ+    this.send(ws, {\n  1607ŌåÆ+      type: 'sync',\n  1608ŌåÆ+      content: state.content,\n  1609ŌåÆ+      version: state.version,\n  1610ŌåÆ+      clientId,\n  1611ŌåÆ+    });\n  1612ŌåÆ+\n  1613ŌåÆ+    ws.on('message', (data) => {\n  1614ŌåÆ+      try {\n  1615ŌåÆ+        const message = JSON.parse(data.toString());\n  1616ŌåÆ+        this.handleMessage(conn, message);\n  1617ŌåÆ+      } catch (err) {\n  1618ŌåÆ+        this.send(ws, {\n  1619ŌåÆ+          type: 'error',\n  1620ŌåÆ+          message: err instanceof Error ? err.message : 'Invalid message',\n  1621ŌåÆ+        });\n  1622ŌåÆ+      }\n  1623ŌåÆ+    });\n  1624ŌåÆ+\n  1625ŌåÆ+    ws.on('close', () => {\n  1626ŌåÆ+      state.clients.delete(clientId);\n  1627ŌåÆ+      if (state.clients.size === 0) {\n  1628ŌåÆ+        // Keep state in memory for quick reconnection, don't clean up immediately\n  1629ŌåÆ+      }\n  1630ŌåÆ+    });\n  1631ŌåÆ+\n  1632ŌåÆ+    ws.on('error', () => {\n  1633ŌåÆ+      state.clients.delete(clientId);\n  1634ŌåÆ+    });\n  1635ŌåÆ+  }\n  1636ŌåÆ+\n  1637ŌåÆ+  private handleMessage(\n  1638ŌåÆ+    conn: ClientConnection,\n  1639ŌåÆ+    message: { type: string; version?: number; operation?: Operation },\n  1640ŌåÆ+  ): void {\n  1641ŌåÆ+    if (message.type !== 'operation') {\n  1642ŌåÆ+      this.send(conn.ws, {\n  1643ŌåÆ+        type: 'error',\n  1644ŌåÆ+        message: `Unknown message type: ${message.type}`,\n  1645ŌåÆ+      });\n  1646ŌåÆ+      return;\n  1647ŌåÆ+    }\n  1648ŌåÆ+\n  1649ŌåÆ+    const state = this.documents.get(conn.documentId);\n  1650ŌåÆ+    if (!state) {\n  1651ŌåÆ+      this.send(conn.ws, { type: 'error', message: 'Document not found' });\n  1652ŌåÆ+      return;\n  1653ŌåÆ+    }\n  1654ŌåÆ+\n  1655ŌåÆ+    if (typeof message.version !== 'number') {\n  1656ŌåÆ+      this.send(conn.ws, { type: 'error', message: 'Version is required' });\n  1657ŌåÆ+      return;\n  1658ŌåÆ+    }\n  1659ŌåÆ+\n  1660ŌåÆ+    if (!Array.isArray(message.operation)) {\n  1661ŌåÆ+      this.send(conn.ws, { type: 'error', message: 'Operation is required and must be an array' });\n  1662ŌåÆ+      return;\n  1663ŌåÆ+    }\n  1664ŌåÆ+\n  1665ŌåÆ+    const clientVersion = message.version;\n  1666ŌåÆ+    let operation = message.operation;\n  1667ŌåÆ+\n  1668ŌåÆ+    // The client's operation was based on version clientVersion.\n  1669ŌåÆ+    // We need to transform it against all operations from clientVersion to current version.\n  1670ŌåÆ+    if (clientVersion < 1 || clientVersion > state.version) {\n  1671ŌåÆ+      this.send(conn.ws, {\n  1672ŌåÆ+        type: 'error',\n  1673ŌåÆ+        message: `Invalid version ${clientVersion}. Current version is ${state.version}`,\n  1674ŌåÆ+      });\n  1675ŌåÆ+      return;\n  1676ŌåÆ+    }\n  1677ŌåÆ+\n  1678ŌåÆ+    // Transform against concurrent operations\n  1679ŌåÆ+    // state.operations[i] took version (i+1) to version (i+2)\n  1680ŌåÆ+    // Client at version v needs transforms against operations[v-1], operations[v], ...\n  1681ŌåÆ+    const startIdx = clientVersion - 1;\n  1682ŌåÆ+    for (let i = startIdx; i < state.operations.length; i++) {\n  1683ŌåÆ+      const serverOp = state.operations[i];\n  1684ŌåÆ+      try {\n  1685ŌåÆ+        const [transformedClient] = transform(operation, serverOp);\n  1686ŌåÆ+        operation = transformedClient;\n  1687ŌåÆ+      } catch (err) {\n  1688ŌåÆ+        this.send(conn.ws, {\n  1689ŌåÆ+          type: 'error',\n  1690ŌåÆ+          message: `Transform failed: ${err instanceof Error ? err.message : 'unknown error'}`,\n  1691ŌåÆ+        });\n  1692ŌåÆ+        return;\n  1693ŌåÆ+      }\n  1694ŌåÆ+    }\n  1695ŌåÆ+\n  1696ŌåÆ+    // Validate the transformed operation against current content\n  1697ŌåÆ+    const validationError = validate(operation, state.content.length);\n  1698ŌåÆ+    if (validationError) {\n  1699ŌåÆ+      this.send(conn.ws, { type: 'error', message: validationError });\n  1700ŌåÆ+      return;\n  1701ŌåÆ+    }\n  1702ŌåÆ+\n  1703ŌåÆ+    // Apply the operation\n  1704ŌåÆ+    let newContent: string;\n  1705ŌåÆ+    try {\n  1706ŌåÆ+      newContent = apply(state.content, operation);\n  1707ŌåÆ+    } catch (err) {\n  1708ŌåÆ+      this.send(conn.ws, {\n  1709ŌåÆ+        type: 'error',\n  1710ŌåÆ+        message: `Apply failed: ${err instanceof Error ? err.message : 'unknown error'}`,\n  1711ŌåÆ+      });\n  1712ŌåÆ+      return;\n  1713ŌåÆ+    }\n  1714ŌåÆ+\n  1715ŌåÆ+    // Persist to database\n  1716ŌåÆ+    const newVersion = this.db.updateDocumentContent(\n  1717ŌåÆ+      conn.documentId,\n  1718ŌåÆ+      newContent,\n  1719ŌåÆ+      JSON.stringify(operation),\n  1720ŌåÆ+    );\n  1721ŌåÆ+\n  1722ŌåÆ+    // Update in-memory state\n  1723ŌåÆ+    state.operations.push(operation);\n  1724ŌåÆ+    state.content = newContent;\n  1725ŌåÆ+    state.version = newVersion;\n  1726ŌåÆ+\n  1727ŌåÆ+    // Send ack to the sender\n  1728ŌåÆ+    this.send(conn.ws, { type: 'ack', version: newVersion });\n  1729ŌåÆ+\n  1730ŌåÆ+    // Broadcast to other clients\n  1731ŌåÆ+    for (const [cid, client] of state.clients) {\n  1732ŌåÆ+      if (cid !== conn.clientId && client.ws.readyState === WebSocket.OPEN) {\n  1733ŌåÆ+        this.send(client.ws, {\n  1734ŌåÆ+          type: 'operation',\n  1735ŌåÆ+          operation,\n  1736ŌåÆ+          version: newVersion,\n  1737ŌåÆ+          clientId: conn.clientId,\n  1738ŌåÆ+        });\n  1739ŌåÆ+      }\n  1740ŌåÆ+    }\n  1741ŌåÆ+  }\n  1742ŌåÆ+\n  1743ŌåÆ+  private send(ws: WebSocket, message: object): void {\n  1744ŌåÆ+    if (ws.readyState === WebSocket.OPEN) {\n  1745ŌåÆ+      ws.send(JSON.stringify(message));\n  1746ŌåÆ+    }\n  1747ŌåÆ+  }\n  1748ŌåÆ+\n  1749ŌåÆ+  closeAll(): void {\n  1750ŌåÆ+    for (const [, state] of this.documents) {\n  1751ŌåÆ+      for (const [, client] of state.clients) {\n  1752ŌåÆ+        client.ws.close();\n  1753ŌåÆ+      }\n  1754ŌåÆ+    }\n  1755ŌåÆ+    this.documents.clear();\n  1756ŌåÆ+    this.wss.close();\n  1757ŌåÆ+  }\n  1758ŌåÆ+}"}]},"parent_tool_use_id":null,"session_id":"f1200fcd-d534-41e0-a6ea-ae485dd4b49b","uuid":"f9aa4632-ddf2-40bb-9136-10ded4928a4e","tool_use_result":{"type":"text","file":{"filePath":"/tmp/.claude/projects/-workspace/f1200fcd-d534-41e0-a6ea-ae485dd4b49b/tool-results/toolu_01FpYzhiohipKNLvKMwcUE4Z.txt","content":"diff --git a/src/db.ts b/src/db.ts\nnew file mode 100644\nindex 0000000..2089758\n--- /dev/null\n+++ b/src/db.ts\n@@ -0,0 +1,162 @@\n+import Database from 'better-sqlite3';\n+import { randomUUID } from 'crypto';\n+import fs from 'fs';\n+import path from 'path';\n+\n+export interface Document {\n+  id: string;\n+  title: string;\n+  content: string;\n+  created_at: string;\n+  updated_at: string;\n+}\n+\n+export interface Version {\n+  id: number;\n+  document_id: string;\n+  version: number;\n+  content: string;\n+  operation: string | null;\n+  created_at: string;\n+}\n+\n+export class DocumentDB {\n+  private db: Database.Database;\n+\n+  constructor(dbPath?: string) {\n+    this.db = new Database(dbPath || ':memory:');\n+    this.db.pragma('journal_mode = WAL');\n+    this.db.pragma('foreign_keys = ON');\n+    this.init();\n+  }\n+\n+  private init(): void {\n+    const schemaPath = path.resolve(\n+      path.dirname(new URL(import.meta.url).pathname),\n+      '..',\n+      'schema.sql',\n+    );\n+    let schema: string;\n+    try {\n+      schema = fs.readFileSync(schemaPath, 'utf-8');\n+    } catch {\n+      // Fallback inline schema if file not found\n+      schema = `\n+        CREATE TABLE IF NOT EXISTS documents (\n+          id TEXT PRIMARY KEY,\n+          title TEXT NOT NULL,\n+          content TEXT NOT NULL DEFAULT '',\n+          created_at TEXT NOT NULL DEFAULT (datetime('now')),\n+          updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n+        );\n+        CREATE TABLE IF NOT EXISTS versions (\n+          id INTEGER PRIMARY KEY AUTOINCREMENT,\n+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n+          version INTEGER NOT NULL,\n+          content TEXT NOT NULL,\n+          operation TEXT,\n+          created_at TEXT NOT NULL DEFAULT (datetime('now')),\n+          UNIQUE(document_id, version)\n+        );\n+        CREATE TABLE IF NOT EXISTS active_connections (\n+          id TEXT PRIMARY KEY,\n+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n+          connected_at TEXT NOT NULL DEFAULT (datetime('now'))\n+        );\n+      `;\n+    }\n+    this.db.exec(schema);\n+  }\n+\n+  createDocument(title: string, content: string = ''): Document {\n+    const id = randomUUID();\n+    const stmt = this.db.prepare(\n+      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`,\n+    );\n+    stmt.run(id, title, content);\n+\n+    // Create initial version\n+    this.db.prepare(\n+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, ?)`,\n+    ).run(id, content, JSON.stringify({ type: 'init' }));\n+\n+    return this.getDocument(id)!;\n+  }\n+\n+  getDocument(id: string): Document | undefined {\n+    const stmt = this.db.prepare(`SELECT * FROM documents WHERE id = ?`);\n+    return stmt.get(id) as Document | undefined;\n+  }\n+\n+  listDocuments(): Document[] {\n+    const stmt = this.db.prepare(\n+      `SELECT * FROM documents ORDER BY updated_at DESC`,\n+    );\n+    return stmt.all() as Document[];\n+  }\n+\n+  updateDocument(\n+    id: string,\n+    updates: { title?: string; content?: string },\n+  ): Document | undefined {\n+    const doc = this.getDocument(id);\n+    if (!doc) return undefined;\n+\n+    const title = updates.title ?? doc.title;\n+    const content = updates.content ?? doc.content;\n+\n+    this.db.prepare(\n+      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`,\n+    ).run(title, content, id);\n+\n+    return this.getDocument(id);\n+  }\n+\n+  deleteDocument(id: string): boolean {\n+    const result = this.db.prepare(`DELETE FROM documents WHERE id = ?`).run(\n+      id,\n+    );\n+    return result.changes > 0;\n+  }\n+\n+  updateDocumentContent(id: string, content: string, operation: string): number {\n+    const currentVersion = this.getLatestVersion(id);\n+    const newVersion = currentVersion + 1;\n+\n+    const update = this.db.transaction(() => {\n+      this.db.prepare(\n+        `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`,\n+      ).run(content, id);\n+\n+      this.db.prepare(\n+        `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`,\n+      ).run(id, newVersion, content, operation);\n+    });\n+\n+    update();\n+    return newVersion;\n+  }\n+\n+  getLatestVersion(documentId: string): number {\n+    const row = this.db.prepare(\n+      `SELECT MAX(version) as max_version FROM versions WHERE document_id = ?`,\n+    ).get(documentId) as { max_version: number | null } | undefined;\n+    return row?.max_version ?? 0;\n+  }\n+\n+  getVersionHistory(documentId: string): Version[] {\n+    return this.db.prepare(\n+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`,\n+    ).all(documentId) as Version[];\n+  }\n+\n+  getVersion(documentId: string, version: number): Version | undefined {\n+    return this.db.prepare(\n+      `SELECT * FROM versions WHERE document_id = ? AND version = ?`,\n+    ).get(documentId, version) as Version | undefined;\n+  }\n+\n+  close(): void {\n+    this.db.close();\n+  }\n+}\ndiff --git a/src/ot.test.ts b/src/ot.test.ts\nnew file mode 100644\nindex 0000000..698d1b4\n--- /dev/null\n+++ b/src/ot.test.ts\n@@ -0,0 +1,319 @@\n+import { describe, it, expect } from 'vitest';\n+import {\n+  apply,\n+  transform,\n+  compose,\n+  normalize,\n+  insertAt,\n+  deleteAt,\n+  validate,\n+  inputLength,\n+  outputLength,\n+  type Operation,\n+} from './ot.js';\n+\n+describe('OT: apply', () => {\n+  it('should apply insert at beginning', () => {\n+    const doc = 'hello';\n+    const op: Operation = [\n+      { type: 'insert', text: 'say ' },\n+      { type: 'retain', count: 5 },\n+    ];\n+    expect(apply(doc, op)).toBe('say hello');\n+  });\n+\n+  it('should apply insert at end', () => {\n+    const doc = 'hello';\n+    const op: Operation = [\n+      { type: 'retain', count: 5 },\n+      { type: 'insert', text: ' world' },\n+    ];\n+    expect(apply(doc, op)).toBe('hello world');\n+  });\n+\n+  it('should apply insert in middle', () => {\n+    const doc = 'helo';\n+    const op: Operation = [\n+      { type: 'retain', count: 2 },\n+      { type: 'insert', text: 'l' },\n+      { type: 'retain', count: 2 },\n+    ];\n+    expect(apply(doc, op)).toBe('hello');\n+  });\n+\n+  it('should apply delete', () => {\n+    const doc = 'hello world';\n+    const op: Operation = [\n+      { type: 'retain', count: 5 },\n+      { type: 'delete', count: 6 },\n+    ];\n+    expect(apply(doc, op)).toBe('hello');\n+  });\n+\n+  it('should apply to empty document', () => {\n+    expect(apply('', [{ type: 'insert', text: 'hi' }])).toBe('hi');\n+  });\n+\n+  it('should apply empty operation to empty document', () => {\n+    expect(apply('', [])).toBe('');\n+  });\n+\n+  it('should throw on retain past end', () => {\n+    expect(() => apply('hi', [{ type: 'retain', count: 5 }])).toThrow();\n+  });\n+\n+  it('should throw if operation does not consume entire document', () => {\n+    expect(() => apply('hello', [{ type: 'retain', count: 3 }])).toThrow();\n+  });\n+});\n+\n+describe('OT: transform', () => {\n+  it('should transform two inserts at different positions', () => {\n+    // Doc: \"abc\" (length 3)\n+    // A inserts \"X\" at position 1: retain(1), insert(\"X\"), retain(2)\n+    // B inserts \"Y\" at position 2: retain(2), insert(\"Y\"), retain(1)\n+    const a: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'insert', text: 'X' },\n+      { type: 'retain', count: 2 },\n+    ];\n+    const b: Operation = [\n+      { type: 'retain', count: 2 },\n+      { type: 'insert', text: 'Y' },\n+      { type: 'retain', count: 1 },\n+    ];\n+\n+    const [aPrime, bPrime] = transform(a, b);\n+\n+    const doc = 'abc';\n+    const afterA = apply(doc, a);   // \"aXbc\"\n+    const afterB = apply(doc, b);   // \"abYc\"\n+\n+    const afterAB = apply(afterA, bPrime); // Apply b' after a\n+    const afterBA = apply(afterB, aPrime); // Apply a' after b\n+\n+    expect(afterAB).toBe(afterBA);\n+    // Both insertions preserved\n+    expect(afterAB).toContain('X');\n+    expect(afterAB).toContain('Y');\n+  });\n+\n+  it('should transform two inserts at same position', () => {\n+    // Doc: \"abc\"\n+    // Both insert at position 1\n+    const a: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'insert', text: 'X' },\n+      { type: 'retain', count: 2 },\n+    ];\n+    const b: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'insert', text: 'Y' },\n+      { type: 'retain', count: 2 },\n+    ];\n+\n+    const [aPrime, bPrime] = transform(a, b);\n+\n+    const doc = 'abc';\n+    const afterAB = apply(apply(doc, a), bPrime);\n+    const afterBA = apply(apply(doc, b), aPrime);\n+\n+    expect(afterAB).toBe(afterBA);\n+    expect(afterAB).toContain('X');\n+    expect(afterAB).toContain('Y');\n+  });\n+\n+  it('should transform insert vs delete', () => {\n+    // Doc: \"abcde\" (length 5)\n+    // A inserts \"X\" at position 2\n+    // B deletes 2 chars at position 1\n+    const a: Operation = [\n+      { type: 'retain', count: 2 },\n+      { type: 'insert', text: 'X' },\n+      { type: 'retain', count: 3 },\n+    ];\n+    const b: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'delete', count: 2 },\n+      { type: 'retain', count: 2 },\n+    ];\n+\n+    const [aPrime, bPrime] = transform(a, b);\n+\n+    const doc = 'abcde';\n+    const afterAB = apply(apply(doc, a), bPrime);\n+    const afterBA = apply(apply(doc, b), aPrime);\n+\n+    expect(afterAB).toBe(afterBA);\n+    expect(afterAB).toContain('X');\n+  });\n+\n+  it('should transform delete vs delete (same region)', () => {\n+    // Doc: \"abcde\"\n+    // Both delete \"bc\" (position 1, count 2)\n+    const a: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'delete', count: 2 },\n+      { type: 'retain', count: 2 },\n+    ];\n+    const b: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'delete', count: 2 },\n+      { type: 'retain', count: 2 },\n+    ];\n+\n+    const [aPrime, bPrime] = transform(a, b);\n+\n+    const doc = 'abcde';\n+    const afterAB = apply(apply(doc, a), bPrime);\n+    const afterBA = apply(apply(doc, b), aPrime);\n+\n+    expect(afterAB).toBe(afterBA);\n+    expect(afterAB).toBe('ade');\n+  });\n+\n+  it('should transform overlapping deletes', () => {\n+    // Doc: \"abcde\"\n+    // A deletes positions 1-3 (\"bcd\")\n+    // B deletes positions 2-4 (\"cde\")\n+    const a: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'delete', count: 3 },\n+      { type: 'retain', count: 1 },\n+    ];\n+    const b: Operation = [\n+      { type: 'retain', count: 2 },\n+      { type: 'delete', count: 3 },\n+    ];\n+\n+    const [aPrime, bPrime] = transform(a, b);\n+\n+    const doc = 'abcde';\n+    const afterAB = apply(apply(doc, a), bPrime);\n+    const afterBA = apply(apply(doc, b), aPrime);\n+\n+    expect(afterAB).toBe(afterBA);\n+    expect(afterAB).toBe('a');\n+  });\n+\n+  it('should handle identity operations', () => {\n+    const a: Operation = [{ type: 'retain', count: 3 }];\n+    const b: Operation = [{ type: 'retain', count: 3 }];\n+\n+    const [aPrime, bPrime] = transform(a, b);\n+\n+    expect(apply('abc', aPrime)).toBe('abc');\n+    expect(apply('abc', bPrime)).toBe('abc');\n+  });\n+});\n+\n+describe('OT: compose', () => {\n+  it('should compose two sequential operations', () => {\n+    const doc = 'hello';\n+    const a: Operation = [\n+      { type: 'retain', count: 5 },\n+      { type: 'insert', text: ' world' },\n+    ];\n+    const b: Operation = [\n+      { type: 'retain', count: 11 },\n+      { type: 'insert', text: '!' },\n+    ];\n+\n+    const composed = compose(a, b);\n+    expect(apply(doc, composed)).toBe(apply(apply(doc, a), b));\n+  });\n+\n+  it('should compose insert then delete', () => {\n+    const doc = 'ab';\n+    const a: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'insert', text: 'X' },\n+      { type: 'retain', count: 1 },\n+    ];\n+    const b: Operation = [\n+      { type: 'retain', count: 1 },\n+      { type: 'delete', count: 1 },\n+      { type: 'retain', count: 1 },\n+    ];\n+\n+    const composed = compose(a, b);\n+    expect(apply(doc, composed)).toBe(apply(apply(doc, a), b));\n+  });\n+});\n+\n+describe('OT: normalize', () => {\n+  it('should merge adjacent retains', () => {\n+    const op: Operation = [\n+      { type: 'retain', count: 2 },\n+      { type: 'retain', count: 3 },\n+    ];\n+    expect(normalize(op)).toEqual([{ type: 'retain', count: 5 }]);\n+  });\n+\n+  it('should remove zero-length components', () => {\n+    const op: Operation = [\n+      { type: 'retain', count: 0 },\n+      { type: 'insert', text: 'hi' },\n+      { type: 'delete', count: 0 },\n+    ];\n+    expect(normalize(op)).toEqual([{ type: 'insert', text: 'hi' }]);\n+  });\n+\n+  it('should merge adjacent inserts', () => {\n+    const op: Operation = [\n+      { type: 'insert', text: 'hel' },\n+      { type: 'insert', text: 'lo' },\n+    ];\n+    expect(normalize(op)).toEqual([{ type: 'insert', text: 'hello' }]);\n+  });\n+});\n+\n+describe('OT: helper functions', () => {\n+  it('insertAt should create correct operation', () => {\n+    const op = insertAt(5, 2, 'XX');\n+    expect(apply('abcde', op)).toBe('abXXcde');\n+  });\n+\n+  it('deleteAt should create correct operation', () => {\n+    const op = deleteAt(5, 1, 2);\n+    expect(apply('abcde', op)).toBe('ade');\n+  });\n+\n+  it('inputLength should calculate correctly', () => {\n+    const op: Operation = [\n+      { type: 'retain', count: 3 },\n+      { type: 'insert', text: 'xx' },\n+      { type: 'delete', count: 2 },\n+    ];\n+    expect(inputLength(op)).toBe(5);\n+  });\n+\n+  it('outputLength should calculate correctly', () => {\n+    const op: Operation = [\n+      { type: 'retain', count: 3 },\n+      { type: 'insert', text: 'xx' },\n+      { type: 'delete', count: 2 },\n+    ];\n+    expect(outputLength(op)).toBe(5);\n+  });\n+});\n+\n+describe('OT: validate', () => {\n+  it('should return null for valid operation', () => {\n+    const op: Operation = [\n+      { type: 'retain', count: 3 },\n+      { type: 'insert', text: 'X' },\n+      { type: 'delete', count: 2 },\n+    ];\n+    expect(validate(op, 5)).toBeNull();\n+  });\n+\n+  it('should return error for wrong base length', () => {\n+    const op: Operation = [{ type: 'retain', count: 3 }];\n+    expect(validate(op, 5)).toContain('does not match');\n+  });\n+\n+  it('should return null for empty operation on empty document', () => {\n+    expect(validate([], 0)).toBeNull();\n+  });\n+});\ndiff --git a/src/ot.ts b/src/ot.ts\nnew file mode 100644\nindex 0000000..d212d32\n--- /dev/null\n+++ b/src/ot.ts\n@@ -0,0 +1,391 @@\n+/**\n+ * Operational Transformation (OT) engine for collaborative text editing.\n+ *\n+ * Operations are sequences of components that describe edits:\n+ * - retain(n): skip n characters\n+ * - insert(s): insert string s at current position\n+ * - delete(n): delete n characters at current position\n+ *\n+ * The key function is `transform(a, b)` which takes two concurrent operations\n+ * and returns [a', b'] such that apply(apply(doc, a), b') === apply(apply(doc, b), a').\n+ */\n+\n+export type OpComponent =\n+  | { type: 'retain'; count: number }\n+  | { type: 'insert'; text: string }\n+  | { type: 'delete'; count: number };\n+\n+export type Operation = OpComponent[];\n+\n+/** Apply an operation to a document string. */\n+export function apply(doc: string, op: Operation): string {\n+  let result = '';\n+  let pos = 0;\n+\n+  for (const comp of op) {\n+    switch (comp.type) {\n+      case 'retain':\n+        if (pos + comp.count > doc.length) {\n+          throw new Error(\n+            `Retain count ${comp.count} exceeds remaining document length (pos=${pos}, docLen=${doc.length})`,\n+          );\n+        }\n+        result += doc.slice(pos, pos + comp.count);\n+        pos += comp.count;\n+        break;\n+      case 'insert':\n+        result += comp.text;\n+        break;\n+      case 'delete':\n+        if (pos + comp.count > doc.length) {\n+          throw new Error(\n+            `Delete count ${comp.count} exceeds remaining document length (pos=${pos}, docLen=${doc.length})`,\n+          );\n+        }\n+        pos += comp.count;\n+        break;\n+    }\n+  }\n+\n+  // Append any remaining text (if op didn't cover the whole doc, that's an error)\n+  if (pos < doc.length) {\n+    throw new Error(\n+      `Operation did not consume entire document (pos=${pos}, docLen=${doc.length})`,\n+    );\n+  }\n+\n+  return result;\n+}\n+\n+/** Get the input length an operation expects. */\n+export function inputLength(op: Operation): number {\n+  let len = 0;\n+  for (const comp of op) {\n+    if (comp.type === 'retain') len += comp.count;\n+    else if (comp.type === 'delete') len += comp.count;\n+  }\n+  return len;\n+}\n+\n+/** Get the output length after applying an operation. */\n+export function outputLength(op: Operation): number {\n+  let len = 0;\n+  for (const comp of op) {\n+    if (comp.type === 'retain') len += comp.count;\n+    else if (comp.type === 'insert') len += comp.text.length;\n+  }\n+  return len;\n+}\n+\n+/**\n+ * Transform two concurrent operations a and b (both based on the same document state)\n+ * into a' and b' such that:\n+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')\n+ *\n+ * Returns [a', b'] where:\n+ * - a' can be applied after b\n+ * - b' can be applied after a\n+ */\n+export function transform(\n+  a: Operation,\n+  b: Operation,\n+): [Operation, Operation] {\n+  const aPrime: Operation = [];\n+  const bPrime: Operation = [];\n+\n+  let ia = 0;\n+  let ib = 0;\n+\n+  // We walk through both operations simultaneously using iterators\n+  // that can partially consume components.\n+  let aComp: OpComponent | null = a[ia] ?? null;\n+  let bComp: OpComponent | null = b[ib] ?? null;\n+\n+  const nextA = (): void => {\n+    ia++;\n+    aComp = a[ia] ?? null;\n+  };\n+  const nextB = (): void => {\n+    ib++;\n+    bComp = b[ib] ?? null;\n+  };\n+\n+  while (aComp !== null || bComp !== null) {\n+    // If a is an insert, it goes into a' and b' gets a retain over it\n+    if (aComp !== null && aComp.type === 'insert') {\n+      aPrime.push({ type: 'insert', text: aComp.text });\n+      bPrime.push({ type: 'retain', count: aComp.text.length });\n+      nextA();\n+      continue;\n+    }\n+\n+    // If b is an insert, it goes into b' and a' gets a retain over it\n+    if (bComp !== null && bComp.type === 'insert') {\n+      bPrime.push({ type: 'insert', text: bComp.text });\n+      aPrime.push({ type: 'retain', count: bComp.text.length });\n+      nextB();\n+      continue;\n+    }\n+\n+    // Both must be non-null at this point for retain/delete pairs\n+    if (aComp === null || bComp === null) {\n+      throw new Error('Operations have different base lengths');\n+    }\n+\n+    if (aComp.type === 'retain' && bComp.type === 'retain') {\n+      const minLen = Math.min(aComp.count, bComp.count);\n+      aPrime.push({ type: 'retain', count: minLen });\n+      bPrime.push({ type: 'retain', count: minLen });\n+\n+      if (aComp.count === bComp.count) {\n+        nextA();\n+        nextB();\n+      } else if (aComp.count < bComp.count) {\n+        bComp = { type: 'retain', count: bComp.count - aComp.count };\n+        nextA();\n+      } else {\n+        aComp = { type: 'retain', count: aComp.count - bComp.count };\n+        nextB();\n+      }\n+    } else if (aComp.type === 'delete' && bComp.type === 'delete') {\n+      // Both delete the same text, so neither needs to in the transformed version\n+      if (aComp.count === bComp.count) {\n+        nextA();\n+        nextB();\n+      } else if (aComp.count < bComp.count) {\n+        bComp = { type: 'delete', count: bComp.count - aComp.count };\n+        nextA();\n+      } else {\n+        aComp = { type: 'delete', count: aComp.count - bComp.count };\n+        nextB();\n+      }\n+    } else if (aComp.type === 'delete' && bComp.type === 'retain') {\n+      const minLen = Math.min(aComp.count, bComp.count);\n+      aPrime.push({ type: 'delete', count: minLen });\n+      // b doesn't need to retain what a deleted\n+\n+      if (aComp.count === bComp.count) {\n+        nextA();\n+        nextB();\n+      } else if (aComp.count < bComp.count) {\n+        bComp = { type: 'retain', count: bComp.count - aComp.count };\n+        nextA();\n+      } else {\n+        aComp = { type: 'delete', count: aComp.count - bComp.count };\n+        nextB();\n+      }\n+    } else if (aComp.type === 'retain' && bComp.type === 'delete') {\n+      const minLen = Math.min(aComp.count, bComp.count);\n+      bPrime.push({ type: 'delete', count: minLen });\n+      // a doesn't need to retain what b deleted\n+\n+      if (aComp.count === bComp.count) {\n+        nextA();\n+        nextB();\n+      } else if (aComp.count < bComp.count) {\n+        bComp = { type: 'delete', count: bComp.count - aComp.count };\n+        nextA();\n+      } else {\n+        aComp = { type: 'retain', count: aComp.count - bComp.count };\n+        nextB();\n+      }\n+    } else {\n+      throw new Error(\n+        `Unexpected component combination: ${aComp.type} / ${bComp.type}`,\n+      );\n+    }\n+  }\n+\n+  return [