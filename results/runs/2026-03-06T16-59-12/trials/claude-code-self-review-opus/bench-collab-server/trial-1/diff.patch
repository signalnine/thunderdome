n\n    if (aComp === null || bComp === null) {\n      throw new Error('Compose: operations have incompatible lengths');\n    }\n\n    if (aComp.type === 'retain' && bComp.type === 'retain') {\n      const minLen = Math.min(aComp.count, bComp.count);\n      result.push({ type: 'retain', count: minLen });\n      if (aComp.count === bComp.count) {\n        nextA();\n        nextB();\n      } else if (aComp.count < bComp.count) {\n        bComp = { type: 'retain', count: bComp.count - aComp.count };\n        nextA();\n      } else {\n        aComp = { type: 'retain', count: aComp.count - bComp.count };\n        nextB();\n      }\n    } else if (aComp.type === 'insert' && bComp.type === 'retain') {\n      const minLen = Math.min(aComp.text.length, bComp.count);\n      result.push({ type: 'insert', text: aComp.text.slice(0, minLen) });\n      if (aComp.text.length === bComp.count) {\n        nextA();\n        nextB();\n      } else if (aComp.text.length < bComp.count) {\n        bComp = { type: 'retain', count: bComp.count - aComp.text.length };\n        nextA();\n      } else {\n        aComp = { type: 'insert', text: aComp.text.slice(minLen) };\n        nextB();\n      }\n    } else if (aComp.type === 'insert' && bComp.type === 'delete') {\n      const minLen = Math.min(aComp.text.length, bComp.count);\n      // Insert followed by delete cancels out\n      if (aComp.text.length === bComp.count) {\n        nextA();\n        nextB();\n      } else if (aComp.text.length < bComp.count) {\n        bComp = { type: 'delete', count: bComp.count - aComp.text.length };\n        nextA();\n      } else {\n        aComp = { type: 'insert', text: aComp.text.slice(minLen) };\n        nextB();\n      }\n    } else if (aComp.type === 'retain' && bComp.type === 'delete') {\n      const minLen = Math.min(aComp.count, bComp.count);\n      result.push({ type: 'delete', count: minLen });\n      if (aComp.count === bComp.count) {\n        nextA();\n        nextB();\n      } else if (aComp.cou