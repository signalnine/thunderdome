= apply(apply(doc, b), a').\n+ */\n+\n+export type OpComponent =\n+  | { type: 'retain'; count: number }\n+  | { type: 'insert'; text: string }\n+  | { type: 'delete'; count: number };\n+\n+export type Operation = OpComponent[];\n+\n+/** Apply an operation to a document string. */\n+export function apply(doc: string, op: Operation): string {\n+  let result = '';\n+  let pos = 0;\n+\n+  for (const comp of op) {\n+    switch (comp.type) {\n+      case 'retain':\n+        if (pos + comp.count > doc.length) {\n+          throw new Error(\n+            `Retain count ${comp.count} exceeds remaining document length (pos=${pos}, docLen=${doc.length})`,\n+          );\n+        }\n+        result += doc.slice(pos, pos + comp.count);\n+        pos += comp.count;\n+        break;\n+      case 'insert':\n+        result += comp.text;\n+        break;\n+      case 'delete':\n+        if (pos + comp.count > doc.length) {\n+          throw new Error(\n+            `Delete count ${comp.count} exceeds remaining document length (pos=${pos}, docLen=${doc.length})`,\n+          );\n+        }\n+        pos += comp.count;\n+        break;\n+    }\n+  }\n+\n+  // Append any remaining text (if op didn't cover the whole doc, that's an error)\n+  if (pos < doc.length) {\n+    throw new Error(\n+      `Operation did not consume entire document (pos=${pos}, docLen=${doc.length})`,\n+    );\n+  }\n+\n+  return result;\n+}\n+\n+/** Get the input length an operation expects. */\n+export function inputLength(op: Operation): number {\n+  let len = 0;\n+  for (const comp of op) {\n+    if (comp.type === 'retain') len += comp.count;\n+    else if (comp.type === 'delete') len += comp.count;\n+  }\n+  return len;\n+}\n+\n+/** Get the output length after applying an operation. */\n+export function outputLength(op: Operation): number {\n+  let len = 0;\n+  for (const comp of op) {\n+    if (comp.type === 'retain') len += comp.count;\n+    else if (comp.type === 'insert') len += comp.text.length;\n+  }\n+  return len;\n+}\n+\n+/**\n+ * Transform two concurrent operations a and b (both based on the same document state)\n+ * into a' and b' such that:\n+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')\n+ *\n+ * Returns [a', b'] where:\n+ * - a' can be applied after b\n+ * - b' can be applied after a\n+ */\n+export function transform(\n+  a: Operation,\n+  b: Operation,\n+): [Operation, Operation] {\n+  const aPrime: Operation = [];\n+  const bPrime: Operation = [];\n+\n+  let ia = 0;\n+  let ib = 0;\n+\n+  // We walk through both operations simultaneously using iterators\n+  // that can partially consume components.\n+  let aComp: OpComponent | null = a[ia] ?? null;\n+  let bComp: OpComponent | null = b[ib] ?? null;\n+\n+  const nextA = (): void => {\n+    ia++;\n+    aComp = a[ia] ?? null;\n+  };\n+  const nextB = (): void => {\n+    ib++;\n+    bComp = b[ib] ?? null;\n+  };\n+\n+  while (aComp !== null || bComp !== null) {\n+    // If a is an insert, it goes into a' and b' gets a retain over it\n+    if (aComp !== null && aComp.type === 'insert') {\n+      aPrime.push({ type: 'insert', text: aComp.text });\n+      bPrime.push({ type: 'retain', count: aComp.text.length });\n+      nextA();\n+      continue;\n+    }\n+\n+    // If b is an insert, it goes into b' and a' gets a retain over it\n+    if (bComp !== null && bComp.type === 'insert') {\n+      bPrime.push({ type: 'insert', text: bComp.text });\n+      aPrime.push({ type: 'retain', count: bComp.text.length });\n+      nextB();\n+      continue;\n+    }\n+\n+    // Both must be non-null at this point for retain/delete pairs\n+    if (aComp === null || bComp === null) {\n+      throw new Error('Operations have different base lengths');\n+    }\n+\n+    if (aComp.type === 'retain' && bComp.type === 'retain') {\n+      const minLen = Math.min(aComp.count, bComp.count);\n+      aPrime.push({ type: 'retain', count: minLen });\n+      bPrime.push({ type: 'retain', count: minLen });\n+\n+      if (aComp.count === bComp.count) {\n+        nextA();\n+        nextB();\n+      } else if (aComp.count < bComp.count) {\n+        bComp = { type: 'retain', count: bComp.count - aComp.count };\n+        nextA();\n+      } else {\n+        aComp = { type: 'retain', count: aComp.count - bComp.count };\n+        nextB();\n+      }\n+    } else if (aComp.type === 'delete' && bComp.type === 'delete') {\n+      // Both delete the same text, so neither needs to in the transformed version\n+      if (aComp.count === bComp.count) {\n+        nextA();\n+        nextB();\n+      } else if (aComp.count < bComp.count) {\n+        bComp = { type: 'delete', count: bComp.count - aComp.count };\n+        nextA();\n+      } else {\n+        aComp = { type: 'delete', count: aComp.count - bComp.count };\n+        nextB();\n+      }\n+    } else if (aComp.type === 'delete' && bComp.type === 'retain') {\n+      const minLen = Math.min(aComp.count, bComp.count);\n+      aPrime.push({ type: 'delete', count: minLen });\n+      // b doesn't need to retain what a deleted\n+\n+      if (aComp.count === bComp.count) {\n+        nextA();\n+        nextB();\n+      } else if (aComp.count < bComp.count) {\n+        bComp = { type: 'retain', count: bComp.count - aComp.count };\n+        nextA();\n+      } else {\n+        aComp = { type: 'delete', count: aComp.count - bComp.count };\n+        nextB();\n+      }\n+    } else if (aComp.type === 'retain' && bComp.type === 'delete') {\n+      const minLen = Math.min(aComp.count, bComp.count);\n+      bPrime.push({ type: 'delete', count: minLen });\n+      // a doesn't need to retain what b deleted\n+\n+      if (aComp.count === bComp.count) {\n+        nextA();\n+        nextB();\n+      } else if (aComp.count < bComp.count) {\n+        bComp = { type: 'delete', count: bComp.count - aComp.count };\n+        nextA();\n+      } else {\n+        aComp = { type: 'retain', count: aComp.count - bComp.count };\n+        nextB();\n+      }\n+    } else {\n+      throw new E