+import express from 'express';
+import { createServer, type Server as HttpServer } from 'http';
+import { DocumentDB } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = new DocumentDB(dbPath);
+  const app = express();
+  const httpServer: HttpServer = createServer(app);
+
+  // Set up REST routes
+  const router = createRouter(db);
+  app.use('/api', router);
+
+  // Set up WebSocket collaboration
+  const collab = new CollaborationServer(httpServer, db);
+
+  let started = false;
+
+  return {
+    app,
+
+    start(port = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        if (started) {
+          const addr = httpServer.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Server already started but address not available'));
+          }
+          return;
+        }
+
+        httpServer.listen(port, () => {
+          started = true;
+          const addr = httpServer.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Failed to get server address'));
+          }
+        });
+
+        httpServer.on('error', reject);
+      });
+    },
+
+    stop(): Promise<void> {
+      return new Promise((resolve, reject) => {
+        collab.closeAll();
+        httpServer.close((err) => {
+          db.close();
+          if (err) reject(err);
+          else resolve();
+        });
+      });
+    },
+  };
+}
