d', content: 'v1' });\n  1143ŌåÆ+\n  1144ŌåÆ+    const res = await request(app.app)\n  1145ŌåÆ+      .get(`/api/documents/${created.body.id}/versions`)\n  1146ŌåÆ+      .expect(200);\n  1147ŌåÆ+\n  1148ŌåÆ+    expect(res.body.length).toBeGreaterThanOrEqual(1);\n  1149ŌåÆ+    expect(res.body[0].version).toBe(1);\n  1150ŌåÆ+  });\n  1151ŌåÆ+\n  1152ŌåÆ+  it('should get a specific version', async () => {\n  1153ŌåÆ+    const created = await request(app.app)\n  1154ŌåÆ+      .post('/api/documents')\n  1155ŌåÆ+      .send({ title: 'Versioned', content: 'initial' });\n  1156ŌåÆ+\n  1157ŌåÆ+    const res = await request(app.app)\n  1158ŌåÆ+      .get(`/api/documents/${created.body.id}/versions/1`)\n  1159ŌåÆ+      .expect(200);\n  1160ŌåÆ+\n  1161ŌåÆ+    expect(res.body.version).toBe(1);\n  1162ŌåÆ+    expect(res.body.content).toBe('initial');\n  1163ŌåÆ+  });\n  1164ŌåÆ+});\n  1165ŌåÆ+\n  1166ŌåÆ+describe('WebSocket collaboration', () => {\n  1167ŌåÆ+  it('should receive sync message on connect', async () => {\n  1168ŌåÆ+    const created = await request(app.app)\n  1169ŌåÆ+      .post('/api/documents')\n  1170ŌåÆ+      .send({ title: 'WS Test', content: 'hello' });\n  1171ŌåÆ+\n  1172ŌåÆ+    const { ws, sync } = await connectWs(created.body.id);\n  1173ŌåÆ+    expect(sync.content).toBe('hello');\n  1174ŌåÆ+    expect(sync.version).toBe(1);\n  1175ŌåÆ+    expect(sync.clientId).toBeDefined();\n  1176ŌåÆ+    ws.close();\n  1177ŌåÆ+  });\n  1178ŌåÆ+\n  1179ŌåÆ+  it('should broadcast operations to other clients', async () => {\n  1180ŌåÆ+    const created = await request(app.app)\n  1181ŌåÆ+      .post('/api/documents')\n  1182ŌåÆ+      .send({ title: 'Collab', content: 'hello' });\n  1183ŌåÆ+\n  1184ŌåÆ+    const docId = created.body.id;\n  1185ŌåÆ+    const { ws: ws1 } = await connectWs(docId);\n  1186ŌåÆ+    const { ws: ws2 } = await connectWs(docId);\n  1187ŌåÆ+\n  1188ŌåÆ+    // ws2 listens for operations\n  1189ŌåÆ+    const opPromise = waitForMessage(ws2, 'operation');\n  1190ŌåÆ+\n  1191ŌåÆ+    // ws1 sends an insert operation\n  1192ŌåÆ+    const op: Operation = [\n  1193ŌåÆ+      { type: 'retain', count: 5 },\n  1194ŌåÆ+      { type: 'insert', text: ' world' },\n  1195ŌåÆ+    ];\n  1196ŌåÆ+    ws1.send(JSON.stringify({ type: 'operation', version: 1, operation: op }));\n  1197ŌåÆ+\n  1198ŌåÆ+    const received = await opPromise;\n  1199ŌåÆ+    expect(received.type).toBe('operation');\n  1200ŌåÆ+    expect(received.version).toBe(2);\n  1201ŌåÆ+\n  1202ŌåÆ+    ws1.close();\n  1203ŌåÆ+    ws2.close();\n  1204ŌåÆ+  });\n  1205ŌåÆ+\n  1206ŌåÆ+  it('should ack operations to sender', async () => {\n  1207ŌåÆ+    const created = await request(app.app)\n  1208ŌåÆ+      .post('/api/documents')\n  1209ŌåÆ+      .send({ title: 'Ack Test', content: 'abc' });\n  1210ŌåÆ+\n  1211ŌåÆ+    const { ws } = await connectWs(created.body.id);\n  1212ŌåÆ+\n  1213ŌåÆ+    const ackPromise = waitForMessage(ws, 'ack');\n  1214ŌåÆ+\n  1215ŌåÆ+    const op: Operation = [\n  1216ŌåÆ+      { type: 'retain', count: 3 },\n  1217ŌåÆ+      { type: 'insert', text: 'def' },\n  1218ŌåÆ+    ];\n  1219ŌåÆ+    ws.send(JSON.stringify({ type: 'operation', version: 1, operation: op }));\n  1220ŌåÆ+\n  1221ŌåÆ+    const ack = await ackPromise;\n  1222ŌåÆ+    expect(ack.type).toBe('ack');\n  1223ŌåÆ+    expect(ack.version).toBe(2);\n  1224ŌåÆ+\n  1225ŌåÆ+    ws.close();\n  1226ŌåÆ+  });\n  1227ŌåÆ+\n  1228ŌåÆ+  it('should persist changes via WebSocket to REST', async () => {\n  1229ŌåÆ+    const created = await request(app.app)\n  1230ŌåÆ+      .post('/api/documents')\n  1231ŌåÆ+      .send({ title: 'Persist', content: 'hello' });\n  1232ŌåÆ+\n  1233ŌåÆ+    const docId = created.body.id;\n  1234ŌåÆ+    const { ws } = await connectWs(docId);\n  1235ŌåÆ+\n  1236ŌåÆ+    const ackPromise = waitForMessage(ws, 'ack');\n  1237ŌåÆ+\n  1238ŌåÆ+    const op: Operation = [\n  1239ŌåÆ+      { type: 'retain', count: 5 },\n  1240ŌåÆ+      { type: 'insert', text: ' world' },\n  1241ŌåÆ+  