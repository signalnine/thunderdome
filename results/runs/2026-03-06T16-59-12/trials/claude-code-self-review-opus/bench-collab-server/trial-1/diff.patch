etain', count: 2 },\n   253ŌåÆ+    ];\n   254ŌåÆ+    const b: Operation = [\n   255ŌåÆ+      { type: 'retain', count: 2 },\n   256ŌåÆ+      { type: 'insert', text: 'Y' },\n   257ŌåÆ+      { type: 'retain', count: 1 },\n   258ŌåÆ+    ];\n   259ŌåÆ+\n   260ŌåÆ+    const [aPrime, bPrime] = transform(a, b);\n   261ŌåÆ+\n   262ŌåÆ+    const doc = 'abc';\n   263ŌåÆ+    const afterA = apply(doc, a);   // \"aXbc\"\n   264ŌåÆ+    const afterB = apply(doc, b);   // \"abYc\"\n   265ŌåÆ+\n   266ŌåÆ+    const afterAB = apply(afterA, bPrime); // Apply b' after a\n   267ŌåÆ+    const afterBA = apply(afterB, aPrime); // Apply a' after b\n   268ŌåÆ+\n   269ŌåÆ+    expect(afterAB).toBe(afterBA);\n   270ŌåÆ+    // Both insertions preserved\n   271ŌåÆ+    expect(afterAB).toContain('X');\n   272ŌåÆ+    expect(afterAB).toContain('Y');\n   273ŌåÆ+  });\n   274ŌåÆ+\n   275ŌåÆ+  it('should transform two inserts at same position', () => {\n   276ŌåÆ+    // Doc: \"abc\"\n   277ŌåÆ+    // Both insert at position 1\n   278ŌåÆ+    const a: Operation = [\n   279ŌåÆ+      { type: 'retain', count: 1 },\n   280ŌåÆ+      { type: 'insert', text: 'X' },\n   281ŌåÆ+      { type: 'retain', count: 2 },\n   282ŌåÆ+    ];\n   283ŌåÆ+    const b: Operation = [\n   284ŌåÆ+      { type: 'retain', count: 1 },\n   285ŌåÆ+      { type: 'insert', text: 'Y' },\n   286ŌåÆ+      { type: 'retain', count: 2 },\n   287ŌåÆ+    ];\n   288ŌåÆ+\n   289ŌåÆ+    const [aPrime, bPrime] = transform(a, b);\n   290ŌåÆ+\n   291ŌåÆ+    const doc = 'abc';\n   292ŌåÆ+    const afterAB = apply(apply(doc, a), bPrime);\n   293ŌåÆ+    const afterBA = apply(apply(doc, b), aPrime);\n   294ŌåÆ+\n   295ŌåÆ+    expect(afterAB).toBe(afterBA);\n   296ŌåÆ+    expect(afterAB).toContain('X');\n   297ŌåÆ+    expect(afterAB).toContain('Y');\n   298ŌåÆ+  });\n   299ŌåÆ+\n   300ŌåÆ+  it('should transform insert vs delete', () => {\n   301ŌåÆ+    // Doc: \"abcde\" (length 5)\n   302ŌåÆ+    // A inserts \"X\" at position 2\n   303ŌåÆ+    // B deletes 2 c