+function connectWs(docId: string): Promise<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(docId));
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'sync') {
+        resolve({ ws, sync: msg });
+      }
+    });
+    ws.on('error', reject);
+  });
