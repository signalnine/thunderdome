s: Map<string, ClientConnection>;\n}\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private documents: Map<string, DocumentState> = new Map();\n  private db: DocumentDB;\n\n  constructor(server: HttpServer, db: DocumentDB) {\n    this.db = db;\n    this.wss = new WebSocketServer({ noServer: true });\n\n    server.on('upgrade', (request, socket, head) => {\n      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);\n      const match = url.pathname.match(/^\\/documents\\/([^/]+)\\/ws$/);\n\n      if (!match) {\n        socket.destroy();\n        return;\n      }\n\n      const documentId = match[1];\n      const doc = this.db.getDocument(documentId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.handleConnection(ws, documentId);\n      });\n    });\n  }\n\n  private getOrCreateDocumentState(documentId: string): DocumentState {\n    let state = this.documents.get(documentId);\n    if (!state) {\n      const doc = this.db.getDocument(documentId);\n      if (!doc) throw new Error(`Document ${documentId} not found`);\n\n      const version = this.db.getLatestVersion(documentId);\n      // Load stored operations for transformation\n      const versions = this.db.getVersionHistory(documentId);\n      const operations: Operation[] = [];\n      for (const v of versions) {\n        if (v.operation) {\n          try {\n            const parsed = JSON.parse(v.operation);\n            if (Array.isArray(parsed)) {\n              operations.push(parsed);\n            }\n          } catch {\n            // Skip malformed operations\n          }\n        }\n      }\n\n      state = {\n        version,\n        content: doc.content,\n        operations,\n        clients: new Map(),\n      };\n      this.documents.set(documentId, state);\n    }\n    return state;\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const clientId = randomUUID();\n    const state = this.getOrCreateDocumentState(documentId);\n\n    const conn: ClientConnection = { ws, clientId, documentId };\n    state.clients.set(clientId, conn);\n\n    // Send sync message with current state\n    this.send(ws, {\n      type: 'sync',\n      content: state.content,\n      version: state.version,\n      clientId,\n    });\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString());\n        this.handleMessage(conn, message);\n      } catch (err) {\n        this.send(ws, {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        });\n      }\n    });\n\n    ws.on('close', () => {\n      state.clients.delete(clientId);\n      if (state.clients.size === 0) {\n        // Keep state in memory for quick reconnection, don't clean up immediately\n      }\n    });\n\n    ws.on('error', () => {\n      state.clients.delete(clientId);\n    });\n  }\n\n  private handleMessage(\n    conn: ClientConnection,\n    message: { type: string; version?: number; operation?: Operation },\n  ): void {\n    if (message.type !== 'operation') {\n      this.send(conn.ws, {\n        type: 'error',\n        message: `Unknown message type: ${message.type}`,\n      });\n      return;\n    }\n\n    const state = this.documents.get(conn.documentId);\n    if (!state) {\n      this.send(conn.ws, { type: 'error', message: 'Document not found' });\n      return;\n    }\n\n    if (typeof message.version !== 'number') {\n      this.send(conn.ws, { type: 'error', message: 'Version is required' });\n      return;\n    }\n\n    if (!Array.isArray(message.operation)) {\n      this.send(conn.ws, { type: 'error', message: 'Operation is required and must be an array' });\n      return;\n    }\n\n    const clientVersion = message.version;\n    let operation = message.operation;\n\n    // The client's operation was based on version clientVersion.\n    // We need to transform it against all operations from clientVersion to current version.\n    if (clientVersion < 0 || clientVersion > state.version) {\n      this.send(conn.ws, {\n        type: 'error',\n        message: `Invalid version ${clientVersion}. Current version is ${state.version}`,\n      });\n      return;\n    }\n\n    // Transform against concurrent operations\n    // state.operations[i] is the operation that took version (i) to version (i+1)\n    // We need to transform against operations from clientVersion to state.version\n    const startIdx = clientVersion;\n    for (let i = startIdx; i < state.operations.length; i++) {\n      const serverOp = state.operations[i];\n      try {\n        const [transformedClient] = transform(operation, serverOp);\n        operation = transformedClient;\n      } catch (err) {\n        this.send(conn.ws, {\n          type: 'error',\n          message: `Transform failed: ${err instanceof Error ? err.message : 'unknown error'}`,\n        });\n        return;\n      }\n    }\n\n    // Validate the transformed operation against current content\n    const validationError = validate(operation, state.content.length);\n    if (validationError) {\n      this.send(conn.ws, { type: 'error', message: validationError });\n      return;\n    }\n\n    // Apply the operation\n    let newContent: string;\n    try {\n      newContent = apply(state.content, operation);\n    } catch (err) {\n      this.send(conn.ws, {\n        type: 'error',\n        message: `Apply failed: ${err instanceof Error ? err.message : 'unknown error'}`,\n      });\n      return;\n    }\n\n    // Persist to database\n    const newVersion = this.db.updateDocumentContent(\n      conn.documentId,\n      newContent,\n      JSON.stringify(operation),\n    );\n\n    // Update in-memory state\n    state.operations.push(operation);\n    state.content = newContent;\n    state.version = newVersion;\n