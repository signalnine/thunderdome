es two concurrent operations\n   509ŌåÆ+ * and returns [a', b'] such that apply(apply(doc, a), b') === apply(apply(doc, b), a').\n   510ŌåÆ+ */\n   511ŌåÆ+\n   512ŌåÆ+export type OpComponent =\n   513ŌåÆ+  | { type: 'retain'; count: number }\n   514ŌåÆ+  | { type: 'insert'; text: string }\n   515ŌåÆ+  | { type: 'delete'; count: number };\n   516ŌåÆ+\n   517ŌåÆ+export type Operation = OpComponent[];\n   518ŌåÆ+\n   519ŌåÆ+/** Apply an operation to a document string. */\n   520ŌåÆ+export function apply(doc: string, op: Operation): string {\n   521ŌåÆ+  let result = '';\n   522ŌåÆ+  let pos = 0;\n   523ŌåÆ+\n   524ŌåÆ+  for (const comp of op) {\n   525ŌåÆ+    switch (comp.type) {\n   526ŌåÆ+      case 'retain':\n   527ŌåÆ+        if (pos + comp.count > doc.length) {\n   528ŌåÆ+          throw new Error(\n   529ŌåÆ+            `Retain count ${comp.count} exceeds remaining document length (pos=${pos}, docLen=${doc.length})`,\n   530ŌåÆ+          );\n   531ŌåÆ+        }\n   532ŌåÆ+        result += doc.slice(pos, pos + comp.count);\n   533ŌåÆ+        pos += comp.count;\n   534ŌåÆ+        break;\n   535ŌåÆ+      case 'insert':\n   536ŌåÆ+        result += comp.text;\n   537ŌåÆ+        break;\n   538ŌåÆ+      case 'delete':\n   539ŌåÆ+        if (pos + comp.count > doc.length) {\n   540ŌåÆ+          throw new Error(\n   541ŌåÆ+            `Delete count ${comp.count} exceeds remaining document length (pos=${pos}, docLen=${doc.length})`,\n   542ŌåÆ+          );\n   543ŌåÆ+        }\n   544ŌåÆ+        pos += comp.count;\n   545ŌåÆ+        break;\n   546ŌåÆ+    }\n   547ŌåÆ+  }\n   548ŌåÆ+\n   549ŌåÆ+  // Append any remaining text (if op didn't cover the whole doc, that's an error)\n   550ŌåÆ+  if (pos < doc.length) {\n   551ŌåÆ+    throw new Error(\n   552ŌåÆ+      `Operation did not consume entire document (pos=${pos}, docLen=${doc.length})`,\n   553ŌåÆ+    );\n   554ŌåÆ+  }\n   555ŌåÆ+\n   556ŌåÆ+  return result;\n   557ŌåÆ+}\n   558ŌåÆ+\n   559ŌåÆ+/** Get the input length an operation expects. */\n   560ŌåÆ+export function inputLength(op: Operation): number {\n   561ŌåÆ+  let len = 0;\n   562ŌåÆ+  for (const comp of op) {\n   563ŌåÆ+    if (comp.type === 'retain') len += comp.count;\n   564ŌåÆ+    else if (comp.type === 'delete') len += comp.count;\n   565ŌåÆ+  }\n   566ŌåÆ+  return len;\n   567ŌåÆ+}\n   568ŌåÆ+\n   569ŌåÆ+/** Get the output length after applying an operation. */\n   570ŌåÆ+export function outputLength(op: Operation): number {\n   571ŌåÆ+  let len = 0;\n   572ŌåÆ+  for (const comp of op) {\n   573ŌåÆ+    if (comp.type === 'retain') len += comp.count;\n   574ŌåÆ+    else if (comp.type === 'insert') len += comp.text.length;\n   575ŌåÆ+  }\n   576ŌåÆ+  return len;\n   577ŌåÆ+}\n   578ŌåÆ+\n   579ŌåÆ+/**\n   580ŌåÆ+ * Transform two concurrent operations a and b (both based on the same document state)\n   581ŌåÆ+ * into a' and b' such that:\n   582ŌåÆ+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')\n   583ŌåÆ+ *\n   584ŌåÆ+ * Returns [a', b'] where:\n   585ŌåÆ+ * - a' can be applied after b\n   586ŌåÆ+ * - b' can be applied after a\n   587ŌåÆ+ */\n   588ŌåÆ+export function transform(\n   589ŌåÆ+  a: Operation,\n   590ŌåÆ+  b: Operation,\n   591ŌåÆ+): [Operation, Operation] {\n   592ŌåÆ+  const aPrime: Operation = [];\n   593ŌåÆ+  const bPrime: Operation = [];\n   594ŌåÆ+\n   595ŌåÆ+  let ia = 0;\n   596ŌåÆ+  let ib = 0;\n   597ŌåÆ+\n   598ŌåÆ+  // We walk through both operations simultaneously using iterators\n   599ŌåÆ+  // that can partially consume components.\n   600ŌåÆ+  let aComp: OpComponent | null = a[ia] ?? null;\n   601ŌåÆ+  let bComp: OpComponent | null = b[ib] ?? null;\n   602ŌåÆ+\n   603ŌåÆ+  const nextA = (): void => {\n   604ŌåÆ+    ia++;\n   605ŌåÆ+    aComp = a[ia] ?? null;\n   606ŌåÆ+  };\n   607ŌåÆ+  const nextB = (): void => {\n   608ŌåÆ+    ib++;\n   609ŌåÆ+    bComp = b[ib] ?? null;\n   610ŌåÆ+  };\n   611ŌåÆ+\n   612ŌåÆ+  while (aComp !== null || bComp !== null) {\n   613ŌåÆ+    // If a is