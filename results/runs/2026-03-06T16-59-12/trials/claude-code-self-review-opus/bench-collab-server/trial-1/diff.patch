+/**
+ * Operational Transformation (OT) engine for collaborative text editing.
+ *
+ * Operations are sequences of components that describe edits:
+ * - retain(n): skip n characters
+ * - insert(s): insert string s at current position
+ * - delete(n): delete n characters at current position
+ *
+ * The key function is `transform(a, b)` which takes two concurrent operations
+ * and returns [a', b'] such that apply(apply(doc, a), b') === apply(apply(doc, b), a').
+ */
+
+export type OpComponent =
+  | { type: 'retain'; count: number }
+  | { type: 'insert'; text: string }
+  | { type: 'delete'; count: number };
+
+export type Operation = OpComponent[];
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, op: Operation): string {
+  let result = '';
+  let pos = 0;
+
+  for (const comp of op) {
+    switch (comp.type) {
+      case 'retain':
+        if (pos + comp.count > doc.length) {
+          throw new Error(
+            `Retain count ${comp.count} exceeds remaining document length (pos=${pos}, docLen=${doc.length})`,
+          );
+        }
+        result += doc.slice(pos, pos + comp.count);
+        pos += comp.count;
+        break;
+      case 'insert':
+        result += comp.text;
+        break;
+      case 'delete':
+        if (pos + comp.count > doc.length) {
+          throw new Error(
+            `Delete count ${comp.count} exceeds remaining document length (pos=${pos}, docLen=${doc.length})`,
+          );
+        }
+        pos += comp.count;
+        break;
+    }
+  }
+
+  // Append any remaining text (if op didn't cover the whole doc, that's an error)
+  if (pos < doc.length) {
+    throw new Error(
+      `Operation did not consume entire document (pos=${pos}, docLen=${doc.length})`,
+    );
+  }
+
+  return result;
+}
+
+/** Get the input length an operation expects. */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const comp of op) {
+    if (comp.type === 'retain') len += comp.count;
+    else if (comp.type === 'delete') len += comp.count;
+  }
+  return len;
+}
+
+/** Get the output length after applying an operation. */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const comp of op) {
+    if (comp.type === 'retain') len += comp.count;
+    else if (comp.type === 'insert') len += comp.text.length;
+  }
+  return len;
+}
+
+/**
+ * Transform two concurrent operations a and b (both based on the same document state)
+ * into a' and b' such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Returns [a', b'] where:
+ * - a' can be applied after b
+ * - b' can be applied after a
+ */
+export function transform(
+  a: Operation,
+  b: Operation,
+): [Operation, Operation] {
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  let ia = 0;
+  let ib = 0;
+
+  // We walk through both operations simultaneously using iterators
+  // that can partially consume components.
+  let aComp: OpComponent | null = a[ia] ?? null;
+  let bComp: OpComponent | null = b[ib] ?? null;
+
+  const nextA = (): void => {
+    ia++;
+    aComp = a[ia] ?? null;
+  };
+  const nextB = (): void => {
+    ib++;
+    bComp = b[ib] ?? null;
+  };
+
+  while (aComp !== null || bComp !== null) {
+    // If a is an insert, it goes into a' and b' gets a retain over it
+    if (aComp !== null && aComp.type === 'insert') {
+      aPrime.push({ type: 'insert', text: aComp.text });
+      bPrime.push({ type: 'retain', count: aComp.text.length });
+      nextA();
+      continue;
+    }
+
+    // If b is an insert, it goes into b' and a' gets a retain over it
+    if (bComp !== null && bComp.type === 'insert') {
+      bPrime.push({ type: 'insert', text: bComp.text });
+      aPrime.push({ type: 'retain', count: bComp.text.length });
+      nextB();
+      continue;
+    }
+
+    // Both must be non-null at this point for retain/delete pairs
+    if (aComp === null || bComp === null) {
+      throw new Error('Operations have different base lengths');
+    }
+
+    if (aComp.type === 'retain' && bComp.type === 'retain') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      aPrime.push({ type: 'retain', count: minLen });
+      bPrime.push({ type: 'retain', count: minLen });
+
+      if (aComp.count === bComp.count) {
+        nextA();
+        nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'retain', count: bComp.count - aComp.count };
+        nextA();
+      } else {
+        aComp = { type: 'retain', count: aComp.count - bComp.count };
+        nextB();
+      }
+    } else if (aComp.type === 'delete' && bComp.type === 'delete') {
+      // Both delete the same text, so neither needs to in the transformed version
+      if (aComp.count === bComp.count) {
+        nextA();
+        nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'delete', count: bComp.count - aComp.count };
+        nextA();
+      } else {
+        aComp = { type: 'delete', count: aComp.count - bComp.count };
+        nextB();
+      }
+    } else if (aComp.type === 'delete' && bComp.type === 'retain') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      aPrime.push({ type: 'delete', count: minLen });
+      // b doesn't need to retain what a deleted
+
+      if (aComp.count === bComp.count) {
+        nextA();
+        nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'retain', count: bComp.count - aComp.count };
+        nextA();
+      } else {
+        aComp = { type: 'delete', count: aComp.count - bComp.count };
+        nextB();
+      }
+    } else if (aComp.type === 'retain' && bComp.type === 'delete') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      bPrime.push({ type: 'delete', count: minLen });
+      // a doesn't need to retain what b deleted
+
+      if (aComp.count === bComp.count) {
+        nextA();
+        nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'delete', count: bComp.count - aComp.count };
+        nextA();
+      } else {
+        aComp = { type: 'retain', count: aComp.count - bComp.count };
+        nextB();
+      }
+    } else {
+      throw new Error(
+        `Unexpected component combination: ${aComp.type} / ${bComp.type}`,
+      );
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/** Compose two sequential operations into a single operation. */
+export function compose(a: Operation, b: Operation): Operation {
+  const result: Operation = [];
+
+  let ia = 0;
+  let ib = 0;
+  let aComp: OpComponent | null = a[ia] ?? null;
+  let bComp: OpComponent | null = b[ib] ?? null;
+
+  const nextA = (): void => {
+    ia++;
+    aComp = a[ia] ?? null;
+  };
+  const nextB = (): void => {
+    ib++;
+    bComp = b[ib] ?? null;
+  };
+
+  while (aComp !== null || bComp !== null) {
+    if (aComp !== null && aComp.type === 'delete') {
+      result.push(aComp);
+      nextA();
+      continue;
+    }
+
+    if (bComp !== null && bComp.type === 'insert') {
+      result.push(bComp);
+      nextB();
+      continue;
+    }
+
+    if (aComp === null || bComp === null) {
+      throw new Error('Compose: operations have incompatible lengths');
+    }
+
+    if (aComp.type === 'retain' && bComp.type === 'retain') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      result.push({ type: 'retain', count: minLen });
+      if (aComp.count === bComp.count) {
+        nextA();
+        nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'retain', count: bComp.count - aComp.count };
+        nextA();
+      } else {
+        aComp = { type: 'retain', count: aComp.count - bComp.count };
+        nextB();
+      }
+    } else if (aComp.type === 'insert' && bComp.type === 'retain') {
+      const minLen = Math.min(aComp.text.length, bComp.count);
+      result.push({ type: 'insert', text: aComp.text.slice(0, minLen) });
+      if (aComp.text.length === bComp.count) {
+        nextA();
+        nextB();
+      } else if (aComp.text.length < bComp.count) {
+        bComp = { type: 'retain', count: bComp.count - aComp.text.length };
+        nextA();
+      } else {
+        aComp = { type: 'insert', text: aComp.text.slice(minLen) };
+        nextB();
+      }
+    } else if (aComp.type === 'insert' && bComp.type === 'delete') {
+      const minLen = Math.min(aComp.text.length, bComp.count);
+      // Insert followed by delete cancels out
+      if (aComp.text.length === bComp.count) {
+        nextA();
+        nextB();
+      } else if (aComp.text.length < bComp.count) {
+        bComp = { type: 'delete', count: bComp.count - aComp.text.length };
+        nextA();
+      } else {
+        aComp = { type: 'insert', text: aComp.text.slice(minLen) };
+        nextB();
+      }
+    } else if (aComp.type === 'retain' && bComp.type === 'delete') {
+      const minLen = Math.min(aComp.count, bComp.count);
+      result.push({ type: 'delete', count: minLen });
+      if (aComp.count === bComp.count) {
+        nextA();
+        nextB();
+      } else if (aComp.count < bComp.count) {
+        bComp = { type: 'delete', count: bComp.count - aComp.count };
+        nextA();
+      } else {
+        aComp = { type: 'retain', count: aComp.count - bComp.count };
+        nextB();
+      }
+    } else {
+      throw new Error(
+        `Compose: unexpected combination: ${aComp.type} / ${bComp.type}`,
+      );
+    }
+  }
+
+  return normalize(result);
+}
+
+/** Normalize an operation by merging adjacent same-type components and removing no-ops. */
+export function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const comp of op) {
+    if (comp.type === 'retain' && comp.count === 0) continue;
+    if (comp.type === 'delete' && comp.count === 0) continue;
+    if (comp.type === 'insert' && comp.text === '') continue;
+
+    const last = result[result.length - 1];
+    if (last && last.type === comp.type) {
+      if (last.type === 'retain' && comp.type === 'retain') {
+        result[result.length - 1] = {
+          type: 'retain',
+          count: last.count + comp.count,
+        };
+      } else if (last.type === 'delete' && comp.type === 'delete') {
+        result[result.length - 1] = {
+          type: 'delete',
+          count: last.count + comp.count,
+        };
+      } else if (last.type === 'insert' && comp.type === 'insert') {
+        result[result.length - 1] = {
+          type: 'insert',
+          text: last.text + comp.text,
+        };
+      }
+    } else {
+      result.push(comp);
+    }
+  }
+  return result;
+}
+
+/**
+ * Helper: create an insert-at-position operation for a document of given length.
+ */
+export function insertAt(
+  docLength: number,
+  position: number,
+  text: string,
+): Operation {
+  const op: Operation = [];
+  if (position > 0) op.push({ type: 'retain', count: position });
+  op.push({ type: 'insert', text });
+  if (position < docLength)
+    op.push({ type: 'retain', count: docLength - position });
+  return op;
+}
+
+/**
+ * Helper: create a delete-at-position operation for a document of given length.
+ */
+export function deleteAt(
+  docLength: number,
+  position: number,
+  count: number,
+): Operation {
+  const op: Operation = [];
+  if (position > 0) op.push({ type: 'retain', count: position });
+  op.push({ type: 'delete', count });
+  const remaining = docLength - position - count;
+  if (remaining > 0) op.push({ type: 'retain', count: remaining });
+  return op;
+}
+
+/** Validate an operation against a document of given length. */
+export function validate(op: Operation, docLength: number): string | null {
+  let consumed = 0;
+  for (let i = 0; i < op.length; i++) {
+    const comp = op[i];
+    if (comp.type === 'retain') {
+      if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {
+        return `Invalid retain count at index ${i}`;
+      }
+      consumed += comp.count;
+    } else if (comp.type === 'delete') {
+      if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {
+        return `Invalid delete count at index ${i}`;
+      }
+      consumed += comp.count;
+    } else if (comp.type === 'insert') {
+      if (typeof comp.text !== 'string') {
+        return `Invalid insert text at index ${i}`;
+      }
+    } else {
+      return `Unknown component type at index ${i}`;
+    }
+  }
+  if (consumed !== docLength) {
+    return `Operation base length ${consumed} does not match document length ${docLength}`;
+  }
+  return null;
+}
