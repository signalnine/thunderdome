/** Compose two sequential operations into a single operation. */\n   702ŌåÆ+export function compose(a: Operation, b: Operation): Operation {\n   703ŌåÆ+  const result: Operation = [];\n   704ŌåÆ+\n   705ŌåÆ+  let ia = 0;\n   706ŌåÆ+  let ib = 0;\n   707ŌåÆ+  let aComp: OpComponent | null = a[ia] ?? null;\n   708ŌåÆ+  let bComp: OpComponent | null = b[ib] ?? null;\n   709ŌåÆ+\n   710ŌåÆ+  const nextA = (): void => {\n   711ŌåÆ+    ia++;\n   712ŌåÆ+    aComp = a[ia] ?? null;\n   713ŌåÆ+  };\n   714ŌåÆ+  const nextB = (): void => {\n   715ŌåÆ+    ib++;\n   716ŌåÆ+    bComp = b[ib] ?? null;\n   717ŌåÆ+  };\n   718ŌåÆ+\n   719ŌåÆ+  while (aComp !== null || bComp !== null) {\n   720ŌåÆ+    if (aComp !== null && aComp.type === 'delete') {\n   721ŌåÆ+      result.push(aComp);\n   722ŌåÆ+      nextA();\n   723ŌåÆ+      continue;\n   724ŌåÆ+    }\n   725ŌåÆ+\n   726ŌåÆ+    if (bComp !== null && bComp.type === 'insert') {\n   727ŌåÆ+      result.push(bComp);\n   728ŌåÆ+      nextB();\n   729ŌåÆ+      continue;\n   730ŌåÆ+    }\n   731ŌåÆ+\n   732ŌåÆ+    if (aComp === null || bComp === null) {\n   733ŌåÆ+      throw new Error('Compose: operations have incompatible lengths');\n   734ŌåÆ+    }\n   735ŌåÆ+\n   736ŌåÆ+    if (aComp.type === 'retain' && bComp.type === 'retain') {\n   737ŌåÆ+      const minLen = Math.min(aComp.count, bComp.count);\n   738ŌåÆ+      result.push({ type: 'retain', count: minLen });\n   739ŌåÆ+      if (aComp.count === bComp.count) {\n   740ŌåÆ+        nextA();\n   741ŌåÆ+        nextB();\n   742ŌåÆ+      } else if (aComp.count < bComp.count) {\n   743ŌåÆ+        bComp = { type: 'retain', count: bComp.count - aComp.count };\n   744ŌåÆ+        nextA();\n   745ŌåÆ+      } else {\n   746ŌåÆ+        aComp = { type: 'retain', count: aComp.count - bComp.count };\n   747ŌåÆ+        nextB();\n   748ŌåÆ+      }\n   749ŌåÆ+    } else if (aComp.type === 'insert' && bComp.type === 'retain') {\n   750ŌåÆ+      const minLen = Math.min(aComp.text.length, bComp.count);\n   751ŌåÆ+      result.push({ type: 'insert', text: aComp.text.slice(0, minLen) });\n   752ŌåÆ+      if (aComp.text.length === bComp.count) {\n   753ŌåÆ+        nextA();\n   754ŌåÆ+        nextB();\n   755ŌåÆ+      } else if (aComp.text.length < bComp.count) {\n   756ŌåÆ+        bComp = { type: 'retain', count: bComp.count - aComp.text.length };\n   757ŌåÆ+        nextA();\n   758ŌåÆ+      } else {\n   759ŌåÆ+        aComp = { type: 'insert', text: aComp.text.slice(minLen) };\n   760ŌåÆ+        nextB();\n   761ŌåÆ+      }\n   762ŌåÆ+    } else if (aComp.type === 'insert' && bComp.type === 'delete') {\n   763ŌåÆ+      const minLen = Math.min(aComp.text.length, bComp.count);\n   764ŌåÆ+      // Insert followed by delete cancels out\n   765ŌåÆ+      if (aComp.text.length === bComp.count) {\n   766ŌåÆ+        nextA();\n   767ŌåÆ+        nextB();\n   768ŌåÆ+      } else if (aComp.text.length < bComp.count) {\n   769ŌåÆ+        bComp = { type: 'delete', count: bComp.count - aComp.text.length };\n   770ŌåÆ+        nextA();\n   771ŌåÆ+      } else {\n   772ŌåÆ+        aComp = { type: 'insert', text: aComp.text.slice(minLen) };\n   773ŌåÆ+        nextB();\n   774ŌåÆ+      }\n   775ŌåÆ+    } else if (aComp.type === 'retain' && bComp.type === 'delete') {\n   776ŌåÆ+      const minLen = Math.min(aComp.count, bComp.count);\n   777ŌåÆ+      result.push({ type: 'delete', count: minLen });\n   778ŌåÆ+      if (aComp.count === bComp.count) {\n   779ŌåÆ+        nextA();\n   780ŌåÆ+        nextB();\n   781ŌåÆ+      } else if (aComp.count < bComp.count) {\n   782ŌåÆ+        bComp = { type: 'delete', count: bComp.count - aComp.count };\n   783ŌåÆ+        nextA();\n   784ŌåÆ+      } else {\n   785ŌåÆ+        aComp = { type: 'retain', count: aComp.count - bComp.count };\n   786ŌåÆ+        nextB();\n   787ŌåÆ+      }\n   788ŌåÆ+    } else {\n   789ŌåÆ+      throw new Error(\n   790ŌåÆ+        `Compose: unexpected combination: ${aComp.type} / ${bComp.type}`,\n   791ŌåÆ+      );\n   792ŌåÆ+    }\n   793ŌåÆ+  }\n   794ŌåÆ+\n   795ŌåÆ+  return normalize(result);\n   796ŌåÆ+}\n   797ŌåÆ+\n   798ŌåÆ+/** Normalize an operation by merging adjacent same-type components and removing no-ops. */\n   799ŌåÆ+export function normalize(op: Operation): Operation {\n   800ŌåÆ+  const result: Operation = [];\n   801ŌåÆ+  for (const comp of op) {\n   802ŌåÆ+    if (comp.type === 'retain' && comp.count === 0) continue;\n   803ŌåÆ+    if (comp.type === 'delete' && comp.count === 0) continue;\n   804ŌåÆ+    if (comp.type === 'insert' && comp.text === '') continue;\n   805ŌåÆ+\n   806ŌåÆ+    const last = result[result.length - 1];\n   807ŌåÆ+    if (last && last.type === comp.type) {\n   808ŌåÆ+      if (last.type === 'retain' && comp.type === 'retain') {\n   809ŌåÆ+        result[result.length - 1] = {\n   810ŌåÆ+          type: 'retain',\n   811ŌåÆ+          count: last.count + comp.count,\n   812ŌåÆ+        };\n   813ŌåÆ+      } else if (last.type === 'delete' && comp.type === 'delete') {\n   814ŌåÆ+        result[result.length - 1] = {\n   815ŌåÆ+          type: 'delete',\n   816ŌåÆ+          count: last.count + comp.count,\n   817ŌåÆ+        };\n   818ŌåÆ+      } else if (last.type === 'insert' && comp.type === 'insert') {\n   819ŌåÆ+        result[result.length - 1] = {\n   820ŌåÆ+          type: 'insert',\n   821ŌåÆ+          text: last.text + comp.text,\n   822ŌåÆ+        };\n   823ŌåÆ+      }\n   824ŌåÆ+    } else {\n   825ŌåÆ+      result.push(comp);\n   826ŌåÆ+    }\n   827ŌåÆ+  }\n   828ŌåÆ+  return result;\n   829ŌåÆ+}\n   830ŌåÆ+\n   831ŌåÆ+/**\n   832ŌåÆ+ * Helper: create an insert-at-position operation for a document of given length.\n   833ŌåÆ+ */\n   834ŌåÆ+export function insertAt(\n   835ŌåÆ+  docLength: number,\n   836ŌåÆ+  position: number,\n   837ŌåÆ+  text: string,\n   838ŌåÆ+): Operation {\n   839ŌåÆ+  const op: Operation = [];\n   840ŌåÆ+  if (position > 0) op.push({ type: 'retain', count: position });\n   841ŌåÆ+  op.push({ type: 'insert', text });\n   842ŌåÆ+  if (position < docLength)\n   843ŌåÆ+    op.push({ type: 'retain', count: docLength - position });\n   844ŌåÆ+  return op;\n   845ŌåÆ+}\n   846ŌåÆ+\n   847ŌåÆ+/**\n   848ŌåÆ+ * Helper: create a delete-at-position operation for a document of given length.\n   849ŌåÆ+ */\n   850ŌåÆ+export function deleteAt(\n   851ŌåÆ+  docLength: number,\n   852ŌåÆ+  position: number,\n   853ŌåÆ+  count: number,\n   854ŌåÆ+): Operation {\n   855ŌåÆ+  const op: Operation = [];\n   856ŌåÆ+  if (position > 0) op.push({ type: 'retain', count: position });\n   857ŌåÆ+  op.push({ type: 'delete', count });\n   858ŌåÆ+  const remaining = docLength - position - count;\n   859ŌåÆ+  if (remaining > 0) op.push({ type: 'retain', count: remaining });\n   860ŌåÆ+  return op;\n   861ŌåÆ+}\n   862ŌåÆ+\n   863ŌåÆ+/** Validate an operation against a document of given length. */\n   864ŌåÆ+export function validate(op: Operation, docLength: number): string | null {\n   865ŌåÆ+  let consumed = 0;\n   866ŌåÆ+  for (let i = 0; i < op.length; i++) {\n   867ŌåÆ+    const comp = op[i];\n   868ŌåÆ+    if (comp.type === 'retain') {\n   869ŌåÆ+      if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {\n   870ŌåÆ+        return `Invalid retain count at index ${i}`;\n   871ŌåÆ+      }\n   872ŌåÆ+      consumed += comp.count;\n   873ŌåÆ+    } else if (comp.type === 'delete') {\n   874ŌåÆ+      if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) {\n   875ŌåÆ+        return `Invalid delete count at index ${i}`;\n   876ŌåÆ+      }\n   877ŌåÆ+      consumed += comp.count;\n   878ŌåÆ+    } else if (comp.type === 'insert') {\n   879ŌåÆ+      if (typeof comp.text !== 'string') {\n   880ŌåÆ+        return `Invalid insert text at index ${i}`;\n   881ŌåÆ+      }\n   882ŌåÆ+    } else {\n   883ŌåÆ+      return `Unknown component type at index ${i}`;\n   884ŌåÆ+    }\n   885ŌåÆ+  }\n   886ŌåÆ+  if (consumed !== docLength) {\n   887ŌåÆ+    return `Operation base length ${consumed} does not match document length ${docLength}`;\n   888ŌåÆ+  }\n   889ŌåÆ+  return null;\n   890ŌåÆ+}\n   891ŌåÆdiff --git a/src/routes.ts b/src/routes.ts\n   892ŌåÆnew file mode 100644\n   893ŌåÆindex 0000000..2fcecd9\n   894ŌåÆ--- /dev/null\n   895ŌåÆ+++ b/src/routes.ts\n   896ŌåÆ@@ -0,0 +1,104 @@\n   897ŌåÆ+import { Router, json } from 'express';\n   898ŌåÆ+import type { DocumentDB } from './db.js';\n   899ŌåÆ+\n   900ŌåÆ+export function createRouter(db: DocumentDB): Router {\n   901ŌåÆ+  const router = Router();\n   902ŌåÆ+  router.use(json());\n   903ŌåÆ+\n   904ŌåÆ+  // Create a document\n   905ŌåÆ+  router.post('/documents', (req, res) => {\n   906ŌåÆ+    const { title, content } = req.body;\n   907ŌåÆ+    if (!title || typeof title !== 'string') {\n   908ŌåÆ+      res.status(400).json({ error: 'Title is required and must be a string' });\n   909ŌåÆ+      return;\n   910ŌåÆ+    }\n   911ŌåÆ+    const doc = db.createDocument(title, typeof content === 'string' ? content : '');\n   912ŌåÆ+    res.status(201).json(doc);\n   913ŌåÆ+  });\n   914ŌåÆ+\n   915ŌåÆ+  // List all documents\n   916ŌåÆ+  router.get('/documents', (_req, res) => {\n   917ŌåÆ+    const docs = db.listDocuments();\n   918ŌåÆ+    res.json(docs);\n   919ŌåÆ+  });\n   920ŌåÆ+\n   921ŌåÆ+  // Get a single document\n   922ŌåÆ+  router.get('/documents/:id', (req, res) => {\n   923ŌåÆ+    const doc = db.getDocument(req.params.id);\n   924ŌåÆ+    if (!doc) {\n   925ŌåÆ+      res.status(404).json({ error: 'Document not found' });\n   926ŌåÆ+      return;\n   927ŌåÆ+    }\n   928ŌåÆ+    res.json(doc);\n   929ŌåÆ+  });\n   930ŌåÆ+\n   931ŌåÆ+  // Update a document (title and/or content)\n   932ŌåÆ+  router.put('/documents/:id', (req, res) => {\n   933ŌåÆ+    const { title, content } = req.body;\n   934ŌåÆ+    const updates: { title?: string; content?: string } = {};\n   935ŌåÆ+    if (title !== undefined) {\n   936ŌåÆ+      if (typeof title !== 'string') {\n   937ŌåÆ+        res.status(400).json({ error: 'Title must be a string' });\n   938ŌåÆ+        return;\n   939ŌåÆ+      }\n   940ŌåÆ+      updates.title = title;\n   941ŌåÆ+    }\n   942ŌåÆ+    if (content !== undefined) {\n   943ŌåÆ+      if (typeof content !== 'string') {\n   944ŌåÆ+        res.status(400).json({ error: 'Content must be a string' });\n   945ŌåÆ+        return;\n   946ŌåÆ+      }\n   947ŌåÆ+      updates.content = content;\n   948ŌåÆ+    }\n   949ŌåÆ+\n   950ŌåÆ+    const doc = db.updateDocument(req.params.id, updates);\n   951ŌåÆ+    if (!doc) {\n   952ŌåÆ+      res.status(404).json({ error: 'Document not found' });\n   953ŌåÆ+      return;\n   954ŌåÆ+    }\n   955ŌåÆ+    res.json(doc);\n   956ŌåÆ+  });\n   957ŌåÆ+\n   958ŌåÆ+  // Delete a document\n   959ŌåÆ+  router.delete('/documents/:id', (req, res) => {\n   960ŌåÆ+    const deleted = db.deleteDocument(req.params.id);\n   961ŌåÆ+    if (!deleted) {\n   962ŌåÆ+      res.status(404).json({ error: 'Document not found' });\n   963ŌåÆ+      return;\n   964ŌåÆ+    }\n   965ŌåÆ+    res.status(204).send();\n   966ŌåÆ+  });\n   967ŌåÆ+\n   968ŌåÆ+  // Get version history for a document\n   969ŌåÆ+  router.get('/documents/:id/versions', (req, res) => {\n   970ŌåÆ+    const doc = db.getDocument(req.params.id);\n   971ŌåÆ+    if (!doc) {\n   972ŌåÆ+      res.status(404).json({ error: 'Document not found' });\n   973ŌåÆ+      return;\n   974ŌåÆ+    }\n   975ŌåÆ+    const versions = db.getVersionHistory(req.params.id);\n   976ŌåÆ+    res.json(versions);\n   977ŌåÆ+  });\n   978ŌåÆ+\n   979ŌåÆ+  // Get a specific version\n   980ŌåÆ+  router.get('/documents/:id/versions/:version', (req, res) => {\n   981ŌåÆ+    const doc = db.getDocument(req.params.id);\n   982ŌåÆ+    if (!doc) {\n   983ŌåÆ+      res.status(404).json({ error: 'Document not found' });\n   984ŌåÆ+      return;\n   985ŌåÆ+    }\n   986ŌåÆ+    const versionNum = parseInt(req.params.version, 10);\n   987ŌåÆ+    if (isNaN(versionNum)) {\n   988ŌåÆ+      res.status(400).json({ error: 'Version must be a number' });\n   989ŌåÆ+      return;\n   990ŌåÆ+    }\n   991ŌåÆ+    const version = db.getVersion(req.params.id, versionNum);\n   992ŌåÆ+    if (!version) {\n   993ŌåÆ+      res.status(404).json({ error: 'Version not found' });\n   994ŌåÆ+      return;\n   995ŌåÆ+    }\n   996ŌåÆ+    res.json(version);\n   997ŌåÆ+  });\n   998ŌåÆ+\n   999ŌåÆ+  return router;\n  1000ŌåÆ+}\n  1001ŌåÆdiff --git a/src/server.test.ts b/src/server.test.ts\n  1002ŌåÆnew file mode 100644\n  1003ŌåÆindex 0000000..24c9c7b\n  1004ŌåÆ--- /dev/null\n  1005ŌåÆ+++ b/src/server.test.ts\n  1006ŌåÆ@@ -0,0 +1,415 @@\n  1007ŌåÆ+import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n  1008ŌåÆ+import request from 'supertest';\n  1009ŌåÆ+import { WebSocket } from 'ws';\n  1010ŌåÆ+import { createApp, type AppInstance } from './server.js';\n  1011ŌåÆ+import type { Operation } from './ot.js';\n  1012ŌåÆ+\n  1013ŌåÆ+let app: AppInstance;\n  1014ŌåÆ+let port: number;\n  1015ŌåÆ+\n  1016ŌåÆ+beforeEach(async () => {\n  1017ŌåÆ+  app = createApp(); // in-memory DB\n  1018ŌåÆ+  port = await app.start(0);\n  1019ŌåÆ+});\n  1020ŌåÆ+\n  1021ŌåÆ+afterEach(async () => {\n  1022ŌåÆ+  await app.stop();\n  1023ŌåÆ+});\n  1024ŌåÆ+\n  1025ŌåÆ+function wsUrl(docId: string): string {\n  1026ŌåÆ+  return `ws://localhost:${port}/documents/${docId}/ws`;\n  1027ŌåÆ+}\n  1028ŌåÆ+\n  1029ŌåÆ+function connectWs(docId: string): Promise<{ ws: WebSocket; sync: { content: string; version: number; clientId: string } }> {\n  1030ŌåÆ+  return new Promise((resolve, reject) => {\n  1031ŌåÆ+    const ws = new WebSocket(wsUrl(docId));\n  1032ŌåÆ+    ws.on('message', (data) => {\n  1033ŌåÆ+      const msg = JSON.parse(data.toString());\n  1034ŌåÆ+      if (msg.type === 'sync') {\n  1035ŌåÆ+        resolve({ ws, sync: msg });\n  1036ŌåÆ+      }\n  1037ŌåÆ+    });\n  1038ŌåÆ+    ws.on('error', reject);\n  1039ŌåÆ+  });\n  1040ŌåÆ+}\n  1041ŌåÆ+\n  1042ŌåÆ+function waitForMessage(ws: WebSocket, type?: string): Promise<Record<string, unknown>> {\n  1043ŌåÆ+  return new Promise((resolve) => {\n  1044ŌåÆ+    const handler = (data: Buffer | string) => {\n  1045ŌåÆ+      const msg = JSON.parse(data.toString());\n  1046ŌåÆ+      if (!type || msg.type === type) {\n  1047ŌåÆ+        ws.removeListener('message', handler);\n  1048ŌåÆ+        resolve(msg);\n  1049ŌåÆ+      }\n  1050ŌåÆ+    };\n  1051ŌåÆ+    ws.on('message', handler);\n  1052ŌåÆ+  });\n  1053ŌåÆ+}\n  1054ŌåÆ+\n  1055ŌåÆ+describe('REST API', () => {\n  1056ŌåÆ+  it('should create a document', async () => {\n  1057ŌåÆ+    const res = await request(app.app)\n  1058ŌåÆ+      .post('/api/documents')\n  1059ŌåÆ+      .send({ title: 'Test Doc', content: 'Hello' })\n  1060ŌåÆ+      .expect(201);\n  1061ŌåÆ+\n  1062ŌåÆ+    expect(res.body.title).toBe('Test Doc');\n  1063ŌåÆ+    expect(res.body.content).toBe('Hello');\n  1064ŌåÆ+    expect(res.body.id).toBeDefined();\n  1065ŌåÆ+  });\n  1066ŌåÆ+\n  1067ŌåÆ+  it('should reject document creation without title', async () => {\n  1068ŌåÆ+    await request(app.app)\n  1069ŌåÆ+      .post('/api/documents')\n  1070ŌåÆ+      .send({ content: 'Hello' })\n  1071ŌåÆ+      .expect(400);\n  1072ŌåÆ+  });\n  1073ŌåÆ+\n  1074ŌåÆ+  it('should list documents', async () => {\n  1075ŌåÆ+    await request(app.app)\n  1076ŌåÆ+      .post('/api/documents')\n  1077ŌåÆ+      .send({ title: 'Doc 1' });\n  1078ŌåÆ+    await request(app.app)\n  1079ŌåÆ+      .post('/api/documents')\n  1080ŌåÆ+      .send({ title: 'Doc 2' });\n  1081ŌåÆ+\n  1082ŌåÆ+    const res = await request(app.app).get('/api/documents').expect(200);\n  1083ŌåÆ+    expect(res.body.length).toBe(2);\n  1084ŌåÆ+  });\n  1085ŌåÆ+\n  1086ŌåÆ+  it('should get a document by id', async () => {\n  1087ŌåÆ+    const created = await request(app.app)\n  1088ŌåÆ+      .post('/api/documents')\n  1089ŌåÆ+      .send({ title: 'My Doc', content: 'content here' });\n  1090ŌåÆ+\n  1091ŌåÆ+    const res = await request(app.app)\