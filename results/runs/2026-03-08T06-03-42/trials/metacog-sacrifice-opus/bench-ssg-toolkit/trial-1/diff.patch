--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,79 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(content: string): string {
+  return content.replace(/^:::(note|warning|tip)\n([\s\S]*?)^:::/gm, (_match, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+function processFootnotes(html: string, rawContent: string): string {
+  // Extract footnote definitions from raw content
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  const definitions = new Map<string, string>();
+  let match: RegExpExecArray | null;
+  while ((match = footnoteDefRegex.exec(rawContent)) !== null) {
+    definitions.set(match[1], match[2]);
+  }
+
+  if (definitions.size === 0) {
+    return html;
+  }
+
+  // Replace footnote references in HTML
+  let result = html.replace(/\[\^(\d+)\]/g, (_m, id: string) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  // Remove rendered footnote definition paragraphs from HTML
+  // These appear as paragraphs like: <p>[^1]: text</p> or as text within paragraphs
+  result = result.replace(/<p>\s*\[\^(\d+)\]:\s*.*?<\/p>\s*/g, '');
+
+  // Build footnotes section
+  const footnoteItems = Array.from(definitions.entries())
+    .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+    .join('\n');
+
+  result += `\n<section class="footnotes">\n<ol>\n${footnoteItems}\n</ol>\n</section>`;
+
+  return result;
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        let content = file.content;
+
+        // Process admonitions before markdown parsing
+        content = processAdmonitions(content);
+
+        // Remove footnote definitions before markdown parsing to avoid them being rendered as paragraphs
+        const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+        const definitions = new Map<string, string>();
+        let match: RegExpExecArray | null;
+        while ((match = footnoteDefRegex.exec(content)) !== null) {
+          definitions.set(match[1], match[2]);
+        }
+
+        // Strip footnote definitions from content before parsing
+        const contentWithoutDefs = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+        // Parse markdown to HTML
+        const rawContent = content;
+        let html = await marked.parse(contentWithoutDefs);
+
+        // Process footnotes
+        html = processFootnotes(html, rawContent);
+
+        return {
+          ...file,
+          content: html,
+        };
+      },
+    },
+  };
+}
