@@ -0,0 +1,36 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        // Pattern to match src="./..." or href="./..."
+        const relativeUrlRegex = /(src|href)="\.\/([^"]+)"/g;
+
+        const discoveredAssets: string[] = [];
+        const newContent = file.content.replace(relativeUrlRegex, (_match, attr: string, path: string) => {
+          discoveredAssets.push(path);
+          return `${attr}="/assets/${path}"`;
+        });
+
+        // Update the asset manifest in ctx.data
+        if (discoveredAssets.length > 0) {
+          let manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+          if (!manifest) {
+            manifest = { assets: [] };
+            ctx.data.set('asset-manifest', manifest);
+          }
+          manifest.assets.push(...discoveredAssets);
+        }
+
+        return {
+          ...file,
+          content: newContent,
+        };
+      },
+    },
+  };
+}
