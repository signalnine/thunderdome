+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Document CRUD', () => {
+    it('should create and get a document', () => {
+      store.create('doc1', { name: 'test' });
+      expect(store.get('doc1')).toEqual({ name: 'test' });
+    });
+
+    it('should throw when creating a document with existing ID', () => {
+      store.create('doc1', { name: 'test' });
+      expect(() => store.create('doc1', { name: 'other' })).toThrow();
+    });
+
+    it('should throw when getting a non-existent document', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { name: 'original' });
+      store.update('doc1', { name: 'updated' });
+      expect(store.get('doc1')).toEqual({ name: 'updated' });
+    });
+
+    it('should throw when updating a non-existent document', () => {
+      expect(() => store.update('nonexistent', { name: 'x' })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { name: 'test' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting a non-existent document', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('should deep clone on create and get (prevent external mutation)', () => {
+      const content = { nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
+      const retrieved = store.get('doc1') as { nested: { value: number } };
+      expect(retrieved.nested.value).toBe(1);
+
+      retrieved.nested.value = 888;
+      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);
+    });
+  });
+
+  describe('Version History', () => {
+    it('should create a version on create', () => {
+      store.create('doc1', { name: 'v1' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ name: 'v1' });
+    });
+
+    it('should create a new version on update', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(2);
+      expect(history[0].content).toEqual({ name: 'v1' });
+      expect(history[1].content).toEqual({ name: 'v2' });
+    });
+
+    it('should return versions in chronological order', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+      expect(history[1].timestamp).toBeLessThanOrEqual(history[2].timestamp);
+    });
+
+    it('should get a specific version by ID', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ name: 'v1' });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ name: 'v2' });
+    });
+
+    it('should throw for non-existent version', () => {
+      store.create('doc1', { name: 'v1' });
+      expect(() => store.getVersion('doc1', 'bad-id')).toThrow();
+    });
+
+    it('each version should have a unique ID', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+      const history = store.getHistory('doc1');
+      const ids = history.map(v => v.id);
+      expect(new Set(ids).size).toBe(3);
+    });
+  });
+
+  describe('Branching', () => {
+    it('should default to main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('should list branches', () => {
+      expect(store.listBranches()).toEqual(['main']);
+    });
+
+    it('should create and switch to a branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('should list multiple branches', () => {
+      store.createBranch('feature');
+      store.createBranch('bugfix');
+      expect(store.listBranches()).toContain('main');
+      expect(store.listBranches()).toContain('feature');
+      expect(store.listBranches()).toContain('bugfix');
+    });
+
+    it('should throw when creating a branch with existing name', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('should throw when switching to a non-existent branch', () => {
+      expect(() => store.switchBranch('nonexistent')).toThrow();
+    });
+
+    it('should isolate changes between branches', () => {
+      store.create('doc1', { value: 'main' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { value: 'feature' });
+
+      expect(store.get('doc1')).toEqual({ value: 'feature' });
+
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ value: 'main' });
+    });
+
+    it('should copy documents when creating a branch', () => {
+      store.create('doc1', { value: 'original' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ value: 'original' });
+    });
+
+    it('should create branch from a specified source branch', () => {
+      store.create('doc1', { value: 'main' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { value: 'feature' });
+
+      // Create a new branch from 'feature', not from current
+      store.switchBranch('main');
+      store.createBranch('feature2', 'feature');
+      store.switchBranch('feature2');
+      expect(store.get('doc1')).toEqual({ value: 'feature' });
+    });
+
+    it('new documents on a branch should not be visible on other branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { value: 'feature-only' });
+
+      store.switchBranch('main');
+      expect(() => store.get('doc1')).toThrow();
+    });
+  });
+
+  describe('Merging', () => {
+    it('should merge changes from source branch when only source changed', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 2 });
+    });
+
+    it('should keep target changes when only target changed', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      // Change on main (target)
+      store.update('doc1', { a: 1, b: 20 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, b: 20 });
+    });
+
+    it('should merge non-conflicting changes from both sides', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+
+      // Change on feature
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2, c: 3 });
+
+      // Change on main (different field)
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20, c: 3 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });
+    });
+
+    it('should detect conflicts when both sides change the same field differently', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100, b: 2 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200, b: 2 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe('doc1');
+      expect(result.conflicts[0].path).toBe('a');
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe(200);
+      expect(result.conflicts[0].theirs).toBe(100);
+    });
+
+    it('should not apply merge when conflicts exist', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 'feature' });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 'main' });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // Main should be unchanged
+      expect(store.get('doc1')).toEqual({ a: 'main' });
+    });
+
+    it('should not conflict when both sides change to the same value', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 42, b: 2 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 42, b: 2 });
+
+      const result = store.merge('feature');
