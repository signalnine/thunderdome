+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  base: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  ours: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  theirs: any;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, DocumentEntry>;
+  /** Snapshot of documents at the time this branch was created (the fork point / common ancestor). */
+  forkPoint: Map<string, object | null>;
+  /** The name of the branch this was forked from. */
+  parentBranch: string | null;
+}
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+let versionCounter = 0;
+
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {
+  return {
+    content: deepClone(entry.content),
+    versions: entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+function snapshotDocuments(docs: Map<string, DocumentEntry>): Map<string, object | null> {
+  const snapshot = new Map<string, object | null>();
+  for (const [id, entry] of docs) {
+    if (entry.deleted) {
+      snapshot.set(id, null);
+    } else {
+      snapshot.set(id, deepClone(entry.content));
+    }
+  }
+  return snapshot;
+}
+
+function isPlainObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+/**
+ * Three-way structural merge of two objects against a common base.
+ * Returns the merged result and any conflicts found.
+ */
+function threeWayMerge(
+  base: Record<string, unknown> | null | undefined,
+  ours: Record<string, unknown> | null | undefined,
+  theirs: Record<string, unknown> | null | undefined,
+  documentId: string,
+  pathPrefix: string,
+): { result: Record<string, unknown>; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+  const result: Record<string, unknown> = {};
+
+  const baseObj = base ?? {};
+  const oursObj = ours ?? {};
+  const theirsObj = theirs ?? {};
+
+  // Collect all keys from all three
+  const allKeys = new Set<string>([
+    ...Object.keys(baseObj),
+    ...Object.keys(oursObj),
+    ...Object.keys(theirsObj),
+  ]);
+
+  for (const key of allKeys) {
+    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+    const baseVal = baseObj[key];
+    const oursVal = oursObj[key];
+    const theirsVal = theirsObj[key];
+
+    const baseHas = key in baseObj;
+    const oursHas = key in oursObj;
+    const theirsHas = key in theirsObj;
+
+    const oursChanged = !deepEqual(baseVal, oursVal) || (baseHas !== oursHas);
+    const theirsChanged = !deepEqual(baseVal, theirsVal) || (baseHas !== theirsHas);
+
+    if (!oursChanged && !theirsChanged) {
+      // Neither side changed — keep base value
+      if (baseHas) {
+        result[key] = deepClone(baseVal);
+      }
+    } else if (oursChanged && !theirsChanged) {
+      // Only ours changed — take ours
+      if (oursHas) {
+        result[key] = deepClone(oursVal);
+      }
+      // If ours deleted the key (oursHas is false), we don't set it
+    } else if (!oursChanged && theirsChanged) {
+      // Only theirs changed — take theirs
+      if (theirsHas) {
+        result[key] = deepClone(theirsVal);
+      }
+    } else {
+      // Both changed
+      if (deepEqual(oursVal, theirsVal) && oursHas === theirsHas) {
+        // Both changed to the same value
+        if (oursHas) {
+          result[key] = deepClone(oursVal);
+        }
+      } else if (isPlainObject(oursVal) && isPlainObject(theirsVal) && isPlainObject(baseVal)) {
+        // Both are objects — recurse
+        const sub = threeWayMerge(
+          baseVal as Record<string, unknown>,
+          oursVal as Record<string, unknown>,
+          theirsVal as Record<string, unknown>,
+          documentId,
+          currentPath,
+        );
+        result[key] = sub.result;
+        conflicts.push(...sub.conflicts);
+      } else {
+        // Conflict — take ours for the merged result
+        conflicts.push({
+          documentId,
+          path: currentPath,
+          base: baseHas ? deepClone(baseVal) : undefined,
+          ours: oursHas ? deepClone(oursVal) : undefined,
+          theirs: theirsHas ? deepClone(theirsVal) : undefined,
+        });
+        if (oursHas) {
+          result[key] = deepClone(oursVal);
+        }
+      }
+    }
+  }
+
+  return { result, conflicts };
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (a === undefined || b === undefined) return false;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return false;
+
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    for (let i = 0; i < a.length; i++) {
+      if (!deepEqual(a[i], b[i])) return false;
+    }
+    return true;
+  }
+
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+
+  const aObj = a as Record<string, unknown>;
+  const bObj = b as Record<string, unknown>;
+  const aKeys = Object.keys(aObj);
+  const bKeys = Object.keys(bObj);
+
+  if (aKeys.length !== bKeys.length) return false;
+
+  for (const key of aKeys) {
+    if (!(key in bObj)) return false;
+    if (!deepEqual(aObj[key], bObj[key])) return false;
+  }
+
+  return true;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      forkPoint: new Map(),
+      parentBranch: null,
+    });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branchName = name ?? this.currentBranch;
+    const branch = this.branches.get(branchName);
+    if (!branch) {
+      throw new Error(`Branch "${branchName}" does not exist`);
+    }
+    return branch;
+  }
+
+  // ── Document CRUD ─────────────────────────────────────────
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    entry.deleted = true;
+  }
+
+  // ── Version History ───────────────────────────────────────
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = entry.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ── Branching ─────────────────────────────────────────────
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.getBranchData(sourceName);
+
+    // Deep-clone the entire document map for the new branch
+    const newDocs = new Map<string, DocumentEntry>();
+    for (const [id, entry] of source.documents) {
+      newDocs.set(id, cloneDocumentEntry(entry));
+    }
+
+    // The fork point is the current state of the source branch's documents
+    const forkPoint = snapshotDocuments(source.documents);
+
+    this.branches.set(name, {
+      documents: newDocs,
+      forkPoint,
+      parentBranch: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ── Merging ───────────────────────────────────────────────
+
+  merge(sourceBranch: string): MergeResult {
+    const targetBranchName = this.currentBranch;
+
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+    if (sourceBranch === targetBranchName) {
+      throw new Error('Cannot merge a branch into itself');
+    }
+
+    const source = this.getBranchData(sourceBranch);
+    const target = this.getBranchData(targetBranchName);
+
+    // Determine common ancestor (the fork point of the source branch)
+    // The fork point represents the state of documents when the source was created from its parent
+    const baseSnapshot = source.forkPoint;
+
+    // Collect all document IDs across base, source, and target
+    const allDocIds = new Set<string>();
+    for (const id of baseSnapshot.keys()) allDocIds.add(id);
+    for (const [id, entry] of source.documents) {
+      if (!entry.deleted) allDocIds.add(id);
+    }
+    for (const [id, entry] of target.documents) {
+      if (!entry.deleted) allDocIds.add(id);
+    }
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+    const documentsToApply: Array<{ id: string; content: object | null }> = [];
+
+    for (const docId of allDocIds) {
+      const baseContent = baseSnapshot.has(docId) ? baseSnapshot.get(docId) : undefined;
+      const baseExists = baseSnapshot.has(docId) && baseContent !== null;
+
+      const sourceEntry = source.documents.get(docId);
+      const sourceExists = sourceEntry !== undefined && !sourceEntry.deleted;
+      const sourceContent = sourceExists ? sourceEntry!.content : null;
+
+      const targetEntry = target.documents.get(docId);
+      const targetExists = targetEntry !== undefined && !targetEntry.deleted;
+      const targetContent = targetExists ? targetEntry!.content : null;
+
+      // Check if either side changed this document relative to base
+      const sourceChanged = baseExists !== sourceExists || !deepEqual(baseContent ?? null, sourceContent);
+      const targetChanged = baseExists !== targetExists || !deepEqual(baseContent ?? null, targetContent);
+
+      if (!sourceChanged && !targetChanged) {
+        // No changes on either side — skip (already in target)
+        if (targetExists && targetContent !== null) {
+          merged[docId] = deepClone(targetContent) as object;
+        }
+        continue;
+      }
+
+      if (sourceChanged && !targetChanged) {
+        // Only source changed — take source's version
+        if (sourceExists && sourceContent !== null) {
+          merged[docId] = deepClone(sourceContent) as object;
+          documentsToApply.push({ id: docId, content: deepClone(sourceContent) as object });
+        } else {
+          // Source deleted the doc
+          documentsToApply.push({ id: docId, content: null });
+        }
+        continue;
+      }
+
+      if (!sourceChanged && targetChanged) {
+        // Only target changed — keep target's version (already there)
+        if (targetExists && targetContent !== null) {
+          merged[docId] = deepClone(targetContent) as object;
+        }
+        continue;
+      }
+
+      // Both sides changed this document
+      if (!sourceExists && !targetExists) {
+        // Both deleted — nothing to merge
+        documentsToApply.push({ id: docId, content: null });
+        continue;
+      }
+
+      if (sourceExists && targetExists) {
+        // Both modified — do field-level three-way merge
+        const baseObj = (baseExists && baseContent ? baseContent : {}) as Record<string, unknown>;
+        const { result, conflicts } = threeWayMerge(
+          baseObj,
+          targetContent as Record<string, unknown>,
+          sourceContent as Record<string, unknown>,
+          docId,
+          '',
+        );
+
+        merged[docId] = result as object;
+        allConflicts.push(...conflicts);
+        if (conflicts.length === 0) {
+          documentsToApply.push({ id: docId, content: result as object });
+        }
+        continue;
+      }
+
+      // One side deleted, other modified — conflict at document level
+      // Note: the spec says merge is field-level. We treat this as the
+      // target (ours) having the document in whatever state it's in.
+      if (targetExists && targetContent !== null) {
+        merged[docId] = deepClone(targetContent) as object;
+      }
+      // If source exists and target deleted: source wins in merged for preview,
+      // but there's a conceptual conflict. For simplicity, since spec says
+      // "ours wins for conflicts", we keep whichever is ours (target).
+      if (sourceExists && !targetExists) {
+        // Source has the doc, target deleted it.
+        // "ours" is the target (current branch) which deleted it.
+        // Don't include in merged since it was deleted on our side.
+      }
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the target branch
+      for (const { id, content } of documentsToApply) {
+        if (content === null) {
+          // Delete the document
+          const entry = target.documents.get(id);
+          if (entry) {
+            entry.deleted = true;
+          }
+        } else {
+          const existing = target.documents.get(id);
+          if (existing && !existing.deleted) {
+            // Update existing document
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(content),
+            };
+            existing.content = deepClone(content);
+            existing.versions.push(version);
+          } else {
+            // Create new document (was created on source branch)
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(content),
+            };
+            target.documents.set(id, {
+              content: deepClone(content),
+              versions: [version],
+              deleted: false,
+            });
+          }
+        }
+      }
+
+      // Update the source branch's fork point to current target state
+      // so subsequent merges have the right base
+      source.forkPoint = snapshotDocuments(target.documents);
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+}
