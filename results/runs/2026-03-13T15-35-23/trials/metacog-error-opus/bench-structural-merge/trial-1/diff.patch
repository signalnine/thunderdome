   const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.getBranchData(sourceName);\n\n    // Deep-clone the entire document map for the new branch\n    const newDocs = new Map<string, DocumentEntry>();\n    for (const [id, entry] of source.documents) {\n      newDocs.set(id, cloneDocumentEntry(entry));\n    }\n\n    // The fork point is the current state of the source branch's documents\n    const forkPoint = snapshotDocuments(source.documents);\n\n    this.branches.set(name, {\n      documents: newDocs,\n      forkPoint,\n      parentBranch: sourceName,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ── Merging ───────────────────────────────────────────────\n\n  merge(sourceBranch: string): MergeResult {\n    const targetBranchName = this.currentBranch;\n\n    if (!this.branches.has(sourceBranch)) {\n      throw new Error(`Branch \"${sourceBranch}\" does not exist`);\n    }\n    if (sourceBranch === targetBranchName) {\n      throw new Error('Cannot merge a branch into itself');\n    }\n\n    const source = this.getBranchData(sourceBranch);\n    const target = this.getBranchData(targetBranchName);\n\n    // Determine common ancestor (the fork point of the source branch)\n    // The fork point represents the state of documents when the source was created from its parent\n    const baseSnapshot = source.forkPoint;\n\n    // Collect all document IDs across base, source, and target\n    const allDocIds = new Set<string>();\n    for (const id of baseSnapshot.keys()) allDocIds.add(id);\n    for (const [id, entry] of source.documents) {\n      if (!entry.deleted) allDocIds.add(id);\n    }\n    for (const [id, entry] of target.documents) {\n      if (!entry.deleted) allDocIds.add(id);\n    }\n\n    const merged: Record<string, object> = {};\n    const allConflicts: Conflict[] = [];\n    const documentsToApply: Array<{ id: string; content: object | null }> = [];\n\n    for (const docId of allDocIds) {\n      const baseContent = baseSnapshot.has(docId) ? baseSnapshot.get(docId) : undefined;\n      const baseExists = baseSnapshot.has(docId) && baseContent !== null;\n\n      const sourceEntry = source.documents.get(docId);\n      const sourceExists = sourceEntry !== undefined && !sourceEntry.deleted;\n      const sourceContent = sourceExists ? sourceEntry!.content : null;\n\n      const targetEntry = target.documents.get(docId);\n      const targetExists = targetEntry !== undefined && !targetEntry.deleted;\n      const targetContent = targetExists ? targetEntry!.content : null;\n\n      // Check if either side changed this document relative to base\n      const sourceChanged = baseExists !== sourceExists || !deepEqual(baseContent ?? null, sourceContent);\n      const targetChanged = baseExists !== targetExists || !deepEqual(baseContent ?? null, targetContent);\n\n      if (!sourceChanged && !targetChanged) {\n        // No changes on either side — skip (already in target)\n        if (targetExists && targetContent !== null) {\n          merged[docId] = deepClone(targetContent) as object;\n        }\n        continue;\n      }\n\n      if (sourceChanged && !targetChanged) {\n        // Only source changed — take source's version\n        if (sourceExists && sourceContent !== null) {\n          merged[docId] = deepClone(sourceContent) as object;\n          documentsToApply.push({ id: docId, content: deepClone(sourceContent) as object });\n        } else {\n          // Source deleted the doc\n          documentsToApply.push({ id: docId, content: null });\n        }\n        continue;\n      }\n\n      if (!sourceChanged && targetChanged) {\n        // Only target changed — keep target's version (already there)\n        if (targetExists && targetContent !== null) {\n          merged[docId] = deepClone(targetContent) as object;\n        }\n        continue;\n      }\n\n      // Both sides changed this document\n      if (!sourceExists && !targetExists) {\n        // Both deleted — nothing to merge\n        documentsToApply.push({ id: docId, content: null });\n        continue;\n      }\n\n      if (sourceExists && targetExists) {\n        // Both modified — do field-level three-way merge\n        const baseObj = (baseExists && baseContent ? baseContent : {}) as Record<string, unknown>;\n        const { result, conflicts } = threeWayMerge(\n          baseObj,\n          sourceContent as Record<string, unknown>,\n          targetContent as Record<string, unknown>,\n          docId,\n          '',\n        );\n\n        merged[docId] = result as object;\n        allConflicts.push(...conflicts);\n        if (conflicts.length === 0) {\n          documentsToApply.push({ id: docId, content: result as object });\n        }\n        continue;\n      }\n\n      // One side deleted, other modified — conflict at document level\n      // Note: the spec says merge is field-level. We treat this as the\n      // target (ours) having the document in whatever state it's in.\n      if (targetExists && targetContent !== null) {\n        merged[docId] = deepClone(targetContent) as object;\n      }\n      // If source exists and target deleted: source wins in merged for preview,\n      // but there's a conceptual conflict. For simplicity, since spec says\n      // \"ours wins for conflicts\", we keep whichever is ours (target).\n      if (sourceExists && !targetExists) {\n        // Source has the doc, target deleted it.\n        // \"ours\" is the target (current branch) which deleted it.\n        // Don't include in merged since it was deleted on our side.\n      }\n    }\n\n    const applied = allConflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge to the target branch\n      for