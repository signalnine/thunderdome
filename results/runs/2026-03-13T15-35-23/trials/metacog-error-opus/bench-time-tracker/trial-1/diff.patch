r and create the file\", () => {\n      const entry = tracker.start(\"coding\");\n      expect(entry.task).toBe(\"coding\");\n      expect(entry.stop).toBeNull();\n      expect(existsSync(filePath)).toBe(true);\n    });\n\n    it(\"should throw on empty task name\", () => {\n      expect(() => tracker.start(\"\")).toThrow(\"Task name must not be empty\");\n    });\n\n    it(\"should throw on whitespace-only task name\", () => {\n      expect(() => tracker.start(\"   \")).toThrow(\"Task name must not be empty\");\n    });\n\n    it(\"should auto-stop a running timer when starting a new one\", () => {\n      tracker.start(\"task1\");\n      tracker.start(\"task2\");\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].stop).not.toBeNull();\n      expect(entries[1].stop).toBeNull();\n    });\n\n    it(\"should support unicode and emoji task names\", () => {\n      const entry = tracker.start(\"日本語タスク 🎯\");\n      expect(entry.task).toBe(\"日本語タスク 🎯\");\n\n      // Verify persistence\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"日本語タスク 🎯\");\n    });\n  });\n\n  describe(\"stop\", () => {\n    it(\"should stop the running timer\", () => {\n      tracker.start(\"coding\");\n      const stopped = tracker.stop();\n      expect(stopped.task).toBe(\"coding\");\n      expect(stopped.stop).not.toBeNull();\n    });\n\n    it(\"should throw when no timer is running\", () => {\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n\n    it(\"should throw when timer was already stopped\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should create parent directories automatically\", () => {\n      const nested = join(tmpdir(), \"a-\" + Date.now(), \"b\", \"c\", \"data.json\");\n      const t = new TimeTracker(nested);\n      t.start(\"test\");\n      expect(existsSync(nested)).toBe(true);\n      // cleanup\n      rmSync(join(nested, \"..\", \"..\", \"..\"), { recursive: true });\n    });\n\n    it(\"should persist entries across instances\", () => {\n      tracker.start(\"task1\");\n      tracker.stop();\n      tracker.start(\"task2\");\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].task).toBe(\"task1\");\n      expect(entries[1].task).toBe(\"task2\");\n    });\n  });\n\n  describe(\"getEntries\", () => {\n    it(\"should return all entries when no filter is given\", () => {\n      tracker.start(\"a\");\n      tracker.start(\"b\");\n      tracker.start(\"c\");\n      expect(tracker.getEntries()).toHaveLength(3);\n    });\n\n    it(\"should filter by date range\", () => {\n      const past = new Date(\"2020-01-01T00:00:00Z\");\n      const future = new Date(\"2030-01-01T00:00:00Z\");\n\n      tracker.start(\"task\");\n      tracker.stop();\n\n      // Entry is created now, so filtering with future dates should exclude it\n      expect(tracker.getEntries({ from: future })).toHaveLength(0);\n\n      // Filtering with a past date should include it\n      expect(tracker.getEntries({ from: past })).toHaveLength(1);\n\n      // Filtering with past end should exclude it\n      expect(tracker.getEntries({ to: past })).toHaveLength(0);\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should sum durations for the same task name\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThan(0);\n    });\n\n    it(\"should include running tasks using current time\", () => {\n      tracker.start(\"running-task\");\n      const summary = tracker.getSummary();\n      expect(summary[\"running-task\"]).toBeGreaterThanOrEqual(0);\n    });\n\n    it(\"should separate different task names\", () => {\n      tracker.start(\"task-a\");\n      tracker.stop();\n      tracker.start(\"task-b\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(Object.keys(summary)).toHaveLength(2);\n      expect(summary[\"task-a\"]).toBeDefined();\n      expect(summary[\"task-b\"]).toBeDefined();\n    });\n  });\n});\n","structuredPatch":[{"oldStart":142,"oldLines":7,"newStart":142,"newLines":8,"lines":["       tracker.stop();"," ","       const summary = tracker.getSummary();","-      expect(summary[\"coding\"]).toBeGreaterThan(0);","+      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);","+      expect(Object.keys(summary)).toHaveLength(1);","     });"," ","     it(\"should include running tasks using current time\", () => {"]}],"userModified":false,"replaceAll":false}}
