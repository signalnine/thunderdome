+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601 or null if still running
+}
+
+export interface TimeSummary {
+  [task: string]: number; // milliseconds
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      if (existsSync(this.filePath)) {
+        const raw = readFileSync(this.filePath, "utf-8");
+        const data: unknown = JSON.parse(raw);
+        if (!Array.isArray(data)) {
+          return [];
+        }
+        return data as TimeEntry[];
+      }
+    } catch {
+      // File doesn't exist or is invalid JSON — start fresh
+    }
+    return [];
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+
+  /**
+   * Start a new timer. If a timer is already running, it is stopped first.
+   */
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  /**
+   * Get the currently running entry, or null if none.
+   */
+  private getRunningEntry(): TimeEntry | null {
+    for (let i = this.entries.length - 1; i >= 0; i--) {
+      if (this.entries[i].stop === null) {
+        return this.entries[i];
+      }
+    }
+    return null;
+  }
+
+  /**
+   * Get all entries, optionally filtered by date range.
+   * Both `from` and `to` are inclusive bounds on the entry's start time.
+   */
+  getEntries(options?: { from?: Date; to?: Date }): TimeEntry[] {
+    if (!options?.from && !options?.to) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter((entry) => {
+      const startTime = new Date(entry.start).getTime();
+      if (options?.from && startTime < options.from.getTime()) {
+        return false;
+      }
+      if (options?.to && startTime > options.to.getTime()) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  /**
+   * Get a summary of total time (in milliseconds) per task name.
+   * Running entries use the current time for their duration.
+   */
+  getSummary(options?: { from?: Date; to?: Date }): TimeSummary {
+    const entries = this.getEntries(options);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const startMs = new Date(entry.start).getTime();
+      const stopMs = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = stopMs - startMs;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+}
