antity: number): void {\n      const currentReserved = reserved.get(productId) ?? 0;\n      const releaseAmount = Math.min(quantity, currentReserved);\n      reserved.set(productId, currentReserved - releaseAmount);\n      stock.set(productId, (stock.get(productId) ?? 0) + releaseAmount);\n      emitUpdate(productId);\n    },\n\n    setLowStockThreshold(productId: string, threshold: number): void {\n      thresholds.set(productId, threshold);\n      checkLowStock(productId);\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":405,"cache_read_input_tokens":24682,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":405},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1d09a49a-d930-488b-a446-6c245de40da2","uuid":"84df29a3-eb38-42f6-a5c9-0fed32999254"}
