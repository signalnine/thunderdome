 userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    // 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 70 });\n\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 10 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toEqual([\n      { productId: 'p2', count: 12 },\n      { productId: 'p1', count: 5 },\n    ]);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const bus = new EventBus();\n\n    // Create all services - analytics and notifications must be created first to listen\n    const analytics = createAnalyticsService(bus);\n    const notifications = createNotificationService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Step 1: Create products\n    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');\n\n    // Wait for events to propagate\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Step 2: Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Step 3: Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n\n    // Step 4: Calculate pricing\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const priceResult = pricing.calculateTotal(items);\n    expect(priceResult.subtotal).toBeCloseTo(1059.97);\n    expect(priceResult.tax).toBeCloseTo(105.997);\n\n    // Step 5: Reserve inventory\n    for (const item of cart.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Step 6: Create order\n    const orderId = orders.createOrder('user1', cartId, priceResult.total);\n\n    // Wait for async events\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Step 7: Process payment\n    const paymentResult = await payment.processPayment(orderId, priceResult.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Step 8: Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n\n    // Wait for async events\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Verify order status\n    const order = orders.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.CONFIRMED);\n\n    // Verify notifications were sent\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.length).toBeGreaterThan(0);\n\n    // Verify analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBeCloseTo(priceResult.total);\n    expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 cart\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":240,"cache_read_input_tokens":34965,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":240},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1d09a49a-d930-488b-a446-6c245de40da2","uuid":"2738432d-a7df-4a20-82ee-62d3daab8a64"}
