    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Gizmo', 19.99, 'gadgets');\n    catalog.createProduct('Book', 12.99, 'books');\n\n    expect(catalog.listProducts()).toHaveLength(3);\n    expect(catalog.listProducts('gadgets')).toHaveLength(2);\n    expect(catalog.listProducts('books')).toHaveLength(1);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 9.99, 'gadgets');\n    catalog.createProduct('Red Widget', 19.99, 'gadgets');\n    catalog.createProduct('Book', 12.99, 'books');\n\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(2);\n  });\n\n  it('should update product fields', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { price: 14.99, name: 'Super Widget' });\n    const product = catalog.getProduct(id);\n    expect(product!.price).toBe(14.99);\n    expect(product!.name).toBe('Super Widget');\n    expect(product!.category).toBe('gadgets');\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct('nonexistent')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n\n    // Wait for async emit\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    const log = bus.getLog();\n    const createEvents = log.filter(e => e.event === Events.PRODUCT_CREATED);\n    expect(createEvents).toHaveLength(1);\n    expect((createEvents[0].payload as { productId: string }).productId).toBe(id);\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('prod1', 100);\n    expect(inventory.getStock('prod1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('nonexistent')).toBe(0);\n  });\n\n  it('should reserve stock if sufficient', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('prod1', 10);\n    expect(inventory.reserve('prod1', 5)).toBe(true);\n    expect(inventory.getStock('prod1')).toBe(5);\n  });\n\n  it('should fail to reserve if insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('prod1', 3);\n    expect(inventory.reserve('prod1', 5)).toBe(false);\n    expect(inventory.getStock('prod1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('prod1', 10);\n    inventory.reserve('prod1', 5);\n    inventory.release('prod1', 3);\n    expect(inventory.getStock('prod1')).toBe(8);\n  });\n\n  it('should emit low stock alert when threshold is crossed', async () => {\n    const inventory = createInventoryService(bus);\n    let alertFired = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });\n\n    inventory.setStock('prod1', 10);\n    inventory.setLowStockThreshold('prod1', 5);\n    inventory.reserve('prod1', 6);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(alertFired).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n    const c = cart.getCart(id);\n    expect(c).toEqual({ id, userId: 'user1', items: [] });\n  });\n\n  it('should add items to cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'prod1', quantity: 2 }]);\n  });\n\n  it('should consolidate items for same product', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.addItem(id, 'prod1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'prod1', quantity: 5 }]);\n  });\n\n  it('should remove items from cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.addItem(id, 'prod2', 1);\n    cart.removeItem(id, 'prod1');\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'prod2', quantity: 1 }]);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.updateQuantity(id, 'prod1', 10);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'prod1', quantity: 10 }]);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'prod1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([]);\n  });\n\n  it('should return null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with 10% tax', () => {\n    con