mitted with previous status\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const statusEvents = log.filter(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvents.length).toBeGreaterThan(0);\n    const lastEvent = statusEvents[statusEvents.length - 1].payload as { previousStatus: string };\n    expect(lastEvent.previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 10);\n    orders.createOrder('user1', 'cart2', 20);\n    orders.createOrder('user2', 'cart3', 30);\n\n    const user1Orders = orders.listOrders('user1');\n    expect(user1Orders).toHaveLength(2);\n  });\n\n  it('should return null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 50);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should refund a successful transaction', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 50);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund an unknown transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 50);\n\n    const log = bus.getLog();\n    const paymentEvents = log.filter(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(paymentEvents).toHaveLength(1);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should deliver notifications to subscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // Simulate order creation\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    // Simulate order status change\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBeGreaterThan(0);\n    expect(notes[0].type).toBe('order_status');\n  });\n\n  it('should not deliver notifications to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    // Don't subscribe\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes).toHaveLength(0);\n  });\n\n  it('should deliver payment notifications', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes.some(n => n.type === 'payment')).toBe(true);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events by type', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 10, category: 'test' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'Gizmo', price: 20, category: 'test' });\n\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(0);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count failed payments as revenue', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'declined' });\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    // 2 unique carts\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    // 1 order\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });\n\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 70 });\n\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [{ productId: 'p2', quantity: 10 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u2', cartId: 'c2', total: 200 });\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toEqual([\n      { productId: 'p2', count: 12 },\n      { productId: 'p1', count: 5 },\n    ]);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const bus = new EventBus();\n\n    // Create all services - analytics and notifications must be created first to listen\n    const analytics = createAnalyticsService(bus);\n    const notifications = createNotificationService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Step 1: Create products\n    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');\n\n    // Wait for events to propagate\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Step 2: Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Step 3: Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n\n    // Step 4: Calculate pricing\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const priceResult = pricing.calculateTotal(items);\n    expect(priceResult.subtotal).toBeCloseTo(1059.97);\n    expect(priceResult.tax).toBeCloseTo(105.997);\n\n    // Step 5: Reserve inventory\n    for (const item of cart.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Step 6: Create order\n    const orderId = orders.createOrder('user1', cartId, priceResult.total);\n\n    // Wait for async events\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Step 7: Process payment\n    const paymentResult = await payment.processPayment(orderId, priceResult.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Step 8: Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n\n    // Wait for async events\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Verify order status\n    const order = orders.getOrder(orderId);\n    expect(order!.status).toBe(OrderStatus.CONFIRMED);\n\n    // Verify notifications were sent\n    const userNotifications = notifications.getNotifications('user1');\n    expect(userNotifications.length).toBeGreaterThan(0);\n\n    // Verify analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBeCloseTo(priceResult.total);\n    expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 cart\n  });\n});\n","structuredPatch":[],"originalFile":null}}
