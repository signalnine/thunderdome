yment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund an unknown transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 50);\n\n    const log = bus.getLog();\n    const paymentEvents = log.filter(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(paymentEvents).toHaveLength(1);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should deliver notifications to subscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // Simulate order creation\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    // Simulate order status change\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes.length).toBeGreaterThan(0);\n    expect(notes[0].type).toBe('order_status');\n  });\n\n  it('should not deliver notifications to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    // Don't subscribe\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 50 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n\n    const notes = notifications.getNotifications('user1');\n    expect(notes).toHaveLength(0);\n  });\n\n  it('should deliver payment notifications', async () => {\n    const notifications = createN