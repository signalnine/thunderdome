+// Beam direction constants
+const DIR_DOWN = 0;
+const DIR_DOWN_LEFT = 1;
+const DIR_DOWN_RIGHT = 2;
+
+type Direction = typeof DIR_DOWN | typeof DIR_DOWN_LEFT | typeof DIR_DOWN_RIGHT;
+
+function colDelta(dir: Direction): number {
+  if (dir === DIR_DOWN) return 0;
+  if (dir === DIR_DOWN_LEFT) return -1;
+  return 1; // DIR_DOWN_RIGHT
+}
+
+/**
+ * Simulate beam propagation and return visited cells set + path count.
+ * Uses a single pass: propagate all active beams step by step.
+ * For path counting, each beam state carries a bigint multiplicity
+ * so we never enumerate individual paths.
+ */
+function simulate(grid: string[][]): { visited: Set<number>; pathCount: bigint } {
+  const rows = grid.length;
+  if (rows === 0) return { visited: new Set(), pathCount: 0n };
+  const cols = grid[0].length;
+  if (cols === 0) return { visited: new Set(), pathCount: 0n };
+
+  // Find the source
+  let sourceCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sourceCol = c;
+      break;
+    }
+  }
+  if (sourceCol === -1) return { visited: new Set(), pathCount: 0n };
+
+  const visited = new Set<number>();
+  const key = (r: number, c: number): number => r * cols + c;
+
+  // Mark source as visited
+  visited.add(key(0, sourceCol));
+
+  // Active beams: map from (row, col, dir) to count (bigint)
+  // We use a Map<string, bigint> for current beams
+  // Start: one beam at source position going down, with count 1
+  // But the source is at row 0 — the beam needs to move from there.
+  // The beam starts AT the source cell and then propagates.
+  // If the source cell itself is a splitter... per spec source is always 'S'.
+
+  // We process beams step by step. Each step moves all beams one cell.
+  // Beams at the same (row, col, dir) are merged by summing counts.
+
+  // Initial state: beam at source (0, sourceCol) going DOWN
+  // We need to advance it. The source cell is visited.
+  // Check if source is also a splitter — no, spec says source is 'S'.
+
+  let beams = new Map<string, bigint>();
+  const beamKey = (r: number, c: number, d: Direction): string => `${r},${c},${d}`;
+
+  // The beam starts at the source. We need to move it to the next cell.
+  // Process: from (0, sourceCol, DOWN), move to (1, sourceCol)
+  beams.set(beamKey(0, sourceCol, DIR_DOWN), 1n);
+
+  let totalExitPaths = 0n;
+
+  // Step-by-step propagation
+  while (beams.size > 0) {
+    const nextBeams = new Map<string, bigint>();
+
+    const addBeam = (r: number, c: number, d: Direction, count: bigint): void => {
+      const k = beamKey(r, c, d);
+      const existing = nextBeams.get(k);
+      nextBeams.set(k, existing !== undefined ? existing + count : count);
+    };
+
+    for (const [bk, count] of beams) {
+      const parts = bk.split(',');
+      const r = parseInt(parts[0]);
+      const c = parseInt(parts[1]);
+      const d = parseInt(parts[2]) as Direction;
+
+      // Move the beam one step in its current direction
+      const nextRow = r + 1;
+      const nextCol = c + colDelta(d);
+
+      // Check bounds
+      if (nextRow < 0 || nextRow >= rows || nextCol < 0 || nextCol >= cols) {
+        // Beam exits the grid — count as a completed path
+        totalExitPaths += count;
+        continue;
+      }
+
+      // Mark cell as visited
+      visited.add(key(nextRow, nextCol));
+
+      // Check what's at the next cell
+      const cell = grid[nextRow][nextCol];
+      if (cell === '^') {
+        // Splitter: beam splits into down-left and down-right
+        addBeam(nextRow, nextCol, DIR_DOWN_LEFT, count);
+        addBeam(nextRow, nextCol, DIR_DOWN_RIGHT, count);
+      } else {
+        // Empty cell or source (shouldn't be source mid-grid but handle anyway)
+        // Beam continues in same direction
+        addBeam(nextRow, nextCol, d, count);
+      }
+    }
+
+    beams = nextBeams;
+  }
+
+  return { visited, pathCount: totalExitPaths };
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const { visited } = simulate(grid);
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const { pathCount } = simulate(grid);
+  return pathCount;
+}
