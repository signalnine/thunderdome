maining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = a & b;\n            break;\n          case 'OR':\n            result = a | b;\n            break;\n          case 'XOR':\n            result = a ^ b;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find 8 swapped output wires in a broken ripple-carry adder circuit.\n *\n * Combines rule-based detection with structural walking to identify\n * all swapped wires in a broken ripple-carry adder.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped: Set<string> = new Set();\n\n  // Find max input bit\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));\n    }\n  }\n\n  function pad(n: number): string {\n    return n.toString().padStart(2, '0');\n  }\n\n  const highestZ = `z${pad(maxBit + 1)}`;\n\n  function isZWire(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function isInputXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function hasInputXY(g: Gate): boolean {\n    return isInputXY(g.in1) || isInputXY(g.in2);\n  }\n\n  function isBit0(g: Gate): boolean {\n    return (g.in1 === 'x00' || g.in2 === 'x00') && (g.in1 === 'y00' || g.in2 === 'y00');\n  }\n\n  // ===== Rule-based detection =====\n  // These rules identify individual wires that are in structurally wrong positions.\n  // They work on the ORIGINAL gates (not copies) to avoid mutation issues.\n\n  // Build consumer map on original gates\n  function getConsumerOps(wire: string): Set<string> {\n    return new Set(\n      gates.filter(g => g.in1 === wire || g.in2 === wire).map(g => g.op)\n    );\n  }\n\n  for (const gate of gates) {\n    const { op, out } = gate;\n\n    if (op === 'XOR') {\n      if (hasInputXY(gate)) {\n        // Partial sum XOR: x_i XOR y_i\n        if (isBit0(gate)) {\n          // Bit 0: should output z00\n          if (out !== 'z00') {\n            swapped.add(out);\n            swapped.add('z00');\n          }\n        } else {\n          // Bit > 0: should NOT output a z wire\n          if (isZWire(out)) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        // Final sum XOR (t_i XOR c_{i-1}): should output a z wire\n        if (!isZWire(out)) {\n          swapped.add(out);\n        }\n      }\n    } else if (op === 'AND') {\n      if (!isBit0(gate)) {\n        // AND output (non-bit-0) should feed into an OR gate\n        const ops = getConsumerOps(out);\n        if (!ops.has('OR')) {\n          swapped.add(out);\n        }\n      }\n    } else if (op === 'OR') {\n      // OR output is a carry wire\n      if (out !== highestZ && isZWire(out)) {\n        // Non-final carry should NOT be a z wire\n        swapped.add(out);\n      }\n    }\n  }\n\n  // If rules found all 8, return immediately\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // ===== Walk-based detection =====\n  // For any remaining swaps not caught by rules, walk through the adder structure.\n  // Work on copies to apply fixes.\n  const gatesCopy: Gate[] = gates.map(g => ({ ...g }));\n\n  const outToGate = new Map<string, Gate>();\n  const gateByOpInputs = new Map<string, Gate>();\n\n  function rebuildLookups() {\n    outToGate.clear();\n    gateByOpInputs.clear();\n    for (const g of gatesCopy) {\n      outToGate.set(g.out, g);\n      const ins = [g.in1, g.in2].sort();\n      gateByOpInputs.set(`${g.op}:${ins[0]}:${ins[1]}`, g);\n    }\n  }\n  rebuildLookups();\n\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    const ins = [in1, in2].sort();\n    return gateByOpInputs.get(`${op}:${ins[0]}:${ins[1]}`);\n  }\n\n  function consumers(wire: string): Gate[] {\n    return gatesCopy.filter(g => g.in1 === wire || g.in2 === wire);\n  }\n\n  function consumerOps(wire: string): Set<string> {\n    return new Set(consumers(wire).map(g => g.op));\n  }\n\n  function doSwap(a: string, b: string): void {\n    if (a === b) return;\n    swapped.add(a);\n    swapped.add(b);\n    for (const g of gatesCopy) {\n      if (g.out === a) g.out = b;\n      else if (g.out === b) g.out = a;\n    }\n    rebuildLookups();\n  }\n\n  // First, fix the rule-detected swaps on gatesCopy.\n  // Pair up rule-detected wires into swap pairs.\n  const ruleSwapped = [...swapped];\n  const paired = new Set<string>();\n\n  // Strategy: for each flagged non-z wire, find its z-wire partner.\n  // For pairs where both are non-z (e.g., AND output → flagged because no OR consumer,\n  // and its partner), we handle after z-pairs.\n  for (const wire of ruleSwapped) {\n    if (paired.has(wire)) continue;\n\n    if (isZWire(wire)) {\n      // This z wire is in the wrong place. Find what should be here.\n      // The gate producing this z wire tells us what's wrong.\n      const producer = outToGate.get(wire);\n      if (producer) {\n        if (producer.op === 'AND' && !isBit0(producer)) {\n          // An AND gate is producing a z wire — it should feed an OR instead.\n          // The z wire should come from an XOR gate.\n          // Find which non-z wire is flagged that should be paired with this z.\n          for (const other of ruleSwapped) {\n            if (paired.has(other)) continue;\n            if (other === wire) continue;\n            if (!isZWire(other)) {\n              const otherProducer = outToGate.get(other);\n              if (otherProducer && otherProducer.op === 'XOR' && !hasInputXY(otherProducer)) {\n                // This non-z wire is produced by a sum XOR — it should be a z wire\n                doSwap(wire, other);\n                paired.add(wire);\n                paired.add(other);\n                break;\n              }\n            }\n          }\n        } else if (producer.op === 'OR') {\n          // An OR gate producing a z wire — carry is in a z position\n          for (const other of ruleSwapped) {\n            if (paired.has(other)) continue;\n            if (other === wire) continue;\n            if (!isZWire(other)) {\n              const otherProducer = outToGate.get(other);\n              if (otherProducer && otherProducer.op === 'XOR' && !hasInputXY(otherProducer)) {\n                doSwap(wire, other);\n                paired.add(wire);\n                paired.add(other);\n                break;\n              }\n            }\n          }\n        } else if (producer.op === 'XOR' && hasInputXY(producer)) {\n          // A partial sum XOR is producing a z wire — wrong, it should be internal\n          for (const other of ruleSwapped) {\n            if (paired.has(other)) continue;\n            if (other === wire) continue;\n            if (!isZWire(other)) {\n              doSwap(wire, other);\n              paired.add(wire);\n              paired.add(other);\n              break;\n            }\n          }\n        }\n      }\n    }\n  }\n\n  // Handle remaining unpaired non-z wires\n  const unpaired = ruleSwapped.filter(w => !paired.has(w));\n  for (let i = 0; i < unpaired.length; i += 2) {\n    if (i + 1 < unpaired.length) {\n      doSwap(unpaired[i], unpaired[i + 1]);\n    }\n  }\n\n  // Now walk to find any remaining swaps\n  let carry: string | undefined;\n\n  for (let bit = 0; bit <= maxBit; bit++) {\n    const x = `x${pad(bit)}`;\n    const y = `y${pad(bit)}`;\n    const z = `z${pad(bit)}`;\n\n    if (bit === 0) {\n      const xorGate = findGate('XOR', x, y);\n      if (xorGate && xorGate.out !== z) {\n        doSwap(xorGate.out, z);\n      }\n      const andGate = findGate('AND', x, y);\n      if (andGate) carry = andGate.out;\n    } else {\n      if (carry === undefined) continue;\n\n      const partialXor = findGate('XOR', x, y);\n      if (!partialXor) continue;\n      let tWire = partialXor.out;\n\n      // Partial sum should not be a z wire\n      if (isZWire(tWire)) {\n        const carryXorCons = consumers(carry).filter(g => g.op === 'XOR');\n        if (carryXorCons.length >= 1) {\n          const realT = carryXorCons[0].in1 === carry\n            ? carryXorCons[0].in2\n            : carryXorCons[0].in1;\n          doSwap(tWire, realT);\n          tWire = realT;\n        }\n      }\n\n      // Find sum gate\n      let sumGate = findGate('XOR', tWire, carry);\n\n      if (!sumGate) {\n        const zGate = outToGate.get(z);\n        if (zGate && zGate.op === 'XOR') {\n          const ins = [zGate.in1, zGate.in2];\n          if (ins.includes(carry)) {\n            const realT = ins[0] === carry ? ins[1] : ins[0];\n            if (realT !== tWire) doSwap(tWire, realT);\n            tWire = realT;\n            sumGate = zGate;\n          } else if (ins.includes(tWire)) {\n            const realCarry = ins[0] === tWire ? ins[1] : ins[0];\n            if (realCarry !== carry) doSwap(carry, realCarry);\n            carry = realCarry;\n            sumGate = zGate;\n          }\n        }\n        if (!sumGate) {\n          const carryXorCons = consumers(carry).filter(g => {\n            if (g.op !== 'XOR') return false;\n            return !(isInputXY(g.in1) && isInputXY(g.in2));\n          });\n          if (carryXorCons.length === 1) {\n            sumGate = carryXorCons[0];\n            const otherIn = sumGate.in1 === carry ? sumGate.in2 : sumGate.in1;\n            if (otherIn !== tWire) {\n              doSwap(tWire, otherIn);\n              tWire = otherIn;\n            }\n          } else if (carryXorCons.length === 0) {\n            const tXorCons = consumers(tWire).filter(g => g.op === 'XOR');\n            if (tXorCons.length === 1) {\n              sumGate = tXorCons[0];\n              const realCarry = sumGate.in1 === tWire ? sumGate.in2 : sumGate.in1;\n              if (realCarry !== carry) {\n                doSwap(carry, realCarry);\n                carry = realCarry;\n              }\n            }\n          }\n        }\n      }\n\n      if (sumGate && sumGate.out !== z) {\n        doSwap(sumGate.out, z);\n      }\n\n      // Carry computation\n      const genGate = findGate('AND', x, y);\n      if (!genGate) continue;\n      const aWire = genGate.out;\n\n      const propGate = findGate('AND', tWire, carry);\n      let bWire: string | undefined;\n      if (propGate) bWire = propGate.out;\n\n      if (bWire !== undefined) {\n        const carryOutGate = findGate('OR', aWire, bWire);\n        if (carryOutGate) {\n          carry = carryOutGate.out;\n        } else {\n          // Find correct OR gate\n          const bOrCons = consumers(bWire).filter(g => g.op === 'OR');\n          const aOrCons = consumers(aWire).filter(g => g.op === 'OR');\n\n          if (bOrCons.length === 1 && aOrCons.length !== 1) {\n            const g = bOrCons[0];\n            const realA = g.in1 === bWire ? g.in2 : g.in1;\n            if (realA !== aWire) doSwap(aWire, realA);\n            carry = g.out;\n          } else if (aOrCons.length === 1 && bOrCons.length !== 1) {\n            const g = aOrCons[0];\n            const realB = g.in1 === aWire ? g.in2 : g.in1;\n            if (realB !== bWire) doSwap(bWire, realB);\n            carry = g.out;\n          } else if (aOrCons.length === 1 && bOrCons.length === 1) {\n            // Both found. Pick the one whose carry connects to next bit.\n            const aOrGate = aOrCons[0];\n            const bOrGate = bOrCons[0];\n            const aCarry = aOrGate.out;\n            const bCarry = bOrGate.out;\n\n            if (bit === maxBit) {\n              if (aCarry === highestZ) {\n                const realB = aOrGate.in1 === aWire ? aOrGate.in2 : aOrGate.in1;\n                if (realB !== bWire) doSwap(bWire, realB);\n                carry = aCarry;\n              } else if (bCarry === highestZ) {\n                const realA = bOrGate.in1 === bWire ? bOrGate.in2 : bOrGate.in1;\n                if (realA !== aWire) doSwap(aWire, realA);\n                carry = bCarry;\n              }\n            } else {\n              const aOps = consumerOps(aCarry);\n              const bOps = consumerOps(bCarry);\n              if (aOps.has('XOR') && aOps.has('AND')) {\n                const realB = aOrGate.in1 === aWire ? aOrGate.in2 : aOrGate.in1;\n                if (realB !== bWire) doSwap(bWire, realB);\n                carry = aCarry;\n              } else if (bOps.has('XOR') && bOps.has('AND')) {\n                const realA = bOrGate.in1 === bWire ? bOrGate.in2 : bOrGate.in1;\n                if (realA !== aWire) doSwap(aWire, realA);\n                carry = bCarry;\n              }\n            }\n          }\n        }\n      } else {\n        // propGate not found\n        const carryAndCons = consumers(carry).filter(\n          g => g.op === 'AND' && !(isInputXY(g.in1) && isInputXY(g.in2))\n        );\n        if (carryAndCons.length === 1) {\n          bWire = carryAndCons[0].out;\n          const carryOutGate = findGate('OR', aWire, bWire);\n          if (carryOutGate) carry = carryOutGate.out;\n        }\n      }\n\n      // Validate last bit carry\n      if (bit === maxBit && carry && carry !== highestZ) {\n        doSwap(carry, highestZ);\n        carry = highestZ;\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":48,"oldLines":39,"newStart":48,"newLines":15,"lines":[" /**","  * Find 8 swapped output wires in a broken ripple-carry adder circuit.","  *","- * Uses structural rules to identify gates whose outputs violate the","- * expected pattern of a ripple-carry adder. Both rule-based checking","- * (for