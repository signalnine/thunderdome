  // Swap z08 and a07","-    gates = swapOutputs(gates, 'z08', 'a07');","+  it('should handle a 45-bit adder with swaps efficiently', () => {","+    let gates = buildAdder(45);","+    // 4 swaps","+    gates = swapOutputs(gates, 'z10', 'a20');","+    gates = swapOutputs(gates, 'z25', 'b30');","+    gates = swapOutputs(gates, 'c15', 't40');","+    gates = swapOutputs(gates, 'z45', 't44');"," ","+    const start = Date.now();","     const result = findSwappedWires(gates);","-    expect(result).toEqual(['a04', 'a07', 'b04', 'c05', 't02', 'z02', 'z06', 'z08'].sort());","+    const elapsed = Date.now() - start;","+","+    expect(result).toEqual(['a20', 'b30', 'c15', 't40', 't44', 'z10', 'z25', 'z45'].sort());","+    expect(elapsed).toBeLessThan(5000);","   });"," });"]}],"originalFile":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should handle a simple AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n  });\n\n  it('should handle a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0, b: 1, c: 0, d: 0, e: 0,\n    });\n  });\n\n  it('should handle gates listed in reverse dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n\n  it('should simulate a 2-bit adder correctly', () => {\n    // 2-bit adder: X + Y = Z (x00,x01 + y00,y01 = z00,z01,z02)\n    const gates: Gate[] = [\n      // Bit 0: half adder\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1: full adder\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 0 + 0 = 0\n    let result = simulate(gates, { x00: 0, x01: 0, y00: 0, y01: 0 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n\n    // 1 + 1 = 2 (binary: 10)\n    result = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n\n    // 3 + 3 = 6 (binary: 110)\n    result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n\n    // 2 + 1 = 3 (binary: 011)\n    result = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(result.z00).toBe(1);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  /**\n   * Build a correct N-bit ripple-carry adder circuit.\n   * Returns the gates with predictable wire names.\n   */\n  function buildCorrectAdder(bits: number): Gate[] {\n    const gates: Gate[] = [];\n\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < bits; i++) {\n      const pad = i.toString().padStart(2, '0');\n      const x = `x${pad}`;\n      const y = `y${pad}`;\n      const z = `z${pad}`;\n      const t = `t${pad}`;\n      const a = `a${pad}`;\n      const b = `b${pad}`;\n      const c = `c${pad}`;\n      const prevC = `c${(i - 1).toString().padStart(2, '0')}`;\n\n      gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n      gates.push({ op: 'XOR', in1: t, in2: prevC, out: z });\n      gates.push({ op: 'AND', in1: x, in2: y, out: a });\n      gates.push({ op: 'AND', in1: t, in2: prevC, out: b });\n      gates.push({ op: 'OR', in1: a, in2: b, out: c });\n    }\n\n    // Final carry -> highest z bit\n    const lastC = `c${(bits - 1).toString().padStart(2, '0')}`;\n    const lastZ = `z${bits.toString().padStart(2, '0')}`;\n    // We need a gate for this. Use an OR with itself or just pass through.\n    // Actually in a real circuit this would just be a wire, but since we need gates:\n    // The last carry IS the last z. Let's rename.\n    // Actually, re-reading the spec: c_{n-1} -> z_n just means the carry becomes the MSB.\n    // In real circuits, the last OR gate's output IS z_n.\n    // Let's just make the last carry gate output z_n directly.\n    const lastBit = bits - 1;\n    const lastPad = lastBit.toString().padStart(2, '0');\n    // Find and fix the last carry gate\n    const lastCarryGate = gates.find(\n      g => g.op === 'OR' && g.out === `c${lastPad}`\n    );\n    if (lastCarryGate) {\n      lastCarryGate.out = lastZ;\n    }\n\n    return gates;\n  }\n\n  /**\n   * Swap two output wires in the gate list (mutating copies).\n   */\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === wire1) return { ...g, out: wire2 };\n      if (g.out === wire2) return { ...g, out: wire1 };\n      return { ...g };\n    });\n  }\n\n  /**\n   * Verify that the adder produces correct results for several test cases.\n   */\n  function verifyAdder(gates: Gate[], bits: number): boolean {\n    const maxVal = (1 << bits) - 1;\n    const testCases = [\n      [0, 0],\n      [1, 0],\n      [0, 1],\n      [1, 1],\n      [maxVal, 0],\n      [0, maxVal],\n      [maxVal, maxVal],\n      [maxVal, 1],\n    ];\n\n    for (const [x, y] of testCases) {\n      const inputs: Record<string, number> = {};\n      for (let i = 0; i < bits; i++) {\n        const pad = i.toString().padStart(2, '0');\n        inputs[`x${pad}`] = (x >> i) & 1;\n        inputs[`y${pad}`] = (y >> i) & 1;\n      }\n\n      const result = simulate(gates, inputs);\n      const expected = x + y;\n\n      let actual = 0;\n      for (let i = 0; i <= bits; i++) {\n        const pad = i.toString().padStart(2, '0');\n        actual += (result[`z${pad}`] ?? 0) << i;\n      }\n\n      if (actual !== expected) return false;\n    }\n    return true;\n  }\n\n  it('should verify that a correct 4-bit adder works', () => {\n    const gates = buildCorrectAdder(4);\n    expect(verifyAdder(gates, 4)).toBe(true);\n  });\n\n  it('should find swapped wires in a 4-bit adder', () => {\n    let gates = buildCorrectAdder(4);\n    //