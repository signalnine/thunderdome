*\n * For bit 0:\n *   x_0 XOR y_0 -> z_0\n *   x_0 AND y_0 -> c_0\n *\n * We walk through the adder bit by bit, identifying which wires play each role.\n * When a wire doesn't match its expected role, we've found a swap.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped: Set<string> = new Set();\n\n  // Build lookup structures\n  // Map from output wire to gate\n  const outToGate = new Map<string, Gate>();\n  for (const g of gates) {\n    outToGate.set(g.out, g);\n  }\n\n  // Find gate by (op, inputs) regardless of input order\n  const gateByOpInputs = new Map<string, Gate>();\n  for (const g of gates) {\n    const inputs = [g.in1, g.in2].sort();\n    const key = `${g.op}:${inputs[0]}:${inputs[1]}`;\n    gateByOpInputs.set(key, g);\n  }\n\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    const inputs = [in1, in2].sort();\n    const key = `${op}:${inputs[0]}:${inputs[1]}`;\n    return gateByOpInputs.get(key);\n  }\n\n  // Find how many input bits we have\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1]));\n      }\n    }\n  }\n\n  // Helper: check if a wire name is an x or y input wire\n  function isInputWire(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  // For each gate, find gates that use its output as an input\n  function findConsumers(wire: string): Gate[] {\n    return gates.filter(g => g.in1 === wire || g.in2 === wire);\n  }\n\n  // Get the other input of a gate given one input\n  function otherInput(g: Gate, knownInput: string): string {\n    if (g.in1 === knownInput) return g.in2;\n    if (g.in2 === knownInput) return g.in1;\n    throw new Error(`Wire ${knownInput} is not an input of gate outputting ${g.out}`);\n  }\n\n  // The approach: walk through each bit position and validate the structure.\n  // We track the carry wire from the previous bit.\n  // When we find a mismatch, we identify the swap.\n\n  let carry: string | undefined;\n\n  function padBit(n: number): string {\n    return n.toString().padStart(2, '0');\n  }\n\n  for (let bit = 0; bit <= maxBit; bit++) {\n    const xWire = `x${padBit(bit)}`;\n    const yWire = `y${padBit(bit)}`;\n    const zWire = `z${padBit(bit)}`;\n\n    if (bit === 0) {\n      // Bit 0: half adder\n      // x00 XOR y00 -> z00\n      const xorGate = findGate('XOR', xWire, yWire);\n      if (xorGate) {\n        if (xorGate.out !== zWire) {\n          // The XOR gate's output should be z00 but it's swapped\n          swapped.add(xorGate.out);\n          swapped.add(zWire);\n          // We need to also fix our lookup\n          doSwap(xorGate.out, zWire);\n        }\n      }\n      // x00 AND y00 -> c00\n      const andGate = findGate('AND', xWire, yWire);\n      if (andGate) {\n        carry = andGate.out;\n      }\n    } else {\n      // Bit i > 0: full adder\n      // Step 1: find partial sum = x_i XOR y_i -> t_i\n      const xorGate = findGate('XOR', xWire, yWire);\n      if (!xorGate) continue;\n      let tWire = xorGate.out;\n\n      // Step 2: find final sum = t_i XOR carry -> z_i\n      // The z wire should come from an XOR of tWire and carry\n      if (carry === undefined) continue;\n\n      let sumGate = findGate('XOR', tWire, carry);\n\n      if (!sumGate) {\n        // One of tWire or carry might be swapped.\n        // Let's check what the z wire's gate looks like\n        const zGate = outToGate.get(zWire);\n        if (zGate && zGate.op === 'XOR') {\n          // z_i is correctly output by an XOR gate, but the inputs don't match\n          // One of the inputs should be carry, the other should be tWire\n          // Figure out which is wrong\n          const zInputs = [zGate.in1, zGate.in2];\n          if (zInputs.includes(carry)) {\n            // carry is correct, so tWire is wrong - tWire got swapped with the actual input\n            const a