@@ -0,0 +1,236 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+  let changed = true;
+
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find 8 swapped output wires in a broken ripple-carry adder circuit.
+ *
+ * Uses structural walking through the adder bit by bit, fixing swaps as they
+ * are detected, combined with rule-based validation.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped: Set<string> = new Set();
+
+  // Find max input bit
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));
+    }
+  }
+
+  function pad(n: number): string {
+    return n.toString().padStart(2, '0');
+  }
+
+  const highestZ = `z${pad(maxBit + 1)}`;
+
+  function isZWire(w: string): boolean {
+    return /^z\d+$/.test(w);
+  }
+
+  function isInputXY(w: string): boolean {
+    return /^[xy]\d+$/.test(w);
+  }
+
+  function hasInputXY(g: Gate): boolean {
+    return isInputXY(g.in1) || isInputXY(g.in2);
+  }
+
+  function isBit0(g: Gate): boolean {
+    return (g.in1 === 'x00' || g.in2 === 'x00') && (g.in1 === 'y00' || g.in2 === 'y00');
+  }
+
+  // Rule-based detection on ORIGINAL gates (read-only)
+  function getConsumerOps(wire: string): Set<string> {
+    return new Set(
+      gates.filter(g => g.in1 === wire || g.in2 === wire).map(g => g.op)
+    );
+  }
+
+  for (const gate of gates) {
+    const { op, out } = gate;
+
+    if (op === 'XOR') {
+      if (hasInputXY(gate)) {
+        if (isBit0(gate)) {
+          if (out !== 'z00') {
+            swapped.add(out);
+            swapped.add('z00');
+          }
+        } else {
+          if (isZWire(out)) {
+            swapped.add(out);
+          }
+        }
+      } else {
+        if (!isZWire(out)) {
+          swapped.add(out);
+        }
+      }
+    } else if (op === 'AND') {
+      if (!isBit0(gate)) {
+        const ops = getConsumerOps(out);
+        if (!ops.has('OR')) {
+          swapped.add(out);
+        }
+      }
+    } else if (op === 'OR') {
+      if (out === highestZ) {
+        // Final carry → highest z: OK
+      } else if (isZWire(out)) {
+        // Non-final carry should NOT be a z wire
+        swapped.add(out);
+      } else {
+        // Non-final carry should feed into both XOR and AND
+        const ops = getConsumerOps(out);
+        if (!ops.has('XOR') || !ops.has('AND')) {
+          swapped.add(out);
+        }
+      }
+    }
+  }
+
+  // Additional rule: bit 0 carry should feed XOR and AND
+  {
+    const bit0And = gates.find(g => g.op === 'AND' && isBit0(g));
+    if (bit0And) {
+      const ops = getConsumerOps(bit0And.out);
+      if (!ops.has('XOR') || !ops.has('AND')) {
+        swapped.add(bit0And.out);
+      }
+    }
+  }
+
+  // Additional rule: for each XOR with x/y inputs (non-bit-0), its output
+  // should feed into both an XOR and an AND gate
+  for (const gate of gates) {
+    if (gate.op === 'XOR' && hasInputXY(gate) && !isBit0(gate)) {
+      const ops = getConsumerOps(gate.out);
+      if (!ops.has('XOR') || !ops.has('AND')) {
+        swapped.add(gate.out);
+      }
+    }
+  }
+
+  // Additional rule: highest z should be produced by the last-bit's OR gate.
+  // We use two complementary strategies:
+  //
+  // Strategy A: Trace forward from AND(x_maxBit, y_maxBit) to find the last-bit
+  // OR gate. This works when the AND gate's output is NOT itself swapped (the OR
+  // gate's inputs still match the AND gate's current output).
+  //
+  // Strategy B: When highestZ is produced by a non-OR gate, trace backward from
+  // that gate to find the swap partner. This handles cases where the AND gate's
+  // output IS swapped, breaking the forward trace.
+  {
+    const lastX = `x${pad(maxBit)}`;
+    const lastY = `y${pad(maxBit)}`;
+    const lastGenGate = gates.find(
+      g => g.op === 'AND' &&
+      ((g.in1 === lastX && g.in2 === lastY) || (g.in1 === lastY && g.in2 === lastX))
+    );
+
+    // Strategy A: trace forward from lastGenGate
+    if (lastGenGate) {
+      const correctLastOR = gates.find(
+        g => g.op === 'OR' && (g.in1 === lastGenGate.out || g.in2 === lastGenGate.out)
+      );
+      if (correctLastOR && correctLastOR.out !== highestZ) {
+        swapped.add(highestZ);
+        swapped.add(correctLastOR.out);
+      }
+    }
+
+    // Strategy B: if highestZ is produced by a non-OR gate, it's swapped.
+    // Find the swap partner by examining the non-OR gate's structural role.
+    const highestZGate = gates.find(g => g.out === highestZ);
+    if (highestZGate && highestZGate.op !== 'OR') {
+      swapped.add(highestZ);
+
+      // If Strategy A already found the partner, we're done.
+      // Otherwise, we need to find it by examining what wire the highestZ-producing
+      // gate should output. Its consumers still reference the original wire name.
+      let partnerFound = false;
+      if (lastGenGate) {
+        const correctLastOR = gates.find(
+          g => g.op === 'OR' && (g.in1 === lastGenGate.out || g.in2 === lastGenGate.out)
+        );
+        if (correctLastOR && correctLastOR.out !== highestZ) {
+          partnerFound = true; // Already handled by Strategy A
+        }
+      }
+
+      if (!partnerFound && highestZGate.op === 'XOR' && hasInputXY(highestZGate)) {
+        // G is a half-sum XOR for some bit i. Find bit i from inputs.
+        const xInput = [highestZGate.in1, highestZGate.in2].find(w => w.startsWith('x'));
+        if (xInput) {
+          const bitNum = parseInt(xInput.slice(1));
+          const expectedZ = `z${pad(bitNum)}`;
+          // Find the sum-XOR for bit i that produces z_i
+          const sumXOR = gates.find(
+            g => g.op === 'XOR' && !hasInputXY(g) && g.out === expectedZ
+          );
+          if (sumXOR) {
+            // One of sumXOR's inputs is the half-sum wire (the expected output of G).
+            // That wire is now produced by the last-bit OR (the swap partner).
+            // Identify it: the input produced by an OR gate is the swap partner.
+            for (const inp of [sumXOR.in1, sumXOR.in2]) {
+              const producer = gates.find(g => g.out === inp);
+              if (producer && producer.op === 'OR') {
+                swapped.add(inp);
+                break;
+              }
+            }
+          }
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
