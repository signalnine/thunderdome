Gate[], wire1: string, wire2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === wire1) return { ...g, out: wire2 };\n      if (g.out === wire2) return { ...g, out: wire1 };\n      return { ...g };\n    });\n  }\n\n  /**\n   * Verify that the adder produces correct results for several test cases.\n   */\n  function verifyAdder(gates: Gate[], bits: number): boolean {\n    const maxVal = (1 << bits) - 1;\n    const testCases = [\n      [0, 0],\n      [1, 0],\n      [0, 1],\n      [1, 1],\n      [maxVal, 0],\n      [0, maxVal],\n      [maxVal, maxVal],\n      [maxVal, 1],\n    ];\n\n    for (const [x, y] of testCases) {\n      const inputs: Record<string, number> = {};\n      for (let i = 0; i < bits; i++) {\n        const pad = i.toString().padStart(2, '0');\n        inputs[`x${pad}`] = (x >> i) & 1;\n        inputs[`y${pad}`] = (y >> i) & 1;\n      }\n\n      const result = simulate(gates, inputs);\n      const expected = x + y;\n\n      let actual = 0;\n      for (let i = 0; i <= bits; i++) {\n        const pad = i.toString().padStart(2, '0');\n        actual += (result[`z${pad}`] ?? 0) << i;\n      }\n\n      if (actual !== expected) return false;\n    }\n    return true;\n  }\n\n  it('should verify that a correct 4-bit adder works', () => {\n    const gates = buildCorrectAdder(4);\n    expect(verifyAdder(gates, 4)).toBe(true);\n  });\n\n  it('should find swapped wires in a 4-bit adder', () => {\n    let gates = buildCorrectAdder(4);\n    // Swap z01 and a01\n    gates = swapOutputs(gates, 'z01', 'a01');\n    // Swap t02 and b03\n    gates = swapOutputs(gates, 't02', 'b03');\n    // Swap z03 and c02\n    gates = swapOutputs(gates, 'z03', 'c02');\n    // Swap c03 (which is z04) and a03\n    gates = swapOutputs(gates, 'z04', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'b03', 'c02', 't02', 'z01', 'z03', 'z04'].sort());\n  });\n\n  it('should find swapped wires in a larger adder', () => {\n    let g