n    gateByOpInputs.clear();\n    for (const g of gatesCopy) {\n      outToGate.set(g.out, g);\n      const ins = [g.in1, g.in2].sort();\n      gateByOpInputs.set(`${g.op}:${ins[0]}:${ins[1]}`, g);\n    }\n  }\n  rebuildLookups();\n\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    const ins = [in1, in2].sort();\n    return gateByOpInputs.get(`${op}:${ins[0]}:${ins[1]}`);\n  }\n\n  // Find max input bit\n  let maxBit = 0;\n  for (const g of gatesCopy) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));\n    }\n  }\n\n  function pad(n: number): string {\n    return n.toString().padStart(2, '0');\n  }\n\n  const highestZ = `z${pad(maxBit + 1)}`;\n\n  function isZWire(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function consumers(wire: string): Gate[] {\n    return gatesCopy.filter(g => g.in1 === wire || g.in2 === wire);\n  }\n\n  function doSwap(a: string, b: string): void {\n    if (a === b) return;\n    swapped.add(a);\n    swapped.add(b);\n    for (const g of gatesCopy) {\n      if (g.out === a) g.out = b;\n      else if (g.out === b) g.out = a;\n    }\n    rebuildLookups();\n  }\n\n  // Walk through the adder bit by bit\n  let carry: string | undefined;\n\n  for (let bit = 0; bit <= maxBit; bit++) {\n    const x = `x${pad(bit)}`;\n    const y = `y${pad(bit)}`;\n    const z = `z${pad(bit)}`;\n\n    if (bit === 0) {\n      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> c00\n      const xorGate = findGate('XOR', x, y);\n      if (xorGate && xorGate.out !== z) {\n        doSwap(xorGate.out, z);\n      }\n      const andGate = findGate('AND', x, y);\n      if (andGate) {\n        carry = andGate.out;\n      }\n    } else {\n      if (carry === undefined) continue;\n\n      // Full adder: 5 gates per bit\n      // 1. Partial sum: x_i XOR y_i -> t_i\n      const partialXor = findGate('XOR', x, y);\n      if (!partialXor) continue;\n      let tWire = partialXor.out;\n\n      // Rule: tWire should NOT be a z wire (partial sums are internal)\n      if (isZWire(tWire)) {\n        // tWire is a z wire — wrong. The gate that should produce this z\n        // wire had its output swapped with tWire.\n        // Find the real z wire producer by looking at what uses carry.\n        const carryXorConsumers = consumers(carry).filter(g => g.op === 'XOR');\n        if (carryXorConsumers.length >= 1) {\n          // The sum XOR uses carry; its other input should be the real tWire\n          const candidate = carryXorConsumers[0];\n          const realT = candidate.in1 === carry ? candidate.in2 : candidate.in1;\n          doSwap(tWire, realT);\n          tWire = realT;\n        }\n      }\n\n      // 2. Final sum: t_i XOR carry -> z_i\n      let sumGate = findGate('XOR', tWire, carry);\n\n      if (!sumGate) {\n        // Sum gate not found. Either tWire or carry is swapped.\n        // Strategy: find the gate that produces z_i and work backwards.\n        const zGate = outToGate.get(z);\n        if (zGate && zGate.op === 'XOR') {\n          // z_i is produced by an XOR gate — but wrong inputs\n          const gateInputs = [zGate.in1, zGate.in2];\n          if (gateInputs.includes(carry)) {\n            // carry is correct; tWire is wrong\n            const realT = gateInputs[0] === carry ? gateInputs[1] : gateInputs[0];\n            doSwap(tWire, realT);\n            tWire = realT;\n            sumGate = zGate;\n          } else if (gateInputs.includes(tWire)) {\n            // tWire is correct; carry is wrong\n            const realCarry = gateInputs[0] === tWire ? gateInputs[1] : gateInputs[0];\n            doSwap(carry, realCarry);\n            carry = realCarry;\n            sumGate = zGate;\n          } else {\n            // Neither match — both might be wrong, or the z gate is wrong\n            // Fall through to carry-based search\n          }\n        }\n\n        if (!sumGate) {\n          // z_i is NOT produced by an XOR, or couldn't fix from z gate\n          // Find XOR that uses carry (non-input XOR)\n          const carryXorConsumers = consumers(carry).filter(g => {\n            if (g.op !== 'XOR') return false;\n            const ins = [g.in1, g.in2];\n            return !(ins.every(w => /^[xy]\\d+$/.test(w)));\n          });\n          if (carryXorConsumers.length === 1) {\n            sumGate = carryXorConsumers[0];\n            const otherIn = sumGate.in1 === carry ? sumGate.in2 : sumGate.in1;\n            if (otherIn !== tWire) {\n              doSwap(tWire, otherIn);\n              tWire = otherIn;\n            }\n          } else if (carryXorConsumers.length === 0) {\n            // Carry has no XOR consumer — carry itself might be disconnected\n            // Look at what tWire's XOR consumer expects\n            const tXorConsumers = consumers(tWire).filter(g => g.op === 'XOR');\n            if (tXorConsumers.length === 1) {\n              sumGate = tXorConsumers[0];\n              const realCarry = sumGate.in1 === tWire ? sumGate.in2 : sumGate.in1;\n              if (realCarry !== carry) {\n                doSwap(carry, realCarry);\n                carry = realCarry;\n              }\n            }\n          }\n        }\n      }\n\n      // Verify sumGate outputs z_i\n      if (sumGate && sumGate.out !== z) {\n        doSwap(sumGate.out, z);\n      }\n\n      // 3. Generate carry: x_i AND y_i -> a_i\n      const genGate = findGate('AND', x, y);\n      if (!genGate) continue;\n      const aWire = genGate.out;\n\n      // 4. Propagate carry: t_i AND carry -> b_i\n      const propGate = findGate('AND', tWire, carry);\n      let bWire: string | undefined;\n      if (propGate) {\n        bWire = propGate.out;\n      }\n\n      // 5. Carry out: a_i OR b_i -> c_i\n      if (bWire !== undefined) {\n        const carryOutGate = findGate('OR', aWire, bWire);\n        if (carryOutGate) {\n          carry = carryOutGate.out;\n        } else {\n          // OR(aWire, bWire) doesn't exist.\n          // bWire is reliable (from AND(tWire, carry) which we traced).\n          // aWire might be swapped.\n          const bOrConsumers = consumers(bWire).filter(g => g.op === 'OR');\n          if (bOrConsumers.length === 1) {\n            const g = bOrConsumers[0];\n            const realA = g.in1 === bWire ? g.in2 : g.in1;\n            if (realA !== aWire) {\n              doSwap(aWire, realA);\n            }\n            carry = g.out;\n          } else {\n            // Try aWire\n            const aOrConsumers = consumers(aWire).filter(g => g.op === 'OR');\n            if (aOrConsumers.length === 1) {\n              const g = aOrConsumers[0];\n              const realB = g.in1 === aWire ? g.in2 : g.in1;\n              if (realB !== bWire) {\n                doSwap(bWire, realB);\n              }\n              carry = g.out;\n            }\n          }\n        }\n      } else {\n        // propGate not found (AND(tWire, carry) doesn't exist)\n        // This shouldn't happen if tWire and carry are correct.\n        // Try to find the AND consumer of carry that's not an x/y AND\n        const carryAndConsumers = consumers(carry).filter(\n          g => g.op === 'AND' && !(\n            /^[xy]\\d+$/.test(g.in1) && /^[xy]\\d+$/.test(g.in2)\n          )\n        );\n        if (carryAndConsumers.length === 1) {\n          bWire = carryAndConsumers[0].out;\n          const carryOutGate = findGate('OR', aWire, bWire);\n          if (carryOutGate) {\n            carry = carryOutGate.out;\n          }\n        }\n      }\n\n      // Validate carry for the last bit\n      if (bit === maxBit) {\n        if (carry && carry !== highestZ) {\n          doSwap(carry, highestZ);\n          carry = highestZ;\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":48,"oldLines":8,"newStart":48,"newLines":9,"lines":[" /**","  * Find 8 swapped output wires in a broken ripple-carry adder cir