theOtherInput);\n              tWire = theOtherInput;\n              sumGate = g;\n              // Also check if this gate's output is z\n              if (g.out !== zWire) {\n                swapped.add(g.out);\n                swapped.add(zWire);\n                doSwap(g.out, zWire);\n              }\n            }\n          } else {\n            // Check consumers of tWire\n            const tConsumers = findConsumers(tWire);\n            const tXorConsumers = tConsumers.filter(g => g.op === 'XOR');\n            if (tXorConsumers.length === 1) {\n              const g = tXorConsumers[0];\n              const theOtherInput = otherInput(g, tWire);\n              // theOtherInput should be carry but isn't\n              swapped.add(carry);\n              swapped.add(theOtherInput);\n              doSwap(carry, theOtherInput);\n              carry = theOtherInput;\n              sumGate = g;\n              if (g.out !== zWire) {\n                swapped.add(g.out);\n                swapped.add(zWire);\n                doSwap(g.out, zWire);\n              }\n            }\n          }\n        }\n      }\n\n      if (sumGate) {\n        // Check that sum gate outputs to z wire\n        if (sumGate.out !== zWire) {\n          swapped.add(sumGate.out);\n          swapped.add(zWire);\n          doSwap(sumGate.out, zWire);\n        }\n      }\n\n      // Step 3: compute carry out\n      // a_i = x_i AND y_i (generate)\n      const genGate = findGate('AND', xWire, yWire);\n      if (!genGate) continue;\n      const aWire = genGate.out;\n\n      // b_i = t_i AND carry (propagate)\n      const propGate = findGate('AND', tWire, carry);\n      let bWire: string | undefined;\n      if (propGate) {\n        bWire = propGate.out;\n      }\n\n      // c_i = a_i OR b_i (carry out)\n      if (bWire !== undefined) {\n        const carryGate = findGate('OR', aWire, bWire);\n        if (carryGate) {\n          carry = carryGate.out;\n        } else {\n          // Try to find the OR gate that uses one of aWire/bWire\n          const aConsumers = findConsumers(aWire).filter(g => g.op === 'OR');\n          if (aConsumers.length === 1) {\n            const g = aConsumers[0];\n            const other = otherInput(g, aWire);\n            if (other !== bWire) {\n              swapped.add(bWire);\n              swapped.add(other);\n              doSwap(bWire, other);\n              bWire = other;\n            }\n            carry = g.out;\n          } else {\n            const bConsumers = findConsumers(bWire).filter(g => g.op === 'OR');\n            if (bConsumers.length === 1) {\n              const g = bConsumers[0];\n              const other = otherInput(g, bWire);\n              if (other !== aWire) {\n                swapped.add(aWire);\n                swapped.add(other);\n                doSwap(aWire, other);\n              }\n              carry = g.out;\n            }\n          }\n        }\n      } else {\n        // Propagate gate not found, carry might be wrong or tWire wrong\n        // Try to find AND gate that uses carry\n        const currentCarry = carry;\n        const carryAndConsumers = findConsumers(currentCarry).filter(g => g.op === 'AND' && !isInputWire(otherInput(g, currentCarry)));\n        if (carryAndConsumers.length === 1) {\n          bWire = carryAndConsumers[0].out;\n          // Find carry out from OR of aWire and bWire\n          const carryGate = findGate('OR', aWire, bWire);\n          if (carryGate) {\n            carry = carryGate.out;\n          }\n        }\n      }\n    }\n  }\n\n  // The final carry should be the highest z wire\n  const finalZ = `z${padBit(maxBit + 1)}`;\n  if (carry && carry !== finalZ) {\n    // Check if the carry wire should be the final z\n    // Only flag if we haven't already swapped enough\n    if (swapped.size < 8) {\n      swapped.add(carry);\n      swapped.add(finalZ);\n    }\n  }\n\n  function doSwap(a: string, b: string): void {\n    // Swap the output wires in our lookup structures\n    const gateA = outToGate.get(a);\n    const gateB = outToGate.get(b);\n    if (gateA && gateB) {\n      gateA.out = b;\n      gateB.out = a;\n      outToGate.set(a, gateB);\n      outToGate.set(b, gateA);\n      // Update gateByOpInputs\n      const inputsA = [gateA.in1, gateA.in2].sort();\n      const inputsB = [gateB.in1, gateB.in2].sort();\n      gateByOpInputs.set(`${gateA.op}:${inputsA[0]}:${inputsA[1]}`, gateA);\n      gateByOpInputs.set(`${gateB.op}:${inputsB[0]}:${inputsB[1]}`, gateB);\n    }\n  }\n\n  return [...swapped].sort();\n}\n"}}
