gates per bit\n      // 1. Partial sum: x_i XOR y_i -> t_i\n      const partialXor = findGate('XOR', x, y);\n      if (!partialXor) continue;\n      let tWire = partialXor.out;\n\n      // Rule: tWire should NOT be a z wire (partial sums are internal)\n      if (isZWire(tWire)) {\n        // tWire is a z wire — wrong. The gate that should produce this z\n        // wire had its output swapped with tWire.\n        // Find the real z wire producer by looking at what uses carry.\n        const carryXorConsumers = consumers(carry).filter(g => g.op === 'XOR');\n        if (carryXorConsumers.length >= 1) {\n          // The sum XOR uses carry; its other input should be the real tWire\n          const candidate = carryXorConsumers[0];\n          const realT = candidate.in1 === carry ? candidate.in2 : candidate.in1;\n          doSwap(tWire, realT);\n          tWire = realT;\n        }\n      }\n\n      // 2. Final sum: t_i XOR carry -> z_i\n      let sumGate = findGate('XOR', tWire, carry);\n\n      if (!sumGate) {\n        // Sum gate not found. Either tWire or carry is swapped.\n        // Strategy: find the gate that produces z_i and work backwards.\n        const zGate = outToGate.get(z);\n        if (zGate && zGate.op === 'XOR') {\n          // z_i is produced by an XOR gate — but wrong inputs\n          const gateInputs = [zGate.in1, zGate.in2];\n          if (gateInputs.includes(carry)) {\n            // carry is correct; tWire is wrong\n            const realT = gateInputs[0] === carry ? gateInputs[1] : gateInputs[0];\n            doSwap(tWire, realT);\n            tWire = realT;\n            sumGate = zGate;\n          } else if (gateInputs.includes(tWire)) {\n            // tWire is correct; carry is wrong\n            const realCarry = gateInputs[0] === tWire ? gateInputs[1] : gateInputs[0];\n            doSwap(carry, realCarry);\n            carry = realCarry;\n            sumGate = zGate;\n          } else {\n            // Neither match — both might be wrong, 