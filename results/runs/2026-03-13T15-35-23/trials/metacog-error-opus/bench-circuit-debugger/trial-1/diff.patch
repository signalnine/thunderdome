ngth === 1) {\n            const g = aOrConsumers[0];\n            const other = g.in1 === aWire ? g.in2 : g.in1;\n            if (other !== bWire) {\n              doSwap(bWire, other);\n            }\n            carry = g.out;\n          } else {\n            // Try bWire\n            const bOrConsumers = consumers(bWire).filter(g => g.op === 'OR');\n            if (bOrConsumers.length === 1) {\n              const g = bOrConsumers[0];\n              const other = g.in1 === bWire ? g.in2 : g.in1;\n              if (other !== aWire) {\n                doSwap(aWire, other);\n              }\n              carry = g.out;\n            }\n          }\n        }\n      } else {\n        // propGate not found — this means either tWire or carry name changed\n        // after our earlier fixes, or the AND's output is wrong\n        // Try to find the AND that uses carry (but not x/y inputs)\n        const carryAndConsumers = consumers(carry).filter(\n          g => g.op === 'AND' && !(\n            /^[xy]\\d+$/.test(g.in1) && /^[xy]\\d+$/.test(g.in2)\n          )\n        );\n        if (carryAndConsumers.length === 1) {\n          bWire = carryAndConsumers[0].out;\n          const carryOutGate = findGate('OR', aWire, bWire);\n          if (carryOutGate) {\n            carry = carryOutGate.out;\n          }\n        }\n      }\n\n      // Validate carry: for non-last bits, carry should feed into XOR and AND\n      // For the last bit, carry should be highestZ\n      if (bit === maxBit) {\n        if (carry !== highestZ) {\n          // The carry should be the highest z but isn't\n          if (carry && swapped.size < 8) {\n            doSwap(carry, highestZ);\n            carry = highestZ;\n          }\n        }\n      } else if (carry) {\n        const ops = consumerOps(carry);\n        // Carry should feed XOR and AND for the next bit\n        if (!ops.has('XOR') && !ops.has('AND')) {\n          // This carry is completely disconnected — it's been swapped\n          //