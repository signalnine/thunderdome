it: carry out is the highest z wire\n        gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `z${(bits).toString().padStart(2, '0')}` });\n      } else {\n        gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });\n      }\n    }\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], w1: string, w2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === w1) return { ...g, out: w2 };\n      if (g.out === w2) return { ...g, out: w1 };\n      return { ...g };\n    });\n  }\n\n  it('should find swapped wires: z wire swapped with internal XOR output', () => {\n    // Swap z01 (final sum output) with t02 (partial sum)\n    // z01: comes from XOR(t01, c00), t02: comes from XOR(x02, y02)\n    // After swap: XOR(t01,c00)->t02 and XOR(x02,y02)->z01\n    // Rule: final sum XOR should output z wire -> t02 flagged\n    // Rule: partial sum XOR (non-bit0) should not output z wire -> z01 flagged\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 'z01', 't02');\n    // Swap z03 with a05 (AND generate)\n    gates = swapOutputs(gates, 'z03', 'a05');\n    // Swap c04 (OR carry) with b06 (AND propagate)\n    gates = swapOutputs(gates, 'c04', 'b06');\n    // Swap z08 (highest z = carry out) with t07 (partial sum)\n    gates = swapOutputs(gates, 'z08', 't07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a05', 'b06', 'c04', 't02', 't07', 'z01', 'z03', 'z08'].sort());\n  });\n\n  it('should find swapped wires in a 4-bit adder', () => {\n    let gates = buildAdder(4);\n    // Swap z01 with a01 (AND -> z wire)\n    gates = swapOutputs(gates, 'z01', 'a01');\n    // Swap t02 with c01 (partial XOR output with carry)\n    gates = swapOutputs(gates, 't02', 'c01');\n    // Swap z03 with b03 (z wire with propagate AND)\n    gates = swapOutputs(gates, 'z03', 'b03');\n    // Swap z04 (final carry = OR output) with t03 (partial sum)\n    gates = swapOutputs(gates, 'z04', 't03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b03', 'c01', 't02', 't03', 'z01', 'z03', 'z04'].sort());\n  });\n\n  it('should handle a 45-bit adder with swaps efficiently', () => {\n    let gates = buildAdder(45);\n    // 4 swaps\n    gates = swapOutputs(gates, 'z10', 'a20');\n    gates = swapOutputs(gates, 'z25', 'b30');\n    gates = swapOutputs(gates, 'c15', 't40');\n    gates = swapOutputs(gates, 'z45', 't44');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(result).toEqual(['a20', 'b30', 'c15', 't40', 't44', 'z10', 'z25', 'z45'].sort());\n    expect(elapsed).toBeLessThan(5000);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":107,"cache_read_input_tokens":44490,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":107},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3718bd19-0ddf-4b76-8212-0c47cbec5f2b","uuid":"47482e18-5827-4050-bc86-f634d9fe8cf2"}
