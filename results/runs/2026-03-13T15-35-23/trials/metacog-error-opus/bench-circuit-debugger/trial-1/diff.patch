s(t1Gate.out).filter(g => g.op === 'XOR');\n              if (sumConsumers.length === 1) {\n                const actualCarry = sumConsumers[0].in1 === t1Gate.out\n                  ? sumConsumers[0].in2\n                  : sumConsumers[0].in1;\n                if (actualCarry !== carry) {\n                  doSwap(carry, actualCarry);\n                  carry = actualCarry;\n                }\n              }\n            }\n          }\n        }\n      }\n    } else {\n      if (carry === undefined) continue;\n\n      // Validate carry: for bit 1, carry should come from AND(x00,y00).\n      // For bit > 1, carry should come from OR gate.\n      // If it comes from the wrong gate type, it's been swapped.\n      const carryGateProducer = outToGate.get(carry);\n      if (carryGateProducer) {\n        const expectedOp = bit === 1 ? 'AND' : 'OR';\n        if (carryGateProducer.op !== expectedOp) {\n          // The carry wire is produced by the wrong gate type — it's been swapped\n          // with the partial sum of some bit (which comes from XOR).\n          // We need to find the real carry.\n          // The real carry should be produced by the expected op and should feed\n          // into the sum XOR for this bit (which also takes the partial sum).\n          // The partial sum for this bit = XOR(x_i, y_i).\n          const partialXorCheck = findGate('XOR', x, y);\n          if (partialXorCheck) {\n            const tCheck = partialXorCheck.out;\n            // Find XOR gate that uses tCheck — its other input should be the real carry\n            const tXorConsumers = consumers(tCheck).filter(g => g.op === 'XOR');\n            if (tXorConsumers.length === 1) {\n              const realCarry = tXorConsumers[0].in1 === tCheck\n                ? tXorConsumers[0].in2\n                : tXorConsumers[0].in1;\n              if (realCarry !== carry) {\n                doSwap(carry, realCarry);\n                carry = realCarry;\n              }\n            }\n      