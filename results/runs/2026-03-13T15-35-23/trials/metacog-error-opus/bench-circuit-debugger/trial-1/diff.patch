 of structural rules and bit-by-bit walking to identify\n * gates whose outputs violate the expected pattern of a ripple-carry adder.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Work on copies so we can fix swaps as we find them\n  const gatesCopy: Gate[] = gates.map(g => ({ ...g }));\n  const swapped: Set<string> = new Set();\n\n  // Build lookup structures\n  function rebuildLookups() {\n    outToGate.clear();\n    gateByOpInputs.clear();\n    for (const g of gatesCopy) {\n      outToGate.set(g.out, g);\n      const inputs = [g.in1, g.in2].sort();\n      gateByOpInputs.set(`${g.op}:${inputs[0]}:${inputs[1]}`, g);\n    }\n  }\n\n  const outToGate = new Map<string, Gate>();\n  const gateByOpInputs = new Map<string, Gate>();\n  rebuildLookups();\n\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    const inputs = [in1, in2].sort();\n    return gateByOpInputs.get(`${op}:${inputs[0]}:${inputs[1]}`);\n  }\n\n  // Find max input bit\n  let maxBit = 0;\n  for (const g of gatesCopy) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1]));\n      }\n    }\n  }\n\n  function pad(n: number): string {\n    return n.toString().padStart(2, '0');\n  }\n\n  const highestZ = `z${pad(maxBit + 1)}`;\n\n  function isZWire(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function consumers(wire: string): Gate[] {\n    return gatesCopy.filter(g => g.in1 === wire || g.in2 === wire);\n  }\n\n  function consumerOps(wire: string): Set<string> {\n    return new Set(consumers(wire).map(g => g.op));\n  }\n\n  function doSwap(a: string, b: string): void {\n    swapped.add(a);\n    swapped.add(b);\n    // Actually swap the output wires in gatesCopy\n    for (const g of gatesCopy) {\n      if (g.out === a) g.out = b;\n      else if (g.out === b) g.out = a;\n    }\n    rebuildLookups();\n  }\n\n  // Walk through the adder bit by bit, tracing the expected structure.\n  // At each bit, we know what gates should exist and what their outputs should look like.\n  let carry: string | undefined;\n\n  for (let bit = 0; bit <= maxBit; bit++) {\n    const x = `x${pad(bit)}`;\n    const y = `y${pad(bit)}`;\n    const z = `z${pad(bit)}`;\n\n    if (bit === 0) {\n      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> c00\n      const xorGate = findGate('XOR', x, y);\n      if (xorGate && xorGate.out !== z) {\n        doSwap(xorGate.out, z);\n      }\n      const andGate = findGate('AND', x, y);\n      if (andGate) {\n        carry = andGate.out;\n        // Validate carry: it should feed into XOR and AND (the next bit's sum and propagate)\n        // If it feeds into OR, it's been swapped with something\n        if (maxBit > 0) {\n          const ops = consumerOps(carry);\n          if (ops.has('OR') && !ops.has('XOR')) {\n            // carry has been swapped — find what it should be\n            // The correct carry should feed XOR and AND\n            // Look at the XOR for bit 1: it uses x01 XOR y01 -> t01, then t01 XOR carry -> z01\n            // The partial sum for bit 1:\n            const t1Gate = findGate('XOR', `x${pad(1)}`, `y${pad(1)}`);\n            if (t1Gate) {\n              // Find the sum XOR that uses t1Gate.out\n              const sumConsumers = consumers(t1Gate.out).filter(g => g.op === 'XOR');\n              if (sumConsumers.length === 1) {\n                const actualCarry = sumConsumers[0].in1 === t1Gate.out\n                  ? sumConsumers[0].in2\n                  : sumConsumers[0].in1;\n                if (actualCarry !== carry) {\n                  doSwap(carry, actualCarry);\n                  carry = actualCarry;\n                }\n              }\n            }\n          }\n        }\n      }\n    } else {\n      if (carry === undefined) continue;\n\n      // Full adder for bit > 0:\n      // 1. Partial sum: x_i XOR y_i -> t_i\n      const partialXor = findGate('XOR', x, y);\n      if (!partialXor) continue;\n      let tWire = partialXor.out;\n\n      // Validate: tWire should NOT be a z wire (for non-bit-0)\n      if (isZWire(tWire)) {\n        // tWire is a z wire — it's been swapped\n        // The real z wire for this bit should come from the sum XOR\n        // We need to find what wire should be here\n        // Look for an XOR that uses carry as input\n        const carryXorConsumers = consumers(carry).filter(g => g.op === 'XOR');\n        if (carryXorConsumers.length === 1) {\n          const otherInput = carryXorConsumers[0].in1 === carry\n            ? carryXorConsumers[0].in2\n            : carryXorConsumers[0].in1;\n          // otherInput should be the real tWire\n          doSwap(tWire, otherInput);\n          tWire = otherInput;\n        } else {\n          // Multiple or no XOR consumers of carry — try to find what z maps to\n          const zGate = outToGate.get(z);\n          if (zGate) {\n            doSwap(tWire, z);\n            tWire = z;\n          }\n        }\n      }\n\n      // 2. Final sum: t_i XOR carry -> z_i\n      let sumGate = findGate('XOR', tWire, carry);\n\n      if (!sumGate) {\n        // Can't find the sum gate. One of tWire or carry is wrong.\n        // Check: what gate produces z_i?\n        const zGate = outToGate.get(z);\n        if (zGate && zGate.op === 'XOR') {\n          // z is correctly an XOR output. Check its inputs.\n          const inputs = [zGate.in1, zGate.in2];\n          if (inputs.includes(carry) && !inputs.includes(tWire)) {\n            // carry is right, tWire is wrong\n            const realT = inputs[0] === carry ? inputs[1] : inputs[0];\n            doSwap(tWire, realT);\n            tWire = realT;\n            sumGate = zGate;\n          } else if (inputs.includes(tWire) && !inputs.includes(carry)) {\n            // tWire is right, carry is wrong\n            const realCarry = inputs[0] === tWire ? inputs[1] : inputs[0];\n            doSwap(carry, realCarry);\n            carry = realCarry;\n            sumGate = zGate;\n          }\n        } else {\n          // z is not produced by an XOR, or z gate not found\n          // Find the XOR gate that uses carry and something\n          const carryXorConsumers = consumers(carry).filter(g => g.op === 'XOR');\n          // One of them should be the partial sum XOR (which uses x_i and y_i), skip that\n          const sumCandidates = carryXorConsumers.filter(g => {\n            const inputs = [g.in1, g.in2];\n            return !(/^[xy]\\d+$/.test(inputs[0]) && /^[xy]\\d+$/.test(inputs[1]));\n          });\n          if (sumCandidates.length === 1) {\n            sumGate = sumCandidates[0];\n            // Check if its other input is tWire\n            const otherIn = sumGate.in1 === carry ? sumGate.in2 : sumGate.in1;\n            if (otherIn !== tWire) {\n              doSwap(tWire, otherIn);\n              tWire = otherIn;\n            }\n          }\n        }\n      }\n\n      if (sumGate && sumGate.out !== z) {\n        doSwap(sumGate.out, z);\n      }\n\n      // 3. Generate carry: x_i AND y_i -> a_i\n      const genGate = findGate('AND', x, y);\n      if (!genGate) continue;\n      const aWire = genGate.out;\n\n      // 4. Propagate carry: t_i AND carry -> b_i\n      const propGate = findGate('AND', tWire, carry);\n      let bWire: string | undefined;\n      if (propGate) {\n        bWire = propGate.out;\n      }\n\n      // 5. Carry out: a_i OR b_i -> c_i\n      if (bWire !== undefined) {\n        const carryOutGate = findGate('OR', aWire, bWire);\n        if (carryOutGate) {\n          carry = carryOutGate.out;\n        } else {\n          // One of aWire or bWire might be swapped\n          // Find the OR that uses aWire\n          const aOrConsumers = consumers(aWire).filter(g => g.op === 'OR');\n          if (aOrConsumers.length === 1) {\n            const g = aOrConsumers[0];\n            const other = g.in1 === aWire ? g.in2 : g.in1;\n            if (other !== bWire) {\n              doSwap(bWire, other);\n            }\n            carry = g.out;\n          } else {\n            // Try bWire\n            const bOrConsumers = consumers(bWire).filter(g => g.op === 'OR');\n            if (bOrConsumers.length === 1) {\n              const g = bOrConsumers[0];\n              const other = g.in1 === bWire ? g.in2 : g.in1;\n              if (other !== aWire) {\n                doSwap(aWire, other);\n              }\n              carry = g.out;\n            }\n          }\n        }\n      } else {\n        // propGate not found — this means either tWire or carry name changed\n        // after our earlier fixes, or the AND's output is wrong\n        // Try to find the AND that uses carry (but not x/y inputs)\n        const carryAndConsumers = consumers(carry).filter(\n          g => g.op === 'AND' && !(\n            /^[xy]\\d+$/.test(g.in1) && /^[xy]\\d+$/.test(g.in2)\n          )\n        );\n        if (carryAndConsumers.length === 1) {\n          bWire = carryAndConsumers[0].out;\n          const carryOutGate = findGate('OR', aWire, bWire);\n          if (carryOutGate) {\n            carry = carryOutGate.out;\n          }\n        }\n      }\n\n      // Validate carry: for non-last bits, carry should feed into XOR and AND\n      // For the last bit, carry should be highestZ\n      if (bit === maxBit) {\n        if (carry !== highestZ) {\n          // The carry should be the highest z but isn't\n          if (carry && swapped.size < 8) {\n            doSwap(carry, highestZ);\n            carry = highestZ;\n          }\n        }\n      } else if (carry) {\n        const ops = consumerOps(carry);\n        // Carry should feed XOR and AND for the next bit\n        if (!ops.has('XOR') && !ops.has('AND')) {\n          // This carry is completely disconnected — it's been swapped\n          // Find what the next bit's sum XOR expects\n          const nextBit = bit + 1;\n          const nextPartialXor = findGate('XOR', `x${pad(nextBit)}`, `y${pad(nextBit)}`);\n          if (nextPartialXor) {\n            const nextTWire = nextPartialXor.out;\n            const nextSumCandidates = consumers(nextTWire).filter(g => g.op === 'XOR');\n            if (nextSumCandidates.length === 1) {\n              const realCarry = nextSumCandidates[0].in1 === nextTWire\n                ? nextSumCandidates[0].in2\n                : nextSumCandidates[0].in1;\n              if (realCarry !== carry) {\n                doSwap(carry, realCarry);\n                carry = realCarry;\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":48,"oldLines":21,"newStart":48,"newLines":37,"lines":[" /**","  * Find 8 swapped output wires in a broken ripple-carry adder circuit.","  *","- * Uses structural rules to identify gates whose outputs violate the","- * expected pattern of a ripple-carry adder.","+ * Uses a combination of structural rules and bit-by-bit walking to identify","+ * gates whose outputs violate the expected pattern of a ripple-carry adder.","  */"," export function findSwappedWires(gates: Gate[]): string[] {","+  // Work on copies so we can fix swaps as we find them","+  const gatesCopy: Gate[] = gates.map(g => ({ ...g }));","   const swapped: Set<string> = new Set();"," ","   // Build lookup structures","+  function rebuildLookups() {","+    outToGate.clear();","+    gateByOpInputs.clear();","+    for (const g of gatesCopy) {","+      outToGate.set(g.out, g);","+      const inputs = [g.in1, g.in2].sort();","+      gateByOpInputs.set(`${g.op}:${inputs[0]}:${inputs[1]}`, g);","+    }","+  }","+","   const outToGate = new Map<string, Gate>();","-  for (const g of gates) {","-    outToGate.set(g.out, g);","+  const gateByOpInputs = new Map<string, Gate>();","+  rebuildLookups();","+","+  function findGate(op: string, in1: string, in2: string): Gate | undefined {","+    const inputs = [in1, in2].sort();","+    return gateByOpInputs.g