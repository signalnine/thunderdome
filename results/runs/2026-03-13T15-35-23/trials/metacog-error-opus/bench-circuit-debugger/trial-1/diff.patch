j++) {\n        if (paired.has(swappedList[j])) continue;\n        // Check if swapping these two would fix a rule violation\n        // Simple heuristic: if one is a z wire and the other isn't, they're a pair\n        const a = swappedList[i];\n        const b = swappedList[j];\n        if ((isZWire(a) && !isZWire(b)) || (!isZWire(a) && isZWire(b))) {\n          doSwap(a, b);\n          paired.add(a);\n          paired.add(b);\n          break;\n        }\n      }\n    }\n\n    // Now walk to find remaining swaps\n    let carry: string | undefined;\n\n    for (let bit = 0; bit <= maxBit; bit++) {\n      const x = `x${pad(bit)}`;\n      const y = `y${pad(bit)}`;\n      const z = `z${pad(bit)}`;\n\n      if (bit === 0) {\n        const andGate = findGate('AND', x, y);\n        if (andGate) carry = andGate.out;\n      } else {\n        if (carry === undefined) continue;\n\n        const partialXor = findGate('XOR', x, y);\n        if (!partialXor) continue;\n        let tWire = partialXor.out;\n\n        // Find sum gate\n        let sumGate = findGate('XOR', tWire, carry);\n\n        if (!sumGate) {\n          // Try to find via z gate\n          const zGate = outToGate.get(z);\n          if (zGate && zGate.op === 'XOR') {\n            const gateInputs = [zGate.in1, zGate.in2];\n            if (gateInputs.includes(carry)) {\n              const realT = gateInputs[0] === carry ? gateInputs[1] : gateInputs[0];\n              if (realT !== tWire) {\n                doSwap(tWire, realT);\n                tWire = realT;\n              }\n              sumGate = zGate;\n            } else if (gateInputs.includes(tWire)) {\n              const realCarry = gateInputs[0] === tWire ? gateInputs[1] : gateInputs[0];\n              if (realCarry !== carry) {\n                doSwap(carry, realCarry);\n                carry = realCarry;\n              }\n              sumGate = zGate;\n            }\n          }\n\n          if (!sumGate) {\n            // Find non-input XOR that uses carry\n            const carryXorConsumers = consumers(carry).filter(g => {\n              if (g.op !== 'XOR') return false;\n              return !(isInputXY(g.in1) && isInputXY(g.in2));\n            });\n            if (carryXorConsumers.length === 1) {\n              sumGate = carryXorConsumers[0];\n              const otherIn = sumGate.in1 === carry ? sumGate.in2 : sumGate.in1;\n              if (otherIn !== tWire) {\n                doSwap(tWire, otherIn);\n                tWire = otherIn;\n              }\n            } else if (carryXorConsumers.length === 0) {\n              const tXorConsumers = consumers(tWire).filter(g => g.op === 'XOR');\n              if (tXorConsumers.length === 1) {\n                sumGate = tXorConsumers[0];\n                const realCarry = sumGate.in1 === tWire ? sumGate.in2 : sumGate.in1;\n                if (realCarry !== carry) {\n                  doSwap(carry, realCarry);\n                  carry = realCarry;\n                }\n              }\n            }\n          }\n        }\n\n        if (sumGate && sumGate.out !== z) {\n          doSwap(sumGate.out, z);\n        }\n\n        // Carry computation\n        const genGate = findGate('AND', x, y);\n        if (!genGate) continue;\n        const aWire = genGate.out;\n\n        const propGate = findGate('AND', tWire, carry);\n        let bWire: string | undefined;\n        if (propGate) bWire = propGate.out;\n\n        if (bWire !== undefined) {\n          const carryOutGate = findGate('OR', aWire, bWire);\n          if (carryOutGate) {\n            carry = carryOutGate.out;\n          } else {\n            // Find the correct OR gate\n            const bOrConsumers = consumers(bWire).filter(g => g.op === 'OR');\n            const aOrConsumers = consumers(aWire).filter(g => g.op === 'OR');\n\n            type Candidate = { orGate: Gate; swapFrom: string; swapTo: string };\n            const candidates: Candidate[] = [];\n\n            if (bOrConsumers.length === 1) {