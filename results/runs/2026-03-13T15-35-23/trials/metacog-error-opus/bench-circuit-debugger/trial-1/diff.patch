ad}`, out: `c${pad}` });\n      }\n    }\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], w1: string, w2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === w1) return { ...g, out: w2 };\n      if (g.out === w2) return { ...g, out: w1 };\n      return { ...g };\n    });\n  }\n\n  it('should find swapped z wire with AND output', () => {\n    // z01 <-> a01: XOR sum output swapped with AND generate output\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 'a05');\n    gates = swapOutputs(gates, 'z06', 'c04');\n    gates = swapOutputs(gates, 'z08', 'b07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a05', 'b07', 'c04', 'z01', 'z03', 'z06', 'z08'].sort());\n  });\n\n  it('should find swapped z wire with OR carry output', () => {\n    // z wire swapped with carry output\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 'z02', 'c01');\n    gates = swapOutputs(gates, 'z05', 'c04');\n    gates = swapOutputs(gates, 'z07', 'a06');\n    gates = swapOutputs(gates, 'z08', 'b03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a06', 'b03', 'c01', 'c04', 'z02', 'z05', 'z07', 'z08'].sort());\n  });\n\n  it('should find swapped partial sum with z wire from different bit', () => {\n    // t wire (partial sum) swapped with z wire from different bit\n    let gates = buildAdder(8);\n    gates = swapOutputs(gates, 't02', 'z05');\n    gates = swapOutputs(gates, 't04', 'z07');\n    gates = swapOutputs(gates, 'a01', 'z01');\n    gates = swapOutputs(gates, 'z08', 'c06');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'c06', 't02', 't04', 'z01', 'z05', 'z07', 'z08'].sort());\n  });\n\n  it('should find swaps across distant bits', () => {\n    let gates = buildAdder(10);\n    gates = swapOutputs(gates, 'z01', 'a09');\n    gates = swapOutputs(gates, 'z05', 'b02');\n    gates = s