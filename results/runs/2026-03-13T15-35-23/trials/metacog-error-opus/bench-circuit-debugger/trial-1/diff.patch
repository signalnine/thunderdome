pped.add(carry);\n      swapped.add(finalZ);\n    }\n  }\n\n  function doSwap(a: string, b: string): void {\n    // Swap the output wires in our lookup structures\n    const gateA = outToGate.get(a);\n    const gateB = outToGate.get(b);\n    if (gateA && gateB) {\n      gateA.out = b;\n      gateB.out = a;\n      outToGate.set(a, gateB);\n      outToGate.set(b, gateA);\n      // Update gateByOpInputs\n      const inputsA = [gateA.in1, gateA.in2].sort();\n      const inputsB = [gateB.in1, gateB.in2].sort();\n      gateByOpInputs.set(`${gateA.op}:${inputsA[0]}:${inputsA[1]}`, gateA);\n      gateByOpInputs.set(`${gateB.op}:${inputsB[0]}:${inputsB[1]}`, gateB);\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":305,"oldLines":7,"newStart":305,"newLines":8,"lines":["       } else {","         // Propagate gate not found, carry might be wrong or tWire wrong","         // Try to find AND gate that uses carry","-        const carryAndConsumers = findConsumers(carry).filter(g => g.op === 'AND' && !isInputWire(otherInput(g, carry)));","+        const currentCarry = carry;","+        const carryAndConsumers = findConsumers(currentCarry).filter(g => g.op === 'AND' && !isInputWire(otherInput(g, currentCarry)));","         if (carryAndConsumers.length === 1) {","           bWire = carryAndConsumers[0].out;","           // Find carry out from OR of aWire and bWire"]}],"userModified":false,"replaceAll":false}}
