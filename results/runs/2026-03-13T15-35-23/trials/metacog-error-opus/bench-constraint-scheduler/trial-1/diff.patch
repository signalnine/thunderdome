result.unscheduled).toHaveLength(0);\n    });\n\n    it('should default attendees to 1', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const smallRooms: Room[] = [\n        { id: 'r1', name: 'Tiny Room', capacity: 1 },\n      ];\n      const result = schedule(events, smallRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('room capacity', () => {\n    it('should not assign event to room with insufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },\n      ];\n      const smallRooms: Room[] = [\n        { id: 'r1', name: 'Small Room', capacity: 10 },\n      ];\n      const result = schedule(events, smallRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('should assign event to room with sufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      const room = result.assignments[0].roomId;\n      const assignedRoom = rooms.find(r => r.id === room);\n      expect(assignedRoom!.capacity).toBeGreaterThanOrEqual(15);\n    });\n  });\n\n  describe('time window', () => {\n    it('should not schedule event that exceeds time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Long Event', duration: 600 },\n      ];\n      const tightOptions: ScheduleOptions = {\n        startTime: 540,\n        endTime: 600,  // Only 60 minutes\n      };\n      const result = schedule(events, rooms, tightOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('should schedule event that exactly fits the time wi