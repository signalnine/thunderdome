.path, id, prereq].join(' -> ')}`);\n      }\n      if (c === WHITE) {\n        dfs(prereq, [...path, id]);\n      }\n    }\n\n    color.set(id, BLACK);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id, []);\n    }\n  }\n}\n\n/**\n * Topological sort using Kahn's algorithm.\n * Returns events in dependency order (prerequisites first).\n */\nfunction topologicalSort(events: Event[]): Event[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const eventIds = new Set(events.map(e => e.id));\n  const inDegree = new Map<string, number>();\n  const dependents = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    dependents.set(e.id, []);\n  }\n\n  for (const e of events) {\n    for (const prereq of e.prerequisites ?? []) {\n      if (eventIds.has(prereq)) {\n        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n        dependents.get(prereq)!.push(e.id);\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const e of events) {\n    if (inDegree.get(e.id) === 0) {\n      queue.push(e.id);\n    }\n  }\n\n  const sorted: Event[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    sorted.push(eventMap.get(id)!);\n    for (const dep of dependents.get(id) ?? []) {\n      const newDeg = (inDegree.get(dep) ?? 1) - 1;\n      inDegree.set(dep, newDeg);\n      if (newDeg === 0) {\n        queue.push(dep);\n      }\n    }\n  }\n\n  return sorted;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering existing assignments, prerequisite completion times, and gaps.\n */\nfunction findEarliestStart(\n  event: Event,\n  roomId: string,\n  assignments: Assignment[],\n  options: ScheduleOptions,\n  gap: number,\n): number | null {\n  // Determine the earliest start based on prerequisites\n  let earliest = options.startTime;\n  for (const prereqId of event.prerequisites ?? []) {\n    const prereqAssignment = assignments.find(a => a.eventId === prereqId);\n    if (prereqAssignment) {\n      earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n    }\n  }\n\n  // Check if event can fit before the end of the window\n  if (earliest + event.duration > options.endTime) {\n    return null;\n  }\n\n  // Get existing assignments for this room, sorted by start time\n  const roomAssignments = assignments\n    .filter(a => a.roomId === roomId)\n    .sort((a, b) => a.startTime - b.startTime);\n\n  // Find the first available slot\n  let candidateStart = earliest;\n\n  for (const existing of roomAssignments) {\n    // If our candidate fits before this existing assignment (with gap)\n    if (candidateStart + event.duration + gap <= existing.startTime) {\n      // This slot works\n      break;\n    }\n    // Otherwise, try after this existing assignment\n    candidateStart = Math.max(candidateStart, existing.endTime + gap);\n  }\n\n  // Final check: does the event fit in the time window?\n  if (candidateStart + event.duration > options.endTime) {\n    return null;\n  }\n\n  return candidateStart;\n}\n\n/**\n * Schedule events into rooms, maximizing the number of scheduled events.\n * Uses constraint-aware placement with backtracking.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Detect cycles first\n  detectCycles(events);\n\n  // Topological sort\n  const sorted = topologicalSort(events);\n\n  // Events not in sorted (missing prerequisites that aren't in the event list)\n  // are still included — topologicalSort only includes valid events\n  const sortedIds = new Set(sorted.map(e => e.id));\n  const allEvents = [...sorted, ...events.filter(e => !sortedIds.has(e.id))];\n\n  // For each event, compute eligible rooms (capacity check)\n  const eligibleRooms = new Map<string, Room[]>();\n  for (const event of allEvents) {\n    const attendees = event.attendees ?? 1;\n    const eligible = rooms.filter(r => r.capacity >= attendees);\n    // Sort: preferred room first, then by capacity (smallest sufficient room first)\n    eligible.sort((a, b) => {\n      if (event.preferredRoom) {\n        if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n        if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n      }\n      return a.capacity - b.capacity;\n    });\n    eligibleRooms.set(event.id, eligible);\n  }\n\n  // Compute constraint score for ordering: events with fewer options should be scheduled first\n  // This is the MRV (Minimum Remaining Values) heuristic from CSP solving\n  const constraintScore = new Map<string, number>();\n  for (const event of allEvents) {\n    const eligible = eligibleRooms.get(event.id) ?? [];\n    const prereqCount = (event.prerequisites ?? []).length;\n    // Lower score = more constrained = schedule first\n    // Fewer eligible rooms + more prerequisites = more constrained\n    constraintScore.set(event.id, eligible.length * 100 - prereqCount * 10);\n  }\n\n  // Group events by their topological level for better ordering\n  const eventMap = new Map<string, Event>();\n  for (const e of allEvents) {\n    eventMap.set(e.id, e);\n  }\n\n  // Re-sort within each topological level by constraint score\n  // First, compute topological levels\n  const levels = new Map<string, number>();\n  function computeLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const event = eventMap.get(id);\n    if (!event || !event.prerequisites || event.prerequisites.length === 0) {\n      levels.set(id, 0);\n      return 0;\n    }\n    let maxLevel = 0;\n    for (const prereq of event.prerequisites) {\n      if (eventMap.has(prereq)) {\n        maxLevel = Math.max(maxLevel, computeLevel(prereq) + 1);\n      }\n    }\n    levels.set(id, maxLevel);\n    return maxLevel;\n  }\n\n  for (const e of allEvents) {\n    computeLevel(e.id);\n  }\n\n  // Sort: by topological level first, then by constraint score (most constrained first)\n  allEvents.sort((a, b) => {\n    const levelDiff = (levels.get(a.id) ?? 0) - (levels.get(b.id) ?? 0);\n    if (levelDiff !== 0) return levelDiff;\n    return (constraintScore.get(a.id) ?? 0) - (constraintScore.get(b.id) ?? 0);\n  });\n\n  // Try to schedule with backtracking for better optimization\n  const bestResult = greedySchedule(allEvents, rooms, eligibleRooms, options, gap);\n\n  // If some events are unscheduled, try alternative orderings to improve\n  if (bestResult.unscheduled.length > 0) {\n    // Try scheduling unscheduled events first in different room orders\n    const improved = tryImproveSchedule(\n      allEvents,\n      rooms,\n      eligibleRooms,\n      options,\n      gap,\n      bestResult,\n    );\n    return improved;\n  }\n\n  return bestResult;\n}\n\nfunction greedySchedule(\n  orderedEvents: Event[],\n  rooms: Room[],\n  eligibleRooms: Map<string, Room[]>,\n  options: ScheduleOptions,\n  gap: number,\n): ScheduleResult {\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  for (const event of orderedEvents) {\n    const eligible = eligibleRooms.get(event.id) ?? [];\n    if (eligible.length === 0) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    // Check if all prerequisites are scheduled\n    const prereqsMet = (event.prerequisites ?? []).every(\n      prereqId => assignments.some(a => a.eventId === prereqId)\n    );\n    if (!prereqsMet) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    let placed = false;\n    for (const room of eligible) {\n      const startTime = findEarliestStart(event, room.id, assignments, options, gap);\n      if (startTime !== null) {\n        assignments.push({\n          eventId: event.id,\n          roomId: room.id,\n          startTime,\n          endTime: startTime + event.duration,\n        });\n        placed = true;\n        break;\n      }\n    }\n\n    if (!placed) {\n      unscheduled.push(event.id);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\n/**\n * Try to improve the schedule by attempting different orderings and\n * room assignments for unscheduled events.\n */\nfunction tryImproveSchedule(\n  allEvents: Event[],\n  rooms: Room[],\n  eligibleRooms: Map<string, Room[]>,\n  options: ScheduleOptions,\n  gap: number,\n  currentBest: ScheduleResult,\n): ScheduleResult {\n  let best = currentBest;\n\n  // Strategy 1: Try reversed room preference order\n  const reversedRoomEligible = new Map<string, Room[]>();\n  for (const [eventId, roomList] of eligibleRooms) {\n    reversedRoomEligible.set(eventId, [...roomList].reverse());\n  }\n\n  const attempt1 = greedySchedule(allEvents, rooms, reversedRoomEligible, options, gap);\n  if (attempt1.unscheduled.length < best.unscheduled.length) {\n    best = attempt1;\n  }\n\n  // Strategy 2: Try different event orderings — longest events first\n  const byDuration = [...allEvents].sort((a, b) => {\n    const levelA = getLevelFromPrereqs(a, allEvents);\n    const levelB = getLevelFromPrereqs(b, allEvents);\n    if (levelA !== levelB) return levelA - levelB;\n    return b.duration - a.duration;\n  });\n  const attempt2 = greedySchedule(byDuration, rooms, eligibleRooms, options, gap);\n  if (attempt2.unscheduled.length < best.unscheduled.length) {\n    best = attempt2;\n  }\n\n  // Strategy 3: Try shortest events first (more events might fit)\n  const byShortDuration = [...allEvents].sort((a, b) => {\n    const levelA = getLevelFromPrereqs(a, allEvents);\n    const levelB = getLevelFromPrereqs(b, allEvents);\n    if (levelA !== levelB) return levelA - levelB;\n    return a.duration - b.duration;\n  });\n  const attempt3 = greedySchedule(byShortDuration, rooms, eligibleRooms, options, gap);\n  if (attempt3.unscheduled.length < best.unscheduled.length) {\n    best = attempt3;\n  }\n\n  // Strategy 4: Try placing currently unscheduled events with priority\n  if (best.unscheduled.length > 0) {\n    const eventMap = new Map(allEvents.map(e => [e.id, e]));\n    const unschedSet = new Set(best.unscheduled);\n    const prioritized = [\n      ...allEvents.filter(e => unschedSet.has(e.id)),\n      ...allEvents.filter(e => !unschedSet.has(e.id)),\n    ];\n    // Need to respect topological order still\n    const reordered = respectTopoOrder(prioritized, allEvents);\n    const attempt4 = greedySchedule(reordered, rooms, eligibleRooms, options, gap);\n    if (attempt4.unscheduled.length < best.unscheduled.length) {\n      best = attempt4;\n    }\n  }\n\n  return best;\n}\n\nfunction getLevelFromPrereqs(event: Event, allEvents: Event[]): number {\n  const eventMap = new Map(allEvents.map(e => [e.id, e]));\n  const memo = new Map<string, number>();\n\n  function level(id: string): number {\n    if (memo.has(id)) return memo.get(id)!;\n    const e = eventMap.get(id);\n    if (!e || !e.prerequisites || e.prerequisites.length === 0) {\n      memo.set(id, 0);\n      return 0;\n    }\n    let max = 0;\n    for (const p of e.prerequisites) {\n      if (eventMap.has(p)) {\n        max = Math.max(max, level(p) + 1);\n      }\n    }\n    memo.set(id, max);\n    return max;\n  }\n\n  return level(event.id);\n}\n\nfunction respectTopoOrder(prioritized: Event[], allEvents: Event[]): Event[] {\n  const eventMap = new Map(allEvents.map(e => [e.id, e]));\n  const result: Event[] = [];\n  const scheduled = new Set<string>();\n  const remaining = new Set(prioritized.map(e => e.id));\n\n  // Repeatedly pick events whose prerequisites are all scheduled\n  while (remaining.size > 0) {\n    let placed = false;\n    for (const event of prioritized) {\n      if (!remaining.has(event.id)) continue;\n      const prereqs = (event.prerequisites ?? []).filter(p => eventMap.has(p));\n      if (prereqs.every(p => scheduled.has(p))) {\n        result.push(event);\n        scheduled.add(event.id);\n        remaining.delete(event.id);\n        placed = true;\n      }\n    }\n    if (!placed) {\n      // Remaining events have unmet prerequisites; add them anyway\n      for (const event of prioritized) {\n        if (remaining.has(event.id)) {\n          result.push(event);\n          remaining.delete(event.id);\n        }\n      }\n      break;\n    }\n  }\n\n  return result;\n}\n\nexport default schedule;\n","structuredPatch":[{"oldStart":385,"oldLines":7,"newStart":385,"newLines":6,"lines":[" ","   // Strategy 4: Try placing currently unscheduled events with priority","   if (best.unscheduled.length > 0) {","-    const eventMap = new Map(allEvents.map(e => [e.id, e]));","     const unschedSet = new Set(best.unscheduled);","     const prioritized = [","       ...allEvents.filter(e => unschedSet.has(e.id)),"]}],"userModified":false,"replaceAll":false}}
