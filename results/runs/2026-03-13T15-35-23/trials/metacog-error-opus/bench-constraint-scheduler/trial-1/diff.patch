rerequisite', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Self Ref', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);\n    });\n\n    it('should throw error for two-event cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 60, prerequisites: ['e2'] },\n        { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);\n    });\n\n    it('should throw error for indirect cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 60, prerequisites: ['e3'] },\n        { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },\n        { id: 'e3', name: 'C', duration: 60, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/[Cc]ycle/);\n    });\n  });\n\n  describe('preferred room', () => {\n    it('should honor preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'room-b' },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should use different room when preferred room has insufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15, preferredRoom: 'room-a' },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).not.toBe('room-a'); // capacity 10 < 15\n    });\n\n    it('should use different room when preferred room is full', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 480, preferredRoom: 'room-a' },\n        { id: 'e2', name: 'Event 2', duration: 60, preferredRoom: 'room-a' },\n      ];\n      // room-a is occupied all day by e1, so e2 should go elsewhere\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      // Both events should be scheduled\n      const e2Assignment = result.assignments.find(a => a.eventId === 'e2');\n      expect(e2Assignment).toBeDefined();\n    });\n  });\n\n  describe('unscheduled events', () => {\n    it('should report events that cannot be scheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 100 },\n      ];\n      const smallRooms: Room[] = [\n        { id: 'r1', name: 'Small', capacity: 10 },\n      ];\n      const result = schedule(events, smallRooms, defaultOptions);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should maximize number of scheduled events', () => {\n      // Create a scenario where greedy scheduling might fail\n      // but optimal scheduling can fit more events\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 120 },\n        { id: 'e2', name: 'Event 2', duration: 120 },\n        { id: 'e3', name: 'Event 3', duration: 120 },\n        { id: 'e4', name: 'Event 4', duration: 30 },\n        { id: 'e5', name: 'Event 5', duration: 30 },\n      ];\n      const tightRooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 100 },\n      ];\n      const tightOptions: ScheduleOptions = {\n        startTime: 0,\n        endTime: 480,  // 8 hours\n        gap: 15,\n      };\n      const result = schedule(events, tightRooms, tightOptions);\n      // With 480 minutes and 15 min gaps: can fit 120+15+120+15+120+15+30+15+30 = 480\n      // That's all 5 events\n      expect(result.assignments.length).toBeGreaterThanOrEqual(4);\n    });\n  });\n\n  describe('complex scenarios', () => {\n    it('should handle events across multiple rooms', () => {\n      const events: Event[] = Array.from({ length: 10 }, (_, i) => ({\n        id: `e${i + 1}`,\n        name: `Event ${i + 1}`,\n        duration: 60,\n      }));\n      const result = schedule(events, rooms, defaultOptions);\n      // 480 minutes / (60 + 15) = 6.4, so 6 per room, 3 rooms = 18 max\n      // All 10 should fit\n      expect(result.assignments).toHaveLength(10);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should handle mixed prerequisites and room preferences', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Setup', duration: 30, preferredRoom: 'room-a' },\n        { id: 'e2', name: 'Main', duration: 60, prerequisites: ['e1'], preferredRoom: 'room-b' },\n        { id: 'e3', name: 'Teardown', duration: 30, prerequisites: ['e2'], preferredRoom: 'room-a' },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
