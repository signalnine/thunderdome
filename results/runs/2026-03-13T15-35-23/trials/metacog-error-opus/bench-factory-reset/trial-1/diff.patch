+  const particular = new Array(numVars).fill(0);
+  for (let i = 0; i < rank; i++) {
+    particular[pivotCols[i]] = aug[i][numVars];
+  }
+
+  const nullSpace: number[][] = [];
+  for (const freeCol of freeCols) {
+    const vec = new Array(numVars).fill(0);
+    vec[freeCol] = 1;
+    for (let i = 0; i < rank; i++) {
+      vec[pivotCols[i]] = mod(-aug[i][freeCol], p);
+    }
+    nullSpace.push(vec);
+  }
+
+  return { rank, solvable: true, particular, nullSpace };
+}
+
+// --- Counter optimization over free variables ---
+
+function solutionSum(sol: number[]): number {
+  let s = 0;
+  for (let i = 0; i < sol.length; i++) s += sol[i];
+  return s;
+}
+
+function lexCompare(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
+
+function computeSolution(
+  particular: number[],
+  nullSpace: number[][],
+  coeffs: number[],
+  p: number
+): number[] {
+  const n = particular.length;
+  const result = new Array(n);
+  for (let i = 0; i < n; i++) {
+    let val = particular[i];
+    for (let k = 0; k < coeffs.length; k++) {
+      val += coeffs[k] * nullSpace[k][i];
+    }
+    result[i] = mod(val, p);
+  }
+  return result;
+}
+
+function optimizeCounter(
+  particular: number[],
+  nullSpace: number[][],
+  p: number
+): number[] {
+  const numFree = nullSpace.length;
+
+  if (numFree === 0) {
+    return particular.map((v) => mod(v, p));
+  }
+
+  const totalCombinations = Math.pow(p, numFree);
+
+  if (totalCombinations <= 5_000_000) {
+    return enumerateOptimalCounter(particular, nullSpace, p);
+  } else {
+    // For large search spaces, use coordinate descent
+    return coordinateDescentCounter(particular, nullSpace, p);
+  }
+}
+
+function enumerateOptimalCounter(
+  particular: number[],
+  nullSpace: number[][],
+  p: number
+): number[] {
+  const numFree = nullSpace.length;
+  const coeffs = new Array(numFree).fill(0);
+
+  let bestSol: number[] | null = null;
+  let bestSum = Infinity;
+
+  const enumerate = (idx: number): void => {
+    if (idx === numFree) {
+      const sol = computeSolution(particular, nullSpace, coeffs, p);
+      const s = solutionSum(sol);
+      if (
+        s < bestSum ||
+        (s === bestSum && bestSol !== null && lexCompare(sol, bestSol) < 0)
+      ) {
+        bestSum = s;
+        bestSol = sol;
+      }
+      return;
+    }
+    for (let v = 0; v < p; v++) {
+      coeffs[idx] = v;
+      enumerate(idx + 1);
+    }
+  };
+
+  enumerate(0);
+  return bestSol!;
+}
+
+/**
+ * Coordinate descent optimizer for counter problems with large search spaces.
+ * Iteratively optimizes each free variable while holding others fixed.
+ * Then tries all p values for each free variable to find the lex smallest
+ * among solutions with the same minimum sum.
+ */
+function coordinateDescentCounter(
+  particular: number[],
+  nullSpace: number[][],
+  p: number
+): number[] {
+  const numFree = nullSpace.length;
+  const coeffs = new Array(numFree).fill(0);
+
+  // Compute current solution
+  function getCurrentSol(): number[] {
+    return computeSolution(particular, nullSpace, coeffs, p);
+  }
+
+  // Phase 1: Minimize sum using coordinate descent
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let k = 0; k < numFree; k++) {
+      const origVal = coeffs[k];
+      let bestVal = origVal;
+      let bestSolSum = solutionSum(getCurrentSol());
+
+      for (let v = 0; v < p; v++) {
+        if (v === origVal) continue;
+        coeffs[k] = v;
+        const sol = getCurrentSol();
+        const s = solutionSum(sol);
+        if (s < bestSolSum) {
+          bestSolSum = s;
+          bestVal = v;
+          improved = true;
+        }
+      }
+      coeffs[k] = bestVal;
+    }
+  }
+
+  const targetSum = solutionSum(getCurrentSol());
+
+  // Phase 2: Among all solutions with the target sum, find lex smallest.
+  // Greedily optimize from left to right.
+  // For each free variable (in order), try all p values and pick the one
+  // that gives the lex smallest solution while maintaining the minimum sum.
+  for (let k = 0; k < numFree; k++) {
+    const origVal = coeffs[k];
+    let bestVal = origVal;
+    let bestSol = getCurrentSol();
+
+    for (let v = 0; v < p; v++) {
+      if (v === origVal) continue;
+      coeffs[k] = v;
+      const sol = getCurrentSol();
+      const s = solutionSum(sol);
+      if (s === targetSum && lexCompare(sol, bestSol) < 0) {
+        bestSol = sol;
+        bestVal = v;
+      }
+    }
+    coeffs[k] = bestVal;
+  }
+
+  return getCurrentSol();
+}
+
+// --- Public API ---
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every((v) => v === 0) ? [] : null;
+  }
+
+  if (numLights === 0) return new Array(numButtons).fill(0);
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    matrix.push(new Array(numButtons).fill(0));
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const light of buttons[j]) {
+      matrix[light][j] = 1;
+    }
+  }
+
+  const rhs = lights.map((v) => mod(v, modulus));
+
+  const result = gaussianElimination(
+    matrix,
+    rhs,
+    numButtons,
+    numLights,
+    modulus
+  );
+
+  if (!result.solvable) return null;
+
+  return optimizeCounter(result.particular, result.nullSpace, modulus);
+}
