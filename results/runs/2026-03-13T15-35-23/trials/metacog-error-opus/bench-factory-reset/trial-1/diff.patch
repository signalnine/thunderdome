< BigInt(light);\n    }\n    buttonMasks.push(mask);\n  }\n\n  // Split buttons into two halves\n  const halfSize = Math.floor(numButtons / 2);\n  const leftSize = halfSize;\n  const rightSize = numButtons - halfSize;\n\n  // Build map for left half: state -> { minCount, bestButtons }\n  // For the left half (buttons 0..leftSize-1), enumerate all 2^leftSize subsets\n  const leftMap = new Map<\n    bigint,\n    { count: number; buttons: number[] }[]\n  >();\n\n  for (let mask = 0; mask < (1 << leftSize); mask++) {\n    let state = 0n;\n    const pressed: number[] = [];\n    for (let i = 0; i < leftSize; i++) {\n      if (mask & (1 << i)) {\n        state ^= buttonMasks[i];\n        pressed.push(i);\n      }\n    }\n\n    const existing = leftMap.get(state);\n    if (existing === undefined) {\n      leftMap.set(state, [{ count: pressed.length, buttons: pressed }]);\n    } else {\n      // Keep only the best entries (min count, then lex smallest for that count)\n      const entry = { count: pressed.length, buttons: pressed };\n      // Check if we should add this entry\n      const minCount = existing[0].count;\n      if (entry.count < minCount) {\n        // New best, replace all\n        existing.length = 0;\n        existing.push(entry);\n      } else if (entry.count === minCount) {\n        // Same count, check lex order of index sets\n        // Keep only the lex smallest\n        if (compareIndexSets(entry.buttons, existing[0].buttons) < 0) {\n          existing[0] = entry;\n        }\n      }\n      // If entry.count > minCount, skip (worse)\n    }\n  }\n\n  // For right half (buttons leftSize..numButtons-1), enumerate and look up complement\n  let bestResult: number[] | null = null;\n  let bestCount = Infinity;\n\n  for (let mask = 0; mask < (1 << rightSize); mask++) {\n    let state = 0n;\n    const rightPressed: number[] = [];\n    for (let i = 0; i < rightSize; i++) {\n      if (mask & (1 << i)) {\n        state ^= buttonMasks[leftSize + i];\n        rightPressed.push(leftSize + i);\n      }\n    }\n\n    // Need left state such that leftState XOR state = targetMask\n    const neededLeft = targetMask ^ state;\n    const leftEntries = leftMap.get(neededLeft);\n    if (leftEntries === undefined) continue;\n\n    for (const leftEntry of leftEntries) {\n      const totalCount = leftEntry.count + rightPressed.length;\n      if (totalCount < bestCount) {\n        bestCount = totalCount;\n        bestResult = [...leftEntry.buttons, ...rightPressed];\n      } else if (totalCount === bestCount) {\n        const candidate = [...leftEntry.buttons, ...rightPressed];\n        if (compareIndexSets(candidate, bestResult!) < 0) {\n          bestResult = candidate;\n        }\n      }\n    }\n  }\n\n  return bestResult;\n}\n\nfunction compareIndexSets(a: number[], b: number[]): number {\n  const len = Math.min(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    if (a[i] < b[i]) return -1;\n    if (a[i] > b[i]) return 1;\n  }\n  return a.length - b.length;\n}\n\n// --- Counter solver: Gaussian elimination over GF(p) ---\n\ninterface GaussResult {\n  rank: number;\n  solvable: boolean;\n  particular: number[];\n  nullSpace: number[][];\n}\n\nfunction gaussianElimination(\n  matrix: number[][],\n  rhs: number[],\n  numVars: number,\n  numEqs: number,\n  p: number\n): GaussResult {\n  const aug: number[][] = [];\n  for (let i = 0; i < numEqs; i++) {\n    const row = new Array(numVars + 1);\n    for (let j = 0; j < numVars; j++) {\n      row[j] = mod(matrix[i][j], p);\n    }\n    row[numVars] = mod(rhs[i], p);\n    aug.push(row);\n  }\n\n  const pivotCols: number[] = [];\n  let pivotRow = 0;\n\n  for (let col = 0; col < numVars && pivotRow < numEqs; col++) {\n    let maxRow = -1;\n    for (let row = pivotRow; row < numEqs; row++) {\n      if (aug[row][col] !== 0) {\n        maxRow = row;\n        break;\n      }\n    }\n    if (maxRow === -1) continue;\n\n    [aug[pivotRow], aug[maxRow]] = [aug[maxRow], aug[pivotRow]];\n\n    const