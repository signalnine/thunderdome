+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_012etFNwCbQgAvNf6AL1mUh2","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016gMG9GoU6i94hEB4SSY7i4","name":"Write","input":{"file_path":"/workspace/src/index.ts","content":"/**\n * Factory Reset — Toggle and Counter puzzle solvers\n *\n * Toggle: meet-in-the-middle over button subsets (GF(2))\n * Counter: Gaussian elimination over GF(p) with optimization\n */\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// --- Finite field arithmetic helpers ---\n\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\nfunction modInverse(a: number, p: number): number {\n  a = mod(a, p);\n  if (a === 0) return 0;\n  let [old_r, r] = [a, p];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return mod(old_s, p);\n}\n\n// --- Toggle solver: meet-in-the-middle ---\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return target.every((t) => !t) ? [] : null;\n  }\n\n  // Convert target to bitmask\n  let targetMask = 0n;\n  for (let i = 0; i < numLights; i++) {\n    if (target[i]) targetMask |= 1n << BigInt(i);\n  }\n\n  // Convert buttons to bitmasks\n  const buttonMasks: bigint[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    let mask = 0n;\n    for (const light of buttons[j]) {\n      mask |= 1n << BigInt(light);\n    }\n    buttonMasks.push(mask);\n  }\n\n  // Split buttons into two halves\n  const halfSize = Math.floor(numButtons / 2);\n  const leftSize = halfSize;\n  const rightSize = numButtons - halfSize;\n\n  // Build map for left half: state -> { minCount, bestButtons }\n  // For the left half (buttons 0..leftSize-1), enumerate all 2^leftSize subsets\n  const leftMap = new Map<\n    bigint,\n    { count: number; buttons: number[] }[]\n  >();\n\n  for (let mask = 0; mask < (1 << leftSize); mask++) {\n    let state = 0n;\n    const pressed: number[] = [];\n    for (let i = 0; i < leftSize; i++) {\n      if (mask & (1 << i)) {\n        state ^= buttonMasks[i];\n        pressed.push(i);\n      }\n    }\n\n    const existing = leftMap.get(state);\n    if (existing === undefined) {\n      leftMap.set(state, [{ count: pressed.length, buttons: pressed }]);\n    } else {\n      // Keep only the best entries (min count, then lex smallest for that count)\n      const entry = { count: pressed.length, buttons: pressed };\n      // Check if we should add this entry\n      const minCount = existing[0].count;\n      if (entry.count < minCount) {\n        // New best, replace all\n        existing.length = 0;\n        existing.push(entry);\n      } else if (entry.count === minCount) {\n        // Same count, check lex order of index sets\n        // Keep only the lex smallest\n        if (compareIndexSets(entry.buttons, existing[0].buttons) < 0) {\n          existing[0] = entry;\n        }\n      }\n      // If entry.count > minCount, skip (worse)\n    }\n  }\n\n  // For right half (buttons leftSize..numButtons-1), enumerate and look up complement\n  let bestResult: number[] | null = null;\n  let bestCount = Infinity;\n\n  for (let mask = 0; mask < (1 << rightSize); mask++) {\n    let state = 0n;\n    const rightPressed: number[] = [];\n    for (let i = 0; i < rightSize; i++) {\n      if (mask & (1 << i)) {\n        state ^= buttonMasks[leftSize + i];\n        rightPressed.push(leftSize + i);\n      }\n    }\n\n    // Need left state such that leftState XOR state = targetMask\n    const neededLeft = targetMask ^ state;\n    const leftEntries = leftMap.get(neededLeft);\n    if (leftEntries === undefined) continue;\n\n    for (const leftEntry of leftEntries) {\n      const totalCount = leftEntry.count + rightPressed.length;\n      if (totalCount < bestCount) {\n        bestCount = totalCount;\n        bestResult = [...leftEntry.buttons, ...rightPressed];\n      } else if (totalCount === bestCount) {\n        const candidate = [...leftEntry.buttons, ...rightPressed];\n        if (compareIndexSets(candidate, bestResult!) < 0) {\n          bestResult = candidate;\n        }\n      }\n    }\n  }\n\n  return bestResult;\n}\n\nfunction compareIndexSets(a: number[], b: number[]): number {\n  const len = Math.min(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    if (a[i] < b[i]) return -1;\n    if (a[i] > b[i]) return 1;\n  }\n  return a.length - b.length;\n}\n\n// --- Counter solver: Gaussian elimination over GF(p) ---\n\ninterface GaussResult {\n  rank: number;\n  solvable: boolean;\n  particular: number[];\n  nullSpace: number[][];\n}\n\nfunction gaussianElimination(\n  matrix: number[][],\n  rhs: number[],\n  numVars: number,\n  numEqs: number,\n  p: number\n): GaussResult {\n  const aug: number[][] = [];\n  for (let i = 0; i < numEqs; i++) {\n    const row = new Array(numVars + 1);\n    for (let j = 0; j < numVars; j++) {\n      row[j] = mod(matrix[i][j], p);\n    }\n    row[numVars] = mod(rhs[i], p);\n    aug.push(row);\n  }\n\n  const pivotCols: number[] = [];\n  let pivotRow = 0;\n\n  for (let col = 0; col < numVars && pivotRow < numEqs; col++) {\n    let maxRow = -1;\n    for (let row = pivotRow; row < numEqs; row++) {\n      if (aug[row][col] !== 0) {\n        maxRow = row;\n        break;\n      }\n    }\n    if (maxRow === -1) continue;\n\n    [aug[pivotRow], aug[maxRow]] = [aug[maxRow], aug[pivotRow]];\n\n    const inv = modInverse(aug[pivotRow][col], p);\n    for (let j = col; j <= numVars; j++) {\n      aug[pivotRow][j] = mod(aug[pivotRow][j] * inv, p);\n    }\n\n    for (let row = 0; row < numEqs; row++) {\n      if (row === pivotRow || aug[row][col] === 0) continue;\n      const factor = aug[row][col];\n      for (let j = col; j <= numVars; j++) {\n        aug[row][j] = mod(aug[row][j] - factor * aug[pivotRow][j], p);\n      }\n    }\n\n    pivotCols.push(col);\n    pivotRow++;\n  }\n\n  const rank = pivotCols.length;\n\n  for (let row = rank; row < numEqs; row++) {\n    if (aug[row][numVars] !== 0) {\n      return { rank, solvable: false, particular: [], nullSpace: [] };\n    }\n  }\n\n  const pivotSet = new Set(pivotCols);\n  const freeCols: number[] = [];\n  for (let j = 0; j < numVars; j++) {\n    if (!pivotSet.has(j)) freeCols.push(j);\n  }\n\n  const particular = new Array(numVars).fill(0);\n  for (let i = 0; i < rank; i++) {\n    particular[pivotCols[i]] = aug[i][numVars];\n  }\n\n  const nullSpace: number[][] = [];\n  for (const freeCol of freeCols) {\n    const vec = new Array(numVars).fill(0);\n    vec[freeCol] = 1;\n    for (let i = 0; i < rank; i++) {\n      vec[pivotCols[i]] = mod(-aug[i][freeCol], p);\n    }\n    nullSpace.push(vec);\n  }\n\n  return { rank, solvable: true, particular, nullSpace };\n}\n\n// --- Counter optimization over free variables ---\n\nfunction solutionSum(sol: number[]): number {\n  let s = 0;\n  for (let i = 0; i < sol.length; i++) s += sol[i];\n  return s;\n}\n\nfunction lexCompare(a: number[], b: number[]): number {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return -1;\n    if (a[i] > b[i]) return 1;\n  }\n  return 0;\n}\n\nfunction computeSolution(\n  particular: number[],\n  nullSpace: number[][],\n  coeffs: number[],\n  p: number\n): number[] {\n  const n = particular.length;\n  const result = new Array(n);\n  for (let i = 0; i < n; i++) {\n    let val = particular[i];\n    for (let k = 0; k < coeffs.length; k++) {\n      val += coeffs[k] * nullSpace[k][i];\n    }\n    result[i] = mod(val, p);\n  }\n  return result;\n}\n\nfunction optimizeCounter(\n  particular: number[],\n  nullSpace: number[][],\n  p: number\n): number[] {\n  const numFree = nullSpace.length;\n\n  if (numFree === 0) {\n    return particular.map((v) => mod(v, p));\n  }\n\n  const totalCombinations = Math.pow(p, numFree);\n\n  if (totalCombinations <= 5_000_000) {\n    return enumerateOptimalCounter(particular, nullSpace, p);\n  } else {\n    return meetInTheMiddleCounter(particular, nullSpace, p);\n  }\n}\n\nfunction enumerateOptimalCounter(\n  particular: number[],\n  nullSpace: number[][],\n  p: number\n): number[] {\n  const numFree = nullSpace.length;\n  const coeffs = new Array(numFree).fill(0);\n\n  let bestSol: number[] | null = null;\n  let bestSum = Infinity;\n\n  const enumerate = (idx: number): void => {\n    if (idx === numFree) {\n      const sol = computeSolution(particular, nullSpace, coeffs, p);\n      const s = solutionSum(sol);\n      if (\n        s < bestSum ||\n        (s === bestSum && bestSol !== null && lexCompare(sol, bestSol) < 0)\n      ) {\n        bestSum = s;\n        bestSol = sol;\n      }\n      return;\n    }\n    for (let v = 0; v < p; v++) {\n      coeffs[idx] = v;\n      enumerate(idx + 1);\n    }\n  };\n\n  enumerate(0);\n  return bestSol!;\n}\n\nfunction meetInTheMiddleCounter(\n  particular: number[],\n  nullSpace: number[][],\n  p: number\n): number[] {\n  const numFree = nullSpace.length;\n  const numButtons = particular.length;\n\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  function generateHalf(startIdx: number, count: number): number[][] {\n    const entries: number[][] = [];\n    const coeffs = new Array(count).fill(0);\n    const totalCombs = Math.pow(p, count);\n\n    for (let c = 0; c < totalCombs; c++) {\n      let tmp = c;\n      for (let i = count - 1; i >= 0; i--) {\n        coeffs[i] = tmp % p;\n        tmp = Math.floor(tmp / p);\n      }\n\n      const delta = new Array(numButtons).fill(0);\n      for (let k = 0; k < count; k++) {\n        if (coeffs[k] === 0) continue;\n        const basisIdx = startIdx + k;\n        for (let j = 0; j < numButtons; j++) {\n          delta[j] += coeffs[k] * nullSpace[basisIdx][j];\n        }\n      }\n\n      entries.push(delta.sli