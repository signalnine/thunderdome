@@ -0,0 +1,252 @@
+/**
+ * Operational Transform (OT) implementation for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string at current position
+ * - number < 0: delete |N| characters at current position
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  clientId: string;
+  baseVersion: number;
+  operation: Operation;
+}
+
+/** Calculate the input length an operation expects */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      else len += Math.abs(c);
+    }
+  }
+  return len;
+}
+
+/** Calculate the output length an operation produces */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+    } else {
+      len += c.length;
+    }
+  }
+  return len;
+}
+
+/** Normalize an operation by merging adjacent same-type components and removing no-ops */
+export function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+    const last = result[result.length - 1];
+    if (typeof c === 'number' && typeof last === 'number') {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+        continue;
+      }
+    }
+    if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+      continue;
+    }
+    result.push(c);
+  }
+  return result;
+}
+
+/** Apply an operation to a document string, returning the new document */
+export function applyOp(doc: string, op: Operation): string {
+  let pos = 0;
+  let result = '';
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        if (pos + c > doc.length) {
+          throw new Error(`Retain past end of document: pos=${pos}, retain=${c}, docLen=${doc.length}`);
+        }
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        const del = Math.abs(c);
+        if (pos + del > doc.length) {
+          throw new Error(`Delete past end of document: pos=${pos}, delete=${del}, docLen=${doc.length}`);
+        }
+        pos += del;
+      }
+    } else {
+      result += c;
+    }
+  }
+  if (pos < doc.length) {
+    result += doc.slice(pos);
+  }
+  return result;
+}
+
+/**
+ * Make a simple insert operation: insert `text` at position `pos` in a document of length `docLen`.
+ */
+export function makeInsert(pos: number, text: string, docLen: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(text);
+  if (docLen - pos > 0) op.push(docLen - pos);
+  return normalize(op);
+}
+
+/**
+ * Make a simple delete operation: delete `count` characters at position `pos` in a document of length `docLen`.
+ */
+export function makeDelete(pos: number, count: number, docLen: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(-count);
+  if (docLen - pos - count > 0) op.push(docLen - pos - count);
+  return normalize(op);
+}
+
+/**
+ * Transform two concurrent operations (a and b) that were both applied to the same document state.
+ * Returns [a', b'] such that apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Uses the simple position-based approach: walk both ops simultaneously,
+ * consuming matching amounts of input.
+ */
+export function transform(a: Operation, b: Operation): [Operation, Operation] {
+  // Expand operations into micro-ops for easier processing
+  const expandedA = expand(a);
+  const expandedB = expand(b);
+
+  const aPrime: OpComponent[] = [];
+  const bPrime: OpComponent[] = [];
+
+  let ia = 0;
+  let ib = 0;
+
+  while (ia < expandedA.length || ib < expandedB.length) {
+    const ca = ia < expandedA.length ? expandedA[ia] : null;
+    const cb = ib < expandedB.length ? expandedB[ib] : null;
+
+    // a inserts: include in a', retain over it in b'
+    if (ca !== null && typeof ca === 'string') {
+      aPrime.push(ca);
+      bPrime.push(ca.length);
+      ia++;
+      continue;
+    }
+
+    // b inserts: include in b', retain over it in a'
+    if (cb !== null && typeof cb === 'string') {
+      bPrime.push(cb);
+      aPrime.push(cb.length);
+      ib++;
+      continue;
+    }
+
+    if (ca === null && cb === null) break;
+
+    if (ca === null || cb === null) {
+      throw new Error('Transform: operations have different input lengths');
+    }
+
+    // Both are numbers now (retain or delete, magnitude 1 from expansion)
+    const numA = ca as number;
+    const numB = cb as number;
+
+    if (numA === 1 && numB === 1) {
+      // both retain
+      aPrime.push(1);
+      bPrime.push(1);
+    } else if (numA === -1 && numB === -1) {
+      // both delete same char — neither needs to do anything
+    } else if (numA === -1 && numB === 1) {
+      // a deletes, b retains — a' deletes, b' skips
+      aPrime.push(-1);
+    } else if (numA === 1 && numB === -1) {
+      // a retains, b deletes — b' deletes, a' skips
+      bPrime.push(-1);
+    }
+
+    ia++;
+    ib++;
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/**
+ * Expand an operation into unit-sized components.
+ * Retains become multiple 1s, deletes become multiple -1s, inserts stay as strings.
+ */
+function expand(op: Operation): OpComponent[] {
+  const result: OpComponent[] = [];
+  for (const c of op) {
+    if (typeof c === 'string') {
+      result.push(c);
+    } else if (c > 0) {
+      for (let i = 0; i < c; i++) result.push(1);
+    } else if (c < 0) {
+      for (let i = 0; i < Math.abs(c); i++) result.push(-1);
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform operation `op` against a sequence of operations that have been applied since `op`'s base version.
+ * Returns the transformed operation that can be applied to the current document state.
+ */
+export function transformAgainstOps(op: Operation, serverOps: Operation[]): Operation {
+  let transformed = op;
+  for (const serverOp of serverOps) {
+    const [, bPrime] = transform(serverOp, transformed);
+    transformed = bPrime;
+  }
+  return transformed;
+}
+
+/**
+ * Validate that an operation is well-formed for a document of the given length.
+ */
+export function validateOperation(op: Operation, docLen: number): string | null {
+  if (!Array.isArray(op)) {
+    return 'Operation must be an array';
+  }
+  let consumed = 0;
+  for (const c of op) {
+    if (typeof c === 'string') {
+      if (c.length === 0) continue;
+      // inserts are fine
+    } else if (typeof c === 'number') {
+      if (!Number.isInteger(c) || c === 0) {
+        return `Invalid operation component: ${c}`;
+      }
+      if (c > 0) {
+        consumed += c;
+      } else {
+        consumed += Math.abs(c);
+      }
+    } else {
+      return `Invalid operation component type: ${typeof c}`;
+    }
+  }
+  if (consumed !== docLen) {
+    return `Operation input length (${consumed}) doesn't match document length (${docLen})`;
+  }
+  return null;
+}
