st(app.app)\n   331→      .post('/documents')\n   332→      .send({ title: 'Version Test', content: 'hello' });\n   333→    const docId = createRes.body.id;\n   334→\n   335→    const ws = await openWs(docId);\n   336→    await waitForMessage(ws); // sync\n   337→\n   338→    ws.send(JSON.stringify({\n   339→      type: 'operation',\n   340→      baseVersion: 999,\n   341→      operation: [5],\n   342→    }));\n   343→\n   344→    const errMsg = await waitForMessage<{type: string}>(ws);\n   345→    expect(errMsg.type).toBe('error');\n   346→\n   347→    ws.close();\n   348→  });\n   349→\n   350→  it('handles 10 concurrent clients without corruption', async () => {\n   351→    const createRes = await request(app.app)\n   352→      .post('/documents')\n   353→      .send({ title: 'Concurrency Test', content: '' });\n   354→    const docId = createRes.body.id;\n   355→\n   356→    const clients: WebSocket[] = [];\n   357→    for (let i = 0; i < 10; i++) {\n   358→      const ws = await openWs(docId);\n   359→      await waitForMessage(ws); // sync\n   360→      clients.push(ws);\n   361→    }\n   362→\n   363→    // Each client inserts a character, one after another\n   364→    for (let i = 0; i < 10; i++) {\n   365→      const currentDoc = await request(app.app).get(`/documents/${docId}`);\n   366→      const content = currentDoc.body.content;\n   367→      const op = makeInsert(content.length, String(i), content.length);\n   368→      const version = (await request(app.app).get(`/documents/${docId}/versions`)).body;\n   369→      const latestVersion = version[version.length - 1].version;\n   370→\n   371→      clients[i].send(JSON.stringify({\n   372→        type: 'operation',\n   373→        baseVersion: latestVersion,\n   374→        operation: op,\n   375→      }));\n   376→\n   377→      // Wait for ack\n   378→      await waitForMessage(clients[i]);\n   379→\n   380→      // Drain broadcasts from other clients\n   381→      for (let j = 0; j < 10; j++) {\n   38