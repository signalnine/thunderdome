+import express from 'express';
+import { createServer, type Server as HttpServer } from 'http';
+import { createDatabase, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+  const app = express();
+
+  const router = createRouter(store);
+  app.use('/api', router);
+
+  // Also mount at root for convenience
+  app.use(router);
+
+  let httpServer: HttpServer | null = null;
+  let collab: CollaborationServer | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        httpServer = createServer(app);
+        collab = new CollaborationServer(httpServer, store);
+
+        httpServer.listen(port ?? 0, () => {
+          const addr = httpServer!.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : port ?? 0;
+          resolve(actualPort);
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      return new Promise((resolve, reject) => {
+        if (collab) {
+          collab.closeAll();
+          collab = null;
+        }
+        if (httpServer) {
+          httpServer.close((err) => {
+            db.close();
+            if (err) reject(err);
+            else resolve();
+          });
+          httpServer = null;
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    },
+  };
+}
