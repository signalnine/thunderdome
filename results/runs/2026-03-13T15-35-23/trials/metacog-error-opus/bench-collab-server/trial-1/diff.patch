nexport type Operation = OpComponent[];\n\nexport interface OperationMessage {\n  type: 'operation';\n  docId: string;\n  clientId: string;\n  baseVersion: number;\n  operation: Operation;\n}\n\n/** Calculate the input length an operation expects */\nexport function inputLength(op: Operation): number {\n  let len = 0;\n  for (const c of op) {\n    if (typeof c === 'number') {\n      if (c > 0) len += c;\n      else len += Math.abs(c);\n    }\n  }\n  return len;\n}\n\n/** Calculate the output length an operation produces */\nexport function outputLength(op: Operation): number {\n  let len = 0;\n  for (const c of op) {\n    if (typeof c === 'number') {\n      if (c > 0) len += c;\n    } else {\n      len += c.length;\n    }\n  }\n  return len;\n}\n\n/** Normalize an operation by merging adjacent same-type components and removing no-ops */\nexport function normalize(op: Operation): Operation {\n  const result: Operation = [];\n  for (const c of op) {\n    if (typeof c === 'number' && c === 0) continue;\n    if (typeof c === 'string' && c === '') continue;\n    if (result.length === 0) {\n      result.push(c);\n      continue;\n    }\n    const last = result[result.length - 1];\n    if (typeof c === 'number' && typeof last === 'number') {\n      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {\n        result[result.length - 1] = last + c;\n        continue;\n      }\n    }\n    if (typeof c === 'string' && typeof last === 'string') {\n      result[result.length - 1] = last + c;\n      continue;\n    }\n    result.push(c);\n  }\n  return result;\n}\n\n/** Apply an operation to a document string, returning the new document */\nexport function applyOp(doc: string, op: Operation): string {\n  let pos = 0;\n  let result = '';\n  for (const c of op) {\n    if (typeof c === 'number') {\n      if (c > 0) {\n        if (pos + c > doc.length) {\n          throw new Error(`Retain past end of document: pos=${pos}, retain=${c}, docLen=${doc.length}`);\n        }\n        result +=