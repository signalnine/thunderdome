er.close((err) => {\n            db.close();\n            if (err) reject(err);\n            else resolve();\n          });\n          httpServer = null;\n        } else {\n          db.close();\n          resolve();\n        }\n      });\n    },\n  };\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
