@@ -0,0 +1,426 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { WebSocket } from 'ws';
+import { createApp, type AppInstance } from './server.js';
+import { makeInsert } from './ot.js';
+
+let app: AppInstance;
+let port: number;
+let baseUrl: string;
+
+function wsUrl(docId: string): string {
+  return `ws://localhost:${port}/documents/${docId}/ws`;
+}
+
+// Message queue wrapper for WebSocket to handle the race condition
+// where server sends sync before the client's 'open' event fires.
+class WsClient {
+  ws: WebSocket;
+  private queue: unknown[] = [];
+  private waiters: Array<(msg: unknown) => void> = [];
+
+  constructor(ws: WebSocket) {
+    this.ws = ws;
+    ws.on('message', (data) => {
+      const parsed = JSON.parse(data.toString());
+      if (this.waiters.length > 0) {
+        this.waiters.shift()!(parsed);
+      } else {
+        this.queue.push(parsed);
+      }
+    });
+  }
+
+  recv<T = unknown>(timeoutMs = 5000): Promise<T> {
+    if (this.queue.length > 0) {
+      return Promise.resolve(this.queue.shift() as T);
+    }
+    return new Promise<T>((resolve, reject) => {
+      const timer = setTimeout(() => {
+        const idx = this.waiters.indexOf(waiter);
+        if (idx >= 0) this.waiters.splice(idx, 1);
+        reject(new Error('WS message timeout'));
+      }, timeoutMs);
+      const waiter = (msg: unknown) => {
+        clearTimeout(timer);
+        resolve(msg as T);
+      };
+      this.waiters.push(waiter);
+    });
+  }
+
+  send(data: unknown): void {
+    this.ws.send(JSON.stringify(data));
+  }
+
+  close(): void {
+    this.ws.close();
+  }
+}
+
+function connectWs(docId: string): Promise<WsClient> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(docId));
+    // Attach message queue BEFORE open so we capture early messages
+    const client = new WsClient(ws);
+    ws.on('open', () => resolve(client));
+    ws.on('error', reject);
+  });
+}
+
+async function apiPost(path: string, body: unknown): Promise<{status: number; body: Record<string, unknown>}> {
+  const res = await fetch(`${baseUrl}${path}`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
