ject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    // Attach message queue BEFORE open so we capture early messages\n    const client = new WsClient(ws);\n    ws.on('open', () => resolve(client));\n    ws.on('error', reject);\n  });\n}\n\nasync function apiPost(path: string, body: unknown): Promise<{status: number; body: Record<string, unknown>}> {\n  const res = await fetch(`${baseUrl}${path}`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(body),\n  });\n  return { status: res.status, body: await res.json() };\n}\n\nasync function apiGet(path: string): Promise<{status: number; body: Record<string, unknown>}> {\n  const res = await fetch(`${baseUrl}${path}`);\n  if (res.status === 204) return { status: 204, body: {} };\n  return { status: res.status, body: await res.json() };\n}\n\nasync function apiPut(path: string, body: unknown): Promise<{status: number; body: Record<string, unknown>}> {\n  const res = await fetch(`${baseUrl}${path}`, {\n    method: 'PUT',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(body),\n  });\n  return { status: res.status, body: await res.json() };\n}\n\nasync function apiPatch(path: string, body: unknown): Promise<{status: number; body: Record<string, unknown>}> {\n  const res = await fetch(`${baseUrl}${path}`, {\n    method: 'PATCH',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(body),\n  });\n  return { status: res.status, body: await res.json() };\n}\n\nasync function apiDelete(path: string): Promise<{status: number}> {\n  const res = await fetch(`${baseUrl}${path}`, { method: 'DELETE' });\n  return { status: res.status };\n}\n\ndescribe('REST API', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('creates a document', async () => {\n    const res = await apiPost('/documents', { title: 'Test Doc', content: 'hello' });\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('hello');\n    expect(res.body.id).toBeDefined();\n  });\n\n  it('rejects document creation without title', async () => {\n    const res = await apiPost('/documents', { content: 'hello' });\n    expect(res.status).toBe(400);\n  });\n\n  it('lists documents', async () => {\n    await apiPost('/documents', { title: 'Doc 1' });\n    await apiPost('/documents', { title: 'Doc 2' });\n    const res = await apiGet('/documents');\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.body)).toBe(true);\n    expect((res.body as unknown as unknown[]).length).toBe(2);\n  });\n\n  it('gets a single document', async () => {\n    const createRes = await apiPost('/documents', { title: 'Test', content: 'content' });\n    const res = await apiGet(`/documents/${createRes.body.id}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Test');\n    expect(res.body.content).toBe('content');\n  });\n\n  it('returns 404 for missing document', async () => {\n    const res = await apiGet('/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('updates a document', async () => {\n    const createRes = await apiPost('/documents', { title: 'Original' });\n    const res = await apiPut(`/documents/${createRes.body.id}`, { title: 'Updated', content: 'new content' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('new content');\n  });\n\n  it('partially updates a document', async () => {\n    const createRes = await apiPost('/documents', { title: 'Original', content: 'keep' });\n    const res = await apiPatch(`/documents/${createRes.body.id}`, { title: 'New Title' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('New Title');\n    expect(res.body.content).toBe('keep');\n  