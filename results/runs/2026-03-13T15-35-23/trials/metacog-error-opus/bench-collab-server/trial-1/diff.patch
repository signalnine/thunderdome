> {\n    const res = await api('POST', '/documents', { title: 'Test Doc', content: 'hello' });\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('hello');\n    expect(res.body.id).toBeDefined();\n  });\n\n  it('rejects document creation without title', async () => {\n    const res = await api('POST', '/documents', { content: 'hello' });\n    expect(res.status).toBe(400);\n  });\n\n  it('lists documents', async () => {\n    await api('POST', '/documents', { title: 'Doc 1' });\n    await api('POST', '/documents', { title: 'Doc 2' });\n    const res = await api('GET', '/documents');\n    expect(res.status).toBe(200);\n    expect((res.body as unknown as unknown[]).length).toBe(2);\n  });\n\n  it('gets a single document', async () => {\n    const createRes = await api('POST', '/documents', { title: 'Test', content: 'content' });\n    const res = await api('GET', `/documents/${createRes.body.id}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Test');\n    expect(res.body.content).toBe('content');\n  });\n\n  it('returns 404 for missing document', async () => {\n    const res = await api('GET', '/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('updates a document', async () => {\n    const createRes = await api('POST', '/documents', { title: 'Original' });\n    const res = await api('PUT', `/documents/${createRes.body.id}`, { title: 'Updated', content: 'new content' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('new content');\n  });\n\n  it('partially updates a document', async () => {\n    const createRes = await api('POST', '/documents', { title: 'Original', content: 'keep' });\n    const res = await api('PATCH', `/documents/${createRes.body.id}`, { title: 'New Title' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('New Title');\n    expect(res.body.content).toBe('keep');\n  });\n\n  it('deletes a document', async () => {\n    const createRes = await api('POST', '/documents', { title: 'To Delete' });\n    const delRes = await api('DELETE', `/documents/${createRes.body.id}`);\n    expect(delRes.status).toBe(204);\n    const getRes = await api('GET', `/documents/${createRes.body.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('gets version history', async () => {\n    const createRes = await api('POST', '/documents', { title: 'Versioned', content: 'v0' });\n    const res = await api('GET', `/documents/${createRes.body.id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = res.body as unknown as unknown[];\n    expect(versions.length).toBe(1);\n    expect((versions[0] as Record<string, unknown>).version).toBe(0);\n    expect((versions[0] as Record<string, unknown>).content).toBe('v0');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('sends sync message on connect', async () => {\n    const createRes = await api('POST', '/documents', { title: 'WS Test', content: 'hello' });\n    const docId = createRes.body.id as string;\n\n    const ws = await openWs(docId);\n    const msg = await waitForMessage<{ type: string; content: string; version: number }>(ws);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n\n    ws.close();\n  });\n\n  it('applies an operation and acknowledges', async () => {\n    const createRes = await api('POST', '/documents', { title: 'WS Test', content: 'hello' });\n    const docId = createRes.body.id as string;\n\n    const ws = await openWs(docId);\n    await waitForMessage(ws); // sync\n\n    const op = makeInsert(5, ' world', 5);\n    ws.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 0,\n      operation: op,\n    }));\n\n    const ack = await waitForMessage<{ type: string; version: number }>(ws);\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const res = await api('GET', `/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('broadcasts operations to other clients', async () => {\n    const createRes = await api('POST', '/documents', { title: 'Broadcast Test', content: 'hello' });\n    const docId = createRes.body.id as string;\n\n    const ws1 = await openWs(docId);\n    await waitForMessage(ws1); // sync\n\n    const ws2 = await openWs(docId);\n    await waitForMessage(ws2); // sync\n\n    // Client 1 sends an operation\n    const op = makeInsert(5, ' world', 5);\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 0,\n      operation: op,\n    }));\n\n    // Client 1 gets ack\n    const ack = await waitForMessage<{ type: string }>(ws1);\n    expect(ack.type).toBe('ack');\n\n    // Client 2 gets the broadcast\n    const broadcast = await waitForMessage<{ type: string; operation: unknown }>(ws2);\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.operation).toBeDefined();\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('handles concurrent edits with OT', async () => {\n    const createRes = await api('POST', '/documents', { title: 'OT Test', content: 'hello' });\n    const docId = createRes.body.id as string;\n\n    const ws1 = await openWs(docId);\n    await waitForMessage(ws1); // sync\n\n    const ws2 = await openWs(docId);\n    await waitForMessage(ws2); // sync\n\n    // Client 1: insert ' world' at end, based on version 0\n    const op1 = makeInsert(5, ' world', 5);\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 0,\n      operation: op1,\n    }));\n\n    // Wait for ack and broadcast\n    await waitForMessage(ws1); // ack\n    await waitForMessage(ws2); // broadcast of op1\n\n    // Client 2: insert '!' at end, but based on version 0 (concurrent)\n    const op2 = makeInsert(5, '!', 5);\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 0,\n      operation: op2,\n    }));\n\n    await waitForMessage(ws2); // ack\n\n    // Check final doc\n    const res = await api('GET', `/documents/${docId}`);\n    const content = res.body.content as string;\n    expect(content).toContain('hello');\n    expect(content).toContain(' world');\n    expect(content).toContain('!');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('rejects malformed operations', async () => {\n    const createRes = await api('POST', '/documents', { title: 'Error Test', content: 'hello' });\n    const docId = createRes.body.id as string;\n\n    const ws = await openWs(docId);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 0,\n      operation: 'not-an-array',\n    }));\n\n    const errMsg = await waitForMessage<{ type: string; message: string }>(ws);\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('rejects invalid baseVersion', async () => {\n    const createRes = await api('POST', '/documents', { title: 'Version Test', content: 'hello' });\n    const docId = createRes.body.id as string;\n\n    const ws = await openWs(docId);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 999,\n      operation: [5],\n    }));\n\n    const errMsg = await waitForMessage<{ type: string }>(ws);\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const createRes = await api('POST', '/documents', { title: 'Concurrency Test', content: '' });\n    const docId = createRes.body.id as string;\n\n    const clients: WebSocket[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ws = await openWs(docId);\n      await waitForMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client inserts one character sequentially\n    for (let i = 0; i < 10; i++) {\n      const docRes = await api('GET', `/documents/${docId}`);\n      const content = docRes.body.content as string;\n      const versionsRes = await api('GET', `/documents/${docId}/versions`);\n      const versions = versionsRes.body as unknown as { version: number }[];\n      const latestVersion = versions[versions.length - 1].version;\n\n      const op = makeInsert(content.length, String(i), content.length);\n      clients[i].send(JSON.stringify({\n        type: 'operation',\n        baseVersion: latestVersion,\n        operation: op,\n      }));\n\n      // Wait for ack\n      await waitForMessage(clients[i]);\n\n      // Small delay for broadcasts to propagate\n      await new Promise(r => setTimeout(r, 30));\n\n      // Drain broadcasts from other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i && clients[j].readyState === WebSocket.OPEN) {\n          // Drain any pending messages (non-blocking)\n          // We'll just let them accumulate\n        }\n      }\n    }\n\n    // Verify final state\n    const finalDoc = await api('GET', `/documents/${docId}`);\n    const finalContent = finalDoc.body.content as string;\n    expect(finalContent.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(finalContent).toContain(String(i));\n    }\n\n    for (const ws of clients) ws.close();\n  });\n});\n\ndescribe('Persistence', () => {\n  it('persists documents across server restarts', async () => {\n    const tmpFile = `/tmp/test-collab-${Date.now()}.db`;\n\n    const app1 = createApp(tmpFile);\n    const port1 = await app1.start(0);\n\n    const res = await fetch(`http://localhost:${port1}/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persistent', content: 'saved data' }),\n    });\n    const doc = await res.json();\n\n    await app1.stop();\n\n    const app2 = createApp(tmpFile);\n    const port2 = await app2.start(0);\n\n    const checkRes = await fetch(`http://localhost:${port2}/documents/${doc.id}`);\n    const checkBody = await checkRes.json();\n    expect(checkBody.title).toBe('Persistent');\n    expect(checkBody.content).toBe('saved data');\n\n    await app2.stop();\n\n    const { unlinkSync } = await import('fs');\n    try { unlinkSync(tmpFile); } catch { /* ignore */ }\n  });\n\n  it('persists version history across restarts', async () => {\n    const tmpFile = `/tmp/test-collab-ver-${Date.now()}.db`;\n\n    const app1 = createApp(tmpFile);\n    const port1 = await app1.start(0);\n\n    const createRes = await fetch(`http://localhost:${port1}/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Versioned', content: 'v0' }),\n    });\n    const doc = await createRes.json();\n\n    // Connect via WS and make an edit\n    const ws = new WebSocket(`ws://localhost:${port1}/documents/${doc.id}/ws`);\n    await new Promise<void>((resolve) => ws.on('open', resolve));\n    await waitForMessage(ws); // sync\n\n    const op = makeInsert(2, 'XX', 2);\n    ws.send(JSON.stringify({\n      type: 'operation',\n      baseVersion: 0,\n      operation: op,\n    }));\n    await waitForMessage(ws); // ack\n    ws.close();\n    await new Promise(r => setTimeout(r, 100));\n\n    await app1.stop();\n\n    const app2 = createApp(tmpFile);\n    const port2 = await app2.start(0);\n\n    const versionsRes = await fetch(`http://localhost:${port2}/documents/${doc.id}/versions`);\n    const versions = await versionsRes.json();\n    expect(versions.length).toBe(2);\n    expect(versions[1].version).toBe(1);\n\n    await app2.stop();\n\n    const { unlinkSync } = await import('fs');\n    try { unlinkSync(tmpFile); } catch { /* ignore */ }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":nu