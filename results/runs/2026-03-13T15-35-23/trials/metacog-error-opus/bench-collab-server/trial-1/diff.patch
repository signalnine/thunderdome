tServer, WebSocket } from 'ws';\nimport type { Server as HttpServer } from 'http';\nimport type { DocumentStore } from './db.js';\nimport {\n  type Operation,\n  applyOp,\n  validateOperation,\n  transformAgainstOps,\n} from './ot.js';\n\ninterface ClientConnection {\n  ws: WebSocket;\n  clientId: string;\n  docId: string;\n}\n\ninterface IncomingOperation {\n  type: 'operation';\n  clientId: string;\n  baseVersion: number;\n  operation: Operation;\n}\n\ninterface SyncMessage {\n  type: 'sync';\n  docId: string;\n  content: string;\n  version: number;\n}\n\ninterface AckMessage {\n  type: 'ack';\n  version: number;\n}\n\ninterface BroadcastOperation {\n  type: 'operation';\n  clientId: string;\n  version: number;\n  operation: Operation;\n}\n\ninterface ErrorMessage {\n  type: 'error';\n  message: string;\n}\n\ntype OutgoingMessage = SyncMessage | AckMessage | BroadcastOperation | ErrorMessage;\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private store: DocumentStore;\n  // Map from docId -> set of client connections\n  private rooms: Map<string, Set<ClientConnection>> = new Map();\n\n  constructor(httpServer: HttpServer, store: DocumentStore) {\n    this.store = store;\n    this.wss = new WebSocketServer({ noServer: true });\n\n    httpServer.on('upgrade', (request, socket, head) => {\n      const rawUrl = request.url || '/';\n      const url = new URL(rawUrl, `http://${request.headers.host || 'localhost'}`);\n      const pathParts = url.pathname.split('/').filter(Boolean);\n\n      // Supported paths: /documents/:docId/ws, /ws/documents/:docId, /ws/:docId\n      let docId: string | null = null;\n\n      if (pathParts.length >= 3 && pathParts[0] === 'documents' && pathParts[2] === 'ws') {\n        docId = pathParts[1];\n      } else if (pathParts.length >= 3 && pathParts[0] === 'ws' && pathParts[1] === 'documents') {\n        docId = pathParts[2];\n      } else if (pathParts.length >= 2 && pathParts[0] === 'ws') {\n        docId = pathParts[1];\n      }\n\n      if (!docId) {\n        socket.destroy();\n        return;\n      }\n\n      const doc = this.store.getDocument(docId);\n      if (!doc) {\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        console.log('[DEBUG] handleUpgrade callback, ws.readyState:', ws.readyState);\n        this.handleConnection(ws, docId!);\n      });\n    });\n  }\n\n  private handleConnection(ws: WebSocket, docId: string): void {\n    const clientId = Math.random().toString(36).substring(2, 10);\n    const conn: ClientConnection = { ws, clientId, docId };\n\n    if (!this.rooms.has(docId)) {\n      this.rooms.set(docId, new Set());\n    }\n    this.rooms.get(docId)!.add(conn);\n\n    // Send sync message with current state\n    const doc = this.store.getDocument(docId);\n    console.log('[DEBUG] handleConnection docId:', docId, 'doc:', doc ? 'found' : 'NOT FOUND', 'ws.readyState:', ws.readyState);\n    if (doc) {\n      const version = this.store.getLatestVersion(docId);\n      const msg = {\n        type: 'sync' as const,\n        docId,\n        content: doc.content,\n        version,\n      };\n      console.log('[DEBUG] Sending sync, ws.readyState:', ws.readyState);\n      this.send(ws, msg);\n      console.log('[DEBUG] Sync sent');\n    }\n\n    ws.on('message', (data) => {\n      try {\n        const msg = JSON.parse(data.toString());\n        this.handleMessage(conn, msg);\n      } catch (err) {\n        this.send(ws, {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        });\n      }\n    });\n\n    ws.on('close', () => {\n      const room = this.rooms.get(docId);\n      if (room) {\n        room.delete(conn);\n        if (room.size === 0) {\n          this.rooms.delete(docId);\n        }\n      }\n    });\n\n    ws.on('error', () => {\n      const room = this.rooms.get(docId);\n      if (room) {\n        room.delete(conn);\n        if (room.size === 0) {\n          this.rooms.delete(docId);\n        }\n      }\n    });\n  }\n\n  private handleMessage(conn: ClientConnection, msg: unknown): void {\n    if (!msg || typeof msg !== 'object') {\n      this.send(conn.ws, { type: 'error', message: 'Invalid message format' });\n      return;\n    }\n\n    const opMsg = msg as IncomingOperation;\n\n    if (opMsg.type !== 'operation') {\n      this.send(conn.ws, { type: 'error', message: `Unknown message type: ${(msg as {type?: string}).type}` });\n      return;\n    }\n\n    if (!Array.isArray(opMsg.operation)) {\n      this.send(conn.ws, { type: 'error', message: 'operation must be an array' });\n      return;\n    }\n\n    if (typeof opMsg.baseVersion !== 'number') {\n      this.send(conn.ws, { type: 'error', message: 'baseVersion must be a number' });\n      return;\n    }\n\n    const doc = this.store.getDocument(conn.docId);\n    if (!doc) {\n      this.send(conn.ws, { type: 'error', message: 'Document not found' });\n      return;\n    }\n\n    const currentVersion = this.store.getLatestVersion(conn.docId);\n\n    if (opMsg.baseVersion < 0 || opMsg.baseVersion > currentVersion) {\n      this.send(conn.ws, {\n        type: 'error',\n        message: `Invalid baseVersion: ${opMsg.baseVersion}. Current version is ${currentVersion}`,\n      });\n      return;\n    }\n\n    // Get all operations that happened since the client's base version\n    const serverVersions = this.store.getOperationsSinceVersion(conn.docId, opMsg.baseVersion);\n    const serverOps: Operation[] = serverVersions\n      .filter(v => v.operation !== null)\n      .map(v => JSON.parse(v.operation!) as Operation);\n\n    // Transform the incoming operation against all server ops\n    let transformedOp: Operation;\n    try {\n      transformedOp = transformAgainstOps(opMsg.operation, serverOps);\n    } catch (err) {\n      this.send(conn.ws, {\n        type: 'error',\n        message: `Transform failed: ${err instanceof Error ? err.message : 'unknown error'}`,\n      });\n      return;\n    }\n\n    // Validate the transformed operation against current document\n    const validationError = validateOperation(transformedOp, doc.content.length);\n    if (validationError) {\n      this.send(conn.ws, { type: 'error', message: validationError });\n      return;\n    }\n\n    // Apply the transformed operation\n    let newContent: string;\n    try {\n      newContent = applyOp(doc.content, transformedOp);\n    } catch (err) {\n      this.send(conn.ws, {\n        type: 'error',\n        message: `Apply failed: ${err instanceof Error ? err.message : 'unknown error'}`,\n      });\n      return;\n    }\n\n    // Persist the new version\n    const newVersion = this.store.applyOperation(conn.docId, newContent, transformedOp);\n\n    // Acknowledge to the sender\n    this.send(conn.ws, { type: 'ack', version: newVersion });\n\n    // Broadcast to other clients in the room\n    const room = this.rooms.get(conn.docId);\n    if (room) {\n      const broadcastMsg: BroadcastOperation = {\n        type: 'operation',\n        clientId: conn.clientId,\n        version: newVersion,\n        operation: transformedOp,\n      };\n      for (const client of room) {\n        if (client !== conn && client.ws.readyState === 1) {\n          this.send(client.ws, broadcastMsg);\n        }\n      }\n    }\n  }\n\n  private send(ws: WebSocket, msg: OutgoingMessage): void {\n    if (ws.readyState === 1) { // WebSocket.OPEN = 1\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  closeAll(): void {\n    for (const [, room] of this.rooms) {\n      for (const conn of room) {\n        conn.ws.close();\n      }\n    }\n    this.rooms.clear();\n    this.wss.close();\n  }\n}\n","numLines":267,"startLine":1,"totalLines":267}}}
