retain over it in b'\n    if (ca !== null && typeof ca === 'string') {\n      aPrime.push(ca);\n      bPrime.push(ca.length);\n      ia++;\n      continue;\n    }\n\n    // b inserts: include in b', retain over it in a'\n    if (cb !== null && typeof cb === 'string') {\n      bPrime.push(cb);\n      aPrime.push(cb.length);\n      ib++;\n      continue;\n    }\n\n    if (ca === null && cb === null) break;\n\n    if (ca === null || cb === null) {\n      throw new Error('Transform: operations have different input lengths');\n    }\n\n    // Both are numbers now (retain or delete, magnitude 1 from expansion)\n    const numA = ca as number;\n    const numB = cb as number;\n\n    if (numA === 1 && numB === 1) {\n      // both retain\n      aPrime.push(1);\n      bPrime.push(1);\n    } else if (numA === -1 && numB === -1) {\n      // both delete same char — neither needs to do anything\n    } else if (numA === -1 && numB === 1) {\n      // a deletes, b retains — a' deletes, b' skips\n      aPrime.push(-1);\n    } else if (numA === 1 && numB === -1) {\n      // a retains, b deletes — b' deletes, a' skips\n      bPrime.push(-1);\n    }\n\n    ia++;\n    ib++;\n  }\n\n  return [normalize(aPrime), normalize(bPrime)];\n}\n\n/**\n * Expand an operation into unit-sized components.\n * Retains become multiple 1s, deletes become multiple -1s, inserts stay as strings.\n */\nfunction expand(op: Operation): OpComponent[] {\n  const result: OpComponent[] = [];\n  for (const c of op) {\n    if (typeof c === 'string') {\n      result.push(c);\n    } else if (c > 0) {\n      for (let i = 0; i < c; i++) result.push(1);\n    } else if (c < 0) {\n      for (let i = 0; i < Math.abs(c); i++) result.push(-1);\n    }\n  }\n  return result;\n}\n\n/**\n * Transform operation `op` against a sequence of operations that have been applied since `op`'s base version.\n * Returns the transformed operation that can be applied to the current document state.\n */\nexport function transformAgainstOps(op: Ope