t(app.app)\n      .get(`/documents/${createRes.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe('Test');\n    expect(res.body.content).toBe('content');\n  });\n\n  it('returns 404 for missing document', async () => {\n    await request(app.app).get('/documents/nonexistent').expect(404);\n  });\n\n  it('updates a document', async () => {\n    const createRes = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Original' });\n\n    const res = await request(app.app)\n      .put(`/documents/${createRes.body.id}`)\n      .send({ title: 'Updated', content: 'new content' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('new content');\n  });\n\n  it('deletes a document', async () => {\n    const createRes = await request(app.app)\n      .post('/documents')\n      .send({ title: 'To Delete' });\n\n    await request(app.app)\n      .delete(`/documents/${createRes.body.id}`)\n      .expect(204);\n\n    await request(app.app)\n      .get(`/documents/${createRes.body.id}`)\n      .expect(404);\n  });\n\n  it('gets version history', async () => {\n    const createRes = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Versioned', content: 'v0' });\n\n    const res = await request(app.app)\n      .get(`/documents/${createRes.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBe(1);\n    expect(res.body[0].version).toBe(0);\n    expect(res.body[0].content).toBe('v0');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('sends sync message on connect', async () => {\n    const createRes = await request(app.app)\n      .post('/documents')\n      .send({ title: 'WS Test', content: 'hello' });\n    const docId = createRes.body.id;\n\n    const ws = await openWs(docId);\n    const m