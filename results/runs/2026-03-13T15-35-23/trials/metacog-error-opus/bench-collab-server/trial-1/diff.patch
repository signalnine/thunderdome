0) {\n          this.rooms.delete(docId);\n        }\n      }\n    });\n\n    ws.on('error', () => {\n      const room = this.rooms.get(docId);\n      if (room) {\n        room.delete(conn);\n        if (room.size === 0) {\n          this.rooms.delete(docId);\n        }\n      }\n    });\n  }\n\n  private handleMessage(conn: ClientConnection, msg: unknown): void {\n    if (!msg || typeof msg !== 'object') {\n      this.send(conn.ws, { type: 'error', message: 'Invalid message format' });\n      return;\n    }\n\n    const opMsg = msg as IncomingOperation;\n\n    if (opMsg.type !== 'operation') {\n      this.send(conn.ws, { type: 'error', message: `Unknown message type: ${(msg as {type?: string}).type}` });\n      return;\n    }\n\n    if (!Array.isArray(opMsg.operation)) {\n      this.send(conn.ws, { type: 'error', message: 'operation must be an array' });\n      return;\n    }\n\n    if (typeof opMsg.baseVersion !== 'number') {\n      this.send(conn.ws, { type: 'error', message: 'baseVersion must be a number' });\n      return;\n    }\n\n    const doc = this.store.getDocument(conn.docId);\n    if (!doc) {\n      this.send(conn.ws, { type: 'error', message: 'Document not found' });\n      return;\n    }\n\n    const currentVersion = this.store.getLatestVersion(conn.docId);\n\n    if (opMsg.baseVersion < 0 || opMsg.baseVersion > currentVersion) {\n      this.send(conn.ws, {\n        type: 'error',\n        message: `Invalid baseVersion: ${opMsg.baseVersion}. Current version is ${currentVersion}`,\n      });\n      return;\n    }\n\n    // Get all operations that happened since the client's base version\n    const serverVersions = this.store.getOperationsSinceVersion(conn.docId, opMsg.baseVersion);\n    const serverOps: Operation[] = serverVersions\n      .filter(v => v.operation !== null)\n      .map(v => JSON.parse(v.operation!) as Operation);\n\n    // Transform the incoming operation against all server ops\n    let transformedOp: Operation;\n    try {\n      transf