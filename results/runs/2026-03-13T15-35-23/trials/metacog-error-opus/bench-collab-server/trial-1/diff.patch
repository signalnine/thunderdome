});\n\n  it('rejects malformed operations', async () => {\n    const createRes = await apiPost('/documents', { title: 'Error Test', content: 'hello' });\n    const docId = createRes.body.id as string;\n\n    const client = await connectWs(docId);\n    await client.recv(); // sync\n\n    client.send({ type: 'operation', baseVersion: 0, operation: 'not-an-array' });\n\n    const errMsg = await client.recv<{ type: string; message: string }>();\n    expect(errMsg.type).toBe('error');\n\n    client.close();\n  });\n\n  it('rejects invalid baseVersion', async () => {\n    const createRes = await apiPost('/documents', { title: 'Version Test', content: 'hello' });\n    const docId = createRes.body.id as string;\n\n    const client = await connectWs(docId);\n    await client.recv(); // sync\n\n    client.send({ type: 'operation', baseVersion: 999, operation: [5] });\n\n    const errMsg = await client.recv<{ type: string }>();\n    expect(errMsg.type).toBe('error');\n\n    client.close();\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const createRes = await apiPost('/documents', { title: 'Concurrency Test', content: '' });\n    const docId = createRes.body.id as string;\n\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = await connectWs(docId);\n      await c.recv(); // sync\n      clients.push(c);\n    }\n\n    // Each client inserts one character sequentially\n    for (let i = 0; i < 10; i++) {\n      const docRes = await apiGet(`/documents/${docId}`);\n      const content = docRes.body.content as string;\n      const versionsRes = await apiGet(`/documents/${docId}/versions`);\n      const versions = versionsRes.body as unknown as { version: number }[];\n      const latestVersion = versions[versions.length - 1].version;\n\n      const op = makeInsert(content.length, String(i), content.length);\n      clients[i].send({ type: 'operation', baseVersion: latestVersion, operation: op });\n\n      awai