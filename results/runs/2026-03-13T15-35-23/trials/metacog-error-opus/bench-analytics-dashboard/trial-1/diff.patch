,\n        ],\n      });\n\n    expect(res.status).toBe(201);\n    expect(res.body.inserted).toBe(3);\n  });\n\n  it(\"should reject unauthenticated event ingestion\", async () => {\n    const res = await request(app)\n      .post(\"/api/events\")\n      .send({ name: \"page_view\" });\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe(\"Query Engine\", () => {\n  let token: string;\n\n  beforeEach(async () => {\n    const reg = await request(app)\n      .post(\"/api/users/register\")\n      .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"tenant1\" });\n    token = reg.body.token;\n\n    // Ingest test events\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-01T14:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-02T10:00:00Z\" },\n          { name: \"click\", properties: { element: \"button\" }, timestamp: \"2024-01-02T12:00:00Z\" },\n        ],\n      });\n  });\n\n  it(\"should count events\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\" });\n\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(3);\n  });\n\n  it(\"should count events with date filter\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", startDate: \"2024-01-02\", endDate: \"2024-01-03\" });\n\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(1);\n  });\n\n  it(\"should return timeseries data\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/timeseries\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", interval: \"day\" });\n\n    expect(res.status).toBe(200);\n    expect(res.body.data.length).toBe(2);\n  });\n\n  it(\"should return breakdown data\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/breakdown\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", property: \"url\" });\n\n    expect(res.status).toBe(200);\n    expect(res.body.data.length).toBe(2);\n    // /home should have count 2, /about count 1\n    const homeEntry = res.body.data.find((d: { value: string }) => d.value === \"/home\");\n    expect(homeEntry.count).toBe(2);\n  });\n});\n\ndescribe(\"Tenant Isolation\", () => {\n  let token1: string;\n  let token2: string;\n\n  beforeEach(async () => {\n    const reg1 = await request(app)\n      .post(\"/api/users/register\")\n      .send({ email: \"user1@t1.com\", password: \"pass\", tenantId: \"tenant1\" });\n    token1 = reg1.body.token;\n\n    const reg2 = await request(app)\n      .post(\"/api/users/register\")\n      .send({ email: \"user2@t2.com\", password: \"pass\", tenantId: \"tenant2\" });\n    token2 = reg2.body.token;\n\n    // Tenant 1 events\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token1}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"page_view\", properties: { url: \"/about\" } },\n        ],\n      });\n\n    // Tenant 2 events\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token2}`)\n      .send({\n        events: [{ name: \"page_view\", properties: { url: \"/pricing\" } }],\n      });\n  });\n\n  it(\"should only count events for the requesting tenant\", async () => {\n    const res1 = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token1}`)\n      .send({ eventName: \"page_view\" });\n\n    expect(res1.body.count).toBe(2);\n\n    const res2 = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token2}`)\n      .send({ eventName: \"page_view\" });\n\n    expect(res2.body.count).toBe(1);\n  });\n\n  it(\"should not allow tenant2 to see tenant1's dashboards\", async () => {\n    // Create dashboard as tenant1\n    const dash = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token1}`)\n      .send({ name: \"My Dashboard\" });\n\n    // Try to access as tenant2\n    const res = await request(app)\n      .get(`/api/dashboards/${dash.body.id}`)\n      .set(\"Authorization\", `Bearer ${token2}`);\n\n    expect(res.status).toBe(404);\n  });\n\n  it(\"should only export events for the requesting tenant\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token1}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(2);\n  });\n});\n\ndescribe(\"Dashboard CRUD\", () => {\n  let token: string;\n\n  beforeEach(async () => {\n    const reg = await request(app)\n      .post(\"/api/users/register\")\n      .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"tenant1\" });\n    token = reg.body.token;\n  });\n\n  it(\"should create a dashboard\", async () => {\n    const res = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Sales Dashboard\", config: { theme: \"dark\" } });\n\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"Sales Dashboard\");\n  });\n\n  it(\"should list dashboards\", async () => {\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 2\" });\n\n    const res = await request(app)\n      .get(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.dashboards.length).toBe(2);\n  });\n\n  it(\"should update a dashboard\", async () => {\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Old Name\" });\n\n    const res = await request(app)\n      .put(`/api/dashboards/${created.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"New Name\" });\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"New Name\");\n  });\n\n  it(\"should delete a dashboard\", async () => {\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"To Delete\" });\n\n    const res = await request(app)\n      .delete(`/api/dashboards/${created.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(204);\n  });\n});\n\ndescribe(\"Data Export\", () => {\n  let token: string;\n\n  beforeEach(async () => {\n    const reg = await request(app)\n      .post(\"/api/users/register\")\n      .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"tenant1\" });\n    token = reg.body.token;\n\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"click\", properties: { element: \"btn\" } },\n        ],\n      });\n  });\n\n  it(\"should export events as JSON\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(2);\n  });\n\n  it(\"should export events as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,tenant_id,name\");\n  });\n\n  it(\"should export dashboard as JSON\", async () => {\n    const dash = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Export Me\" });\n\n    const res = await request(app)\n      .get(`/api/export/dashboards/${dash.body.id}/json`)\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.dashboard.name).toBe(\"Export Me\");\n  });\n\n  it(\"should export dashboard as CSV\", async () => {\n    const dash = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Export Me\" });\n\n    const res = await request(app)\n      .get(`/api/export/dashboards/${dash.body.id}/csv`)\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"Export Me\");\n  });\n\n  it(\"should reject unauthenticated export\", async () => {\n    const res = await request(app).get(\"/api/export/events/json\");\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
