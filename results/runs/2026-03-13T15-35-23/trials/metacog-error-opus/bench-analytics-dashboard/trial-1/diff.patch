on_x,position_y,width,height\";\n    const rows = widgets.map((w) =>\n      [\n        escapeCsvField(w.id),\n        escapeCsvField(w.type),\n        escapeCsvField(w.config),\n        String(w.position_x),\n        String(w.position_y),\n        String(w.width),\n        String(w.height),\n      ].join(\",\")\n    );\n\n    const csv = `dashboard_id,name,owner_id\\n${escapeCsvField(dashboard.id)},${escapeCsvField(dashboard.name)},${escapeCsvField(dashboard.owner_id)}\\n\\n${header}\\n${rows.join(\"\\n\")}`;\n\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", `attachment; filename=dashboard-${id}.csv`);\n    res.send(csv);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2112,"cache_read_input_tokens":25802,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2112},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"43289af4-d5d7-4d48-bcfc-22c3c20e73f8","uuid":"474eb3aa-14d0-4e81-9c9f-307196180ea9"}
