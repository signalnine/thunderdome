+import { describe, it, expect, beforeEach } from "vitest";
+import request from "supertest";
+import { createApp } from "./app.js";
+import { createDatabase } from "./db.js";
+import type { Application } from "express";
+import type Database from "better-sqlite3";
+
+let app: Application;
+let db: Database.Database;
+
+beforeEach(() => {
+  db = createDatabase(":memory:");
+  app = createApp(db);
+});
+
+describe("User Management", () => {
+  it("should register a new user", async () => {
+    const res = await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass123", tenantId: "tenant1" });
+
+    expect(res.status).toBe(201);
+    expect(res.body.email).toBe("test@example.com");
+    expect(res.body.tenantId).toBe("tenant1");
+    expect(res.body.token).toBeDefined();
+    expect(res.body.role).toBe("viewer");
+  });
+
+  it("should register with a role", async () => {
+    const res = await request(app)
+      .post("/api/users/register")
+      .send({ email: "admin@example.com", password: "pass123", tenantId: "tenant1", role: "admin" });
+
+    expect(res.status).toBe(201);
+    expect(res.body.role).toBe("admin");
+  });
+
+  it("should reject duplicate emails", async () => {
+    await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass123", tenantId: "tenant1" });
+
+    const res = await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass456", tenantId: "tenant1" });
+
+    expect(res.status).toBe(409);
+  });
+
+  it("should login and return a token", async () => {
+    await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass123", tenantId: "tenant1" });
+
+    const res = await request(app)
+      .post("/api/users/login")
+      .send({ email: "test@example.com", password: "pass123" });
+
+    expect(res.status).toBe(200);
+    expect(res.body.token).toBeDefined();
+  });
+
+  it("should reject wrong password", async () => {
+    await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass123", tenantId: "tenant1" });
+
+    const res = await request(app)
+      .post("/api/users/login")
+      .send({ email: "test@example.com", password: "wrong" });
+
+    expect(res.status).toBe(401);
+  });
+
+  it("should get user profile", async () => {
+    const reg = await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass123", tenantId: "tenant1" });
+
+    const res = await request(app)
+      .get("/api/users/me")
+      .set("Authorization", `Bearer ${reg.body.token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.email).toBe("test@example.com");
+    expect(res.body.tenantId).toBe("tenant1");
+  });
+
+  it("should reject unauthenticated access to profile", async () => {
+    const res = await request(app).get("/api/users/me");
+    expect(res.status).toBe(401);
+  });
+
+  it("should change user role (admin only)", async () => {
+    const admin = await request(app)
+      .post("/api/users/register")
+      .send({ email: "admin@t1.com", password: "pass", tenantId: "tenant1", role: "admin" });
+
+    const viewer = await request(app)
+      .post("/api/users/register")
+      .send({ email: "viewer@t1.com", password: "pass", tenantId: "tenant1" });
+
+    const res = await request(app)
+      .put(`/api/users/${viewer.body.id}/role`)
+      .set("Authorization", `Bearer ${admin.body.token}`)
+      .send({ role: "editor" });
+
+    expect(res.status).toBe(200);
+    expect(res.body.role).toBe("editor");
+  });
+
+  it("should not allow non-admins to change roles", async () => {
+    const viewer = await request(app)
+      .post("/api/users/register")
+      .send({ email: "viewer@t1.com", password: "pass", tenantId: "tenant1" });
+
+    const other = await request(app)
+      .post("/api/users/register")
+      .send({ email: "other@t1.com", password: "pass", tenantId: "tenant1" });
+
+    const res = await request(app)
+      .put(`/api/users/${other.body.id}/role`)
+      .set("Authorization", `Bearer ${viewer.body.token}`)
+      .send({ role: "admin" });
+
+    expect(res.status).toBe(403);
+  });
+});
+
+describe("Event Ingestion", () => {
+  let token: string;
+
+  beforeEach(async () => {
+    const reg = await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass123", tenantId: "tenant1" });
+    token = reg.body.token;
+  });
+
+  it("should ingest a single event", async () => {
+    const res = await request(app)
+      .post("/api/events")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ name: "page_view", properties: { url: "/home" } });
+
+    expect(res.status).toBe(201);
+    expect(res.body.name).toBe("page_view");
+    expect(res.body.properties.url).toBe("/home");
+  });
+
+  it("should ingest batch events", async () => {
+    const res = await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view", properties: { url: "/home" } },
+          { name: "click", properties: { element: "button" } },
+          { name: "page_view", properties: { url: "/about" } },
+        ],
+      });
+
+    expect(res.status).toBe(201);
+    expect(res.body.inserted).toBe(3);
+  });
+
+  it("should reject unauthenticated event ingestion", async () => {
+    const res = await request(app)
+      .post("/api/events")
+      .send({ name: "page_view" });
+    expect(res.status).toBe(401);
+  });
+});
+
+describe("Query Engine", () => {
+  let token: string;
+
+  beforeEach(async () => {
+    const reg = await request(app)
+      .post("/api/users/register")
+      .send({ email: "test@example.com", password: "pass123", tenantId: "tenant1" });
+    token = reg.body.token;
+
+    // Ingest test events
+    await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-01T10:00:00Z" },
+          { name: "page_view", properties: { url: "/about" }, timestamp: "2024-01-01T14:00:00Z" },
+          { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-02T10:00:00Z" },
+          { name: "click", properties: { element: "button" }, timestamp: "2024-01-02T12:00:00Z" },
+        ],
+      });
+  });
+
+  it("should count events", async () => {
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ eventName: "page_view" });
+
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(3);
+  });
+
+  it("should count events with date filter", async () => {
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ eventName: "page_view", startDate: "2024-01-02", endDate: "2024-01-03" });
+
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(1);
+  });
+
+  it("should return timeseries data", async () => {
+    const res = await request(app)
+      .post("/api/queries/timeseries")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ eventName: "page_view", interval: "day" });
+
+    expect(res.status).toBe(200);
+    expect(res.body.data.length).toBe(2);
+  });
+
+  it("should return breakdown data", async () => {
+    const res = await request(app)
+      .post("/api/queries/breakdown")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ eventName: "page_view", property: "url" });
+
+    expect(res.status).toBe(200);
+    expect(res.body.data.length).toBe(2);
+    // /home should have count 2, /about count 1
+    const homeEntry = res.body.data.find((d: { value: string }) => d.value === "/home");
+    expect(homeEntry.count).toBe(2);
+  });
+});
+
+describe("Tenant Isolation", () => {
+  let token1: string;
+  let token2: string;
+
+  beforeEach(async () => {
