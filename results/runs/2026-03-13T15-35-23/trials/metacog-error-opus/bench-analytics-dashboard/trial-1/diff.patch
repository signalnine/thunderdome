@@ -0,0 +1,151 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+interface CountResult {
+  count: number;
+}
+
+interface TimeseriesRow {
+  bucket: string;
+  count: number;
+}
+
+interface BreakdownRow {
+  value: string | null;
+  count: number;
+}
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const { eventName, startDate, endDate, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as CountResult;
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    // Default to daily buckets
+    const bucketInterval = interval || "day";
+
+    let dateFormat: string;
+    switch (bucketInterval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "month":
+        dateFormat = "%Y-%m-01";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const rows = db.prepare(sql).all(...params) as TimeseriesRow[];
+    res.json({ data: rows });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const { eventName, property, startDate, endDate, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const rows = db.prepare(sql).all(...params) as BreakdownRow[];
+    res.json({ data: rows });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..1ae9094
--- /dev/null
+++ b/src/routes/users.ts
@@ -0,0 +1,147 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { createHash } from "crypto";
+import { v4 as uuidv4 } from "uuid";
+import { AuthenticatedRequest, authMiddleware, requireRole, signToken } from "../auth.js";
+
+function hashPassword(password: string): string {
+  return createHash("sha256").update(password).digest("hex");
+}
+
+export function createUserRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Register
+  router.post("/register", (req: AuthenticatedRequest, res: Response): void => {
+    const { email, password, tenantId, role } = req.body;
+
+    if (!email || !password || !tenantId) {
+      res.status(400).json({ error: "email, password, and tenantId are required" });
+      return;
+    }
+
+    const validRoles = ["admin", "editor", "viewer"];
+    const userRole = role && validRoles.includes(role) ? role : "viewer";
+
+    const existing = db.prepare("SELECT id FROM users WHERE email = ?").get(email);
+    if (existing) {
+      res.status(409).json({ error: "Email already registered" });
+      return;
+    }
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+
+    db.prepare(
+      "INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, email, passwordHash, tenantId, userRole);
+
+    const token = signToken({ userId: id, email, tenantId, role: userRole });
+
+    res.status(201).json({
+      id,
+      email,
+      tenantId,
+      role: userRole,
+      token,
+    });
+  });
+
+  // Login
+  router.post("/login", (req: AuthenticatedRequest, res: Response): void => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: "email and password are required" });
+      return;
+    }
+
+    const user = db.prepare("SELECT * FROM users WHERE email = ?").get(email) as
+      | { id: string; email: string; password_hash: string; tenant_id: string; role: string }
+      | undefined;
+
+    if (!user) {
+      res.status(401).json({ error: "Invalid credentials" });
+      return;
+    }
+
+    const passwordHash = hashPassword(password);
+    if (user.password_hash !== passwordHash) {
+      res.status(401).json({ error: "Invalid credentials" });
+      return;
+    }
+
+    const token = signToken({
+      userId: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+    });
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      token,
+    });
+  });
+
+  // Get profile
+  router.get("/me", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const user = db.prepare("SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?").get(
+      req.user!.userId
+    ) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: "User not found" });
+      return;
+    }
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      createdAt: user.created_at,
+    });
+  });
+
+  // Change user role (admin only, same tenant)
+  router.put(
+    "/:userId/role",
+    authMiddleware,
+    requireRole("admin"),
+    (req: AuthenticatedRequest, res: Response): void => {
+      const { userId } = req.params;
+      const { role } = req.body;
+
+      const validRoles = ["admin", "editor", "viewer"];
+      if (!role || !validRoles.includes(role)) {
+        res.status(400).json({ error: "Valid role is required (admin, editor, viewer)" });
+        return;
+      }
+
+      // Tenant isolation: only update users in same tenant
+      const targetUser = db.prepare("SELECT id, tenant_id FROM users WHERE id = ? AND tenant_id = ?").get(
+        userId,
+        req.user!.tenantId
+      ) as { id: string; tenant_id: string } | undefined;
+
+      if (!targetUser) {
+        res.status(404).json({ error: "User not found in your organization" });
+        return;
+      }
+
+      db.prepare("UPDATE users SET role = ? WHERE id = ? AND tenant_id = ?").run(
+        role,
+        userId,
+        req.user!.tenantId
+      );
+
+      res.json({ id: userId, role });
+    }
+  );
+
+  return router;
+}
