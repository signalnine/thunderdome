\n    const res2 = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token2}`)\n      .send({ eventName: \"page_view\" });\n\n    expect(res2.body.count).toBe(1);\n  });\n\n  it(\"should not allow tenant2 to see tenant1's dashboards\", async () => {\n    // Create dashboard as tenant1\n    const dash = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token1}`)\n      .send({ name: \"My Dashboard\" });\n\n    // Try to access as tenant2\n    const res = await request(app)\n      .get(`/api/dashboards/${dash.body.id}`)\n      .set(\"Authorization\", `Bearer ${token2}`);\n\n    expect(res.status).toBe(404);\n  });\n\n  it(\"should only export events for the requesting tenant\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token1}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(2);\n  });\n});\n\ndescribe(\"Dashboard CRUD\", () => {\n  let token: string;\n\n  beforeEach(async () => {\n    const reg = await request(app)\n      .post(\"/api/users/register\")\n      .send({ email: \"test@example.com\", password: \"pass123\", tenantId: \"tenant1\" });\n    token = reg.body.token;\n  });\n\n  it(\"should create a dashboard\", async () => {\n    const res = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Sales Dashboard\", config: { theme: \"dark\" } });\n\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"Sales Dashboard\");\n  });\n\n  it(\"should list dashboards\", async () => {\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 2\" }