index 0000000..e718f0e
--- /dev/null
+++ b/src/routes/dashboards.ts
@@ -0,0 +1,213 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post("/", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, ownerId, dashConfig);
+
+    res.status(201).json({
+      id,
+      tenantId,
+      name,
+      ownerId,
+      config: config || {},
+      createdAt: new Date().toISOString(),
+      updatedAt: new Date().toISOString(),
+    });
+  });
+
+  // List dashboards for tenant
+  router.get("/", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const rows = db.prepare("SELECT * FROM dashboards WHERE tenant_id = ?").all(tenantId) as DashboardRow[];
+
+    const dashboards = rows.map((row) => ({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+    }));
+
+    res.json({ dashboards });
+  });
+
+  // Get single dashboard with widgets
+  router.get("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { id } = req.params;
+
+    const row = db.prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?").get(
+      id,
+      tenantId
+    ) as DashboardRow | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare("SELECT * FROM widgets WHERE dashboard_id = ?").all(row.id) as WidgetRow[];
+
+    res.json({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+      widgets: widgets.map((w) => ({
+        id: w.id,
+        dashboardId: w.dashboard_id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        positionX: w.position_x,
+        positionY: w.position_y,
+        width: w.width,
+        height: w.height,
+      })),
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { id } = req.params;
+    const { name, config } = req.body;
+
+    const existing = db.prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?").get(
+      id,
+      tenantId
+    ) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ? AND tenant_id = ?"
+    ).run(updatedName, updatedConfig, now, id, tenantId);
+
+    res.json({
+      id,
+      tenantId,
+      name: updatedName,
+      ownerId: existing.owner_id,
+      config: config || JSON.parse(existing.config),
+      createdAt: existing.created_at,
+      updatedAt: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { id } = req.params;
+
+    const existing = db.prepare("SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?").get(
+      id,
+      tenantId
+    ) as { id: string } | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ? AND tenant_id = ?").run(id, tenantId);
+
+    res.status(204).send();
+  });
+
+  // Add widget to dashboard
+  router.post("/:id/widgets", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { id: dashboardId } = req.params;
+    const { type, config, positionX, positionY, width, height } = req.body;
+
+    // Verify dashboard belongs to tenant
+    const dashboard = db.prepare("SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?").get(
+      dashboardId,
+      tenantId
+    ) as { id: string } | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const validTypes = ["counter", "timeseries", "breakdown", "funnel"];
+    if (!type || !validTypes.includes(type)) {
+      res.status(400).json({ error: "Valid widget type is required (counter, timeseries, breakdown, funnel)" });
+      return;
+    }
+
+    const widgetId = uuidv4();
+    const widgetConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+    ).run(widgetId, dashboardId, type, widgetConfig, positionX || 0, positionY || 0, width || 1, height || 1);
+
+    res.status(201).json({
+      id: widgetId,
+      dashboardId,
+      type,
+      config: config || {},
+      positionX: positionX || 0,
+      positionY: positionY || 0,
+      width: width || 1,
+      height: height || 1,
+    });
+  });
+
+  return router;
+}
