nsertStmt = db.prepare(\n      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    );\n\n    const insertMany = db.transaction((eventList: typeof events) => {\n      const results: Array<{ id: string; name: string }> = [];\n      for (const event of eventList) {\n        if (!event.name) continue;\n        const id = uuidv4();\n        const eventTimestamp = event.timestamp || new Date().toISOString();\n        const eventProperties = event.properties ? JSON.stringify(event.properties) : \"{}\";\n        insertStmt.run(id, tenantId, event.name, eventProperties, eventTimestamp, userId, event.sessionId || null);\n        results.push({ id, name: event.name });\n      }\n      return results;\n    });\n\n    const results = insertMany(events);\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1391,"cache_read_input_tokens":22198,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1391},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"43289af4-d5d7-4d48-bcfc-22c3c20e73f8","uuid":"87675abe-ed35-4db9-a378-04f9c89ae66d"}
