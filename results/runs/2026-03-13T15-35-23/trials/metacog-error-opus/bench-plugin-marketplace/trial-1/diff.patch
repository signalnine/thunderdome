new file mode 100644
index 0000000..47071d1
--- /dev/null
+++ b/src/deps/deps.test.ts
@@ -0,0 +1,163 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { RegistryService, DepsService, PluginManifest } from '../types.js';
+
+function makeManifest(
+  name: string,
+  deps: Record<string, string> = {}
+): PluginManifest {
+  return {
+    name,
+    version: '1.0.0',
+    description: `Plugin ${name}`,
+    author: 'tester',
+    dependencies: deps,
+    entryPoint: `console.log("${name}")`,
+    permissions: [],
+  };
+}
+
+describe('Dependency Graph', () => {
+  let depsService: DepsService;
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    depsService = createDepsService();
+    registry = createRegistry();
+  });
+
+  describe('buildTree', () => {
+    it('should build a tree with no dependencies', () => {
+      registry.register(makeManifest('root'));
+      const tree = depsService.buildTree('root', registry);
+
+      expect(tree.name).toBe('root');
+      expect(tree.version).toBe('1.0.0');
+      expect(tree.dependencies).toEqual([]);
+    });
+
+    it('should build a tree with nested dependencies', () => {
+      registry.register(makeManifest('root', { child: '^1.0.0' }));
+      registry.register(makeManifest('child', { grandchild: '^1.0.0' }));
+      registry.register(makeManifest('grandchild'));
+
+      const tree = depsService.buildTree('root', registry);
+      expect(tree.name).toBe('root');
+      expect(tree.dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].name).toBe('child');
+      expect(tree.dependencies[0].dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].dependencies[0].name).toBe('grandchild');
+    });
+
+    it('should handle missing dependencies gracefully', () => {
+      registry.register(makeManifest('root', { missing: '^1.0.0' }));
+      const tree = depsService.buildTree('root', registry);
+
+      expect(tree.dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].name).toBe('missing');
+      expect(tree.dependencies[0].version).toBe('unknown');
+    });
+  });
+
+  describe('detectCycles', () => {
+    it('should return null when no cycles exist', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b'));
+
+      expect(depsService.detectCycles('a', registry)).toBeNull();
+    });
+
+    it('should detect a simple cycle', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { a: '^1.0.0' }));
+
+      const cycles = depsService.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles!.length).toBeGreaterThan(0);
+    });
+
+    it('should detect a longer cycle', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { c: '^1.0.0' }));
+      registry.register(makeManifest('c', { a: '^1.0.0' }));
+
+      const cycles = depsService.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+    });
+  });
+
+  describe('hasCircularDependency', () => {
+    it('should return false for acyclic graph', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b'));
+
+      expect(depsService.hasCircularDependency('a', registry)).toBe(false);
+    });
+
+    it('should return true for cyclic graph', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { a: '^1.0.0' }));
+
+      expect(depsService.hasCircularDependency('a', registry)).toBe(true);
+    });
+  });
+
+  describe('topologicalSort', () => {
+    it('should return single node for no dependencies', () => {
+      registry.register(makeManifest('root'));
+
+      const sorted = depsService.topologicalSort('root', registry);
+      expect(sorted).toEqual(['root']);
+    });
+
+    it('should sort dependencies before dependents', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));
+      registry.register(makeManifest('b'));
+      registry.register(makeManifest('c'));
+
+      const sorted = depsService.topologicalSort('a', registry);
+      // Dependencies should come before 'a'
+      expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));
+      expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('a'));
+    });
+
+    it('should handle deep chains', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { c: '^1.0.0' }));
+      registry.register(makeManifest('c'));
+
+      const sorted = depsService.topologicalSort('a', registry);
+      expect(sorted).toEqual(['c', 'b', 'a']);
+    });
+  });
+
+  describe('flattenDependencies', () => {
+    it('should return empty array for no dependencies', () => {
+      registry.register(makeManifest('root'));
+      expect(depsService.flattenDependencies('root', registry)).toEqual([]);
+    });
+
+    it('should flatten transitive dependencies', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0' }));
+      registry.register(makeManifest('b', { c: '^1.0.0' }));
+      registry.register(makeManifest('c'));
+
+      const flat = depsService.flattenDependencies('a', registry);
+      expect(flat).toContain('b');
+      expect(flat).toContain('c');
+      expect(flat).toHaveLength(2);
+    });
+
+    it('should deduplicate shared dependencies', () => {
+      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));
+      registry.register(makeManifest('b', { d: '^1.0.0' }));
+      registry.register(makeManifest('c', { d: '^1.0.0' }));
+      registry.register(makeManifest('d'));
+
+      const flat = depsService.flattenDependencies('a', registry);
+      const dCount = flat.filter((n) => n === 'd').length;
+      expect(dCount).toBe(1);
+    });
+  });
+});
diff --git a/src/deps/index.ts b/src/deps/index.ts
new file mode 100644
index 0000000..b778661
--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,132 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeImpl(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    if (visited.has(name)) {
+      return node; // Break cycle
+    }
+
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      node.dependencies.push(buildTreeImpl(depName, registry, new Set(visited)));
+    }
+
+    return node;
+  }
+
+  function detectCyclesImpl(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    allCycles: string[][]
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    const idx = path.indexOf(name);
+    if (idx !== -1) {
+      // Found a cycle: extract the cycle from where the repetition starts
+      allCycles.push([...path.slice(idx), name]);
+      return;
+    }
+
+    path.push(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      detectCyclesImpl(depName, registry, [...path], allCycles);
+    }
+  }
+
+  function collectAllDeps(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!visited.has(depName)) {
+        visited.add(depName);
+        result.push(depName);
+        collectAllDeps(depName, registry, visited, result);
+      }
+    }
+  }
+
+  function topoSort(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    stack: Set<string>,
+    result: string[]
+  ): void {
+    visited.add(name);
+    stack.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        if (stack.has(depName)) {
+          // Circular dependency - skip
+          continue;
+        }
+        if (!visited.has(depName)) {
+          topoSort(depName, registry, visited, stack, result);
+        }
+      }
+    }
+
+    stack.delete(name);
+    result.push(name);
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeImpl(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles: string[][] = [];
+      detectCyclesImpl(name, registry, [], cycles);
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const stack = new Set<string>();
+      const result: string[] = [];
+      topoSort(name, registry, visited, stack, result);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      collectAllDeps(name, registry, visited, result);
+      return result;
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const cycles = this.detectCycles(name, registry);
+      return cycles !== null;
+    },
+  };
+}
