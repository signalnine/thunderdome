@@ -0,0 +1,138 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { Marketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '1 + 1',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Marketplace Integration', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should create a marketplace with all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin with no dependencies', async () => {
+      const manifest = makeManifest({ entryPoint: '2 + 2' });
+      const result = await marketplace.installPlugin(manifest);
+
+      expect(result.resolvedDependencies).toEqual([]);
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe(4);
+    });
+
+    it('should register the plugin in the registry', async () => {
+      const manifest = makeManifest();
+      await marketplace.installPlugin(manifest);
+
+      const retrieved = marketplace.registry.get('test-plugin');
+      expect(retrieved).not.toBeNull();
+      expect(retrieved!.name).toBe('test-plugin');
+    });
+
+    it('should reject a manifest without name', async () => {
+      const manifest = makeManifest({ name: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+        'Plugin manifest must have a valid name'
+      );
+    });
+
+    it('should reject a manifest without version', async () => {
+      const manifest = makeManifest({ version: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+        'Plugin manifest must have a valid version'
+      );
+    });
+
+    it('should reject a manifest without entryPoint', async () => {
+      const manifest = makeManifest({ entryPoint: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+        'Plugin manifest must have a valid entryPoint'
+      );
+    });
+
+    it('should resolve dependencies when available', async () => {
+      // First install a dependency
+      marketplace.registry.register(
+        makeManifest({ name: 'dep-plugin', version: '1.0.0' })
+      );
+      marketplace.registry.register(
+        makeManifest({ name: 'dep-plugin', version: '1.5.0' })
+      );
+
+      const manifest = makeManifest({
+        name: 'main-plugin',
+        dependencies: { 'dep-plugin': '^1.0.0' },
+      });
+
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-plugin');
+      expect(result.resolvedDependencies[0].version).toBe('1.5.0');
+    });
+
+    it('should reject plugins with circular dependencies', async () => {
+      // Register plugin B that depends on A
+      marketplace.registry.register(
+        makeManifest({
+          name: 'plugin-b',
+          dependencies: { 'plugin-a': '^1.0.0' },
+        })
+      );
+
+      // Try to install plugin A that depends on B
+      const manifest = makeManifest({
+        name: 'plugin-a',
+        dependencies: { 'plugin-b': '^1.0.0' },
+      });
+
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+        'Circular dependency detected'
+      );
+
+      // Plugin A should have been removed from registry
+      expect(marketplace.registry.get('plugin-a')).toBeNull();
+    });
+
+    it('should execute the entry point in sandbox', async () => {
+      const manifest = makeManifest({
+        entryPoint: '"hello from plugin"',
+      });
+
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe('hello from plugin');
+    });
+
+    it('should handle sandbox execution failures', async () => {
+      const manifest = makeManifest({
+        entryPoint: 'throw new Error("plugin init failed")',
+      });
+
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.sandboxResult.success).toBe(false);
+      expect(result.sandboxResult.error).toBe('plugin init failed');
+    });
+  });
+});
