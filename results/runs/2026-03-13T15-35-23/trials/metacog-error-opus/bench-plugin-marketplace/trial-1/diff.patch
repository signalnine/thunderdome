     visited.add(depName);\n        result.push(depName);\n        collectAllDeps(depName, registry, visited, result);\n      }\n    }\n  }\n\n  function topoSort(\n    name: string,\n    registry: RegistryService,\n    visited: Set<string>,\n    stack: Set<string>,\n    result: string[]\n  ): void {\n    visited.add(name);\n    stack.add(name);\n\n    const manifest = registry.get(name);\n    if (manifest) {\n      for (const depName of Object.keys(manifest.dependencies)) {\n        if (stack.has(depName)) {\n          // Circular dependency - skip\n          continue;\n        }\n        if (!visited.has(depName)) {\n          topoSort(depName, registry, visited, stack, result);\n        }\n      }\n    }\n\n    stack.delete(name);\n    result.push(name);\n  }\n\n  return {\n    buildTree(name: string, registry: RegistryService): DependencyNode {\n      return buildTreeImpl(name, registry, new Set());\n    },\n\n    detectCycles(name: string, registry: RegistryService): string[][] | null {\n      const cycles: string[][] = [];\n      detectCyclesImpl(name, registry, [], cycles);\n      return cycles.length > 0 ? cycles : null;\n    },\n\n    topologicalSort(name: string, registry: RegistryService): string[] {\n      const visited = new Set<string>();\n      const stack = new Set<string>();\n      const result: string[] = [];\n      topoSort(name, registry, visited, stack, result);\n      return result;\n    },\n\n    flattenDependencies(name: string, registry: RegistryService): string[] {\n      const visited = new Set<string>();\n      const result: string[] = [];\n      collectAllDeps(name, registry, visited, result);\n      return result;\n    },\n\n    hasCircularDependency(name: string, registry: RegistryService): boolean {\n      const cycles = this.detectCycles(name, registry);\n      return cycles !== null;\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":377,"