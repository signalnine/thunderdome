+
+  // ─── Integration Tests ─────────────────────────────────────────────
+
+  describe('Integration', () => {
+    it('should handle priority + delay + dependencies together', () => {
+      const dep = tq.add('dependency');
+
+      // High priority but depends on dep — blocked
+      tq.add('high-blocked', { priority: 1, dependencies: [dep.id] });
+      // Low priority, no dep, but delayed into the future
+      tq.add('low-delayed', { priority: 10, delay: 60000 });
+      // Medium priority, available now
+      tq.add('medium-available', { priority: 5 });
+
+      // First should be dep (priority 5, no blockers)
+      const first = tq.next()!;
+      expect(first.payload).toBe('dependency');
+
+      // Next should be medium-available (high is blocked, low is delayed)
+      const second = tq.next()!;
+      expect(second.payload).toBe('medium-available');
+
+      // Nothing else available
+      expect(tq.next()).toBeNull();
+
+      // Complete dep, now high-blocked should be available
+      tq.complete(first.id);
+      const third = tq.next()!;
+      expect(third.payload).toBe('high-blocked');
+    });
+
+    it('should handle retry into DLQ and redrive', () => {
+      tq.add('test', { maxRetries: 1, backoffDelay: 0 });
+      const task = tq.next()!;
+      tq.fail(task.id, new Error('fail'));
+
+      // Task exhausted retries → DLQ
+      expect(task.status).toBe('failed');
+      expect(tq.getDeadLetterQueue()).toHaveLength(1);
+
+      // Redrive
+      tq.redriveTask(task.id);
+      expect(tq.getDeadLetterQueue()).toHaveLength(0);
+
+      const redriven = tq.next()!;
+      expect(redriven.id).toBe(task.id);
+      expect(redriven.attempts).toBe(1);
+    });
+
+    it('should handle concurrency + cancel freeing slots', () => {
+      tq.setConcurrency('default', 1);
+      tq.add('a');
+      tq.add('b');
+
+      const t1 = tq.next()!;
+      expect(tq.next()).toBeNull(); // at limit
+
+      tq.cancel(t1.id);
+      const t2 = tq.next()!;
+      expect(t2.payload).toBe('b');
+    });
+
+    it('should get task by id', () => {
+      const task = tq.add('findme');
+      const found = tq.getTask(task.id);
+      expect(found?.payload).toBe('findme');
+    });
+  });
+});
