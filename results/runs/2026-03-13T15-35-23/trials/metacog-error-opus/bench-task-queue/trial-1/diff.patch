+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01TRU2S1n3qAGZbPN4kySTqG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VWjfACSEDZxTChwdMg7xdS","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './index.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ─── Phase 1: Basic FIFO Queue ─────────────────────────────────────\n\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.add({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to each task', () => {\n      const t1 = tq.add('a');\n      const t2 = tq.add('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.add('first');\n      tq.add('second');\n      tq.add('third');\n\n      const t1 = tq.next();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = tq.next();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = tq.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(tq.pendingCount()).toBe(0);\n      tq.add('a');\n      tq.add('b');\n      expect(tq.pendingCount()).toBe(2);\n      tq.next();\n      expect(tq.pendingCount()).toBe(1);\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      const task = tq.add('test');\n      expect(task.status).toBe('pending');\n      const retrieved = tq.next();\n      expect(retrieved?.id).toBe(task.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n\n    it('should set attempts to 1 on first retrieval', () => {\n      tq.add('test');\n      const task = tq.next();\n      expect(task?.attempts).toBe(1);\n    });\n  });\n\n  // ─── Phase 2: Named Queues ─────────────────────────────────────────\n\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name specified', () => {\n      tq.add('test');\n      expect(tq.getQueueNames()).toContain('default');\n    });\n\n    it('should support multiple independent queues', () => {\n      tq.add('email-task', { queue: 'emails' });\n      tq.add('image-task', { queue: 'images' });\n\n      expect(tq.pendingCount('emails')).toBe(1);\n      expect(tq.pendingCount('images')).toBe(1);\n\n      const emailTask = tq.next('emails');\n      expect(emailTask?.payload).toBe('email-task');\n      expect(tq.pendingCount('emails')).toBe(0);\n      expect(tq.pendingCount('images')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      tq.add('a', { queue: 'q1' });\n      tq.add('b', { queue: 'q2' });\n      tq.add('c', { queue: 'q3' });\n      const names = tq.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n      expect(names).toContain('q3');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.next('nonexistent')).toBeNull();\n    });\n\n    it('should return null for empty queue', () => {\n      tq.add('test', { queue: 'q1' });\n      tq.next('q1');\n      expect(tq.next('q1')).toBeNull();\n    });\n\n    it('should be backward-compatible with Phase 1', () => {\n      tq.add('task1');\n      const task = tq.next();\n      expect(task?.payload).toBe('task1');\n    });\n  });\n\n  // ─── Phase 3: Priority ─────────────────────────────────────────────\n\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = tq.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should process higher priority tasks first', () => {\n      tq.add('low', { priority: 10 });\n      tq.add('high', { priority: 1 });\n      tq.add('medium', { priority: 5 });\n\n      expect(tq.next()?.payload).toBe('high');\n      expect(tq.next()?.payload).toBe('medium');\n      expect(tq.next()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO for same priority', () => {\n      tq.add('first', { priority: 3 });\n      tq.add('second', { priority: 3 });\n      tq.add('third', { priority: 3 });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority', () => {\n      expect(() => tq.add('test', { priority: 0 })).toThrow();\n      expect(() => tq.add('test', { priority: 11 })).toThrow();\n      expect(() => tq.add('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('should handle priority per queue', () => {\n      tq.add('low', { queue: 'q1', priority: 10 });\n      tq.add('high', { queue: 'q1', priority: 1 });\n      tq.add('q2-task', { queue: 'q2', priority: 5 });\n\n      expect(tq.next('q1')?.payload).toBe('high');\n      expect(tq.next('q2')?.payload).toBe('q2-task');\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.add('test', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n  });\n\n  // ─── Phase 4: Delayed Tasks ────────────────────────────────────────\n\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should delay task availability', () => {\n      tq.add('delayed', { delay: 60000 }); // 60 seconds from now\n      expect(tq.next()).toBeNull(); // not available yet\n    });\n\n    it('should make delayed task available after time passes', () => {\n      const task = tq.add('delayed', { delay: 100 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());\n    });\n\n    it('should support processAt option', () => {\n      const future = new Date(Date.now() + 60000);\n      const task = tq.add('scheduled', { processAt: future });\n      expect(task.availableAt).toEqual(future);\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      tq.add('delayed', { delay: 60000 });\n      tq.add('immediate');\n\n      const task = tq.next();\n      expect(task?.payload).toBe('immediate');\n      expect(tq.next()).toBeNull(); // delayed not available yet\n    });\n\n    it('should order delayed tasks by availability time', () => {\n      const now = Date.now();\n      tq.add('later', { processAt: new Date(now - 2000) });\n      tq.add('earliest', { processAt: new Date(now - 5000) });\n      tq.add('middle', { processAt: new Date(now - 3000) });\n\n      expect(tq.next()?.payload).toBe('earliest');\n      expect(tq.next()?.payload).toBe('middle');\n      expect(tq.next()?.payload).toBe('later');\n    });\n\n    it('should respect delay with named queues', () => {\n      tq.add('delayed', { queue: 'q1', delay: 60000 });\n      tq.add('immediate', { queue: 'q1' });\n\n      expect(tq.next('q1')?.payload).toBe('immediate');\n      expect(tq.next('q1')).toBeNull();\n    });\n\n    it('should indicate when task becomes available', () => {\n      const task = tq.add('test', { delay: 5000 });\n      expect(task.availableAt).toBeInstanceOf(Date);\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n  });\n\n  // ─── Phase 5: Retry with Backoff ───────────────────────────────────\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark task as completed', () => {\n      tq.add('test');\n      const task = tq.next()!;\n      tq.complete(task.id);\n      expect(task.status).toBe('completed');\n    });\n\n    it('should mark task as failed', () => {\n      tq.add('test', { maxRetries: 0 });\n      const task = tq.next()!;\n      tq.fail(task.id, new Error('oops'));\n      expect(task.status).toBe('failed');\n      expect(task.error?.message).toBe('oops');\n    });\n\n    it('should retry failed tasks with backoff', () => {\n      tq.add('test', { maxRetries: 3, backoffDelay: 100 });\n      const task = tq.next()!;\n      tq.fail(task.id, new Error('fail'));\n\n      // Task should be re-queued as pending with delay\n      expect(task.status).toBe('pending');\n      expect(task.failCount).toBe(1);\n      expect(task.attempts).toBe(1);\n\n      // Should have a delayed availability\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should use exponential backoff delays', () => {\n      tq.add('test', { maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt and fail\n      const task = tq.next()!;\n      const beforeFail1 = Date.now();\n      tq.fail(task.id);\n\n      // First retry delay: 1000 * 2^0 = 1000ms\n      const delay1 = task.availableAt.getTime() - beforeFail1;\n      expect(delay1).toBeGreaterThanOrEqual(900); // allow some timing slack\n      expect(delay1).toBeLessThan(1500);\n    });\n\n    it('should default to 3 max retries', () => {\n      const task = tq.add('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default to 1000ms backoff delay', () => {\n      const task = tq.add('test');\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should track attempt count', () => {\n      tq.add('test', { maxRetries: 3, backoffDelay: 0 });\n      const task = tq.next()!;\n      expect(task.attempts).toBe(1);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      tq.add('test', { queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const task = tq.next('myqueue')!;\n      tq.fail(task.id);\n      expect(task.queue).toBe('myqueue');\n      expect(task.priority).toBe(2);\n    });\n\n    it('should remain in failed state when retries exhausted', () => {\n      tq.add('test', { maxRetries: 1, backoffDelay: 0 });\n      const task = tq.next()!;\n      tq.fail(task.id); // attempt 1 of max 1 → exhausted\n      expect(task.status).toBe('failed');\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const task = tq.add('test');\n      expect(() => tq.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing non-processing task', () => {\n      const task = tq.add('test');\n      expect(() => tq.fail(task.id)).toThrow();\n    });\n  });\n\n  // ─── Phase 6: Dead Letter Queue ────────────────────────────────────\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move permanently failed tasks to DLQ', () => {\n      tq.add('test', { maxRetries: 1, backoffDelay: 0 });\n      const task = tq.next()!;\n      tq.fail(task.id, new Error('permanent'));\n\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error?.message).toBe('permanent');\n    });\n\n    it('should retain fail count in DLQ', () => {\n      tq.add('test', { maxRetries: 1, backoffDelay: 0 });\n      const task = tq.next()!;\n      tq.fail(task.id);\n      expect(task.failCount).toBe(1);\n    });\n\n    it('should redrive a dead-lettered task', () => {\n      tq.add('test', { maxRetries: 1, backoffDelay: 0 });\n      const task = tq.next()!;\n      tq.fail(task.id);\n\n      const redriven = tq.redriveTask(task.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempts).toBe(0);\n      expect(redriven.failCount).toBe(0);\n\n      // Should be retrievable again\n      const retrieved = tq.next()!;\n      expect(retrieved.id).toBe(task.id);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      tq.add('test1', { maxRetries: 1, backoffDelay: 0 });\n      tq.add('test2', { maxRetries: 1, backoffDelay: 0 });\n\n      const t1 = tq.next()!;\n      tq.fail(t1.id);\n      const t2 = tq.next()!;\n      tq.fail(t2.id);\n\n      expect(tq.getDeadLetterQueue()).toHaveLength(2);\n      const cleared = tq.clearDeadLetterQueue();\n      expect(cleared).toBe(2);\n      expect(tq.getDeadLetterQueue()).toHaveLength(0);\n    });\n\n    it('should have independent DLQ per queue', () => {\n      tq.add('q1-task', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      tq.add('q2-task', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n      const t1 = tq.next('q1')!;\n      tq.fail(t1.id);\n      const t2 = tq.next('q2')!;\n      tq.fail(t2.id);\n\n      expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterQueue('q1')).toHaveLength(0);\n      expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n    });\n\n    it('should throw when redriving non-failed task', () => {\n      const task = tq.add('test');\n      expect(() => tq.redriveTask(task.id)).toThrow();\n    });\n  });\n\n  // ─── Phase 7: Task Dependencies ───────────────────────────────────\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block task until dependencies complete', () => {\n      const t1 = tq.add('dep');\n      const t2 = tq.add('dependent', { dependencies: [t1.id] });\n\n      // t2 is blocked, so only t1 is retrievable\n      const next = tq.next()!;\n      expect(next.id).toBe(t1.id);\n\n      // t2 still blocked\n      expect(tq.next()).toBeNull();\n\n      // Complete t1\n      tq.complete(t1.id);\n\n      // Now t2 is available\n      const next2 = tq.next()!;\n      expect(next2.id).toBe(t2.id);\n    });\n\n    it('should support multiple dependencies', () => {\n      const t1 = tq.add('dep1');\n      const t2 = tq.add('dep2');\n      tq.add('dependent', { dependencies: [t1.id, t2.id] });\n\n      tq.next(); // t1\n      tq.complete(t1.id);\n\n      // Still blocked — t2 not complete\n      const next = tq.next();\n      expect(next?.id).toBe(t2.id);\n\n      tq.complete(t2.id);\n\n      // Now available\n      const dep = tq.next()!;\n      expect(dep.payload).toBe('dependent');\n    });\n\n    it('should throw for non-existent dependency', () => {\n      expect(() => tq.add('test', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const t1 = tq.add('dep', { maxRetries: 0 });\n      tq.add('dependent', { dependencies: [t1.id] });\n\n      const next = tq.next()!;\n      tq.fail(next.id);\n\n      // Dependent remains blocked (failed dep is not \"completed\")\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should expose dependency status', () => {\n      const t1 = tq.add('dep1');\n      const t2 = tq.add('dep2');\n      const t3 = tq.add('dependent', { dependencies: [t1.id, t2.id] });\n\n      let status = tq.getDependencyStatus(t3.id);\n      expect(status.total).toBe(2);\n      expect(status.completed).toBe(0);\n      expect(status.pending).toHaveLength(2);\n\n      const next = tq.next()!;\n      tq.complete(next.id);\n\n      status = tq.getDependencyStatus(t3.id);\n      expect(status.completed).toBe(1);\n      expect(status.pending).toHaveLength(1);\n    });\n\n    it('should work with dependencies and priorities', () => {\n      const dep = tq.add('dep');\n      tq.add('high-dependent', { priority: 1, dependencies: [dep.id] });\n      tq.add('low-no-dep', { priority: 10 });\n\n      // low-no-dep is available, high-dependent is blocked\n      const first = tq.next()!;\n      // Should get dep first (priority 5 < 10)\n      expect(first.payload).toBe('dep');\n\n      const second = tq.next()!;\n      expect(second.payload).toBe('low-no-dep');\n    });\n  });\n\n  // ─── Phase 8: Concurrency Control ─────────────────────────────────\n\n  describe('Phase 