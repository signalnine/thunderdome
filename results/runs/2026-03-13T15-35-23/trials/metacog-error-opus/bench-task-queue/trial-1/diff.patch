| progress > 100) {\n      throw new Error(`Progress must be between 0 and 100, got: ${progress}`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    let listeners = this.progressListeners.get(taskId);\n    if (!listeners) {\n      listeners = new Set();\n      this.progressListeners.set(taskId, listeners);\n    }\n    listeners.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      listeners!.delete(listener);\n      if (listeners!.size === 0) {\n        this.progressListeners.delete(taskId);\n      }\n    };\n  }\n\n  cancel(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status === 'pending') {\n      task.status = 'cancelled';\n      // Remove from pending queue\n      const q = this.queues.get(task.queue);\n      if (q) {\n        const idx = q.pending.findIndex(t => t.id === taskId);\n        if (idx !== -1) {\n          q.pending.splice(idx, 1);\n        }\n      }\n    } else if (task.status === 'processing') {\n      task.status = 'cancelled';\n      const q = this.queues.get(task.queue);\n      if (q) {\n        q.activeCount = Math.max(0, q.activeCount - 1);\n      }\n      // Resolve processing promise if exists\n      const resolver = this.processingResolvers.get(taskId);\n      if (resolver) {\n        resolver();\n        this.processingResolvers.delete(taskId);\n        this.processingPromises.delete(taskId);\n      }\n    } else {\n      throw new Error(`Cannot cancel task in status: ${task.status}`);\n    }\n\n    // Clean up listeners\n    this.progressListeners.delete(taskId);\n  }\n\n  // ─── Phase 10: Recurring Tasks ─────────────────────────────────────\n\n  addSchedule(cronExpression: string, payload: unknown, options: ScheduleOptions = {}): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Queue is shutting down, cannot add new schedules');\n    }\n\n    this.validateCron(cronExpression);\n\n    const schedule: Schedule = {\n      id: options.id ?? randomUUID(),\n      cronExpression,\n      queue: options.queue ?? DEFAULT_QUEUE,\n      payload,\n      priority: options.priority ?? 5,\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now: Date = new Date()): Task[] {\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunAt(schedule, now)) {\n        const task = this.add(schedule.payload, {\n          queue: schedule.queue,\n          priority: schedule.priority,\n        });\n        schedule.lastRun = now;\n        created.push(task as Task);\n      }\n    }\n\n    return created;\n  }\n\n  private validateCron(expr: string): void {\n    const parts = expr.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${expr}. Must have 5 fields.`);\n    }\n\n    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Validate basic patterns\n    const isValid = (field: string): boolean => {\n      if (field === '*') return true;\n      if (/^\\d+$/.test(field)) return true;\n      if (/^\\*\\/\\d+$/.test(field)) return true;\n      return false;\n    };\n\n    for (const field of [minute, hour, dayOfMonth, month, dayOfWeek]) {\n      if (!isValid(field)) {\n        throw new Error(`Invalid cron field: ${field}`);\n      }\n    }\n  }\n\n  private shouldRunAt(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cronExpression.trim().split(/\\s+/);\n    const [minuteField, hourField, dayOfMonthField, monthField, dayOfWeekField] = parts;\n\n    const minute = now.getMinutes();\n    const hour = now.getHours();\n    const dayOfMonth = now.getDate();\n    const month = now.getMonth() + 1;\n    const dayOfWeek = now.getDay();\n\n    if (!this.matchesCronField(minuteField, minute)) return false;\n    if (!this.matchesCronField(hourField, hour)) return false;\n    if (!this.matchesCronField(dayOfMonthField, dayOfMonth)) return false;\n    if (!this.matchesCronField(monthField, month)) return false;\n    if (!this.matchesCronField(dayOfWeekField, dayOfWeek)) return false;\n\n    // Check if we already ran at this time\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDay = schedule.lastRun.getDate();\n      const lastMonth = schedule.lastRun.getMonth();\n      const lastYear = schedule.lastRun.getFullYear();\n\n      if (\n        lastMinute === minute &&\n        lastHour === hour &&\n        lastDay === dayOfMonth &&\n        lastMonth === now.getMonth() &&\n        lastYear === now.getFullYear()\n      ) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  private matchesCronField(field: string, value: number): boolean {\n    if (field === '*') return true;\n\n    if (field.startsWith('*/')) {\n      const interval = parseInt(field.slice(2), 10);\n      return value % interval === 0;\n    }\n\n    const num = parseInt(field, 10);\n    return value === num;\n  }\n\n  // ─── Phase 11: Middleware ──────────────────────────────────────────\n\n  use(queueName: string, middleware: Middleware): void;\n  use(middleware: Middleware): void;\n  use(queueNameOrMiddleware: string | Middleware, middleware?: Middleware): void {\n    let queueName: string;\n    let mw: Middleware;\n\n    if (typeof queueNameOrMiddleware === 'string') {\n      queueName = queueNameOrMiddleware;\n      mw = middleware!;\n    } else {\n      queueName = DEFAULT_QUEUE;\n      mw = queueNameOrMiddleware;\n    }\n\n    const q = this.getOrCreateQueue(queueName);\n    q.middlewares.push(mw);\n  }\n\n  setHandler(queueName: string, handler: TaskHandler): void;\n  setHandler(handler: TaskHandler): void;\n  setHandler(queueNameOrHandler: string | TaskHandler, handler?: TaskHandler): void {\n    let queueName: string;\n    let h: TaskHandler;\n\n    if (typeof queueNameOrHandler === 'string') {\n      queueName = queueNameOrHandler;\n      h = handler!;\n    } else {\n      queueName = DEFAULT_QUEUE;\n      h = queueNameOrHandler;\n    }\n\n    const q = this.getOrCreateQueue(queueName);\n    q.handler = h;\n  }\n\n  async process(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {\n    const task = this.next(queueName);\n    if (!task) return null;\n\n    const q = this.queues.get(queueName);\n    if (!q) return null;\n\n    const middlewares = [...q.middlewares];\n    const handler = q.handler;\n\n    try {\n      let idx = 0;\n      const runNext = async (): Promise<void> => {\n        if (idx < middlewares.length) {\n          const mw = middlewares[idx++];\n          await mw(task, runNext);\n        } else if (handler) {\n          await handler(task);\n        }\n      };\n\n      await runNext();\n\n      // Only complete if still processing (middleware might have changed status)\n      if (task.status === 'processing') {\n        this.complete(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.fail(task.id, err instanc