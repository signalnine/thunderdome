diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..8dbc35d
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,822 @@
+import { randomUUID } from 'crypto';
+
+// ─── Types ───────────────────────────────────────────────────────────────────
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: Error;
+  failCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export type Middleware = (task: Task, next: () => Promise<void>) => Promise<void>;
+
+export type TaskHandler = (task: Task) => Promise<void> | void;
+
+export interface ScheduleOptions {
+  id?: string;
+  queue?: string;
+  priority?: number;
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  priority: number;
+  lastRun?: Date;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
+
+// ─── Internal Queue State ────────────────────────────────────────────────────
+
+interface QueueState {
+  pending: Task[];
+  middlewares: Middleware[];
+  handler?: TaskHandler;
+  concurrencyLimit: number;
+  activeCount: number;
+  deadLetterQueue: Task[];
+}
+
+// ─── TaskQueue ───────────────────────────────────────────────────────────────
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueue {
+  private queues: Map<string, QueueState> = new Map();
+  private allTasks: Map<string, Task> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+  private processingPromises: Map<string, Promise<void>> = new Map();
+
+  // ─── Queue management ───────────────────────────────────────────────
+
+  private getOrCreateQueue(name: string): QueueState {
+    let q = this.queues.get(name);
+    if (!q) {
+      q = {
+        pending: [],
+        middlewares: [],
+        concurrencyLimit: 0, // 0 = unlimited
+        activeCount: 0,
+        deadLetterQueue: [],
+      };
+      this.queues.set(name, q);
+    }
+    return q;
+  }
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ─── Phase 1 & 2: Add and retrieve tasks ────────────────────────────
+
+  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShuttingDown) {
+      throw new Error('Queue is shutting down, cannot add new tasks');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? 5;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      if (!this.allTasks.has(depId)) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    // Detect circular dependencies
+    if (dependencies.length > 0) {
+      // We need a temporary task id to check circularity
+      const tempId = '__temp__';
+      this.detectCircularDeps(tempId, dependencies);
+    }
+
+    const now = new Date();
+    let availableAt = now;
+
+    if (options.processAt) {
+      availableAt = options.processAt;
+    } else if (options.delay !== undefined && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: 'pending',
+      queue: queueName,
+      priority,
+      createdAt: now,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      backoffDelay: options.backoffDelay ?? 1000,
+      failCount: 0,
+      dependencies,
+      progress: 0,
+    };
+
+    this.allTasks.set(task.id, task as Task);
+    const q = this.getOrCreateQueue(queueName);
+    q.pending.push(task as Task);
+
+    return task;
+  }
+
+  next(queueName: string = DEFAULT_QUEUE): Task | null {
+    const q = this.queues.get(queueName);
+    if (!q) return null;
+
+    // Check concurrency limit
+    if (q.concurrencyLimit > 0 && q.activeCount >= q.concurrencyLimit) {
+      return null;
+    }
+
+    const now = new Date();
+
+    // Find the best available task:
+    // 1. Must be pending
+    // 2. Must be available (availableAt <= now)
+    // 3. Dependencies must be resolved
+    // 4. Highest priority (lowest number) first
+    // 5. For same priority, FIFO (earliest createdAt, or insertion order)
+    // 6. For delayed tasks that are now available: order by availableAt, then priority, then FIFO
+
+    let bestIdx = -1;
+    let bestTask: Task | null = null;
+
+    for (let i = 0; i < q.pending.length; i++) {
+      const t = q.pending[i];
+      if (t.status !== 'pending') continue;
+      if (t.availableAt > now) continue;
+      if (!this.areDependenciesResolved(t)) continue;
+
+      if (bestTask === null || this.compareTasks(t, bestTask) < 0) {
+        bestTask = t;
+        bestIdx = i;
+      }
+    }
+
+    if (bestIdx === -1) return null;
+
+    q.pending.splice(bestIdx, 1);
+    bestTask!.status = 'processing';
+    bestTask!.attempts++;
+    q.activeCount++;
+
+    return bestTask;
+  }
+
+  private compareTasks(a: Task, b: Task): number {
+    // Priority first (lower number = higher priority)
+    if (a.priority !== b.priority) return a.priority - b.priority;
+    // Then by availableAt
+    const aTime = a.availableAt.getTime();
+    const bTime = b.availableAt.getTime();
+    if (aTime !== bTime) return aTime - bTime;
+    // Then FIFO by createdAt
+    return a.createdAt.getTime() - b.createdAt.getTime();
+  }
+
+  private areDependenciesResolved(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (!dep || dep.status !== 'completed') return false;
+    }
+    return true;
+  }
+
+  pendingCount(queueName: string = DEFAULT_QUEUE): number {
+    const q = this.queues.get(queueName);
+    if (!q) return 0;
+    return q.pending.filter(t => t.status === 'pending').length;
+  }
+
+  // ─── Phase 5: Complete and Fail ─────────────────────────────────────
+
+  complete(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in status: ${task.status}`);
+    }
+
+    task.status = 'completed';
+    task.progress = 100;
+
+    const q = this.queues.get(task.queue);
+    if (q) {
+      q.activeCount = Math.max(0, q.activeCount - 1);
+    }
+
+    // Clean up listeners
+    this.progressListeners.delete(taskId);
+
+    // Resolve processing promise if exists
+    const resolver = this.processingResolvers.get(taskId);
+    if (resolver) {
+      resolver();
+      this.processingResolvers.delete(taskId);
+      this.processingPromises.delete(taskId);
+    }
+  }
+
+  fail(taskId: string, error?: Error): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in status: ${task.status}`);
+    }
+
+    task.error = error;
+    task.failCount++;
+
+    const q = this.queues.get(task.queue);
+    if (q) {
+      q.activeCount = Math.max(0, q.activeCount - 1);
+    }
+
+    // Clean up listeners
+    this.progressListeners.delete(taskId);
+
+    // Check if retries remaining
+    if (task.attempts < task.maxRetries) {
+      // Re-enqueue with exponential backoff
+      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+
+      if (q) {
+        q.pending.push(task);
+      }
+    } else {
+      // No more retries — task is permanently failed
+      task.status = 'failed';
+
+      // Move to dead letter queue
+      if (q) {
+        q.deadLetterQueue.push(task);
+      }
+    }
+
+    // Resolve processing promise if exists
+    const resolver = this.processingResolvers.get(taskId);
+    if (resolver) {
+      resolver();
+      this.processingResolvers.delete(taskId);
+      this.processingPromises.delete(taskId);
+    }
+  }
+
+  // ─── Phase 6: Dead Letter Queue ────────────────────────────────────
+
+  getDeadLetterQueue(queueName: string = DEFAULT_QUEUE): Task[] {
+    const q = this.queues.get(queueName);
+    if (!q) return [];
+    return [...q.deadLetterQueue];
+  }
+
+  redriveTask(taskId: string): Task {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'failed') {
+      throw new Error(`Task is not in failed state: ${task.status}`);
+    }
+
+    const q = this.getOrCreateQueue(task.queue);
+
+    // Remove from DLQ
+    const dlqIdx = q.deadLetterQueue.findIndex(t => t.id === taskId);
+    if (dlqIdx !== -1) {
+      q.deadLetterQueue.splice(dlqIdx, 1);
+    }
+
+    // Reset and re-enqueue
+    task.status = 'pending';
+    task.attempts = 0;
+    task.failCount = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.progress = 0;
+
+    q.pending.push(task);
+
+    return task;
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): number {
+    const q = this.queues.get(queueName);
+    if (!q) return 0;
+    const count = q.deadLetterQueue.length;
+    // Remove all DLQ tasks from allTasks too
+    for (const t of q.deadLetterQueue) {
+      this.allTasks.delete(t.id);
+    }
+    q.deadLetterQueue = [];
+    return count;
+  }
+
+  // ─── Phase 7: Dependency helpers ───────────────────────────────────
+
+  private detectCircularDeps(_taskId: string, dependencies: string[]): void {
+    // Since tasks can only depend on already-existing tasks, and new tasks
+    // aren't in allTasks yet, true circular deps (A->B->A) can't form through
+    // normal creation order. However, we check for robustness and to satisfy
+    // the spec requirement that circular dependencies are detected.
+    // We check that the dependency set doesn't include mutual dependencies
+    // among themselves (which would indicate a malformed graph).
+    const visited = new Set<string>();
+
+    const collectTransitiveDeps = (id: string): Set<string> => {
+      const result = new Set<string>();
+      const stack = [id];
+      while (stack.length > 0) {
+        const current = stack.pop()!;
+        if (result.has(current)) continue;
+        result.add(current);
+        const task = this.allTasks.get(current);
+        if (task) {
+          for (const dep of task.dependencies) {
+            stack.push(dep);
+          }
+        }
+      }
+      return result;
+    };
+
+    // Check each dependency's transitive deps don't include another direct dependency
+    // in a way that would form a cycle with the new task
+    for (const depId of dependencies) {
+      if (visited.has(depId)) continue;
+      visited.add(depId);
+      const transitive = collectTransitiveDeps(depId);
+      // The transitive closure of a dep should not include the dep itself
+      // in a cycle (which collectTransitiveDeps would detect by design)
+      // This check is mostly a safety net
+      for (const otherId of dependencies) {
+        if (otherId !== depId && transitive.has(otherId)) {
+          // This means depId transitively depends on otherId,
+          // and our new task depends on both — that's fine (diamond deps).
+          // It's only circular if otherId also transitively depends on depId.
+          const otherTransitive = collectTransitiveDeps(otherId);
+          if (otherTransitive.has(depId)) {
+            throw new Error('Circular dependency detected');
+          }
+        }
+      }
+    }
+  }
+
+  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const pending: string[] = [];
+    let completed = 0;
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (dep && dep.status === 'completed') {
+        completed++;
+      } else {
+        pending.push(depId);
+      }
+    }
+
+    return { total: task.dependencies.length, completed, pending };
+  }
+
+  // ─── Phase 8: Concurrency Control ──────────────────────────────────
+
+  setConcurrency(queueName: string, limit: number): void {
+    const q = this.getOrCreateQueue(queueName);
+    q.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number; active: number } {
+    const q = this.queues.get(queueName);
+    if (!q) return { limit: 0, active: 0 };
+    return { limit: q.concurrencyLimit, active: q.activeCount };
+  }
+
+  // ─── Phase 9: Progress and Cancellation ─────────────────────────────
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot report progress for task in status: ${task.status}`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Progress must be between 0 and 100, got: ${progress}`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    let listeners = this.progressListeners.get(taskId);
+    if (!listeners) {
+      listeners = new Set();
+      this.progressListeners.set(taskId, listeners);
+    }
+    listeners.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      listeners!.delete(listener);
+      if (listeners!.size === 0) {
+        this.progressListeners.delete(taskId);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status === 'pending') {
+      task.status = 'cancelled';
+      // Remove from pending queue
+      const q = this.queues.get(task.queue);
+      if (q) {
+        const idx = q.pending.findIndex(t => t.id === taskId);
+        if (idx !== -1) {
+          q.pending.splice(idx, 1);
+        }
+      }
+    } else if (task.status === 'processing') {
+      task.status = 'cancelled';
+      const q = this.queues.get(task.queue);
+      if (q) {
+        q.activeCount = Math.max(0, q.activeCount - 1);
+      }
+      // Resolve processing promise if exists
+      const resolver = this.processingResolvers.get(taskId);
+      if (resolver) {
+        resolver();
+        this.processingResolvers.delete(taskId);
+        this.processingPromises.delete(taskId);
+      }
+    } else {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    // Clean up listeners
+    this.progressListeners.delete(taskId);
+  }
+
+  // ─── Phase 10: Recurring Tasks ─────────────────────────────────────
+
+  addSchedule(cronExpression: string, payload: unknown, options: ScheduleOptions = {}): Schedule {
+    if (this.isShuttingDown) {
+      throw new Error('Queue is shutting down, cannot add new schedules');
+    }
+
+    this.validateCron(cronExpression);
+
+    const schedule: Schedule = {
+      id: options.id ?? randomUUID(),
+      cronExpression,
+      queue: options.queue ?? DEFAULT_QUEUE,
+      payload,
+      priority: options.priority ?? 5,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): boolean {
+    return this.schedules.delete(scheduleId);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now: Date = new Date()): Task[] {
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRunAt(schedule, now)) {
+        const task = this.add(schedule.payload, {
+          queue: schedule.queue,
+          priority: schedule.priority,
+        });
+        schedule.lastRun = now;
+        created.push(task as Task);
+      }
+    }
+
+    return created;
+  }
+
+  private validateCron(expr: string): void {
+    const parts = expr.trim().split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expr}. Must have 5 fields.`);
+    }
+
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Validate basic patterns
+    const isValid = (field: string): boolean => {
+      if (field === '*') return true;
+      if (/^\d+$/.test(field)) return true;
+      if (/^\*\/\d+$/.test(field)) return true;
+      return false;
+    };
+
+    for (const field of [minute, hour, dayOfMonth, month, dayOfWeek]) {
+      if (!isValid(field)) {
+        throw new Error(`Invalid cron field: ${field}`);
+      }
+    }
+  }
+
+  private shouldRunAt(schedule: Schedule, now: Date): boolean {
+    const parts = schedule.cronExpression.trim().split(/\s+/);
+    const [minuteField, hourField, dayOfMonthField, monthField, dayOfWeekField] = parts;
+
+    const minute = now.getMinutes();
+    const hour = now.getHours();
+    const dayOfMonth = now.getDate();
+    const month = now.getMonth() + 1;
+    const dayOfWeek = now.getDay();
+
+    if (!this.matchesCronField(minuteField, minute)) return false;
+    if (!this.matchesCronField(hourField, hour)) return false;
+    if (!this.matchesCronField(dayOfMonthField, dayOfMonth)) return false;
+    if (!this.matchesCronField(monthField, month)) return false;
+    if (!this.matchesCronField(dayOfWeekField, dayOfWeek)) return false;
+
+    // Check if we already ran at this time
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDay = schedule.lastRun.getDate();
+      const lastMonth = schedule.lastRun.getMonth();
+      const lastYear = schedule.lastRun.getFullYear();
+
+      if (
+        lastMinute === minute &&
+        lastHour === hour &&
+        lastDay === dayOfMonth &&
+        lastMonth === now.getMonth() &&
+        lastYear === now.getFullYear()
+      ) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchesCronField(field: string, value: number): boolean {
+    if (field === '*') return true;
+
+    if (field.startsWith('*/')) {
+      const interval = parseInt(field.slice(2), 10);
+      return value % interval === 0;
+    }
+
+    const num = parseInt(field, 10);
+    return value === num;
+  }
+
+  // ─── Phase 11: Middleware ──────────────────────────────────────────
+
+  use(queueName: string, middleware: Middleware): void;
+  use(middleware: Middleware): void;
+  use(queueNameOrMiddleware: string | Middleware, middleware?: Middleware): void {
+    let queueName: string;
+    let mw: Middleware;
+
+    if (typeof queueNameOrMiddleware === 'string') {
+      queueName = queueNameOrMiddleware;
+      mw = middleware!;
+    } else {
+      queueName = DEFAULT_QUEUE;
+      mw = queueNameOrMiddleware;
+    }
+
+    const q = this.getOrCreateQueue(queueName);
+    q.middlewares.push(mw);
+  }
+
+  setHandler(queueName: string, handler: TaskHandler): void;
+  setHandler(handler: TaskHandler): void;
+  setHandler(queueNameOrHandler: string | TaskHandler, handler?: TaskHandler): void {
+    let queueName: string;
+    let h: TaskHandler;
+
+    if (typeof queueNameOrHandler === 'string') {
+      queueName = queueNameOrHandler;
+      h = handler!;
+    } else {
+      queueName = DEFAULT_QUEUE;
+      h = queueNameOrHandler;
+    }
+
+    const q = this.getOrCreateQueue(queueName);
+    q.handler = h;
+  }
+
+  async process(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {
+    const task = this.next(queueName);
+    if (!task) return null;
+
+    const q = this.queues.get(queueName);
+    if (!q) return null;
+
+    const middlewares = [...q.middlewares];
+    const handler = q.handler;
+
+    try {
+      let idx = 0;
+      const runNext = async (): Promise<void> => {
+        if (idx < middlewares.length) {
+          const mw = middlewares[idx++];
+          await mw(task, runNext);
+        } else if (handler) {
+          await handler(task);
+        }
+      };
+
+      await runNext();
+
+      // Only complete if still processing (middleware might have changed status)
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));
+      }
+    }
+
+    return task;
+  }
+
+  // ─── Phase 12: Graceful Shutdown ───────────────────────────────────
+
+  private processingResolvers: Map<string, () => void> = new Map();
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    const startTime = Date.now();
+
+    this.shutdownPromise = this.executeShutdown(timeoutMs, startTime);
+    return this.shutdownPromise;
+  }
+
+  private async executeShutdown(timeoutMs: number, startTime: number): Promise<ShutdownResult> {
+    let completed = 0;
+    let forceCancelled = 0;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Find all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.allTasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    if (processingTasks.length > 0) {
+      // Create promises for each processing task
+      const taskPromises: Promise<void>[] = processingTasks.map(task => {
+        return new Promise<void>(resolve => {
+          // Check if already done
+          if (task.status !== 'processing') {
+            resolve();
+            return;
+          }
+          this.processingResolvers.set(task.id, resolve);
+        });
+      });
+
+      // Wait for all processing tasks with timeout
+      const timeoutPromise = new Promise<'timeout'>(resolve => {
+        setTimeout(() => resolve('timeout'), timeoutMs);
+      });
+
+      const result = await Promise.race([
+        Promise.all(taskPromises).then(() => 'done' as const),
+        timeoutPromise,
+      ]);
+
+      if (result === 'timeout') {
+        // Force-cancel remaining processing tasks
+        for (const task of processingTasks) {
+          if (task.status === 'processing') {
+            task.status = 'cancelled';
+            forceCancelled++;
+            const q = this.queues.get(task.queue);
+            if (q) {
+              q.activeCount = Math.max(0, q.activeCount - 1);
+            }
+            // Clean up resolver
+            const resolver = this.processingResolvers.get(task.id);
+            if (resolver) {
+              resolver();
+              this.processingResolvers.delete(task.id);
+            }
+          } else {
+            completed++;
+          }
+        }
+      } else {
+        completed = processingTasks.length;
+      }
+    }
+
+    const durationMs = Date.now() - startTime;
+
+    return { completed, forceCancelled, durationMs };
+  }
+
+  // ─── Utility ──────────────────────────────────────────────────────
+
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  get isShutdown(): boolean {
+    return this.isShuttingDown;
+  }
+}
