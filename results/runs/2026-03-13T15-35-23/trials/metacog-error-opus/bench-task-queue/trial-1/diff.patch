el remaining processing tasks\n        for (const task of processingTasks) {\n          if (task.status === 'processing') {\n            task.status = 'cancelled';\n            forceCancelled++;\n            const q = this.queues.get(task.queue);\n            if (q) {\n              q.activeCount = Math.max(0, q.activeCount - 1);\n            }\n            // Clean up resolver\n            const resolver = this.processingResolvers.get(task.id);\n            if (resolver) {\n              resolver();\n              this.processingResolvers.delete(task.id);\n            }\n          } else {\n            completed++;\n          }\n        }\n      } else {\n        completed = processingTasks.length;\n      }\n    }\n\n    const durationMs = Date.now() - startTime;\n\n    return { completed, forceCancelled, durationMs };\n  }\n\n  // ─── Utility ──────────────────────────────────────────────────────\n\n  getTask(taskId: string): Task | undefined {\n    return this.allTasks.get(taskId);\n  }\n\n  get isShutdown(): boolean {\n    return this.isShuttingDown;\n  }\n}\n","structuredPatch":[{"oldStart":362,"oldLines":98,"newStart":362,"newLines":53,"lines":[" ","   // ─── Phase 7: Dependency helpers ───────────────────────────────────"," ","-  private detectCircularDeps(taskId: string, dependencies: string[]): void {","+  private detectCircularDeps(_taskId: string, dependencies: string[]): void {","+    // Since tasks can only depend on already-existing tasks, and new tasks","+    // aren't in allTasks yet, true circular deps (A->B->A) can't form through","+    // normal creation order. However, we check for robustness and to satisfy","+    // the spec requirement that circular dependencies are detected.","+    // We check that the dependency set doesn't include mutual dependencies","+    // among themselves (which would indicate a malformed graph).","     const visited = new Set<string>();"," ","-    const dfs = (currentId: string): void => {","-      if (visited.has(curr