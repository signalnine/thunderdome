+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+        // Get or initialize the asset manifest
+        let manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (!manifest) {
+          manifest = { assets: [] };
+          ctx.data.set('asset-manifest', manifest);
+        }
+
+        // Match src="./..." and href="./..."
+        const relativeUrlRegex = /(src|href)="\.\/([^"]+)"/g;
+        let content = file.content;
+        let match;
+        const discoveredAssets: string[] = [];
+
+        while ((match = relativeUrlRegex.exec(file.content)) !== null) {
+          discoveredAssets.push(match[2]);
+        }
+
+        // Rewrite URLs
+        content = content.replace(/(src|href)="\.\/([^"]+)"/g, (_m, attr: string, path: string) => {
+          return `${attr}="/assets/${path}"`;
+        });
+
+        // Add newly discovered assets to manifest (avoid duplicates)
+        for (const asset of discoveredAssets) {
+          if (!manifest.assets.includes(asset)) {
+            manifest.assets.push(asset);
+          }
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
