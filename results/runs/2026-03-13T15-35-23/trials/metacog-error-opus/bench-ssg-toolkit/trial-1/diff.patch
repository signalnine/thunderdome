@@ -0,0 +1,63 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import { marked } from 'marked';
+
+function processFootnotes(content: string): { text: string; footnotes: Map<string, string> } {
+  const footnotes = new Map<string, string>();
+  const defRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  let match;
+  while ((match = defRegex.exec(content)) !== null) {
+    footnotes.set(match[1], match[2]);
+  }
+
+  // Remove footnote definitions from content
+  let text = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '').trim();
+
+  // Replace inline footnote references with sup links
+  text = text.replace(/\[\^(\d+)\]/g, (_m, id: string) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  return { text, footnotes };
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(/:::(note|warning|tip)\n([\s\S]*?):::/g, (_m, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+function buildFootnoteSection(footnotes: Map<string, string>): string {
+  if (footnotes.size === 0) return '';
+  const items = Array.from(footnotes.entries())
+    .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+    .join('\n');
+  return `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonitions before markdown conversion
+        content = processAdmonitions(content);
+
+        // Process footnotes before markdown conversion
+        const { text, footnotes } = processFootnotes(content);
+        content = text;
+
+        // Convert markdown to HTML using marked (synchronous)
+        content = marked.parse(content, { async: false }) as string;
+
+        // Append footnote section
+        content += buildFootnoteSection(footnotes);
+
+        return { ...file, content };
+      },
+    },
+  };
+}
