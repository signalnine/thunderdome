@@ -0,0 +1,268 @@
+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from '../src/index.js';
+
+describe('simulate', () => {
+  it('handles basic AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('handles basic OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+  });
+
+  it('handles basic XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('handles chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, d: 0, c: 1, e: 1,
+    });
+  });
+
+  it('handles gates provided in reverse dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, d: 0, c: 1, e: 1,
+    });
+  });
+
+  it('simulates a 2-bit adder correctly', () => {
+    // 2-bit adder: x=01 (1), y=01 (1), expected z=010 (2)
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+    // 1 + 1 = 2 (binary 10)
+    const result = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(0);
+
+    // 3 + 1 = 4 (binary 100)
+    const result2 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 0 });
+    expect(result2.z00).toBe(0);
+    expect(result2.z01).toBe(0);
+    expect(result2.z02).toBe(1);
+
+    // 3 + 3 = 6 (binary 110)
+    const result3 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });
+    expect(result3.z00).toBe(0);
+    expect(result3.z01).toBe(1);
+    expect(result3.z02).toBe(1);
+  });
+
+  it('handles deep dependency chains', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'AND', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'OR', in1: 'e', in2: 'f', out: 'g' },
+      { op: 'XOR', in1: 'g', in2: 'h', out: 'i' },
+    ];
+    const result = simulate(gates, { a: 1, b: 0, d: 1, f: 0, h: 1 });
+    expect(result.c).toBe(1); // 1 XOR 0
+    expect(result.e).toBe(1); // 1 AND 1
+    expect(result.g).toBe(1); // 1 OR 0
+    expect(result.i).toBe(0); // 1 XOR 1
+  });
+});
+
+describe('findSwappedWires', () => {
+  const pad = (n: number) => String(n).padStart(2, '0');
+
+  function buildCorrectAdder(bits: number): Gate[] {
+    const gates: Gate[] = [];
+
+    // Bit 0: half adder
+    gates.push({ op: 'XOR', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `z${pad(0)}` });
+    gates.push({ op: 'AND', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `c${pad(0)}` });
+
+    for (let i = 1; i < bits; i++) {
+      gates.push({ op: 'XOR', in1: `x${pad(i)}`, in2: `y${pad(i)}`, out: `t${pad(i)}` });
+      gates.push({ op: 'XOR', in1: `t${pad(i)}`, in2: `c${pad(i - 1)}`, out: `z${pad(i)}` });
+      gates.push({ op: 'AND', in1: `x${pad(i)}`, in2: `y${pad(i)}`, out: `a${pad(i)}` });
+      gates.push({ op: 'AND', in1: `t${pad(i)}`, in2: `c${pad(i - 1)}`, out: `b${pad(i)}` });
+      gates.push({ op: 'OR', in1: `a${pad(i)}`, in2: `b${pad(i)}`, out: `c${pad(i)}` });
+    }
+
+    return gates;
+  }
+
+  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {
+    return gates.map((g) => {
+      if (g.out === wire1) return { ...g, out: wire2 };
+      if (g.out === wire2) return { ...g, out: wire1 };
+      return g;
+    });
+  }
+
+  it('detects swapped z-wires with AND outputs', () => {
+    let gates = buildCorrectAdder(10);
+    const swaps: [string, string][] = [
+      ['z02', 'a02'],
+      ['z05', 'b05'],
+      ['z07', 'a07'],
+      ['z09', 'a09'],
+    ];
+    for (const [a, b] of swaps) gates = swapOutputs(gates, a, b);
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(swaps.flatMap(([a, b]) => [a, b]).sort());
+  });
+
+  it('detects swaps involving carry wires and partial sums', () => {
+    let gates = buildCorrectAdder(10);
+    const swaps: [string, string][] = [
+      ['t03', 'c03'],
+      ['t05', 'c05'],
+      ['z02', 'a02'],
+      ['z09', 'b09'],
+    ];
+    for (const [a, b] of swaps) gates = swapOutputs(gates, a, b);
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(swaps.flatMap(([a, b]) => [a, b]).sort());
+  });
+
+  it('detects swaps involving z01 and partial sum', () => {
+    let gates = buildCorrectAdder(20);
+    const swaps: [string, string][] = [
+      ['z01', 't01'],
+      ['a05', 'c05'],
+      ['z10', 'b10'],
+      ['z15', 'a15'],
+    ];
+    for (const [a, b] of swaps) gates = swapOutputs(gates, a, b);
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(swaps.flatMap(([a, b]) => [a, b]).sort());
+  });
+
+  it('detects swaps with OR outputs going to z', () => {
+    let gates = buildCorrectAdder(10);
+    const swaps: [string, string][] = [
+      ['z03', 'c03'],
+      ['z05', 'c05'],
+      ['z07', 'c07'],
+      ['z09', 'c09'],
+    ];
+    for (const [a, b] of swaps) gates = swapOutputs(gates, a, b);
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(swaps.flatMap(([a, b]) => [a, b]).sort());
+  });
+
+  it('handles 45-bit adder within 5 seconds', () => {
+    let gates = buildCorrectAdder(45);
+    const swaps: [string, string][] = [
+      ['z05', 'a05'],
+      ['z15', 'b15'],
+      ['t25', 'c25'],
+      ['z40', 'a40'],
+    ];
+    for (const [a, b] of swaps) gates = swapOutputs(gates, a, b);
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toEqual(swaps.flatMap(([a, b]) => [a, b]).sort());
+  });
+
+  it('detects mixed swap types in a 45-bit adder', () => {
+    let gates = buildCorrectAdder(45);
+    const swaps: [string, string][] = [
+      ['z01', 't01'],    // z-wire with partial sum
+      ['a10', 'c10'],    // generate with carry
+      ['t30', 'c30'],    // partial sum with carry
+      ['z44', 'b44'],    // z-wire with propagate
+    ];
+    for (const [a, b] of swaps) gates = swapOutputs(gates, a, b);
+    const result = findSwappedWires(gates);
