+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a logic gate circuit given initial wire values.
+ * Process gates in dependency order until all gates have fired.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set<number>(gates.map((_, i) => i));
+
+  let progress = true;
+  while (remaining.size > 0 && progress) {
+    progress = false;
+    for (const idx of remaining) {
+      const gate = gates[idx];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.delete(idx);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a ripple-carry adder circuit.
+ *
+ * Combines structural rules with carry-chain tracing to detect all swapped wires.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+
+  // Build lookup structures
+  const gateByOutput = new Map<string, Gate>();
+  for (const gate of gates) {
+    gateByOutput.set(gate.out, gate);
+  }
+
+  // Build consumer lookup
+  const consumers = new Map<string, Gate[]>();
+  for (const gate of gates) {
+    for (const inp of [gate.in1, gate.in2]) {
+      if (!consumers.has(inp)) consumers.set(inp, []);
+      consumers.get(inp)!.push(gate);
+    }
+  }
+
+  // Find the number of input bits
+  const xWires = gates
+    .flatMap((g) => [g.in1, g.in2])
+    .filter((w) => w.startsWith('x'));
+  const maxBit = Math.max(...xWires.map((w) => parseInt(w.slice(1), 10)));
+  const finalZ = `z${String(maxBit + 1).padStart(2, '0')}`;
+  const pad = (n: number) => String(n).padStart(2, '0');
+
+  // Helper: find a gate by op and inputs (order-independent)
+  function findGate(op: Gate['op'], in1: string, in2: string): Gate | undefined {
+    return gates.find(
+      (g) =>
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))
+    );
+  }
+
+  // Phase 1: Structural rules that detect most swaps
+  // Rule 1: z-wires (except final) must be produced by XOR
+  for (let i = 0; i <= maxBit; i++) {
+    const zWire = `z${pad(i)}`;
+    const producer = gateByOutput.get(zWire);
+    if (producer && producer.op !== 'XOR') {
+      swapped.add(zWire);
+    }
+  }
+
+  for (const gate of gates) {
+    const out = gate.out;
+    const inputsAreXY =
+      (gate.in1.startsWith('x') || gate.in1.startsWith('y')) &&
+      (gate.in2.startsWith('x') || gate.in2.startsWith('y'));
+
+    if (gate.op === 'XOR') {
+      if (inputsAreXY) {
+        // Rule 2: partial-sum XOR must not output to z (except z00)
+        if (out.startsWith('z') && out !== 'z00') {
+          swapped.add(out);
+        }
+      } else {
+        // Rule 3: final-sum XOR must output to z
+        if (!out.startsWith('z')) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    if (gate.op === 'AND') {
+      if (!(inputsAreXY && (gate.in1.endsWith('00') || gate.in2.endsWith('00')))) {
+        // Rule 4: non-bit-0 AND output must feed into OR
+        const cons = consumers.get(out) || [];
+        const feedsIntoOr = cons.some((g) => g.op === 'OR');
+        if (!feedsIntoOr) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    if (gate.op === 'OR') {
+      // Rule 5: OR output must not be z (except final carry)
+      if (out.startsWith('z') && out !== finalZ) {
+        swapped.add(out);
+      }
+    }
+  }
+
+  // Phase 2: If we don't have 8 yet, trace the carry chain to find remaining swaps.
+  // This catches swaps between carry wires and partial-sum wires (both internal,
+  // both feed into XOR+AND, so simple rules can't distinguish them).
+  if (swapped.size < 8) {
+    let carry = '';
+
+    for (let bit = 0; bit <= maxBit; bit++) {
+      const xWire = `x${pad(bit)}`;
+      const yWire = `y${pad(bit)}`;
+      const zWire = `z${pad(bit)}`;
+
+      const xorGate = findGate('XOR', xWire, yWire);
+      const andGate = findGate('AND', xWire, yWire);
+      if (!xorGate || !andGate) continue;
+
+      if (bit === 0) {
+        carry = andGate.out;
+        continue;
+      }
+
+      let partialSum = xorGate.out;
+
+      // Try to find the final-sum XOR: partialSum XOR carry -> zN
+      let sumGate = findGate('XOR', partialSum, carry);
+
+      if (!sumGate) {
+        // One of partialSum or carry is wrong. Check what the zN producer expects.
+        const zProducer = gateByOutput.get(zWire);
+        if (zProducer && zProducer.op === 'XOR') {
+          // zProducer takes two inputs. One should be carry, the other partialSum.
+          if (zProducer.in1 === carry || zProducer.in2 === carry) {
+            // carry is correct, partialSum is wrong
+            const correctPartialSum =
+              zProducer.in1 === carry ? zProducer.in2 : zProducer.in1;
+            if (correctPartialSum !== partialSum) {
+              swapped.add(partialSum);
+              swapped.add(correctPartialSum);
+              partialSum = correctPartialSum;
+            }
+          } else if (zProducer.in1 === partialSum || zProducer.in2 === partialSum) {
+            // partialSum is correct, carry is wrong
+            const correctCarry =
+              zProducer.in1 === partialSum ? zProducer.in2 : zProducer.in1;
+            swapped.add(carry);
+            swapped.add(correctCarry);
+            carry = correctCarry;
+          } else {
+            // Neither matches — one of the z-outputs was swapped (caught by Phase 1).
+            // Try to figure out carry from the z producer's inputs
+            // One input should be a partial sum (produced by x XOR y), the other is carry
+            const inp1Producer = gateByOutput.get(zProducer.in1);
+            const inp1IsPartialSum =
+              inp1Producer &&
+              inp1Producer.op === 'XOR' &&
+              ((inp1Producer.in1.startsWith('x') && inp1Producer.in2.startsWith('y')) ||
+               (inp1Producer.in1.startsWith('y') && inp1Producer.in2.startsWith('x')));
+            if (inp1IsPartialSum) {
+              carry = zProducer.in2;
+              partialSum = zProducer.in1;
+            } else {
+              carry = zProducer.in1;
+              partialSum = zProducer.in2;
+            }
+          }
+          sumGate = zProducer;
+        } else {
+          // zN is swapped (caught by Phase 1). We need to find the actual sum gate
+          // that should output zN. Look for a XOR gate that uses partialSum or carry.
+          const partialSumConsumers = (consumers.get(partialSum) || []).filter(
+            (g) => g.op === 'XOR'
+          );
+          if (partialSumConsumers.length === 1) {
+            sumGate = partialSumConsumers[0];
+            // The other input of this gate is the carry
+            const otherInput =
+              sumGate.in1 === partialSum ? sumGate.in2 : sumGate.in1;
+            if (otherInput !== carry) {
+              // carry was likely swapped too, but that would be caught elsewhere
+              carry = otherInput;
+            }
+          }
+        }
+      }
+
+      // Now compute carry for next bit
+      const propGate = findGate('AND', partialSum, carry);
+      const genCarry = andGate.out;
+      const propCarry = propGate ? propGate.out : '';
+
+      if (propCarry) {
+        const orGate = findGate('OR', genCarry, propCarry);
+        if (orGate) {
+          carry = orGate.out;
+        } else {
+          // OR gate not found — one of genCarry or propCarry might be swapped
+          // Try to find an OR gate that uses one of them
+          const genConsumers = (consumers.get(genCarry) || []).filter(
+            (g) => g.op === 'OR'
+          );
+          const propConsumers = (consumers.get(propCarry) || []).filter(
+            (g) => g.op === 'OR'
+          );
+          if (genConsumers.length === 1) {
+            carry = genConsumers[0].out;
+          } else if (propConsumers.length === 1) {
+            carry = propConsumers[0].out;
+          }
+        }
+      } else {
+        // propGate not found — likely due to a swap affecting partialSum or carry
+        // Try to find carry through other means
+        const genConsumers = (consumers.get(genCarry) || []).filter(
+          (g) => g.op === 'OR'
+        );
+        if (genConsumers.length === 1) {
+          carry = genConsumers[0].out;
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
