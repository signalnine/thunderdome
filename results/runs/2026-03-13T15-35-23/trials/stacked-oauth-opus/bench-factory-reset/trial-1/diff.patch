+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+import type { Machine } from './index.js';
+
+// Helper to verify a toggle solution
+function verifyToggle(machine: Machine, buttons: number[]): boolean {
+  const state = new Array(machine.target.length).fill(false);
+  for (const b of buttons) {
+    for (const light of machine.buttons[b]) {
+      state[light] = !state[light];
+    }
+  }
+  return state.every((s, i) => s === machine.target[i]);
+}
+
+// Helper to verify a counter solution
+function verifyCounter(lights: number[], buttons: number[][], modulus: number, presses: number[]): boolean {
+  const state = new Array(lights.length).fill(0);
+  for (let b = 0; b < buttons.length; b++) {
+    for (const counter of buttons[b]) {
+      state[counter] = (state[counter] + presses[b]) % modulus;
+    }
+  }
+  return state.every((s, i) => s === lights[i]);
+}
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]]
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should return null when no solution exists', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]]
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should solve a simple single button toggle', () => {
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should solve with multiple buttons', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1]]
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should prefer fewer button presses', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]]
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('should return lexicographically smallest on tie', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]]
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle no buttons with non-trivial target', () => {
+    expect(solveToggle({ target: [true], buttons: [] })).toBeNull();
+  });
+
+  it('should handle no buttons with all-off target', () => {
+    expect(solveToggle({ target: [false, false], buttons: [] })).toEqual([]);
+  });
+
+  it('should handle larger systems', () => {
+    const machine: Machine = {
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]]
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 2, 4]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle overlapping buttons', () => {
+    const machine: Machine = {
+      target: [true, false, true, false, true],
+      buttons: [[0, 1, 2], [1, 2, 3], [2, 3, 4]]
+    };
+    const result = solveToggle(machine);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('should handle system with redundant buttons', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [0], [1]]
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('should handle 10x10 identity-like system', () => {
+    const n = 10;
+    const buttons: number[][] = [];
+    const target: boolean[] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+      target.push(i % 2 === 0);
+    }
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+    expect(result).toEqual([0, 2, 4, 6, 8]);
+  });
+
+  it('should handle many redundant buttons (larger null space)', () => {
+    // 3 lights, 8 buttons, each toggling light 0
+    // Target: [true, false, false]
+    // Any odd number of these 8 buttons works for light 0.
+    // Min presses = 1. Lex smallest = [0].
+    const machine: Machine = {
+      target: [true, false, false],
+      buttons: [[0], [0], [0], [0], [0], [0], [0], [0]]
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle 20 buttons with large null space', () => {
+    // 2 lights, 20 buttons all toggling light 0
+    // Target: [true, false]
+    const buttons: number[][] = [];
+    for (let i = 0; i < 20; i++) buttons.push([0]);
+    const machine: Machine = { target: [true, false], buttons };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(1);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle performance for moderate null space dimensions', () => {
+    // 5 lights, 20 buttons. First 5 buttons are identity, rest toggle light 0.
+    const buttons: number[][] = [];
+    for (let i = 0; i < 5; i++) buttons.push([i]);
+    for (let i = 5; i < 20; i++) buttons.push([0]);
+    const target = [true, true, true, true, true];
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+    // Optimal: press buttons [0,1,2,3,4] (5 presses) since all lights need to be on
+    // But buttons 5-19 also toggle light 0, so pressing 0 + any even subset of 5-19 also works
+    // Min presses is 5 (all identity buttons)
+    expect(result!.length).toBe(5);
+  });
+
+  it('should handle 40 buttons 40 lights (performance)', () => {
+    const n = 40;
+    const buttons: number[][] = [];
+    const target: boolean[] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+      target.push(true);
+    }
+    const machine: Machine = { target, buttons };
+    const start = Date.now();
+    const result = solveToggle(machine);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(40);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle large null space (30+ buttons, few lights)', () => {
+    // 2 lights, 30 buttons, all toggling light 0
+    // This creates a null space of dimension ~29
+    // Target: [true, false]
+    const buttons: number[][] = [];
+    for (let i = 0; i < 30; i++) buttons.push([0]);
+    const machine: Machine = { target: [true, false], buttons };
+    const start = Date.now();
+    const result = solveToggle(machine);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(1); // Min presses = 1
+    expect(result).toEqual([0]); // Lex smallest
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle medium null space with mixed buttons', () => {
+    // 3 lights, 28 buttons
+    // First 3 buttons are identity (one per light)
+    // Remaining 25 all toggle light 0
+    // Target: [true, true, true]
+    // Optimal: press buttons [0,1,2] (3 presses)
+    const buttons: number[][] = [[0], [1], [2]];
+    for (let i = 3; i < 28; i++) buttons.push([0]);
+    const machine: Machine = { target: [true, true, true], buttons };
+    const start = Date.now();
+    const result = solveToggle(machine);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+    expect(result!.length).toBe(3);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return array of zeros when target is all zero', () => {
+    expect(solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5)).toEqual([0, 0]);
+  });
+
+  it('should solve a simple single button case', () => {
+    expect(solveCounter([3], [[0]], 5)).toEqual([3]);
+  });
+
+  it('should handle no solution', () => {
+    expect(solveCounter([1, 0], [[0, 1]], 3)).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).not.toBeNull();
+    expect(result!.reduce((a, b) => a + b, 0)).toBe(1);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should return lexicographically smallest on tie', () => {
+    expect(solveCounter([2], [[0], [0]], 5)).toEqual([0, 2]);
+  });
+
+  it('should handle modular arithmetic correctly', () => {
+    expect(solveCounter([0], [[0]], 5)).toEqual([0]);
+  });
+
+  it('should handle multiple independent counters', () => {
+    const result = solveCounter([3, 2], [[0], [1]], 7);
+    expect(result).toEqual([3, 2]);
+    expect(verifyCounter([3, 2], [[0], [1]], 7, result!)).toBe(true);
+  });
+
+  it('should handle no buttons with non-zero target', () => {
+    expect(solveCounter([1], [], 3)).toBeNull();
+  });
+
+  it('should handle no buttons with zero target', () => {
+    expect(solveCounter([0, 0], [], 3)).toEqual([]);
+  });
+
+  it('should handle larger modulus', () => {
+    expect(solveCounter([50], [[0]], 97)).toEqual([50]);
+  });
+
+  it('should solve a 2x2 system over GF(p)', () => {
+    const result = solveCounter([2, 3], [[0, 1], [1]], 5);
+    expect(result).toEqual([2, 1]);
+    expect(verifyCounter([2, 3], [[0, 1], [1]], 5, result!)).toBe(true);
+  });
+
+  it('should prefer minimum sum over lexicographic ordering', () => {
+    // Button 0 increments [0], Button 1 increments [0].
+    // Target: [4]. Mod 5.
+    // Options: [0,4](sum=4), [1,3](sum=4), [2,2](sum=4), [3,1](sum=4), [4,0](sum=4)
+    // All have same sum. Lex smallest: [0, 4]
+    const result = solveCounter([4], [[0], [0]], 5);
+    expect(result).toEqual([0, 4]);
+  });
+
+  it('should handle 10 buttons and 10 counters', () => {
+    const n = 10;
+    const buttons: number[][] = [];
+    const lights: number[] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+      lights.push(i % 7);
+    }
+    const result = solveCounter(lights, buttons, 7);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(lights, buttons, 7, result!)).toBe(true);
+  });
+
+  it('should handle 40 buttons and 40 counters (performance)', () => {
+    const n = 40;
+    const buttons: number[][] = [];
+    const lights: number[] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+      lights.push((i * 3) % 97);
+    }
+    const start = Date.now();
+    const result = solveCounter(lights, buttons, 97);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(lights, buttons, 97, result!)).toBe(true);
+  });
+
+  it('should handle overlapping buttons with modulus', () => {
+    // Button 0 increments [0,1], Button 1 increments [1,2], Button 2 increments [0,2]
+    // Target: [1, 2, 3]. Mod 5.
+    // b0 + b2 = 1 (counter 0)
+    // b0 + b1 = 2 (counter 1)
+    // b1 + b2 = 3 (counter 2)
+    // Adding all: 2(b0+b1+b2) = 6 = 1 mod 5, so b0+b1+b2 = 3 (since 2*3=6=1 mod 5)
+    // b1 = 3 - b0 - b2; from counter 0: b2 = 1 - b0
+    // b1 = 3 - b0 - (1-b0) = 2
+    // b0 + b1 = b0 + 2 = 2 => b0 = 0, b2 = 1
+    const result = solveCounter([1, 2, 3], [[0, 1], [1, 2], [0, 2]], 5);
+    expect(result).not.toBeNull();
+    expect(verifyCounter([1, 2, 3], [[0, 1], [1, 2], [0, 2]], 5, result!)).toBe(true);
+    expect(result).toEqual([0, 2, 1]);
+  });
+
+  it('should find minimum sum with modular wrapping', () => {
+    // Button 0 increments [0]. Target: [1]. Mod 5.
+    // Options: 1 press (sum=1) — clearly minimum
+    const result = solveCounter([1], [[0]], 5);
+    expect(result).toEqual([1]);
+  });
+
+  it('should handle case where 0 presses is optimal for some buttons', () => {
+    // Buttons: [0], [1]. Target: [3, 0]. Mod 7.
+    const result = solveCounter([3, 0], [[0], [1]], 7);
+    expect(result).toEqual([3, 0]);
+  });
+});
