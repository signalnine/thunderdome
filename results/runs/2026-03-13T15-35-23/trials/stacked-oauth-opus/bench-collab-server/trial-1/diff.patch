@@ -0,0 +1,392 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string at current position
+ * - number < 0: delete |N| characters
+ *
+ * The sum of positive retain + |negative delete| must equal the document length
+ * the operation is applied against.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  clientId: string;
+  version: number; // the version this op was created against
+  operation: Operation;
+}
+
+/**
+ * Returns the input length an operation expects.
+ */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      else len += Math.abs(c);
+    }
+  }
+  return len;
+}
+
+/**
+ * Returns the output length after applying an operation.
+ */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      // delete contributes nothing to output
+    } else {
+      len += c.length;
+    }
+  }
+  return len;
+}
+
+/**
+ * Normalize an operation by merging adjacent components of the same type
+ * and removing no-ops.
+ */
+export function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (typeof c === 'number' && typeof last === 'number') {
+        if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+          result[result.length - 1] = last + c;
+          continue;
+        }
+      }
+      if (typeof c === 'string' && typeof last === 'string') {
+        result[result.length - 1] = last + c;
+        continue;
+      }
+    }
+    result.push(c);
+  }
+  return result;
+}
+
+/**
+ * Apply an operation to a document string.
+ */
+export function apply(doc: string, op: Operation): string {
+  let pos = 0;
+  let result = '';
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        // retain
+        if (pos + c > doc.length) {
+          throw new Error(
+            `Retain overflows document: pos=${pos}, retain=${c}, docLen=${doc.length}`
+          );
+        }
+        result += doc.substring(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        const delCount = Math.abs(c);
+        if (pos + delCount > doc.length) {
+          throw new Error(
+            `Delete overflows document: pos=${pos}, delete=${delCount}, docLen=${doc.length}`
+          );
+        }
+        pos += delCount;
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+  // Append any remaining characters (if op doesn't cover full doc, this is an error
+  // but we'll be lenient)
+  if (pos < doc.length) {
+    result += doc.substring(pos);
+  }
+  return result;
+}
+
+/**
+ * Compose two sequential operations into one.
+ * apply(apply(doc, a), b) === apply(doc, compose(a, b))
+ */
+export function compose(a: Operation, b: Operation): Operation {
+  const result: Operation = [];
+  let ia = 0;
+  let ib = 0;
+  let aRemain: OpComponent | null = null;
+  let bRemain: OpComponent | null = null;
+
+  function nextA(): OpComponent | null {
+    if (aRemain !== null) {
+      const v = aRemain;
+      aRemain = null;
+      return v;
+    }
+    if (ia < a.length) return a[ia++];
+    return null;
+  }
+
+  function nextB(): OpComponent | null {
+    if (bRemain !== null) {
+      const v = bRemain;
+      bRemain = null;
+      return v;
+    }
+    if (ib < b.length) return b[ib++];
+    return null;
+  }
+
+  function push(c: OpComponent) {
+    result.push(c);
+  }
+
+  // eslint-disable-next-line no-constant-condition
+  while (true) {
+    const ca = nextA();
+    const cb = nextB();
+
+    if (ca === null && cb === null) break;
+
+    // If a has a delete, it consumes input and doesn't interact with b
+    if (typeof ca === 'number' && ca < 0) {
+      push(ca);
+      if (cb !== null) bRemain = cb;
+      continue;
+    }
+
+    // If b has an insert, it doesn't consume a's output
+    if (typeof cb === 'string') {
+      push(cb);
+      if (ca !== null) aRemain = ca;
+      continue;
+    }
+
+    if (ca === null) {
+      if (cb !== null) push(cb);
+      continue;
+    }
+    if (cb === null) {
+      push(ca);
+      continue;
+    }
+
+    // Both are non-null. ca is retain or insert, cb is retain or delete
+    if (typeof ca === 'string' && typeof cb === 'number' && cb > 0) {
+      // a inserts, b retains over that insert
+      const aLen = ca.length;
+      const bRet = cb;
+      if (aLen <= bRet) {
+        push(ca);
+        if (bRet > aLen) bRemain = bRet - aLen;
+      } else {
+        push(ca.substring(0, bRet));
+        aRemain = ca.substring(bRet);
+      }
+    } else if (typeof ca === 'string' && typeof cb === 'number' && cb < 0) {
+      // a inserts, b deletes from that insert
+      const aLen = ca.length;
+      const bDel = Math.abs(cb);
+      if (aLen <= bDel) {
+        // entire insert is deleted
+        if (bDel > aLen) bRemain = -(bDel - aLen);
+      } else {
+        aRemain = ca.substring(bDel);
+      }
+    } else if (typeof ca === 'number' && ca > 0 && typeof cb === 'number' && cb > 0) {
+      // both retain
+      const min = Math.min(ca, cb);
+      push(min);
+      if (ca > min) aRemain = ca - min;
+      if (cb > min) bRemain = cb - min;
+    } else if (typeof ca === 'number' && ca > 0 && typeof cb === 'number' && cb < 0) {
+      // a retains, b deletes
+      const aRet = ca;
+      const bDel = Math.abs(cb);
+      const min = Math.min(aRet, bDel);
+      push(-min);
+      if (aRet > min) aRemain = aRet - min;
+      if (bDel > min) bRemain = -(bDel - min);
+    }
+  }
+
+  return normalize(result);
+}
+
+/**
+ * Transform two concurrent operations.
+ * Given operations a and b that were both created against the same document state,
+ * returns [a', b'] such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * a has priority (left wins on tie).
+ */
+export function transform(a: Operation, b: Operation): [Operation, Operation] {
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  let ia = 0;
+  let ib = 0;
+  let aRemain: OpComponent | null = null;
+  let bRemain: OpComponent | null = null;
+
+  function nextA(): OpComponent | null {
+    if (aRemain !== null) {
+      const v = aRemain;
+      aRemain = null;
+      return v;
+    }
+    if (ia < a.length) return a[ia++];
+    return null;
+  }
+
+  function nextB(): OpComponent | null {
+    if (bRemain !== null) {
+      const v = bRemain;
+      bRemain = null;
+      return v;
+    }
+    if (ib < b.length) return b[ib++];
+    return null;
+  }
+
+  // eslint-disable-next-line no-constant-condition
+  while (true) {
+    const ca = nextA();
+    const cb = nextB();
+
+    if (ca === null && cb === null) break;
+
+    // a inserts: a' keeps the insert, b' retains over it
+    if (typeof ca === 'string') {
+      aPrime.push(ca);
+      bPrime.push(ca.length);
+      if (cb !== null) bRemain = cb;
+      continue;
+    }
+
+    // b inserts: b' keeps the insert, a' retains over it
+    if (typeof cb === 'string') {
+      bPrime.push(cb);
+      aPrime.push(cb.length);
+      if (ca !== null) aRemain = ca;
+      continue;
+    }
+
+    if (ca === null && cb === null) break;
+
+    if (ca === null) {
+      if (cb !== null) {
+        bPrime.push(cb);
+        // If b is delete, a doesn't need to account for it in same way
+        // But this shouldn't happen in a well-formed pair
+      }
+      continue;
+    }
+    if (cb === null) {
+      aPrime.push(ca);
+      continue;
+    }
+
+    // Both are numbers (retain or delete)
+    const aIsRetain = ca > 0;
+    const bIsRetain = cb > 0;
+    const aAbs = Math.abs(ca);
+    const bAbs = Math.abs(cb);
+
+    if (aIsRetain && bIsRetain) {
+      // Both retain
+      const min = Math.min(aAbs, bAbs);
+      aPrime.push(min);
+      bPrime.push(min);
+      if (aAbs > min) aRemain = aAbs - min;
+      if (bAbs > min) bRemain = bAbs - min;
+    } else if (!aIsRetain && !bIsRetain) {
+      // Both delete the same region
+      const min = Math.min(aAbs, bAbs);
+      // Neither prime gets anything for the overlapping deletion
+      if (aAbs > min) aRemain = -(aAbs - min);
+      if (bAbs > min) bRemain = -(bAbs - min);
+    } else if (!aIsRetain && bIsRetain) {
+      // a deletes, b retains
+      const min = Math.min(aAbs, bAbs);
+      aPrime.push(-min);
+      // b' doesn't retain what a deleted
+      if (aAbs > min) aRemain = -(aAbs - min);
+      if (bAbs > min) bRemain = bAbs - min;
+    } else {
+      // a retains, b deletes
+      const min = Math.min(aAbs, bAbs);
+      bPrime.push(-min);
+      // a' doesn't retain what b deleted
+      if (aAbs > min) aRemain = aAbs - min;
+      if (bAbs > min) bRemain = -(bAbs - min);
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/**
+ * Validate that an operation is well-formed for the given document length.
+ */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) {
+    return 'Operation must be an array';
+  }
+  let consumed = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c) || c === 0) {
+        return `Invalid operation component: ${c}`;
+      }
+      if (c > 0) consumed += c;
+      else consumed += Math.abs(c);
+    } else if (typeof c === 'string') {
+      if (c.length === 0) {
+        return 'Empty string insert is not allowed';
+      }
+    } else {
+      return `Invalid operation component type: ${typeof c}`;
+    }
+  }
+  if (consumed !== docLength) {
+    return `Operation length mismatch: operation consumes ${consumed} chars but document has ${docLength}`;
+  }
+  return null;
+}
+
+/**
+ * Create a simple insert operation.
+ */
+export function makeInsert(pos: number, text: string, docLength: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(text);
+  if (docLength - pos > 0) op.push(docLength - pos);
+  return normalize(op);
+}
+
+/**
+ * Create a simple delete operation.
+ */
+export function makeDelete(pos: number, count: number, docLength: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push(pos);
+  op.push(-count);
+  if (docLength - pos - count > 0) op.push(docLength - pos - count);
+  return normalize(op);
+}
