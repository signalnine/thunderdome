+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server } from 'http';
+import { randomUUID } from 'crypto';
+import { DocumentStore } from './db.js';
+import { Operation, apply, transform, validate } from './ot.js';
+
+interface ClientConnection {
+  id: string;
+  ws: WebSocket;
+  docId: string;
+}
+
+interface DocumentState {
+  version: number;
+  baseVersion: number; // version before any ops in history
+  // history[i] is the operation that transforms baseVersion+i to baseVersion+i+1
+  history: Operation[];
+}
+
+interface IncomingOperation {
+  type: 'operation';
+  version: number;
+  operation: Operation;
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  // docId -> list of connected clients
+  private rooms: Map<string, ClientConnection[]> = new Map();
+  // docId -> server-side document state
+  private docStates: Map<string, DocumentState> = new Map();
+
+  constructor(
+    private server: Server,
+    private store: DocumentStore
+  ) {
+    this.wss = new WebSocketServer({ server, path: undefined });
+
+    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      this.handleConnection(ws, req);
+    });
+  }
+
+  private getDocIdFromUrl(url: string | undefined): string | null {
+    if (!url) return null;
+    const match = url.match(/\/documents\/([^/]+)/);
+    return match ? match[1] : null;
+  }
+
+  private getOrCreateDocState(docId: string): DocumentState | null {
+    let state = this.docStates.get(docId);
+    if (!state) {
+      const doc = this.store.getDocument(docId);
+      if (!doc) return null;
+
+      const versions = this.store.getVersions(docId);
+      const history: Operation[] = [];
+
+      // Find the base version: the highest version number that has no operation
+      // (i.e., the initial snapshot). All versions with operations after that
+      // are the ops in our history array.
+      let baseVersion = 0;
+      let collectOps = false;
+      for (const v of versions) {
+        if (v.operation) {
+          collectOps = true;
+          try {
+            history.push(JSON.parse(v.operation));
+          } catch {
+            // Skip malformed operations
+          }
+        } else if (!collectOps) {
+          // This is a snapshot version (no op); update baseVersion
+          baseVersion = v.version;
+        }
+      }
+
+      state = {
+        version: this.store.getLatestVersion(docId),
+        baseVersion,
+        history,
+      };
+      this.docStates.set(docId, state);
+    }
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, req: IncomingMessage) {
+    const docId = this.getDocIdFromUrl(req.url);
+    if (!docId) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid URL: missing document ID' }));
+      ws.close();
+      return;
+    }
+
+    const doc = this.store.getDocument(docId);
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    const state = this.getOrCreateDocState(docId);
+    if (!state) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Failed to load document state' }));
+      ws.close();
+      return;
+    }
+
+    const clientId = randomUUID();
+    const client: ClientConnection = { id: clientId, ws, docId };
+
+    // Add to room
+    if (!this.rooms.has(docId)) {
+      this.rooms.set(docId, []);
+    }
+    this.rooms.get(docId)!.push(client);
+
+    // Send initial sync with current document state
+    ws.send(
+      JSON.stringify({
+        type: 'sync',
+        clientId,
+        docId,
+        content: doc.content,
+        version: state.version,
+      })
+    );
+
+    ws.on('message', (data) => {
+      try {
+        const message = JSON.parse(data.toString());
+        // Look up state dynamically to avoid stale closure
+        const currentState = this.docStates.get(docId);
+        if (!currentState) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Document state not found' }));
+          return;
+        }
+        this.handleMessage(client, message, currentState);
+      } catch (err) {
+        ws.send(
+          JSON.stringify({
+            type: 'error',
+            message: err instanceof Error ? err.message : 'Invalid message',
+          })
+        );
+      }
+    });
+
+    ws.on('close', () => {
+      this.removeClient(client);
+    });
+
+    ws.on('error', () => {
+      this.removeClient(client);
+    });
+  }
+
+  private handleMessage(
+    client: ClientConnection,
+    message: IncomingOperation,
+    state: DocumentState
+  ) {
+    if (message.type !== 'operation') {
+      client.ws.send(
+        JSON.stringify({ type: 'error', message: `Unknown message type: ${message.type}` })
+      );
+      return;
+    }
+
+    if (!message.operation || !Array.isArray(message.operation)) {
+      client.ws.send(
+        JSON.stringify({ type: 'error', message: 'Invalid operation format' })
+      );
+      return;
+    }
+
+    if (typeof message.version !== 'number' || message.version < 0) {
+      client.ws.send(
+        JSON.stringify({ type: 'error', message: 'Invalid version number' })
+      );
+      return;
+    }
+
+    if (message.version > state.version) {
+      client.ws.send(
+        JSON.stringify({ type: 'error', message: 'Version is ahead of server' })
+      );
+      return;
+    }
+
+    // Get current document content
+    const doc = this.store.getDocument(client.docId);
+    if (!doc) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      return;
+    }
+
+    let op = message.operation;
+
+    // Transform against all operations that happened since the client's version
+    const historyIndex = message.version - state.baseVersion;
+    const concurrentOps = state.history.slice(historyIndex);
+    for (const serverOp of concurrentOps) {
+      try {
+        const [transformedClient] = transform(op, serverOp);
+        op = transformedClient;
+      } catch (err) {
+        client.ws.send(
+          JSON.stringify({
+            type: 'error',
+            message: `Transform failed: ${err instanceof Error ? err.message : 'unknown error'}`,
+          })
+        );
+        return;
+      }
+    }
+
+    // Validate the transformed operation against current document
+    const validationError = validate(op, doc.content.length);
+    if (validationError) {
+      client.ws.send(JSON.stringify({ type: 'error', message: validationError }));
+      return;
+    }
+
+    // Apply the operation
+    let newContent: string;
+    try {
+      newContent = apply(doc.content, op);
+    } catch (err) {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: `Apply failed: ${err instanceof Error ? err.message : 'unknown error'}`,
+        })
+      );
+      return;
+    }
+
+    // Persist first, then update in-memory state
+    try {
+      this.store.addVersion(client.docId, newContent, JSON.stringify(op));
+    } catch (err) {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: `Persist failed: ${err instanceof Error ? err.message : 'unknown error'}`,
+        })
+      );
+      return;
+    }
+
+    // Update in-memory state only after successful persistence
+    state.history.push(op);
+    state.version++;
+
+    // Acknowledge to sender
+    client.ws.send(
+      JSON.stringify({
+        type: 'ack',
+        version: state.version,
+      })
+    );
+
+    // Broadcast to other clients in the room
+    const room = this.rooms.get(client.docId) || [];
+    for (const other of room) {
+      if (other.id !== client.id && other.ws.readyState === WebSocket.OPEN) {
+        other.ws.send(
+          JSON.stringify({
+            type: 'operation',
+            clientId: client.id,
+            version: state.version,
+            operation: op,
+          })
+        );
+      }
+    }
+  }
+
+  private removeClient(client: ClientConnection) {
+    const room = this.rooms.get(client.docId);
+    if (room) {
+      const idx = room.findIndex((c) => c.id === client.id);
+      if (idx !== -1) {
+        room.splice(idx, 1);
+      }
+      if (room.length === 0) {
+        this.rooms.delete(client.docId);
+        // Clean up docState when no clients are connected
+        this.docStates.delete(client.docId);
+      }
+    }
+  }
+
+  getConnectedClients(docId: string): number {
+    return this.rooms.get(docId)?.length || 0;
+  }
+
+  closeAll() {
+    for (const [, clients] of this.rooms) {
+      for (const client of clients) {
+        client.ws.close();
+      }
+    }
+    this.rooms.clear();
+    this.docStates.clear();
+    this.wss.close();
+  }
+}
