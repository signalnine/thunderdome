+
+// ===== Persistence Tests =====
+describe('Persistence', () => {
+  it('should persist documents across server restarts', async () => {
+    const dbPath = '/tmp/test-persist-' + Date.now() + '.db';
+
+    // First server instance
+    const app1 = createApp(dbPath);
+    await app1.start(0);
+
+    const create = await request(app1.app)
+      .post('/api/documents')
+      .send({ title: 'Persistent', content: 'Saved content' });
+    const docId = create.body.id;
+
+    await app1.stop();
+
+    // Second server instance with same DB
+    const app2 = createApp(dbPath);
+    await app2.start(0);
