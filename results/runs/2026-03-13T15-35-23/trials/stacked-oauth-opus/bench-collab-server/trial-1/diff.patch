+    const { ws, sync } = await connectWs(create.body.id);
+    let version = sync.version;
+
+    // Send 20 sequential insert operations
+    for (let i = 0; i < 20; i++) {
+      ws.send(
+        JSON.stringify({
+          type: 'operation',
+          version,
+          operation: i === 0 ? [String(i % 10)] : [i, String(i % 10)],
+        })
+      );
+      const ack = await waitForMessage(ws, 'ack');
