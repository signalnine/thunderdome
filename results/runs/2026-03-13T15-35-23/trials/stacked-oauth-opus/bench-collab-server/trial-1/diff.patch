+import express from 'express';
+import { createServer, Server } from 'http';
+import { createDatabase, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './ws.js';
+import Database from 'better-sqlite3';
+
+export interface AppInstance {
+  app: express.Express;
+  server: Server;
+  db: Database.Database;
+  store: DocumentStore;
+  collaboration: CollaborationServer;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(store);
+  app.use('/api', router);
+  // Also mount at root for flexibility
+  app.use(router);
+
+  const server = createServer(app);
+  const collaboration = new CollaborationServer(server, store);
+
+  const start = (port?: number): Promise<number> => {
+    return new Promise((resolve, reject) => {
+      server.on('error', reject);
+      server.listen(port || 0, () => {
+        const addr = server.address();
+        if (addr && typeof addr === 'object') {
+          resolve(addr.port);
+        } else {
+          reject(new Error('Failed to get server address'));
+        }
+      });
+    });
+  };
+
+  const stop = (): Promise<void> => {
+    return new Promise((resolve, reject) => {
+      collaboration.closeAll();
+      server.close((err) => {
+        db.close();
+        if (err) reject(err);
+        else resolve();
+      });
+    });
+  };
+
+  return { app, server, db, store, collaboration, start, stop };
+}
+
+export default createApp;
