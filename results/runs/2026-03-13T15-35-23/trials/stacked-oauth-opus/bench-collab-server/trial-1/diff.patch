+    // Each client inserts their number
+    for (let i = 0; i < 10; i++) {
+      const c = clients[i];
+      c.ws.send(
+        JSON.stringify({
+          type: 'operation',
+          version: c.sync.version,
+          operation: [String(i)],
+        })
+      );
+      await waitForMessage(c.ws, 'ack');
+    }
+
+    // Wait for all broadcasts
+    await new Promise((r) => setTimeout(r, 500));
+
+    const doc = await request(app.app).get(`/api/documents/${create.body.id}`);
+    // All digits 0-9 should be present
+    for (let i = 0; i < 10; i++) {
