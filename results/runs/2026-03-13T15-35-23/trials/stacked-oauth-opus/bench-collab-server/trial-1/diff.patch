+let app: AppInstance;
+let port: number;
+
+function wsUrl(docId: string): string {
+  return `ws://localhost:${port}/documents/${docId}`;
+}
+
+function connectWs(docId: string): Promise<{ ws: WebSocket; sync: { clientId: string; content: string; version: number } }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(docId));
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'sync') {
+        resolve({ ws, sync: msg });
+      } else if (msg.type === 'error') {
+        reject(new Error(msg.message));
+      }
+    });
+    ws.on('error', reject);
+  });
+}
+
+function waitForMessage(ws: WebSocket, type?: string): Promise<Record<string, unknown>> {
+  return new Promise((resolve) => {
+    const handler = (data: WebSocket.Data) => {
+      const msg = JSON.parse(data.toString());
+      if (!type || msg.type === type) {
+        ws.removeListener('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+  });
+}
