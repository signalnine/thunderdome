+  it('should persist WebSocket edits across restarts', async () => {
+    const dbPath = '/tmp/test-persist-ws-' + Date.now() + '.db';
+
+    const app1 = createApp(dbPath);
+    const port1 = await app1.start(0);
+
+    const create = await request(app1.app)
+      .post('/api/documents')
+      .send({ title: 'WS Persist', content: 'Hello' });
+    const docId = create.body.id;
+
+    const ws1 = new WebSocket(`ws://localhost:${port1}/documents/${docId}`);
+    const syncMsg: Record<string, unknown> = await new Promise((resolve) => {
+      ws1.on('message', (data) => {
+        resolve(JSON.parse(data.toString()));
+      });
+    });
+
+    const op = makeInsert(5, ' World', 5);
+    ws1.send(JSON.stringify({ type: 'operation', version: syncMsg.version, operation: op }));
+    await new Promise<void>((resolve) => {
+      ws1.on('message', (data) => {
+        const msg = JSON.parse(data.toString());
+        if (msg.type === 'ack') resolve();
+      });
+    });
+
+    ws1.close();
+    await new Promise((r) => setTimeout(r, 100));
+    await app1.stop();
+
+    // Restart
+    const app2 = createApp(dbPath);
+    await app2.start(0);
+
+    const doc = await request(app2.app).get(`/api/documents/${docId}`);
+    expect(doc.body.content).toBe('Hello World');
+
+    await app2.stop();
+  });
+
+  it('should persist version history across restarts', async () => {
+    const dbPath = '/tmp/test-persist-versions-' + Date.now() + '.db';
+
+    const app1 = createApp(dbPath);
+    await app1.start(0);
+
+    const create = await request(app1.app)
+      .post('/api/documents')
+      .send({ title: 'Version Persist', content: 'v1' });
+    const docId = create.body.id;
+
+    await app1.stop();
+
+    const app2 = createApp(dbPath);
+    await app2.start(0);
+
+    const versions = await request(app2.app).get(`/api/documents/${docId}/versions`);
+    expect(versions.body.length).toBeGreaterThanOrEqual(1);
+
+    await app2.stop();
+  });
+});
+
+// ===== OT Unit Tests =====
+describe('OT Engine', () => {
+  it('should apply insert operation correctly', () => {
+    const result = apply('Hello', makeInsert(5, ' World', 5));
+    expect(result).toBe('Hello World');
+  });
+
+  it('should apply delete operation correctly', () => {
+    const result = apply('Hello World', makeDelete(5, 6, 11));
+    expect(result).toBe('Hello');
+  });
+
+  it('should transform concurrent inserts', () => {
+    const doc = 'AB';
+    const a = makeInsert(1, 'X', 2);
+    const b = makeInsert(1, 'Y', 2);
+
+    const [aPrime, bPrime] = transform(a, b);
+    const result1 = apply(apply(doc, a), bPrime);
+    const result2 = apply(apply(doc, b), aPrime);
+    expect(result1).toBe(result2);
+  });
+
+  it('should validate operations', () => {
+    expect(validate([5, 'X'], 5)).toBeNull();
+    expect(validate([10, 'X'], 5)).not.toBeNull();
+    expect(validate([], 0)).toBeNull();
+  });
+
+  it('should normalize operations', () => {
+    expect(normalize([3, 2, 'a', 'b'])).toEqual([5, 'ab']);
+    expect(normalize([0, 3])).toEqual([3]);
+  });
+});
