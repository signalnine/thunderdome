+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,32 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Find relative URLs in src="./..." and href="./..."
+        const assetRegex = /(src|href)="\.\/([^"]+)"/g;
+        const discoveredAssets: string[] = [];
+
+        content = content.replace(assetRegex, (_match, attr, filename) => {
+          discoveredAssets.push(filename);
+          return `${attr}="/assets/${filename}"`;
+        });
+
+        // Update asset manifest in ctx.data
+        if (discoveredAssets.length > 0) {
+          const existing = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+          const assets = existing ? [...existing.assets, ...discoveredAssets] : [...discoveredAssets];
+          ctx.data.set('asset-manifest', { assets });
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
