@@ -0,0 +1,50 @@
+import type { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assetPaths = manifest ? manifest.assets : [];
+
+        const routes: Array<{ path: string; handler: string }> = [];
+
+        // Add asset routes
+        for (const asset of assetPaths) {
+          routes.push({ path: `/assets/${asset}`, handler: 'asset' });
+        }
+
+        // Add content routes for .html files
+        for (const key of ctx.output.keys()) {
+          if (key.endsWith('.html')) {
+            routes.push({ path: `/${key}`, handler: 'static' });
+          }
+        }
+
+        // Search index path
+        const searchIndexPath = ctx.output.has('search-index.json')
+          ? '/search-index.json'
+          : '';
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath,
+        };
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
diff --git a/src/plugins/markdown-ext.ts b/src/plugins/markdown-ext.ts
new file mode 100644
index 0000000..191baf1
--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,72 @@
+import { marked } from 'marked';
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): { text: string; footnotes: Map<string, string> } {
+  const footnotes = new Map<string, string>();
+  // Extract footnote definitions: [^N]: text
+  const defRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  let match;
+  let text = content;
+  while ((match = defRegex.exec(content)) !== null) {
+    footnotes.set(match[1], match[2]);
+  }
+  // Remove footnote definitions from text
+  text = text.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '').trim();
+  return { text, footnotes };
+}
+
+function renderFootnoteRefs(html: string, footnotes: Map<string, string>): string {
+  // Replace [^N] references with superscript links
+  return html.replace(/\[\^(\d+)\]/g, (_match, num) => {
+    if (footnotes.has(num)) {
+      return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+    }
+    return _match;
+  });
+}
+
+function renderFootnoteSection(footnotes: Map<string, string>): string {
+  if (footnotes.size === 0) return '';
+  const items = Array.from(footnotes.entries())
+    .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+    .join('\n');
+  return `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+}
+
+function processAdmonitions(content: string): string {
+  // Process :::type\ncontent\n::: blocks before markdown parsing
+  return content.replace(/^:::(note|warning|tip)\n([\s\S]*?)^:::/gm, (_match, type, inner) => {
+    return `<div class="admonition admonition-${type}">\n${inner.trim()}\n</div>`;
+  });
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonitions before markdown
+        content = processAdmonitions(content);
+
+        // Extract and process footnotes
+        const { text, footnotes } = processFootnotes(content);
+        content = text;
+
+        // Parse markdown to HTML
+        content = marked.parse(content, { async: false }) as string;
+
+        // Replace footnote references in HTML
+        if (footnotes.size > 0) {
+          content = renderFootnoteRefs(content, footnotes);
+          content += renderFootnoteSection(footnotes);
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
