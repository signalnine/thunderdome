+import express, { Request, Response, Router } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import jwt from 'jsonwebtoken'; // For JWT
+import { getSql, execSql, runSql } from '../db'; // Assuming db.ts exports getSql, execSql, and runSql
+import { UserRow, DashboardRow } from '../db'; // Import UserRow and DashboardRow interfaces
+
+const router: Router = express.Router();
+
+// Secret key for JWT - In a real app, this should be loaded from environment variables
+const JWT_SECRET = process.env.JWT_SECRET || 'supersecretkey'; // Use a strong, unique key in production
+
+// Helper to verify JWT and tenant
+const verifyUserAndTenant = (req: Request, res: Response, requiredRole?: 'admin' | 'editor' | 'viewer'): boolean => {
+  const authHeader = req.headers.authorization;
+  const token = authHeader && authHeader.split(' ')[1];
+
+  if (!token) {
+    res.status(401).json({ message: 'Unauthorized: No token provided' });
+    return false; // Explicitly return false on failure
+  }
+
+  try {
+    const decoded = jwt.verify(token, JWT_SECRET) as { userId: string; tenantId: string; role: string };
+    const user = getSql<UserRow>('SELECT id, tenant_id, role FROM users WHERE id = ?', [decoded.userId]);
+
+    if (!user) {
+      res.status(401).json({ message: 'Unauthorized: User not found' });
+      return false;
+    }
+
+    if (user.tenant_id !== decoded.tenantId) {
+      res.status(403).json({ message: 'Forbidden: Tenant mismatch' });
+      return false;
+    }
+
+    if (requiredRole && !hasRole(user.role, requiredRole)) {
+        // Corrected template literal syntax for the error message
+        res.status(403).json({ message: `Forbidden: Required role '${requiredRole}' not met` });
+        return false;
+    }
+
+    // Attach user info to response locals for subsequent middleware/route handlers
+    res.locals.user = { userId: user.id, tenantId: user.tenant_id, role: user.role };
+    return true; // User is authenticated and authorized
+
+  } catch (error: any) {
+    console.error('JWT Verification Error:', error);
+    if (error.name === 'TokenExpiredError') {
+      res.status(401).json({ message: 'Unauthorized: Token expired' });
+    } else if (error.name === 'JsonWebTokenError') {
+      res.status(401).json({ message: 'Unauthorized: jwt malformed' });
+    } else {
+      res.status(401).json({ message: 'Unauthorized' });
+    }
+    return false;
+  }
+};
+
+const hasRole = (userRole: string, requiredRole: string): boolean => {
+    const roles = ['admin', 'editor', 'viewer'];
+    const userRoleIndex = roles.indexOf(userRole);
+    const requiredRoleIndex = roles.indexOf(requiredRole);
+    return userRoleIndex !== -1 && requiredRoleIndex !== -1 && userRoleIndex <= requiredRoleIndex;
+};
+
+
+// POST /dashboards
+router.post('/', (req: Request, res: Response) => {
+  if (!verifyUserAndTenant(req, res, 'editor')) return; // Requires editor role or above
+
+  const { name, config } = req.body;
+  const { tenantId, userId } = res.locals.user;
+
+  if (!name) {
+    return res.status(400).json({ message: 'Dashboard name is required' });
+  }
+
+  const dashboardId = uuidv4();
+  const now = new Date().toISOString();
+
+  try {
+    execSql(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)',
+      [dashboardId, tenantId, name, userId, JSON.stringify(config || {}), now, now]
+    );
+    res.status(201).json({ message: 'Dashboard created successfully', dashboardId });
+  } catch (error: any) {
+    console.error('Dashboard creation error:', error);
+    res.status(500).json({ message: 'Failed to create dashboard', error: error.message });
+  }
+});
+
+// GET /dashboards
+router.get('/', (req: Request, res: Response) => {
+  if (!verifyUserAndTenant(req, res, 'viewer')) return; // Requires viewer role or above
+
+  const { tenantId } = res.locals.user;
+
+  try {
+    const dashboards = runSql<DashboardRow[]>('SELECT id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?', [tenantId]);
+    // Parse config JSON for each dashboard
+    const parsedDashboards = dashboards.map((dash: DashboardRow) => ({ // Ensure callback processes individual DashboardRow object
+      ...dash,
+      config: JSON.parse(dash.config)
+    }));
+    res.status(200).json(parsedDashboards);
+  } catch (error: any) {
+    console.error('Get dashboards error:', error);
+    res.status(500).json({ message: 'Failed to retrieve dashboards', error: error.message });
+  }
+});
+
+// GET /dashboards/:id
+router.get('/:id', (req: Request, res: Response) => {
+  if (!verifyUserAndTenant(req, res, 'viewer')) return; // Requires viewer role or above
+
+  const { id } = req.params;
+  const { tenantId } = res.locals.user;
+
+  try {
+    const dashboard = getSql<DashboardRow>('SELECT id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?', [id, tenantId]);
+
+    if (!dashboard) {
+      return res.status(404).json({ message: 'Dashboard not found or access denied' });
+    }
+
+    // Parse config JSON for the response
+    const parsedDashboard = {
+      ...dashboard,
+      config: JSON.parse(dashboard.config)
+    };
+    res.status(200).json(parsedDashboard);
+  } catch (error: any) {
+    console.error('Get dashboard by ID error:', error);
+    res.status(500).json({ message: 'Failed to retrieve dashboard', error: error.message });
+  }
+});
+
+// PUT /dashboards/:id
+router.put('/:id', (req: Request, res: Response) => {
+  if (!verifyUserAndTenant(req, res, 'editor')) return; // Requires editor role or above
+
+  const { id } = req.params;
+  const { tenantId, userId } = res.locals.user;
+  const { name, config } = req.body;
+  const now = new Date().toISOString();
+
+  try {
+    // First, check if the dashboard exists and belongs to the current tenant
+    const currentDashboard = getSql<DashboardRow>('SELECT id, owner_id, tenant_id FROM dashboards WHERE id = ?', [id]);
+
+    if (!currentDashboard) {
+      return res.status(404).json({ message: 'Dashboard not found' });
+    }
+
+    if (currentDashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ message: 'Forbidden: Dashboard does not belong to your tenant' });
+    }
+
+    // Optionally, check if the user is the owner or an admin to allow updates
+    // For simplicity, we'll allow any editor in the tenant to update for now.
+    // More complex logic could check: if (currentDashboard.owner_id !== userId && res.locals.user.role !== 'admin') return res.status(403).json({ message: 'Forbidden: Only owner or admin can update' });
+
+    const updateFields: string[] = [];
+    const params: any[] = [];
+
+    if (name !== undefined) {
+      updateFields.push('name = ?');
+      params.push(name);
+    }
+    if (config !== undefined) {
+      updateFields.push('config = ?');
+      params.push(JSON.stringify(config));
+    }
+    updateFields.push('updated_at = ?');
+    params.push(now);
+
+    if (updateFields.length === 1) { // Only 'updated_at' was provided or no fields changed
+      return res.status(400).json({ message: 'No valid fields provided for update' });
+    }
+
+    // Corrected template literal for SQL query construction
+    const sql = `UPDATE dashboards SET ${updateFields.join(', ')} WHERE id = ? AND tenant_id = ?`;
+    params.push(id, tenantId);
+
+    execSql(sql, params);
+    res.status(200).json({ message: 'Dashboard updated successfully' });
+  } catch (error: any) {
+    console.error('Update dashboard error:', error);
+    res.status(500).json({ message: 'Failed to update dashboard', error: error.message });
+  }
+});
+
+// DELETE /dashboards/:id
+router.delete('/:id', (req: Request, res: Response) => {
+  if (!verifyUserAndTenant(req, res, 'admin')) return; // Requires admin role
+
+  const { id } = req.params;
+  const { tenantId } = res.locals.user;
+
+  try {
+    // Verify ownership or tenant association before deletion
+    const dashboard = getSql<DashboardRow>('SELECT id, tenant_id FROM dashboards WHERE id = ?', [id]);
+
+    if (!dashboard) {
+      return res.status(404).json({ message: 'Dashboard not found' });
+    }
+
+    if (dashboard.tenant_id !== tenantId) {
+      return res.status(403).json({ message: 'Forbidden: Dashboard does not belong to your tenant' });
+    }
+
+    execSql('DELETE FROM dashboards WHERE id = ? AND tenant_id = ?', [id, tenantId]);
+    res.status(200).json({ message: 'Dashboard deleted successfully' });
+  } catch (error: any) {
+    console.error('Delete dashboard error:', error);
+    res.status(500).json({ message: 'Failed to delete dashboard', error: error.message });
+  }
+});
+
+export default router;
