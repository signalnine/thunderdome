+import express, { Request, Response, Router } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getSql, execSql } from '../db';
+import { verifyToken } from '../middleware/auth';
+
+const router: Router = express.Router();
+
+// Interface for an event
+interface Event {
+  name: string;
+  properties?: Record<string, any>;
+  timestamp?: string;
+  userId?: string; // Optional: can be associated with a user/session
+  sessionId?: string; // Optional
+}
+
+// POST /events - Ingest a single event
+router.post('/', verifyToken, async (req: Request, res: Response) => {
+  const { name, properties, timestamp, userId, sessionId } = req.body as Event;
+  const tenantId = res.locals.user.tenantId;
+
+  if (!name) {
+    return res.status(400).json({ message: 'Event name is required' });
+  }
+
+  const eventId = uuidv4();
+  const eventTimestamp = timestamp || new Date().toISOString(); // Use provided timestamp or current time
+
+  try {
+    execSql(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)',
+      [eventId, tenantId, name, JSON.stringify(properties || {}), eventTimestamp, userId || null, sessionId || null]
+    );
+    res.status(201).json({ message: 'Event ingested successfully', eventId });
+  } catch (error: any) {
+    console.error('Event ingestion error:', error);
+    res.status(500).json({ message: 'Failed to ingest event', error: error.message });
+  }
+});
+
+// POST /events/batch - Ingest multiple events
+router.post('/batch', verifyToken, async (req: Request, res: Response) => {
+  const events = req.body as Event[];
+  const tenantId = res.locals.user.tenantId;
+
+  if (!Array.isArray(events) || events.length === 0) {
+    return res.status(400).json({ message: 'Batch must be a non-empty array of events' });
+  }
+
+  try {
+    // Correctly manage the transaction
+    execSql('BEGIN TRANSACTION'); // Start transaction
+
+    for (const event of events) {
+      const { name, properties, timestamp, userId, sessionId } = event;
+
+      if (!name) {
+        // Throwing an error will cause the catch block to execute for rollback
+        throw new Error('Event missing name');
+      }
+
+      const eventId = uuidv4();
+      const eventTimestamp = timestamp || new Date().toISOString();
+
+      execSql(
+        'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)',
+        [eventId, tenantId, name, JSON.stringify(properties || {}), eventTimestamp, userId || null, sessionId || null]
+      );
+    }
+    
+    execSql('COMMIT'); // Commit transaction if all events were inserted successfully
+    res.status(201).json({ message: `Batch ingestion successful: ${events.length} events ingested` });
+  } catch (error: any) {
+    execSql('ROLLBACK'); // Rollback transaction on error
+    console.error('Batch event ingestion error:', error);
+    res.status(500).json({ message: 'Failed to ingest event batch', error: error.message });
+  }
+});
+
+export default router;
