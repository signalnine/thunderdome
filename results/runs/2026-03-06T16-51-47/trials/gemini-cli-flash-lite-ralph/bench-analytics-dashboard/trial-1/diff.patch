+++ b/src/routes/queries.ts
@@ -0,0 +1,165 @@
+import express, { Request, Response, Router } from 'express';
+import { verifyToken } from '../middleware/auth';
+import { getSql } from '../db';
+
+const router: Router = express.Router();
+
+// Helper to build WHERE clauses and parameters for tenant isolation
+const buildTenantFilter = (tenantId: string, baseTableName: string = 'events') => {
+  return {
+    whereClause: `${baseTableName}.tenant_id = ?`,
+    params: [tenantId],
+  };
+};
+
+// Helper to build WHERE clause for event filters
+const buildEventFilterClause = (filters: any, tenantId: string) => {
+  let whereClauses: string[] = [buildTenantFilter(tenantId).whereClause];
+  let queryParams: any[] = [tenantId];
+
+  if (filters) {
+    if (filters.name) {
+      whereClauses.push('name = ?');
+      queryParams.push(filters.name);
+    }
+    if (filters.properties) {
+      // For property filtering, we need to handle JSON. This is a basic example.
+      // In a real-world scenario, you might use JSON_EXTRACT or similar SQLite functions.
+      // For simplicity here, we'll assume direct property matching if it's simple.
+      // A more robust solution might involve indexing JSON properties.
+      for (const key in filters.properties) {
+        whereClauses.push('json_extract(properties, ?)=?');
+        queryParams.push(`$.${key}`);
+        queryParams.push(filters.properties[key]);
+      }
+    }
+    if (filters.userId) {
+      whereClauses.push('user_id = ?');
+      queryParams.push(filters.userId);
+    }
+    if (filters.sessionId) {
+      whereClauses.push('session_id = ?');
+      queryParams.push(filters.sessionId);
+    }
+  }
+  return {
+    where: whereClauses.join(' AND '),
+    params: queryParams,
+  };
+};
+
+// POST /queries/count - Count events matching filters
+router.post('/count', verifyToken, async (req: Request, res: Response) => {
+  const { filters, dateRange } = req.body;
+  const tenantId = res.locals.user.tenantId;
+
+  try {
+    const { where, params } = buildEventFilterClause(filters, tenantId);
+    
+    // Add date range filtering if provided
+    let query = `SELECT COUNT(*) as count FROM events WHERE ${where}`;
+    let queryParams = [...params];
+
+    if (dateRange && dateRange.start && dateRange.end) {
+      query += ' AND timestamp BETWEEN ? AND ?';
+      queryParams.push(dateRange.start, dateRange.end);
+    }
+
+    const result = getSql(query, queryParams);
+    res.status(200).json(result[0]);
+  } catch (error: any) {
+    console.error('Count query error:', error);
+    res.status(500).json({ message: 'Failed to perform count query', error: error.message });
+  }
+});
+
+// POST /queries/timeseries - Time series bucketing
+router.post('/timeseries', verifyToken, async (req: Request, res: Response) => {
+  const { filters, dateRange, interval = 'day' } = req.body; // interval can be 'hour', 'day', 'week', 'month'
+  const tenantId = res.locals.user.tenantId;
+
+  if (!dateRange || !dateRange.start || !dateRange.end) {
+    return res.status(400).json({ message: 'Date range (start and end) is required for timeseries query' });
+  }
+
+  try {
+    const { where, params } = buildEventFilterClause(filters, tenantId);
+    
+    // SQLite date/time functions for bucketing
+    let timeBucketFunction: string;
+    switch (interval.toLowerCase()) {
+      case 'hour':
+        timeBucketFunction = "strftime('%Y-%m-%d %H:00:00', timestamp)";
+        break;
+      case 'week':
+        // Note: SQLite's strftime('%W') is week number of year, which might not be ideal.
+        // A better approach might be to calculate start of week based on date.
+        // For simplicity, let's use day of week + date, or just date for now.
+        // Let's stick to simpler intervals for now or use a common format.
+        // For week, we can group by the start of the week.
+        timeBucketFunction = "strftime('%Y-%m-%d', timestamp, 'weekday 0', '-6 days')"; // Start of week (Sunday as day 0)
+        break;
+      case 'month':
+        timeBucketFunction = "strftime('%Y-%m-01', timestamp)";
+        break;
+      case 'day':
+      default:
+        timeBucketFunction = "strftime('%Y-%m-%d', timestamp)";
+        break;
+    }
+
+    const query = `
+      SELECT ${timeBucketFunction} as time_bucket, COUNT(*) as count
+      FROM events
+      WHERE ${where} AND timestamp BETWEEN ? AND ?
+      GROUP BY time_bucket
+      ORDER BY time_bucket ASC
+    `;
+    const queryParams = [...params, dateRange.start, dateRange.end];
+
+    const results = getSql(query, queryParams);
+    res.status(200).json(results);
+  } catch (error: any) {
+    console.error('Timeseries query error:', error);
+    res.status(500).json({ message: 'Failed to perform timeseries query', error: error.message });
+  }
+});
+
+// POST /queries/breakdown - Breakdown by property
+router.post('/breakdown', verifyToken, async (req: Request, res: Response) => {
+  const { filters, dateRange, groupBy } = req.body;
+  const tenantId = res.locals.user.tenantId;
+
+  if (!groupBy) {
+    return res.status(400).json({ message: 'groupBy property is required for breakdown query' });
+  }
+
+  try {
+    const { where, params } = buildEventFilterClause(filters, tenantId);
+    
+    // For breakdown, we need to group by a property.
+    // SQLite's JSON_EXTRACT is used to get values from the properties JSON.
+    // It's important to ensure that the groupBy property exists in the JSON.
+    let query = `
+      SELECT json_extract(properties, ?) as ${groupBy}, COUNT(*) as count
+      FROM events
+      WHERE ${where}
+    `;
+    let queryParams = [`$.${groupBy}`, ...params];
+
+    if (dateRange && dateRange.start && dateRange.end) {
+      query += ' AND timestamp BETWEEN ? AND ?';
+      queryParams.push(dateRange.start, dateRange.end);
+    }
+    
+    query += ` GROUP BY ${groupBy} ORDER BY count DESC`; // Order by count descending
+
+    const results = getSql(query, queryParams);
+    res.status(200).json(results);
+  } catch (error: any) {
+    console.error('Breakdown query error:', error);
+    res.status(500).json({ message: 'Failed to perform breakdown query', error: error.message });
+  }
+});
+
+export default router;
