+import express, { Request, Response, Router } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import crypto from 'crypto'; // For password hashing
+import jwt from 'jsonwebtoken'; // For JWT
+import { getSql, execSql } from '../db'; // Assuming db.ts exports getSql and execSql
+import { UserRow } from '../db'; // Import UserRow interface
+
+const router: Router = express.Router();
+
+// Secret key for JWT - In a real app, this should be loaded from environment variables
+const JWT_SECRET = process.env.JWT_SECRET || 'supersecretkey'; // Use a strong, unique key in production
+
+// POST /register
+router.post('/register', async (req: Request, res: Response) => {
+  const { email, password, role = 'viewer' } = req.body;
+
+  if (!email || !password) {
+    return res.status(400).json({ message: 'Email and password are required' });
+  }
+
+  // Basic email format validation
+  if (!/\S+@\S+\.\S+/.test(email)) {
+    return res.status(400).json({ message: 'Invalid email format' });
+  }
+
+  // Check if email already exists
+  const existingUser = getSql<UserRow>('SELECT id FROM users WHERE email = ?', [email]);
+  if (existingUser) {
+    return res.status(409).json({ message: 'Email already registered' });
+  }
+
+  // Hash password (using Node.js crypto for simplicity; bcrypt is recommended for production)
+  const salt = crypto.randomBytes(16).toString('hex');
+  const passwordHash = crypto.pbkdf2Sync(password, salt, 1000, 64, 'sha512').toString('hex');
+
+  const tenantId = uuidv4(); // Generate a new tenant ID for each new user/tenant
+  const userId = uuidv4();
+
+  try {
+    execSql(
+      'INSERT INTO users (id, email, password_hash, salt, tenant_id, role) VALUES (?, ?, ?, ?, ?, ?)',
+      [userId, email, passwordHash, salt, tenantId, role]
+    );
+    res.status(201).json({ message: 'User registered successfully', userId, tenantId, role });
+  } catch (error: any) {
+    console.error('Registration error:', error);
+    res.status(500).json({ message: 'Failed to register user', error: error.message });
+  }
+});
+
+// POST /login
+router.post('/login', async (req: Request, res: Response) => {
+  const { email, password } = req.body;
+
+  if (!email || !password) {
+    return res.status(400).json({ message: 'Email and password are required' });
+  }
+
+  try {
+    // Fetch all user details, including salt, in a single query
+    // Using UserRow type for type safety
+    const user = getSql<UserRow>('SELECT * FROM users WHERE email = ?', [email]);
+    console.log('User object retrieved in login:', JSON.stringify(user, null, 2)); // Added logging
+    console.log('Type of user.salt:', typeof user?.salt); // Added more specific logging
+    console.log('Is user.salt an empty string?', user?.salt === ''); // Added more specific logging
+    console.log('Is user.salt null?', user?.salt === null); // Added more specific logging
+    console.log('Is user.salt undefined?', user?.salt === undefined); // Added more specific logging
+
+    if (!user) {
+      // User not found
+      return res.status(401).json({ message: 'Invalid credentials' });
+    }
+
+    // Ensure salt is available as per schema.sql NOT NULL constraint.
+    // If it's somehow missing/invalid, it indicates a deeper data integrity issue.
+    // Changed check to be more explicit about string type and non-empty.
+    if (typeof user.salt !== 'string' || user.salt.length === 0) {
+      console.error(`Login failed for user ${email}: salt is missing or invalid in the database.`);
+      // Returning 500 for internal server error due to data inconsistency
+      return res.status(500).json({ message: 'Internal server error: user data integrity issue' });
+    }
+
+    const hashedPassword = crypto.pbkdf2Sync(password, user.salt, 1000, 64, 'sha512').toString('hex');
+
+    if (hashedPassword !== user.password_hash) {
+      // Password mismatch
+      return res.status(401).json({ message: 'Invalid credentials' });
+    }
+
+    // Generate JWT token with relevant user claims
+    const token = jwt.sign(
+      { userId: user.id, tenantId: user.tenant_id, role: user.role },
+      JWT_SECRET,
+      { expiresIn: '1h' } // Token expires in 1 hour
+    );
+
+    // Return token and essential user info
+    res.status(200).json({ message: 'Login successful', token, userId: user.id, tenantId: user.tenant_id, role: user.role });
+
+  } catch (error: any) {
+    console.error('Login error:', error);
+    res.status(500).json({ message: 'Failed to login', error: error.message });
+  }
+});
+
+// GET /profile
+router.get('/profile', async (req: Request, res: Response) => {
+  // Authentication middleware will attach user info to res.locals.user
+  const user = res.locals.user;
+
+  if (!user) {
+    // This should ideally not happen if auth middleware is correctly implemented
+    return res.status(401).json({ message: 'Unauthorized' });
+  }
+
+  try {
+    // Fetch user details excluding sensitive info like password hash and salt
+    const userProfile = getSql<UserRow>(
+      'SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?',
+      [user.userId]
+    );
+
+    if (!userProfile) {
+      return res.status(404).json({ message: 'User not found' });
+    }
+
+    res.status(200).json(userProfile);
+  } catch (error: any) {
+    console.error('Profile retrieval error:', error);
+    res.status(500).json({ message: 'Failed to retrieve user profile', error: error.message });
+  }
+});
+
+export default router;
