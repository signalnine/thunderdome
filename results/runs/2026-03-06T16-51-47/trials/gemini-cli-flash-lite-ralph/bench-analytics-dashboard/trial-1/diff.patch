+import { Request, Response, NextFunction } from 'express';
+import jwt from 'jsonwebtoken';
+
+// Secret key for JWT - Should match the one used in auth.ts
+const JWT_SECRET = process.env.JWT_SECRET || 'supersecretkey'; // Use a strong, unique key in production
+
+interface DecodedUser {
+  userId: string;
+  tenantId: string;
+  role: string;
+}
+
+export const verifyToken = (req: Request, res: Response, next: NextFunction) => {
+  const authHeader = req.headers['authorization'];
+  const token = authHeader && authHeader.split(' ')[1]; // Bearer TOKEN
+
+  if (token == null) {
+    return res.status(401).json({ message: 'Unauthorized: No token provided' }); // No token found
+  }
+
+  jwt.verify(token, JWT_SECRET, (err: any, decoded: any) => {
+    if (err) {
+      console.error('JWT Verification Error:', err.message);
+      return res.status(403).json({ message: 'Unauthorized: Invalid token' }); // Invalid token
+    }
+    
+    // Attach decoded user info to the request object
+    res.locals.user = decoded as DecodedUser;
+    next();
+  });
+};
