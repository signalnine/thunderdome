+++ b/src/routes/users.ts
@@ -0,0 +1,139 @@
+import express, { Request, Response, Router } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import jwt from 'jsonwebtoken'; // For JWT
+import { getSql, runSql, execSql } from '../db'; // Assuming db.ts exports getSql, runSql, and execSql
+import { UserRow } from '../db'; // Import UserRow interface
+
+const router: Router = express.Router();
+
+// Secret key for JWT - In a real app, this should be loaded from environment variables
+const JWT_SECRET = process.env.JWT_SECRET || 'supersecretkey'; // Use a strong, unique key in production
+
+// Helper to verify JWT and tenant
+const verifyUserAndTenant = (req: Request, res: Response, requiredRole?: 'admin' | 'editor' | 'viewer'): boolean => {
+  const authHeader = req.headers.authorization;
+  const token = authHeader && authHeader.split(' ')[1];
+
+  if (!token) {
+    res.status(401).json({ message: 'Unauthorized: No token provided' });
+    return false; // Explicitly return false on failure
+  }
+
+  try {
+    const decoded = jwt.verify(token, JWT_SECRET) as { userId: string; tenantId: string; role: string };
+    const user = getSql<UserRow>('SELECT id, tenant_id, role FROM users WHERE id = ?', [decoded.userId]);
+
+    if (!user) {
+      res.status(401).json({ message: 'Unauthorized: User not found' });
+      return false;
+    }
+
+    if (user.tenant_id !== decoded.tenantId) {
+      res.status(403).json({ message: 'Forbidden: Tenant mismatch' });
+      return false;
+    }
+
+    if (requiredRole && !hasRole(user.role, requiredRole)) {
+        // Corrected template literal syntax for the error message
+        res.status(403).json({ message: `Forbidden: Required role '${requiredRole}' not met` });
+        return false;
+    }
+
+    // Attach user info to response locals for subsequent middleware/route handlers
+    res.locals.user = { userId: user.id, tenantId: user.tenant_id, role: user.role };
+    return true; // User is authenticated and authorized
+
+  } catch (error: any) {
+    console.error('JWT Verification Error:', error);
+    if (error.name === 'TokenExpiredError') {
+      res.status(401).json({ message: 'Unauthorized: Token expired' });
+    } else if (error.name === 'JsonWebTokenError') {
+      res.status(401).json({ message: 'Unauthorized: jwt malformed' });
+    } else {
+      res.status(401).json({ message: 'Unauthorized' });
+    }
+    return false;
+  }
+};
+
+const hasRole = (userRole: string, requiredRole: string): boolean => {
+    const roles = ['admin', 'editor', 'viewer'];
+    const userRoleIndex = roles.indexOf(userRole);
+    const requiredRoleIndex = roles.indexOf(requiredRole);
+    return userRoleIndex !== -1 && requiredRoleIndex !== -1 && userRoleIndex <= requiredRoleIndex;
+};
+
+// GET /users/profile (Authenticated user can view their own profile)
+router.get('/profile', (req: Request, res: Response) => {
+  if (!verifyUserAndTenant(req, res, 'viewer')) return; // Requires viewer role or above
+
+  const { userId, tenantId } = res.locals.user;
+
+  try {
+    // Fetch user profile, excluding sensitive fields like password_hash and salt
+    const userProfile = getSql<UserRow>('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ? AND tenant_id = ?', [userId, tenantId]);
+
+    if (!userProfile) {
+      return res.status(404).json({ message: 'User profile not found' });
+    }
+
+    res.status(200).json(userProfile);
+  } catch (error: any) {
+    console.error('Get user profile error:', error);
+    res.status(500).json({ message: 'Failed to retrieve user profile', error: error.message });
+  }
+});
+
+// GET /users (Admin can view all users in their tenant)
+router.get('/', (req: Request, res: Response) => {
+  if (!verifyUserAndTenant(req, res, 'admin')) return; // Requires admin role
+
+  const { tenantId } = res.locals.user;
+
+  try {
+    const users = runSql<UserRow[]>('SELECT id, email, tenant_id, role, created_at FROM users WHERE tenant_id = ?', [tenantId]);
+    res.status(200).json(users);
+  } catch (error: any) {
+    console.error('Get all users error:', error);
+    res.status(500).json({ message: 'Failed to retrieve users', error: error.message });
+  }
+});
+
+// PUT /users/:id (Admin can change user roles within their tenant)
+router.put('/:id', (req: Request, res: Response) => {
+  if (!verifyUserAndTenant(req, res, 'admin')) return; // Requires admin role
+
+  const { id } = req.params;
+  const { tenantId } = res.locals.user;
+  const { role } = req.body;
+
+  if (!role || !['admin', 'editor', 'viewer'].includes(role)) {
+    return res.status(400).json({ message: 'Invalid role provided. Must be one of: admin, editor, viewer.' });
+  }
+
+  try {
+    // Check if the target user exists and belongs to the same tenant
+    const targetUser = getSql<UserRow>('SELECT id, tenant_id, role FROM users WHERE id = ?', [id]);
+
+    if (!targetUser) {
+      return res.status(404).json({ message: 'User not found' });
+    }
+
+    if (targetUser.tenant_id !== tenantId) {
+      return res.status(403).json({ message: 'Forbidden: User does not belong to your tenant' });
+    }
+
+    // Prevent self-demotion if the current user is an admin modifying themselves
+    // This logic could be more robust (e.g., check if current user is the same as target user)
+    // For simplicity, we allow admins to change roles, assuming they know what they are doing.
+    // A more refined check could be: if (id === res.locals.user.userId && role !== 'admin') return res.status(400).json({ message: 'Cannot demote yourself from admin.' });
+
+    execSql('UPDATE users SET role = ? WHERE id = ? AND tenant_id = ?', [role, id, tenantId]);
+    res.status(200).json({ message: 'User role updated successfully' });
+  } catch (error: any) {
+    console.error('Update user role error:', error);
+    res.status(500).json({ message: 'Failed to update user role', error: error.message });
+  }
+});
+
+export default router;
