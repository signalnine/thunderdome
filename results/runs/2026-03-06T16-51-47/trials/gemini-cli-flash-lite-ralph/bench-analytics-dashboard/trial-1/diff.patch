@@ -0,0 +1,56 @@
+import express, { Express } from 'express';
+import cors from 'cors'; // For handling Cross-Origin Resource Sharing
+import helmet from 'helmet'; // For setting various HTTP headers for security
+import morgan from 'morgan'; // For HTTP request logging
+import { initializeDatabase } from './db';
+
+import authRoutes from './routes/auth';
+import userRoutes from './routes/users';
+import eventRoutes from './routes/events'; // Import event routes
+import queryRoutes from './routes/queries'; // Import query routes
+import dashboardRoutes from './routes/dashboards'; // Import dashboard routes
+import exportRoutes from './routes/export'; // Import export routes
+
+export const createApp = (): Express => {
+  const app: Express = express();
+
+  // Initialize database
+  try {
+    initializeDatabase();
+    console.log('Database initialized.');
+  } catch (error) {
+    console.error('Failed to initialize database:', error);
+    process.exit(1);
+  }
+
+  // Middleware
+  app.use(cors());
+  app.use(helmet());
+  app.use(morgan('dev'));
+  app.use(express.json());
+  app.use(express.urlencoded({ extended: true }));
+
+  // Routes
+  app.use('/api/auth', authRoutes);
+  app.use('/api/users', userRoutes);
+  app.use('/api/events', eventRoutes); // Mount event routes
+  app.use('/api/queries', queryRoutes); // Mount query routes
+  app.use('/api/dashboards', dashboardRoutes); // Mount dashboard routes
+  app.use('/api/export', exportRoutes); // Mount export routes
+
+  // Health check route
+  app.get('/health', (req, res) => {
+    res.status(200).json({ status: 'OK', timestamp: new Date().toISOString() });
+  });
+
+  // Global error handler
+  app.use((err: any, req: express.Request, res: express.Response, next: express.NextFunction) => {
+    console.error('Unhandled error:', err.stack);
+    res.status(err.status || 500).json({
+      message: err.message || 'Internal Server Error',
+      error: process.env.NODE_ENV === 'development' ? err : {},
+    });
+  });
+
+  return app;
+};
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..58efe7a
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,118 @@
+import Database, { Statement } from 'better-dist';
+import fs from 'fs';
+import path from 'path';
+
+const DB_PATH = process.env.DB_PATH || ':memory:'; // Use in-memory DB by default, or from env var
+
+// Ensure the directory for the database exists if it's a file path
+if (DB_PATH !== ':memory:') {
+  const dbDir = path.dirname(DB_PATH);
+  if (!fs.existsSync(dbDir)) {
+    fs.mkdirSync(dbDir, { recursive: true });
+  }
+}
+
+// Explicitly type the db variable using the Database class from better-sqlite3
+const db = new Database(DB_PATH) as Database.Database;
+
+// Interface for User row returned by database queries
+export interface UserRow {
+  id: string;
+  email: string;
+  password_hash: string;
+  salt: string | null | undefined; // Allow null/undefined for salt, despite schema NOT NULL
+  tenant_id: string;
+  role: 'admin' | 'viewer' | 'editor';
+  created_at: string;
+}
+
+// Interface for Dashboard row
+export interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string; // Stored as JSON string
+  created_at: string;
+  updated_at: string;
+}
+
+// Interface for Event row (simplified for export)
+export interface ExportEventRow {
+  id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id?: string | null;
+  session_id?: string | null;
+}
+
+// Interface for Dashboard row (simplified for export)
+export interface ExportDashboardRow {
+  id: string;
+  name: string;
+  owner_id: string;
+  config: string; // JSON string
+  created_at: string;
+  updated_at: string;
+}
+
+
+// Function to execute SQL from schema.sql
+export const initializeDatabase = () => {
+  const schemaSql = fs.readFileSync(path.join(__dirname, '../schema.sql'), 'utf-8');
+  db.exec(schemaSql);
+  console.log('Database initialized successfully.');
+};
+
+// Function to execute raw SQL statements
+export const runSql = <T = any>(sql: string, params: any[] = []): T[] => {
+  // Use better-sqlite3's Statement type for preparing and running SQL
+  const stmt = db.prepare(sql) as any; // Cast to any to avoid TS2702, if it persists
+  return stmt.all(params) as T[];
+};
+
+// Function to get a single row
+export const getSql = <T = any>(sql: string, params: any[] = []): T | undefined => {
+  const stmt = db.prepare(sql) as any; // Cast to any to avoid TS2702, if it persists
+  const row = stmt.get(params);
+
+  if (!row) {
+    return undefined;
+  }
+
+  // Process the row to ensure string properties are strings and not null/undefined,
+  // especially for 'salt' which is expected to be a string in UserRow.
+  const processedRow: any = {};
+  for (const key in row) {
+    const value = row[key];
+    // If the property is expected to be a string (like salt, password_hash, id, etc.)
+    // and it comes back as null or undefined, default it to an empty string.
+    // This assumes that for 'string' typed properties in T, null/undefined should be treated as empty string.
+    if (typeof value === 'string') {
+      processedRow[key] = value;
+    } else if (value === null || value === undefined) {
+      // Default null/undefined to empty string for string-like properties.
+      // This is a workaround for cases where DB might return null/undefined for NOT NULL columns
+      // or if the driver behaves unexpectedly.
+      processedRow[key] = '';
+    } else {
+      processedRow[key] = value;
+    }
+  }
+  // Explicitly ensure salt is a string. If it was null/undefined, it's now ''.
+  if (typeof processedRow.salt !== 'string') {
+    processedRow.salt = '';
+  }
+
+  return processedRow as T;
+};
+
+// Function to run an insert/update/delete and return the last inserted row ID or count
+export const execSql = (sql: string, params: any[] = []) => {
+  const stmt = db.prepare(sql) as any; // Cast to any to avoid TS2702, if it persists
+  const result = stmt.run(params);
+  return result;
+};
+
+export default db;
