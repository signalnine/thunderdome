+
+      // Advance time to make retried tasks available
+      vi.advanceTimersByTime(300); // Enough to pass the first retry delay (base 100 * 2^1 = 200ms)
+
+      // Process tasks - should get the non-retried high priority first, then the retried high priority
+      let processedTask = queue.processTask();
+      expect(processedTask?.id).toBe(taskHighPrio.id);
+
+      processedTask = queue.processTask();
+      expect(processedTask?.id).toBe(taskHighPrioToRetry.id); // Retried high priority, should come after original high priority
+
+      // Then the low priority non-retried, then the retried low priority
+      processedTask = queue.processTask();
+      expect(processedTask?.id).toBe(taskLowPrio.id);
+
+      processedTask = queue.processTask();
+      expect(processedTask?.id).toBe(taskLowPrioToRetry.id);
+
+      expect(queue.processTask()).toBeUndefined();
+    });
+  });
+
+  // New tests for dead letter queue (DLQ)
+  describe('dead letter queue (DLQ)', () => {
+    beforeEach(() => {
+      vi.useFakeTimers(); // Use fake timers for time-related tests
+    });
+
+    afterEach(() => {
+      vi.useRealTimers(); // Restore real timers after each test
+    });
+
+    it('should move a task to the DLQ when max retries are exhausted', () => {
+      // Task with maxRetries = 1, backoffFactor = 2.
+      // It will be retried once (retryCount becomes 1).
+      // The next retry call should move it to DLQ.
+      const task = queue.addTask({ job: 'process' }, Infinity, 0, 1, 2);
+      const taskId = task.id;
+
+      // First failure
+      queue.failTask(taskId);
+      queue.retryTask(taskId); // retryCount becomes 1, runAt is scheduled
+
+      // Advance time to make the retry available
+      vi.advanceTimersByTime(200); // Delay for retry 1 (100ms * 2^1)
+      queue.processTask(); // Process the first retry
+
+      // Simulate second failure
+      queue.failTask(taskId); // Task is now in failed state
+
+      // Call retryTask for the second time - should exceed maxRetries (1)
+      // retryCount will be 1, maxRetries is 1. retryCount >= maxRetries is true.
+      const finalRetry = queue.retryTask(taskId);
+      expect(finalRetry).toBeDefined();
+      expect(finalRetry?.status).toBe('failed'); // Status should be 'failed'
+      expect(finalRetry?.retryCount).toBe(1); // retryCount remains 1 as it failed before incrementing for next retry
+      expect(queue.getQueueSize()).toBe(0); // Task removed from main queue
+
+      // Check DLQ
+      const dlqTasks = queue.getDeadLetterQueue();
+      expect(dlqTasks.length).toBe(1);
+      expect(dlqTasks[0].id).toBe(taskId);
+      expect(dlqTasks[0].status).toBe('failed'); // Task in DLQ should have status 'failed'
+      expect(dlqTasks[0].retryCount).toBe(1); // The retryCount at the point it was moved
+    });
+
+    it('should not move task to DLQ if failTask is called directly', () => {
+      const task = queue.addTask({ job: 'process' }, Infinity, 0, 1, 2);
+      const taskId = task.id;
+
+      queue.failTask(taskId); // Task status is 'failed', but not in DLQ yet.
+      expect(queue.getQueueSize()).toBe(0); // Removed from main queue
+      expect(queue.getDeadLetterQueue().length).toBe(0); // Not in DLQ
+      expect(queue.getTasks().find(t => t.id === taskId)).toBeUndefined(); // Not in main queue
+
+      // Attempt to retry a task that was only failed, not retried
+      const retryAttempt = queue.retryTask(taskId);
+      // retryTask requires the task to be in the main queue to find it.
+      // Since failTask removed it, retryTask will return undefined.
+      expect(retryAttempt).toBeUndefined();
+
+      // To properly test DLQ via retry, we need the retryTask call to succeed.
+      // The current test setup correctly reflects that failTask itself doesn't trigger DLQ.
+      // The DLQ entry happens when retryTask detects max retries are exceeded.
+    });
+
+    it('should correctly store multiple tasks in DLQ', () => {
+      // Task 1: maxRetries=1, will go to DLQ
+      const task1 = queue.addTask({ job: 'job1' }, Infinity, 0, 1, 2);
+      queue.failTask(task1.id);
+      queue.retryTask(task1.id); // Schedule first retry
+      vi.advanceTimersByTime(200);
+      queue.processTask(); // Process first retry
+      queue.failTask(task1.id); // Fail again
+      queue.retryTask(task1.id); // This call should move it to DLQ
+
+      // Task 2: maxRetries=0, should go to DLQ on first fail
+      const task2 = queue.addTask({ job: 'job2' }, Infinity, 0, 0, 2);
+      queue.failTask(task2.id); // Fail first time
+      // No retryTask call, but failTask itself does NOT move to DLQ in current implementation.
+      // DLQ is for *exceeding retries*. So task2 should not be in DLQ yet by failTask alone.
+
+      // Let's refine the test based on retryTask's DLQ logic
+      queue = new Queue(); // Reset queue
+      const taskDLQ1 = queue.addTask({ job: 'DLQ1' }, Infinity, 0, 1, 2);
+      queue.failTask(taskDLQ1.id);
+      queue.retryTask(taskDLQ1.id); // First retry scheduled
+      vi.advanceTimersByTime(200);
+      queue.processTask(); // Process first retry
+      queue.failTask(taskDLQ1.id); // Fail for the last time
+      queue.retryTask(taskDLQ1.id); // This should move it to DLQ
+
+      const taskDLQ2 = queue.addTask({ job: 'DLQ2' }, Infinity, 0, 0, 2); // maxRetries=0
+      queue.failTask(taskDLQ2.id); // Fail for the first and only time (maxRetries=0 means no retries)
+      // retryTask needs to be called to hit the DLQ logic.
+      // If maxRetries is 0, retryTask should check retryCount (0) >= maxRetries (0), which is true.
+      // Let's test this case in the 'max retries reached' test.
+      // For now, let's assume tasks are only added to DLQ via retryTask logic.
+
+      // Test with two tasks that correctly exhaust retries
+      queue = new Queue();
+      const taskA = queue.addTask({ job: 'A' }, Infinity, 0, 1, 2);
+      queue.failTask(taskA.id);
+      queue.retryTask(taskA.id); // Retry 1 scheduled
+      vi.advanceTimersByTime(200);
+      queue.processTask(); // Process retry 1
+      queue.failTask(taskA.id); // Fail again
+      queue.retryTask(taskA.id); // Should move to DLQ
+
+      const taskB = queue.addTask({ job: 'B' }, Infinity, 0, 1, 2);
+      queue.failTask(taskB.id);
+      queue.retryTask(taskB.id); // Retry 1 scheduled
+      vi.advanceTimersByTime(200);
+      queue.processTask(); // Process retry 1
+      queue.failTask(taskB.id); // Fail again
+      queue.retryTask(taskB.id); // Should move to DLQ
+
+      expect(queue.getQueueSize()).toBe(0); // Both tasks removed from main queue
+      const dlqTasks = queue.getDeadLetterQueue();
+      expect(dlqTasks.length).toBe(2);
+      expect(dlqTasks.some(t => t.id === taskA.id)).toBe(true);
+      expect(dlqTasks.some(t => t.id === taskB.id)).toBe(true);
+    });
+
+    it('should not move tasks to DLQ if retryTask is called with invalid ID', () => {
+      queue.retryTask('invalid-id');
+      expect(queue.getQueueSize()).toBe(0);
+      expect(queue.getDeadLetterQueue().length).toBe(0);
+    });
+
+    it('should handle tasks with maxRetries = 0 correctly', () => {
+      // A task with maxRetries = 0 should go to DLQ on the first failure.
+      const task = queue.addTask({ job: 'process' }, Infinity, 0, 0, 2);
+      const taskId = task.id;
+
+      queue.failTask(taskId); // Mark as failed
+      expect(queue.getQueueSize()).toBe(0); // Removed from main queue
+      expect(queue.getDeadLetterQueue().length).toBe(0); // Not yet in DLQ
+
+      // Call retryTask. Since retryCount (0) >= maxRetries (0), it should move to DLQ.
+      const finalRetry = queue.retryTask(taskId);
+      expect(finalRetry).toBeDefined();
+      expect(finalRetry?.status).toBe('failed');
+      expect(finalRetry?.retryCount).toBe(0); // retryCount stays 0
+
+      expect(queue.getQueueSize()).toBe(0);
+      const dlqTasks = queue.getDeadLetterQueue();
+      expect(dlqTasks.length).toBe(1);
+      expect(dlqTasks[0].id).toBe(taskId);
+      expect(dlqTasks[0].status).toBe('failed');
+    });
+
+    it('should not process tasks that have been moved to the DLQ', () => {
+      // Add a task, fail it, and move it to DLQ
+      const task = queue.addTask({ job: 'process' }, Infinity, 0, 1, 2);
+      const taskId = task.id;
+      queue.failTask(taskId);
+      queue.retryTask(taskId); // Schedule retry 1
+      vi.advanceTimersByTime(200);
+      queue.processTask(); // Process retry 1
+      queue.failTask(taskId); // Fail again
+      queue.retryTask(taskId); // Move to DLQ
+
+      // Now, try to process tasks. It should return undefined as main queue is empty.
+      expect(queue.processTask()).toBeUndefined();
+      // Manually check DLQ tasks are not processed.
+      expect(queue.getDeadLetterQueue().length).toBe(1);
+    });
+  });
+});
