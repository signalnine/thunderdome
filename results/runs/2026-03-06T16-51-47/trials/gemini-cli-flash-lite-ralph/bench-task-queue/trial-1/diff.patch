@@ -0,0 +1,19 @@
+import { Queue, Task } from './queue';
+
+export class QueueManager {
+  private queues: Map<string, Queue> = new Map();
+
+  constructor() {}
+
+  getQueue(name: string): Queue {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, new Queue());
+    }
+    return this.queues.get(name)!;
+  }
+
+  addTaskToQueue(queueName: string, taskData: any, priority: number = Infinity, delayMs: number = 0, maxRetries: number = 3, backoffFactor: number = 2, dependencies: string[] = []): Task {
+    const queue = this.getQueue(queueName);
+    return queue.addTask(taskData, priority, delayMs, maxRetries, backoffFactor, dependencies);
+  }
+}
