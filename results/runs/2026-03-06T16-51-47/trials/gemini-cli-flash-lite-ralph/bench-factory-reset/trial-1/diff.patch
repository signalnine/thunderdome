+// Helper function for modular inverse (since modulus is prime)
+function modInverse(a: number, m: number): number {
+  a %= m;
+  for (let x = 1; x < m; x++) {
+    if ((a * x) % m === 1) {
+      return x;
+    }
+  }
+  // This case should ideally not be reached if 'm' is prime and 'a' is not 0 (mod m)
+  throw new Error("No modular inverse exists");
+}
+
+// Helper function to compare arrays lexicographically
+function compareLexicographically(arr1: number[], arr2: number[]): number {
+  const len = Math.min(arr1.length, arr2.length);
+  for (let i = 0; i < len; i++) {
+    if (arr1[i] < arr2[i]) return -1;
+    if (arr1[i] > arr2[i]) return 1;
+  }
+  return arr1.length - arr2.length;
+}
+
+interface Machine {
+  target: boolean[];     // desired state for each light (all start off)
+  buttons: number[][];   // buttons[i] = array of light indices toggled by button i
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const numLights = machine.target.length;
+  const numButtons = machine.buttons.length;
+
+  if (numLights === 0) {
+    return [];
+  }
+  if (numButtons === 0) {
+    for (const lightState of machine.target) {
+      if (lightState) {
+        return null;
+      }
+    }
+    return [];
+  }
+
+  // Construct augmented matrix
+  // Dimensions: numLights x (numButtons + 1)
+  const matrix: number[][] = Array(numLights).fill(0).map(() => Array(numButtons + 1).fill(0));
+
+  for (let i = 0; i < numLights; i++) {
+    for (let j = 0; j < numButtons; j++) {
+      if (machine.buttons[j].includes(i)) {
+        matrix[i][j] = 1; // Button j affects light i
+      }
+    }
+    matrix[i][numButtons] = machine.target[i] ? 1 : 0; // Target state for light i
+  }
+
+  // Gaussian elimination to Reduced Row Echelon Form
+  let rank = 0;
+  for (let r = 0; r < numLights && rank < numButtons; r++) {
+    let pivotRow = r;
+    while (pivotRow < numLights && matrix[pivotRow][rank] === 0) {
+      pivotRow++;
+    }
+
+    if (pivotRow < numLights) {
+      // Swap rows r and pivotRow
+      [matrix[r], matrix[pivotRow]] = [matrix[pivotRow], matrix[r]];
+
+      // Eliminate other 1s in the current column (reduce to RREF)
+      for (let k = 0; k < numLights; k++) {
+        if (k !== r && matrix[k][rank] === 1) { // If there's a 1 in this column and row
+          for (let j = rank; j <= numButtons; j++) { // XOR the entire row
+            matrix[k][j] = (matrix[k][j] + matrix[r][j]) % 2;
+          }
+        }
+      }
+      rank++;
+    }
+  }
+
+  // Check for inconsistencies (rows like [0, 0, ..., 0, 1])
+  for (let i = 0; i < numLights; i++) {
+    let allZerosInCoeffs = true;
+    for (let j = 0; j < numButtons; j++) {
+      if (matrix[i][j] !== 0) {
+        allZerosInCoeffs = false;
+        break;
+      }
+    }
+    if (allZerosInCoeffs && matrix[i][numButtons] === 1) {
+      return null; // Inconsistent system
+    }
+  }
+
+  // Identify pivot columns (dependent variables) and free variables
+  const pivotCols: number[] = [];
+  const freeVars: number[] = [];
+  let currentRowForPivot = 0;
+  for (let col = 0; col < numButtons; col++) {
+    if (currentRowForPivot < numLights && matrix[currentRowForPivot][col] === 1) {
+      pivotCols.push(col);
+      currentRowForPivot++;
+    } else {
+      freeVars.push(col);
+    }
+  }
+
+  let minPresses = Infinity;
+  let bestSolution: number[] | null = null;
+
+  // Iterate over all combinations of free variables
+  // (1 << freeVars.length) calculates 2^freeVars.length
+  for (let i = 0; i < (1 << freeVars.length); i++) {
+    const currentAssignment = Array(numButtons).fill(0);
+
+    // Assign values to free variables based on current combination 'i'
+    for (let j = 0; j < freeVars.length; j++) {
+      if ((i >> j) & 1) {
+        currentAssignment[freeVars[j]] = 1;
+      }
+    }
+
+    // Solve for dependent variables using the current assignment of free variables
+    for (let r = numLights - 1; r >= 0; r--) {
+      let pivotCol = -1;
+      for (let c = 0; c < numButtons; c++) {
+        if (matrix[r][c] === 1) {
+          pivotCol = c;
+          break;
+        }
+      }
+
+      if (pivotCol !== -1 && !freeVars.includes(pivotCol)) {
+        let sum = 0;
+        for (let c = 0; c < numButtons; c++) {
+          if (c !== pivotCol) {
+            sum = (sum + matrix[r][c] * currentAssignment[c]) % 2;
+          }
+        }
+        currentAssignment[pivotCol] = (matrix[r][numButtons] + sum) % 2;
+      }
+    }
+
+    // Verify the solution against the original system
+    let isValidSolution = true;
+    for (let row = 0; row < numLights; row++) {
+        let actualLightState = 0;
+        for (let col = 0; col < numButtons; col++) {
+            let originalCoeff = 0;
+            if (machine.buttons[col].includes(row)) {
+                originalCoeff = 1;
+            }
+            actualLightState = (actualLightState + originalCoeff * currentAssignment[col]) % 2;
+        }
+        if (actualLightState !== (machine.target[row] ? 1 : 0)) {
+            isValidSolution = false;
+            break;
+        }
+    }
+
+    if (!isValidSolution) {
+        continue;
+    }
+
+    // Calculate presses and check if it's better
+    let currentPresses = 0;
+    const pressedButtons: number[] = [];
+    for (let j = 0; j < numButtons; j++) {
+      if (currentAssignment[j] === 1) {
+        currentPresses++;
+        pressedButtons.push(j);
+      }
+    }
+
+    if (currentPresses < minPresses) {
+      minPresses = currentPresses;
+      bestSolution = pressedButtons;
+    } else if (currentPresses === minPresses) {
+      // Tie-breaking: lexicographically smallest
+      if (bestSolution === null || compareLexicographically(pressedButtons, bestSolution) < 0) {
+        bestSolution = pressedButtons;
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+export function solveCounter(
+  lights: number[],      // target counter values (each 0..modulus-1)
+  buttons: number[][],   // buttons[i] = indices of counters affected
+  modulus: number        // counters wrap at this value (always prime)
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  if (numLights === 0) {
+    return Array(numButtons).fill(0); // No lights, any presses are valid, 0 presses is min.
+  }
+  if (numButtons === 0) {
+    for (const lightTarget of lights) {
+      if (lightTarget !== 0) {
+        return null; // Lights have non-zero target but no buttons to change them
+      }
+    }
+    return []; // All lights are 0, no buttons needed
+  }
+
+  // Construct augmented matrix
+  // Dimensions: numLights x (numButtons + 1)
+  const matrix: number[][] = Array(numLights).fill(0).map(() => Array(numButtons + 1).fill(0));
+
+  for (let i = 0; i < numLights; i++) {
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        matrix[i][j] = (matrix[i][j] + 1) % modulus; // Button j affects light i, increment count
+      }
+    }
+    matrix[i][numButtons] = lights[i]; // Target state for light i
+  }
+
+  // Gaussian elimination to Reduced Row Echelon Form
+  let lead = 0;
+  for (let r = 0; r < numLights && lead < numButtons; r++) {
+    let i = r;
+    while (i < numLights && matrix[i][lead] === 0) {
+      i++;
+    }
+
+    if (i < numLights) {
+      // Swap rows r and i
+      [matrix[r], matrix[i]] = [matrix[i], matrix[r]];
+
+      // Make leading entry 1 (by multiplying by inverse)
+      const inv = modInverse(matrix[r][lead], modulus);
+      for (let j = lead; j <= numButtons; j++) {
+        matrix[r][j] = (matrix[r][j] * inv) % modulus;
+      }
+
+      // Eliminate elements above and below the leading 1 (RREF)
+      for (let k = 0; k < numLights; k++) {
+        if (k !== r) {
+          const factor = matrix[k][lead];
+          for (let j = lead; j <= numButtons; j++) {
+            matrix[k][j] = (matrix[k][j] - factor * matrix[r][j] % modulus + modulus) % modulus;
+          }
+        }
+      }
+      lead++;
+    }
+  }
+
+  // Check for inconsistencies (rows like [0, 0, ..., 0, non-zero])
+  for (let i = 0; i < numLights; i++) {
+    let allZerosInCoeffs = true;
+    for (let j = 0; j < numButtons; j++) {
+      if (matrix[i][j] !== 0) {
+        allZerosInCoeffs = false;
+        break;
+      }
+    }
+    if (allZerosInCoeffs && matrix[i][numButtons] !== 0) {
+      return null; // Inconsistent system
+    }
+  }
+
+  // Identify pivot columns (dependent variables) and free variables
+  const pivotCols: number[] = [];
+  const freeVars: number[] = [];
+  let currentRowForPivot = 0;
+  for (let col = 0; col < numButtons; col++) {
+    if (currentRowForPivot < numLights && matrix[currentRowForPivot][col] === 1) {
+      pivotCols.push(col);
+      currentRowForPivot++;
+    } else {
+      freeVars.push(col);
+    }
+  }
+
+  let minTotalPresses = Infinity;
+  let bestSolution: number[] | null = null;
+
+  const freeVarAssignments = Array(freeVars.length).fill(0);
+
+  // Recursive function to generate combinations for free variables
+  function generateCombinations(k: number) {
+    if (k === freeVars.length) {
+      const currentAssignment = Array(numButtons).fill(0);
+      for (let j = 0; j < freeVars.length; j++) {
+        currentAssignment[freeVars[j]] = freeVarAssignments[j];
+      }
+
+      // Solve for dependent variables
+      for (let r = numLights - 1; r >= 0; r--) {
+        let pivotCol = -1;
+        for (let c = 0; c < numButtons; c++) {
+          if (matrix[r][c] === 1) {
+            pivotCol = c;
+            break;
+          }
+        }
+
+        if (pivotCol !== -1 && !freeVars.includes(pivotCol)) {
+          let sum = 0;
+          for (let c = 0; c < numButtons; c++) {
+            if (c !== pivotCol) {
+              sum = (sum + matrix[r][c] * currentAssignment[c]) % modulus;
+            }
+          }
+          currentAssignment[pivotCol] = (matrix[r][numButtons] - sum + modulus) % modulus;
+        }
+      }
+
+      // Verify the solution against the original system
+      let isValidSolution = true;
+      for (let row = 0; row < numLights; row++) {
+          let actualLightState = 0;
+          for (let col = 0; col < numButtons; col++) {
+              let originalCoeff = 0;
+              if (buttons[col].includes(row)) {
+                  originalCoeff = 1;
+              }
+              actualLightState = (actualLightState + originalCoeff * currentAssignment[col]) % modulus;
+          }
+          if (actualLightState !== lights[row]) {
+              isValidSolution = false;
+              break;
+          }
+      }
+
+      if (!isValidSolution) {
+          return;
+      }
+
+      let currentTotalPresses = 0;
+      for (const val of currentAssignment) {
+        currentTotalPresses += val;
+      }
+
+      if (currentTotalPresses < minTotalPresses) {
+        minTotalPresses = currentTotalPresses;
+        bestSolution = [...currentAssignment];
+      } else if (currentTotalPresses === minTotalPresses) {
+        if (bestSolution === null || compareLexicographically(currentAssignment, bestSolution) < 0) {
+          bestSolution = [...currentAssignment];
+        }
+      }
+      return;
+    }
+
+    for (let val = 0; val < modulus; val++) {
+      freeVarAssignments[k] = val;
+      generateCombinations(k + 1);
+    }
+  }
+
+  generateCombinations(0);
+
+  return bestSolution;
+}
