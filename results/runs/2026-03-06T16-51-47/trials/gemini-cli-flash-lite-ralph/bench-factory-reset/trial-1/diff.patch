+import { describe, it, expect } from 'vitest';
+import { solveCounter } from '../src/index';
+
+describe('solveCounter', () => {
+  it('should return the correct solution for a simple case (mod 2)', () => {
+    const lights = [1, 0];
+    const buttons = [
+      [0], // B0 affects L0
+      [1], // B1 affects L1
+    ];
+    const modulus = 2;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([1, 0]);
+  });
+
+  it('should return the correct solution for a simple case (mod 5)', () => {
+    const lights = [2, 3];
+    const buttons = [
+      [0], // B0 affects L0
+      [1], // B1 affects L1
+    ];
+    const modulus = 5;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([2, 3]);
+  });
+
+  it('should return null for an inconsistent system', () => {
+    const lights = [1];
+    const buttons = [
+      [], // B0 affects nothing
+    ];
+    const modulus = 5;
+    expect(solveCounter(lights, buttons, modulus)).toBeNull();
+  });
+
+  it('should return the solution with minimum total presses and lexicographically smallest', () => {
+    const lights = [1];
+    const buttons = [
+      [0], // B0 affects L0
+      [0], // B1 affects L0
+    ];
+    const modulus = 3;
+    // Equations:
+    // x0 + x1 = 1 (mod 3)
+
+    // Possible solutions for (x0, x1) that sum to 1 (mod 3):
+    // (0, 1) -> total presses: 1. Lex: [0, 1]
+    // (1, 0) -> total presses: 1. Lex: [1, 0]
+    // (2, 2) -> total presses: 4. Lex: [2, 2]
+    // ...
+    // Minimum presses is 1. Between [0,1] and [1,0], [0,1] is lexicographically smaller.
+    expect(solveCounter(lights, buttons, modulus)).toEqual([0, 1]);
+  });
+
+  it('should handle empty lights array', () => {
+    const lights: number[] = [];
+    const buttons = [[0], [1]];
+    const modulus = 3;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([0, 0]);
+  });
+
+  it('should handle empty buttons array with all zero target', () => {
+    const lights = [0, 0];
+    const buttons: number[][] = [];
+    const modulus = 3;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([]);
+  });
+
+  it('should handle empty buttons array with non-zero target (no solution)', () => {
+    const lights = [1, 0];
+    const buttons: number[][] = [];
+    const modulus = 3;
+    expect(solveCounter(lights, buttons, modulus)).toBeNull();
+  });
+});
