+import { describe, it, expect } from 'vitest';
+import { solveToggle } from '../src/index';
+
+describe('solveToggle - Solution Cases', () => {
+  it('should return the correct solution for a simple case', () => {
+    const machine = {
+      target: [true, false],
+      buttons: [
+        [0], // Button 0 toggles light 0
+        [1], // Button 1 toggles light 1
+      ],
+    };
+    expect(solveToggle(machine)).toEqual([0]); // Press button 0
+  });
+
+  it('should return the correct solution when multiple buttons are needed', () => {
+    const machine = {
+      target: [true, true, false],
+      buttons: [
+        [0, 1], // Button 0 toggles lights 0, 1
+        [1, 2], // Button 1 toggles lights 1, 2
+        [0, 2], // Button 2 toggles lights 0, 2
+      ],
+    };
+    // Expected: (b0 XOR b2 = T0), (b0 XOR b1 = T1), (b1 XOR b2 = T2)
+    // T = [1, 1, 0]
+    // b0 + b2 = 1
+    // b0 + b1 = 1
+    // b1 + b2 = 0 => b1 = b2
+    // Substitute b1=b2 into first two:
+    // b0 + b1 = 1
+    // b0 + b1 = 1
+    // This gives b0 + b1 = 1.
+    // Let b1 = 0. Then b0 = 1. So solution [0]. Presses = 1.
+    // Let b1 = 1. Then b0 = 0. So solution [1, 2]. Presses = 2.
+    // Minimum presses is 1, so [0]
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should return the solution with fewest button presses (lexicographically smallest if tied)', () => {
+    const machine = {
+      target: [true, false, false],
+      buttons: [
+        [0],        // B0 toggles L0
+        [1],        // B1 toggles L1
+        [0, 1],     // B2 toggles L0, L1
+      ],
+    };
+    // Target: [1, 0, 0]
+    // L0: b0 + b2 = 1
+    // L1: b1 + b2 = 0
+    // L2: 0 = 0 (redundant)
+
+    // Case 1: b2 = 0
+    // b0 = 1
+    // b1 = 0
+    // Solution: [0]. Presses: 1.
+
+    // Case 2: b2 = 1
+    // b0 = 0
+    // b1 = 1
+    // Solution: [1, 2]. Presses: 2.
+
+    // Fewest presses is 1, so [0].
+    expect(solveToggle(machine)).toEqual([0]);
