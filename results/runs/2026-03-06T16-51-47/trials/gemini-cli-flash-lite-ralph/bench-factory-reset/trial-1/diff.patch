+    // Target: [1, 1]
+    // L0: b0 + b2 = 1
+    // L1: b1 + b2 = 1
+
+    // Case 1: b2 = 0
+    // b0 = 1
+    // b1 = 1
+    // Solution: [0, 1]. Presses: 2.
+
+    // Case 2: b2 = 1
+    // b0 = 0
+    // b1 = 0
