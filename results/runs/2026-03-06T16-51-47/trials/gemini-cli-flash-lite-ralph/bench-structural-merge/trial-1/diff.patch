`.\n\n**Revised `recursiveMerge` and `mergePath` logic:**\n\n```typescript\n// Helper to compare values at a specific path for equality.\nfunction areEqualAtPath(obj1: any, obj2: any, path: string): boolean {\n  const val1 = getPath(obj1, path);\n  const val2 = getPath(obj2, path);\n\n  if (val1 === val2) return true; // Strict equality for primitives, null, undefined.\n\n  // If values are objects or arrays, use deep comparison. Otherwise, strict equality failed, so they are not equal.\n  if (typeof val1 === 'object' && val1 !== null && typeof val2 === 'object' && val2 !== null) {\n    try {\n      return JSON.stringify(val1) === JSON.stringify(val2);\n    } catch (e) {\n      return false; // If stringify fails, they are not considered equal by this method.\n    }\n  }\n  return false; // Strict equality failed for non-objects/non-arrays.\n}\n\n// Recursive merge for objects and arrays\nfunction mergeRecursive(\n    base: any, // Base state object (e.g., document content)\n    ours: any, // Our branch's state object\n    theirs: any, // Their branch's state object\n    currentPath: string = '' // The path leading to the current item (e.g., \"a.b\")\n): { value: any, conflict: Conflict | null } {\n\n    const baseValue = getPath(base, currentPath);\n    const oursValue = getPath(ours, currentPath);\n    const theirsValue = getPath(theirs, currentPath);\n\n    const baseExists = baseValue !== undefined;\n    const oursExists = oursValue !== undefined;\n    const theirsExists = theirsValue !== undefined;\n\n    // --- Handle Deletions at this Path ---\n    if (!oursExists && !theirsExists) {\n        // Deleted on both sides or never existed. No change.\n        return { value: baseValue, conflict: null };\n    } else if (!oursExists) { // Deleted on ours, exists on theirs\n        // Conflict if 'theirs' has changed from 'base' OR if 'base' didn't have it but 'theirs' does.\n        if (!baseExists || !areEqualAtPath(base, theirs, currentPath)) {\n            return