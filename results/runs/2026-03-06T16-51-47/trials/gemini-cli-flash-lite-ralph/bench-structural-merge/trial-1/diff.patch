+// Helper for deep cloning objects using JSON.parse/stringify.
+// Assumes plain JSON objects and will not handle Dates, Regex, Functions, etc.
+function deepClone<T>(obj: T): T {
+  if (obj === null || typeof obj !== 'object') {
+    return obj;
+  }
+  // Use JSON.parse(JSON.stringify(obj)) for deep cloning plain JSON data.
+  return JSON.parse(JSON.stringify(obj));
+}
