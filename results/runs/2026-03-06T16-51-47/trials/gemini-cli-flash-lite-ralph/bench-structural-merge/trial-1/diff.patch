+// Recursively collects all dot-separated paths within an object.
+// Now, it also includes paths to objects and arrays themselves, not just leaf nodes.
+function getAllPaths(obj: any, currentPath: string = '', paths: Set<string> = new Set<string>()): Set<string> {
+  if (currentPath) {
+    paths.add(currentPath);
+  }
