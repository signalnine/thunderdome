length > 0 ? conflicts[0] : null }; // Return first conflict\n        } else {\n            return { value: mergedDoc, conflict: null };\n        }\n    } else {\n        // If not all are plain objects, use the simpler mergePath for the entire document value.\n        // This handles primitives, arrays, or mixed types at the root.\n        return mergePath(baseDoc, oursDoc, theirsDoc, '');\n    }\n}\n```\n\nLet's try to reintegrate this revised logic. The `getHistory` fix seems straightforward. The merge logic is complex, so I'll make targeted changes there.\n\nFinal check on `getHistory` fix logic:\nThe test expects `toThrow(...)`. My code throws an Error.\nThe error message is `Document \"${id}\" not found on branch \"${this.currentBranchName}\".`\nThe test expects `Document \"non_existent_doc\" not found on branch \"main\".`\nThis should match if `this.currentBranchName` is indeed `'main'`.\n\nI will provide the complete, updated `src/index.ts` file.I have updated `src/index.ts` with further refinements to the merging logic, specifically targeting the representation of conflicts and the recursive handling of objects and arrays. I have also re-applied the fix for `getHistory` error handling.\n\nI will now re-run the tests to verify the changes.\n```json\n[\n  {\n    \"tool_code\": \"print(default_api.write_file(file_path='src/index.ts', content='''CONTENT_OF_SRC_INDEX_TS'''))\"\n  }\n]\n```\nI need to replace `CONTENT_OF_SRC_INDEX_TS` with the actual content.\n\nHere's the full, revised content for `src/index.ts`:\n\n```typescript\n// Define interfaces\ninterface Version {\n  id: string;\n  timestamp: number;\n  content: object;\n}\n\ninterface MergeResult {\n  merged: Record<string, object>;\n  conflicts: Conflict[];\n  applied: boolean;\n}\n\ninterface Conflict {\n  documentId: string;\n  path: string;\n  base: any;\n  ours: any;\n  theirs: any;\n}\n\n// Internal representation of a document's state on a branch\ninterface DocumentState {\n  content: object;\n  versions: Version[];\n}\n\n// Represents the state of a branch, including its documents, history, and merge base snapshots.\ninterface BranchState {\n  documents: Map<string, DocumentState>; // Current documents on this branch.\n  history: Map<string, Version[]>;       // Full chronological history of each document on this branch.\n  // Stores the state of each document at the point this branch was created from another.\n  // This serves as the \"base\" for three-way merges.\n  creationState: Map<string, Version>;\n}\n\n// Helper for deep cloning objects using JSON.parse/stringify.\n// Assumes plain JSON objects and will not handle Dates, Regex, Functions, etc.\nfunction deepClone<T>(obj: T): T {\n  if (obj === null || typeof obj !== 'object') {\n    return obj;\n  }\n  // Use JSON.parse(JSON.stringify(obj)) for deep cloning plain JSON data.\n  return JSON.parse(JSON.stringify(obj));\n}\n\n// Helper to safely get a value from an object at a given dot-separated path.\n// Returns undefined if the path is invalid or not found.\nfunction getPath(obj: any, path: string): any {\n  if (!path) return obj; // If path is empty, return the object itself.\n  const parts = path.split('.');\n  let current = obj;\n  for (const part of parts) {\n    if (current === null || typeof current !== 'object') {\n      return undefined; // Cannot traverse further.\n    }\n    if (part in current) {\n      current = current[part];\n    } else {\n      return undefined; // Part not found.\n    }\n  }\n  return current;\n}\n\n// Helper to set a value in an object at a given dot-separated path.\n// Creates intermediate objects if they don't exist.\nfunction setPath(obj: any, path: string, value: any): void {\n  if (!path) {\n    // If path is empty, and value is an object, we should replace the entire object.\n    // If value is not an object, this might be an invalid operation or a no-op.\n    // For simplicity, assume path is always valid for setting.\n    // If path is empty, it implies replacing the root, which is handled by the caller.\n    // If the value is undefined, it should delete the key if it exists at the parent level.\n    // However, setPath is generally used to *set* a value, not delete. Deletion is handled by deletePath.\n    return;\n  }\n  const parts = path.split('.');\n  let current = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null) {\n      current[part] = {}; // Create intermediate objects if they don't exist or are null.\n    }\n    current = current[part];\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\n// Helper to delete a value from an object at a given dot-separated path.\n// Returns true if deletion occurred, false otherwise.\nfunction deletePath(obj: any, path: string): boolean {\n  if (!path) return false; // Cannot delete the root object this way.\n  const parts = path.split('.');\n  let current = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null) {\n      return false; // Path not found.\n    }\n    current = current[part];\n  }\n  const lastPart = parts[parts.length - 1];\n  if (lastPart in current) {\n    delete current[lastPart];\n    return true;\n  }\n  return false;\n}\n\n// Helper to compare values at a specific path for equality.\n// Uses JSON.stringify for deep comparison of primitives, arrays, and simple objects.\n// Fallbacks to strict equality for other types if stringify fails.\nfunction areEqualAtPath(obj1: any, obj2: any, path: string): boolean {\n  const val1 = getPath(obj1, path);\n  const val2 = getPath(obj2, path);\n\n  if (val1 === val2) return true; // Strict equality for primitives, null, undefined.\n\n  // If values are objects or arrays, use deep comparison. Otherwise, strict equality failed, so they are not equal.\n  if (typeof val1 === 'object' && val1 !== null && typeof val2 === 'object' && val2 !== null) {\n    try {\n      return JSON.stringify(val1) === JSON.stringify(val2);\n    } catch (e) {\n      return false; // If stringify fails, they are not considered equal by this method.\n    }\n  }\n  return false; // Strict equality failed for non-objects/non-arrays.\n}\n\n// Recursively collects all dot-separated paths within an object.\nfunction getAllPaths(obj: any, currentPath: string = '', paths: string[] = []): string[] {\n  if (obj === null || typeof obj !== 'object') {\n    if (currentPath) { // Only add if there's an actual path.\n      paths.push(currentPath);\n    }\n    return paths;\n  }\n\n  const keys = Object.keys(obj);\n  if (keys.length === 0 && currentPath) { // Handle empty objects as a valid path.\n    paths.push(currentPath);\n    return paths;\n  }\n\n  for (const key of keys) {\n    const newPath = currentPath ? `${currentPath}.${key}` : key;\n    getAllPaths(obj[key], newPath, paths);\n  }\n  return paths;\n}\n\n\n/**\n * Implements a versioned document store with branching and structural merging capabilities.\n * Mimics Git-like operations for JSON documents.\n */\nclass DocumentStore {\n  private branches: Map<string, BranchState>;\n  private currentBranchName: string;\n\n  constructor() {\n    this.branches = new Map();\n    this.currentBranchName = \"main\";\n    // Initialize the main branch with empty state.\n    this.branches.set(this.currentBranchName, {\n      documents: new Map(),\n      history: new Map(),\n      creationState: new Map() // Base state for merges\n    });\n  }\n\n  // --- Internal Helper Methods ---\n\n  // Gets the state of the currently active branch.\n  private getCurrentBranchState(): BranchState {\n    const state = this.branches.get(this.currentBranchName);\n    if (!state) {\n      // This should ideally not happen if branches are managed correctly.\n      throw new Error(`Internal error: Branch \"${this.currentBranchName}\" not found.`);\n    }\n    return state;\n  }\n\n  // Gets the state of a specified branch. Throws if the branch does not exist.\n  private getBranchState(branchName: string): BranchState {\n    const state = this.branches.get(branchName);\n    if (!state) {\n      throw new Error(`Branch \"${branchName}\" does not exist.`);\n    }\n    return state;\n  }\n\n  // Gets the state of a specific document on a given branch. Throws if not found.\n  private getDocumentState(branchState: BranchState, id: string): DocumentState {\n    const docState = branchState.documents.get(id);\n    if (!docState) {\n      // This error message needs to match the test's expectation for getHistory.\n      throw new Error(`Document \"${id}\" not found on branch \"${this.currentBranchName}\".`);\n    }\n    return docState;\n  }\n\n  // Gets the history of a document on a given branch. Returns empty array if no history.\n  private getDocumentHistory(branchState: BranchState, id: string): Version[] {\n    return branchState.history.get(id) || [];\n  }\n\n  // Gets a specific version of a document on a given branch. Throws if not found.\n  private getDocumentVersion(branchState: BranchState, id: string, versionId: string): Version {\n    const history = this.getDocumentHistory(branchState, id);\n    const version = history.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" for document \"${id}\" not found on branch \"${this.currentBranchName}\".`);\n    }\n    return version;\n  }\n\n  // --- Document CRUD Operations ---\n\n  /**\n   * Stores a new document. Throws if the ID already exists on the current branch.\n   */\n  create(id: string, content: object): void {\n    const branchState = this.getCurrentBranchState();\n    if (branchState.documents.has(id)) {\n      throw new Error(`Document with ID \"${id}\" already exists on branch \"${this.currentBranchName}\".`);\n    }\n\n    const newVersionId = `v_${Date.now()}_${Math.random().toString(36).substring(2, 9)}`;\n    const timestamp = Date.now();\n    const clonedContent = deepClone(content);\n\n    const newVersion: Version = {\n      id: newVersionId,\n      timestamp: timestamp,\n      content: clonedContent,\n    };\n\n    const newDocState: DocumentState = {\n      content: clonedContent,\n      versions: [newVersion],\n    };\n\n    branchState.documents.set(id, newDocState);\n\n    // Initialize history for this new document on this branch\n    if (!branchState.history.has(id)) {\n      branchState.history.set(id, []);\n    }\n    branchState.history.get(id)!.push(newVersion);\n\n    // If this is the first document being added/modified on this branch since creation,\n    // or if this document was not part of the original creation state, capture its current state as base.\n    // This helps in subsequent merges.\n    if (!branchState.creationState.has(id)) {\n      branchState.creationState.set(id, deepClone(newVersion)); // Store a snapshot of this version as base\n    }\n  }\n\n  /**\n   * Returns the current content of a document. Throws if the document doesn't exist.\n   * Returns a deep clone to prevent external mutation.\n   */\n  get(id: string): object {\n    const branchState = this.getCurrentBranchState();\n    const docState = this.getDocumentState(branchState, id);\n    return deepClone(docState.content);\n  }\n\n  /**\n   * Replaces the document content and creates a new version. Throws if the document doesn't exist.\n   * If the content has not changed, the operation is a no-op.\n   */\n  update(id: string, content: object): void {\n    const branchState = this.getCurrentBranchState();\n    const docState = this.getDocumentState(branchState, id);\n\n    // Check if the content has actually changed to avoid unnecessary versioning.\n    if (JSON.stringify(docState.content) === JSON.stringify(content)) {\n      return; // No change, do nothing.\n    }\n\n    const newVersionId = `v_${Date.now()}_${Math.random().toString(36).substring(2, 9)}`;\n    const timestamp = Date.now();\n    const clonedContent = deepClone(content);\n\n    const newVersion: Version = {\n      id: newVersionId,\n      timestamp: timestamp,\n      content: clonedContent,\n    };\n\n    docState.content = clonedContent; // Update current content.\n    docState.versions.push(newVersion); // Add to document's version list on this branch.\n\n    // Add to the branch's global history for this document.\n    if (!branchState.history.has(id)) {\n      branchState.history.set(id, []); // Should not happen if docState exists, but for safety.\n    }\n    branchState.history.get(id)!.push(newVersion);\n\n    // If this document was not part of the initial state of this branch,\n    // ensure its current state is captured as the base for future merges involving this doc.\n    if (!branchState.creationState.has(id)) {\n      branchState.creationState.set(id, deepClone(newVersion)); // Capture this state as base\n    }\n  }\n\n  /**\n   * Removes a document from the current branch. Throws if it doesn't exist.\n   * The document's history remains available.\n   */\n  delete(id: string): void {\n    const branchState = this.getCurrentBranchState();\n    if (!branchState.documents.has(id)) {\n      throw new Error(`Document \"${id}\" not found on branch \"${this.currentBranchName}\".`);\n    }\n\n    branchState.documents.delete(id);\n\n    // To handle delete/update conflicts correctly during merge, we need to record this deletion\n    // in the `creationState` if it wasn't already there. If the document was created on this branch\n    // and then deleted, its \"base\" state should reflect its state *before* deletion.\n    // If it existed on `creationState`, we should mark it as deleted there too for consistency.\n    // For simplicity, we'll use `undefined` to represent a deleted document in `creationState` for merge base.\n    if (!branchState.creationState.has(id)) {\n        // If a document was created on this branch and then deleted, its base state is considered undefined.\n        // However, for merge logic, it's better to represent the *state before deletion* as the base.\n        // A simpler approach: if a doc is deleted, and it existed in `creationState`, we can mark that `creationState` entry as `deleted`.\n        // For now, let's rely on `undefined` in `documents` for `ours` or `theirs` to signify deletion.\n        // The `creationState` tracks the state *at branch creation*. If a doc was deleted on this branch *after* creation,\n        // its `creationState` still holds its pre-deletion state.\n    }\n  }\n\n  // --- Version History Operations ---\n\n  /**\n   * Returns versions of a document in chronological order (oldest first).\n   * Returns deep clones of version contents.\n   * Throws if the document does not exist on the current branch.\n   */\n  getHistory(id: string): Version[] {\n    const branchState = this.getCurrentBranchState();\n    // Check if document exists before attempting to get history\n    if (!branchState.documents.has(id)) {\n        throw new Error(`Document \"${id}\" not found on branch \"${this.currentBranchName}\".`);\n    }\n    const history = this.getDocumentHistory(branchState, id);\n    // Return deep clones of versions to prevent external modification of historical data.\n    return history.map(v => ({ ...v, content: deepClone(v.content) }));\n  }\n\n  /**\n   * Returns the content of a document at a specific version.\n   * Returns a deep clone of the content.\n   */\n  getVersion(id: string, versionId: string): object {\n    const branchState = this.getCurrentBranchState();\n    const version = this.getDocumentVersion(branchState, id, versionId);\n    return deepClone(version.content);\n  }\n\n  // --- Branching Operations ---\n\n  /**\n   * Creates a new branch. If `fromBranch` is not provided, it branches from the current branch.\n   * Throws if the branch name already exists.\n   */\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch with name \"${name}\" already exists.`);\n    }\n\n    const sourceBranchName = fromBranch || this.currentBranchName;\n    const sourceBranchState = this.getBranchState(sourceBranchName);\n\n    // Deep clone the entire state of the source branch to create the new branch.\n    const newBranchState: BranchState = {\n      documents: new Map(),\n      history: new Map(),\n      creationState: new Map()\n    };\n\n    // Clone documents and their version history.\n    for (const [id, docState] of sourceBranchState.documents.entries()) {\n      newBranchState.documents.set(id, {\n        content: deepClone(docState.content),\n        versions: docState.versions.map(v => ({ ...v, content: deepClone(v.content) }))\n      });\n    }\n\n    // Clone history for each document.\n    for (const [id, historyList] of sourceBranchState.history.entries()) {\n      newBranchState.history.set(id, historyList.map(v => ({ ...v, content: deepClone(v.content) })));\n    }\n\n    // Capture the \"base\" state for each document that exists on the source branch.\n    // This `creationState` will be used as the common ancestor for merging `sourceBranch` into `currentBranch` later.\n    for (const [id, version] of sourceBranchState.creationState.entries()) {\n      newBranchState.creationState.set(id, deepClone(version));\n    }\n    // Ensure any documents that were on the source branch but not in its `creationState`\n    // (e.g., documents added after the source branch was created from another branch)\n    // also have their state captured from the source branch's `documents` map if `creationState` is missing an entry.\n    for (const [id, docState] of sourceBranchState.documents.entries()) {\n        if (!newBranchState.creationState.has(id) && docState.versions.length > 0) {\n            // If a document exists on the source branch, but wasn't explicitly in `creationState`,\n            // use its latest version on the source branch as the base. This implies it was created\n            // or modified on the source branch after its divergence point.\n             newBranchState.creationState.set(id, deepClone(docState.versions[docState.versions.length - 1]));\n        }\n    }\n\n\n    this.branches.set(name, newBranchState);\n  }\n\n  /**\n   * Switches the active branch to the specified name.\n   * Throws if the branch does not exist.\n   */\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" does not exist.`);\n    }\n    this.currentBranchName = name;\n  }\n\n  /**\n   * Returns the name of the current active branch.\n   */\n  getBranch(): string {\n    return this.currentBranchName;\n  }\n\n  /**\n   * Returns a list of all existing branch names.\n   */\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // --- Merging Operations ---\n\n  /**\n   * Merges changes from `sourceBranchName` into the current branch.\n   * Uses three-way merge and detects structural conflicts.\n   */\n  merge(sourceBranchName: string): MergeResult {\n    const currentBranchState = this.getCurrentBranchState();\n    const sourceBranchState = this.getBranchState(sourceBranchName);\n\n    if (this.currentBranchName === sourceBranchName) {\n      throw new Error(\"Cannot merge a branch into itself.\");\n    }\n\n    const mergeResult: MergeResult = {\n      merged: {},\n      conflicts: [],\n      applied: false, // Set to true only if merge is auto-applied without conflicts.\n    };\n\n    // Collect all unique document IDs from the current branch, source branch, and their respective creation states.\n    const allDocIds = new Set<string>();\n    for (const id of currentBranchState.documents.keys()) allDocIds.add(id);\n    for (const id of sourceBranchState.documents.keys()) allDocIds.add(id);\n    // Ensure we consider documents that might have been deleted on one branch but exist in the creation state (base)\n    for (const id of currentBranchState.creationState.keys()) allDocIds.add(id);\n    for (const id of sourceBranchState.creationState.keys()) allDocIds.add(id);\n\n\n    for (const docId of allDocIds) {\n      const ourDocState = currentBranchState.documents.get(docId);\n      const theirDocState = sourceBranchState.documents.get(docId);\n\n      // Get the base content for this document.\n      // `ours` is `currentBranch`, `theirs` is `sourceBranch`.\n      // The `base` is the state of `currentBranch` *at the time* `sourceBranch` was created from it.\n      // This is represented by `sourceBranchState.creationState.get(docId)`.\n      // If `sourceBranch` was created from `currentBranch`, `sourceBranch.creationState` holds `currentBranch`'s state.\n      const baseVersion = sourceBranchState.creationState.get(docId); // State of `ours` when `theirs` diverged.\n      const baseContent = baseVersion ? baseVersion.content : undefined;\n\n      const currentDocContent = ourDocState ? ourDocState.content : undefined; // Current content on `ours` branch.\n      const sourceDocContent = theirDocState ? theirDocState.content : undefined; // Current content on `theirs` branch.\n\n      // --- Handle Document Existence Scenarios ---\n\n      // Case 1: Document exists on neither branch (and wasn't in base). Skip.\n      if (currentDocContent === undefined && sourceDocContent === undefined) {\n        continue;\n      }\n\n      let docMergeResult: { value: any, conflict: Conflict | null };\n\n      // Determine if recursive merge is appropriate (both sides are plain objects)\n      const isOurPlainObject = typeof currentDocContent === 'object' && currentDocContent !== null && !Array.isArray(currentDocContent);\n      const isTheirPlainObject = typeof sourceDocContent === 'object' && sourceDocContent !== null && !Array.isArray(sourceDocContent);\n      const isBasePlainObject = typeof baseContent === 'object' && baseContent !== null && !Array.isArray(baseContent);\n\n      if (isOurPlainObject && isTheirPlainObject && (isBasePlainObject || baseContent === undefined)) {\n          // Both sides are plain objects, and base is also a plain object OR base is undefined.\n          // Use recursive merge to handle nested structures.\n          docMergeResult = mergeRecursive(baseContent || {}, currentDocContent || {}, sourceDocContent || {});\n      } else {\n          // If either side is not a plain object, or base is not a plain object (and not undefined),\n          // use simple path merge for the entire document. This handles primitives, arrays, and mixed types at the root.\n          docMergeResult = mergePath(baseContent || {}, currentDocContent || {}, sourceDocContent || {}, '');\n      }\n\n\n      if (docMergeResult.conflict) {\n        docMergeResult.conflict.documentId = docId; // Assign document ID to conflict.\n        mergeResult.conflicts.push(docMergeResult.conflict);\n      } else {\n        // If no conflict, apply the merged value.\n        // If value is undefined, it means the document was deleted and no conflict.\n        if (docMergeResult.value !== undefined) {\n          mergeResult.merged[docId] = deepClone(docMergeResult.value); // Store clone of merged content.\n        } else {\n          // If value is undefined, it implies deletion. Remove from merged if it was there.\n          delete mergeResult.merged[docId];\n        }\n      }\n    }\n\n    // If there are no conflicts, apply the merge to the current branch.\n    if (mergeResult.conflicts.length === 0) {\n      mergeResult.applied = true;\n      // Update the current branch's documents with the merged content.\n      for (const docId in mergeResult.merged) {\n        const newContent = mergeResult.merged[docId];\n        const newVersionId = `v_${Date.now()}_${Math.random().toString(36).substring(2, 9)}`;\n        const timestamp = Date.now();\n\n        const newVersion: Version = {\n          id: newVersionId,\n          timestamp: timestamp,\n          content: deepClone(newContent), // Store clone in version\n        };\n\n        // Update document state on current branch\n        if (currentBranchState.documents.has(docId)) {\n          const docState = currentBranchState.documents.get(docId)!;\n          docState.content = deepClone(newContent); // Update current content\n          docState.versions.push(newVersion); // Add to document's version list\n          if (!currentBranchState.history.has(docId)) currentBranchState.history.set(docId, []);\n          currentBranchState.history.get(docId)!.push(newVersion);\n\n          // Update creation state as well, as this merge is now part of the history that subsequent branches might fork from.\n          // The `creationState` of the *current branch* should reflect the state after merge.\n          // This ensures that if we create a new branch from this point, its base is correct.\n          currentBranchState.creationState.set(docId, deepClone(newVersion)); // Update base to the newly merged version.\n\n        } else {\n          // Document was created on source branch and merged into current. Add it.\n          const newDocState: DocumentState = {\n            content: deepClone(newContent),\n            versions: [newVersion],\n          };\n          currentBranchState.documents.set(docId, newDocState);\n          if (!currentBranchState.history.has(docId)) currentBranchState.history.set(docId, []);\n          currentBranchState.history.get(docId)!.push(newVersion);\n\n          // Set creation state for this newly merged document.\n          currentBranchState.creationState.set(docId, deepClone(newVersion));\n        }\n      }\n      // Handle deletions: If a document was deleted on `currentBranch` (not in `documents`)\n      // but was present in `mergeResult.merged` (meaning it was modified/created on `sourceBranch`),\n      // it has already been added back by the logic above.\n      // If a document was deleted on `sourceBranch` and unmodified on `currentBranch`, it remains deleted on `currentBranch`\n      // because it won't be in `mergeResult.merged`.\n    }\n\n    return mergeResult;\n  }\n}\n\n// Helper function for simple path merging (used for non-object/non-array values or root level).\nfunction mergePath(base: any, ours: any, theirs: any, path: string): { value: any, conflict: Conflict | null } {\n  const baseValue = getPath(base, path);\n  const oursValue = getPath(ours, path);\n  const theirsValue = getPath(theirs, path);\n\n  const baseExists = baseValue !== undefined;\n  const oursExists = oursValue !== undefined;\n  const theirsExists = theirsValue !== undefined;\n\n  // --- Handle Deletions at this Path ---\n  if (!oursExists && !theirsExists) {\n    // Deleted on both sides or never existed. No change.\n    return { value: baseValue, conflict: null };\n  } else if (!oursExists) { // Deleted on ours, exists on theirs\n    // Conflict if 'theirs' has changed from 'base' OR if 'base' didn't have it but 'theirs' does.\n    if (!baseExists || !areEqualAtPath(base, theirs, path)) {\n      return {\n        value: undefined, // Not applied directly, needs conflict resolution\n        conflict: {\n          documentId: 'TODO', // To be filled by caller\n          path: path,\n          base: baseValue,\n          ours: undefined, // Explicitly undefined for deletion\n          theirs: theirsValue,\n        }\n      };\n    } else {\n      // 'theirs' is same as 'base', and 'ours' deleted it. No conflict, deletion is fine.\n      return { value: undefined, conflict: null };\n    }\n  } else if (!theirsExists) { // Deleted on theirs, exists on ours\n    // Conflict if 'ours' has changed from 'base' OR if 'base' didn't have it but 'ours' does.\n    if (!baseExists || !areEqualAtPath(base, ours, path)) {\n      return {\n        value: undefined,\n        conflict: {\n          documentId: 'TODO',\n          path: path,\n          base: baseValue,\n          ours: oursValue,\n          theirs: undefined,\n        }\n      };\n    } else {\n      // 'ours' is same as 'base', and 'theirs' deleted it. No conflict, deletion is fine.\n      return { value: undefined, conflict: null };\n    }\n  }\n\n  // --- Both exist, check for conflicts ---\n  const oursChanged = !areEqualAtPath(base, ours, path);\n  const theirsChanged = !areEqualAtPath(base, theirs, path);\n\n  // Case 1: Conflict - both changed to different values\n  if (oursChanged && theirsChanged && !areEqualAtPath(ours, theirs, path)) {\n    return {\n      value: undefined, // Not applied\n      conflict: {\n        documentId: 'TODO',\n        path: path,\n        base: baseValue,\n        ours: oursValue,\n        theirs: theirsValue,\n      }\n    };\n  }\n\n  // --- No Conflict - determine the resulting value ---\n\n  // If both changed to the same value, take that value.\n  if (oursChanged && theirsChanged && areEqualAtPath(ours, theirs, path)) {\n      return { value: oursValue, conflict: null };\n  } else if (oursChanged) {\n    // Only ours changed (or theirs didn't change from base, and ours did). Take ours.\n    return { value: oursValue, conflict: null };\n  } else if (theirsChanged) {\n    // Only theirs changed (or ours didn't change from base, and theirs did). Take theirs.\n    return { value: theirsValue, conflict: null };\n  } else {\n    // No changes on either side relative to base. Take base value.\n    return { value: baseValue, conflict: null };\n  }\n}\n\n// Recursive merge for objects and arrays\nfunction mergeRecursive(\n    base: any, // Base state object (e.g., document content)\n    ours: any, // Our branch's state object\n    theirs: any, // Their branch's state object\n    currentPath: string = '' // The path leading to the current item (e.g., \"a.b\")\n): { value: any, conflict: Conflict | null } {\n\n    const baseValue = getPath(base, currentPath);\n    const oursValue = getPath(ours, currentPath);\n    const theirsValue = getPath(theirs, currentPath);\n\n    const baseExists = baseValue !== u