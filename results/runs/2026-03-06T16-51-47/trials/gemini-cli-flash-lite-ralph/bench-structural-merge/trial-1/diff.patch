+      value: undefined, // Value is not auto-applied in case of conflict.
+      conflict: {
+        documentId: 'TODO', // Placeholder, filled by caller.
+        path: path,
+        base: baseValue,
+        ours: oursValue,
+        theirs: theirsValue,
+      }
+    };
