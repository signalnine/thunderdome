+
+// Helper for deep cloning objects using JSON.parse/stringify.
+// Assumes plain JSON objects and will not handle Dates, Regex, Functions, etc.
+function deepClone<T>(obj: T): T {
+  if (obj === null || typeof obj !== 'object') {
+    return obj;
+  }
+  // Use JSON.parse(JSON.stringify(obj)) for deep cloning plain JSON data.
+  return JSON.parse(JSON.stringify(obj));
+}
+
+// Helper to safely get a value from an object at a given dot-separated path.
+// Returns undefined if the path is invalid or not found.
+function getPath(obj: any, path: string): any {
+  if (!path) return obj; // If path is empty, return the object itself.
+  const parts = path.split('.');
+  let current = obj;
+  for (const part of parts) {
+    if (current === null || typeof current !== 'object') {
+      return undefined; // Cannot traverse further.
+    }
+    if (part in current) {
+      current = current[part];
+    } else {
+      return undefined; // Part not found.
+    }
+  }
+  return current;
+}
+
+// Helper to set a value in an object at a given dot-separated path.
+// Creates intermediate objects if they don't exist.
+function setPath(obj: any, path: string, value: any): void {
+  if (!path) {
+    // If path is empty, and value is an object, we should replace the entire object.
+    // If value is not an object, this might be an invalid operation or a no-op.
+    // For simplicity, assume path is always valid for setting.
+    // If path is empty, it implies replacing the root, which is handled by the caller.
+    return;
+  }
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null) {
+      current[part] = {}; // Create intermediate objects if they don't exist or are null.
+    }
+    current = current[part];
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+// Helper to delete a value from an object at a given dot-separated path.
+// Returns true if deletion occurred, false otherwise.
+function deletePath(obj: any, path: string): boolean {
+  if (!path) return false; // Cannot delete the root object this way.
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (!(part in current) || typeof current[part] !== 'object' || current[part] === null) {
+      return false; // Path not found.
+    }
+    current = current[part];
+  }
+  const lastPart = parts[parts.length - 1];
+  if (lastPart in current) {
+    delete current[lastPart];
+    return true;
+  }
+  return false;
+}
+
+// Compares two values at a specific path for equality.
+// Uses JSON.stringify for deep comparison of primitives, arrays, and simple objects.
+// Fallbacks to strict equality for other types if stringify fails.
+function areEqualAtPath(obj1: any, obj2: any, path: string): boolean {
+  const val1 = getPath(obj1, path);
+  const val2 = getPath(obj2, path);
+  if (val1 === val2) return true; // Strict equality for primitives, null, undefined.
+  try {
+    return JSON.stringify(val1) === JSON.stringify(val2);
+  } catch (e) {
+    return false; // If stringify fails, they are not considered equal by this method.
+  }
