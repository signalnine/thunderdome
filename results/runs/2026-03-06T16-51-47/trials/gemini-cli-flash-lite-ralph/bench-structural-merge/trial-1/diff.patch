+// Define interfaces
+interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface Conflict {
+  documentId: string;
+  path: string;
+  base: any;
+  ours: any;
+  theirs: any;
+}
+
+// Internal representation of a document's state on a branch
+interface DocumentState {
+  content: object;
+  versions: Version[];
+}
+
+// Represents the state of a branch, including its documents, history, and merge base snapshots.
+interface BranchState {
+  documents: Map<string, DocumentState>; // Current documents on this branch.
+  history: Map<string, Version[]>;       // Full chronological history of each document on this branch.
+  // Stores the state of each document at the point this branch was created from another.
+  // This serves as the "base" for three-way merges.
+  creationState: Map<string, Version>;
