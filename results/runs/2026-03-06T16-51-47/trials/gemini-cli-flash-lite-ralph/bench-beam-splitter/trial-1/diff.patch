+// src/index.test.ts
+import { countBeamCells, countBeamPaths } from './index';
+import { describe, it, expect } from 'vitest';
+
+describe('Beam Splitter', () => {
+  it('should count beam cells for example 1', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('should count beam paths for example 1', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('should count beam cells for example 2', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('should count beam paths for example 2', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('should handle a grid with no splitters', () => {
+    const grid = [
+      ['.', 'S', '.',],
+      ['.', '.', '.',],
+      ['.', '.', '.',],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('should handle a grid with multiple splitters in a line', () => {
+    const grid = [
+        ['.', 'S', '.', '.', '.'],
+        ['.', '.', '^', '.', '.'],
+        ['.', '.', '.', '^', '.'],
+        ['.', '.', '.', '.', '.'],
+    ];
+    // S -> (0,1)
+    // (1,1) -> (1,2) hits ^
+    // Splits: (2,1) DL, (2,3) DR
+    // (2,1) continues DL -> (3,0)
+    // (2,3) hits ^
+    // Splits: (3,2) DL, (3,4) DR
+    expect(countBeamCells(grid)).toBe(4);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+
+  it('should handle a grid with an edge splitter leading to absorption', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // S -> (0,0)
+    // (1,0) hits ^
+    // Splits: (2,-1) absorbed, (2,1) DR
+    // Cells: (0,0), (1,0), (2,1) = 3 cells
+    expect(countBeamCells(grid)).toBe(3);
+    // Paths: S->(0,0)->(1,0) [1 path]
+    // at (1,0) splitter:
+    //  -> (2,-1) DL [1 path] -- absorbed (exits grid)
+    //  -> (2,1) DR [1 path] -- exits
+    // Total paths = 2n
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+});
