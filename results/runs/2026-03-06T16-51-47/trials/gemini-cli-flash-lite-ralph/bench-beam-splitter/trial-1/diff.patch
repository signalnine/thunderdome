+++ b/src/index.ts
@@ -0,0 +1,224 @@
+// src/index.ts
+
+enum Direction {
+  DOWN,
+  DOWN_LEFT,
+  DOWN_RIGHT,
+}
+
+interface Beam {
+  row: number;
+  col: number;
+  direction: Direction;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (!grid || grid.length === 0 || grid[0].length === 0) {
+    return 0;
+  }
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  let startRow = -1;
+  let startCol = -1;
+
+  // Find the source 'S'
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      startRow = 0;
+      startCol = c;
+      break;
+    }
+  }
+
+  if (startRow === -1) {
+    // No source found, though problem description says it's always on top row.
+    return 0;
+  }
+
+  const visitedCells = new Set<string>();
+  const queue: Beam[] = [];
+
+  // Add the initial source cell to visited cells
+  visitedCells.add(`${startRow},${startCol}`);
+
+  // Start the first beam moving DOWN from the source
+  queue.push({ row: startRow, col: startCol, direction: Direction.DOWN });
+
+  while (queue.length > 0) {
+    const { row, col, direction } = queue.shift()!;
+
+    let nextRow = row;
+    let nextCol = col;
+
+    switch (direction) {
+      case Direction.DOWN:
+        nextRow = row + 1;
+        break;
+      case Direction.DOWN_LEFT:
+        nextRow = row + 1;
+        nextCol = col - 1;
+        break;
+      case Direction.DOWN_RIGHT:
+        nextRow = row + 1;
+        nextCol = col + 1;
+        break;
+    }
+
+    // Check boundaries
+    if (nextRow < 0 || nextRow >= rows || nextCol < 0 || nextCol >= cols) {
+      // Beam absorbed
+      continue;
+    }
+
+    const nextCellKey = `${nextRow},${nextCol}`;
+    visitedCells.add(nextCellKey);
+
+    const cellType = grid[nextRow][nextCol];
+
+    if (cellType === '^') {
+      // Splitter: two new beams
+      queue.push({ row: nextRow, col: nextCol, direction: Direction.DOWN_LEFT });
+      queue.push({ row: nextRow, col: nextCol, direction: Direction.DOWN_RIGHT });
+    } else {
+      // Empty or Source (though source won't be hit by other beams in this logic): continue in same direction
+      queue.push({ row: nextRow, col: nextCol, direction: direction });
+    }
+  }
+
+  return visitedCells.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (!grid || grid.length === 0 || grid[0].length === 0) {
+    return 0n;
+  }
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // dp[row][col][incoming_direction_idx]
+  // 0: from (r-1, c) - straight down (corresponds to Direction.DOWN)
+  // 1: from (r-1, c+1) - down-left (corresponds to Direction.DOWN_LEFT)
+  // 2: from (r-1, c-1) - down-right (corresponds to Direction.DOWN_RIGHT)
+  const dp: bigint[][][] = Array(rows)
+    .fill(null)
+    .map(() =>
+      Array(cols)
+        .fill(null)
+        .map(() => [0n, 0n, 0n])
+    );
+
+  let startCol = -1;
+  // Find the source 'S'
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      startCol = c;
+      break;
+    }
+  }
+
+  if (startCol === -1) {
+    return 0n; // Should not happen based on problem description, but good for robustness
+  }
+
+  // Initial beam from 'S' at (0, startCol) moves DOWN.
+  // This means 1 path starts effectively "arriving" at (0, startCol) with an implicit DOWN direction from above.
+  dp[0][startCol][0] = 1n;
+
+  let totalPaths = 0n;
+
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      const pathsIncomingDown = dp[r][c][0];
+      const pathsIncomingDownLeft = dp[r][c][1]; // These paths arrived at (r,c) from (r-1, c+1)
+      const pathsIncomingDownRight = dp[r][c][2]; // These paths arrived at (r,c) from (r-1, c-1)
+
+      const cellType = grid[r][c];
+
+      // Process paths that arrived at (r,c) and continue DOWN (from previous r-1, c)
+      if (pathsIncomingDown > 0n) {
+        if (cellType === '^') {
+          // Splitter: paths split down-left and down-right
+          // New beam: to (r+1, c-1) as DOWN_LEFT
+          if (r + 1 < rows && c - 1 >= 0) {
+            dp[r + 1][c - 1][1] += pathsIncomingDown;
+          } else {
+            totalPaths += pathsIncomingDown;
+          }
+          // New beam: to (r+1, c+1) as DOWN_RIGHT
+          if (r + 1 < rows && c + 1 < cols) {
+            dp[r + 1][c + 1][2] += pathsIncomingDown;
+          } else {
+            totalPaths += pathsIncomingDown;
+          }
+        } else {
+          // Empty or Source: continue DOWN
+          // New beam: to (r+1, c) as DOWN
+          if (r + 1 < rows) {
+            dp[r + 1][c][0] += pathsIncomingDown;
+          } else {
+            totalPaths += pathsIncomingDown;
+          }
+        }
+      }
+
+      // Process paths that arrived at (r,c) and continue DOWN_LEFT (from previous r-1, c+1)
+      if (pathsIncomingDownLeft > 0n) {
+        if (cellType === '^') {
+          // Splitter: paths split down-left and down-right
+          // New beam: to (r+1, c-1) as DOWN_LEFT
+          if (r + 1 < rows && c - 1 >= 0) {
+            dp[r + 1][c - 1][1] += pathsIncomingDownLeft;
+          } else {
+            totalPaths += pathsIncomingDownLeft;
+          }
+          // New beam: to (r+1, c+1) as DOWN_RIGHT
+          if (r + 1 < rows && c + 1 < cols) {
+            dp[r + 1][c + 1][2] += pathsIncomingDownLeft;
+          } else {
+            totalPaths += pathsIncomingDownLeft;
+          }
+        } else {
+          // Empty or Source: continue DOWN_LEFT
+          // New beam: to (r+1, c-1) as DOWN_LEFT
+          if (r + 1 < rows && c - 1 >= 0) {
+            dp[r + 1][c - 1][1] += pathsIncomingDownLeft;
+          } else {
+            totalPaths += pathsIncomingDownLeft;
+          }
+        }
+      }
+
+      // Process paths that arrived at (r,c) and continue DOWN_RIGHT (from previous r-1, c-1)
+      if (pathsIncomingDownRight > 0n) {
+        if (cellType === '^') {
+          // Splitter: paths split down-left and down-right
+          // New beam: to (r+1, c-1) as DOWN_LEFT
+          if (r + 1 < rows && c - 1 >= 0) {
+            dp[r + 1][c - 1][1] += pathsIncomingDownRight;
+          } else {
+            totalPaths += pathsIncomingDownRight;
+          }
+          // New beam: to (r+1, c+1) as DOWN_RIGHT
+          if (r + 1 < rows && c + 1 < cols) {
+            dp[r + 1][c + 1][2] += pathsIncomingDownRight;
+          } else {
+            totalPaths += pathsIncomingDownRight;
+          }
+        } else {
+          // Empty or Source: continue DOWN_RIGHT
+          // New beam: to (r+1, c+1) as DOWN_RIGHT
+          if (r + 1 < rows && c + 1 < cols) {
+            dp[r + 1][c + 1][2] += pathsIncomingDownRight;
+          } else {
+            totalPaths += pathsIncomingDownRight;
+          }
+        }
+      }
+    }
+  }
+
+  return totalPaths;
+}
