+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index.js';
+
+describe('simulate', () => {
+  it('should simulate a single AND gate correctly', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'inputA', in2: 'inputB', out: 'outputC' }];
+    const inputs = { inputA: 1, inputB: 1 };
+    const result = simulate(gates, inputs);
+    expect(result['outputC']).toBe(1);
+  });
+
+  it('should simulate a single OR gate correctly', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'inputA', in2: 'inputB', out: 'outputC' }];
+    const inputs = { inputA: 0, inputB: 1 };
+    const result = simulate(gates, inputs);
+    expect(result['outputC']).toBe(1);
+  });
+
+  it('should simulate a single XOR gate correctly', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'inputA', in2: 'inputB', out: 'outputC' }];
+    const inputs = { inputA: 1, inputB: 0 };
+    const result = simulate(gates, inputs);
+    expect(result['outputC']).toBe(1);
+  });
+
+  it('should simulate a chain of gates correctly', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+    ];
+    const inputs = { x00: 1, y00: 1, x01: 1, y01: 0 };
+    const result = simulate(gates, inputs);
+
+    // 1+1 = 10 (z00=0, c00=1)
+    // 1+0 + carry(1) = 10 (z01=0, c01=1)
+    // So 01 + 11 = 100 (binary) -> 1+3 = 4 (decimal)
+    expect(result['z00']).toBe(0);
+    expect(result['c00']).toBe(1);
+    expect(result['t01']).toBe(1); // x01 XOR y01 (1 XOR 0)
+    expect(result['z01']).toBe(0); // t01 XOR c00 (1 XOR 1)
+    expect(result['a01']).toBe(0); // x01 AND y01 (1 AND 0)
+    expect(result['b01']).toBe(1); // t01 AND c00 (1 AND 1)
+    expect(result['c01']).toBe(1); // a01 OR b01 (0 OR 1)
+  });
+
+  it('should handle unprocessed gates if inputs are missing (though not expected for this problem)', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'inputA', in2: 'inputB', out: 'outputC' }];
+    const inputs = { inputA: 1 }; // inputB is missing
+    const result = simulate(gates, inputs);
+    expect(result['outputC']).toBeUndefined();
+  });
+});
+
+describe('findSwappedWires', () => {
+  const create3BitAdder = (): Gate[] => [
+    // Bit 0
+    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+    // Bit 1
+    { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+    { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+    { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+    { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+    { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+    // Bit 2
+    { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+    { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+    { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+    { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+    { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+  ];
+
+  it('should find 8 swapped wires in a 3-bit adder with 4 pairs of swaps', () => {
+    const correctGates = create3BitAdder();
+    const swappedGates = JSON.parse(JSON.stringify(correctGates)) as Gate[]; // Deep copy
+
+    // Introduce 4 pairs of swaps: 8 wires in total
+    // Original indices: 0(z00), 1(c00), 2(t01), 3(z01), 4(a01), 5(b01), 6(c01), 7(t02), 8(z02), 9(a02), 10(b02), 11(c02)
+
+    // Swap 1: z00 <-> c00
+    swappedGates[0].out = 'c00'; // was z00
+    swappedGates[1].out = 'z00'; // was c00
+
+    // Swap 2: t01 <-> z01
+    swappedGates[2].out = 'z01'; // was t01
+    swappedGates[3].out = 't01'; // was z01
+
+    // Swap 3: a01 <-> b01
+    swappedGates[4].out = 'b01'; // was a01
+    swappedGates[5].out = 'a01'; // was b01
+
+    // Swap 4: t02 <-> z02
+    swappedGates[7].out = 'z02'; // was t02
+    swappedGates[8].out = 't02'; // was z02
+
+    const expectedSwappedWires = [
+      'a01', 'b01', 'c00', 'z00', 't01', 'z01', 't02', 'z02'
+    ].sort();
+
+    const result = findSwappedWires(swappedGates);
+    expect(result).toEqual(expectedSwappedWires);
+  });
+
+
+
+  it('should return an empty array if no wires are swapped', () => {
+    const correctGates = create3BitAdder();
+    const result = findSwappedWires(correctGates);
+    expect(result).toEqual([]);
+  });
+
+  it('should handle circuits with different max bit', () => {
+
+
+    // The findSwappedWires function identifies the correct gate from its op, in1, in2.
+    // The `gates` input has duplicates for 'op, in1, in2' combinations.
+    // This is fine, as long as `correctOutputMap` handles it and correctly maps the intended outputs.
+    // My `correctOutputMap` assumes unique (op, in1, in2) combinations.
+
+    // Let's construct a circuit that matches the correct structure but with a swap for a single bit adder.
+    // For a 0-bit adder (maxBit=0), we have z00, c00.
+    const correct0BitAdder: Gate[] = [
+        { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+        { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+    ];
+
+    const swapped0BitAdder = JSON.parse(JSON.stringify(correct0BitAdder)) as Gate[];
+    swapped0BitAdder[0].out = 'c00'; // was z00
+    swapped0BitAdder[1].out = 'z00'; // was c00
+
+    const expectedSwappedWires0Bit = ['c00', 'z00'].sort();
+    const result0Bit = findSwappedWires(swapped0BitAdder);
+    expect(result0Bit).toEqual(expectedSwappedWires0Bit);
+  });
+});
