@@ -0,0 +1,133 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;   // input wire name
+  in2: string;   // input wire name
+  out: string;   // output wire name
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wireValues: Record<string, number> = { ...inputs };
+  const processedGates = new Set<Gate>();
+
+  // Helper function to get the value of a wire, handling undefined
+  const getWireValue = (wireName: string): number | undefined => {
+    return wireValues[wireName];
+  };
+
+  // Keep looping until no more gates can be processed in an iteration
+  let gatesProcessedInIteration: boolean;
+  do {
+    gatesProcessedInIteration = false;
+    for (const gate of gates) {
+      if (processedGates.has(gate)) {
+        continue;
+      }
+
+      const in1Val = getWireValue(gate.in1);
+      const in2Val = getWireValue(gate.in2);
+
+      // Only process the gate if both input wires have a value
+      if (in1Val !== undefined && in2Val !== undefined) {
+        let outputValue: number;
+        switch (gate.op) {
+          case 'AND':
+            outputValue = in1Val & in2Val;
+            break;
+          case 'OR':
+            outputValue = in1Val | in2Val;
+            break;
+          case 'XOR':
+            outputValue = in1Val ^ in2Val;
+            break;
+          default:
+            throw new Error(`Unknown operation: ${gate.op}`);
+        }
+        wireValues[gate.out] = outputValue;
+        processedGates.add(gate);
+        gatesProcessedInIteration = true;
+      }
+    }
+  } while (gatesProcessedInIteration && processedGates.size < gates.length);
+
+  // If some gates are still unprocessed, it might indicate a problem or unreachable gates
+  // For this problem, it's guaranteed to be acyclic and solvable.
+  if (processedGates.size < gates.length) {
+    console.warn("Not all gates were processed. This might indicate unreachable gates or an issue.");
+  }
+
+  return wireValues;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // 1. Determine Max Bit 'N'
+  let maxBit = -1;
+  const regex = /[xy](\d{2})/; // Matches x or y followed by two digits
+
+  for (const gate of gates) {
+    const inputs = [gate.in1, gate.in2];
+    for (const input of inputs) {
+      const match = input.match(regex);
+      if (match) {
+        const bit = parseInt(match[1], 10);
+        if (bit > maxBit) {
+          maxBit = bit;
+        }
+      }
+    }
+  }
+
+  // 2. Generate 'correctGates' array based on N-bit adder structure
+  const correctGates: Gate[] = [];
+
+  // Bit 0 (Half Adder)
+  correctGates.push({ op: 'XOR', in1: `x00`, in2: `y00`, out: `z00` });
+  correctGates.push({ op: 'AND', in1: `x00`, in2: `y00`, out: `c00` });
+
+  // Bits 1 to MaxBit (Full Adders)
+  for (let i = 1; i <= maxBit; i++) {
+    const x_i = `x${i.toString().padStart(2, '0')}`;
+    const y_i = `y${i.toString().padStart(2, '0')}`;
+    const prev_carry = `c${(i - 1).toString().padStart(2, '0')}`;
+    const t_i = `t${i.toString().padStart(2, '0')}`;
+    const a_i = `a${i.toString().padStart(2, '0')}`;
+    const b_i = `b${i.toString().padStart(2, '0')}`;
+    const c_i = `c${i.toString().padStart(2, '0')}`;
+    const z_i = `z${i.toString().padStart(2, '0')}`;
+
+    correctGates.push({ op: 'XOR', in1: x_i, in2: y_i, out: t_i });
+    correctGates.push({ op: 'XOR', in1: t_i, in2: prev_carry, out: z_i });
+    correctGates.push({ op: 'AND', in1: x_i, in2: y_i, out: a_i });
+    correctGates.push({ op: 'AND', in1: t_i, in2: prev_carry, out: b_i });
+    correctGates.push({ op: 'OR', in1: a_i, in2: b_i, out: c_i });
+  }
+
+  // Final carry bit becomes the most significant bit of Z
+  if (maxBit >= 0) { // Only add if there was at least one bit
+    const final_carry_in_name = `c${maxBit.toString().padStart(2, '0')}`;
+    const final_z_out_name = `z${(maxBit + 1).toString().padStart(2, '0')}`;
+    correctGates.push({ op: 'XOR', in1: final_carry_in_name, in2: final_carry_in_name, out: final_z_out_name }); // This is a dummy gate just to get the wire name cN into zN+1
+  }
+
+  // 3. Create a mapping from (op, in1, in2) to 'correctOut'
+  const correctOutputMap = new Map<string, string>();
+  for (const correctGate of correctGates) {
+    const key = `${correctGate.op}-${correctGate.in1}-${correctGate.in2}`;
+    correctOutputMap.set(key, correctGate.out);
+  }
+
+  // 4. Identify Mismatched 'out' wires
+  const potentialSwappedWires = new Set<string>();
+  for (const inputGate of gates) {
+    const key = `${inputGate.op}-${inputGate.in1}-${inputGate.in2}`;
+    const expectedOut = correctOutputMap.get(key);
+
+    if (expectedOut && inputGate.out !== expectedOut) {
+      potentialSwappedWires.add(inputGate.out);
+      potentialSwappedWires.add(expectedOut);
+    }
+  }
+
+  // 5. Convert to array, sort, and return
+  const result = Array.from(potentialSwappedWires).sort();
+  return result;
+}
