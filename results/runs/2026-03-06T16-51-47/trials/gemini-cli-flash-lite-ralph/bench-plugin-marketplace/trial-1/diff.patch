+import { PluginVersion, PluginManifest, PluginGraph, RegistryService, DepsService, PluginContext } from './types.js'; // Import DepsService and PluginGraph
+
+// Represents an adjacency list for the graph
+type Graph = Map<string, Set<string>>;
+
+export class DependencyGraphBuilder implements DepsService { // Implement DepsService interface
+
+    // --- Methods to implement DepsService interface ---
+
+    buildTree(name: string, registry: RegistryService): PluginGraph | null {
+        const allPlugins = registry.list();
+        const allPluginVersions: PluginVersion[] = allPlugins.map(p => ({
+            name: p.name,
+            version: p.version,
+            description: p.description,
+            author: p.author,
+            dependencies: p.dependencies,
+            entryPoint: p.entryPoint,
+            permissions: p.permissions
+        }));
+        const graph = this.buildGraphFromPluginVersions(allPluginVersions);
+
+        // Recursive helper to build the tree structure
+        const buildNode = (nodeName: string): PluginGraph | null => {
+            if (!graph.has(nodeName)) {
+                return null; // Node not found in graph
+            }
+
+            const dependencies: PluginGraph[] = [];
+            const neighbors = graph.get(nodeName) || new Set();
+            for (const neighbor of neighbors) {
+                const depTree = buildNode(neighbor);
+                if (depTree) {
+                    dependencies.push(depTree);
+                }
+            }
+
+            // Assuming PluginGraph interface can represent a node with name, version, and dependencies
+            // The exact structure of PluginGraph is not fully defined here, so we'll use a placeholder.
+            // In a real scenario, PluginGraph would be a more complex interface like { name: string; version: string; dependencies: PluginGraph[]; }
