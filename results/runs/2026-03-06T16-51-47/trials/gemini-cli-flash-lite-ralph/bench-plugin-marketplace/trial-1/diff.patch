+import semver from 'semver';
+export class VersionResolver {
+    // This method might need access to all available plugin versions in the registry
+    // For now, let's assume it gets a list of all registered plugins.
+    addPluginVersions(availablePlugins, newPlugin) {
+        // In a real implementation, this would update the registry or a local cache
+        // For testing purposes, we'll just return a merged list.
+        const updatedPlugins = [...availablePlugins];
+        if (!updatedPlugins.some(p => p.name === newPlugin.name && p.version === newPlugin.version)) {
+            updatedPlugins.push(newPlugin);
+        }
+        return updatedPlugins;
+    }
+    getAvailableVersions(plugins, pluginName) {
+        return plugins.filter(p => p.name === pluginName);
+    }
+    resolveDependencies(allPlugins, targetPluginManifest) {
+        const resolved = {};
+        const constraints = targetPluginManifest.dependencies || {};
+        const availableVersions = this.getAvailableVersions(allPlugins, targetPluginManifest.name); // Get versions of the target plugin itself if needed for context
+        // Add target plugin to available versions for dependency resolution
+        const completePluginList = [...allPlugins, targetPluginManifest];
+        for (const depName in constraints) {
+            const constraintStr = constraints[depName];
+            const possibleVersions = this.getAvailableVersions(completePluginList, depName);
+            let bestMatch = null;
+            for (const version of possibleVersions) {
+                if (semver.satisfies(version.version, constraintStr, { includePrerelease: true })) {
+                    if (!bestMatch || semver.gt(version.version, bestMatch.version)) {
+                        bestMatch = version;
+                    }
+                }
+            }
+            if (!bestMatch) {
+                throw new Error(`Could not resolve dependency: ${depName}@${constraintStr}`);
+            }
+            resolved[depName] = bestMatch;
+        }
+        // Add the target plugin itself to the resolved list if it has a version constraint specified (though usually not)
+        // Or if we need to ensure it's included when resolving its own dependencies
+        // For now, assume resolved only contains explicit dependencies
+        return resolved;
+    }
+}
