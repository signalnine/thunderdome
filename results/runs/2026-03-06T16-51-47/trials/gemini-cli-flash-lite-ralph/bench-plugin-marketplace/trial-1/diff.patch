+import { DependencyGraphBuilder } from '../dependencyGraph.js'; // Assuming DependencyGraphBuilder is exported from dependencyGraph.ts
+// Helper function to create a mock plugin object for tests
+const createMockPlugin = (name, version) => ({
+    name,
+    version,
+    entryPoint: 'index.js',
+    dependencies: {},
+});
+describe('DependencyGraphBuilder', () => {
+    let graphBuilder;
+    beforeEach(() => {
+        graphBuilder = new DependencyGraphBuilder();
+    });
+    describe('getTopologicalOrder', () => {
+        it('should return a topological order for a simple DAG', () => {
+            const graph = new Map([
+                ['a', new Set(['b', 'c'])],
+                ['b', new Set(['d'])],
+                ['c', new Set(['d'])],
+                ['d', new Set()],
+            ]);
+            const order = graphBuilder.getTopologicalOrder(graph);
+            const orderMap = new Map(order.map((node, index) => [node, index]));
+            expect(orderMap.get('a')).toBeLessThan(orderMap.get('b'));
+            expect(orderMap.get('a')).toBeLessThan(orderMap.get('c'));
+            expect(orderMap.get('b')).toBeLessThan(orderMap.get('d'));
+            expect(orderMap.get('c')).toBeLessThan(orderMap.get('d'));
+        });
+        it('should return a topological order for a more complex DAG', () => {
+            const graph = new Map([
+                ['5', new Set(['2', '0'])],
+                ['4', new Set(['0', '1'])],
+                ['2', new Set(['3'])],
+                ['1', new Set(['3'])],
+                ['0', new Set()],
+                ['3', new Set()],
+            ]);
+            const order = graphBuilder.getTopologicalOrder(graph);
+            // Example valid order: [4, 5, 2, 1, 3, 0] or [5, 4, 2, 1, 3, 0] etc.
+            // Let's test a specific valid output and verify properties.
+            expect(order).toEqual(['5', '4', '2', '1', '3', '0']); // This specific order depends on iteration.
+            // Verify dependencies
+            const orderMap = new Map(order.map((node, index) => [node, index]));
+            expect(orderMap.get('5')).toBeLessThan(orderMap.get('2'));
+            expect(orderMap.get('5')).toBeLessThan(orderMap.get('0'));
+            expect(orderMap.get('4')).toBeLessThan(orderMap.get('0'));
+            expect(orderMap.get('4')).toBeLessThan(orderMap.get('1'));
+            expect(orderMap.get('2')).toBeLessThan(orderMap.get('3'));
+            expect(orderMap.get('1')).toBeLessThan(orderMap.get('3'));
+        });
+        it('should return an empty array for an empty graph', () => {
+            const graph = new Map();
+            expect(graphBuilder.getTopologicalOrder(graph)).toEqual([]);
+        });
+        it('should throw an error for a graph with a circular dependency', () => {
+            const graph = new Map([
+                ['a', new Set(['b'])],
+                ['b', new Set(['c'])],
+                ['c', new Set(['a'])], // Circular dependency
+            ]);
+            expect(() => graphBuilder.getTopologicalOrder(graph)).toThrow('Circular dependency detected');
+        });
+    });
+    describe('flattenTransitiveDependencies', () => {
+        it('should return an empty array if the plugin has no dependencies', () => {
+            const graph = new Map([
+                ['a', new Set()],
+            ]);
+            expect(graphBuilder.flattenTransitiveDependencies('a', graph)).toEqual([]);
+        });
+        it('should return direct dependencies if no transitive ones exist', () => {
+            const graph = new Map([
+                ['a', new Set(['b', 'c'])],
+                ['b', new Set()],
+                ['c', new Set()],
+            ]);
+            const deps = graphBuilder.flattenTransitiveDependencies('a', graph);
+            expect(deps).toEqual(expect.arrayContaining(['b', 'c']));
+            expect(deps).toHaveLength(2);
+        });
+        it('should flatten transitive dependencies', () => {
+            const graph = new Map([
+                ['a', new Set(['b'])],
+                ['b', new Set(['c'])],
+                ['c', new Set(['d'])],
+                ['d', new Set()],
+            ]);
+            const deps = graphBuilder.flattenTransitiveDependencies('a', graph);
+            expect(deps).toEqual(expect.arrayContaining(['b', 'c', 'd']));
+            expect(deps).toHaveLength(3);
+        });
+        it('should handle shared transitive dependencies', () => {
+            const graph = new Map([
+                ['a', new Set(['b', 'c'])],
+                ['b', new Set(['d'])],
+                ['c', new Set(['d'])], // 'd' is shared
+                ['d', new Set()],
+            ]);
+            const deps = graphBuilder.flattenTransitiveDependencies('a', graph);
+            expect(deps).toEqual(expect.arrayContaining(['b', 'c', 'd']));
+            expect(deps).toHaveLength(3); // Ensure 'd' is not duplicated in the flat list
+        });
+        it('should return null if the plugin is not in the graph', () => {
+            const graph = new Map([
+                ['a', new Set(['b'])],
+            ]);
+            expect(graphBuilder.flattenTransitiveDependencies('non-existent', graph)).toBeNull();
+        });
+        it('should handle complex graph with shared dependencies', () => {
+            const graph = new Map([
+                ['a', new Set(['b', 'c'])],
+                ['b', new Set(['d', 'e'])],
+                ['c', new Set(['e', 'f'])], // e is shared
+                ['d', new Set()],
+                ['e', new Set(['g'])],
+                ['f', new Set()],
+                ['g', new Set()],
+            ]);
+            const deps = graphBuilder.flattenTransitiveDependencies('a', graph);
+            expect(deps).toEqual(expect.arrayContaining(['b', 'c', 'd', 'e', 'f', 'g']));
+            expect(deps).toHaveLength(6);
+        });
+    });
+    describe('getPluginVersions', () => {
+        const pluginA_v1 = createMockPlugin('plugin-a', '1.0.0');
+        const pluginA_v2 = createMockPlugin('plugin-a', '2.0.0');
+        const pluginB_v1 = createMockPlugin('plugin-b', '1.0.0');
+        const allPlugins = [pluginA_v1, pluginA_v2, pluginB_v1];
+        it('should return versions for specified plugin names', () => {
+            const names = ['plugin-a', 'plugin-b'];
+            const found = graphBuilder.getPluginVersions(names, allPlugins);
+            expect(found).toHaveLength(2);
+            expect(found).toEqual(expect.arrayContaining([
+                expect.objectContaining({ name: 'plugin-a', version: '1.0.0' }), // Picks the first one
+                expect.objectContaining({ name: 'plugin-b', version: '1.0.0' })
+            ]));
+        });
+        it('should return empty array if no plugin names are provided', () => {
+            const names = [];
+            const found = graphBuilder.getPluginVersions(names, allPlugins);
+            expect(found).toEqual([]);
+        });
+        it('should return empty array if no plugins match names', () => {
+            const names = ['plugin-c', 'plugin-d'];
+            const found = graphBuilder.getPluginVersions(names, allPlugins);
+            expect(found).toEqual([]);
+        });
+        it('should handle cases where some plugins are not found', () => {
+            const names = ['plugin-a', 'plugin-c'];
+            const found = graphBuilder.getPluginVersions(names, allPlugins);
+            expect(found).toHaveLength(1);
+            expect(found[0]).toMatchObject({ name: 'plugin-a', version: '1.0.0' });
+        });
+    });
+});
