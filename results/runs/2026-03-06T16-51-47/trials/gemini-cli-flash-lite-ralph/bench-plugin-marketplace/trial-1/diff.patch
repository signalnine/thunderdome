+import vm from 'vm';
+export class SandboxedRunner {
+    async run(code, context, timeout) {
+        const sandboxContext = vm.createContext({
+            ...context,
+            // Add any global variables or functions that should be available in the sandbox
+            console: console, // Provide console access, but it might be proxied or limited
+            require: (moduleName) => {
+                // Limit or disallow require for security
+                // For this example, we'll throw an error, but a real implementation
+                // might allow specific, safe modules.
+                throw new Error(`Module "${moduleName}" cannot be required from the sandbox.`);
+            }
+        });
+        const startTime = Date.now();
+        let memoryBefore = 0;
+        let memoryAfter = 0;
+        let timedOut = false;
+        let executionError = null;
+        let scriptResult = undefined;
+        try {
+            // Get memory usage before execution
+            memoryBefore = process.memoryUsage().heapUsed;
+            const script = new vm.Script(code, {
+                filename: 'plugin.js', // For better stack traces
+            });
+            // Execute the script
+            scriptResult = script.runInContext(sandboxContext, {
+                timeout: timeout, // Use the same timeout for safety
+                displayErrors: true // Show errors in the sandbox context
+            });
+            // If the result is a Promise, await it
+            if (scriptResult instanceof Promise) {
+                scriptResult = await scriptResult;
+            }
+            memoryAfter = process.memoryUsage().heapUsed;
+        }
+        catch (error) {
+            memoryAfter = process.memoryUsage().heapUsed;
+            if (error.message.includes('timed out')) {
+                timedOut = true;
+            }
+            executionError = error;
+        }
+        finally {
+            const endTime = Date.now();
+            const duration = endTime - startTime;
+            return {
+                success: !executionError && !timedOut,
+                result: executionError ? null : scriptResult,
+                error: executionError ? { message: executionError.message, stack: executionError.stack } : null,
+                timing: {
+                    durationMs: duration,
+                    timeout: timeout,
+                    timedOut: timedOut
+                },
+                memory: {
+                    before: memoryBefore,
+                    after: memoryAfter,
+                    diff: memoryAfter - memoryBefore
+                }
+            };
+        }
+    }
+}
+//# sourceMappingURL=sandboxedRunner.js.map
