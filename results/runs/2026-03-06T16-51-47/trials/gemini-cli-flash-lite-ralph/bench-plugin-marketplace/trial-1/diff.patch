@@ -0,0 +1,45 @@
+import semver from 'semver';
+import { PluginVersion, VersionConstraint, ResolvedVersion, ResolverService } from './types.js'; // Import ResolverService interface
+
+export class VersionResolver implements ResolverService { // Implement ResolverService interface
+
+    // Implement ResolverService methods
+    resolve(constraints: VersionConstraint[], availablePluginsMap: Record<string, string[]>): ResolvedVersion[] {
+        const resolved: ResolvedVersion[] = [];
+
+        for (const constraint of constraints) {
+            const versions = availablePluginsMap[constraint.name] || [];
+            const bestMatchVersionStr = this.maxSatisfying(versions, constraint.range);
+
+            if (!bestMatchVersionStr) {
+                throw new Error(`Could not resolve dependency: ${constraint.name}@${constraint.range}`);
+            }
+
+            resolved.push({
+                name: constraint.name,
+                version: bestMatchVersionStr,
+                satisfies: constraint.range,
+            });
+        }
+        return resolved;
+    }
+
+    satisfies(version: string, range: string): boolean {
+        return semver.satisfies(version, range, { includePrerelease: true });
+    }
+
+    maxSatisfying(versions: string[], range: string): string | null {
+        return semver.maxSatisfying(versions, range, { includePrerelease: true });
+    }
+
+    validRange(range: string): boolean {
+        return semver.validRange(range) !== null;
+    }
+
+    // Existing methods like resolveDependencies are not part of the ResolverService interface.
+    // We will remove them or mark them as internal helpers if not directly used by the interface.
+    // For now, assuming they are not needed by the interface.
+    
+    // Removed addPluginVersions and getAvailableVersions as they are not part of the interface.
+    // resolveDependencies logic is partially incorporated into the new resolve method.
+}
