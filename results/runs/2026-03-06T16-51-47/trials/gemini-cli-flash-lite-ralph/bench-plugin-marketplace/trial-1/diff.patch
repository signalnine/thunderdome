+import Database from 'better-sqlite3';
+import { PluginManifest, PluginVersion, VersionConstraint, RegistryService } from './types.js'; // Import RegistryService
+
+const DB_PATH = '/tmp/.gemini/db/pluginMarketplace.db'; // Using a temporary directory for the DB
+
+export class PluginRegistry implements RegistryService { // Implement RegistryService interface
+    private db: Database.Database;
+
+    constructor() {
+        const dir = DB_PATH.substring(0, DB_PATH.lastIndexOf('/'));
+        // require('fs').mkdirSync(dir, { recursive: true }); // Assuming directory exists or handled by setup
+        
+        this.db = new Database(DB_PATH);
+        this.initializeDatabase();
+    }
+
+    private initializeDatabase() {
+        // Ensure table exists with columns matching PluginManifest/PluginVersion
+        this.db.exec(`
+            CREATE TABLE IF NOT EXISTS plugins (
+                id INTEGER PRIMARY KEY AUTOINCREMENT,
+                name TEXT NOT NULL,
+                version TEXT NOT NULL,
+                entryPoint TEXT NOT NULL,
+                dependencies TEXT NOT NULL, -- Store as JSON string
+                description TEXT DEFAULT '', -- Added for RegistryService compliance
+                author TEXT DEFAULT '',    -- Added for RegistryService compliance
+                permissions TEXT DEFAULT '[]', -- Added for RegistryService compliance
+                UNIQUE(name, version)
+            )
+        `);
+    }
+
+    // Implement RegistryService.register
+    register(manifest: PluginManifest): void {
+        const insert = this.db.prepare(
+            'INSERT INTO plugins (name, version, entryPoint, dependencies, description, author, permissions) VALUES (@name, @version, @entryPoint, @dependencies, @description, @author, @permissions)'
+        );
+        insert.run({
+            name: manifest.name,
+            version: manifest.version,
+            entryPoint: manifest.entryPoint,
+            dependencies: JSON.stringify(manifest.dependencies || []),
+            description: manifest.description || '',
+            author: manifest.author || '',
+            permissions: JSON.stringify(manifest.permissions || [])
+        });
+    }
+
+    // Implement RegistryService.get
+    get(name: string): PluginManifest | null {
+        // Return the latest version for a given plugin name, or null if not found
+        const row = this.db.prepare(
+            'SELECT name, version, entryPoint, dependencies, description, author, permissions FROM plugins WHERE name = ? ORDER BY version DESC'
+        ).get(name) as any;
+
+        if (!row) return null;
+
+        return {
+            name: row.name,
+            version: row.version,
+            entryPoint: row.entryPoint,
+            dependencies: JSON.parse(row.dependencies),
+            description: row.description,
+            author: row.author,
+            permissions: JSON.parse(row.permissions)
+        };
+    }
+
+    // Implement RegistryService.getVersion
+    getVersion(name: string, version: string): PluginManifest | null {
+        const row = this.db.prepare(
+            'SELECT name, version, entryPoint, dependencies, description, author, permissions FROM plugins WHERE name = ? AND version = ?'
+        ).get(name, version) as any;
+
+        if (!row) return null;
+
+        return {
+            name: row.name,
+            version: row.version,
+            entryPoint: row.entryPoint,
+            dependencies: JSON.parse(row.dependencies),
+            description: row.description,
+            author: row.author,
+            permissions: JSON.parse(row.permissions)
+        };
+    }
+
+    // Implement RegistryService.list
+    list(): PluginManifest[] {
+        const rows = this.db.prepare(
+            'SELECT name, version, entryPoint, dependencies, description, author, permissions FROM plugins'
+        ).all() as any[];
+
+        return rows.map(row => ({
+            name: row.name,
+            version: row.version,
+            entryPoint: row.entryPoint,
+            dependencies: JSON.parse(row.dependencies),
+            description: row.description,
+            author: row.author,
+            permissions: JSON.parse(row.permissions)
+        }));
+    }
+
+    // Implement RegistryService.search
+    search(query: string): PluginManifest[] {
+        // Basic search by name
+        const searchTerm = `%${query}%`;
+        const rows = this.db.prepare(
+            'SELECT name, version, entryPoint, dependencies, description, author, permissions FROM plugins WHERE name LIKE ?'
+        ).all(searchTerm) as any[];
+
+        return rows.map(row => ({
+            name: row.name,
+            version: row.version,
+            entryPoint: row.entryPoint,
+            dependencies: JSON.parse(row.dependencies),
+            description: row.description,
+            author: row.author,
+            permissions: JSON.parse(row.permissions)
+        }));
+    }
+
+    // Implement RegistryService.remove
+    remove(name: string, version: string): boolean {
+        const result = this.db.prepare(
+            'DELETE FROM plugins WHERE name = ? AND version = ?'
+        ).run(name, version);
+        return result.changes > 0;
+    }
+
+    // Implement RegistryService.listVersions
+    listVersions(name: string): string[] {
+        const rows = this.db.prepare(
+            'SELECT version FROM plugins WHERE name = ? ORDER BY version DESC'
+        ).all(name) as any[];
+        return rows.map(row => row.version);
+    }
+
+    // Implement RegistryService.update
+    update(name: string, version: string, updates: Partial<PluginManifest>): void {
+        const existingPlugin = this.getVersion(name, version); // Use getVersion to fetch existing data
+        if (!existingPlugin) {
+            throw new Error(`Plugin ${name}@${version} not found for update.`);
+        }
+
+        // Merge updates with existing data, ensuring required fields are present
+        const updatedPlugin: PluginManifest = {
+            ...existingPlugin,
+            ...updates,
+            name: name, // Ensure name and version are not overwritten by updates
+            version: version
+        };
+
+        // Update only fields that are directly stored in the DB
+        const updateFields: string[] = [];
+        const updateParams: any = { name, version };
+
+        if (updates.entryPoint !== undefined) {
+            updateFields.push('entryPoint = @entryPoint');
+            updateParams.entryPoint = updatedPlugin.entryPoint;
+        }
+        if (updates.dependencies !== undefined) {
+            updateFields.push('dependencies = @dependencies');
+            updateParams.dependencies = JSON.stringify(updatedPlugin.dependencies || []);
+        }
+        if (updates.description !== undefined) { // Added for fields that *are* stored
+            updateFields.push('description = @description');
+            updateParams.description = updatedPlugin.description || '';
+        }
+        if (updates.author !== undefined) { // Added for fields that *are* stored
+            updateFields.push('author = @author');
+            updateParams.author = updatedPlugin.author || '';
+        }
+        if (updates.permissions !== undefined) { // Added for fields that *are* stored
+            updateFields.push('permissions = @permissions');
+            updateParams.permissions = JSON.stringify(updatedPlugin.permissions || []);
+        }
+
+        if (updateFields.length === 0) {
+            // No updatable fields provided
+            return;
+        }
+
+        const updateStmt = this.db.prepare(
+            `UPDATE plugins SET ${updateFields.join(', ')} WHERE name = @name AND version = @version`
+        );
+        updateStmt.run(updateParams);
+    }
+    
+    close() {
+        this.db.close();
+    }
+}
