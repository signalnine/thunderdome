+export class DependencyGraph {
+    buildDependencyGraph(plugins) {
+        const graph = new Map();
+        // Initialize graph with all plugin names
+        plugins.forEach(plugin => {
+            if (!graph.has(plugin.name)) {
+                graph.set(plugin.name, new Set());
+            }
+            // Ensure all versions of a plugin are nodes in some way if needed,
+            // but for dependency *name* resolution, just the name is sufficient.
+            // If we need to track specific versions in the graph, the node key would need to be 'name@version'.
+            // For now, we'll use plugin name as the node identifier.
+        });
+        // Add edges based on dependencies
+        plugins.forEach(plugin => {
+            (plugin.dependencies || []).forEach(dep => {
+                // Add an edge from the plugin to its dependency
+                // Ensure the dependency name exists as a node (might not if it's not registered yet)
+                if (!graph.has(dep.name)) {
+                    graph.set(dep.name, new Set());
+                }
+                graph.get(plugin.name)?.add(dep.name);
+            });
+        });
+        return graph;
+    }
+    detectCircularDependencies(graph) {
+        const visiting = new Set();
+        const visited = new Set();
+        const cycles = [];
+        function dfs(node, path) {
+            visiting.add(node);
+            path.push(node);
+            const neighbors = graph.get(node) || new Set();
+            for (const neighbor of neighbors) {
+                if (visiting.has(neighbor)) {
+                    // Cycle detected
+                    const cycleStartIndex = path.indexOf(neighbor);
+                    cycles.push([...path.slice(cycleStartIndex), neighbor].join(' -> '));
+                    // Continue DFS to find all cycles, don't return immediately
+                }
+                else if (!visited.has(neighbor)) {
+                    if (dfs(neighbor, path)) {
+                        // Cycle found deeper, propagate true
+                        // but continue to find other cycles
+                    }
+                }
+            }
+            path.pop();
+            visiting.delete(node);
+            visited.add(node);
+            return cycles.length > 0; // Return true if any cycle was found during this DFS branch
+        }
+        for (const node of graph.keys()) {
+            if (!visited.has(node)) {
+                dfs(node, []);
+            }
+        }
+        return cycles.length > 0 ? cycles : null;
+    }
+    getTopologicalOrder(graph) {
+        const visiting = new Set();
+        const visited = new Set();
+        const order = [];
+        function dfs(node) {
+            visiting.add(node);
+            const neighbors = graph.get(node) || new Set();
+            for (const neighbor of neighbors) {
+                if (visiting.has(neighbor)) {
+                    // Cycle detected, cannot produce topological sort
+                    return true; // Indicate cycle found
+                }
+                if (!visited.has(neighbor)) {
+                    if (dfs(neighbor)) {
+                        return true; // Cycle found deeper
+                    }
+                }
+            }
+            visiting.delete(node);
+            visited.add(node);
+            order.push(node);
+            return false; // No cycle found in this branch
+        }
+        for (const node of graph.keys()) {
+            if (!visited.has(node)) {
+                if (dfs(node)) {
+                    return null; // Cycle detected
+                }
+            }
+        }
+        return order.reverse(); // Topological sort is reverse post-order
+    }
+    flattenTransitiveDependencies(pluginName, graph) {
+        const visited = new Set();
+        const transitiveDeps = [];
+        function dfs(node) {
+            visited.add(node);
+            const neighbors = graph.get(node) || new Set();
+            for (const neighbor of neighbors) {
+                if (!visited.has(neighbor)) {
+                    transitiveDeps.push(neighbor);
+                    dfs(neighbor);
+                }
+            }
+        }
+        if (graph.has(pluginName)) {
+            dfs(pluginName);
+            return transitiveDeps;
+        }
+        else {
+            return null; // Plugin not found in graph
+        }
+    }
+    // Helper to get specific plugin versions based on names from the graph
+    getPluginVersions(pluginNames, allPlugins) {
+        const pluginMap = new Map();
+        allPlugins.forEach(p => {
+            if (!pluginMap.has(p.name)) {
+                pluginMap.set(p.name, []);
+            }
+            pluginMap.get(p.name)?.push(p);
+        });
+        const foundPlugins = [];
+        pluginNames.forEach(name => {
+            if (pluginMap.has(name)) {
+                // For simplicity, if multiple versions exist, we just grab the first one.
+                // A real system might need more sophisticated version selection here
+                // or expect the Resolver to handle this pre-emptively.
+                // For graph *structure*, any valid version is fine.
+                foundPlugins.push(pluginMap.get(name)[0]);
+            }
+        });
+        return foundPlugins;
+    }
+}
