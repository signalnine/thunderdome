+import Database from 'better-sqlite3';
+const DB_PATH = '/tmp/.gemini/db/pluginMarketplace.db'; // Using a temporary directory for the DB
+export class PluginRegistry {
+    db;
+    constructor() {
+        // Ensure the directory exists if it doesn't
+        const dir = DB_PATH.substring(0, DB_PATH.lastIndexOf('/'));
+        // This would typically be handled by setup, but for self-containment here:
+        // require('fs').mkdirSync(dir, { recursive: true });
+        this.db = new Database(DB_PATH);
+        this.initializeDatabase();
+    }
+    initializeDatabase() {
+        this.db.exec(`
+            CREATE TABLE IF NOT EXISTS plugins (
+                id INTEGER PRIMARY KEY AUTOINCREMENT,
+                name TEXT NOT NULL UNIQUE,
+                version TEXT NOT NULL,
+                entryPoint TEXT NOT NULL,
+                dependencies TEXT NOT NULL, -- Store as JSON string
+                UNIQUE(name, version)
+            )
+        `);
+    }
+    addPlugin(manifest) {
+        const insert = this.db.prepare('INSERT INTO plugins (name, version, entryPoint, dependencies) VALUES (@name, @version, @entryPoint, @dependencies)');
+        insert.run({
+            name: manifest.name,
+            version: manifest.version,
+            entryPoint: manifest.entryPoint,
+            dependencies: JSON.stringify(manifest.dependencies || [])
+        });
+    }
+    getPlugin(name, version) {
+        const row = this.db.prepare('SELECT name, version, entryPoint, dependencies FROM plugins WHERE name = ? AND version = ?').get(name, version);
+        if (!row)
+            return null;
+        return {
+            name: row.name,
+            version: row.version,
+            entryPoint: row.entryPoint,
+            dependencies: JSON.parse(row.dependencies)
+        };
+    }
+    getAllPlugins() {
+        const rows = this.db.prepare('SELECT name, version, entryPoint, dependencies FROM plugins').all();
+        return rows.map(row => ({
+            name: row.name,
+            version: row.version,
+            entryPoint: row.entryPoint,
+            dependencies: JSON.parse(row.dependencies)
+        }));
+    }
+    searchPlugins(query) {
+        // Basic search by name
+        const searchTerm = `%${query}%`;
+        const rows = this.db.prepare('SELECT name, version, entryPoint, dependencies FROM plugins WHERE name LIKE ?').all(searchTerm);
+        return rows.map(row => ({
+            name: row.name,
+            version: row.version,
+            entryPoint: row.entryPoint,
+            dependencies: JSON.parse(row.dependencies)
+        }));
+    }
+    removePluginVersion(name, version) {
+        this.db.prepare('DELETE FROM plugins WHERE name = ? AND version = ?').run(name, version);
+    }
+    close() {
+        this.db.close();
+    }
+}
