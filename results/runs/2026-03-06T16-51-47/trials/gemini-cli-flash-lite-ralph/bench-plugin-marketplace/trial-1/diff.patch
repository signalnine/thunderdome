+import Database from 'better-sqlite3';
+import { Review, PluginVersionIdentifier, UserIdentifier } from './types.js';
+
+const DB_PATH = '/tmp/.gemini/db/reviewSystem.db'; // Using a temporary directory for the DB
+
+export class ReviewSystem {
+    private db: Database.Database;
+
+    constructor() {
+        // Ensure the directory exists if it doesn't
+        const dir = DB_PATH.substring(0, DB_PATH.lastIndexOf('/'));
+        // require('fs').mkdirSync(dir, { recursive: true });
+
+        this.db = new Database(DB_PATH);
+        this.initializeDatabase();
+    }
+
+    private initializeDatabase() {
+        this.db.exec(`
+            CREATE TABLE IF NOT EXISTS reviews (
+                id INTEGER PRIMARY KEY AUTOINCREMENT,
+                pluginName TEXT NOT NULL,
+                pluginVersion TEXT NOT NULL,
+                userId TEXT NOT NULL,
+                rating INTEGER NOT NULL CHECK(rating >= 1 AND rating <= 5),
+                comment TEXT,
+                isFlagged BOOLEAN NOT NULL DEFAULT 0,
+                createdAt DATETIME DEFAULT CURRENT_TIMESTAMP,
+                UNIQUE(pluginName, pluginVersion, userId)
+            )
+        `);
+    }
+
+    addReview(review: Review): void {
+        const insert = this.db.prepare(
+            'INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, isFlagged) VALUES (@pluginName, @pluginVersion, @userId, @rating, @comment, @isFlagged)'
+        );
+        insert.run({
+            pluginName: review.pluginName,
+            pluginVersion: review.pluginVersion,
+            userId: review.userId,
+            rating: review.rating,
+            comment: review.comment || '',
+            isFlagged: review.flagged ? 1 : 0 // Changed from isFlagged to flagged
+        });
+    }
+
+    getReviews(filter: { pluginName?: string; pluginVersion?: string; userId?: string; flagged?: boolean }): Review[] {
+        let query = 'SELECT id, pluginName, pluginVersion, userId, rating, comment, isFlagged, createdAt FROM reviews WHERE 1=1';
+        const params: any[] = [];
+
+        if (filter.pluginName !== undefined) {
+            query += ' AND pluginName = ?';
+            params.push(filter.pluginName);
+        }
+        if (filter.pluginVersion !== undefined) {
+            query += ' AND pluginVersion = ?';
+            params.push(filter.pluginVersion);
+        }
+        if (filter.userId !== undefined) {
+            query += ' AND userId = ?';
+            params.push(filter.userId);
+        }
+        if (filter.flagged !== undefined) {
+            query += ` AND isFlagged = ?`;
+            params.push(filter.flagged ? 1 : 0);
+        }
+
+        query += ' ORDER BY createdAt DESC';
+
+        const rows = this.db.prepare(query).all(params) as any[];
+
+        // Fixing the type error: createdAt is likely a string from DB, convert to Date
+        return rows.map(row => ({
+            id: row.id,
+            pluginName: row.pluginName,
+            pluginVersion: row.pluginVersion,
+            userId: row.userId,
+            rating: row.rating,
+            comment: row.comment,
+            flagged: !!row.isFlagged, // Changed from isFlagged to flagged
+            createdAt: row.createdAt
+        }));
+    }
+
+    flagReview(reviewId: number): void {
+        this.db.prepare('UPDATE reviews SET isFlagged = 1 WHERE id = ?').run(reviewId);
+    }
+
+    computeAverageRating(pluginName: string, pluginVersion: string): number | null {
+        const row = this.db.prepare(
+            'SELECT AVG(rating) as avgRating FROM reviews WHERE pluginName = ? AND pluginVersion = ? AND isFlagged = 0'
+        ).get(pluginName, pluginVersion) as any;
+
+        if (!row || row.avgRating === null) {
+            return null;
+        }
+        return parseFloat(row.avgRating.toFixed(2)); // Return as float with 2 decimal places
+    }
+
+    close() {
+        this.db.close();
+    }
+}
