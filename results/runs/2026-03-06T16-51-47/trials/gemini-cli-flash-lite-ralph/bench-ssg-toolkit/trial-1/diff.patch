+import { Plugin, BuildContext, ContentFile, PluginHooks } from '../core/types.js';
+// We might need syntax-highlight for text extraction, but markdown-ext should provide sufficient HTML
+// If direct text extraction from markdown is needed, markdown-ext's transformContent hook
+// could be modified to return plain text or a helper function could be used.
+// For simplicity, we'll assume we can work with the 'content' field which is HTML after markdown-ext.
+
+const PLUGIN_NAME = 'search-index';
+const SEARCH_INDEX_FILENAME = 'search-index.json';
+
+// A simplified search index structure:
+// {
+//   pages: [
+//     { slug: '...', title: '...', content: '...' },
+//     ...
+//   ]
+// }
+interface SearchIndex {
+  pages: Array<{ slug: string; title: string; content: string; }>;
+}
+
+const searchIndexHooks: PluginHooks = {
+  afterBuild: async (ctx: BuildContext): Promise<void> => {
+    const searchIndex: SearchIndex = { pages: [] };
+
+    // Iterate through all content files that have been processed
+    for (const file of ctx.files) {
+      // Only include pages that are likely to be searchable (e.g., not error pages, etc.)
+      // For now, we include all rendered pages.
+      // We should ensure the content is plain text or suitable for indexing.
+      // If 'content' is HTML, we might need to strip HTML tags.
+      // A more robust solution would strip HTML tags here.
+
+      // Basic HTML stripping (simplistic, might need a library for robustness)
+      let plainTextContent = file.content;
+      if (typeof file.content === 'string' && file.content.includes('<')) {
+        // Remove HTML tags, normalize whitespace, and trim
+        plainTextContent = file.content
+          .replace(/<[^>]*>/g, ' ') // Replace tags with spaces to ensure separation
+          .replace(/\s+/g, ' ')     // Normalize multiple whitespace characters to a single space
+          .trim();                 // Trim leading/trailing whitespace
+      }
+
+      searchIndex.pages.push({
+        slug: file.slug,
+        title: file.title,
+        content: plainTextContent,
+      });
+    }
+
+    // Sort pages by slug for consistency, or by date if available and preferred
+    searchIndex.pages.sort((a, b) => a.slug.localeCompare(b.slug));
+
+    // Generate the JSON index
+    const indexJson = JSON.stringify(searchIndex, null, 2);
+
+    // Add the search index file to the output
+    ctx.output.set(SEARCH_INDEX_FILENAME, indexJson);
+  },
+};
+
+export const createSearchIndexPlugin = (): Plugin => {
+  return {
+    name: PLUGIN_NAME,
+    version: '1.0.0',
+    // Depends on markdown-ext for content processing and potentially syntax-highlight
+    // if we need to ensure plain text extraction.
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: searchIndexHooks,
+  };
+};
