@@ -0,0 +1,114 @@
+import { Plugin, BuildContext, ContentFile, PluginHooks } from '../core/types.js';
+import path from 'path';
+import { marked } from 'marked'; // For rendering tag pages if needed
+
+const PLUGIN_NAME = 'taxonomy';
+const TAG_PAGE_TEMPLATE = 'tag'; // Assumes a 'tag.html' template exists
+const CATEGORY_PAGE_TEMPLATE = 'category'; // Assumes a 'category.html' template exists
+
+// Interface for the structured taxonomy data
+interface TaxonomyData {
+  tags: Record<string, ContentFile[]>;
+  categories: Record<string, ContentFile[]>;
+}
+
+const taxonomyHooks: PluginHooks = {
+  // This hook runs before build to collect all taxonomy data from content files
+  beforeBuild: async (ctx: BuildContext): Promise<void> => {
+    const tags: Record<string, ContentFile[]> = {};
+    const categories: Record<string, ContentFile[]> = {};
+
+    // Iterate over all content files to extract tags and categories
+    for (const file of ctx.files) {
+      // Ensure tags and categories are arrays of strings
+      const fileTags = Array.isArray(file.metadata.tags) ? file.metadata.tags.map(String) : [];
+      const fileCategories = Array.isArray(file.metadata.categories) ? file.metadata.categories.map(String) : [];
+
+      for (const tag of fileTags) {
+        if (!tags[tag]) {
+          tags[tag] = [];
+        }
+        tags[tag].push(file);
+      }
+
+      for (const category of fileCategories) {
+        if (!categories[category]) {
+          categories[category] = [];
+        }
+        categories[category].push(file);
+      }
+    }
+
+    // Store the collected taxonomy data in the build context's data map
+    // This can be used by other plugins (e.g., rss-feed, sitemap)
+    ctx.data.set(PLUGIN_NAME, { tags, categories });
+  },
+
+  // This hook runs after all content has been processed and rendered,
+  // allowing us to generate tag and category index pages.
+  afterBuild: async (ctx: BuildContext): Promise<void> => {
+    const taxonomyData = ctx.data.get(PLUGIN_NAME) as TaxonomyData | undefined;
+
+    if (!taxonomyData) {
+      console.warn(`${PLUGIN_NAME}: No taxonomy data found. Skipping page generation.`);
+      return;
+    }
+
+    const { tags, categories } = taxonomyData;
+
+    // Generate Tag Pages
+    for (const [tagName, files] of Object.entries(tags)) {
+      const pageTitle = `Posts tagged "${tagName}"`;
+      const pageContent = `<h1>Posts tagged "${tagName}"</h1><ul>${files.map(file =>
+        `<li><a href="/${file.slug}.html">${file.title}</a></li>`
+      ).join('')}</ul>`;
+
+      const tagPageFile: ContentFile = {
+        slug: `tag/${tagName.toLowerCase().replace(/\s+/g, '-')}`, // e.g., tag/technology
+        title: pageTitle,
+        content: pageContent,
+        metadata: {
+          tagName: tagName,
+          tagPosts: files.map(f => ({ slug: f.slug, title: f.title, date: f.date })),
+        },
+        template: TAG_PAGE_TEMPLATE, // Use a specific template for tag pages
+      };
+      ctx.files.push(tagPageFile); // Add the generated file to the context for rendering
+    }
+
+    // Generate Category Pages
+    for (const [categoryName, files] of Object.entries(categories)) {
+      const pageTitle = `Category: "${categoryName}"`;
+      const pageContent = `<h1>Category: "${categoryName}"</h1><ul>${files.map(file =>
+        `<li><a href="/${file.slug}.html">${file.title}</a></li>`
+      ).join('')}</ul>`;
+
+      const categoryPageFile: ContentFile = {
+        slug: `category/${categoryName.toLowerCase().replace(/\s+/g, '-')}`, // e.g., category/web-development
+        title: pageTitle,
+        content: pageContent,
+        metadata: {
+          categoryName: categoryName,
+          categoryPosts: files.map(f => ({ slug: f.slug, title: f.title, date: f.date })),
+        },
+        template: CATEGORY_PAGE_TEMPLATE, // Use a specific template for category pages
+      };
+      ctx.files.push(categoryPageFile); // Add the generated file to the context for rendering
+    }
+
+    // Note: The actual rendering of these generated files will happen in the engine's
+    // main loop after all plugins have run their afterBuild hooks.
+    // If these pages should be rendered *by* this plugin, the logic would need to be
+    // integrated into the main rendering loop or have a post-processing step.
+    // For now, we add them to ctx.files, assuming the engine will pick them up.
+  },
+};
+
+export const createTaxonomyPlugin = (): Plugin => {
+  return {
+    name: PLUGIN_NAME,
+    version: '1.0.0',
+    dependencies: [], // No dependencies for this wave
+    hooks: taxonomyHooks,
+  };
+};
