@@ -0,0 +1,115 @@
+import { Plugin, BuildContext, ContentFile, PluginHooks } from '../core/types.js';
+import { TaxonomyData } from './taxonomy.js'; // Assuming taxonomy plugin exports its data structure
+
+const PLUGIN_NAME = 'rss-feed';
+const RSS_FEED_FILENAME = 'rss.xml';
+
+// Helper to format date for RSS feed (RFC 822)
+function formatRssDate(dateString?: string): string {
+  if (!dateString) {
+    return new Date().toUTCString(); // Fallback to current date
+  }
+  try {
+    const date = new Date(dateString);
+    // Format: 'ddd, DD MMM YYYY HH:MM:SS GMT'
+    return date.toUTCString();
+  } catch (e) {
+    console.error(`Invalid date format for RSS: ${dateString}. Using current date.`);
+    return new Date().toUTCString();
+  }
+}
+
+// Helper to generate a basic RSS 2.0 XML string
+function generateRssXml(siteConfig: any, posts: ContentFile[]): string {
+  const now = new Date();
+  const rssDate = now.toUTCString();
+
+  const itemsXml = posts.map(post => `
+    <item>
+      <title>${escapeXml(post.title)}</title>
+      <link>${siteConfig.baseUrl.replace(/\/$/, '')}/${post.slug}.html</link>
+      <pubDate>${formatRssDate(post.date)}</pubDate>
+      <description>${escapeXml(post.content.substring(0, 200) + '...')}</description>
+      <guid isPermaLink="true">${siteConfig.baseUrl.replace(/\/$/, '')}/${post.slug}.html</guid>
+      ${(post.metadata.tags || []).map((tag: string) => `<category>${escapeXml(tag)}</category>`).join('')}
+    </item>
+  `).join('');
+
+  return `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
+  <channel>
+    <title>${escapeXml(siteConfig.title)}</title>
+    <link>${siteConfig.baseUrl}</link>
+    <description>Recent posts from ${escapeXml(siteConfig.title)}</description>
+    <language>en-us</language>
+    <lastBuildDate>${rssDate}</lastBuildDate>
+    <atom:link href="${siteConfig.baseUrl.replace(/\/$/, '')}/${RSS_FEED_FILENAME}" rel="self" type="application/rss+xml" />
+    ${itemsXml}
+  </channel>
+</rss>
+  `;
+}
+
+// Basic XML escaping
+function escapeXml(unsafe: string): string {
+  return unsafe.replace(/[<>&'"]/g, (c) => {
+    switch (c) {
+      case '<': return '&lt;';
+      case '>': return '&gt;';
+      case '&': return '&amp;';
+      case "'": return '&apos;';
+      case '"': return '&quot;';
+      default: return c;
+    }
+  });
+}
+
+const rssFeedHooks: PluginHooks = {
+  afterBuild: async (ctx: BuildContext): Promise<void> => {
+    // Get taxonomy data (specifically tags and all posts)
+    const taxonomyData = ctx.data.get('taxonomy') as TaxonomyData | undefined;
+
+    if (!taxonomyData) {
+      console.warn(`${PLUGIN_NAME}: Taxonomy data not found. Cannot generate RSS feed.`);
+      return;
+    }
+
+    // Get all posts, sorted by date if possible.
+    // For simplicity, we'll just take all posts associated with tags.
+    // A more robust implementation would sort all content files by date.
+    let allPosts: ContentFile[] = [];
+    for (const tag in taxonomyData.tags) {
+      allPosts.push(...taxonomyData.tags[tag]);
+    }
+    // Deduplicate posts and sort by date (most recent first)
+    const uniquePosts = Array.from(new Map(allPosts.map(post => [post.slug, post])).values());
+    uniquePosts.sort((a, b) => {
+      const dateA = a.date ? new Date(a.date) : new Date(0);
+      const dateB = b.date ? new Date(b.date) : new Date(0);
+      return dateB.getTime() - dateA.getTime();
+    });
+
+    // Limit the number of posts in the feed (e.g., last 10)
+    const feedPosts = uniquePosts.slice(0, 10);
+
+    if (feedPosts.length === 0) {
+      console.warn(`${PLUGIN_NAME}: No posts found to generate RSS feed.`);
+      return;
+    }
+
+    // Generate the RSS XML
+    const rssXml = generateRssXml(ctx.config, feedPosts);
+
+    // Add the RSS feed file to the output
+    ctx.output.set(RSS_FEED_FILENAME, rssXml);
+  },
+};
+
+export const createRssFeedPlugin = (): Plugin => {
+  return {
+    name: PLUGIN_NAME,
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'markdown-ext'], // Depends on taxonomy for data and markdown-ext for content rendering if needed
+    hooks: rssFeedHooks,
+  };
+};
