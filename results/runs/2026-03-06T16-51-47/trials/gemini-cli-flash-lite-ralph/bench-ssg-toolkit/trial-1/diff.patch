+  const hooks = {
+    transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+      if (file.content && typeof file.content === 'string') {
+        // Use marked.parse to transform markdown to HTML.
+        // For now, we assume basic markdown transformation.
+        // Footnotes and admonitions are not yet implemented in this basic version.
+        const htmlContent = marked.parse(file.content);
+        return {
+          ...file,
+          content: htmlContent ?? '', // Ensure content is a string, even if marked.parse returns null/undefined
