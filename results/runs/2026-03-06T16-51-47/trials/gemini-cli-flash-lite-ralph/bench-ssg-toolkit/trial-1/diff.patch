@@ -0,0 +1,109 @@
+import { Plugin, BuildContext, ContentFile, PluginHooks } from '../core/types.js';
+import { TaxonomyData } from './taxonomy.js'; // Assuming taxonomy plugin exports its data structure
+import { RssFeedData } from './rss-feed.js'; // Assuming rss-feed plugin might expose some data
+
+const PLUGIN_NAME = 'sitemap';
+const SITEMAP_FILENAME = 'sitemap.xml';
+
+// Helper to format date for sitemap.xml (ISO 8601 YYYY-MM-DD)
+function formatSitemapDate(dateString?: string): string {
+  if (!dateString) {
+    // If no dateString is provided, use the current date from the mocked Date object.
+    return new Date().toISOString().split('T')[0];
+  }
+  const date = new Date(dateString);
+  // Check if the date is valid. If not, use the fallback date.
+  if (isNaN(date.getTime())) {
+    console.error(`Invalid date format for sitemap: ${dateString}. Using fallback date.`);
+    // Use the fallback date, which is the current date from the mocked Date object.
+    return new Date().toISOString().split('T')[0];
+  }
+  return date.toISOString().split('T')[0]; // YYYY-MM-DD
+}
+
+// Helper to generate a basic sitemap.xml string
+function generateSitemapXml(siteConfig: any, pages: ContentFile[]): string {
+  // The 'new Date()' here should use the mocked Date object.
+  const sitemapGenerationDate = new Date().toISOString().split('T')[0]; 
+
+  const urlEntries = pages.map(page => {
+    // Ensure absolute URLs
+    const loc = `${siteConfig.baseUrl.replace(/\/$/, '')}/${page.slug}.html`;
+    const pageDate = formatSitemapDate(page.date);
+    return `
+    <url>
+      <loc>${loc}</loc>
+      <lastmod>${pageDate}</lastmod>
+      <changefreq>weekly</changefreq>
+      <priority>0.8</priority>
+    </url>
+    `;
+  }).join('');
+
+  return `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+  ${urlEntries}
+</urlset>
+  `;
+}
+
+const sitemapHooks: PluginHooks = {
+  afterBuild: async (ctx: BuildContext): Promise<void> => {
+    // To generate a sitemap, we need a list of all generated page URLs.
+    // The 'ctx.files' contains the original files plus any generated by plugins *before* rendering.
+    // After rendering, the final output URLs are in 'ctx.output'.
+    // We should collect all slugs that will result in HTML pages.
+    // The taxonomy plugin and other page-generating plugins add to ctx.files.
+    // The engine will render these into ctx.output.
+
+    // For simplicity, we'll iterate through the files that are *intended* to be rendered as HTML.
+    // A more robust approach might inspect ctx.output keys or have a specific way to mark "renderable" pages.
+    const pageSlugs = new Set<string>();
+
+    // Add slugs from original files
+    ctx.files.forEach(file => {
+      if (!file.slug.endsWith('.html')) { // Assuming .html is the default extension
+         pageSlugs.add(file.slug);
+      }
+    });
+
+    // Note: The taxonomy plugin adds new files to ctx.files. We need to ensure those are considered.
+    // The current implementation of taxonomy adds files to ctx.files, which will be rendered by the engine.
+
+    // Construct ContentFile objects from slugs for sitemap generation.
+    // We need at least slug and date. Title and content are less critical for sitemap itself.
+    const pagesForSitemap: ContentFile[] = Array.from(pageSlugs).map(slug => {
+      // Find the original file object to get date and title.
+      // This assumes slug uniqueness and that files added by other plugins are also in ctx.files.
+      const originalFile = ctx.files.find(f => f.slug === slug);
+      return {
+        slug: slug,
+        title: originalFile?.title || slug, // Fallback title
+        content: '', // Not needed for sitemap
+        metadata: {},
+        date: originalFile?.date, // Use the date from the original file
+      };
+    });
+
+    if (pagesForSitemap.length === 0) {
+      console.warn(`${PLUGIN_NAME}: No pages found to generate sitemap.`);
+      return;
+    }
+
+    // Generate the sitemap XML
+    const sitemapXml = generateSitemapXml(ctx.config, pagesForSitemap);
+
+    // Add the sitemap file to the output
+    ctx.output.set(SITEMAP_FILENAME, sitemapXml);
+  },
+};
+
+export const createSitemapPlugin = (): Plugin => {
