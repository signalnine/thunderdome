+import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';
 import { NotFoundError, ValidationError } from './errors.js';
 
+// Constants for search functionality
+const PER_PAGE = 20;
+const SNIPPET_TOKEN_CHARS = '.,!?;:()"\'\\n\\t<>{}[]@#$%^&*+='; // Note: \n needs to be escaped for string literal
+const SNIPPET_MAX_TEXT_LENGTH = 200;
+const SNIPPET_MAX_TOKENS = 20;
+
 export function createRoutes(db: Database.Database): Router {
   const router = Router();
 
@@ -118,5 +124,97 @@ export function createRoutes(db: Database.Database): Router {
     }
   });
 
+  // GET /notes/search - Full-text search notes
+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const query = req.query.q as string | undefined;
+      if (!query || query.trim() === '') {
+        throw new ValidationError('Search query "q" is required');
+      }
+
+      const page = parseInt(req.query.page as string) || 1;
+      const offset = (page - 1) * PER_PAGE;
+
+      // FTS query for search, including ranking, snippets, and pagination
+      const searchStmt = db.prepare(`
+        SELECT
+          notes.id,
+          notes.title,
+          bm25(notes_fts) AS rank,
+          snippets(?, ?, ?, ?, ?, ?) AS snippet -- FTS5 snippets function parameters: query, token_chars, text_length, max_tokens, prefix, suffix
+        FROM notes
+        JOIN notes_fts ON notes.id = notes_fts.rowid -- Join to get original note details
+        WHERE notes_fts MATCH ? -- Perform the FTS search
+        ORDER BY rank DESC -- Order by relevance
+        LIMIT ? OFFSET ? -- Paginate results
+      `);
+
+      // Prepare parameters for the search statement
+      const searchParams = [
+        query, // Parameter 1 for snippets: the search query string
+        SNIPPET_TOKEN_CHARS, // Parameter 2 for snippets: characters defining token boundaries
+        SNIPPET_MAX_TEXT_LENGTH, // Parameter 3 for snippets: maximum text length for snippet
+        SNIPPET_MAX_TOKENS, // Parameter 4 for snippets: maximum number of tokens in snippet
+        '<strong>', // Parameter 5 for snippets: highlight prefix
+        '</strong>', // Parameter 6 for snippets: highlight suffix
+        query, // Parameter 7 for MATCH operator: the search query string
+        PER_PAGE, // Parameter 8 for LIMIT
+        offset // Parameter 9 for OFFSET
+      ];
+
+      const searchResults = searchStmt.all(...searchParams) as SearchResult[];
+
+      // Statement to get the total count of matching notes
+      const totalStmt = db.prepare(`
+        SELECT COUNT(*) AS total FROM notes_fts WHERE notes_fts MATCH ?
+      `);
+      const totalResult = totalStmt.get(query) as { total: number }; // Pass query for MATCH
+
+      res.json({
+        results: searchResults,
+        total: totalResult.total,
+        page: page,
+        perPage: PER_PAGE,
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /notes/search/suggest - Suggest note titles based on prefix
+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const prefix = req.query.q as string | undefined;
+      if (!prefix || prefix.trim() === '') {
+        throw new ValidationError('Search prefix "q" is required');
+      }
+
+      // FTS query for suggestions, matching title with prefix.
+      // Use prefix search syntax like 'prefix*'
+      const suggestStmt = db.prepare(`
+        SELECT
+          notes.id,
+          notes.title
+        FROM notes
+        JOIN notes_fts ON notes.id = notes_fts.rowid
+        WHERE notes_fts.title MATCH ? -- Use placeholder for the prefix search pattern
+        LIMIT ?
+      `);
+
+      // Prepare parameters for the suggest statement
+      const suggestParams = [
+        `${prefix}*`, // Parameter 1: The prefix search pattern (e.g., "python*")
+        5 // Parameter 2: LIMIT to 5 suggestions
+      ];
+
+      const suggestions = suggestStmt.all(...suggestParams) as SuggestResult[];
+
+      res.json({ results: suggestions });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+
   return router;
 }
