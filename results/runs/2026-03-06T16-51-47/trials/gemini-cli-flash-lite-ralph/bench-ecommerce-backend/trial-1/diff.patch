+import { vi, describe, it, expect, beforeEach, SpyInstance } from 'vitest';
+import { EventBus, PaymentService, PaymentProcessedEvent, Events } from '../types';
+import { createPaymentService } from './index';
+
+// Mock EventBus
+const mockEventBus = {
+  emit: vi.fn(),
+  on: vi.fn(),
+  off: vi.fn(),
+  clear: vi.fn(),
+  getLog: vi.fn(),
+} as unknown as EventBus;
+
+// Mock setTimeout to control time-based behavior
+let mockSetTimeout: SpyInstance;
+
+describe('PaymentService', () => {
+  let paymentService: PaymentService;
+  let orderId: string;
+  let transactionId: string | undefined;
+
+  beforeEach(() => {
+    vi.clearAllMocks();
+    orderId = 'order_xyz';
+  });
+
+  // Helper to advance timers if needed
+  const advanceTimers = (ms: number) => {
+    mockSetTimeout.mock.calls.forEach(call => {
+      const callback = call[0];
+      if (call[1] === ms) {
+        callback();
+      }
+    });
+  };
+
+  it('should process payment successfully by default and emit PaymentProcessedEvent', async () => {
+    paymentService = createPaymentService(mockEventBus); // Default options simulateSuccess = true
+    const result = await paymentService.processPayment(orderId, 100);
+
+    expect(result.status).toBe('success');
+    expect(result.transactionId).toBeDefined();
+    transactionId = result.transactionId;
+
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(1);
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.PAYMENT_PROCESSED, {
+      orderId: orderId,
+      status: 'success',
+      transactionId: transactionId,
+      error: undefined,
+    });
+  });
+
+  it('should simulate payment failure and emit PaymentProcessedEvent', async () => {
+    paymentService = createPaymentService(mockEventBus, { simulateFailure: true });
+    const result = await paymentService.processPayment(orderId, 100);
+
+    expect(result.status).toBe('failed');
+    expect(result.transactionId).toBeDefined();
+    transactionId = result.transactionId;
+    expect(result.error).toBe('Simulated payment failure');
+
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(1);
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.PAYMENT_PROCESSED, {
+      orderId: orderId,
+      status: 'failed',
+      transactionId: transactionId,
+      error: 'Simulated payment failure',
+    });
+  });
+
+  it('should simulate payment timeout and emit PaymentProcessedEvent', async () => {
+    // Mock setTimeout to control the timeout
+    mockSetTimeout = vi.spyOn(global, 'setTimeout');
+    const timeoutDuration = 100; // ms
+    paymentService = createPaymentService(mockEventBus, { simulateTimeout: true, timeoutDuration });
+
+    // Don't await here, as it will hang without advancing timers
+    const processPromise = paymentService.processPayment(orderId, 100);
+
+    // Advance timers to simulate the timeout
+    advanceTimers(timeoutDuration);
+
+    const result = await processPromise;
+
+    expect(result.status).toBe('timeout');
+    expect(result.transactionId).toBeDefined();
+    transactionId = result.transactionId;
+    expect(result.error).toBe('Simulated payment timeout');
+
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(1);
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.PAYMENT_PROCESSED, {
+      orderId: orderId,
+      status: 'timeout',
+      transactionId: transactionId,
+      error: 'Simulated payment timeout',
+    });
+
+    // Restore setTimeout
+    mockSetTimeout.mockRestore();
+  });
+
+  it('should process payment successfully even if simulateFailure and simulateTimeout are false', async () => {
+    paymentService = createPaymentService(mockEventBus, { simulateFailure: false, simulateTimeout: false });
+    const result = await paymentService.processPayment(orderId, 100);
+
+    expect(result.status).toBe('success');
+    transactionId = result.transactionId;
+
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(1);
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.PAYMENT_PROCESSED, expect.objectContaining({ status: 'success' }));
+  });
+
+  it('should process payment successfully when simulateSuccess is true (default)', async () => {
+    paymentService = createPaymentService(mockEventBus, { simulateSuccess: true });
+    const result = await paymentService.processPayment(orderId, 100);
+
+    expect(result.status).toBe('success');
+    transactionId = result.transactionId;
+
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(1);
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.PAYMENT_PROCESSED, expect.objectContaining({ status: 'success' }));
+  });
+
+  it('should refund a successful transaction', async () => {
+    // First, process a successful payment to get a transaction ID
+    paymentService = createPaymentService(mockEventBus); // Default success
+    const initialResult = await paymentService.processPayment(orderId, 100);
+    transactionId = initialResult.transactionId!;
+
+    // Now, attempt to refund
+    // Cast to 'any' to access refund method which is internal and not on interface, but available in implementation.
+    const refundSuccess = await (paymentService as any).refund(transactionId);
+    expect(refundSuccess).toBe(true);
+    // In a real test, you might check that the internal transaction map is updated.
+  });
+
+  it('should not refund a transaction that is already refunded or failed', async () => {
+    // Process a successful payment
+    paymentService = createPaymentService(mockEventBus);
+    const initialResult = await paymentService.processPayment(orderId, 100);
+    transactionId = initialResult.transactionId!;
+
+    // Refund it once
+    await (paymentService as any).refund(transactionId);
+
+    // Try to refund again
+    const refundSuccessAgain = await (paymentService as any).refund(transactionId);
+    expect(refundSuccessAgain).toBe(false);
+
+    // Try to refund a non-existent transaction
+    const nonExistentRefund = await (paymentService as any).refund('txn_999');
+    expect(nonExistentRefund).toBe(false);
+  });
+
