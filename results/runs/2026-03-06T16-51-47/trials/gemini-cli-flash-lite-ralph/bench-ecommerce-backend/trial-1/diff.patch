+
+    analyticsService = createAnalyticsService(mockEventBus as EventBus);
+    // Emit only order created events
+    mockEventBus.emit!(Events.ORDER_CREATED, { orderId: orderId1, userId: userId1, cartId: cartId1, total: 100 } as OrderCreatedEvent);
+    expect(analyticsService.getConversionRate()).toBe(0);
+  });
+
+  it('should return an empty array for top products as data is not available', () => {
+    expect(analyticsService.getTopProducts(5)).toEqual([]);
+  });
+});
