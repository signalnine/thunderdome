+import { vi, describe, it, expect, beforeEach } from 'vitest';
+import { EventBus, PricingService, PriceCalculatedEvent, Events, ProductCreatedEvent } from '../types';
+import { createPricingService } from './index';
+
+// Mock EventBus for testing with explicit listener management
+const mockEventBus: Partial<EventBus> = {};
+let eventListeners: Record<string, ((event: any) => void)[]> = {}; // Use let so it can be reset
+
+mockEventBus.on = vi.fn((event: string, handler: (event: any) => void) => {
+  if (!eventListeners[event]) {
+    eventListeners[event] = [];
+  }
+  eventListeners[event].push(handler);
+});
+
+mockEventBus.emit = vi.fn((event: string, payload: any) => {
+  if (eventListeners[event]) {
+    eventListeners[event].forEach(handler => handler(payload));
+  }
+});
+
+mockEventBus.off = vi.fn();
+mockEventBus.getLog = vi.fn().mockReturnValue([]);
+mockEventBus.clear = vi.fn(() => {
+  // Clear listeners and spies managed by this mock
+  Object.keys(eventListeners).forEach(key => delete eventListeners[key]);
+  // Do NOT call vi.clearAllMocks() here, as it would clear the vi.fn() assignments below.
+});
+
+describe('PricingService', () => {
+  let pricingService: PricingService;
+
+  beforeEach(() => {
+    // Clear all Vitest spies first.
+    vi.clearAllMocks();
+
+    // Reset the internal state of our mock event bus (listeners map).
+    eventListeners = {};
+
+    // Re-assign the vi.fn() spies for mockEventBus methods.
+    // These spies will now interact with the reset eventListeners map.
+    mockEventBus.on = vi.fn((event: string, handler: (event: any) => void) => {
+      if (!eventListeners[event]) {
+        eventListeners[event] = [];
+      }
+      eventListeners[event].push(handler);
+    });
+    mockEventBus.emit = vi.fn((event: string, payload: any) => {
+      if (eventListeners[event]) {
+        eventListeners[event].forEach(handler => handler(payload));
+      }
+    });
+    mockEventBus.off = vi.fn();
+    mockEventBus.getLog = vi.fn().mockReturnValue([]);
+    mockEventBus.clear = vi.fn(() => {
+      Object.keys(eventListeners).forEach(key => delete eventListeners[key]);
+    });
+
+    // Create the service with the mock bus. This registers its handlers.
+    pricingService = createPricingService(mockEventBus as EventBus);
+
+    // Simulate product creation events to seed product prices
+    // This is necessary because PricingService relies on prices being set via PRODUCT_CREATED event.
+    const product1: ProductCreatedEvent = { productId: 'prod_1', name: 'Test Product 1', price: 100, category: 'Test' };
+    const product2: ProductCreatedEvent = { productId: 'prod_2', name: 'Test Product 2', price: 50, category: 'Test' };
+    const product3: ProductCreatedEvent = { productId: 'prod_3', name: 'Test Product 3', price: 25, category: 'Test' };
+
+    // Emit the events AFTER creating the service instance so handlers are registered.
+    mockEventBus.emit(Events.PRODUCT_CREATED, product1);
+    mockEventBus.emit(Events.PRODUCT_CREATED, product2);
+    mockEventBus.emit(Events.PRODUCT_CREATED, product3);
+  });
+
+  it('should get the price of a product', () => {
+    expect(pricingService.getPrice('prod_1')).toBe(100);
+    expect(pricingService.getPrice('prod_2')).toBe(50);
+  });
+
+  it('should return 0 for a product with no price set', () => {
+    expect(pricingService.getPrice('non_existent_prod')).toBe(0);
+  });
+
+  it('should add a discount code', () => {
+    pricingService.addDiscountCode('SAVE10', 0.10);
+    // We can't directly test private map state, but subsequent calculations will verify.
+  });
+
+  it('should ignore invalid discount percentages', () => {
+    pricingService.addDiscountCode('INVALID', 1.5); // > 1
+    pricingService.addDiscountCode('INVALID2', -0.1); // < 0
+    // Expect that these codes are not added (or would fail if we had access to internal state)
+    // The test will implicitly pass if no errors are thrown and calculations work correctly.
+  });
+
+  it('should calculate total correctly with no discount', () => {
+    const items = [{ productId: 'prod_1', quantity: 2 }]; // 2 * 100 = 200 subtotal
+    const result = pricingService.calculateTotal(items);
+    // Subtotal = 200
+    // Tax = 200 * 0.10 = 20
+    // Total = 200 + 20 = 220
+    expect(result.subtotal).toBe(200);
+    expect(result.discount).toBe(0);
+    expect(result.tax).toBe(20);
+    expect(result.total).toBe(220);
+  });
+
+  it('should calculate total with a valid discount code', () => {
+    pricingService.addDiscountCode('SAVE10', 0.10); // 10% discount
+    const items = [{ productId: 'prod_1', quantity: 2 }]; // Base subtotal = 200
+    const result = pricingService.calculateTotal(items, 'SAVE10');
+
+    // Subtotal before discount = 200
+    // Discount = 200 * 0.10 = 20
+    // Discounted subtotal = 200 - 20 = 180
+    // Tax = 180 * 0.10 = 18
+    // Total = 180 + 18 = 198
+    expect(result.subtotal).toBe(200); // Original subtotal
+    expect(result.discount).toBe(20);
+    expect(result.tax).toBe(18);
+    expect(result.total).toBe(198);
+  });
+
+  it('should calculate total with multiple items and discount', () => {
+    pricingService.addDiscountCode('SAVE20', 0.20); // 20% discount
+    const items = [
+      { productId: 'prod_1', quantity: 1 }, // price: 100
+      { productId: 'prod_2', quantity: 2 }, // price: 50 (total 100)
+      { productId: 'prod_3', quantity: 4 }, // price: 25 (total 100)
+    ];
+    // Base subtotal = 100 + 100 + 100 = 300
+    const result = pricingService.calculateTotal(items, 'SAVE20');
+
+    // Subtotal before discount = 300
+    // Discount = 300 * 0.20 = 60
+    // Discounted subtotal = 300 - 60 = 240
+    // Tax = 240 * 0.10 = 24
+    // Total = 240 + 24 = 264
+    expect(result.subtotal).toBe(300);
+    expect(result.discount).toBe(60);
+    expect(result.tax).toBe(24);
+    expect(result.total).toBe(264);
+  });
+
+  it('should handle unknown discount codes gracefully', () => {
+    const items = [{ productId: 'prod_1', quantity: 1 }]; // Subtotal = 100
+    const result = pricingService.calculateTotal(items, 'UNKNOWNCODE');
+
+    // Should not apply discount, tax and total should be based on original subtotal
+    // Subtotal = 100
+    // Tax = 100 * 0.10 = 10
+    // Total = 100 + 10 = 110
+    expect(result.subtotal).toBe(100);
+    expect(result.discount).toBe(0);
+    expect(result.tax).toBe(10);
+    expect(result.total).toBe(110);
+  });
+
+  it('should handle unknown products in the items list', () => {
+    const items = [
+      { productId: 'prod_1', quantity: 1 }, // price: 100
+      { productId: 'unknown_prod', quantity: 5 }, // price: 0 (or undefined)
+    ];
+    const result = pricingService.calculateTotal(items);
+
+    // Only prod_1 contributes to subtotal
+    // Subtotal = 100
+    // Tax = 100 * 0.10 = 10
+    // Total = 100 + 10 = 110
+    expect(result.subtotal).toBe(100);
+    expect(result.discount).toBe(0);
+    expect(result.tax).toBe(10);
+    expect(result.total).toBe(110);
+  });
+
+  it('should emit PriceCalculatedEvent', () => {
+    const items = [{ productId: 'prod_1', quantity: 1 }]; // Subtotal = 100
+    pricingService.calculateTotal(items, 'SAVE10'); // Discount = 10, Tax = 9, Total = 99
+
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(1);
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.PRICE_CALCULATED, {
+      cartId: 'N/A', // As per implementation
+      subtotal: 100, // Original subtotal
+      discount: 10,
+      tax: 9,
+      total: 99,
+    });
+  });
+});
