+import { EventBus, NotificationService, NotificationSentEvent, OrderStatusChangedEvent, PaymentProcessedEvent, Events, OrderStatus } from '../types';
+import { createNotificationsService } from './index';
+
+describe('NotificationsService', () => {
+  let notificationsService: NotificationService;
+  let userId: string;
+  let orderId: string;
+  let anotherOrderId: string;
+
+  // Mock EventBus
+  const mockEventBus = {
+    emit: vi.fn(),
+    on: vi.fn(),
+    off: vi.fn(),
+    clear: vi.fn(),
+    getLog: vi.fn(),
+  } as unknown as EventBus;
+
+  beforeEach(() => {
+    vi.clearAllMocks();
+    notificationsService = createNotificationsService(mockEventBus);
+    userId = 'user_test_1';
+    orderId = 'order_111';
+    anotherOrderId = 'order_222';
+
+    // Handlers are registered when createNotificationsService is called.
+    // The orderUserMap needs to be populated before events are processed.
+    // We will emit ORDER_CREATED events within individual tests to ensure
+    // orderUserMap is populated for the specific orderId being tested.
+  });
+
+  it('should subscribe a user to notifications', () => {
+    notificationsService.subscribe(userId);
+    // Check that the service registers its handlers for relevant events.
+    expect(mockEventBus.on).toHaveBeenCalledWith(Events.ORDER_CREATED, expect.any(Function));
+    expect(mockEventBus.on).toHaveBeenCalledWith(Events.ORDER_STATUS_CHANGED, expect.any(Function));
+    expect(mockEventBus.on).toHaveBeenCalledWith(Events.PAYMENT_PROCESSED, expect.any(Function));
+  });
+
+  it('should retrieve notifications for a user', () => {
+    notificationsService.subscribe(userId);
+
+    // Ensure orderUserMap is populated BEFORE emitting events that rely on it.
+    mockEventBus.emit(Events.ORDER_CREATED, { orderId: orderId, userId: userId });
+
+    // Manually trigger some events that should lead to notifications
+    // Simulate order status change
+    const orderStatusChangedEvent: OrderStatusChangedEvent = {
+      orderId: orderId,
+      status: OrderStatus.SHIPPED,
+      previousStatus: OrderStatus.CONFIRMED,
+    };
+    mockEventBus.emit(Events.ORDER_STATUS_CHANGED, orderStatusChangedEvent);
+
+    // Simulate payment processed event
+    const paymentProcessedEvent: PaymentProcessedEvent = {
+      orderId: orderId,
+      status: 'success',
+      transactionId: 'txn_123',
+    };
+    mockEventBus.emit(Events.PAYMENT_PROCESSED, paymentProcessedEvent);
+
+    const userNotifications = notificationsService.getNotifications(userId);
+    expect(userNotifications).toHaveLength(2);
+
+    // Check details of the first notification (order status change)
+    expect(userNotifications[0]).toEqual({
+      type: 'order:shipped',
+      message: `Order ${orderId} status changed from CONFIRMED to SHIPPED.`,
+      timestamp: expect.any(Number),
+    });
+
+    // Check details of the second notification (payment success)
+    expect(userNotifications[1]).toEqual({
+      type: 'payment:success',
+      message: `Payment for order ${orderId} was successful.`,
+      timestamp: expect.any(Number),
+    });
+  });
+
+  it('should not retrieve notifications for a user who is not subscribed or has none', () => {
+    const unknownUser = 'user_unknown';
+    const notifications = notificationsService.getNotifications(unknownUser);
+    expect(notifications).toEqual([]);
+  });
+
+  it('should send notification on order status change', () => {
+    // Ensure orderUserMap is populated first
+    mockEventBus.emit(Events.ORDER_CREATED, { orderId: orderId, userId: userId });
+
