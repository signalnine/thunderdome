+    expect(updatedCart?.items.get(productId2)).toEqual({ productId: productId2, quantity: 2 });
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(3); // Add D1 (1 emit), Add D2 (1 emit), Remove D1 (1 emit)
+  });
+
+  it('should do nothing when removing a non-existent item', () => {
+    const productId = 'prod_E';
+    cartService.addItem(cartId, productId, 1);
+    const initialItemsSize = cartService.getCart(cartId)?.items.size;
