+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.NOTIFICATION_SENT, {
+      userId: userId,
+      type: 'order:delivered',
+      message: `Order ${orderId} status changed from SHIPPED to DELIVERED.`,
+    });
+  });
+
+  it('should send notification on payment success', () => {
+    // Ensure orderUserMap is populated first
+    mockEventBus.emit(Events.ORDER_CREATED, { orderId: orderId, userId: userId });
+
+    const paymentProcessedEvent: PaymentProcessedEvent = {
+      orderId: orderId,
+      status: 'success',
+      transactionId: 'txn_abc',
