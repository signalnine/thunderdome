@@ -0,0 +1,89 @@
+import { EventBus, OrderService, Order, OrderStatus, OrderCreatedEvent, OrderStatusChangedEvent, Events } from '../types';
+
+// Helper function to get initial Order interface based on types.ts
+interface OrderInternal extends Omit<Order, 'status'> {
+  status: OrderStatus;
+  previousStatus?: OrderStatus; // Track previous status for events
+}
+
+export function createOrdersService(bus: EventBus): OrderService {
+  const orders = new Map<string, OrderInternal>();
+  let nextOrderId = 1;
+
+  const generateOrderId = (): string => 'order_' + nextOrderId++;
+
+  const getOrder = (orderId: string): Order | null => {
+    const order = orders.get(orderId);
+    if (!order) return null;
+    // Return a clean Order object without internal status tracking like previousStatus
+    const { previousStatus, ...rest } = order;
+    return rest;
+  };
+
+  const createOrder = (userId: string, cartId: string, total: number): string => {
+    const id = generateOrderId();
+    const newOrder: OrderInternal = {
+      id,
+      userId,
+      cartId, // Store cartId for reference, though not explicitly in Order interface, it's used in creation event
+      total,
+      status: OrderStatus.PENDING,
+      previousStatus: undefined, // No previous status for new orders
+    };
+    orders.set(id, newOrder);
+
+    // Emit OrderCreatedEvent
+    const eventPayload: OrderCreatedEvent = {
+      orderId: newOrder.id,
+      userId: newOrder.userId,
+      cartId: newOrder.cartId,
+      total: newOrder.total,
+    };
+    bus.emit(Events.ORDER_CREATED, eventPayload);
+
+    return id;
+  };
+
+  const updateStatus = (orderId: string, status: OrderStatus): void => {
+    const order = orders.get(orderId);
+    if (!order) {
+      console.warn('Order not found for status update: ' + orderId);      return;
+    }
+
+    if (order.status === status) {
+      // No change in status
+      return;
+    }
+
+    // Store previous status before updating
+    const previousStatus = order.status;
+    order.previousStatus = previousStatus; // Store for event
+    order.status = status;
+
+    // Emit OrderStatusChangedEvent
+    const eventPayload: OrderStatusChangedEvent = {
+      orderId: order.id,
+      status: order.status,
+      previousStatus: order.previousStatus,
+    };
+    bus.emit(Events.ORDER_STATUS_CHANGED, eventPayload);
+  };
+
+  const listOrders = (userId: string): Order[] => {
+    const userOrders = Array.from(orders.values())
+      .filter(order => order.userId === userId)
+      .map(order => {
+        // Return clean Order objects
+        const { previousStatus, ...rest } = order;
+        return rest;
+      });
+    return userOrders;
+  };
+
+  return {
+    createOrder,
+    getOrder,
+    updateStatus,
+    listOrders,
+  };
+}
