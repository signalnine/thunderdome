@@ -0,0 +1,83 @@
+import { EventBus, AnalyticsService, Events, PriceCalculatedEvent, OrderCreatedEvent, PaymentProcessedEvent, CartUpdatedEvent } from '../types';
+
+interface AnalyticsData {
+  eventCounts: Map<string, number>;
+  totalRevenue: number;
+  orderCount: number;
+  uniqueCarts: Set<string>;
+  productOrderCounts: Map<string, number>;
+}
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const analyticsData: AnalyticsData = {
+    eventCounts: new Map<string, number>(),
+    totalRevenue: 0,
+    orderCount: 0,
+    uniqueCarts: new Set<string>(),
+    productOrderCounts: new Map<string, number>(),
+  };
+
+  // --- Event Listeners ---
+
+  // Listen for order creation to count orders
+  const handleOrderCreated = (event: OrderCreatedEvent) => {
+    console.log('AnalyticsService: handleOrderCreated called'); // Added for debugging
+    analyticsData.orderCount++;
+    // Placeholder: If OrderCreatedEvent had item details, we would update productOrderCounts here.
+    // For now, just counting the order itself.
+    analyticsData.eventCounts.set(Events.ORDER_CREATED, (analyticsData.eventCounts.get(Events.ORDER_CREATED) || 0) + 1);
+  };
+  bus.on(Events.ORDER_CREATED, handleOrderCreated);
+
+  // Listen for payment processing to track revenue
+  const handlePaymentProcessed = (event: PaymentProcessedEvent) => {
+    if (event.status === 'success' && event.transactionId) {
+      // Placeholder: Amount is missing from PaymentProcessedEvent. Cannot track revenue accurately.
+      // A real implementation would need the order amount.
+      // For now, we just count successful payment events.
+      analyticsData.eventCounts.set(Events.PAYMENT_PROCESSED, (analyticsData.eventCounts.get(Events.PAYMENT_PROCESSED) || 0) + 1);
+    }
+  };
+  bus.on(Events.PAYMENT_PROCESSED, handlePaymentProcessed);
+
+  // Listen for cart updates to track unique carts for conversion rate
+  const handleCartUpdated = (event: CartUpdatedEvent) => {
+    analyticsData.uniqueCarts.add(event.cartId);
+    analyticsData.eventCounts.set(Events.CART_UPDATED, (analyticsData.eventCounts.get(Events.CART_UPDATED) || 0) + 1);
+    // Placeholder: If CartUpdatedEvent had item details, product order counts could be partially tracked here,
+    // but prompt specifies 'products by order quantity', implying completed orders.
+  };
+  bus.on(Events.CART_UPDATED, handleCartUpdated);
+
+  // --- Metrics Calculation Methods ---
+
+  const getEventCount = (eventType: string): number => {
+    return analyticsData.eventCounts.get(eventType) || 0;
+  };
+
+  const getRevenue = (): number => {
+    // As noted in handlePaymentProcessed, amount is missing from events.
+    // Returning 0 as accurate revenue tracking is not possible with current event structure.
+    return 0;
+  };
+
+  const getConversionRate = (): number => {
+    const cartCount = analyticsData.uniqueCarts.size;
+    const orderCount = analyticsData.orderCount;
+    if (cartCount === 0) return 0;
+    return orderCount / cartCount;
+  };
+
+  const getTopProducts = (limit: number): Array<{ productId: string; count: number }> => {
+    // Data for product order counts is not available in the emitted events (OrderCreatedEvent, PaymentProcessedEvent).
+    // Returning an empty array as per lack of data.
+    return [];
+  };
+
+  return {
+    getEventCount,
+    getRevenue,
+    getConversionRate,
+    getTopProducts,
+  };
+}
