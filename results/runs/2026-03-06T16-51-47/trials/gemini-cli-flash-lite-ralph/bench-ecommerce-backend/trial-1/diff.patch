+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.NOTIFICATION_SENT, {
+      userId: userId,
+      type: 'payment:success',
+      message: `Payment for order ${orderId} was successful.`,
+    });
+  });
+
+  it('should send notification on payment failure', () => {
+    // Ensure orderUserMap is populated first
+    mockEventBus.emit(Events.ORDER_CREATED, { orderId: orderId, userId: userId });
+
+    const paymentProcessedEvent: PaymentProcessedEvent = {
+      orderId: orderId,
+      status: 'failed',
+      transactionId: 'txn_def',
+      error: 'Insufficient funds',
+    };
+    mockEventBus.emit(Events.PAYMENT_PROCESSED, paymentProcessedEvent);
+
+    const userNotifications = notificationsService.getNotifications(userId);
+    expect(userNotifications).toHaveLength(1);
+    expect(userNotifications[0]).toEqual({
+      type: 'payment:failed',
+      message: `Payment for order ${orderId} failed: Insufficient funds.`,
+      timestamp: expect.any(Number),
+    });
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.NOTIFICATION_SENT, {
+      userId: userId,
+      type: 'payment:failed',
+      message: `Payment for order ${orderId} failed: Insufficient funds.`,
+    });
+  });
+
+  it('should send notification on payment timeout', () => {
+    // Ensure orderUserMap is populated first
+    mockEventBus.emit(Events.ORDER_CREATED, { orderId: orderId, userId: userId });
+
+    const paymentProcessedEvent: PaymentProcessedEvent = {
+      orderId: orderId,
+      status: 'timeout',
+      transactionId: 'txn_ghi',
+    };
+    mockEventBus.emit(Events.PAYMENT_PROCESSED, paymentProcessedEvent);
+
+    const userNotifications = notificationsService.getNotifications(userId);
+    expect(userNotifications).toHaveLength(1);
+    expect(userNotifications[0]).toEqual({
+      type: 'payment:timeout',
+      message: `Payment for order ${orderId} timed out.`,
+      timestamp: expect.any(Number),
+    });
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.NOTIFICATION_SENT, {
+      userId: userId,
+      type: 'payment:timeout',
+      message: `Payment for order ${orderId} timed out.`,
+    });
+  });
+
+  it('should handle events for orders that are not mapped to a user (e.g., order created without a user)', () => {
+    // This test checks robustness when orderUserMap does not have an entry.
+    // No ORDER_CREATED event is emitted for 'order_no_user' here.
+
+    const orderWithoutUser = 'order_no_user';
+    const statusChangedEvent: OrderStatusChangedEvent = {
+      orderId: orderWithoutUser,
+      status: OrderStatus.CANCELLED,
+      previousStatus: OrderStatus.PENDING,
+    };
+    mockEventBus.emit(Events.ORDER_STATUS_CHANGED, statusChangedEvent);
