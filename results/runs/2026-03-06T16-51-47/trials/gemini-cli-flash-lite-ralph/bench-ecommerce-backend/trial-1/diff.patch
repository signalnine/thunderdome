@@ -0,0 +1,173 @@
+import { EventBus, ProductCreatedEvent, InventoryService, OrderItem, Events } from '../types';
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  // Stores { quantity, threshold } for each product
+  const stockLevels = new Map<string, { quantity: number; threshold: number }>();
+  // Tracks stock quantity reserved for ongoing orders
+  const reservedStock = new Map<string, number>();
+
+  // Event handler for product creation to initialize stock with default threshold
+  const handleProductCreated = (event: ProductCreatedEvent) => {
+    const { productId } = event;
+    const defaultThreshold = 10; // Default low stock threshold
+    console.log(`Inventory: handleProductCreated called for ${productId}`);
+    stockLevels.set(productId, { quantity: 0, threshold: defaultThreshold });
+    console.log(`Inventory: Stock initialized for ${productId}. Map size after set: ${stockLevels.size}`);
+    console.log(`Inventory: Stock data for ${productId} immediately after set:`, stockLevels.get(productId));
+  };
+
+  // Register listener for product creation events
+  bus.on(Events.PRODUCT_CREATED, handleProductCreated);
+
+  // Event handler for stock reservation requests from the Orders service
+  const handleReserveStockRequested = (event: { orderId: string; items?: OrderItem[] }) => {
+    const { orderId, items } = event;
+    let allReserved = true;
+    const successfullyReserved: OrderItem[] = [];
+
+    console.log(`Inventory: Handling RESERVE_STOCK_REQUESTED for order ${orderId} with items:`, items);
+
+    // Add a check for items before iterating
+    if (!items || items.length === 0) {
+        console.warn(`Inventory: No items provided for order ${orderId}. Skipping reservation.`);
+        console.warn(`Inventory: No items provided for order ${orderId}. Skipping reservation.`);
+        return; // Exit here if no items
+        }    // Attempt to reserve stock for each item in the order
+    for (const item of items) {
+      const reserved = reserveStock(item.productId, item.quantity);
+      if (reserved) {
+        successfullyReserved.push(item);
+      } else {
+        allReserved = false;
+        // If any reservation fails, we must stop and signal failure
+        break;
+      }
+    }
+
+    if (allReserved) {
+      // If all items were reserved, emit success event
+      console.log(`Inventory: Stock successfully reserved for order ${orderId}.`);
+      bus.emit(Events.STOCK_RESERVED, { orderId, reservedItems: successfullyReserved });
+    } else {
+      // If any reservation failed, release any stock that was successfully reserved in *this* call
+      // to maintain data integrity (rollback).
+      console.log(`Inventory: Reservation failed for order ${orderId}. Rolling back reservations.`);
+      successfullyReserved.forEach(item => releaseStock(item.productId, item.quantity));
+      bus.emit(Events.STOCK_RESERVATION_FAILED, { orderId, reason: 'Insufficient stock for one or more items.' });
+    }
+  };
+
+  // Register listener for stock reservation requests
+  bus.on(Events.RESERVE_STOCK_REQUESTED, handleReserveStockRequested);
+
+  const setStock = (productId: string, quantity: number): void => {
+    console.log(`Inventory: setStock called for ${productId} with quantity ${quantity}`);
+    console.log(`Inventory: setStock - Checking if ${productId} exists in stockLevels. Map size before has(): ${stockLevels.size}`);
+    if (!stockLevels.has(productId)) {
+      console.warn(`Inventory: Attempted to set stock for unknown product ID: ${productId}. stockLevels.has() returned false.`);
+      // If the product doesn't exist, initialize it with the given quantity and default threshold
+      const defaultThreshold = 10;
+      stockLevels.set(productId, { quantity: quantity, threshold: defaultThreshold });
+      console.log(`Inventory: Initialized stock for unknown product ${productId} to ${quantity}`);
+      checkAndAlertLowStock(productId, quantity, defaultThreshold);
+      return;
+    }
+    const currentStockData = stockLevels.get(productId)!;
+    console.log(`Inventory: setStock - currentStockData for ${productId}:`, currentStockData);
+    const oldQuantity = currentStockData.quantity;
+    stockLevels.set(productId, { ...currentStockData, quantity: quantity });
+    console.log(`Inventory: Stock for ${productId} updated from ${oldQuantity} to ${quantity}. Threshold: ${currentStockData.threshold}`);
+    // Check for low stock after setting
+    checkAndAlertLowStock(productId, quantity, currentStockData.threshold);
+  };
+
+  const checkStock = (productId: string): number => {
+    console.log(`Inventory: checkStock called for ${productId}`);
+    console.log(`Inventory: checkStock - Checking if ${productId} exists in stockLevels. Map size before get(): ${stockLevels.size}`);
+    const stock = stockLevels.get(productId);
+    if (!stock) {
+      console.log(`Inventory: checkStock returning 0 for unknown product ID: ${productId}`);
+      return 0;
+    }
+    console.log(`Inventory: checkStock for ${productId} returning ${stock.quantity}`);
+    return stock.quantity;
+  };
+
+  const reserveStock = (productId: string, quantity: number): boolean => {
+    console.log(`Inventory: reserveStock called for ${productId} with quantity ${quantity}`);
+    console.log(`Inventory: reserveStock - Checking if ${productId} exists in stockLevels. Map size before has(): ${stockLevels.size}`);
+    if (!stockLevels.has(productId)) {
+      console.error(`Inventory: Cannot reserve stock for non-existent product: ${productId}`);
+      return false;
+    }
+    const currentStockData = stockLevels.get(productId)!;
+    const availableQuantity = currentStockData.quantity;
+    const currentReserved = reservedStock.get(productId) || 0;
+
+    console.log(`Inventory: Current stock for ${productId}: ${availableQuantity}, Reserved: ${currentReserved}`);
+
+    if (availableQuantity >= quantity) {
+      // Update main stock level by reducing it
+      const newQuantity = availableQuantity - quantity;
+      stockLevels.set(productId, { ...currentStockData, quantity: newQuantity });
+      // Add to reserved stock map
+      reservedStock.set(productId, currentReserved + quantity);
+      console.log(`Inventory: Stock reserved for ${productId}. New quantity: ${newQuantity}, New reserved: ${currentReserved + quantity}`);
+      // Check for low stock after reservation
+      checkAndAlertLowStock(productId, newQuantity, currentStockData.threshold);
+      return true;
+    } else {
+      console.warn(`Inventory: Insufficient stock for product ${productId}. Requested: ${quantity}, Available: ${availableQuantity}`);
+      return false;
+    }
+  };
+
+  const releaseStock = (productId: string, quantity: number): void => {
+    // This is typically called when an order is cancelled or payment fails
+    console.log(`Inventory: releaseStock called for ${productId} with quantity ${quantity}`);
+    console.log(`Inventory: releaseStock - Checking if ${productId} exists in stockLevels. Map size before has(): ${stockLevels.size}`);
+    if (!stockLevels.has(productId)) {
+      console.warn(`Inventory: Attempted to release stock for unknown product ID: ${productId}`);
+      return; // Silently fail if product is unknown
+    }
+    const currentStockData = stockLevels.get(productId)!;
+    const currentReserved = reservedStock.get(productId) || 0;
+
+    if (currentReserved >= quantity) {
+      // Decrease reserved stock
+      reservedStock.set(productId, currentReserved - quantity);
+      // Increase main stock level
+      const newQuantity = currentStockData.quantity + quantity;
+      stockLevels.set(productId, { ...currentStockData, quantity: newQuantity });
+      console.log(`Inventory: Stock released for ${productId}: ${quantity}. New quantity: ${newQuantity}, New reserved: ${currentReserved - quantity}`);
+      // No need to check low stock here, as we are increasing stock.
+    } else {
+      console.warn(`Inventory: Attempted to release more stock for ${productId} than was reserved. Reserved: ${currentReserved}, Quantity to release: ${quantity}`);
+    }
+  };
+
+  // Helper to check and emit low stock alert
+  const checkAndAlertLowStock = (productId: string, currentQuantity: number, threshold: number) => {
+    if (currentQuantity < threshold) {
+      console.log(`Inventory: LOW STOCK DETECTED for ${productId}: ${currentQuantity} (Threshold: ${threshold})`);
+      bus.emit(Events.LOW_STOCK_ALERT, { productId, quantity: currentQuantity, threshold });
+    }
+  };
+
+  // The detectLowStock method is part of the interface, so we provide an implementation.
+  // Actual detection happens on quantity changes (setStock, reserveStock).
+  const detectLowStock = (): void => {
+    console.log('Inventory: detectLowStock called');
+    stockLevels.forEach((stock, productId) => {
+      checkAndAlertLowStock(productId, stock.quantity, stock.threshold);
+    });
+  };
+
+  return {
+    setStock,
+    checkStock,
+    reserveStock,
+    releaseStock,
+    detectLowStock,
+  };
+}
