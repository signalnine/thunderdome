+import { vi, describe, it, expect, beforeEach } from 'vitest';
+import { EventBus, OrderService, Order, OrderStatus, OrderCreatedEvent, OrderStatusChangedEvent, Events } from '../types';
+import { createOrdersService } from './index';
+
+// Mock EventBus
+const mockEventBus = {
+  emit: vi.fn(),
+  on: vi.fn(),
+  off: vi.fn(),
+  clear: vi.fn(),
+  getLog: vi.fn(),
+} as unknown as EventBus;
+
+describe('OrdersService', () => {
+  let ordersService: OrderService;
+  let userId: string;
+  let cartId: string;
+  let orderId: string; // Declared but will be assigned within tests that create orders
+
+  beforeEach(() => {
+    vi.clearAllMocks();
+    ordersService = createOrdersService(mockEventBus);
+    userId = 'user_456';
+    cartId = 'cart_abc'; // Mock cart ID
+  });
+
+  it('should create an order and emit OrderCreatedEvent', () => {
+    const totalAmount = 150.75;
+    orderId = ordersService.createOrder(userId, cartId, totalAmount);
+
+    expect(orderId).toBeDefined();
+    expect(orderId.startsWith('order_')).toBe(true);
+
+    const createdOrder = ordersService.getOrder(orderId);
+    expect(createdOrder).not.toBeNull();
+    expect(createdOrder?.id).toBe(orderId);
+    expect(createdOrder?.userId).toBe(userId);
+    // The Order interface from types.ts doesn't include cartId, but it's used in the event.
+    // We are testing the returned Order object, which should not contain cartId if it's not in the interface.
+
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(1);
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.ORDER_CREATED, {
+      orderId: orderId,
+      userId: userId,
+      cartId: cartId,
+      total: totalAmount,
+    });
+  });
+
+  it('should return null for a non-existent order ID', () => {
+    expect(ordersService.getOrder('order_999')).toBeNull();
+  });
+
+  it('should update order status and emit OrderStatusChangedEvent', () => {
+    const totalAmount = 200;
+    orderId = ordersService.createOrder(userId, cartId, totalAmount); // This emits ORDER_CREATED
+    const initialOrder = ordersService.getOrder(orderId);
+    expect(initialOrder?.status).toBe(OrderStatus.PENDING);
+
+    ordersService.updateStatus(orderId, OrderStatus.CONFIRMED);
+    const confirmedOrder = ordersService.getOrder(orderId);
+    expect(confirmedOrder?.status).toBe(OrderStatus.CONFIRMED);
+
+    // Expect 2 calls: 1 for ORDER_CREATED, 1 for ORDER_STATUS_CHANGED
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(2);
+    expect(mockEventBus.emit).toHaveBeenCalledWith(Events.ORDER_STATUS_CHANGED, {
+      orderId: orderId,
+      status: OrderStatus.CONFIRMED,
+      previousStatus: OrderStatus.PENDING,
+    });
+  });
+
+  it('should not emit event if order status remains the same', () => {
+    const totalAmount = 50;
+    orderId = ordersService.createOrder(userId, cartId, totalAmount); // Emits ORDER_CREATED
+    
+    // Update to CONFIRMED
+    ordersService.updateStatus(orderId, OrderStatus.CONFIRMED); // Emits ORDER_STATUS_CHANGED
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(2); // CREATED + CONFIRMED
+
+    // Try to update to CONFIRMED again
+    ordersService.updateStatus(orderId, OrderStatus.CONFIRMED);
+    // No new event should be emitted, so total calls should remain 2.
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(2); 
+  });
+
+  it('should not update status if order does not exist', () => {
+    const nonExistentOrderId = 'order_999';
+    
+    // Before calling updateStatus, ensure no events have been emitted by this test's setup.
+    // The beforeEach clears mocks, so emit count is 0.
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(0);
+
+    ordersService.updateStatus(nonExistentOrderId, OrderStatus.SHIPPED);
+    
+    // The updateStatus call on a non-existent order should not emit any new events.
+    // Therefore, the total count should remain 0.
+    expect(mockEventBus.emit).toHaveBeenCalledTimes(0); 
+    
+    // Explicitly check that the ORDER_STATUS_CHANGED event was NOT emitted.
+    expect(mockEventBus.emit).not.toHaveBeenCalledWith(Events.ORDER_STATUS_CHANGED, expect.any(Object));
+  });
+
+  it('should list orders for a specific user', () => {
+    const anotherUserId = 'user_789';
+    const anotherCartId = 'cart_xyz';
+
+    // Create orders for user1
+    const order1Id = ordersService.createOrder(userId, cartId, 100); // Emits ORDER_CREATED
+    const order2Id = ordersService.createOrder(userId, cartId, 200); // Emits ORDER_CREATED
+    ordersService.updateStatus(order1Id, OrderStatus.SHIPPED); // Emits ORDER_STATUS_CHANGED
+
+    // Create order for user2
+    const order3Id = ordersService.createOrder(anotherUserId, anotherCartId, 300); // Emits ORDER_CREATED
+
+    const user1Orders = ordersService.listOrders(userId);
+    expect(user1Orders).toHaveLength(2);
+    expect(user1Orders.map(o => o.id)).toContain(order1Id);
+    expect(user1Orders.map(o => o.id)).toContain(order2Id);
+    expect(user1Orders.find(o => o.id === order1Id)?.status).toBe(OrderStatus.SHIPPED);
+
+    const user2Orders = ordersService.listOrders(anotherUserId);
+    expect(user2Orders).toHaveLength(1);
+    expect(user2Orders[0].id).toBe(order3Id);
+  });
+
+  it('should return an empty array if a user has no orders', () => {
+    const userWithNoOrders = 'user_no_orders';
+    const orders = ordersService.listOrders(userWithNoOrders);
+    expect(orders).toHaveLength(0);
+    // Ensure no events were emitted during this check
+    expect(mockEventBus.emit).not.toHaveBeenCalled();
+  });
+});
