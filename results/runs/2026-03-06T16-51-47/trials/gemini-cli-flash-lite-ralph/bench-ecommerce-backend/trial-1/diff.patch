+++ b/src/notifications/index.ts
@@ -0,0 +1,90 @@
+import { EventBus, NotificationService, NotificationSentEvent, OrderStatusChangedEvent, PaymentProcessedEvent, Events, OrderStatus } from '../types';
+
+interface UserNotification {
+  type: string;
+  message: string;
+  timestamp: number;
+}
+
+export function createNotificationsService(bus: EventBus): NotificationService {
+  // Map userId to a list of their notifications
+  const userNotifications = new Map<string, UserNotification[]>();
+  // Track which orders belong to which user (for associating payment/order events with users)
+  const orderUserMap = new Map<string, string>();
+
+  // Helper to send a notification to a user
+  const sendNotification = (userId: string, type: string, message: string) => {
+    console.log(`Notifications: Sending notification to user ${userId} - Type: ${type}, Message: ${message}`);
+    const notification: UserNotification = { type, message, timestamp: Date.now() };
+    const notifications = userNotifications.get(userId) || [];
+    notifications.push(notification);
+    userNotifications.set(userId, notifications);
+
+    // Emit NotificationSentEvent
+    const eventPayload: NotificationSentEvent = { userId, type, message };
+    bus.emit(Events.NOTIFICATION_SENT, eventPayload);
+  };
+
+  // Listener for order creation to map orderId to userId
+  const handleOrderCreated = (event: { orderId: string; userId: string }) => {
+    console.log(`Notifications: Handling ORDER_CREATED for order ${event.orderId}, user ${event.userId}`);
+    orderUserMap.set(event.orderId, event.userId);
+    console.log(`Notifications: orderUserMap size after set: ${orderUserMap.size}`);
+  };
+  bus.on(Events.ORDER_CREATED, handleOrderCreated);
+
+  // Listener for order status changes
+  const handleOrderStatusChanged = (event: OrderStatusChangedEvent) => {
+    console.log(`Notifications: Handling ORDER_STATUS_CHANGED for order ${event.orderId}, previous status ${event.previousStatus}, new status ${event.status}`);
+    const userId = orderUserMap.get(event.orderId);
+    console.log(`Notifications: Retrieved userId for order ${event.orderId} from orderUserMap: ${userId}`);
+    if (userId) { // Ensure userId is valid and found
+      sendNotification(
+        userId,
+        'order:' + event.status, // e.g., "order:shipped"
+        'Order ' + event.orderId + ' status changed from ' + event.previousStatus + ' to ' + event.status + '.'
+      );
+    } else {
+      console.warn('User ID not found for order ' + event.orderId + ' when handling status change.');
+    }
+  };
+  bus.on(Events.ORDER_STATUS_CHANGED, handleOrderStatusChanged);
+
+  // Listener for payment processing events
+  const handlePaymentProcessed = (event: PaymentProcessedEvent) => {
+    console.log(`Notifications: Handling PAYMENT_PROCESSED for order ${event.orderId}, status ${event.status}`);
+    const userId = orderUserMap.get(event.orderId);
+    console.log(`Notifications: Retrieved userId for order ${event.orderId} from orderUserMap: ${userId}`);
+    if (userId) { // Ensure userId is valid and found
+      if (event.status === 'success') {
+        sendNotification(userId, 'payment:success', 'Payment for order ' + event.orderId + ' was successful.');
+      } else if (event.status === 'failed') {
+        sendNotification(userId, 'payment:failed', 'Payment for order ' + event.orderId + ' failed: ' + (event.error || 'Unknown error') + '.');
+      } else if (event.status === 'timeout') {
+        sendNotification(userId, 'payment:timeout', 'Payment for order ' + event.orderId + ' timed out.');
+      }
+    } else {
+      console.warn('User ID not found for order ' + event.orderId + ' when handling payment processed.');
+    }
+  };
+  bus.on(Events.PAYMENT_PROCESSED, handlePaymentProcessed);
+
+  // Subscribe users to notifications (for future events)
+  const subscribe = (userId: string): void => {
+    if (!userNotifications.has(userId)) {
+      userNotifications.set(userId, []);
+    }
+  };
+
+  // Retrieve notifications for a user
+  const getNotifications = (userId: string): UserNotification[] => {
+    const notifications = userNotifications.get(userId) || [];
+    console.log(`Notifications: Retrieving notifications for user ${userId}. Found ${notifications.length} notifications.`);
+    return notifications;
+  };
+
+  return {
+    subscribe,
+    getNotifications,
+  };
+}
