+    // Expect no notifications to be sent for this order, and no errors.
+    // The handlers should gracefully do nothing if userId is not found.
+    expect(mockEventBus.emit).not.toHaveBeenCalledWith(Events.NOTIFICATION_SENT, expect.any(Object));
