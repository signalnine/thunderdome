diff --git a/src/analytics/index.test.ts b/src/analytics/index.test.ts
new file mode 100644
index 0000000..ebc3ffa
--- /dev/null
+++ b/src/analytics/index.test.ts
@@ -0,0 +1,113 @@
+import { vi, describe, it, expect, beforeEach } from 'vitest';
+import { EventBus, AnalyticsService, Events, OrderCreatedEvent, PaymentProcessedEvent, CartUpdatedEvent } from '../types';
+import { createAnalyticsService } from './index';
+
+// Mock EventBus for testing with actual listener management
+const mockEventBus: Partial<EventBus> = {
+  listeners: new Map<string, ((event: any) => void)[]>(),
+  on: vi.fn((event: string, handler: (event: any) => void) => {
+    if (!mockEventBus.listeners.has(event)) {
+      mockEventBus.listeners.set(event, []);
+    }
+    mockEventBus.listeners.get(event)?.push(handler);
+  }),
+  emit: vi.fn((event: string, payload: any) => {
+    const handlers = mockEventBus.listeners.get(event);
+    handlers?.forEach(handler => handler(payload));
+  }),
+  off: vi.fn(),
+  getLog: vi.fn().mockReturnValue([]), // Mock implementation, not used in analytics tests
+  clear: vi.fn(() => {
+    // Clear listeners map and Vitest spies.
+    mockEventBus.listeners.clear();
+    vi.clearAllMocks();
+  }),
+};
+
+
+interface AnalyticsData {
+  eventCounts: Map<string, number>;
+  totalRevenue: number;
+  orderCount: number;
+  uniqueCarts: Set<string>;
+  productOrderCounts: Map<string, number>;
+}
+
+describe('AnalyticsService', () => {
+  let analyticsService: AnalyticsService;
+  let userId1: string;
+  let userId2: string;
+  let orderId1: string;
+  let orderId2: string;
+  let orderId3: string;
+  let cartId1: string;
+  let cartId2: string;
+
+  beforeEach(() => {
+    // Reset the mock bus and its listeners before each test
+    mockEventBus.clear!(); // Clears listeners and spies managed by the mock's clear method.
+
+    // Re-create the service with the reset mock bus. This registers the handlers.
+    analyticsService = createAnalyticsService(mockEventBus as EventBus);
+
+    userId1 = 'user_a';
+    userId2 = 'user_b';
+    orderId1 = 'order_1';
+    orderId2 = 'order_2';
+    orderId3 = 'order_3';
+    cartId1 = 'cart_x';
+    cartId2 = 'cart_y';
+
+    // Simulate events to populate analytics data
+    // Order created events
+    mockEventBus.emit!(Events.ORDER_CREATED, { orderId: orderId1, userId: userId1, cartId: cartId1, total: 100 } as OrderCreatedEvent);
+    mockEventBus.emit!(Events.ORDER_CREATED, { orderId: orderId2, userId: userId1, cartId: cartId1, total: 150 } as OrderCreatedEvent);
+    mockEventBus.emit!(Events.ORDER_CREATED, { orderId: orderId3, userId: userId2, cartId: cartId2, total: 200 } as OrderCreatedEvent);
+
+    // Cart updated events
+    mockEventBus.emit!(Events.CART_UPDATED, { cartId: cartId1, userId: userId1, items: [] } as CartUpdatedEvent);
+    mockEventBus.emit!(Events.CART_UPDATED, { cartId: cartId2, userId: userId2, items: [] } as CartUpdatedEvent);
+    // Add another cart update for the same cart to ensure uniqueness is handled
+    mockEventBus.emit!(Events.CART_UPDATED, { cartId: cartId1, userId: userId1, items: [] } as CartUpdatedEvent);
+
+
+    // Payment processed events (simulating successful payments for orderId1 and orderId3)
+    // Note: PaymentProcessedEvent doesn't contain amount, so revenue tracking is limited.
+    mockEventBus.emit!(Events.PAYMENT_PROCESSED, { orderId: orderId1, status: 'success', transactionId: 'txn_1' } as PaymentProcessedEvent);
+    // For orderId2, let's assume payment failed or wasn't processed yet.
+    mockEventBus.emit!(Events.PAYMENT_PROCESSED, { orderId: orderId3, status: 'success', transactionId: 'txn_3' } as PaymentProcessedEvent);
+  });
+
+  it('should count events', () => {
+    expect(analyticsService.getEventCount(Events.ORDER_CREATED)).toBe(3);
+    expect(analyticsService.getEventCount(Events.CART_UPDATED)).toBe(3); // 3 cart updates emitted
+    expect(analyticsService.getEventCount(Events.PAYMENT_PROCESSED)).toBe(2); // Only 2 successful payments counted here
+  });
+
+  it('should return 0 revenue as amount is not available in events', () => {
+    expect(analyticsService.getRevenue()).toBe(0);
+  });
+
+  it('should calculate conversion rate correctly', () => {
+    // 2 unique carts (cartId1, cartId2) and 3 orders created.
+    // Conversion rate = orders / unique carts = 3 / 2 = 1.5
+    // The number of orders (3) is greater than unique carts (2) because we emitted 3 order created events.
+    // If an order was created without a cart update, it would still count towards orderCount.
+    // In this setup: 3 orders / 2 unique carts.
+    expect(analyticsService.getConversionRate()).toBe(1.5);
+  });
+
+  it('should return 0 conversion rate if no carts are updated', () => {
+    // Resetting mocks and re-creating service without cart events
