+++ b/src/server.ts
@@ -0,0 +1,423 @@
+import express from 'express';
+import http from 'http';
+import { WebSocketServer } from 'ws'; // Using a specific named import for the Server
+import Database from 'better-sqlite3'; // Import Database for use in tests
+import fs from 'fs';
+import path from 'path';
+
+// Use a file in the temporary directory for persistence
+const DB_FILE_NAME = 'collaborative_editor.db';
+const DB_PATH = path.join('/tmp/.gemini/tmp/workspace', DB_FILE_NAME); // Using the project's temp dir
+
+// Ensure the directory exists
+const dbDir = path.dirname(DB_PATH);
+if (!fs.existsSync(dbDir)){
+    fs.mkdirSync(dbDir, { recursive: true });
+}
+
+const SCHEMA_SQL = `
+CREATE TABLE IF NOT EXISTS documents (
+    id INTEGER PRIMARY KEY AUTOINCREMENT,
+    title TEXT NOT NULL,
+    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
+    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
+);
+
+CREATE TABLE IF NOT EXISTS document_history (
+    document_id INTEGER NOT NULL,
+    version INTEGER NOT NULL,
+    content TEXT NOT NULL,
+    operations TEXT, -- Store operations as JSON string for OT/CRDT
+    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
+    PRIMARY KEY (document_id, version),
+    FOREIGN KEY (document_id) REFERENCES documents(id)
+);
+`;
+
+interface Document {
+    id: number;
+    title: string;
+    created_at: string;
+    updated_at: string;
+}
+
+interface Operation {
+    type: 'insert' | 'delete';
+    position: number;
+    text?: string; // for insert
+    length?: number; // for delete
+    version: number; // version before this operation
+    clientId: string; // to identify client who sent it
+}
+
+interface ServerMessage {
+    type: 'sync' | 'operation' | 'error';
+    payload: any;
+}
+
+// WebSocket client might have its own WebSocket class, use generic ws.WebSocket for server-side typing
+// import WebSocket from 'ws'; // This was the original, which caused issues.
+// The type 'WebSocket' is already declared in the current scope.
+// However, for the client connections, the 'ws' module's WebSocket type is needed.
+// We can use the type from the imported 'ws' module.
+
+export function createApp(dbFilePath: string = DB_PATH) {
+    const db = new Database(dbFilePath);
+    db.exec(SCHEMA_SQL);
+
+    const app = express();
+    app.use(express.json()); // Middleware to parse JSON bodies
+
+    const server = http.createServer(app);
+    const wss = new WebSocketServer({ server }); // Use the imported WebSocketServer
+
+    const documentClients: Map<number, Map<string, ws.WebSocket>> = new Map(); // Type using ws.WebSocket
+    const documentVersions: Map<number, number> = new Map();
+
+
+    // --- REST API Endpoints ---
+
+    app.get('/documents', (req, res) => {
+        try {
+            const stmt = db.prepare('SELECT id, title, created_at, updated_at FROM documents ORDER BY updated_at DESC');
+            const documents: Document[] = stmt.all();
+            res.json(documents);
+        } catch (error: any) {
+            console.error('Error listing documents:', error.message);
+            res.status(500).json({ error: 'Failed to list documents' });
+        }
+    });
+
+    app.post('/documents', (req, res) => {
+        const { title } = req.body;
+        if (!title) {
+            return res.status(400).json({ error: 'Title is required' });
+        }
+        try {
+            // FIX: Changed placeholder to named parameter to match .run({ title })
+            const insertDocStmt = db.prepare('INSERT INTO documents (title) VALUES (:title)');
+            const result = insertDocStmt.run({ title });
+            const newDocId = result.lastInsertRowid;
+
+            const getDocStmt = db.prepare('SELECT id, title, created_at, updated_at FROM documents WHERE id = ?');
+            const newDoc = getDocStmt.get({ id: newDocId });
+
+            const initialVersionStmt = db.prepare('INSERT INTO document_history (document_id, version, content, operations) VALUES (:document_id, :version, :content, :operations)');
+            initialVersionStmt.run({ document_id: newDocId, version: 0, content: '', operations: JSON.stringify([]) });
+
+            res.status(201).json(newDoc);
+        } catch (error: any) {
+            console.error('Error creating document:', error.message);
+            res.status(500).json({ error: 'Failed to create document' });
+        }
+    });
+
+    app.get('/documents/:id', (req, res) => {
+        const { id } = req.params;
+        try {
+            const docStmt = db.prepare('SELECT * FROM documents WHERE id = ?');
+            const doc = docStmt.get({ id });
+
+            if (!doc) {
+                return res.status(404).json({ error: 'Document not found' });
+            }
+
+            const versionStmt = db.prepare('SELECT content FROM document_history WHERE document_id = ? ORDER BY version DESC LIMIT 1');
+            const latestVersion = versionStmt.get({ id });
+
+            res.json({
+                ...doc,
+                content: latestVersion ? latestVersion.content : '',
+            });
+        } catch (error: any) {
+            console.error(`Error getting document ${id}:`, error.message);
+            res.status(500).json({ error: 'Failed to get document' });
+        }
+    });
+
+    app.put('/documents/:id', (req, res) => {
+        const { id } = req.params;
+        const { title } = req.body;
+
+        if (!title) {
+            return res.status(400).json({ error: 'Title is required for update' });
+        }
+
+        try {
+            const updateStmt = db.prepare('UPDATE documents SET title = ?, updated_at = CURRENT_TIMESTAMP WHERE id = ? RETURNING id, title, created_at, updated_at');
+            const updatedDoc = updateStmt.get({ title, id });
+
+            if (!updatedDoc) {
+                return res.status(404).json({ error: 'Document not found' });
+            }
+            res.json(updatedDoc);
+        } catch (error: any) {
+            console.error(`Error updating document ${id}:`, error.message);
+            res.status(500).json({ error: 'Failed to update document' });
+        }
+    });
+
+    app.delete('/documents/:id', (req, res) => {
+        const { id } = req.params;
+        try {
+            db.transaction(() => {
+                db.prepare('DELETE FROM document_history WHERE document_id = ?').run(id);
+                const deleteStmt = db.prepare('DELETE FROM documents WHERE id = ?');
+                const result = deleteStmt.run(id);
+                if (result.changes === 0) {
+                    throw new Error('Document not found');
+                }
+            })();
+            res.status(204).send();
+        } catch (error: any) {
+            if (error.message === 'Document not found') {
+                return res.status(404).json({ error: 'Document not found' });
+            }
+            console.error(`Error deleting document ${id}:`, error.message);
+            res.status(500).json({ error: 'Failed to delete document' });
+        }
+    });
+
+    app.get('/documents/:id/history', (req, res) => {
+        const { id } = req.params;
+        try {
+            const stmt = db.prepare('SELECT version, content, operations, timestamp FROM document_history WHERE document_id = ? ORDER BY version DESC');
+            const history = stmt.all({ id });
+            res.json(history);
+        } catch (error: any) {
+            console.error(`Error getting history for document ${id}:`, error.message);
+            res.status(500).json({ error: 'Failed to get document history' });
+        }
+    });
+
+    // --- WebSocket Handling ---
+
+    wss.on('connection', (ws: ws.WebSocket, req) => { // ws.WebSocket type for client connection
+        const url = req.url;
+        const match = url?.match(/\/documents\/(\d+)/);
+
+        if (!match) {
+            console.warn('WebSocket connection without valid document ID');
+            ws.close(1008, 'Invalid document ID in URL');
+            return;
+        }
+        const docId = parseInt(match[1], 10);
+        // Generate a unique client ID for this connection
+        const clientId = `${docId}-${Math.random().toString(36).substring(2, 15)}`;
+
+        console.log(`Client connected to document ${docId} with ID ${clientId}`);
+
+        if (!documentClients.has(docId)) {
+            documentClients.set(docId, new Map());
+        }
+        documentClients.get(docId)!.set(clientId, ws);
+
+        // Initialize or retrieve current document version
+        if (!documentVersions.has(docId)) {
+            try {
+                const versionStmt = db.prepare('SELECT MAX(version) as maxVersion FROM document_history WHERE document_id = ?');
+                const result = versionStmt.get({ id: docId });
+                const latestVersion = result && result.maxVersion !== null ? result.maxVersion : 0;
+                documentVersions.set(docId, latestVersion);
+            } catch (error: any) {
+                console.error(`Error fetching latest version for doc ${docId}:`, error.message);
+                ws.close(1011, 'Server error fetching document version');
+                return;
+            }
+        }
+
+        // Send current document state and version to the client
+        try {
+            const versionStmt = db.prepare('SELECT content, version FROM document_history WHERE document_id = ? ORDER BY version DESC LIMIT 1');
+            const latestVersionData = versionStmt.get({ id: docId });
+
+            if (!latestVersionData) {
+                // This should not happen if initial version 0 is created correctly on doc creation
+                console.error(`Document ${docId} has no history entries.`);
+                ws.close(1011, 'Server error: Document history not found');
+                return;
+            }
+
+            const syncMessage: ServerMessage = {
+                type: 'sync',
+                payload: {
+                    docId: docId,
+                    content: latestVersionData.content,
+                    version: latestVersionData.version,
+                },
+            };
+            ws.send(JSON.stringify(syncMessage));
+        } catch (error: any) {
+            console.error(`Error sending sync message to client ${clientId} for doc ${docId}:`, error.message);
+            ws.close(1011, 'Server error sending sync data');
+        }
+
+        ws.on('message', async (message: string) => {
+            try {
+                const parsedMessage: ClientMessage = JSON.parse(message);
+
+                if (parsedMessage.type === 'operation') {
+                    const operation = parsedMessage.payload;
+                    console.log(`Received operation from ${clientId} for doc ${docId}:`, operation);
+
+                    // Basic validation
+                    if (operation.version === undefined || operation.position === undefined || operation.clientId !== clientId) {
+                        console.warn(`Malformed operation from ${clientId}:`, operation);
+                        ws.send(JSON.stringify({ type: 'error', payload: 'Malformed operation' }));
+                        return;
+                    }
+
+                    const currentServerVersion = documentVersions.get(docId)!;
+
+                    // --- Core OT/CRDT Logic Placeholder ---
+                    // This section needs to implement actual transformation
+                    // If operation.version < currentServerVersion, transform `operation` against concurrent ops.
+                    // If operation.version > currentServerVersion, reject/warn.
+                    // If operation.version === currentServerVersion, apply directly.
+
+                    if (operation.version < currentServerVersion) {
+                        // Client is out of sync. A real OT system would transform the operation.
+                        // For now, we log and indicate it needs proper handling.
+                        console.warn(`Client ${clientId} is out of sync. Operation version ${operation.version}, current version ${currentServerVersion}. Transformation needed.`);
+                        // TODO: Implement proper OT/CRDT transformation here.
+                        // For simplicity in this initial setup, we might reject or try to apply if it's an insert/delete at the end.
+                        // Rejecting for now to highlight the need for implementation.
+                        ws.send(JSON.stringify({ type: 'error', payload: `Client is out of sync. Please refresh. (Your version: ${operation.version}, Server version: ${currentServerVersion})` }));
+                        return;
+                    }
+
+                    if (operation.version > currentServerVersion) {
+                        console.warn(`Client ${clientId} is ahead of server version. Operation version ${operation.version}, current version ${currentServerVersion}.`);
+                        ws.send(JSON.stringify({ type: 'error', payload: `Client is ahead of server version. Please refresh. (Your version: ${operation.version}, Server version: ${currentServerVersion})` }));
+                        return;
+                    }
+
+                    // Operation is at the current server version. Apply and broadcast.
+                    let newContent = '';
+                    let newVersion = currentServerVersion + 1;
+                    let operationsToStore: Operation[] = []; // Store the operations that led to this new version
+
+                    // Fetch latest content to apply the operation
+                    const latestVersionData = db.prepare('SELECT content FROM document_history WHERE document_id = ? ORDER BY version DESC LIMIT 1').get({ id: docId });
+                    let currentContent = latestVersionData ? latestVersionData.content : '';
+
+                    // Apply operation (simplified application logic)
+                    if (operation.type === 'insert') {
+                        if (operation.text === undefined) {
+                            ws.send(JSON.stringify({ type: 'error', payload: 'Insert operation missing text' }));
+                            return;
+                        }
+                        // Basic bounds check for insert position
+                        const insertPos = Math.min(operation.position, currentContent.length);
+                        newContent = currentContent.slice(0, insertPos) + operation.text + currentContent.slice(insertPos);
+                        operationsToStore.push({ ...operation, position: insertPos }); // Use actual applied position
+                    } else if (operation.type === 'delete') {
+                        if (operation.length === undefined) {
+                            ws.send(JSON.stringify({ type: 'error', payload: 'Delete operation missing length' }));
+                            return;
+                        }
+                        // Basic bounds check for delete operation
+                        const deleteStart = Math.max(0, operation.position);
+                        const deleteEnd = Math.min(currentContent.length, deleteStart + operation.length);
+                        newContent = currentContent.slice(0, deleteStart) + currentContent.slice(deleteEnd);
+                        operationsToStore.push({ ...operation, position: deleteStart, length: deleteEnd - deleteStart }); // Use actual applied range
+                    } else {
+                        ws.send(JSON.stringify({ type: 'error', payload: 'Unknown operation type' }));
+                        return;
+                    }
+
+                    // Store new version in DB
+                    db.transaction(() => {
+                        db.prepare('INSERT INTO document_history (document_id, version, content, operations) VALUES (?, ?, ?, ?)')
+                          .run(docId, newVersion, newContent, JSON.stringify(operationsToStore));
+
+                        // Update the server's tracked version
+                        documentVersions.set(docId, newVersion);
+
+                        // Update document's last updated timestamp
+                        db.prepare('UPDATE documents SET updated_at = CURRENT_TIMESTAMP WHERE id = ?').run(docId);
+                    })();
+
+                    // Broadcast the operation to all other clients
+                    const broadcastMessage: ServerMessage = {
+                        type: 'operation',
+                        payload: {
+                            ...operationsToStore[0], // Send the stored (potentially adjusted) operation
+                            version: newVersion, // Broadcast the new server version
+                            // clientId remains the same so clients can filter
+                        },
+                    };
+
+                    console.log(`Broadcasting operation to document ${docId} clients (new version ${newVersion}):`, broadcastMessage);
+                    documentClients.get(docId)!.forEach((clientWs, cid) => {
+                        if (cid !== clientId) { // Don't send back to the sender
+                            clientWs.send(JSON.stringify(broadcastMessage));
+                        }
+                    });
+                } else {
+                    ws.send(JSON.stringify({ type: 'error', payload: 'Unknown message type' }));
+                }
+            } catch (error: any) {
+                console.error(`Error processing message from client ${clientId} on doc ${docId}:`, error.message);
+                ws.send(JSON.stringify({ type: 'error', payload: 'Internal server error processing message' }));
+            }
+        });
+
+        ws.on('close', () => {
+            console.log(`Client ${clientId} disconnected from document ${docId}`);
+            if (documentClients.has(docId)) {
+                documentClients.get(docId)!.delete(clientId);
+                if (documentClients.get(docId)!.size === 0) {
+                    documentClients.delete(docId);
+                    documentVersions.delete(docId);
+                    console.log(`All clients disconnected from document ${docId}. Cleaned up trackers.`);
+                }
+            }
+        });
+
+        ws.on('error', (error) => {
+            console.error(`WebSocket error for client ${clientId} on document ${docId}:`, error);
+        });
+    });
+
+    // --- Server Lifecycle ---
+
+    const start = (port?: number): Promise<number> => {
+        return new Promise((resolve, reject) => {
+            server.listen(port || 0, () => {
+                const actualPort = (server.address() as any).port;
+                console.log(`Server listening on port ${actualPort}`);
+                resolve(actualPort);
+            });
+            server.on('error', (err: NodeJS.ErrnoException) => {
+                console.error('Server listen error:', err);
+                reject(err);
+            });
+        });
+    };
+
+    const stop = (): Promise<void> => {
+        return new Promise((resolve, reject) => {
+            wss.close(() => {
+                console.log('WebSocket server closed.');
+                server.close((err?: NodeJS.ErrnoException) => {
+                    if (err) {
+                        console.error('HTTP server close error:', err);
+                        return reject(err);
+                    }
+                    console.log('HTTP server closed.');
+                    db.close((err?: NodeJS.ErrnoException) => {
+                        if (err) {
+                            console.error('Database close error:', err);
+                            return reject(err);
+                        }
+                        console.log('Database closed.');
+                        resolve();
+                    });
+                });
+            });
+        });
+    };
+
+    return { app, start, stop };
+}
