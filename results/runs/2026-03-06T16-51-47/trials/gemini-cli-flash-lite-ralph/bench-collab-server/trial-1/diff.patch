@@ -0,0 +1,208 @@
+import request from 'supertest';
+import { createApp } from './server';
+import path from 'path';
+import fs from 'fs';
+import http from 'http'; // Import the http module
+import Database from 'better-sqlite3'; // Import better-sqlite3 for test DB manipulation
+
+// Use a unique temporary database file for each test run
+const DB_TEST_DIR = '/tmp/.gemini/tmp/workspace';
+const TEST_DB_PATH = path.join(DB_TEST_DIR, `test_collab_editor_${process.pid}.db`);
+
+// Ensure the test DB directory exists
+if (!fs.existsSync(DB_TEST_DIR)) {
+    fs.mkdirSync(DB_TEST_DIR, { recursive: true });
+}
+
+// Clean up the test database file before and after tests
+beforeAll(async () => {
+    if (fs.existsSync(TEST_DB_PATH)) {
+        fs.unlinkSync(TEST_DB_PATH);
+    }
+});
+
+afterAll(async () => {
+    if (fs.existsSync(TEST_DB_PATH)) {
+        fs.unlinkSync(TEST_DB_PATH);
+    }
+});
+
+describe('Document Management API', () => {
+    let app: express.Express;
+    let server: http.Server;
+    let port: number;
+
+    beforeAll(async () => {
+        const appInstance = createApp(TEST_DB_PATH);
+        app = appInstance.app as express.Express; // Type assertion
+        server = http.createServer(app); // Need to create a http server to get port
+
+        // Start server on a random port
+        port = await new Promise<number>((resolve) => {
+            server.listen(0, () => {
+                resolve((server.address() as { port: number }).port);
+            });
+        });
+    });
+
+    afterAll(async () => {
+        await new Promise<void>((resolve) => {
+            server.close(() => {
+                console.log('Test server closed.');
+                resolve();
+            });
+        });
+    });
+
+    it('should create a new document', async () => {
+        const response = await request(server)
+            .post('/documents')
+            .send({ title: 'My First Document' });
+
+        expect(response.status).toBe(201);
+        expect(response.body).toHaveProperty('id');
+        expect(response.body.title).toBe('My First Document');
+        expect(response.body).toHaveProperty('created_at');
+        expect(response.body).toHaveProperty('updated_at');
+    });
+
+    it('should list all documents', async () => {
+        // Create a couple of documents first
+        await request(server).post('/documents').send({ title: 'Doc A' });
+        await request(server).post('/documents').send({ title: 'Doc B' });
+
+        const response = await request(server).get('/documents');
+
+        expect(response.status).toBe(200);
+        expect(response.body).toBeInstanceOf(Array);
+        expect(response.body.length).toBeGreaterThanOrEqual(2); // At least the two we just created
+        expect(response.body.some(doc => doc.title === 'Doc A')).toBe(true);
+        expect(response.body.some(doc => doc.title === 'Doc B')).toBe(true);
+    });
+
+    it('should get a specific document by ID', async () => {
+        // Create a document
+        const createResponse = await request(server)
+            .post('/documents')
+            .send({ title: 'Document for Get Test' });
+        const docId = createResponse.body.id;
+
+        // Get the document
+        const response = await request(server).get(`/documents/${docId}`);
+
+        expect(response.status).toBe(200);
+        expect(response.body).toHaveProperty('id', docId);
+        expect(response.body.title).toBe('Document for Get Test');
+        expect(response.body.content).toBe(''); // Initially empty content
+    });
+
+    it('should return 404 if document not found for GET', async () => {
+        const response = await request(server).get('/documents/99999'); // Non-existent ID
+        expect(response.status).toBe(404);
+    });
+
+    it('should update a document title', async () => {
+        // Create a document
+        const createResponse = await request(server)
+            .post('/documents')
+            .send({ title: 'Original Title' });
+        const docId = createResponse.body.id;
+
+        // Update the document
+        const response = await request(server)
+            .put(`/documents/${docId}`)
+            .send({ title: 'Updated Title' });
+
+        expect(response.status).toBe(200);
+        expect(response.body.id).toBe(docId);
+        expect(response.body.title).toBe('Updated Title');
+        expect(response.body).toHaveProperty('updated_at');
+
+        // Verify by getting the document
+        const getResponse = await request(server).get(`/documents/${docId}`);
+        expect(getResponse.body.title).toBe('Updated Title');
+    });
+
+    it('should return 404 if document not found for PUT', async () => {
+        const response = await request(server)
+            .put('/documents/99999') // Non-existent ID
+            .send({ title: 'New Title' });
+        expect(response.status).toBe(404);
+    });
+
+    it('should delete a document', async () => {
+        // Create a document
+        const createResponse = await request(server)
+            .post('/documents')
+            .send({ title: 'Document to Delete' });
+        const docId = createResponse.body.id;
+
+        // Delete the document
+        const response = await request(server).delete(`/documents/${docId}`);
+
+        expect(response.status).toBe(204);
+
+        // Verify by trying to get the document
+        const getResponse = await request(server).get(`/documents/${docId}`);
+        expect(getResponse.status).toBe(404);
+    });
+
+    it('should return 404 if document not found for DELETE', async () => {
+        const response = await request(server).delete('/documents/99999'); // Non-existent ID
+        expect(response.status).toBe(404);
+    });
+
+    it('should get document history', async () => {
+        // Create a document
+        const createResponse = await request(server)
+            .post('/documents')
+            .send({ title: 'Document History Test' });
+        const docId = createResponse.body.id;
+
+        // Simulate some edits to create history entries (This part requires WebSocket, but we can mock DB inserts for now or rely on the PUT to update the document's content conceptually for history)
+        // The current PUT only updates title, not content. To test history properly, we need to ensure content can be updated and historical entries are made.
+        // The src/server.ts uses 'document_history' for content. Let's assume some way to update content or test history creation.
+        // For now, let's manually add a history entry for testing purposes or assume PUT/POST implicitly create history.
+        // The current POST /documents inserts version 0. The PUT only updates the document table.
+        // Let's modify the test to reflect how history is *actually* created based on src/server.ts's logic.
+        // The server's logic for GET /documents/:id fetches the latest content from document_history.
+        // However, the PUT only updates the `documents` table. The `document_history` is only created on POST.
+        // This implies that updating content would require a new endpoint or a different PUT behavior.
+
+        // Let's simulate adding history entries via DB directly for this test, as there's no direct content update endpoint yet.
+        // In a real scenario, WebSocket operations would create these.
+        const insertHistoryStmt = (content: string, version: number, ops: string) => {
+             db.prepare('INSERT INTO document_history (document_id, version, content, operations) VALUES (?, ?, ?, ?)')
+              .run(docId, version, content, ops);
+        };
+
+        // Mock database instance for direct DB manipulation in test
+        const db = new Database(TEST_DB_PATH);
+        db.exec(SCHEMA_SQL); // Ensure schema exists
+
+        insertHistoryStmt("Initial content v0", 0, '[]');
+        // Simulate a content update that should create a new history entry
+        // The PUT /documents/:id only updates title. So we cannot test content update/history creation via REST PUT.
+        // We'll test history *retrieval* assuming history entries exist.
+        // For now, let's add some historical data manually to test the GET /documents/:id/history endpoint.
+        // The server creates version 0 on POST. We need to add more entries.
+
+        const historyInsertStmt = db.prepare('INSERT INTO document_history (document_id, version, content, operations) VALUES (?, ?, ?, ?)');
+        historyInsertStmt.run(docId, 1, 'Content version 1', JSON.stringify([{ type: 'insert', position: 0, text: 'Content', version: 0, clientId: 'test-client' }]));
+        historyInsertStmt.run(docId, 2, 'Content version 1 with more', JSON.stringify([{ type: 'insert', position: 15, text: ' with more', version: 1, clientId: 'test-client' }]));
+
+        // Test history retrieval
+        const response = await request(server).get(`/documents/${docId}/history`);
+
+        expect(response.status).toBe(200);
+        expect(response.body).toBeInstanceOf(Array);
+        expect(response.body.length).toBe(3); // Version 0, 1, 2
+
+        const historyEntryV2 = response.body.find((h: any) => h.version === 2);
+        expect(historyEntryV2).not.toBeUndefined();
+        expect(historyEntryV2.content).toBe('Content version 1 with more');
+        expect(JSON.parse(historyEntryV2.operations)).toEqual([{ type: 'insert', position: 15, text: ' with more', version: 1, clientId: 'test-client' }]);
+
+        db.close(); // Close mock DB connection
+    });
+});
