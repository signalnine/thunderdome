+// src/index.ts
+// Spreadsheet class and related utilities will be defined here.
+
+/**
+ * Converts a cell reference string (e.g., "A1", "AA10") to 0-based coordinates.
+ * @param cellRef The cell reference string.
+ * @returns An object with 0-based `row` and `col` properties.
+ */
+export function cellToCoords(cellRef: string): { row: number; col: number } {
+  const match = cellRef.match(/^([A-Z]+)(\d+)$/);
+
+  if (!match) {
+    throw new Error(`Invalid cell reference: ${cellRef}`);
+  }
+
+  const [, colStr, rowStr] = match;
+
+  let col = 0;
+  for (let i = 0; i < colStr.length; i++) {
+    col = col * 26 + (colStr.charCodeAt(i) - 'A'.charCodeAt(0) + 1);
+  }
+  col--; // Adjust to 0-based
+
+  const row = parseInt(rowStr, 10) - 1; // Adjust to 0-based
+
+  return { row, col };
+}
+
+/**
+ * Converts 0-based coordinates to a cell reference string (e.g., {row: 0, col: 0} -> "A1").
+ * @param row The 0-based row index.
+ * @param col The 0-based column index.
+ * @returns The cell reference string.
+ */
+export function coordsToCell(row: number, col: number): string {
+  let colStr = '';
+  let n = col;
+  while (n >= 0) {
+    colStr = String.fromCharCode((n % 26) + 'A'.charCodeAt(0)) + colStr;
+    n = Math.floor(n / 26) - 1;
+  }
+  return `${colStr}${row + 1}`;
+}
+
+/**
+ * Parses a range string (e.g., "A1:C3") into an array of individual cell references.
+ * @param rangeRef The range reference string.
+ * @returns An array of cell reference strings.
+ */
+export function parseRange(rangeRef: string): string[] {
+  const parts = rangeRef.split(':');
+  if (parts.length === 1) {
+    // Single cell range
+    return [rangeRef];
+  } else if (parts.length === 2) {
+    const [startCellRef, endCellRef] = parts;
+    const { row: startRow, col: startCol } = cellToCoords(startCellRef);
+    const { row: endRow, col: endCol } = cellToCoords(endCellRef);
+
+    const cells: string[] = [];
+    // Ensure iteration goes from smaller to larger row/col
+    const minRow = Math.min(startRow, endRow);
+    const maxRow = Math.max(startRow, endRow);
+    const minCol = Math.min(startCol, endCol);
+    const maxCol = Math.max(startCol, endCol);
+
+    for (let r = minRow; r <= maxRow; r++) {
+      for (let c = minCol; c <= maxCol; c++) {
+        cells.push(coordsToCell(r, c));
+      }
+    }
+    return cells;
+  } else {
+    throw new Error(`Invalid range reference: ${rangeRef}`);
+  }
+}
