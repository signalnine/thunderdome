+    // String literal (e.g., "hello")
+    match = formula.substring(cursor).match(/^"([^"]*)"/);
+    if (match) {
+      tokens.push({ type: TokenType.String, value: match[1] });
+      cursor += match[0].length;
+      continue;
+    }
+
+    // Cell Reference or Range (e.g., A1, B2:C3, SUM(A1:A5))
+    match = formula.substring(cursor).match(/^([A-Z]+[1-9]\d*)(:[A-Z]+[1-9]\d*)?/i);
