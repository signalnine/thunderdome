+    // Skip whitespace
+    if (formula[cursor] === ' ') {
+      cursor++;
+      continue;
+    }
+
+    // Operators (multi-character first)
+    const operatorChars = ['>=', '<=', '<>', '=', '>', '<', '+', '-', '*', '/'];
+    let matchedOperator = false;
+    for (const op of operatorChars) {
+      if (formula.substring(cursor, cursor + op.length) === op) {
+        tokens.push({ type: TokenType.Operator, value: op });
+        cursor += op.length;
+        matchedOperator = true;
+        break;
+      }
+    }
+    if (matchedOperator) {
+      continue;
+    }
+
+    // Parentheses
+    if (formula[cursor] === '(' || formula[cursor] === ')') {
+      tokens.push({ type: TokenType.Parenthesis, value: formula[cursor] });
+      cursor++;
+      continue;
+    }
+
+    // Comma (for function arguments)
+    if (formula[cursor] === ',') {
+      tokens.push({ type: TokenType.Comma, value: ',' });
+      cursor++;
+      continue;
+    }
