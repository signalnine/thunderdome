+      case TokenType.String:
+        consume();
+        return { type: ASTNodeType.StringLiteral, value: token.value };
+      case TokenType.Boolean:
+        consume();
+        return { type: ASTNodeType.BooleanLiteral, value: token.value === 'TRUE' };
+      case TokenType.CellRef:
+        consume();
+        return { type: ASTNodeType.CellReference, value: token.value };
+      case TokenType.Range:
+        consume();
+        return { type: ASTNodeType.RangeReference, value: token.value };
+      case TokenType.Parenthesis:
+        if (token.value === '(') {
+          consume(TokenType.Parenthesis, '('); // Consume '('
+          const expression = parseExpression();
+          consume(TokenType.Parenthesis, ')'); // Consume ')'
+          return expression;
+        }
+        break;
+      case TokenType.Function:
+        return parseFunctionCall();
+    }
+    throw new Error(`Unexpected token at primary: ${token.value} (${TokenType[token.type]})`);
+  }
+
+  function parseFunctionCall(): ASTNode {
+    const functionToken = consume(TokenType.Function);
+    consume(TokenType.Parenthesis, '('); // Consume '('
+
+    const args: ASTNode[] = [];
+    if (peek() && peek()!.value !== ')') {
+      args.push(parseExpression());
+      while (peek() && peek()!.type === TokenType.Comma) {
+        consume(TokenType.Comma); // Consume ','
+        args.push(parseExpression());
+      }
+    }
+    consume(TokenType.Parenthesis, ')'); // Consume ')'
+
+    return { type: ASTNodeType.FunctionCall, value: functionToken.value, args };
+  }
+
+
+  function parseExpression(minPrecedence = 0): ASTNode {
+    let left = parsePrimary();
+
+    while (true) {
+      const operator = peek();
+      if (!operator || operator.type !== TokenType.Operator || getOperatorPrecedence(operator) < minPrecedence) {
+        break;
+      }
+
+      const currentPrecedence = getOperatorPrecedence(operator);
+      consume(TokenType.Operator, operator.value); // Consume the operator
+
+      const right = parseExpression(currentPrecedence + 1);
+
+      if (['=', '<>', '>', '<', '>=', '<='].includes(operator.value)) {
+        left = { type: ASTNodeType.ComparisonExpression, operator: operator.value, left, right };
+      } else {
+        left = { type: ASTNodeType.BinaryExpression, operator: operator.value, left, right };
+      }
+    }
+    return left;
+  }
+
+  const ast = parseExpression();
+  if (peek()) {
+    throw new Error(`Unexpected tokens at end of input: ${peek()!.value}`);
+  }
+  return ast;
+}
+
+// Define the result structure for evaluation, including collected dependencies
+interface EvaluationResult {
+  value: any;
+  dependencies: Set<string>; // Direct dependencies identified during this evaluation pass
+}
+
+export class Spreadsheet {
+  public cells: Map<string, Cell> = new Map(); // Temporarily public for debugging
+
+  constructor() {}
+
+  // Built-in functions for formula evaluation
+  private builtInFunctions: { [key: string]: (...args: any[]) => any } = {
+    SUM: (rangeCells: any[]) => {
+      if (!Array.isArray(rangeCells)) {
+        throw new Error('SUM expects a range or array of values.');
+      }
+      return rangeCells.reduce((acc, val) => {
+        const num = typeof val === 'number' ? val : parseFloat(String(val));
+        return isNaN(num) ? acc : acc + num;
+      }, 0);
+    },
+    AVERAGE: (rangeCells: any[]) => {
+      if (!Array.isArray(rangeCells)) {
+        throw new Error('AVERAGE expects a range or array of values.');
+      }
+      const numbers = rangeCells.filter(val => typeof val === 'number' || !isNaN(parseFloat(String(val))));
+      if (numbers.length === 0) return 0; // Or throw error/return #DIV/0!
+      return this.builtInFunctions.SUM(numbers) / numbers.length;
+    },
+    MIN: (rangeCells: any[]) => {
+      if (!Array.isArray(rangeCells)) {
+        throw new Error('MIN expects a range or array of values.');
+      }
+      const numbers = rangeCells.filter(val => typeof val === 'number' || !isNaN(parseFloat(String(val))));
+      if (numbers.length === 0) return 0; // Or throw error
+      return Math.min(...numbers);
+    },
+    MAX: (rangeCells: any[]) => {
+      if (!Array.isArray(rangeCells)) {
+        throw new Error('MAX expects a range or array of values.');
+      }
+      const numbers = rangeCells.filter(val => typeof val === 'number' || !isNaN(parseFloat(String(val))));
+      if (numbers.length === 0) return 0; // Or throw error
+      return Math.max(...numbers);
+    },
+    COUNT: (rangeCells: any[]) => {
+      if (!Array.isArray(rangeCells)) {
+        throw new Error('COUNT expects a range or array of values.');
+      }
+      return rangeCells.filter(val => typeof val === 'number' || typeof val === 'string' || typeof val === 'boolean').length;
+    },
+    IF: (condition: boolean, trueValue: any, falseValue: any) => {
+      return condition ? trueValue : falseValue;
+    },
+  };
+
+  /**
+   * Evaluates an Abstract Syntax Tree (AST) node to compute its value.
+   * @param node The AST node to evaluate.
+   * @param evaluatingCell The cell reference of the cell currently being evaluated (for dependency tracking).
+   * @param collectDependencies If true, dependencies will be collected into the result.
+   * @returns An object containing the computed `value` and a `Set` of `dependencies`.
+   */
+  evaluate(node: ASTNode, evaluatingCell: string, collectDependencies: boolean = true): EvaluationResult {
+    const resultDependencies = new Set<string>();
+
+    const getDependencyValue = (ref: string): any => {
+      if (collectDependencies) {
+        resultDependencies.add(ref);
+      }
+      return this.get(ref);
+    };
+
+    let computedValue: any;
+
+    switch (node.type) {
+      case ASTNodeType.NumberLiteral:
+      case ASTNodeType.StringLiteral:
+      case ASTNodeType.BooleanLiteral:
+        computedValue = node.value;
+        break;
+
+      case ASTNodeType.CellReference: {
+        const referencedCell = node.value as string;
+        computedValue = getDependencyValue(referencedCell);
+        // Handle null/empty cells in formulas as 0 for arithmetic operations
+        if (computedValue === null && ['+', '-', '*', '/'].includes(node.operator || '')) {
+            computedValue = 0;
+        }
+        break;
+      }
+
+      case ASTNodeType.RangeReference: {
+        const rangeCellsRefs = parseRange(node.value as string);
+        const values: any[] = [];
+        rangeCellsRefs.forEach(ref => {
+          values.push(getDependencyValue(ref));
+        });
+        computedValue = values;
+        break;
+      }
+
+      case ASTNodeType.BinaryExpression: {
+        const leftResult = this.evaluate(node.left!, evaluatingCell, collectDependencies);
+        const rightResult = this.evaluate(node.right!, evaluatingCell, collectDependencies);
+        
+        if (collectDependencies) {
+          leftResult.dependencies.forEach(dep => resultDependencies.add(dep));
+          rightResult.dependencies.forEach(dep => resultDependencies.add(dep));
+        }
+
+        const left = leftResult.value;
+        const right = rightResult.value;
+        const op = node.operator;
+
+        switch (op) {
+          case '+': computedValue = (typeof left === 'number' ? left : parseFloat(String(left) || '0')) + (typeof right === 'number' ? right : parseFloat(String(right) || '0')); break;
+          case '-': computedValue = (typeof left === 'number' ? left : parseFloat(String(left) || '0')) - (typeof right === 'number' ? right : parseFloat(String(right) || '0')); break;
+          case '*': computedValue = (typeof left === 'number' ? left : parseFloat(String(left) || '0')) * (typeof right === 'number' ? right : parseFloat(String(right) || '0')); break;
+          case '/':
+            const rightNum = (typeof right === 'number' ? right : parseFloat(String(right) || '0'));
+            if (rightNum === 0) computedValue = '#DIV/0!';
+            else computedValue = (typeof left === 'number' ? left : parseFloat(String(left) || '0')) / rightNum;
+            break;
+          default: throw new Error(`Unknown binary operator: ${op}`);
+        }
+        break;
+      }
+
+      case ASTNodeType.ComparisonExpression: {
+        const leftResult = this.evaluate(node.left!, evaluatingCell, collectDependencies);
+        const rightResult = this.evaluate(node.right!, evaluatingCell, collectDependencies);
+
+        if (collectDependencies) {
+          leftResult.dependencies.forEach(dep => resultDependencies.add(dep));
+          rightResult.dependencies.forEach(dep => resultDependencies.add(dep));
+        }
+        
+        const left = leftResult.value;
+        const right = rightResult.value;
+        const op = node.operator;
+
+        switch (op) {
+          case '=': computedValue = left == right; break; // Use == for loose equality to match spreadsheet behavior
+          case '<>': computedValue = left != right; break;
+          case '>': computedValue = left > right; break;
+          case '<': computedValue = left < right; break;
+          case '>=': computedValue = left >= right; break;
+          case '<=': computedValue = left <= right; break;
+          default: throw new Error(`Unknown comparison operator: ${op}`);
+        }
+        break;
+      }
+
+      case ASTNodeType.FunctionCall: {
+        const functionName = node.value as string;
+        const func = this.builtInFunctions[functionName];
+        if (!func) {
+          throw new Error(`Unknown function: ${functionName}`);
+        }
+
+        const evaluatedArgResults = node.args!.map(arg => {
+          const res = this.evaluate(arg, evaluatingCell, collectDependencies);
+          if (collectDependencies) {
+            res.dependencies.forEach(dep => resultDependencies.add(dep));
+          }
+          return res.value;
+        });
+        
+        // IF function takes arguments as-is, SUM/AVERAGE/etc expect range values
+        if (functionName === 'IF') {
+            computedValue = func(...evaluatedArgResults);
+        } else {
+            // For functions that operate on ranges, flatten the arguments if they are arrays (from RangeReference)
+            const flattenedArgs = evaluatedArgResults.flat();
+            computedValue = func(flattenedArgs);
+        }
+        break;
+      }
+
+      default:
+        throw new Error(`Unknown AST node type: ${ASTNodeType[node.type]}`);
+    }
+    return { value: computedValue, dependencies: resultDependencies };
+  }
+
+
+
+  get(cellRef: string): string | number | boolean | null {
+    const cell = this.cells.get(cellRef);
+    return cell ? cell.computedValue : null;
+  }
+
+  getDisplay(cellRef: string): string {
+    const value = this.get(cellRef);
+    if (value === null) return '';
+    if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';
+    return String(value);
+  }
+
+  getCells(): Map<string, any> {
+    const result = new Map<string, any>();
+    this.cells.forEach((cell, cellRef) => {
+      if (cell.computedValue !== null) {
+        result.set(cellRef, cell.computedValue);
+      }
+    });
+    return result;
+  }
+}
