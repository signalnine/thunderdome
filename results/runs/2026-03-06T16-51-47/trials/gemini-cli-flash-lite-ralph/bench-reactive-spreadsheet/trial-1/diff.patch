+// src/index.test.ts
+import { describe, it, expect, beforeEach } from 'vitest';
+import { cellToCoords, coordsToCell, parseRange, Spreadsheet, TokenType, tokenize, ASTNodeType, parse } from './index';
+
+describe('Cell Coordinate Conversions', () => {
+  it('should convert cell references to 0-based coordinates', () => {
+    expect(cellToCoords('A1')).toEqual({ row: 0, col: 0 });
+    expect(cellToCoords('B2')).toEqual({ row: 1, col: 1 });
+    expect(cellToCoords('Z1')).toEqual({ row: 0, col: 25 });
+    expect(cellToCoords('AA1')).toEqual({ row: 0, col: 26 });
+    expect(cellToCoords('AZ1')).toEqual({ row: 0, col: 51 });
+    expect(cellToCoords('BA1')).toEqual({ row: 0, col: 52 });
+    expect(cellToCoords('A100')).toEqual({ row: 99, col: 0 });
+  });
+
+  it('should convert 0-based coordinates to cell references', () => {
+    expect(coordsToCell(0, 0)).toBe('A1');
+    expect(coordsToCell(1, 1)).toBe('B2');
+    expect(coordsToCell(0, 25)).toBe('Z1');
+    expect(coordsToCell(0, 26)).toBe('AA1');
+    expect(coordsToCell(0, 51)).toBe('AZ1');
+    expect(coordsToCell(0, 52)).toBe('BA1');
+    expect(coordsToCell(99, 0)).toBe('A100');
+  });
+
+  it('should handle round trip conversion', () => {
+    const testCases = ['A1', 'B2', 'Z10', 'AA5', 'ABC123'];
+    testCases.forEach(cellRef => {
+      const coords = cellToCoords(cellRef);
+      expect(coordsToCell(coords.row, coords.col)).toBe(cellRef);
+    });
+  });
+
+  it('should throw error for invalid cell references', () => {
+    expect(() => cellToCoords('1A')).toThrow('Invalid cell reference');
+    expect(() => cellToCoords('A')).toThrow('Invalid cell reference');
+    expect(() => cellToCoords('1')).toThrow('Invalid cell reference');
+    expect(() => cellToCoords('')).toThrow('Invalid cell reference');
+  });
+});
+
+describe('Cell Range Parsing', () => {
+  it('should parse a single cell reference as a range', () => {
+    expect(parseRange('A1')).toEqual(['A1']);
+  });
+
+  it('should parse a column range correctly', () => {
+    const expected = ['A1', 'A2', 'A3'];
+    expect(parseRange('A1:A3')).toEqual(expected);
+  });
+
+  it('should parse a row range correctly', () => {
+    const expected = ['A1', 'B1', 'C1'];
+    expect(parseRange('A1:C1')).toEqual(expected);
+  });
+
+  it('should parse a block range correctly', () => {
+    const expected = [
+      'A1', 'B1', 'C1',
+      'A2', 'B2', 'C2',
+      'A3', 'B3', 'C3',
+    ];
+    expect(parseRange('A1:C3')).toEqual(expected);
+  });
+
+  it('should handle inverted ranges (end before start) correctly', () => {
+    const expected = [
+      'A1', 'B1',
+      'A2', 'B2',
+    ];
+    // Inverted column range
+    expect(parseRange('B2:A1')).toEqual(expected);
+    // Inverted row range
+    expect(parseRange('A2:B1')).toEqual(expected);
+    // Inverted block range (different order)
+    expect(parseRange('B1:A2')).toEqual(expected);
+  });
+
+  it('should throw error for invalid range references', () => {
+    expect(() => parseRange('A1:B:C')).toThrow('Invalid range reference');
+    expect(() => parseRange('A:B')).toThrow('Invalid cell reference'); // cellToCoords will throw
+    expect(() => parseRange('1:2')).toThrow('Invalid cell reference'); // cellToCoords will throw
+  });
+});
+
+describe('Spreadsheet Basic Operations (without formulas)', () => {
+  let sheet: Spreadsheet;
+
+  beforeEach(() => {
+    sheet = new Spreadsheet();
+  });
+
+  it('should set and get numeric values', () => {
+    sheet.set('A1', 10);
+    expect(sheet.get('A1')).toBe(10);
+  });
+
+  it('should set and get string values', () => {
+    sheet.set('B2', 'hello');
+    expect(sheet.get('B2')).toBe('hello');
+  });
+
+  it('should set and get boolean values', () => {
+    sheet.set('C3', true);
+    expect(sheet.get('C3')).toBe(true);
+  });
+
+  it('should return null for empty cells', () => {
+    expect(sheet.get('D4')).toBeNull();
+  });
+
+  it('should update cell values', () => {
+    sheet.set('A1', 10);
+    expect(sheet.get('A1')).toBe(10);
+    sheet.set('A1', 20);
+    expect(sheet.get('A1')).toBe(20);
+  });
+
+  it('should get display values correctly', () => {
+    sheet.set('A1', 10);
+    sheet.set('B2', 'world');
+    sheet.set('C3', true);
+    sheet.set('D4', false);
+    expect(sheet.getDisplay('A1')).toBe('10');
+    expect(sheet.getDisplay('B2')).toBe('world');
+    expect(sheet.getDisplay('C3')).toBe('TRUE');
+    expect(sheet.getDisplay('D4')).toBe('FALSE');
+    expect(sheet.getDisplay('E5')).toBe('');
+  });
+
+  it('should return all non-empty cells with getCells', () => {
+    sheet.set('A1', 1);
+    sheet.set('B2', 'test');
+    sheet.set('C3', true);
