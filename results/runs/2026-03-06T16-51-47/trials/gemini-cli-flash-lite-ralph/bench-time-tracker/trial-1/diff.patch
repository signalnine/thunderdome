@@ -0,0 +1,297 @@
+import { TimeTracker, TimeEntry } from './index.js';
+import fs from 'fs';
+import path from 'path';
+import os from 'os';
+
+describe('TimeTracker', () => {
+    let tempDir: string;
+    let dataFilePath: string;
+    let tracker: TimeTracker; // Declare tracker at a higher scope
+
+    beforeEach(() => {
+        tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'time-tracker-test-'));
+        dataFilePath = path.join(tempDir, 'test-data.json');
+        // Ensure the directory exists for tests, although TimeTracker should create it
+        fs.mkdirSync(tempDir, { recursive: true });
+        // Initialize tracker for tests that use it
+        tracker = new TimeTracker(dataFilePath);
+        vi.useFakeTimers(); // Ensure fake timers are active for all tests
+    });
+
+    afterEach(() => {
+        // Clean up the temporary directory and its contents
+        fs.rmSync(tempDir, { recursive: true, force: true });
+        vi.useRealTimers(); // Restore real timers after all tests in this describe block
+    });
+
+    describe('Initialization and Persistence', () => {
+        it('should initialize with an empty state if data file does not exist', () => {
+            // tracker is already initialized in beforeEach with a new dataFilePath
+            expect(tracker.getAllEntries()).toEqual([]);
+        });
+
+        it('should load existing entries and active timer from data file', () => {
+            const startTime = new Date('2023-01-01T10:00:00Z');
+            const endTime = new Date('2023-01-01T11:00:00Z');
+            const activeStartTime = new Date('2023-01-02T10:00:00Z');
+
+            const initialData = {
+                entries: [{ taskName: 'Existing Task', startTime: startTime.toISOString(), endTime: endTime.toISOString() }],
+                activeTimer: { taskName: 'Active Task', startTime: activeStartTime.toISOString() },
+            };
+            fs.writeFileSync(dataFilePath, JSON.stringify(initialData), 'utf-8');
+
+            // Re-initialize tracker to load from the file
+            tracker = new TimeTracker(dataFilePath);
+
+            // Expecting the loaded entries to be Date objects, not strings
+            expect(tracker.getAllEntries()).toEqual([{ taskName: 'Existing Task', startTime: startTime, endTime: endTime }]);
+            // The active timer state is implicitly tested by other tests like stopTimer and summarizeTasks.
+        });
+
+        it('should create parent directories if they do not exist on save', () => {
+            const nestedDir = path.join(tempDir, 'nested', 'data');
+            const nestedFilePath = path.join(nestedDir, 'nested-test-data.json');
+            // Create a new tracker for this specific test case to isolate directory creation
+            const nestedTracker = new TimeTracker(nestedFilePath);
