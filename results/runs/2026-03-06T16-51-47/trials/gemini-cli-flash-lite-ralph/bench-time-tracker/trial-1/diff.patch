--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,153 @@
+import fs from 'fs';
+import path from 'path';
+
+interface TimeEntry {
+    taskName: string;
+    startTime: Date;
+    endTime?: Date;
+}
+
+interface ActiveTimer {
+    taskName: string;
+    startTime: Date;
+}
+
+class TimeTracker {
+    private entries: TimeEntry[] = [];
+    private activeTimer: ActiveTimer | null = null;
+    private filePath: string;
+
+    constructor(filePath: string = 'time-tracker-data.json') {
+        this.filePath = path.resolve(filePath);
+        // Ensure directory exists before attempting to load
+        const dir = path.dirname(this.filePath);
+        if (!fs.existsSync(dir)) {
+            fs.mkdirSync(dir, { recursive: true });
+        }
+        this.loadEntries();
+    }
+
+    private loadEntries(): void {
+        try {
+            if (fs.existsSync(this.filePath)) {
+                const data = fs.readFileSync(this.filePath, 'utf-8');
+                const parsedData: { entries: TimeEntry[], activeTimer: ActiveTimer | null } = JSON.parse(data);
+                this.entries = parsedData.entries.map(entry => ({
+                    ...entry,
+                    startTime: new Date(entry.startTime),
+                    endTime: entry.endTime ? new Date(entry.endTime) : undefined,
+                }));
+                this.activeTimer = parsedData.activeTimer
+                    ? { ...parsedData.activeTimer, startTime: new Date(parsedData.activeTimer.startTime) }
+                    : null;
+            }
+        } catch (error) {
+            console.error('Error loading time tracker data:', error);
+            // If loading fails, start with empty state
+            this.entries = [];
+            this.activeTimer = null;
+        }
+    }
+
+    private saveEntries(): void {
+        try {
+            // Directory should already exist from constructor or previous save
+            const dataToSave = {
+                entries: this.entries,
+                activeTimer: this.activeTimer,
+            };
+            fs.writeFileSync(this.filePath, JSON.stringify(dataToSave, null, 2), 'utf-8');
+        } catch (error) {
+            console.error('Error saving time tracker data:', error);
+            // Handle error appropriately, e.g., throw or log
+        }
+    }
+
+    startTimer(taskName: string): void {
+        if (!taskName || taskName.trim() === '') {
+            throw new Error('Task name cannot be empty.');
+        }
+
+        // If there's an active timer, stop it first
+        if (this.activeTimer) {
+            this.stopTimer();
+        }
+
+        // Start the new timer
+        this.activeTimer = {
+            taskName: taskName.trim(),
+            startTime: new Date(),
+        };
+        // Persistence is handled by stopTimer, or when the application exits/explicitly saved.
+        // For now, only stopTimer triggers a save.
+    }
+
+    stopTimer(): void {
+        if (!this.activeTimer) {
+            throw new Error('No active timer to stop.');
+        }
+
+        const endTime = new Date();
+        const newEntry: TimeEntry = {
+            taskName: this.activeTimer.taskName,
+            startTime: this.activeTimer.startTime,
+            endTime: endTime,
+        };
+        this.entries.push(newEntry);
+        this.activeTimer = null; // Clear the active timer
+        this.saveEntries(); // Save entries to disk after stopping
+    }
+
+    // Placeholder for getAllEntries
+    getAllEntries(): TimeEntry[] {
+        // Return a copy to prevent external modification
+        return [...this.entries];
+    }
+
+    // Placeholder for getEntriesByDateRange
+    getEntriesByDateRange(startDate: Date, endDate: Date): TimeEntry[] {
+        return this.entries.filter(entry => {
+            const entryStartTime = entry.startTime;
+            // If endTime is not set, it means the timer is still running. Use current time for duration calculation.
+            const entryEndTime = entry.endTime || new Date();
+
+            // Condition: Entry starts before range ends AND Entry ends after range starts
+            return entryStartTime <= endDate && entryEndTime >= startDate;
+        });
+    }
+
+    // Placeholder for summarize
+    summarizeTasks(): Record<string, number> {
+        const summary: Record<string, number> = {};
+        const currentTime = new Date();
+
+        // Process existing completed entries
+        this.entries.forEach(entry => {
+            const taskName = entry.taskName;
+            const startTime = entry.startTime;
+            const endTime = entry.endTime as Date; // Completed entries must have an endTime
+            const duration = endTime.getTime() - startTime.getTime();
+
+            if (!summary[taskName]) {
+                summary[taskName] = 0;
+            }
+            summary[taskName] += duration;
+        });
+
+        // Process active timer if it exists
+        if (this.activeTimer) {
+            const taskName = this.activeTimer.taskName;
+            const startTime = this.activeTimer.startTime;
+            const duration = currentTime.getTime() - startTime.getTime();
+
+            if (!summary[taskName]) {
+                summary[taskName] = 0;
+            }
+            summary[taskName] += duration;
+        }
+
+        return summary;
+    }
+}
+
+export { TimeTracker, TimeEntry };
