erService.updateStatus(orderId, OrderStatus.CONFIRMED);\n    expect(orderService.getOrder(orderId)?.status).toBe(OrderStatus.CONFIRMED);\n\n    // Ship and deliver\n    orderService.updateStatus(orderId, OrderStatus.SHIPPED);\n    orderService.updateStatus(orderId, OrderStatus.DELIVERED);\n    expect(orderService.getOrder(orderId)?.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notifs = notificationService.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.PAYMENT_PROCESSED)).toBe(1);\n  });\n});\n","numLines":266,"startLine":242,"totalLines":507}}}
