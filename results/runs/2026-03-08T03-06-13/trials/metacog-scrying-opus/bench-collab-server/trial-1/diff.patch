n2. **10 concurrent clients**: The issue is that some clients receive broadcasts from other clients' ops before their own ack. The `nextMessage()` call picks up broadcast messages instead of the ack.\n\nLet me fix both:"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":937,"cache_read_input_tokens":91030,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":937},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0b27271c-c570-4b7c-9c3d-a2af3aa05996","uuid":"6695856b-4507-4425-afb3-32c0cba81e31"}
