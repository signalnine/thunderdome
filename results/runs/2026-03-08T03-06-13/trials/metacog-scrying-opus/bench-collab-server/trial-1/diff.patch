s","content":"import { describe, it, expect } from 'vitest';\nimport { applyOp, applyOps, transformOp, validateOperation, transformAgainstOps, type Operation } from '../src/ot.js';\n\ndescribe('OT Engine', () => {\n  describe('applyOp', () => {\n    it('inserts text at position', () => {\n      expect(applyOp('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');\n    });\n\n    it('inserts text at beginning', () => {\n      expect(applyOp('world', { type: 'insert', position: 0, text: 'hello ' })).toBe('hello world');\n    });\n\n    it('inserts text in middle', () => {\n      expect(applyOp('helo', { type: 'insert', position: 3, text: 'l' })).toBe('hello');\n    });\n\n    it('deletes text at position', () => {\n      expect(applyOp('hello world', { type: 'delete', position: 5, length: 6 })).toBe('hello');\n    });\n\n    it('deletes text at beginning', () => {\n      expect(applyOp('hello world', { type: 'delete', position: 0, length: 6 })).toBe('world');\n    });\n  });\n\n  describe('validateOperation', () => {\n    it('accepts valid insert', () => {\n      expect(validateOperation({ type: 'insert', position: 0, text: 'hi' }, 0)).toBeNull();\n    });\n\n    it('rejects insert with position beyond doc length', () => {\n      expect(validateOperation({ type: 'insert', position: 5, text: 'hi' }, 3)).not.toBeNull();\n    });\n\n    it('rejects insert with empty text', () => {\n      expect(validateOperation({ type: 'insert', position: 0, text: '' }, 0)).not.toBeNull();\n    });\n\n    it('accepts valid delete', () => {\n      expect(validateOperation({ type: 'delete', position: 0, length: 3 }, 5)).toBeNull();\n    });\n\n    it('rejects delete beyond doc length', () => {\n      expect(validateOperation({ type: 'delete', position: 3, length: 5 }, 5)).not.toBeNull();\n    });\n\n    it('rejects delete with zero length', () => {\n      expect(validateOperation({ type: 'delete', position: 0, length: 0 }, 5)).not.toBeNull();\n    });\n  });\n\n  describe('transformOp - insert vs insert', () => {\n    it('no change when a inserts before b', () => {\n      const a: Operation = { type: 'insert', position: 1, text: 'X' };\n      const b: Operation = { type: 'insert', position: 3, text: 'Y' };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'insert', position: 1, text: 'X' }]);\n    });\n\n    it('shifts a right when a inserts after b', () => {\n      const a: Operation = { type: 'insert', position: 5, text: 'X' };\n      const b: Operation = { type: 'insert', position: 2, text: 'YZ' };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'insert', position: 7, text: 'X' }]);\n    });\n\n    it('shifts a right when both insert at same position (tie-break)', () => {\n      const a: Operation = { type: 'insert', position: 3, text: 'X' };\n      const b: Operation = { type: 'insert', position: 3, text: 'Y' };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'insert', position: 4, text: 'X' }]);\n    });\n  });\n\n  describe('transformOp - insert vs delete', () => {\n    it('no change when insert is before delete', () => {\n      const a: Operation = { type: 'insert', position: 1, text: 'X' };\n      const b: Operation = { type: 'delete', position: 3, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'insert', position: 1, text: 'X' }]);\n    });\n\n    it('shifts insert left when insert is after delete', () => {\n      const a: Operation = { type: 'insert', position: 5, text: 'X' };\n      const b: Operation = { type: 'delete', position: 2, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'insert', position: 3, text: 'X' }]);\n    });\n\n    it('moves insert to delete position when insert is within deleted range', () => {\n      const a: Operation = { type: 'insert', position: 4, text: 'X' };\n      const b: Operation = { type: 'delete', position: 2, length: 5 };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'insert', position: 2, text: 'X' }]);\n    });\n  });\n\n  describe('transformOp - delete vs insert', () => {\n    it('no change when delete is before insert', () => {\n      const a: Operation = { type: 'delete', position: 0, length: 2 };\n      const b: Operation = { type: 'insert', position: 5, text: 'X' };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'delete', position: 0, length: 2 }]);\n    });\n\n    it('shifts delete right when delete starts after insert', () => {\n      const a: Operation = { type: 'delete', position: 5, length: 2 };\n      const b: Operation = { type: 'insert', position: 3, text: 'XY' };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'delete', position: 7, length: 2 }]);\n    });\n\n    it('splits delete when insert is within delete range', () => {\n      const a: Operation = { type: 'delete', position: 2, length: 5 };\n      const b: Operation = { type: 'insert', position: 4, text: 'XY' };\n      const result = transformOp(a, b);\n      expect(result.length).toBe(2);\n      expect(result[0]).toEqual({ type: 'delete', position: 2, length: 2 });\n      expect(result[1]).toEqual({ type: 'delete', position: 4, length: 3 });\n    });\n  });\n\n  describe('transformOp - delete vs delete', () => {\n    it('no change when a is entirely before b', () => {\n      const a: Operation = { type: 'delete', position: 0, length: 2 };\n      const b: Operation = { type: 'delete', position: 5, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'delete', position: 0, length: 2 }]);\n    });\n\n    it('shifts a left when a is entirely after b', () => {\n      const a: Operation = { type: 'delete', position: 5, length: 2 };\n      const b: Operation = { type: 'delete', position: 0, length: 3 };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'delete', position: 2, length: 2 }]);\n    });\n\n    it('returns empty when a is entirely within b', () => {\n      const a: Operation = { type: 'delete', position: 3, length: 2 };\n      const b: Operation = { type: 'delete', position: 2, length: 5 };\n      const result = transformOp(a, b);\n      expect(result).toEqual([]);\n    });\n\n    it('shrinks a when a contains b', () => {\n      const a: Operation = { type: 'delete', position: 2, length: 8 };\n      const b: Operation = { type: 'delete', position: 3, length: 3 };\n      const result = transformOp(a, b);\n      expect(result).toEqual([{ type: 'delete', position: 2, length: 5 }]);\n    });\n  });\n\n  describe('convergence', () => {\n    function converge(doc: string, a: Operation, b: Operation): { doc1: string; doc2: string } {\n      // Path 1: apply a first, then transform(b, a) applied\n      // Path 2: apply b first, then transform(a, b) applied\n      const bPrime = transformOp(b, a);\n      const aPrime = transformOp(a, b);\n      const doc1 = applyOps(applyOp(doc, a), bPrime);\n      const doc2 = applyOps(applyOp(doc, b), aPrime);\n      return { doc1, doc2 };\n    }\n\n    it('two concurrent inserts at different positions converge', () => {\n      const { doc1, doc2 } = converge(\n        'hello',\n        { type: 'insert', position: 0, text: 'A' },\n        { type: 'insert', position: 5, text: 'B' }\n      );\n      expect(doc1).toBe(doc2);\n      expect(doc1).toBe('AhelloB');\n    });\n\n    it('two concurrent inserts at same position converge', () => {\n      const { doc1, doc2 } = converge(\n        'hello',\n        { type: 'insert', position: 2, text: 'A' },\n        { type: 'insert', position: 2, text: 'B' }\n      );\n      expect(doc1).toBe(doc2);\n    });\n\n    it('concurrent insert and delete converge', () => {\n      const { doc1, doc2 } = converge(\n        'hello world',\n        { type: 'insert', position: 5, text: ' beautiful' },\n        { type: 'delete', position: 5, length: 6 }\n      );\n      expect(doc1).toBe(doc2);\n    });\n\n    it('concurrent delete and insert within delete range converge', () => {\n      const { doc1, doc2 } = converge(\n        'abcdefgh',\n        { type: 'delete', position: 2, length: 3 },\n        { type: 'insert', position: 4, text: 'X' }\n      );\n      expect(doc1).toBe(doc2);\n      expect(doc1).toContain('X');\n    });\n\n    it('two concurrent deletes converge', () => {\n      const { doc1, doc2 } = converge(\n        'hello world',\n        { type: 'delete', position: 0, length: 5 },\n        { type: 'delete', position: 6, length: 5 }\n      );\n      expect(doc1).toBe(doc2);\n      expect(doc1).toBe(' ');\n    });\n\n    it('overlapping deletes converge', () => {\n      const { doc1, doc2 } = converge(\n        'abcdefghij',\n        { type: 'delete', position: 2, length: 5 },\n        { type: 'delete', position: 4, length: 4 }\n      );\n      expect(doc1).toBe(doc2);\n    });\n  });\n\n  describe('transformAgainstOps', () => {\n    it('transforms against multiple operations', () => {\n      const ops: Operation[] = [\n        { type: 'insert', position: 0, text: 'A' },\n        { type: 'insert', position: 1, text: 'B' },\n      ];\n      const op: Operation = { type: 'insert', position: 0, text: 'X' };\n      const result = transformAgainstOps(op, ops);\n      expect(result.length).toBe(1);\n      expect(result[0]).toEqual({ type: 'insert', position: 2, text: 'X' });\n    });\n\n    it('returns empty when operation becomes redundant', () => {\n      const ops: Operation[] = [\n        { type: 'delete', position: 0, length: 5 },\n      ];\n      const op: Operation = { type: 'delete', position: 1, length: 2 };\n      const result = transformAgainstOps(op, ops);\n      expect(result).toEqual([]);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":5,"lines":[" import { describe, it, expect } from 'vitest';","-import { applyOp, transform