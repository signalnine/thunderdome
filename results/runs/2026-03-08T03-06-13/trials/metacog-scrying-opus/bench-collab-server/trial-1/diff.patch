+import { Router, json } from 'express';
+import { randomUUID } from 'crypto';
+import type Database from 'better-sqlite3';
+import {
+  createDocument,
+  getDocument,
+  listDocuments,
+  updateDocument,
+  deleteDocument,
+  getDocumentVersions,
+  getDocumentVersion,
+} from './db.js';
+
+export function createRouter(db: Database.Database): Router {
+  const router = Router();
+  router.use(json());
+
+  // List all documents
+  router.get('/documents', (_req, res) => {
+    const docs = listDocuments(db);
+    res.json(docs);
+  });
+
+  // Create a new document
+  router.post('/documents', (req, res) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'title is required and must be a string' });
+      return;
+    }
+    const id = randomUUID();
+    const doc = createDocument(db, id, title, content ?? '');
+    res.status(201).json(doc);
+  });
+
+  // Get a single document
+  router.get('/documents/:id', (req, res) => {
+    const doc = getDocument(db, req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document
+  router.put('/documents/:id', (req, res) => {
+    const { title, content } = req.body;
+    const doc = updateDocument(db, req.params.id, { title, content });
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Partially update a document
+  router.patch('/documents/:id', (req, res) => {
+    const { title, content } = req.body;
+    const doc = updateDocument(db, req.params.id, { title, content });
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req, res) => {
+    const deleted = deleteDocument(db, req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get version history for a document
+  router.get('/documents/:id/versions', (req, res) => {
+    const doc = getDocument(db, req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = getDocumentVersions(db, req.params.id);
+    res.json(versions);
+  });
+
+  // Get a specific version
+  router.get('/documents/:id/versions/:version', (req, res) => {
+    const doc = getDocument(db, req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versionNum = parseInt(req.params.version, 10);
+    if (isNaN(versionNum)) {
+      res.status(400).json({ error: 'Version must be a number' });
+      return;
+    }
+    const version = getDocumentVersion(db, req.params.id, versionNum);
+    if (!version) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+    res.json(version);
+  });
+
+  return router;
+}
