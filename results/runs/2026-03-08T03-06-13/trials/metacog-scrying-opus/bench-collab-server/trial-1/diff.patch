-    ws.on('error', reject);
-  });
-}
-
-/** Wait for the messages array to have at least `idx + 1` entries, then return messages[idx]. */
-function waitForMsg(client: WsClient, idx: number, timeout = 3000): Promise<Record<string, unknown>> {
-  return new Promise((resolve, reject) => {
-    if (client.messages.length > idx) {
-      resolve(client.messages[idx]);
-      return;
-    }
-    const timer = setTimeout(
-      () => reject(new Error(`Timed out waiting for message at index ${idx} (have ${client.messages.length})`)),
-      timeout
-    );
-    const interval = setInterval(() => {
-      if (client.messages.length > idx) {
-        clearTimeout(timer);
-        clearInterval(interval);
-        resolve(client.messages[idx]);
-      }
-    }, 5);
-  });
-}
-
-
-function delay(ms: number): Promise<void> {
-  return new Promise((resolve) => setTimeout(resolve, ms));
-}
-
-function sendOp(client: WsClient, operation: Record<string, unknown>, version?: number) {
-  const msg: Record<string, unknown> = { type: 'operation', operation };
-  if (version !== undefined) msg.version = version;
-  client.ws.send(JSON.stringify(msg));
-}
-
-function closeClient(client: WsClient): Promise<void> {
-  return new Promise((resolve) => {
-    if (client.ws.readyState === WebSocket.CLOSED || client.ws.readyState === WebSocket.CLOSING) {
-      resolve();
-      return;
-    }
-    client.ws.on('close', () => resolve());
-    client.ws.close();
-  });
-}
