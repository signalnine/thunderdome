+    it('returns 404 for non-existent document', async () => {
+      await request(appInstance.app)
+        .get('/api/documents/nonexistent/versions')
+        .expect(404);
+    });
+  });
+
+  describe('GET /api/documents/:id/versions/:version', () => {
+    it('returns a specific version', async () => {
+      const created = await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'Version Specific', content: 'v0 content' });
