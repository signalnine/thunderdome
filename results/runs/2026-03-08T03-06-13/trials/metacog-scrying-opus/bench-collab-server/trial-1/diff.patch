   const created = await request(appInstance.app)\n        .post('/api/documents')\n        .send({ title: 'Get Test' });\n\n      const res = await request(appInstance.app)\n        .get(`/api/documents/${created.body.id}`)\n        .expect(200);\n\n      expect(res.body.title).toBe('Get Test');\n    });\n\n    it('returns 404 for non-existent document', async () => {\n      await request(appInstance.app)\n        .get('/api/documents/nonexistent')\n        .expect(404);\n    });\n  });\n\n  describe('PUT /api/documents/:id', () => {\n    it('updates a document', async () => {\n      const created = await request(appInstance.app)\n        .post('/api/documents')\n        .send({ title: 'Before Update' });\n\n      const res = await request(appInstance.app)\n        .put(`/api/documents/${created.body.id}`)\n        .send({ title: 'After Update', content: 'Updated content' })\n        .expect(200);\n\n      expect(res.body.title).toBe('After Update');\n      expect(res.body.content).toBe('Updated content');\n    });\n\n    it('returns 404 for non-existent document', async () => {\n      await request(appInstance.app)\n        .put('/api/documents/nonexistent')\n        .send({ title: 'test' })\n        .expect(404);\n    });\n  });\n\n  describe('DELETE /api/documents/:id', () => {\n    it('deletes a document', async () => {\n      const created = await request(appInstance.app)\n        .post('/api/documents')\n        .send({ title: 'To Delete' });\n\n      await request(appInstance.app)\n        .delete(`/api/documents/${created.body.id}`)\n        .expect(204);\n\n      await request(appInstance.app)\n        .get(`/api/documents/${created.body.id}`)\n        .expect(404);\n    });\n\n    it('returns 404 for non-existent document', async () => {\n      await request(appInstance.app)\n        .delete('/api/documents/nonexistent')\n        .expect(404);\n    });\n  });\n\n  describe('GET /api/documents/:id/versions', () => {\n    it('returns version history', async