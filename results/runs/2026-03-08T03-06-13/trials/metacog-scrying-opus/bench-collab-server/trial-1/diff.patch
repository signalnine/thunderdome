InsertOp | DeleteOp;\n\n/**\n * Validate that an operation is well-formed and makes sense for a document of the given length.\n */\nexport function validateOperation(op: Operation, docLength: number): string | null {\n  if (op.type === 'insert') {\n    if (typeof op.position !== 'number' || op.position < 0 || op.position > docLength) {\n      return `Invalid insert position ${op.position} for document of length ${docLength}`;\n    }\n    if (typeof op.text !== 'string' || op.text.length === 0) {\n      return 'Insert operation must have non-empty text';\n    }\n  } else if (op.type === 'delete') {\n    if (typeof op.position !== 'number' || op.position < 0) {\n      return `Invalid delete position ${op.position}`;\n    }\n    if (typeof op.length !== 'number' || op.length <= 0) {\n      return 'Delete operation must have positive length';\n    }\n    if (op.position + op.length > docLength) {\n      return `Delete range [${op.position}, ${op.position + op.length}) exceeds document length ${docLength}`;\n    }\n  } else {\n    return `Unknown operation type: ${(op as { type: string }).type}`;\n  }\n  return null;\n}\n\n/**\n * Apply an operation to a document string.\n */\nexport function applyOp(doc: string, op: Operation): string {\n  if (op.type === 'insert') {\n    return doc.slice(0, op.position) + op.text + doc.slice(op.position);\n  } else {\n    return doc.slice(0, op.position) + doc.slice(op.position + op.length);\n  }\n}\n\n/**\n * Transform operation `a` against operation `b`.\n * Returns a new operation `a'` such that if `b` has already been applied to the document,\n * applying `a'` produces the same result as if both `a` and `b` were applied.\n *\n * This implements the standard OT transform function (inclusion transformation).\n * `a` is the incoming (client) operation, `b` is the already-applied (server) operation.\n */\nexport function transformOp(a: Operation, b: Operation): Operation | null {\n  if (a.type === 'insert' && b.type === 'insert') {\n  