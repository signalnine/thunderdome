 'sync';\n  content: string;\n  version: number;\n  documentId: string;\n}\n\ninterface ServerAckMessage {\n  type: 'ack';\n  version: number;\n}\n\ninterface ServerOperationMessage {\n  type: 'operation';\n  operation: Operation;\n  version: number;\n  clientId: string;\n}\n\ninterface ServerErrorMessage {\n  type: 'error';\n  message: string;\n}\n\ntype ServerMessage = ServerSyncMessage | ServerAckMessage | ServerOperationMessage | ServerErrorMessage;\n\n/**\n * Per-document state held in memory for active collaboration sessions.\n */\ninterface DocumentSession {\n  /** Current authoritative content */\n  content: string;\n  /** Current version number */\n  version: number;\n  /** History of operations since version 0, indexed by version-1 */\n  operations: Operation[];\n  /** Connected clients */\n  clients: Set<ClientConnection>;\n}\n\nexport class CollaborationManager {\n  private sessions: Map<string, DocumentSession> = new Map();\n  private wss: WebSocketServer | null = null;\n  private allConnections: Set<WebSocket> = new Set();\n\n  constructor(private db: Database.Database) {}\n\n  attach(server: HttpServer): void {\n    this.wss = new WebSocketServer({ server });\n\n    this.wss.on('connection', (ws, req) => {\n      this.allConnections.add(ws);\n\n      // Extract document ID from URL path: /ws/documents/:id\n      const url = req.url;\n      if (!url) {\n        this.sendMessage(ws, { type: 'error', message: 'No URL provided' });\n        ws.close();\n        return;\n      }\n\n      const match = url.match(/\\/ws\\/documents\\/([^/?]+)/);\n      if (!match) {\n        this.sendMessage(ws, { type: 'error', message: 'Invalid WebSocket path. Use /ws/documents/:id' });\n        ws.close();\n        return;\n      }\n\n      const documentId = match[1];\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    // Check document exists\n    const doc = getDocument(this.db, documentId);\n    if (!doc) {\n      this.sendMessage(ws, { type: 'error', message: 'Document not found' });\n      ws.close();\n      return;\n    }\n\n    // Get or create session\n    const session = this.getOrCreateSession(documentId);\n\n    // Create client connection\n    const clientId = Math.random().toString(36).substring(2, 10);\n    const connection: ClientConnection = { ws, documentId, clientId };\n    session.clients.add(connection);\n\n    // Send sync message with current state\n    this.sendMessage(ws, {\n      type: 'sync',\n      content: session.content,\n      version: session.version,\n      documentId,\n    });\n\n    // Handle incoming messages\n    ws.on('message', (data) => {\n      try {\n        const raw = data.toString();\n        const message = JSON.parse(raw);\n        this.handleMessage(connection, session, message);\n      } catch (e) {\n        this.sendMessage(ws, {\n          type: 'error',\n          message: `Invalid message: ${e instanceof Error ? e.message : String(e)}`,\n        });\n      }\n    });\n\n    // Handle disconnect\n    ws.on('close', () => {\n      session.clients.delete(connection);\n      this.allConnections.delete(ws);\n      // Don't remove the session - it keeps the in-memory state for reconnections\n    });\n\n    ws.on('error', () => {\n      session.clients.delete(connection);\n      this.allConnections.delete(ws);\n    });\n  }\n\n  private getOrCreateSession(documentId: string): DocumentSession {\n    let session = this.sessions.get(documentId);\n    if (!session) {\n      const doc = getDocument(this.db, documentId)!;\n      // Rebuild operations history from DB\n      const versions = getDocumentVersions(this.db, documentId);\n      const operations: Operation[] = [];\n      for (const v of versions) {\n        if (v.operation) {\n          operations.push(JSON.parse(v.operation));\n        }\n      }\n      session = {\n        content: doc.content,\n        version: getLatestVersion(this.db, documentId),\n        operations,\n        clients: new Set(),\n      };\n      this.sessions.set(documentId, session);\n    }\n    return session;\n  }\n\n  private handleMessage(connection: ClientConnection, session: DocumentSession, message: unknown): void {\n    if (!message || typeof message !== 'object') {\n      this.sendMessage(connection.ws, { type: 'error', message: 'Invalid message format' });\n      return;\n    }\n\n    const msg = message as Record<string, unknown>;\n\n    if (msg.type !== 'operation') {\n      this.sendMessage(connection.ws, { type: 'error', message: `Unknown message type: ${msg.type}` });\n      return;\n    }\n\n    const opMsg = msg as unknown as ClientOperationMessage;\n\n    if (!opMsg.operation || typeof opMsg.operation !== 'object') {\n      this.sendMessage(connection.ws, { type: 'error', message: 'Missing operation' });\n      return;\n    }\n\n    if (typeof opMsg.version !== 'number' || opMsg.version < 0) {\n      this.sendMessage(connection.ws, { type: 'error', message: 'Invalid version number' });\n      return;\n    }\n\n    if (opMsg.version > session.version) {\n      this.sendMessage(connection.ws, { type: 'error', message: 'Version is ahead of server' });\n      return;\n    }\n\n    // Get operations that happened since the client's version\n    const opsToTransformAgainst = session.operations.slice(opMsg.version);\n\n    // Transform the incoming operation against all concurrent operations\n    const transformedOps = transformAgainstOps(opMsg.operation, opsToTransformAgainst);\n\n    if (transformedOps.length === 0) {\n      // Operation was made redundant by concurrent operations (e.g., delete of already-deleted text)\n      this.sendMessage(connection.ws, { type: 'ack', version: session.version });\n      return;\n    }\n\n    // Validate the transformed operations against current document state\n    let tempContent = session.content;\n    for (const op of transformedOps) {\n      const validationError = validateOperation(op, tempContent.length);\n      if (validationError) {\n        this.sendMessage(connection.ws, { type: 'error', message: validationError });\n        return;\n      }\n      tempContent = applyOp(tempContent, op);\n    }\n\n    // Apply all transformed operations\n    session.content = applyOps(session.content, transformedOps);\n    session.version++;\n    // Store all ops for this version (flatten into history for future transforms)\n    for (const op of transformedOps) {\n      session.operations.push(op);\n    }\n\n    // Persist to database\n    addVersion(this.db, connection.documentId, session.version, session.content, JSON.stringify(transformedOps));\n    updateDocumentContent(this.db, connection.documentId, session.content);\n\n    // Send ack to the sender\n    this.sendMessage(connection.ws, { type: 'ack', version: session.version });\n\n    // Broadcast to all other clients on this document\n    const clientId = opMsg.clientId ?? connection.clientId;\n    for (const client of session.clients) {\n      if (client.ws !== connection.ws && client.ws.readyState === WebSocket.OPEN) {\n        for (const op of transformedOps) {\n          this.sendMessage(client.ws, {\n            type: 'operation',\n            operation: op,\n            version: session.version,\n            clientId,\n          });\n        }\n      }\n    }\n  }\n\n  private sendMessage(ws: WebSocket, message: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(message));\n    }\n  }\n\n  /**\n   * Invalidate the in-memory session for a document (e.g., after REST update).\n   */\n  invalidateSession(documentId: string): void {\n    this.sessions.delete(documentId);\n  }\n\n  /**\n   * Close all connections and clean up.\n   */\n  shutdown(): void {\n    for (const ws of this.allConnections) {\n      ws.close();\n    }\n    this.allConnections.clear();\n    this.sessions.clear();\n    if (this.wss) {\n      this.wss.close();\n      this.wss = n