) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  // Delete a document\n  router.delete('/documents/:id', (req, res) => {\n    const deleted = deleteDocument(db, req.params.id);\n    if (!deleted) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get version history for a document\n  router.get('/documents/:id/versions', (req, res) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = getDocumentVersions(db, req.params.id);\n    res.json(versions);\n  });\n\n  // Get a specific version\n  router.get('/documents/:id/versions/:version', (req, res) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versionNum = parseInt(req.params.version, 10);\n    if (isNaN(versionNum)) {\n      res.status(400).json({ error: 'Version must be a number' });\n      return;\n    }\n    const version = getDocumentVersion(db, req.params.id, versionNum);\n    if (!version) {\n      res.status(404).json({ error: 'Version not found' });\n      return;\n    }\n    res.json(version);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":341,"cache_read_input_tokens":27974,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":341},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0b27271c-c570-4b7c-9c3d-a2af3aa05996","uuid":"8cb2eb5c-c815-4127-b1ef-cd8eed582a03"}
