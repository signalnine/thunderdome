+
+      expect(res.body.content).toBe('');
+    });
+
+    it('rejects document without title', async () => {
+      await request(appInstance.app)
+        .post('/api/documents')
+        .send({ content: 'No title' })
+        .expect(400);
+    });
+  });
+
+  describe('GET /api/documents', () => {
+    it('lists all documents', async () => {
+      const res = await request(appInstance.app)
+        .get('/api/documents')
+        .expect(200);
+
+      expect(Array.isArray(res.body)).toBe(true);
+      expect(res.body.length).toBeGreaterThanOrEqual(2);
+    });
+  });
+
+  describe('GET /api/documents/:id', () => {
+    it('retrieves a document by id', async () => {
+      const created = await request(appInstance.app)
+        .post('/api/documents')
+        .send({ title: 'Get Test' });
+
+      const res = await request(appInstance.app)
+        .get(`/api/documents/${created.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('Get Test');
+    });
