@@ -0,0 +1,63 @@
+import express from 'express';
+import { createServer, type Server as HttpServer } from 'http';
+import type Database from 'better-sqlite3';
+import { createDb } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  server: HttpServer;
+  db: Database.Database;
+  collaborationManager: CollaborationManager;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDb(dbPath);
+  const app = express();
+  const server = createServer(app);
+
+  // REST routes
+  const router = createRouter(db);
+  app.use('/api', router);
+
+  // WebSocket collaboration
+  const collaborationManager = new CollaborationManager(db);
+  collaborationManager.attach(server);
+
+  const instance: AppInstance = {
+    app,
+    server,
+    db,
+    collaborationManager,
+
+    start(port = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        server.listen(port, () => {
+          const addr = server.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Failed to get server address'));
+          }
+        });
+        server.on('error', reject);
+      });
+    },
+
+    stop(): Promise<void> {
+      return new Promise((resolve, reject) => {
+        collaborationManager.shutdown();
+        server.close((err) => {
+          db.close();
+          if (err) reject(err);
+          else resolve();
+        });
+      });
+    },
+  };
+
+  return instance;
+}
