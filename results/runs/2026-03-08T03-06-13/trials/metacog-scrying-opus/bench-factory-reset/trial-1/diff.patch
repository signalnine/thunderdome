alues[j] = 0;","+          for (let i = 0; i < numButtons; i++) {","+            residuals[i] = mod(residuals[i] + coeffs[i][j], p);","+          }","+        } else {","+          for (let i = 0; i < numButtons; i++) {","+            residuals[i] = mod(residuals[i] + coeffs[i][j], p);","+          }","+          break;","+        }","+      }","+    }","+","+    let sum = 0;","+    for (let i = 0; i < numButtons; i++) sum += residuals[i];","+","+    loEntries.push({","+      sum,","+      xlo: loValues.slice(),","+      residuals: residuals.slice()","+    });","+  }","+","+  // Phase 2: for each x_hi combo, compute partial_hi and find best x_lo","+  // For each x_hi, for each lo entry, total = sum_i (lo_residual[i] + partial_hi[i]) mod p","+  // We can't avoid O(size1 * size2 * numButtons) in the worst case with this approach.","+  // But we can sort lo entries by sum and prune.","+","+  // Sort lo entries by sum (ascending) for pruning","+  loEntries.sort((a, b) => a.sum - b.sum);","+","+  let bestSolution: number[] | null = null;","+  let bestTotal = Infinity;","+","+  const hiValues = new Array(half2).fill(0);","+  const partialHi = new Array(numButtons).fill(0);","+","+  for (let combo = 0; combo < size2; combo++) {","+    if (combo > 0) {","+      for (let j = 0; j < half2; j++) {","+        hiValues[j]++;","+        if (hiValues[j] >= p) {","+          hiValues[j] = 0;","+          for (let i = 0; i < numButtons; i++) {","+            partialHi[i] = mod(partialHi[i] + coeffs[i][j + half1], p);","+          }","+        } else {","+          for (let i = 0; i < numButtons; i++) {","+            partialHi[i] = mod(partialHi[i] + coeffs[i][j + half1], p);","+          }","+          break;","+        }","+      }","+    }","+","+    let hiSum = 0;","+    for (let i = 0; i < numButtons; i++) hiSum += partialHi[i];","+","+    // Lower bound for any lo entry: lo.sum + hiSum - p * numButtons (if all wrap)","+    // Upper bound we're interested in: bestTotal","+    /