+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numButtons = buttons.length;
+  const numLights = target.length;
+
+  if (numButtons === 0) {
+    return target.some(t => t) ? null : [];
+  }
+
+  // Build augmented matrix over GF(2): rows=lights, cols=buttons+1
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+  for (let b = 0; b < numButtons; b++) {
+    for (const light of buttons[b]) {
+      if (light < numLights) matrix[light][b] ^= 1;
+    }
+  }
+
+  // Gaussian elimination over GF(2) to RREF
+  const pivotCol: number[] = [];
+  let rank = 0;
+  for (let col = 0; col < numButtons; col++) {
+    let found = -1;
+    for (let row = rank; row < numLights; row++) {
+      if (matrix[row][col] === 1) { found = row; break; }
+    }
+    if (found === -1) continue;
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+    pivotCol.push(col);
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && matrix[row][col] === 1) {
+        for (let c = 0; c < numButtons + 1; c++) matrix[row][c] ^= matrix[rank][c];
+      }
+    }
+    rank++;
+  }
+
+  // Check inconsistency
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] === 1) return null;
+  }
+
+  // Identify free variables
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) freeVars.push(col);
+  }
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const values = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) values[pivotCol[r]] = matrix[r][numButtons];
+    const pressed: number[] = [];
+    for (let i = 0; i < numButtons; i++) if (values[i] === 1) pressed.push(i);
+    return pressed;
+  }
+
+  // Express each button value as: baseVal[i] XOR parity(coeff[i] & freeAssignment)
+  // For numFree <= 30, use regular numbers. Otherwise use bigint.
+  if (numFree <= 30) {
+    return solveToggleFreeSmall(numButtons, numFree, matrix, rank, pivotCol, freeVars);
+  } else {
+    return solveToggleFreeLarge(numButtons, numFree, matrix, rank, pivotCol, freeVars);
+  }
+}
+
+function solveToggleFreeSmall(
+  numButtons: number, numFree: number, matrix: number[][],
+  rank: number, pivotCol: number[], freeVars: number[]
+): number[] {
+  const baseVal = new Array(numButtons).fill(0);
+  const coeff = new Array(numButtons).fill(0);
+  for (let j = 0; j < numFree; j++) coeff[freeVars[j]] = 1 << j;
+  for (let r = 0; r < rank; r++) {
+    const pc = pivotCol[r];
+    baseVal[pc] = matrix[r][numButtons];
+    let c = 0;
+    for (let j = 0; j < numFree; j++) {
+      if (matrix[r][freeVars[j]] === 1) c |= (1 << j);
+    }
+    coeff[pc] = c;
+  }
+
+  // Group buttons by coeff value
+  const groups = new Map<number, { size: number; baseOnes: number }>();
+  for (let i = 0; i < numButtons; i++) {
+    const c = coeff[i];
+    const g = groups.get(c);
+    if (g) { g.size++; g.baseOnes += baseVal[i]; }
+    else groups.set(c, { size: 1, baseOnes: baseVal[i] });
+  }
+  const gCoeffs: number[] = [];
+  const gSizes: number[] = [];
+  const gBaseOnes: number[] = [];
+  for (const [c, g] of groups) { gCoeffs.push(c); gSizes.push(g.size); gBaseOnes.push(g.baseOnes); }
+  const numGroups = gCoeffs.length;
+
+  const countForF = (f: number): number => {
+    let count = 0;
+    for (let g = 0; g < numGroups; g++) {
+      count += parity32(gCoeffs[g] & f) ? gSizes[g] - gBaseOnes[g] : gBaseOnes[g];
+    }
+    return count;
+  };
+
+  const buildSol = (f: number): number[] => {
+    const pressed: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if ((baseVal[i] ^ parity32(coeff[i] & f)) === 1) pressed.push(i);
+    }
+    return pressed;
+  };
+
+  if (numFree <= 22) {
+    // Direct enumeration - 2^22 * 40 groups ≈ 168M ops, fast enough
+    let bestCount = numButtons + 1;
+    let bestF = 0;
+    const limit = 1 << numFree;
+    for (let f = 0; f < limit; f++) {
+      const count = countForF(f);
+      if (count < bestCount) { bestCount = count; bestF = f; }
+      else if (count === bestCount && lexSmaller(buildSol(f), buildSol(bestF))) {
+        bestF = f;
+      }
+    }
+    return buildSol(bestF);
+  }
+
+  // Meet-in-the-middle
+  const half1 = numFree >> 1;
+  const half2 = numFree - half1;
+  const mask1 = (1 << half1) - 1;
+  const gCoeffsLo = gCoeffs.map(c => c & mask1);
+  const gCoeffsHi = gCoeffs.map(c => c >>> half1);
+  const deltas = gSizes.map((s, i) => s - 2 * gBaseOnes[i]);
+
+  // Build loMap: signature -> flo (keep the first/smallest flo per sig)
+  const loMap = new Map<number, number>();
+  for (let flo = 0; flo < (1 << half1); flo++) {
+    let sig = 0;
+    for (let g = 0; g < numGroups; g++) {
+      if (parity32(gCoeffsLo[g] & flo)) sig |= (1 << g);
+    }
+    if (!loMap.has(sig)) loMap.set(sig, flo);
+  }
+
+  let bestCount = numButtons + 1;
+  let bestF = 0;
+
+  for (let fhi = 0; fhi < (1 << half2); fhi++) {
+    let hiSig = 0;
+    for (let g = 0; g < numGroups; g++) {
+      if (parity32(gCoeffsHi[g] & fhi)) hiSig |= (1 << g);
+    }
+
+    // Ideal: flip group g iff delta_g < 0
+    let targetLoSig = 0;
+    for (let g = 0; g < numGroups; g++) {
+      const wantFlip = deltas[g] < 0 ? 1 : 0;
+      if (wantFlip !== ((hiSig >> g) & 1)) targetLoSig |= (1 << g);
+    }
+
+    // Check target + distance-1 neighbors + distance-2 neighbors
+    const checked = new Set<number>();
+    const tryFlo = (sig: number) => {
+      if (checked.has(sig)) return;
+      checked.add(sig);
+      const flo = loMap.get(sig);
+      if (flo === undefined) return;
+      const f = flo | (fhi << half1);
+      const count = countForF(f);
+      if (count < bestCount) { bestCount = count; bestF = f; }
+      else if (count === bestCount && lexSmaller(buildSol(f), buildSol(bestF))) {
+        bestF = f;
+      }
+    };
+
+    tryFlo(targetLoSig);
+    for (let g = 0; g < numGroups; g++) {
+      tryFlo(targetLoSig ^ (1 << g));
+      for (let g2 = g + 1; g2 < numGroups; g2++) {
+        tryFlo(targetLoSig ^ (1 << g) ^ (1 << g2));
+      }
+    }
+  }
+
+  // Also check f=0
+  {
+    const count = countForF(0);
+    if (count < bestCount) { bestCount = count; bestF = 0; }
+    else if (count === bestCount && lexSmaller(buildSol(0), buildSol(bestF))) {
+      bestF = 0;
+    }
+  }
+
+  return buildSol(bestF);
+}
+
+function solveToggleFreeLarge(
+  numButtons: number, numFree: number, matrix: number[][],
+  rank: number, pivotCol: number[], freeVars: number[]
+): number[] {
+  // BigInt path for > 30 free vars
+  const baseVal = new Array(numButtons).fill(0);
+  const coeff: bigint[] = new Array(numButtons).fill(0n);
+  for (let j = 0; j < numFree; j++) coeff[freeVars[j]] = 1n << BigInt(j);
+  for (let r = 0; r < rank; r++) {
+    const pc = pivotCol[r];
+    baseVal[pc] = matrix[r][numButtons];
+    let c = 0n;
+    for (let j = 0; j < numFree; j++) {
+      if (matrix[r][freeVars[j]] === 1) c |= (1n << BigInt(j));
+    }
+    coeff[pc] = c;
+  }
+
+  // Group buttons by coeff value
+  const groups = new Map<bigint, { size: number; baseOnes: number }>();
+  for (let i = 0; i < numButtons; i++) {
+    const c = coeff[i];
+    const g = groups.get(c);
+    if (g) { g.size++; g.baseOnes += baseVal[i]; }
+    else groups.set(c, { size: 1, baseOnes: baseVal[i] });
+  }
+  const gCoeffs: bigint[] = [];
+  const gSizes: number[] = [];
+  const gBaseOnes: number[] = [];
+  for (const [c, g] of groups) { gCoeffs.push(c); gSizes.push(g.size); gBaseOnes.push(g.baseOnes); }
+  const numGroups = gCoeffs.length;
+  const deltas = gSizes.map((s, i) => s - 2 * gBaseOnes[i]);
+
+  const countForF = (f: bigint): number => {
+    let count = 0;
+    for (let g = 0; g < numGroups; g++) {
+      count += parityBig(gCoeffs[g] & f) ? gSizes[g] - gBaseOnes[g] : gBaseOnes[g];
+    }
+    return count;
+  };
+
+  const buildSol = (f: bigint): number[] => {
+    const pressed: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if ((baseVal[i] ^ (parityBig(coeff[i] & f) ? 1 : 0)) === 1) pressed.push(i);
+    }
+    return pressed;
+  };
+
+  const half1 = numFree >> 1;
+  const half2 = numFree - half1;
+  const mask1 = (1n << BigInt(half1)) - 1n;
+  const gCoeffsLo = gCoeffs.map(c => c & mask1);
+  const gCoeffsHi = gCoeffs.map(c => c >> BigInt(half1));
+
+  // Build loMap
+  const loMap = new Map<number, bigint>();
+  for (let floi = 0; floi < (1 << half1); floi++) {
+    const flo = BigInt(floi);
+    let sig = 0;
+    for (let g = 0; g < numGroups; g++) {
+      if (parityBig(gCoeffsLo[g] & flo)) sig |= (1 << g);
+    }
+    if (!loMap.has(sig)) loMap.set(sig, flo);
+  }
+
+  let bestCount = numButtons + 1;
+  let bestF = 0n;
+
+  for (let fhii = 0; fhii < (1 << half2); fhii++) {
+    const fhi = BigInt(fhii);
+    let hiSig = 0;
+    for (let g = 0; g < numGroups; g++) {
+      if (parityBig(gCoeffsHi[g] & fhi)) hiSig |= (1 << g);
+    }
+
+    let targetLoSig = 0;
+    for (let g = 0; g < numGroups; g++) {
+      const wantFlip = deltas[g] < 0 ? 1 : 0;
+      if (wantFlip !== ((hiSig >> g) & 1)) targetLoSig |= (1 << g);
+    }
+
+    const checked = new Set<number>();
+    const tryFlo = (sig: number) => {
+      if (checked.has(sig)) return;
+      checked.add(sig);
+      const flo = loMap.get(sig);
+      if (flo === undefined) return;
+      const f = flo | (fhi << BigInt(half1));
+      const count = countForF(f);
+      if (count < bestCount) { bestCount = count; bestF = f; }
+      else if (count === bestCount && lexSmaller(buildSol(f), buildSol(bestF))) {
+        bestF = f;
+      }
+    };
+
+    tryFlo(targetLoSig);
+    for (let g = 0; g < numGroups; g++) {
+      tryFlo(targetLoSig ^ (1 << g));
+      for (let g2 = g + 1; g2 < numGroups; g2++) {
+        tryFlo(targetLoSig ^ (1 << g) ^ (1 << g2));
+      }
+    }
+  }
+
+  // Also check f=0
+  {
+    const count = countForF(0n);
+    if (count < bestCount) { bestCount = count; bestF = 0n; }
+    else if (count === bestCount && lexSmaller(buildSol(0n), buildSol(bestF))) {
+      bestF = 0n;
+    }
+  }
+
+  return buildSol(bestF);
+}
+
+function parityBig(x: bigint): boolean {
+  let p = false;
+  while (x > 0n) {
+    if (x & 1n) p = !p;
+    x >>= 1n;
+  }
+  return p;
+}
+
+function parity32(x: number): number {
+  x ^= x >> 16;
+  x ^= x >> 8;
+  x ^= x >> 4;
+  x ^= x >> 2;
+  x ^= x >> 1;
+  return x & 1;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+// ============================================================
+// Part 2: Counter Puzzle over GF(p)
+// ============================================================
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numButtons = buttons.length;
+  const numLights = lights.length;
+
+  if (numButtons === 0) {
+    return lights.some(l => mod(l, modulus) !== 0) ? null : [];
+  }
+
+  // Build augmented matrix over GF(p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = mod(lights[i], modulus);
+    matrix.push(row);
+  }
+  for (let b = 0; b < numButtons; b++) {
+    for (const light of buttons[b]) {
+      if (light < numLights) {
+        matrix[light][b] = mod(matrix[light][b] + 1, modulus);
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(p) to RREF
+  const pivotCol: number[] = [];
+  let rank = 0;
+  for (let col = 0; col < numButtons; col++) {
+    let found = -1;
+    for (let row = rank; row < numLights; row++) {
+      if (matrix[row][col] !== 0) { found = row; break; }
+    }
+    if (found === -1) continue;
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+    pivotCol.push(col);
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let c = 0; c < numButtons + 1; c++) matrix[rank][c] = mod(matrix[rank][c] * inv, modulus);
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = 0; c < numButtons + 1; c++) {
+          matrix[row][c] = mod(matrix[row][c] - factor * matrix[rank][c], modulus);
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check inconsistency
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] !== 0) return null;
+  }
+
+  // Identify free variables
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) freeVars.push(col);
+  }
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const values = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) values[pivotCol[r]] = matrix[r][numButtons];
+    return values;
+  }
+
+  // Express each button value as affine function of free vars
+  const base = new Array(numButtons).fill(0);
+  const coeffs: number[][] = Array.from({ length: numButtons }, () => new Array(numFree).fill(0));
+
+  for (let j = 0; j < numFree; j++) coeffs[freeVars[j]][j] = 1;
+  for (let r = 0; r < rank; r++) {
+    const pc = pivotCol[r];
+    base[pc] = matrix[r][numButtons];
+    for (let j = 0; j < numFree; j++) {
+      coeffs[pc][j] = mod(-matrix[r][freeVars[j]], modulus);
+    }
+  }
+
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (totalCombinations <= 10_000_000) {
+    return enumCounterDirect(numButtons, numFree, base, coeffs, modulus);
+  }
+
+  return counterCoordinateDescent(numButtons, numFree, base, coeffs, modulus);
+}
+
+function enumCounterDirect(
+  numButtons: number, numFree: number, base: number[],
+  coeffs: number[][], modulus: number
+): number[] {
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+  const p = modulus;
+  const values = new Array(numButtons);
+  for (let i = 0; i < numButtons; i++) values[i] = base[i];
+  const freeValues = new Array(numFree).fill(0);
+  const totalCombinations = Math.pow(p, numFree);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    if (combo > 0) {
+      for (let j = 0; j < numFree; j++) {
+        freeValues[j]++;
+        if (freeValues[j] >= p) {
+          freeValues[j] = 0;
+          for (let i = 0; i < numButtons; i++) values[i] = mod(values[i] + coeffs[i][j], p);
+        } else {
+          for (let i = 0; i < numButtons; i++) values[i] = mod(values[i] + coeffs[i][j], p);
+          break;
+        }
+      }
+    }
+
+    let sum = 0;
+    for (let i = 0; i < numButtons; i++) sum += values[i];
+
+    if (sum < bestSum || (sum === bestSum && lexSmallerArray(values, bestSolution!))) {
+      bestSum = sum;
+      bestSolution = values.slice();
+    }
+  }
+
+  return bestSolution!;
+}
+
+function counterCoordinateDescent(
+  numButtons: number, numFree: number, base: number[],
+  coeffs: number[][], modulus: number
+): number[] {
+  const p = modulus;
+  const freeValues = new Array(numFree).fill(0);
+
+  for (let round = 0; round < 20; round++) {
+    let improved = false;
+    for (let j = 0; j < numFree; j++) {
+      let bestVal = freeValues[j];
+      let bestSum = Infinity;
+      let bestSol: number[] | null = null;
+
+      for (let v = 0; v < p; v++) {
+        freeValues[j] = v;
+        const solution = computeCounterSolution(numButtons, numFree, base, coeffs, freeValues, p);
+        const sum = solution.reduce((a, b) => a + b, 0);
+        if (sum < bestSum || (sum === bestSum && (bestSol === null || lexSmallerArray(solution, bestSol)))) {
+          bestSum = sum;
+          bestVal = v;
+          bestSol = solution;
+        }
+      }
+
+      if (freeValues[j] !== bestVal) improved = true;
+      freeValues[j] = bestVal;
+    }
+    if (!improved) break;
+  }
+
+  return computeCounterSolution(numButtons, numFree, base, coeffs, freeValues, modulus);
+}
+
+function computeCounterSolution(
+  numButtons: number, numFree: number, base: number[],
+  coeffs: number[][], freeValues: number[], modulus: number
+): number[] {
+  const solution = new Array(numButtons);
+  for (let i = 0; i < numButtons; i++) {
+    let val = base[i];
+    for (let j = 0; j < numFree; j++) val += coeffs[i][j] * freeValues[j];
+    solution[i] = mod(val, modulus);
+  }
+  return solution;
+}
+
+function lexSmallerArray(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function mod(a: number, m: number): number {
+  return ((a % m) + m) % m;
+}
+
+function modInverse(a: number, m: number): number {
+  a = mod(a, m);
+  let [old_r, r] = [a, m];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return mod(old_s, m);
+}
