+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph and return a topological ordering.
+ * Throws an error if a cycle (including self-references) is found.
+ * Only considers prerequisites that reference events in the provided list.
+ */
+function detectCycleAndTopoSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+
+  // Build adjacency list (prereq -> dependent) only for known events
+  const adjList = new Map<string, string[]>();
+  const inDegree = new Map<string, number>();
+
+  for (const e of events) {
+    if (!adjList.has(e.id)) adjList.set(e.id, []);
+    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);
+
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        // Self-reference is always a cycle
+        if (prereq === e.id) {
+          throw new Error(`Cycle detected: event "${e.id}" has itself as a prerequisite`);
+        }
+        // Only consider prerequisites that exist in our event list
+        if (!eventIds.has(prereq)) continue;
+        if (!adjList.has(prereq)) adjList.set(prereq, []);
+        if (!inDegree.has(prereq)) inDegree.set(prereq, 0);
+        adjList.get(prereq)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  // Kahn's algorithm
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    sorted.push(node);
+    for (const neighbor of adjList.get(node) ?? []) {
+      const newDeg = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) queue.push(neighbor);
+    }
+  }
+
+  if (sorted.length < inDegree.size) {
+    throw new Error('Cycle detected in prerequisite graph');
+  }
+
+  return sorted.filter(id => eventIds.has(id));
+}
+
+interface RoomTimeline {
+  roomId: string;
+  capacity: number;
+  slots: Array<{ start: number; end: number }>;
+}
+
+function findEarliestSlot(
+  timeline: RoomTimeline,
+  duration: number,
+  earliestStart: number,
+  windowEnd: number,
+  gap: number
+): number | null {
+  if (earliestStart + duration > windowEnd) return null;
+
+  if (timeline.slots.length === 0) {
+    return earliestStart;
+  }
+
+  // Collect candidate start times
+  const candidates: number[] = [earliestStart];
+  for (const slot of timeline.slots) {
+    candidates.push(slot.end + gap);
+  }
+  candidates.sort((a, b) => a - b);
+
+  for (const candidateStart of candidates) {
+    if (candidateStart < earliestStart) continue;
+    const candidateEnd = candidateStart + duration;
+    if (candidateEnd > windowEnd) continue;
+
+    let conflicts = false;
+    for (const slot of timeline.slots) {
+      // Check overlap including gap margins
+      if (candidateStart < slot.end + gap && candidateEnd > slot.start - gap) {
+        conflicts = true;
+        break;
+      }
+    }
+
+    if (!conflicts) {
+      return candidateStart;
+    }
+  }
+
+  return null;
+}
+
+/**
+ * Run a greedy scheduling pass with a given event ordering.
+ * Returns the assignments and unscheduled lists.
+ */
+function greedySchedule(
+  sortedEventIds: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  timelines: Map<string, RoomTimeline>,
+  startTime: number,
+  endTime: number,
+  gap: number,
+): { assignments: Map<string, Assignment>; unscheduled: string[] } {
+  const assignments = new Map<string, Assignment>();
+  const unscheduled: string[] = [];
+
+  for (const eventId of sortedEventIds) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+
+    // Compute earliest start based on prerequisites
+    let earliestStart = startTime;
+    let prereqFailed = false;
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (!eventMap.has(prereqId)) continue; // ignore unknown prereqs
+        const prereqAssignment = assignments.get(prereqId);
+        if (prereqAssignment) {
+          earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);
+        } else {
+          // Prerequisite exists but wasn't scheduled
+          prereqFailed = true;
+          break;
+        }
+      }
+    }
+
+    if (prereqFailed || earliestStart + event.duration > endTime) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    // Sort rooms: preferred room first, then smallest capacity that fits
+    const viableRooms = rooms
+      .filter(r => r.capacity >= attendees)
+      .sort((a, b) => {
+        if (event.preferredRoom) {
+          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;
+          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;
+        }
+        return a.capacity - b.capacity;
+      });
+
+    let placed = false;
+    for (const room of viableRooms) {
+      const timeline = timelines.get(room.id)!;
+      const slotStart = findEarliestSlot(timeline, event.duration, earliestStart, endTime, gap);
+      if (slotStart !== null) {
+        assignments.set(event.id, {
+          eventId: event.id,
+          roomId: room.id,
+          startTime: slotStart,
+          endTime: slotStart + event.duration,
+        });
+        timeline.slots.push({ start: slotStart, end: slotStart + event.duration });
+        timeline.slots.sort((a, b) => a.start - b.start);
+        placed = true;
+        break;
+      }
+    }
+
+    if (!placed) {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  // Detect cycles and get topological order
+  const topoOrder = detectCycleAndTopoSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Compute viable room count for each event
+  const viableRoomCount = new Map<string, number>();
+  for (const e of events) {
+    const attendees = e.attendees ?? 1;
+    const count = rooms.filter(r => r.capacity >= attendees).length;
+    viableRoomCount.set(e.id, count);
+  }
+
+  // Compute topological levels (longest path from a root)
+  const levels = new Map<string, number>();
+  function getLevel(id: string): number {
+    if (levels.has(id)) return levels.get(id)!;
+    const ev = eventMap.get(id);
+    if (!ev || !ev.prerequisites || ev.prerequisites.length === 0) {
+      levels.set(id, 0);
+      return 0;
+    }
+    let maxPrereqLevel = 0;
+    for (const prereq of ev.prerequisites) {
+      if (eventMap.has(prereq)) {
+        maxPrereqLevel = Math.max(maxPrereqLevel, getLevel(prereq) + 1);
+      }
+    }
+    levels.set(id, maxPrereqLevel);
+    return maxPrereqLevel;
+  }
+  for (const e of events) {
+    getLevel(e.id);
+  }
+
+  // Compute the length of the longest chain each event participates in
+  // (both as ancestor and descendant)
+  const chainDepth = new Map<string, number>();
+  const dependents = new Map<string, string[]>();
+  for (const e of events) {
+    if (!dependents.has(e.id)) dependents.set(e.id, []);
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        if (eventMap.has(prereq)) {
+          if (!dependents.has(prereq)) dependents.set(prereq, []);
+          dependents.get(prereq)!.push(e.id);
+        }
+      }
+    }
+  }
+
+  function getMaxDepth(id: string, memo: Map<string, number>): number {
+    if (memo.has(id)) return memo.get(id)!;
+    const deps = dependents.get(id) ?? [];
+    let maxChild = 0;
+    for (const dep of deps) {
+      maxChild = Math.max(maxChild, 1 + getMaxDepth(dep, memo));
+    }
+    memo.set(id, maxChild);
+    return maxChild;
+  }
+  const depthMemo = new Map<string, number>();
+  for (const e of events) {
+    const depth = (levels.get(e.id) ?? 0) + getMaxDepth(e.id, depthMemo);
+    chainDepth.set(e.id, depth);
+  }
+
+  // Create base timelines
+  function makeTimelines(): Map<string, RoomTimeline> {
+    const tls = new Map<string, RoomTimeline>();
+    for (const room of rooms) {
+      tls.set(room.id, { roomId: room.id, capacity: room.capacity, slots: [] });
+    }
+    return tls;
+  }
+
+  // Strategy 1: most-constrained-first within topological levels
+  const ordering1 = [...topoOrder].sort((a, b) => {
+    const levelDiff = (levels.get(a) ?? 0) - (levels.get(b) ?? 0);
+    if (levelDiff !== 0) return levelDiff;
+    const viableDiff = (viableRoomCount.get(a) ?? 0) - (viableRoomCount.get(b) ?? 0);
+    if (viableDiff !== 0) return viableDiff;
+    const durA = eventMap.get(a)?.duration ?? 0;
+    const durB = eventMap.get(b)?.duration ?? 0;
+    return durB - durA;
+  });
+
+  // Strategy 2: longest chain first (prioritize events in long prerequisite chains)
+  const ordering2 = [...topoOrder].sort((a, b) => {
+    const levelDiff = (levels.get(a) ?? 0) - (levels.get(b) ?? 0);
+    if (levelDiff !== 0) return levelDiff;
+    const chainDiff = (chainDepth.get(b) ?? 0) - (chainDepth.get(a) ?? 0);
+    if (chainDiff !== 0) return chainDiff;
+    const viableDiff = (viableRoomCount.get(a) ?? 0) - (viableRoomCount.get(b) ?? 0);
+    if (viableDiff !== 0) return viableDiff;
+    return 0;
+  });
+
+  // Strategy 3: longest duration first within levels
+  const ordering3 = [...topoOrder].sort((a, b) => {
+    const levelDiff = (levels.get(a) ?? 0) - (levels.get(b) ?? 0);
+    if (levelDiff !== 0) return levelDiff;
+    const durA = eventMap.get(a)?.duration ?? 0;
+    const durB = eventMap.get(b)?.duration ?? 0;
+    if (durA !== durB) return durB - durA;
+    const viableDiff = (viableRoomCount.get(a) ?? 0) - (viableRoomCount.get(b) ?? 0);
+    return viableDiff;
+  });
+
+  // Run all strategies and pick the one that schedules the most events
+  const strategies = [ordering1, ordering2, ordering3];
+  let bestResult: { assignments: Map<string, Assignment>; unscheduled: string[] } | null = null;
+
+  for (const ordering of strategies) {
+    const tls = makeTimelines();
+    const result = greedySchedule(ordering, eventMap, rooms, tls, startTime, endTime, gap);
+    if (!bestResult || result.assignments.size > bestResult.assignments.size) {
+      bestResult = result;
+    }
+    if (result.unscheduled.length === 0) break; // optimal
+  }
+
+  return {
+    assignments: Array.from(bestResult!.assignments.values()),
+    unscheduled: bestResult!.unscheduled,
+  };
+}
