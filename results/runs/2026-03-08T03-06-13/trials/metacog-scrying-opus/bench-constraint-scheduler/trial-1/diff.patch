\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    sorted.push(node);\n    for (const neighbor of adjList.get(node) ?? []) {\n      const newDeg = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  // If we haven't visited all nodes, there's a cycle\n  const allNodes = new Set(inDegree.keys());\n  if (sorted.length < allNodes.size) {\n    throw new Error('Cycle detected in prerequisite graph');\n  }\n\n  // Return only event IDs that are in our events list\n  const eventIds = new Set(events.map(e => e.id));\n  return sorted.filter(id => eventIds.has(id));\n}\n\ninterface RoomTimeline {\n  roomId: string;\n  capacity: number;\n  // Sorted list of [startTime, endTime] for events assigned to this room\n  slots: Array<{ start: number; end: number }>;\n}\n\nfunction findEarliestSlot(\n  timeline: RoomTimeline,\n  duration: number,\n  earliestStart: number,\n  windowEnd: number,\n  gap: number\n): number | null {\n  const endNeeded = earliestStart + duration;\n  if (endNeeded > windowEnd) return null;\n\n  if (timeline.slots.length === 0) {\n    return earliestStart;\n  }\n\n  // Try to find a slot that doesn't conflict with existing assignments\n  // Collect all possible start times to try\n  const candidates: number[] = [earliestStart];\n\n  // After each existing slot (with gap)\n  for (const slot of timeline.slots) {\n    candidates.push(slot.end + gap);\n  }\n\n  // Sort candidates\n  candidates.sort((a, b) => a - b);\n\n  for (const candidateStart of candidates) {\n    if (candidateStart < earliestStart) continue;\n    const candidateEnd = candidateStart + duration;\n    if (candidateEnd > windowEnd) continue;\n\n    // Check if this candidate conflicts with any existing slot\n    let conflicts = false;\n    for (const slot of timeline.slots) {\n      // Two intervals overlap if one starts before the other ends\n      // But we also need gap between them\n      const gapStart = slot.start - gap;\n      const gapEnd = slot.end + gap;\n      if (candidateStart < gapEnd && candidateEnd > gapStart) {\n        conflicts = true;\n        break;\n      }\n    }\n\n    if (!conflicts) {\n      return candidateStart;\n    }\n  }\n\n  return null;\n}\n\nfunction insertSlot(timeline: RoomTimeline, start: number, end: number): void {\n  timeline.slots.push({ start, end });\n  timeline.slots.sort((a, b) => a.start - b.start);\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // Detect cycles and get topological order\n  const topoOrder = detectCycleAndTopoSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // For each event, compute how constrained it is:\n  // - fewer viable rooms = more constrained\n  // - more prerequisites = more constrained\n  // - longer duration = more constrained\n  const viableRoomCount = new Map<string, number>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const count = rooms.filter(r => r.capacity >= attendees).length;\n    viableRoomCount.set(e.id, count);\n  }\n\n  // Build a priority-aware topological ordering\n  // We respect topological constraints but within the same \"level\",\n  // we prioritize more constrained events\n  const topoIndex = new Map<string, number>();\n  for (let i = 0; i < topoOrder.length; i++) {\n    topoIndex.set(topoOrder[i], i);\n  }\n\n  // Compute topological \"levels\" (longest path from a root)\n  const levels = new Map<string, number>();\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const ev = eventMap.get(id);\n    if (!ev || !ev.prerequisites || ev.prerequisites.length === 0) {\n      levels.set(id, 0);\n      return 0;\n    }\n    let maxPrereqLevel = 0;\n    for (const prereq of ev.prerequisites) {\n      if (eventMap.has(prereq)) {\n        maxPrereqLevel = Math.max(maxPrereqLevel, getLevel(prereq) + 1);\n      }\n    }\n    levels.set(id, maxPrereqLevel);\n    return maxPrereqLevel;\n  }\n  for (const e of events) {\n    getLevel(e.id);\n  }\n\n  // Sort: by level first (respects topo order), then by most constrained\n  const sortedEventIds = [...topoOrder].sort((a, b) => {\n    const levelDiff = (levels.get(a) ?? 0) - (levels.get(b) ?? 0);\n    if (levelDiff !== 0) return levelDiff;\n\n    // More constrained first (fewer viable rooms)\n    const viableDiff = (viableRoomCount.get(a) ?? 0) - (viableRoomCount.get(b) ?? 0);\n    if (viableDiff !== 0) return viableDiff;\n\n    // Longer duration first\n    const durA = eventMap.get(a)?.duration ?? 0;\n    const durB = eventMap.get(b)?.duration ?? 0;\n    return durB - durA;\n  });\n\n  // Try to schedule using backtracking with the sorted order\n  // For practical sizes, we use a greedy approach with smart ordering\n  // and then try to improve by attempting to schedule unscheduled events\n\n  const timelines = new Map<string, RoomTimeline>();\n  for (const room of rooms) {\n    timelines.set(room.id, {\n      roomId: room.id,\n      capacity: room.capacity,\n      slots: [],\n    });\n  }\n\n  const assignments = new Map<string, Assignment>();\n  const unscheduled: string[] = [];\n\n  // Greedy scheduling pass\n  for (const eventId of sortedEventIds) {\n    const event = eventMap.get(eventId)!;\n    const attendees = event.attendees ?? 1;\n\n    // Compute earliest start based on prerequisites\n    let earliestStart = startTime;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const prereqAssignment = assignments.get(prereqId);\n        if (prereqAssignment) {\n          earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n        } else if (eventMap.has(prereqId)) {\n          // Prerequisite exists but wasn't scheduled - this event can't be scheduled either\n          earliestStart = Infinity;\n          break;\n        }\n        // If prereq doesn't exist in events list, ignore it\n      }\n    }\n\n    if (earliestStart === Infinity || earliestStart + event.duration > endTime) {\n      unscheduled.push(eventId);\n      continue;\n    }\n\n    // Sort rooms: preferred room first, then by best capacity fit (smallest room that fits)\n    const viableRooms = rooms\n      .filter(r => r.capacity >= attendees)\n      .sort((a, b) => {\n        // Preferred room first\n        if (event.preferredRoom) {\n          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n        }\n        // Then smallest capacity that fits (best fit)\n        return a.capacity - b.capacity;\n      });\n\n    let placed = false;\n    for (const room of viableRooms) {\n      const timeline = timelines.get(room.id)!;\n      const slotStart = findEarliestSlot(timeline, event.duration, earliestStart, endTime, gap);\n      if (slotStart !== null) {\n        const assignment: Assignment = {\n          eventId: event.id,\n          roomId: room.id,\n          startTime: slotStart,\n          endTime: slotStart + event.duration,\n        };\n        assignments.set(event.id, assignment);\n        insertSlot(timeline, slotStart, slotStart + event.duration);\n        placed = true;\n        break;\n      }\n    }\n\n    if (!placed) {\n      unscheduled.push(eventId);\n    }\n  }\n\n  // If there are unscheduled events, try a second pass with different strategies\n  // Try scheduling unscheduled events by looking at all possible time slots more carefully\n  if (unscheduled.length > 0) {\n    const stillUnscheduled: string[] = [];\n    const retryEvents = [...unscheduled];\n    unscheduled.length = 0;\n\n    for (const eventId of retryEvents) {\n      const event = eventMap.get(eventId)!;\n      const attendees = event.attendees ?? 1;\n\n      let earliestStart = startTime;\n      let prereqFailed = false;\n      if (event.prerequisites) {\n        for (const prereqId of event.prerequisites) {\n          const prereqAssignment = assignments.get(prereqId);\n          if (prereqAssignment) {\n            earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n          } else if (eventMap.has(prereqId)) {\n            prereqFailed = true;\n            break;\n          }\n        }\n      }\n\n      if (prereqFailed || earliestStart + event.duration > endTime) {\n        stillUnscheduled.push(eventId);\n        continue;\n      }\n\n      const viableRooms = rooms\n        .filter(r => r.capacity >= attendees)\n        .sort((a, b) => {\n          if (event.preferredRoom) {\n            if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n            if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n          }\n          return a.capacity - b.capacity;\n        });\n\n      let placed = false;\n      for (const room of viableRooms) {\n        const timeline = timelines.get(room.id)!;\n        const slotStart = findEarliestSlot(timeline, event.duration, earliestStart, endTime, gap);\n        if (slotStart !== null) {\n          const assignment: Assignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + event.duration,\n          };\n          assignments.set(event.id, assignment);\n          insertSlot(timeline, slotStart, slotStart + event.duration);\n          placed = true;\n          break;\n        }\n      }\n\n      if (!placed) {\n        stillUnscheduled.push(eventId);\n      }\n    }\n\n    unscheduled.push(...stillUnscheduled);\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n","structuredPatch":[],"originalFile":null}}
