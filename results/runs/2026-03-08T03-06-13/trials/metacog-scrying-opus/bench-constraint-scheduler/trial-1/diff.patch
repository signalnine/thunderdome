=> r.capacity >= attendees).length;\n    viableRoomCount.set(e.id, count);\n  }\n\n  // Compute topological levels (longest path from a root)\n  const levels = new Map<string, number>();\n  function getLevel(id: string): number {\n    if (levels.has(id)) return levels.get(id)!;\n    const ev = eventMap.get(id);\n    if (!ev || !ev.prerequisites || ev.prerequisites.length === 0) {\n      levels.set(id, 0);\n      return 0;\n    }\n    let maxPrereqLevel = 0;\n    for (const prereq of ev.prerequisites) {\n      if (eventMap.has(prereq)) {\n        maxPrereqLevel = Math.max(maxPrereqLevel, getLevel(prereq) + 1);\n      }\n    }\n    levels.set(id, maxPrereqLevel);\n    return maxPrereqLevel;\n  }\n  for (const e of events) {\n    getLevel(e.id);\n  }\n\n  // Compute the length of the longest chain each event participates in\n  // (both as ancestor and descendant)\n  const chainDepth = new Map<string, number>();\n  const dependents = new Map<string, string[]>();\n  for (const e of events) {\n    if (!dependents.has(e.id)) dependents.set(e.id, []);\n    if (e.prerequisites) {\n      for (const prereq of e.prerequisites) {\n        if (eventMap.has(prereq)) {\n          if (!dependents.has(prereq)) dependents.set(prereq, []);\n          dependents.get(prereq)!.push(e.id);\n        }\n      }\n    }\n  }\n\n  function getMaxDepth(id: string, memo: Map<string, number>): number {\n    if (memo.has(id)) return memo.get(id)!;\n    const deps = dependents.get(id) ?? [];\n    let maxChild = 0;\n    for (const dep of deps) {\n      maxChild = Math.max(maxChild, 1 + getMaxDepth(dep, memo));\n    }\n    memo.set(id, maxChild);\n    return maxChild;\n  }\n  const depthMemo = new Map<string, number>();\n  for (const e of events) {\n    const depth = (levels.get(e.id) ?? 0) + getMaxDepth(e.id, depthMemo);\n    chainDepth.set(e.id, depth);\n  }\n\n  // Create base timelines\n  function makeTimelines(): Map<string, RoomTimeline> {\n    const tls = new Map<string, RoomTimeline>();\n    for (const room of rooms) {\n      tls.set(room.id, { roomId: room.id, capacity: room.capacity, slots: [] });\n    }\n    return tls;\n  }\n\n  // Strategy 1: most-constrained-first within topological levels\n  const ordering1 = [...topoOrder].sort((a, b) => {\n    const levelDiff = (levels.get(a) ?? 0) - (levels.get(b) ?? 0);\n    if (levelDiff !== 0) return levelDiff;\n    const viableDiff = (viableRoomCount.get(a) ?? 0) - (viableRoomCount.get(b) ?? 0);\n    if (viableDiff !== 0) return viableDiff;\n    const durA = eventMap.get(a)?.duration ?? 0;\n    const durB = eventMap.get(b)?.duration ?? 0;\n    return durB - durA;\n  });\n\n  // Strategy 2: longest chain first (prioritize events in long prerequisite chains)\n  const ordering2 = [...topoOrder].sort((a, b) => {\n    const levelDiff = (levels.get(a) ?? 0) - (levels.get(b) ?? 0);\n    if (levelDiff !== 0) return levelDiff;\n    const chainDiff = (chainDepth.get(b) ?? 0) - (chainDepth.get(a) ?? 0);\n    if (chainDiff !== 0) return chainDiff;\n    const viableDiff = (viableRoomCount.get(a) ?? 0) - (viableRoomCount.get(b) ?? 0);\n    if (viableDiff !== 0) return viableDiff;\n    return 0;\n  });\n\n  // Strategy 3: longest duration first within levels\n  const ordering3 = [...topoOrder].sort((a, b) => {\n    const levelDiff = (levels.get(a) ?? 0) - (levels.get(b) ?? 0);\n    if (levelDiff !== 0) return levelDiff;\n    const durA = eventMap.get(a)?.duration ?? 0;\n    const durB = eventMap.get(b)?.duration ?? 0;\n    if (durA !== durB) return durB - durA;\n    const viableDiff = (viableRoomCount.get(a) ?? 0) - (viableRoomCount.get(b) ?? 0);\n    return viableDiff;\n  });\n\n  // Run all strategies and pick the one that schedules the most events\n  const strategies = [ordering1, ordering2, ordering3];\n  let bestResult: { assignments: Map<string, Assignment>; unscheduled: string[] } | null = null;\n\n  for (const ordering of strategies) {\n    const tls = makeTimelines();\n    const result = greedySchedule(ordering, 