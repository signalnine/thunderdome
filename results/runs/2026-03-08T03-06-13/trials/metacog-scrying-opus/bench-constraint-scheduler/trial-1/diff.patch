djList.has(prereq)) adjList.set(prereq, []);\n        if (!inDegree.has(prereq)) inDegree.set(prereq, 0);\n        adjList.get(prereq)!.push(e.id);\n        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n      }\n    }\n  }\n\n  // Kahn's algorithm for topological sort + cycle detection\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    sorted.push(node);\n    for (const neighbor of adjList.get(node) ?? []) {\n      const newDeg = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  // If we haven't visited all nodes, there's a cycle\n  const allNodes = new Set(inDegree.keys());\n  if (sorted.length < allNodes.size) {\n    throw new Error('Cycle detected in prerequisite graph');\n  }\n\n  // Return only event IDs that are in our events list\n  const eventIds = new Set(events.map(e => e.id));\n  return sorted.filter(id => eventIds.has(id));\n}\n\ninterface RoomTimeline {\n  roomId: string;\n  capacity: number;\n  // Sorted list of [startTime, endTime] for events assigned to this room\n  slots: Array<{ start: number; end: number }>;\n}\n\nfunction findEarliestSlot(\n  timeline: RoomTimeline,\n  duration: number,\n  earliestStart: number,\n  windowEnd: number,\n  gap: number\n): number | null {\n  const endNeeded = earliestStart + duration;\n  if (endNeeded > windowEnd) return null;\n\n  if (timeline.slots.length === 0) {\n    return earliestStart;\n  }\n\n  // Try to find a slot that doesn't conflict with existing assignments\n  // Collect all possible start times to try\n  const candidates: number[] = [earliestStart];\n\n  // After each existing slot (with gap)\n  for (const slot of timeline.slots) {\n    candidates.push(slot.end + gap);\n  }\n\n  // Sort candidates\n  candidates.sort((a, b) => a - b);\n\n  for (const candid