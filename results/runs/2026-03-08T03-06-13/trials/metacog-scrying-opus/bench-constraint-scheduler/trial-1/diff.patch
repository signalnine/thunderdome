dTime: 1020 }\n  );\n  const a = result.assignments.find(x => x.eventId === 'a')!;\n  const b = result.assignments.find(x => x.eventId === 'b')!;\n  assert(b.startTime >= a.endTime + 15, 'b should start after a + gap');\n});\n\ntest('prerequisite gap applies', () => {\n  const result = schedule(\n    [\n      { id: 'a', name: 'A', duration: 30 },\n      { id: 'b', name: 'B', duration: 30, prerequisites: ['a'] },\n    ],\n    [{ id: 'r1', name: 'R1', capacity: 20 }, { id: 'r2', name: 'R2', capacity: 20 }],\n    { startTime: 540, endTime: 1020, gap: 10 }\n  );\n  const a = result.assignments.find(x => x.eventId === 'a')!;\n  const b = result.assignments.find(x => x.eventId === 'b')!;\n  assert(b.startTime >= a.endTime + 10, 'prereq gap should apply');\n});\n\ntest('self-reference cycle throws', () => {\n  let threw = false;\n  try {\n    schedule([{ id: 'a', name: 'A', duration: 60, prerequisites: ['a'] }], [{ id: 'r1', name: 'R1', capacity: 20 }], { startTime: 540, endTime: 1020 });\n  } catch {\n    threw = true;\n  }\n  assert(threw, 'should throw on self-reference');\n});\n\ntest('mutual cycle throws', () => {\n  let threw = false;\n  try {\n    schedule(\n      [\n        { id: 'a', name: 'A', duration: 60, prerequisites: ['b'] },\n        { id: 'b', name: 'B', duration: 60, prerequisites: ['a'] },\n      ],\n      [{ id: 'r1', name: 'R1', capacity: 20 }],\n      { startTime: 540, endTime: 1020 }\n    );\n  } catch {\n    threw = true;\n  }\n  assert(threw, 'should throw on mutual cycle');\n});\n\ntest('3-node cycle throws', () => {\n  let threw = false;\n  try {\n    schedule(\n      [\n        { id: 'a', name: 'A', duration: 60, prerequisites: ['c'] },\n        { id: 'b', name: 'B', duration: 60, prerequisites: ['a'] },\n        { id: 'c', name: 'C', duration: 60, prerequisites: ['b'] },\n      ],\n      [{ id: 'r1', name: 'R1', capacity: 20 }],\n      { startTime: 540, endTime: 1020 }\n    );\n  } catch {\n    threw = true;\n  }\n  assert(threw, 'should throw on 3-node cycle');\n});\n\ntest('unknown prereq is ignored', () => {\n  const result = schedule(\n    [{ id: 'b', name: 'B', duration: 60, prerequisites: ['nonexistent'] }],\n    [{ id: 'r1', name: 'R1', capacity: 20 }],\n    { startTime: 540, endTime: 1020 }\n  );\n  assert(result.assignments.length === 1);\n});\n\n// === Room Preference Tests ===\nconsole.log('\\nRoom Preference Tests:');\n\ntest('preferred room honored', () => {\n  const result = schedule(\n    [{ id: 'e1', name: 'E1', duration: 60, attendees: 5, preferredRoom: 'r2' }],\n    [{ id: 'r1', name: 'R1', capacity: 10 }, { id: 'r2', name: 'R2', capacity: 10 }],\n    { startTime: 540, endTime: 1020 }\n  );\n  assert(result.assignments[0].roomId === 'r2');\n});\n\ntest('preferred room with cross-preferences', () => {\n  const result = schedule(\n    [\n      { id: 'e1', name: 'E1', duration: 60, attendees: 5, preferredRoom: 'r2' },\n      { id: 'e2', name: 'E2', duration: 60, attendees: 5, preferredRoom: 'r1' },\n    ],\n    [{ id: 'r1', name: 'R1', capacity: 10 }, { id: 'r2', name: 'R2', capacity: 10 }],\n    { startTime: 540, endTime: 615, gap: 0 }\n  );\n  assert(result.assignments.find(a => a.eventId === 'e1')?.roomId === 'r2');\n  assert(result.assignments.find(a => a.eventId === 'e2')?.roomId === 'r1');\n});\n\n// === Optimization Tests ===\nconsole.log('\\nOptimization Tests:');\n\ntest('most constrained first', () => {\n  const result = schedule(\n    [\n      { id: 'y', name: 'Y', duration: 60, attendees: 15 },\n      { id: 'z', name: 'Z', duration: 60, attendees: 15 },\n      { id: 'x', name: 'X', duration: 60, attendees: 25 },\n    ],\n    [{ id: 'a', name: 'A', capacity: 30 }, { id: 'b', name: 'B', capacity: 20 }],\n    { startTime: 540, endTime: 615, gap: 0 }\n  );\n  assert(result.assignments.length === 2);\n  assert(result.assignments.some(a => a.eventId === 'x'));\n});\n\ntest('best fit room assignment', () => {\n  const result = schedule(\n    [\n      { id: 'a', name: 'A', duration: 60,