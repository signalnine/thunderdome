  [{ id: 'e1', name: 'E1', duration: 60 }],\n    [{ id: 'r1', name: 'R1', capacity: 1 }],\n    { startTime: 540, endTime: 1020 }\n  );\n  assert(result.assignments.length === 1);\n});\n\n// === Gap Tests ===\nconsole.log('\\\\nGap Tests:');\n\ntest('default gap is 15', () => {\n  const result = schedule(\n    [{ id: 'a', name: 'A', duration: 30 }, { id: 'b', name: 'B', duration: 30 }],\n    [{ id: 'r1', name: 'R1', capacity: 20 }],\n    { startTime: 540, endTime: 1020 }\n  );\n  const a = result.assignments.find(x => x.eventId === 'a');\n  const b = result.assignments.find(x => x.eventId === 'b');\n  assert(b.startTime - a.endTime >= 15, 'gap should be >= 15');\n});\n\ntest('custom gap', () => {\n  const result = schedule(\n    [{ id: 'a', name: 'A', duration: 30 }, { id: 'b', name: 'B', duration: 30 }],\n    [{ id: 'r1', name: 'R1', capacity: 20 }],\n    { startTime: 540, endTime: 1020, gap: 30 }\n  );\n  const a = result.assignments.find(x => x.eventId === 'a');\n  const b = result.assignments.find(x => x.eventId === 'b');\n  assert(b.startTime - a.endTime >= 30, 'gap should be >= 30');\n});\n\ntest('gap = 0', () => {\n  const result = schedule(\n    [{ id: 'a', name: 'A', duration: 30 }, { id: 'b', name: 'B', duration: 30 }],\n    [{ id: 'r1', name: 'R1', capacity: 20 }],\n    { startTime: 540, endTime: 1020, gap: 0 }\n  );\n  const a = result.assignments.find(x => x.eventId === 'a');\n  const b = result.assignments.find(x => x.eventId === 'b');\n  assert(b.startTime === a.endTime, 'events should be back to back');\n});\n\n// === Prerequisite Tests ===\nconsole.log('\\\\nPrerequisite Tests:');\n\ntest('prerequisite ordering', () => {\n  const result = schedule(\n    [\n      { id: 'a', name: 'A', duration: 60 },\n      { id: 'b', name: 'B', duration: 60, prerequisites: ['a'] },\n    ],\n    [{ id: 'r1', name: 'R1', capacity: 20 }],\n    { startTime: 540, endTime: 1020 }\n  );\n  const a = result.assignments.find(x => x.eventId === 'a');\n  const b = result.assign