+    // Comparison operators
+    if (formula[i] === '<') {
+      if (formula[i + 1] === '=') {
+        tokens.push({ type: 'COMP', value: '<=' });
+        i += 2;
+      } else if (formula[i + 1] === '>') {
+        tokens.push({ type: 'COMP', value: '<>' });
+        i += 2;
+      } else {
+        tokens.push({ type: 'COMP', value: '<' });
+        i++;
+      }
+      continue;
+    }
+
+    if (formula[i] === '>') {
+      if (formula[i + 1] === '=') {
+        tokens.push({ type: 'COMP', value: '>=' });
+        i += 2;
+      } else {
+        tokens.push({ type: 'COMP', value: '>' });
+        i++;
+      }
+      continue;
+    }
+
+    // Arithmetic operators and equals (comparison)
+    if ('+-*/'.includes(formula[i])) {
+      tokens.push({ type: 'OP', value: formula[i] });
+      i++;
+      continue;
+    }
+
+    if (formula[i] === '=') {
+      tokens.push({ type: 'COMP', value: '=' });
+      i++;
+      continue;
+    }
+
+    if (formula[i] === '(') {
+      tokens.push({ type: 'LPAREN', value: '(' });
+      i++;
+      continue;
+    }
+
+    if (formula[i] === ')') {
+      tokens.push({ type: 'RPAREN', value: ')' });
+      i++;
+      continue;
+    }
+
+    if (formula[i] === ',') {
+      tokens.push({ type: 'COMMA', value: ',' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${formula[i]}`);
+  }
+
+  tokens.push({ type: 'EOF', value: '' });
+  return tokens;
+}
+
+// ─── AST Nodes ──────────────────────────────────────────────────────────────
+
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell_ref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binary_op'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'unary_neg'; operand: ASTNode }
+  | { type: 'func_call'; name: string; args: ASTNode[] };
+
+// ─── Parser (Recursive Descent) ─────────────────────────────────────────────
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private consume(expectedType?: TokenType): Token {
+    const token = this.tokens[this.pos];
+    if (expectedType && token.type !== expectedType) {
+      throw new Error(`Expected ${expectedType} but got ${token.type} (${token.value})`);
+    }
+    this.pos++;
+    return token;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    return node;
+  }
+
+  // comparison: addition (('>' | '<' | '>=' | '<=' | '=' | '<>') addition)?
+  private parseComparison(): ASTNode {
+    let left = this.parseAddition();
+
+    while (this.peek().type === 'COMP') {
+      const op = this.consume().value;
+      const right = this.parseAddition();
+      left = { type: 'binary_op', op, left, right };
+    }
+
+    return left;
+  }
+
+  // addition: multiplication (('+' | '-') multiplication)*
+  private parseAddition(): ASTNode {
+    let left = this.parseMultiplication();
+
+    while (this.peek().type === 'OP' && (this.peek().value === '+' || this.peek().value === '-')) {
+      const op = this.consume().value;
+      const right = this.parseMultiplication();
+      left = { type: 'binary_op', op, left, right };
+    }
+
+    return left;
+  }
+
+  // multiplication: unary (('*' | '/') unary)*
+  private parseMultiplication(): ASTNode {
+    let left = this.parseUnary();
+
+    while (this.peek().type === 'OP' && (this.peek().value === '*' || this.peek().value === '/')) {
+      const op = this.consume().value;
+      const right = this.parseUnary();
+      left = { type: 'binary_op', op, left, right };
+    }
+
+    return left;
+  }
+
+  // unary: '-' unary | primary
+  private parseUnary(): ASTNode {
+    if (this.peek().type === 'OP' && this.peek().value === '-') {
+      this.consume();
+      const operand = this.parseUnary();
+      return { type: 'unary_neg', operand };
+    }
+    return this.parsePrimary();
+  }
+
+  // primary: NUMBER | STRING | BOOLEAN | CELL_REF | RANGE | FUNC '(' args ')' | '(' expr ')'
+  private parsePrimary(): ASTNode {
+    const token = this.peek();
+
+    if (token.type === 'NUMBER') {
+      this.consume();
+      return { type: 'number', value: parseFloat(token.value) };
+    }
+
+    if (token.type === 'STRING') {
+      this.consume();
+      return { type: 'string', value: token.value };
+    }
+
+    if (token.type === 'BOOLEAN') {
+      this.consume();
+      return { type: 'boolean', value: token.value === 'TRUE' };
+    }
+
+    if (token.type === 'RANGE') {
+      this.consume();
+      const [start, end] = token.value.split(':');
+      return { type: 'range', start, end };
+    }
+
+    if (token.type === 'CELL_REF') {
+      this.consume();
+      return { type: 'cell_ref', ref: token.value };
+    }
+
+    if (token.type === 'FUNC') {
+      const name = this.consume().value;
+      this.consume('LPAREN');
+      const args: ASTNode[] = [];
+      if (this.peek().type !== 'RPAREN') {
+        args.push(this.parse());
+        while (this.peek().type === 'COMMA') {
+          this.consume('COMMA');
+          args.push(this.parse());
+        }
+      }
+      this.consume('RPAREN');
+      return { type: 'func_call', name, args };
+    }
+
+    if (token.type === 'LPAREN') {
+      this.consume();
+      const expr = this.parse();
+      this.consume('RPAREN');
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${token.type} (${token.value})`);
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// ─── Dependency Extraction ──────────────────────────────────────────────────
+
+function extractDependencies(ast: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(node: ASTNode): void {
+    switch (node.type) {
+      case 'cell_ref':
+        deps.add(node.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(node.start, node.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binary_op':
+        walk(node.left);
+        walk(node.right);
+        break;
+      case 'unary_neg':
+        walk(node.operand);
+        break;
+      case 'func_call':
+        for (const arg of node.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean: no deps
+    }
+  }
+
+  walk(ast);
+  return deps;
+}
+
+// ─── Cell Data ──────────────────────────────────────────────────────────────
+
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  computed: CellValue;
+  dependencies: Set<string>;
+}
+
+// ─── Spreadsheet ────────────────────────────────────────────────────────────
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // dependents: cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+
+    let formula: ASTNode | null = null;
+    let dependencies = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.substring(1);
+      formula = parseFormula(formulaStr);
+      dependencies = extractDependencies(formula);
+    }
+
+    // Remove old dependencies
+    const oldCell = this.cells.get(ref);
+    if (oldCell) {
+      for (const dep of oldCell.dependencies) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    // Add new dependencies
+    for (const dep of dependencies) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Check for circular references before committing
+    if (dependencies.size > 0) {
+      this.checkCircular(ref, dependencies);
+    }
+
+    // Compute value
+    const computed = formula ? this.evaluate(formula) : (typeof value === 'string' && !value.startsWith('=') ? value : value);
+
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      computed,
+      dependencies,
+    };
+
+    this.cells.set(ref, cellData);
+
+    // Propagate changes to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = normalizeRef(cell);
+    const cellData = this.cells.get(ref);
+    if (!cellData) return null;
+    return cellData.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, cellData] of this.cells) {
+      result.set(ref, cellData.computed);
+    }
+    return result;
+  }
+
+  // ─── Circular Reference Detection ──────────────────────────────────────
+
+  private checkCircular(startRef: string, dependencies: Set<string>): void {
+    // DFS from each dependency to see if we can reach startRef
+    const visited = new Set<string>();
+
+    const dfs = (current: string): boolean => {
+      if (current === startRef) return true;
+      if (visited.has(current)) return false;
+      visited.add(current);
+
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.dependencies) {
+          if (dfs(dep)) return true;
+        }
+      }
+      return false;
+    };
+
+    for (const dep of dependencies) {
+      visited.clear();
+      if (dfs(dep)) {
+        // Rollback: remove the newly added dependent links
+        for (const d of dependencies) {
+          this.dependents.get(d)?.delete(startRef);
+        }
+        // Restore old dependencies if there was an old cell
+        const oldCell = this.cells.get(startRef);
+        if (oldCell) {
+          for (const d of oldCell.dependencies) {
+            if (!this.dependents.has(d)) {
+              this.dependents.set(d, new Set());
+            }
+            this.dependents.get(d)!.add(startRef);
+          }
+        }
+        throw new Error(`Circular reference detected involving ${startRef}`);
+      }
+    }
+  }
+
+  // ─── Propagation ───────────────────────────────────────────────────────
+
+  private propagate(changedRef: string): void {
+    // Get all cells that need recomputation in topological order
+    const order = this.topologicalSort(changedRef);
+
+    for (const ref of order) {
+      const cellData = this.cells.get(ref);
+      if (cellData && cellData.formula) {
+        cellData.computed = this.evaluate(cellData.formula);
+      }
+    }
+  }
+
+  private topologicalSort(startRef: string): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const dfs = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          dfs(dep);
+        }
+      }
+
+      result.push(ref);
+    };
+
+    dfs(startRef);
+
+    // Reverse to get topological order (dependencies first)
+    // But remove the startRef itself since it's already computed
+    result.reverse();
+    return result.filter(r => r !== startRef);
+  }
+
+  // ─── Evaluation ────────────────────────────────────────────────────────
+
+  private evaluate(node: ASTNode): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cell_ref': {
+        const cellData = this.cells.get(node.ref);
+        if (!cellData) return 0;
+        return cellData.computed ?? 0;
+      }
+      case 'range':
+        // Ranges shouldn't be evaluated directly, only in function context
+        throw new Error('Range cannot be evaluated outside a function');
+      case 'unary_neg': {
+        const operand = this.evaluate(node.operand);
+        if (typeof operand === 'number') return -operand;
+        return 0;
+      }
+      case 'binary_op':
+        return this.evaluateBinaryOp(node.op, node.left, node.right);
+      case 'func_call':
+        return this.evaluateFunction(node.name, node.args);
+    }
+  }
+
+  private evaluateBinaryOp(op: string, left: ASTNode, right: ASTNode): CellValue {
+    const l = this.evaluate(left);
+    const r = this.evaluate(right);
+
+    if (op === '+' || op === '-' || op === '*' || op === '/') {
+      const lNum = typeof l === 'number' ? l : 0;
+      const rNum = typeof r === 'number' ? r : 0;
+
+      switch (op) {
+        case '+': return lNum + rNum;
+        case '-': return lNum - rNum;
+        case '*': return lNum * rNum;
+        case '/': return rNum !== 0 ? lNum / rNum : 0;
+      }
+    }
+
+    // Comparison operators
+    switch (op) {
+      case '>':  return (l as number) > (r as number);
+      case '<':  return (l as number) < (r as number);
+      case '>=': return (l as number) >= (r as number);
+      case '<=': return (l as number) <= (r as number);
+      case '=':  return l === r;
+      case '<>': return l !== r;
+    }
+
+    return 0;
+  }
+
+  private resolveRangeValues(node: ASTNode): CellValue[] {
+    if (node.type === 'range') {
+      const cells = expandRange(node.start, node.end);
+      return cells.map(ref => {
+        const cellData = this.cells.get(ref);
+        return cellData ? cellData.computed : null;
+      });
+    }
+    // Single value
+    return [this.evaluate(node)];
+  }
+
+  private evaluateFunction(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        let sum = 0;
+        for (const arg of args) {
+          const values = this.resolveRangeValues(arg);
+          for (const v of values) {
+            if (typeof v === 'number') sum += v;
+          }
+        }
+        return sum;
+      }
+      case 'AVERAGE': {
+        let sum = 0;
+        let count = 0;
+        for (const arg of args) {
+          const values = this.resolveRangeValues(arg);
+          for (const v of values) {
+            if (typeof v === 'number') {
+              sum += v;
+              count++;
+            }
+          }
+        }
+        return count > 0 ? sum / count : 0;
+      }
+      case 'MIN': {
+        let min = Infinity;
+        for (const arg of args) {
+          const values = this.resolveRangeValues(arg);
+          for (const v of values) {
+            if (typeof v === 'number' && v < min) min = v;
+          }
+        }
+        return min === Infinity ? 0 : min;
+      }
+      case 'MAX': {
+        let max = -Infinity;
+        for (const arg of args) {
+          const values = this.resolveRangeValues(arg);
+          for (const v of values) {
+            if (typeof v === 'number' && v > max) max = v;
+          }
+        }
+        return max === -Infinity ? 0 : max;
+      }
+      case 'COUNT': {
+        let count = 0;
+        for (const arg of args) {
+          const values = this.resolveRangeValues(arg);
+          for (const v of values) {
+            if (typeof v === 'number') count++;
+          }
+        }
+        return count;
+      }
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evaluate(args[0]);
+        const isTruthy = condition === true || (typeof condition === 'number' && condition !== 0);
+        return isTruthy ? this.evaluate(args[1]) : this.evaluate(args[2]);
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
