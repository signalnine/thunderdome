+import { describe, it, expect, beforeEach } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  let sheet: Spreadsheet;
+
+  beforeEach(() => {
+    sheet = new Spreadsheet();
+  });
+
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve floating point numbers', () => {
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+
+    it('should store and retrieve strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should handle case-insensitive cell references', () => {
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('a1')).toBe(10);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers as strings', () => {
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display computed formula results', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate addition', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(20);
+    });
+
+    it('should evaluate multiplication', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      sheet.set('A1', 20);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(5);
+    });
+
+    it('should handle operator precedence', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=A1+A2*A3');
+      expect(sheet.get('A4')).toBe(14); // 2 + (3*4) = 14
+    });
+
+    it('should handle parentheses', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=(A1+A2)*A3');
+      expect(sheet.get('A4')).toBe(20); // (2+3)*4 = 20
+    });
+
+    it('should handle numeric literals in formulas', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+    });
+
+    it('should handle unary negation', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-10);
+    });
+  });
+
+  describe('reactive updates', () => {
+    it('should update direct dependents', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+    });
+
+    it('should update transitive dependents', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+1');
+      sheet.set('A3', '=A2+1');
+      sheet.set('A4', '=A3+1');
+      expect(sheet.get('A4')).toBe(13);
+
+      sheet.set('A1', 100);
+      expect(sheet.get('A2')).toBe(101);
+      expect(sheet.get('A3')).toBe(102);
+      expect(sheet.get('A4')).toBe(103);
+    });
+
+    it('should update multiple dependents', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1*2');
+      sheet.set('C1', '=A1*3');
+      sheet.set('D1', '=B1+C1');
+
+      sheet.set('A1', 5);
+      expect(sheet.get('B1')).toBe(10);
+      expect(sheet.get('C1')).toBe(15);
+      expect(sheet.get('D1')).toBe(25);
+    });
+
+    it('should handle overwriting a formula cell with a value', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+1');
+      expect(sheet.get('A2')).toBe(11);
+
+      sheet.set('A2', 99);
+      expect(sheet.get('A2')).toBe(99);
+
+      // Changing A1 should no longer affect A2
+      sheet.set('A1', 999);
+      expect(sheet.get('A2')).toBe(99);
+    });
+  });
+
+  describe('SUM function', () => {
+    it('should sum a column range', () => {
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('A3', 3);
+      sheet.set('A4', 4);
+      sheet.set('A5', 5);
+      sheet.set('B1', '=SUM(A1:A5)');
+      expect(sheet.get('B1')).toBe(15);
+    });
+
+    it('should sum a row range', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', 30);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(60);
+    });
+
+    it('should sum a block range', () => {
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('B1', 3);
+      sheet.set('B2', 4);
+      sheet.set('C1', '=SUM(A1:B2)');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should ignore non-numeric values in SUM', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 20);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+
+    it('should reactively update SUM', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('B1')).toBe(70);
+    });
+  });
+
+  describe('AVERAGE function', () => {
+    it('should compute average of a range', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+
+    it('should ignore non-numeric values', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'text');
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20); // (10+30)/2
+    });
+  });
+
+  describe('MIN function', () => {
+    it('should find minimum value', () => {
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MIN(A1:A3)');
+      expect(sheet.get('B1')).toBe(10);
+    });
+  });
+
+  describe('MAX function', () => {
+    it('should find maximum value', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 30);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MAX(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+  });
+
+  describe('COUNT function', () => {
+    it('should count numeric values', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 'text');
+      sheet.set('A3', 20);
+      sheet.set('A4', true);
+      sheet.set('B1', '=COUNT(A1:A4)');
+      expect(sheet.get('B1')).toBe(2);
+    });
+  });
+
+  describe('IF function', () => {
+    it('should return trueValue when condition is true', () => {
+      sheet.set('A1', 50);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('big');
+    });
