+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019GcoR7TS3xR6ZsEtGiV9Xk","type":"tool_result","content":"     1â†’import { Template } from './types.js';\n     2â†’\n     3â†’export function createDefaultTemplate(): Template {\n     4â†’  return {\n     5â†’    name: 'default',\n     6â†’    render: (content: string, data: Record<string, unknown>) => {\n     7â†’      return `<!DOCTYPE html>\n     8â†’<html>\n     9â†’<head>\n    10â†’  <meta charset=\"utf-8\">\n    11â†’  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n    12â†’</head>\n    13â†’<body>\n    14â†’  <article>\n    15â†’    <h1>${data.title || ''}</h1>\n    16â†’    ${data.date ? `<time>${data.date}</time>` : ''}\n    17â†’    <div class=\"content\">${content}</div>\n    18â†’  </article>\n    19â†’</body>\n    20â†’</html>`;\n    21â†’    }\n    22â†’  };\n    23â†’}\n    24â†’\n    25â†’export function createListTemplate(): Template {\n    26â†’  return {\n    27â†’    name: 'list',\n    28â†’    render: (content: string, data: Record<string, unknown>) => {\n    29â†’      return `<!DOCTYPE html>\n    30â†’<html>\n    31â†’<head>\n    32â†’  <meta charset=\"utf-8\">\n    33â†’  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n    34â†’</head>\n    35â†’<body>\n    36â†’  <h1>${data.title || ''}</h1>\n    37â†’  <div class=\"list\">${content}</div>\n    38â†’</body>\n    39â†’</html>`;\n    40â†’    }\n    41â†’  };\n    42â†’}\n    43â†’"}]},"parent_tool_use_id":"toolu_018Hc4Y1Kgka332QBPt6Hy6j","session_id":"f8feecf4-a0c5-4c57-9f40-722e41d8ebb2","uuid":"ce9f8889-791f-4f44-bd3c-7ab9ff627628"}
