not raw markdown', async () => {\n    49â†’    const files = [\n    50â†’      makeFile({\n    51â†’        slug: 'post-1',\n    52â†’        title: 'Post 1',\n    53â†’        content: '<p>This is <strong>HTML</strong> content</p>',\n    54â†’        date: '2024-01-01',\n    55â†’      }),\n    56â†’    ];\n    57â†’    const ctx = makeCtx(files);\n    58â†’    await plugin.hooks.afterBuild!(ctx);\n    59â†’    const feed = ctx.output.get('feed.xml')!;\n    60â†’    expect(feed).toContain('<![CDATA[<p>This is <strong>HTML</strong> content</p>]]>');\n    61â†’  });\n    62â†’\n    63â†’  it('feed items include category tags from taxonomy', async () => {\n    64â†’    const files = [\n    65â†’      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'], date: '2024-01-01' }),\n    66â†’    ];\n    67â†’    const tagMap = new Map<string, ContentFile[]>();\n    68â†’    tagMap.set('javascript', [files[0]]);\n    69â†’    const data = new Map<string, unknown>();\n    70â†’    data.set('taxonomy-tags', tagMap);\n    71â†’    const ctx = makeCtx(files, data);\n    72â†’    await plugin.hooks.afterBuild!(ctx);\n    73â†’    const feed = ctx.output.get('feed.xml')!;\n    74â†’    expect(feed).toContain('<category>javascript</category>');\n    75â†’  });\n    76â†’\n    77â†’  it('feed includes channel title from config', async () => {\n    78â†’    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    79â†’    const ctx = makeCtx(files);\n    80â†’    await plugin.hooks.afterBuild!(ctx);\n    81â†’    const feed = ctx.output.get('feed.xml')!;\n    82â†’    expect(feed).toContain('<title>Test Site</title>');\n    83â†’  });\n    84â†’\n    85â†’  it('feed items sorted by date newest first', async () => {\n    86â†’    const files = [\n    87â†’      makeFile({ slug: 'old', title: 'Old Post', date: '2023-01-01' }),\n    88â†’      makeFile({ slug: 'new', title: 'New Post', date: '2024-06-15' }),\n    89â†’      makeFile({ slug: 'mid', title: 'Mid Post