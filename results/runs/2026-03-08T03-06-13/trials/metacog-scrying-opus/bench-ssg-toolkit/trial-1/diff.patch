+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NDShem3kHLgHrNYbofMuFa","type":"tool_result","content":"     1â†’export interface SiteConfig {\n     2â†’  title: string;\n     3â†’  baseUrl: string;\n     4â†’  outputDir: string;\n     5â†’  contentDir: string;\n     6â†’  templateDir: string;\n     7â†’}\n     8â†’\n     9â†’export interface ContentFile {\n    10â†’  slug: string;\n    11â†’  title: string;\n    12â†’  content: string;        // raw content (markdown or html)\n    13â†’  metadata: Record<string, unknown>;\n    14â†’  date?: string;\n    15â†’  tags?: string[];\n    16â†’  template?: string;\n    17â†’}\n    18â†’\n    19â†’export interface BuildContext {\n    20â†’  config: SiteConfig;\n    21â†’  files: ContentFile[];\n    22â†’  output: Map<string, string>;  // output path -> rendered content\n    23â†’  assets: Map<string, Buffer>;  // output path -> binary data\n    24â†’  data: Map<string, unknown>;   // shared plugin data store\n    25â†’}\n    26â†’\n    27â†’export interface PluginHooks {\n    28â†’  beforeBuild?: (ctx: BuildContext) => Promise<void> | void;\n    29â†’  transformContent?: (file: ContentFile, ctx: BuildContext) => Promise<ContentFile> | ContentFile;\n    30â†’  afterBuild?: (ctx: BuildContext) => Promise<void> | void;\n    31â†’}\n    32â†’\n    33â†’export interface Plugin {\n    34â†’  name: string;\n    35â†’  version: string;\n    36â†’  dependencies: string[];  // names of plugins this depends on\n    37â†’  hooks: PluginHooks;\n    38â†’}\n    39â†’\n    40â†’export interface Template {\n    41â†’  name: string;\n    42â†’  render: (content: string, data: Record<string, unknown>) => string;\n    43â†’}\n    44â†’"}]},"parent_tool_use_id":"toolu_018Hc4Y1Kgka332QBPt6Hy6j","session_id":"f8feecf4-a0c5-4c57-9f40-722e41d8ebb2","uuid":"1f0259a0-2e1c-4db2-9346-ef844721bd4c"}
