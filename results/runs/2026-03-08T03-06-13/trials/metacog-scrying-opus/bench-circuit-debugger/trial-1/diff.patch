+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  while (remaining.length > 0) {
+    let progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 !== undefined && v2 !== undefined) {
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = v1 & v2;
+            break;
+          case 'OR':
+            result = v1 | v2;
+            break;
+          case 'XOR':
+            result = v1 ^ v2;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+    if (!progress) {
+      break;
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const workGates: Gate[] = gates.map((g) => ({ ...g }));
+  const swapped = new Set<string>();
+
+  // Find number of input bits
+  let numBits = 0;
+  for (const g of workGates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) numBits = Math.max(numBits, parseInt(m[1], 10) + 1);
+    }
+  }
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  function findGateByOp(op: string, in1: string, in2: string): Gate | undefined {
+    return workGates.find(
+      (g) =>
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))
+    );
+  }
+
+  function doSwap(a: string, b: string): void {
+    if (a === b) return;
+    swapped.add(a);
+    swapped.add(b);
+    const gateA = workGates.find((g) => g.out === a);
+    const gateB = workGates.find((g) => g.out === b);
+    if (gateA) gateA.out = b;
+    if (gateB) gateB.out = a;
+  }
+
+  // Trace the adder structure sequentially, fixing swaps as we find them
+  let carry = '';
+
+  for (let i = 0; i < numBits; i++) {
+    if (swapped.size >= 8) break;
+
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+
+    if (i === 0) {
+      // Half adder: z00 = XOR(x00, y00), carry = AND(x00, y00)
+      const xorGate = findGateByOp('XOR', xi, yi);
+      if (xorGate) {
+        if (xorGate.out !== zi) {
+          doSwap(xorGate.out, zi);
+        }
+      }
+      const andGate = findGateByOp('AND', xi, yi);
+      if (andGate) {
+        carry = andGate.out;
+      }
+    } else {
+      // Full adder for bit i
+      // Expected structure:
+      //   ti = XOR(xi, yi)
+      //   zi = XOR(ti, carry_in)
+      //   ai = AND(xi, yi)
+      //   bi = AND(ti, carry_in)
+      //   carry_out = OR(ai, bi)
+
+      // Step 1: Find partial sum gate: XOR(xi, yi)
+      const partialGate = findGateByOp('XOR', xi, yi);
+      if (!partialGate) continue;
+      let ti = partialGate.out;
+
+      // Step 2: Find sum gate: XOR(ti, carry)
+      let sumGate = findGateByOp('XOR', ti, carry);
+
+      if (!sumGate) {
+        // Either ti or carry is swapped
+        // Strategy A: find XOR gate that uses carry (non-x/y XOR)
+        const xorWithCarry = workGates.find(
+          (g) =>
+            g.op === 'XOR' &&
+            g !== partialGate &&
+            (g.in1 === carry || g.in2 === carry)
+        );
+        if (xorWithCarry) {
+          const otherIn =
+            xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;
+          if (otherIn !== ti) {
+            doSwap(ti, otherIn);
+            ti = partialGate.out;
+          }
+          sumGate = xorWithCarry;
+        } else {
+          // Strategy B: find XOR gate that uses ti (non-x/y XOR)
+          const xorWithTi = workGates.find(
+            (g) =>
+              g.op === 'XOR' &&
+              g !== partialGate &&
+              (g.in1 === ti || g.in2 === ti)
+          );
+          if (xorWithTi) {
+            const otherIn =
+              xorWithTi.in1 === ti ? xorWithTi.in2 : xorWithTi.in1;
+            if (otherIn !== carry) {
+              doSwap(carry, otherIn);
+              carry = otherIn;
+            }
+            sumGate = xorWithTi;
+          }
+        }
+      }
+
+      if (sumGate && sumGate.out !== zi) {
+        doSwap(sumGate.out, zi);
+      }
+
+      // Re-read ti after potential swap
+      ti = partialGate.out;
+
+      // Step 3: Find generate gate: AND(xi, yi)
+      const genGate = findGateByOp('AND', xi, yi);
+      const ai = genGate ? genGate.out : '';
+
+      // Step 4: Find propagate gate: AND(ti, carry)
+      const propGate = findGateByOp('AND', ti, carry);
+      const bi = propGate ? propGate.out : '';
+
+      // Step 5: Find carry-out gate: OR(ai, bi)
+      if (ai && bi) {
+        let orGate = findGateByOp('OR', ai, bi);
+        if (!orGate) {
+          // One of ai or bi is swapped
+          const orWithAi = workGates.find(
+            (g) => g.op === 'OR' && (g.in1 === ai || g.in2 === ai)
+          );
+          const orWithBi = workGates.find(
+            (g) => g.op === 'OR' && (g.in1 === bi || g.in2 === bi)
+          );
+          if (orWithAi) {
+            const otherIn =
+              orWithAi.in1 === ai ? orWithAi.in2 : orWithAi.in1;
+            if (otherIn !== bi) {
+              doSwap(bi, otherIn);
+            }
+            orGate = orWithAi;
+          } else if (orWithBi) {
+            const otherIn =
+              orWithBi.in1 === bi ? orWithBi.in2 : orWithBi.in1;
+            if (otherIn !== ai) {
+              doSwap(ai, otherIn);
+            }
+            orGate = orWithBi;
+          }
+        }
+        if (orGate) {
+          carry = orGate.out;
+        }
+      } else if (ai) {
+        // No propagate gate found; try to find carry via OR gate using ai
+        const orWithAi = workGates.find(
+          (g) => g.op === 'OR' && (g.in1 === ai || g.in2 === ai)
+        );
+        if (orWithAi) {
+          carry = orWithAi.out;
+        }
+      } else if (bi) {
+        const orWithBi = workGates.find(
+          (g) => g.op === 'OR' && (g.in1 === bi || g.in2 === bi)
+        );
+        if (orWithBi) {
+          carry = orWithBi.out;
+        }
+      }
+    }
+  }
+
+  // Check: the final carry should be the lastZ output
+  if (carry && carry !== lastZ && swapped.size < 8) {
+    doSwap(carry, lastZ);
+  }
+
+  // Phase 2: Simulation-based verification and remaining swap detection
+  if (swapped.size < 8) {
+    const brokenBits = findBrokenBits(workGates, numBits);
+
+    if (brokenBits.length > 0) {
+      // For each broken bit, find the swap
+      for (const bit of brokenBits) {
+        if (swapped.size >= 8) break;
+
+        // Get wires in the dependency cone of the broken bit and its neighbors
+        const candidateWires = getDependencyCone(workGates, bit, numBits);
+
+        let found = false;
+        for (let i = 0; i < candidateWires.length && !found; i++) {
+          for (let j = i + 1; j < candidateWires.length && !found; j++) {
+            const w1 = candidateWires[i];
+            const w2 = candidateWires[j];
+
+            // Try this swap
+            const testGates = workGates.map((g) => ({ ...g }));
+            const g1 = testGates.find((g) => g.out === w1);
+            const g2 = testGates.find((g) => g.out === w2);
+            if (g1) g1.out = w2;
+            if (g2) g2.out = w1;
+
+            const newBrokenBits = findBrokenBits(testGates, numBits);
+            // The swap should fix this broken bit and not introduce new ones
+            if (
+              newBrokenBits.length < brokenBits.length &&
+              !newBrokenBits.includes(bit)
+            ) {
+              doSwap(w1, w2);
+              found = true;
+            }
+          }
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
+
+function findBrokenBits(gates: Gate[], numBits: number): number[] {
+  const brokenSet = new Set<number>();
+
+  // Test patterns that exercise each bit
+  for (let b = 0; b < numBits; b++) {
+    const patterns: [bigint, bigint][] = [
+      [1n << BigInt(b), 0n],
+      [0n, 1n << BigInt(b)],
+      [1n << BigInt(b), 1n << BigInt(b)],
+    ];
+
+    // Also test carry propagation from bit b-1
+    if (b > 0) {
+      patterns.push([1n << BigInt(b - 1), 1n << BigInt(b - 1)]);
+      // Full carry chain test
+      const mask = (1n << BigInt(b)) - 1n;
+      patterns.push([mask, 1n]);
+    }
+
+    for (const [x, y] of patterns) {
+      const inputs: Record<string, number> = {};
+      for (let i = 0; i < numBits; i++) {
+        inputs[`x${String(i).padStart(2, '0')}`] = Number(
+          (x >> BigInt(i)) & 1n
+        );
+        inputs[`y${String(i).padStart(2, '0')}`] = Number(
+          (y >> BigInt(i)) & 1n
+        );
+      }
+
+      const result = simulate(gates, inputs);
+      const expected = x + y;
+
+      for (let zb = 0; zb <= numBits; zb++) {
+        const zWire = `z${String(zb).padStart(2, '0')}`;
+        const expectedBit = Number((expected >> BigInt(zb)) & 1n);
+        if (result[zWire] !== expectedBit) {
+          brokenSet.add(zb);
+        }
+      }
+    }
+  }
+
+  return [...brokenSet].sort((a, b) => a - b);
+}
+
+function getDependencyCone(
+  gates: Gate[],
+  bit: number,
+  numBits: number
+): string[] {
+  const wires = new Set<string>();
+  const visited = new Set<string>();
+
+  function traceDeps(wire: string): void {
+    if (visited.has(wire)) return;
+    visited.add(wire);
+    const gate = gates.find((g) => g.out === wire);
+    if (!gate) return;
+    wires.add(wire);
+    if (!/^[xy]\d+$/.test(gate.in1)) traceDeps(gate.in1);
+    if (!/^[xy]\d+$/.test(gate.in2)) traceDeps(gate.in2);
+  }
+
+  // Trace dependencies for the broken bit and nearby bits
+  for (let b = Math.max(0, bit - 1); b <= Math.min(numBits, bit + 1); b++) {
+    const zWire = `z${String(b).padStart(2, '0')}`;
+    traceDeps(zWire);
+  }
+
+  // Also add consumers of collected wires
+  for (const g of gates) {
+    if (wires.has(g.in1) || wires.has(g.in2)) {
+      if (!/^[xy]\d+$/.test(g.out)) {
+        wires.add(g.out);
+      }
+    }
+  }
+
+  return [...wires];
+}
