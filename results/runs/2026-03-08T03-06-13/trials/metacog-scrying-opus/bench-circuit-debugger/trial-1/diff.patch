\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1], 10) + 1);\n    }\n  }\n\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  // Phase 1: Structural rules that always hold in a correct adder\n  // Apply these iteratively until no more swaps are found\n  let foundSwap = true;\n  while (foundSwap) {\n    foundSwap = false;\n\n    for (const g of workGates) {\n      if (swapped.has(g.out) && swapped.size >= 8) continue;\n\n      const isZWire = /^z\\d+$/.test(g.out);\n      const hasXYInputs =\n        (/^[xy]\\d+$/.test(g.in1) && /^[xy]\\d+$/.test(g.in2));\n\n      // Rule 1: z-wires (except lastZ) must come from XOR gates\n      if (isZWire && g.out !== lastZ && g.op !== 'XOR') {\n        // This non-XOR gate shouldn't output a z-wire.\n        // Find the correct source: trace adder structure for this bit.\n        const bitNum = parseInt(g.out.slice(1), 10);\n        const xi = `x${String(bitNum).padStart(2, '0')}`;\n        const yi = `y${String(bitNum).padStart(2, '0')}`;\n\n        if (bitNum === 0) {\n          // z00 should come from XOR(x00, y00)\n          const correctGate = findGate('XOR', xi, yi);\n          if (correctGate && correctGate.out !== g.out) {\n            doSwap(g.out, correctGate.out);\n            foundSwap = true;\n            break;\n          }\n        } else {\n          // zi should come from XOR(ti, carry). Find the XOR gate that\n          // should output zi. It's the XOR gate that doesn't have x/y direct inputs\n          // and is related to bit i.\n          // Simpler: find which XOR gate was swapped with this gate.\n          // The gate `g` currently outputs zi but shouldn't (it's AND or OR).\n          // Some XOR gate currently outputs g's correct name.\n          // We can find it by looking for XOR gates that output non-z wires\n          // but should output z wires.\n\n          // For now, swap with the XOR gate that should be producing zi.\n          // The XOR 