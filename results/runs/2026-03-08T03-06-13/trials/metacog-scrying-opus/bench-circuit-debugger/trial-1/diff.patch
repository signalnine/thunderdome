)).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n  });\n\n  it('should simulate gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'x', in2: 'y', out: 'a' },\n      { op: 'OR', in1: 'a', in2: 'z', out: 'b' },\n    ];\n    const result = simulate(gates, { x: 1, y: 1, z: 0 });\n    expect(result).toEqual({ x: 1, y: 1, z: 0, a: 1, b: 1 });\n  });\n\n  it('should simulate a 2-bit adder', () => {\n    // 2-bit adder: x(1:0) + y(1:0) = z(2:0)\n    const gates: Gate[] = [\n      // Bit 0: half adder\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1: full adder\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 1 + 1 = 2 (01 + 01 = 010)\n    let result = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n\n    // 3 + 3 = 6 (11 + 11 = 110)\n    result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n\n    // 2 + 1 = 3 (10 + 01 = 011)\n    result = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(result.z00).toBe(1);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Build a correct N-bit adder, then swap some outputs and verify detection\n  function buildCorrectAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < numBits; i++) {\n      const xi = `x${String(i).padStart(2, '0')}`;\n      const yi = `y${String(i).padStart(2, '0')}`;\n      const zi = `z${String(i).padStart(2, '0')}`;\n      const ti = `t${String(i).padStart(2, '0')}`;\n      const ai = `a${String(i).padStart(2, '0')}`;\n      const bi = `b${String(i).padStart(2, '0')}`;\n      const ci = `c${String(i).padStart(2, '0')}`;\n      const cPrev = `c${String(i - 1).padStart(2, '0')}`;\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n      gates.push({ op: 'XOR', in1: ti, in2: cPrev, out: zi });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n      gates.push({ op: 'AND', in1: ti, in2: cPrev, out: bi });\n      gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n    }\n\n    // Final carry -> MSB output\n    const lastC = `c${String(numBits - 1).padStart(2, '0')}`;\n    const lastZ = `z${String(numBits).padStart(2, '0')}`;\n    // The carry out of the last bit is the final z bit.\n    // In the spec example, c03 -> z04 - that's just an alias / direct wire.\n    // We represent this by changing the last OR gate's output to the z wire.\n    const lastOrGate = gates.find(g => g.out === lastC);\n    if (lastOrGate) {\n      lastOrGate.out = lastZ;\n    }\n\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], a: string, b: string): void {\n    const gateA = gates.find(g => g.out === a);\n    const gateB = gates.find(g => g.out === b);\n    if (gateA) gateA.out = b;\n    if (gateB) gateB.out = a;\n  }\n\n  it('should find 4 pairs of swapped wires in a small adder', () => {\n    const gates = buildCorrectAdder(8);\n\n    // Swap 4 pairs\n    swapOutputs(gates, 'z01', 'a01'); // swap z01 and a01\n    swapOutputs(gates, 't03', 'c03'); // swap t03 and c03\n    swapOutputs(gates, 'z05', 'b05'); // swap z05 and b05\n    swapOutputs(gates, 'a07', 'z08'); // swap a07 and z08\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a07', 'b05', 'c03', 't03', 'z01', 'z05', 'z08'].sort());\n  });\n\n  it('should find swapped wires in a larger adder', () => {\n    const gates = buildCorrectAdder(20);\n\n    swapOutputs(gates, 'z02', 't02');\n    swapOutputs(gates, 'a05', 'c05');\n    swapOutputs(gates, 'z10', 'c10');\n    swapOutputs(gates, 't15', 'z15');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a05', 'c05', 'c10', 't02', 't15', 'z02', 'z10', 'z15'].sort());\n  });\n\n  it('should handle swaps involving the final carry bit', () => {\n    const gates = buildCorrectAdder(8);\n\n    // Note: the last carry is z09 (for 8-bit adder, the MSB is z08... wait.\n    // buildCorrectAdder(8) creates bits 0-7, so outputs z00-z07 plus z08.\n    // The last OR gate outputs z08 directly.\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'b03');\n    swapOutputs(gates, 't05', 'a05');\n    swapOutputs(gates, 'z07', 'b07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a05', 'b03', 'b07', 't05', 'z01', 'z03', 'z07'].sort());\n  });\n});\n","structuredPatch":[{"oldStart":139,"oldLines":9,"newStart":139,"newLines":6,"lines":["   it('should handle swaps involving the final carry bit', () => {","     const gates = buildCorrectAdder(8);"," ","-    // Note: the last 