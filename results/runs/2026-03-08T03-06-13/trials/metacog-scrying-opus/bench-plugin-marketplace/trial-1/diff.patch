ects.toThrow('name');\n  });\n\n  it('should reject plugin without version', async () => {\n    await expect(\n      marketplace.installPlugin(makeManifest({ version: '' }))\n    ).rejects.toThrow('version');\n  });\n\n  it('should reject plugin without entryPoint', async () => {\n    await expect(\n      marketplace.installPlugin(makeManifest({ entryPoint: '' }))\n    ).rejects.toThrow('entryPoint');\n  });\n\n  it('should resolve dependencies during install', async () => {\n    // Register a dependency first\n    marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));\n    marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.1.0' }));\n\n    const result = await marketplace.installPlugin(\n      makeManifest({\n        name: 'main-plugin',\n        dependencies: { 'dep-a': '^1.0.0' },\n      })\n    );\n    expect(result.resolvedDependencies).toHaveLength(1);\n    expect(result.resolvedDependencies[0].name).toBe('dep-a');\n    expect(result.resolvedDependencies[0].version).toBe('1.1.0');\n  });\n\n  it('should reject circular dependencies', async () => {\n    // Register plugin A that depends on B\n    marketplace.registry.register(\n      makeManifest({ name: 'A', version: '1.0.0', dependencies: { B: '^1.0.0' } })\n    );\n    // Register plugin B that depends on A\n    marketplace.registry.register(\n      makeManifest({ name: 'B', version: '1.0.0', dependencies: { A: '^1.0.0' } })\n    );\n\n    // Try to install C that depends on A (which has circular dep with B)\n    await expect(\n      marketplace.installPlugin(\n        makeManifest({\n          name: 'C',\n          version: '1.0.0',\n          dependencies: { A: '^1.0.0' },\n        })\n      )\n    ).rejects.toThrow('Circular dependency');\n  });\n\n  it('should execute entryPoint and return result', async () => {\n    const result = await marketplace.installPlugin(\n      makeManifest({ entryPoint: '\"hello world\"' })\n    );\n    expect(result.executionResult.success).toBe(true);\n    expect(result.executionResult.output).toBe('hello world');\n  });\n\n  it('should handle entryPoint execution errors', async () => {\n    const result = await marketplace.installPlugin(\n      makeManifest({ entryPoint: 'throw new Error(\"init failed\")' })\n    );\n    expect(result.executionResult.success).toBe(false);\n    expect(result.executionResult.error).toBe('init failed');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":107,"cache_read_input_tokens":27904,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":107},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"650b3ab6-5454-451f-846e-13997cb9ce8c","uuid":"5a13cd8f-da41-4cca-8269-fde35877a225"}
