+  });
+
+  it('should add a review', () => {
+    const review = reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great plugin!',
+    });
+    expect(review.id).toBe(1);
+    expect(review.flagged).toBe(false);
+    expect(review.createdAt).toBeDefined();
+  });
+
+  it('should get reviews for a plugin', () => {
+    reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great!',
+    });
+    reviews.addReview({
+      pluginName: 'other-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 3,
+      comment: 'OK',
+    });
+    const pluginReviews = reviews.getReviews('test-plugin');
+    expect(pluginReviews).toHaveLength(1);
+    expect(pluginReviews[0].pluginName).toBe('test-plugin');
+  });
+
+  it('should compute average rating excluding flagged', () => {
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });
+    const flagged = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: '' });
+    reviews.flagReview(flagged.id);
+
+    const avg = reviews.getAverageRating('p');
+    expect(avg).toBe(4); // (5+3)/2 = 4, flagged one excluded
+  });
+
+  it('should return 0 average for no reviews', () => {
+    expect(reviews.getAverageRating('nonexistent')).toBe(0);
+  });
+
+  it('should flag reviews', () => {
+    const review = reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 1,
+      comment: 'spam',
+    });
+    reviews.flagReview(review.id);
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged).toHaveLength(1);
+    expect(flagged[0].id).toBe(review.id);
+  });
+
+  it('should remove review', () => {
+    const review = reviews.addReview({
+      pluginName: 'p',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 3,
+      comment: '',
+    });
+    expect(reviews.removeReview(review.id)).toBe(true);
+    expect(reviews.getReviews('p')).toHaveLength(0);
+  });
+
+  it('should return false for removing nonexistent review', () => {
+    expect(reviews.removeReview(999)).toBe(false);
+  });
+
+  it('should get reviews by user', () => {
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: '' });
+    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: '' });
+    const userReviews = reviews.getReviewsByUser('user1');
+    expect(userReviews).toHaveLength(2);
+  });
+
+  it('should get review count', () => {
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });
+    expect(reviews.getReviewCount('p')).toBe(2);
+  });
+
+  it('should throw when flagging nonexistent review', () => {
+    expect(() => reviews.flagReview(999)).toThrow();
+  });
+
+  it('should reject invalid rating', () => {
+    expect(() =>
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u', rating: 6, comment: '' })
+    ).toThrow();
+    expect(() =>
+      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u', rating: 0, comment: '' })
+    ).toThrow();
+  });
+});
