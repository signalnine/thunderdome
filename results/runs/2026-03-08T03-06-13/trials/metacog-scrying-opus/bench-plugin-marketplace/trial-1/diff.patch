+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+const DEFAULT_TIMEOUT = 5000;
+
+export function createRunner(): RunnerService {
+  async function runCode(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {}
+  ): Promise<SandboxResult> {
+    const startTime = performance.now();
+    const startMemory = process.memoryUsage().heapUsed;
+
+    try {
+      const sandbox: Record<string, unknown> = {
+        ...context,
+        console: {
+          log: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+        },
+      };
+      const outputs: string[] = [];
+
+      vm.createContext(sandbox);
+      const script = new vm.Script(code);
+      const result = script.runInContext(sandbox, { timeout: timeoutMs });
+
+      const duration = performance.now() - startTime;
+      const memoryUsed = process.memoryUsage().heapUsed - startMemory;
+
+      return {
+        success: true,
+        output: result !== undefined ? result : (outputs.length > 0 ? outputs.join('\n') : undefined),
+        duration,
+        memoryUsed: Math.max(0, memoryUsed),
+      };
+    } catch (err: unknown) {
+      const duration = performance.now() - startTime;
+      const memoryUsed = process.memoryUsage().heapUsed - startMemory;
+      // vm context errors don't pass instanceof Error check, but still have .message
+      const errObj = err as { message?: string };
+      const errorMessage = typeof errObj?.message === 'string' ? errObj.message : String(err);
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed: Math.max(0, memoryUsed),
+        error: errorMessage,
+      };
+    }
+  }
+
+  return {
+    async execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+      return runCode(code, DEFAULT_TIMEOUT, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return runCode(code, timeoutMs, context);
+    },
+  };
+}
