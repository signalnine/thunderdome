ies('A', registry);\n    expect(flat).toContain('B');\n    expect(flat).toContain('C');\n    expect(flat).toContain('D');\n    expect(flat).not.toContain('A');\n  });\n\n  it('should handle missing dependencies gracefully in tree', () => {\n    registry.register(makeManifest('A', { missing: '^1.0.0' }));\n    const tree = depsService.buildTree('A', registry);\n    expect(tree.dependencies).toHaveLength(1);\n    expect(tree.dependencies[0].name).toBe('missing');\n    expect(tree.dependencies[0].version).toBe('unknown');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":107,"cache_read_input_tokens":27904,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":107},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"650b3ab6-5454-451f-846e-13997cb9ce8c","uuid":"0cd6db8e-efc7-4a5a-8ab0-6d4d4418c477"}
