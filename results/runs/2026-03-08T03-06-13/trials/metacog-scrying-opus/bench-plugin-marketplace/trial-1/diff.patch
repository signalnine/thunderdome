n\n  it('should return null for unknown version', () => {\n    registry.register(makeManifest());\n    expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();\n  });\n\n  it('should list all plugins', () => {\n    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    const list = registry.list();\n    expect(list).toHaveLength(2);\n  });\n\n  it('should search plugins by name', () => {\n    registry.register(makeManifest({ name: 'auth-plugin', description: 'auth' }));\n    registry.register(makeManifest({ name: 'db-plugin', description: 'database' }));\n    const results = registry.search('auth');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('auth-plugin');\n  });\n\n  it('should search plugins by description', () => {\n    registry.register(makeManifest({ name: 'foo', description: 'handles authentication' }));\n    const results = registry.search('authentication');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should remove a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    const removed = registry.remove('test-plugin', '1.0.0');\n    expect(removed).toBe(true);\n    expect(registry.listVersions('test-plugin')).toEqual(['2.0.0']);\n  });\n\n  it('should return false when removing nonexistent', () => {\n    expect(registry.remove('none', '1.0.0')).toBe(false);\n  });\n\n  it('should update a plugin manifest', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'updated desc' });\n    const result = registry.get('test-plugin');\n    expect(result!.description).toBe('updated desc');\n  });\n\n  it('should throw when updating nonexistent plugin', () => {\n    expect(() => registry.update('none', '1.0.0', {})).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"