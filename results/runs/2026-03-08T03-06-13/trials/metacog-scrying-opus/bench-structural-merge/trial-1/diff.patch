cloneBranchState(state: BranchState): BranchState {\n  const docs = new Map<string, DocEntry>();\n  for (const [id, entry] of state.docs) {\n    docs.set(id, {\n      content: deepClone(entry.content),\n      versions: entry.versions.map((v) => ({\n        id: v.id,\n        timestamp: v.timestamp,\n        content: deepClone(v.content),\n      })),\n      deleted: entry.deleted,\n    });\n  }\n  return { docs };\n}\n\n/**\n * Check if a value is a plain object (not array, not null, not primitive).\n */\nfunction isPlainObject(val: unknown): val is Record<string, unknown> {\n  return val !== null && typeof val === \"object\" && !Array.isArray(val);\n}\n\n/**\n * Collect all unique keys across up to three objects.\n */\nfunction allKeys(...objs: (Record<string, unknown> | undefined)[]): Set<string> {\n  const keys = new Set<string>();\n  for (const obj of objs) {\n    if (obj) {\n      for (const k of Object.keys(obj)) {\n        keys.add(k);\n      }\n    }\n  }\n  return keys;\n}\n\n/**\n * Deep equality check.\n */\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== \"object\") return a === b;\n  if (Array.isArray(a) !== Array.isArray(b)) return false;\n  if (Array.isArray(a) && Array.isArray(b)) {\n    if (a.length !== b.length) return false;\n    for (let i = 0; i < a.length; i++) {\n      if (!deepEqual(a[i], b[i])) return false;\n    }\n    return true;\n  }\n  const aObj = a as Record<string, unknown>;\n  const bObj = b as Record<string, unknown>;\n  const aKeys = Object.keys(aObj);\n  const bKeys = Object.keys(bObj);\n  if (aKeys.length !== bKeys.length) return false;\n  for (const k of aKeys) {\n    if (!(k in bObj)) return false;\n    if (!deepEqual(aObj[k], bObj[k])) return false;\n  }\n  return true;\n}\n\n/**\n * Three-way merge of two values against a common base.\n * Returns { result, conflicts } where conflicts is an array of Conflict objects.\n */\nfunction threeWayMerge(\n  base: unknown,\n  ours: unknown,\n  theirs: unknown,\n  docId: string,\n  path: string,\n): { result: unknown; conflicts: Conflict[] } {\n  const oursChanged = !deepEqual(base, ours);\n  const theirsChanged = !deepEqual(base, theirs);\n\n  // If neither changed, use base\n  if (!oursChanged && !theirsChanged) {\n    return { result: deepClone(base), conflicts: [] };\n  }\n\n  // If only one side changed, take that side\n  if (oursChanged && !theirsChanged) {\n    return { result: deepClone(ours), conflicts: [] };\n  }\n  if (!oursChanged && theirsChanged) {\n    return { result: deepClone(theirs), conflicts: [] };\n  }\n\n  // Both changed\n  // If both changed to the same value, no conflict\n  if (deepEqual(ours, theirs)) {\n    return { result: deepClone(ours), conflicts: [] };\n  }\n\n  // If all three are plain objects, recurse into keys\n  if (isPlainObject(base) && isPlainObject(ours) && isPlainObject(theirs)) {\n    const merged: Record<string, unknown> = {};\n    const conflicts: Conflict[] = [];\n    const keys = allKeys(base, ours, theirs);\n\n    for (const key of keys) {\n      const subPath = path ? `${path}.${key}` : key;\n      const sub = threeWayMerge(\n        base[key],\n        ours[key],\n        theirs[key],\n        docId,\n        subPath,\n      );\n      merged[key] = sub.result;\n      conflicts.push(...sub.conflicts);\n    }\n    return { result: merged, conflicts };\n  }\n\n  // If both are objects but base isn't (or any other mismatch), and they're\n  // not equal, that's a leaf conflict\n  if (isPlainObject(ours) && isPlainObject(theirs)) {\n    // Even if base isn't an object, we can try to merge the two objects\n    // treating base fields as undefined\n    const baseObj = isPlainObject(base)\n      ? base\n      : ({} as Record<string, unknown>);\n    const merged: Record<string, unknown> = {};\n    const conflicts: Conflict[] = [];\n    const keys = allKeys(baseObj, ours, theirs);\n\n    for (const key of keys) {\n      const subPath = path ? `${path}.${key}` : key;\n      const sub = threeWayMerge(\n        baseObj[key],\n        ours[key],\n        theirs[key],\n        docId,\n        subPath,\n      );\n      merged[key] = sub.result;\n      conflicts.push(...sub.conflicts);\n    }\n    return { result: merged, conflicts };\n  }\n\n  // Leaf conflict: both sides changed to different non-object values\n  return {\n    result: deepClone(ours), // resolve in favor of \"ours\" for the merged view\n    conflicts: [\n      {\n        documentId: docId,\n        path: path,\n        base: deepClone(base),\n        ours: deepClone(ours),\n        theirs: deepClone(theirs),\n      },\n    ],\n  };\n}\n\n// ── DocumentStore ──────────────────────────────────────────────────────────\n\nexport class DocumentStore {\n  private branches: Map<string, Branch> = new Map();\n  private currentBranch: string = \"main\";\n\n  constructor() {\n    this.branches.set(\"main\", {\n      state: { docs: new Map() },\n      forkSnapshot: { docs: new Map() },\n      parentName: null,\n    });\n  }\n\n  // ── CRUD ───────────────────────────────────────────────────────────────\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const existing = branch.state.docs.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const version: Version = {\n      id: newVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n    branch.state.docs.set(id, {\n      content: deepClone(content),\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.state.docs.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return deepClone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.state.docs.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version: Version = {\n      id: newVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n    entry.content = deepClone(content);\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.state.docs.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    entry.deleted = true;\n  }\n\n  // ── Version History ────────────────────────────────────────────────────\n\n  getHistory(id: string): Version[] {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.state.docs.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return entry.versions.map((v) => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.state.docs.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = entry.versions.find((v) => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ── Branching ──────────────────────────────────────────────────────────\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch \"${sourceName}\" not found`);\n    }\n    this.branches.set(name, {\n      state: cloneBranchState(source.state),\n      forkSnapshot: cloneBranchState(source.state),\n      parentName: sourceName,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ── Merging ────────────────────────────────────────────────────────────\n\n  merge(sourceBranch: string): MergeResult {\n    const source = this.branches.get(sourceBranch);\n    if (!source) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n    const target = this.getCurrentBranchData();\n\n    // The common ancestor is the fork snapshot of the source branch\n    const base = source.forkSnapshot;\n\n    // Collect all document IDs across base, ours (target), and theirs (source)\n    const allDocIds = new Set<string>();\n    for (const id of base.docs.keys()) allDocIds.add(id);\n    for (const id of target.state.docs.keys()) allDocIds.add(id);\n    for (const id of source.state.docs.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const allConflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseEntry = base.docs.get(docId);\n      const oursEntry = target.state.docs.get(docId);\n      const theirsEntry = source.state.docs.get(docId);\n\n      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;\n      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : undefined;\n      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : undefined;\n\n      // If nothing changed compared to base for this document, skip\n      const oursChanged = !deepEqual(baseContent, oursContent);\n      const theirsChanged = !deepEqual(baseContent, theirsContent);\n\n      if (!oursChanged && !theirsChanged) {\n        // No changes on either side for this document - skip\n        continue;\n      }\n\n      // If only theirs changed (and ours didn't)\n      if (!oursChanged && theirsChanged) {\n        if (theirsContent === undefined) {\n          // They deleted it, we didn't change it - apply deletion\n          merged[docId] = null as unknown as object;\n        } else {\n          merged[docId] = deepClone(theirsContent) as object;\n        }\n        continue;\n      }\n\n      // If only ours changed (and theirs didn't)\n      if (oursChanged && !theirsChanged) {\n        if (oursContent !== undefined) {\n          merged[docId] = deepClone(oursContent) as object;\n        }\n        // If ours deleted, it's already deleted on our branch\n        continue;\n      }\n\n      // Both changed\n      if (deepEqual(oursContent, theirsContent)) {\n        // Both changed to the same thing - no conflict\n        if (oursContent !== undefined) {\n          merged[docId] = deepClone(oursContent) as object;\n        }\n        continue;\n      }\n\n      // Handle cases where one side deleted and the other modified\n      if (oursContent === undefined || theirsContent === undefined) {\n        // One side deleted, other modified - this is a conflict\n        const result = oursContent !== undefined ? deepClone(oursContent) : theirsContent !== undefined ? deepClone(theirsContent) : undefined;\n        if (result !== undefined) {\n          merged[docId] = result as object;\n        }\n        allConflicts.push({\n          documentId: docId,\n          path: \"\",\n          base: baseContent !== undefined ? deepClone(baseContent) : undefined,\n          ours: oursContent !== undefined ? deepClone(oursContent) : undefined,\n          theirs: theirsContent !== undefined ? deepClone(theirsContent) : undefined,\n        });\n        continue;\n      }\n\n      // Both sides have content - do structural merge\n      const baseObj = (baseContent ?? {}) as Record<string, unknown>;\n      const { result, conflicts } = threeWayMerge(\n        baseObj,\n        oursContent,\n        theirsContent,\n        docId,\n        \"\",\n      );\n      merged[docId] = result as object;\n      allConflicts.push(...conflicts);\n    }\n\n    const applied = allConflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge to the current branch\n      for (const [docId, content] of Object.entries(merged)) {\n        if (content === null) {\n          // Deletion from theirs\n          const entry = target.state.docs.get(docId);\n          if (entry) {\n            entry.deleted = true;\n          }\n        } else {\n          const entry = target.state.docs.get(docId);\n          if (entry) {\n            // Update existing doc\n            const version: Version = {\n              id: newVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(content),\n            };\n            entry.content = deepClone(content);\n            entry.versions.push(version);\n            entry.deleted = false;\n          } else {\n            // New doc from source branch\n            const version: Version = {\n              id: newVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(content),\n            };\n            target.state.docs.set(docId, {\n              content: deepClone(content),\n              versions: [version],\n              deleted: false,\n            });\n          }\n        }\n      }\n    }\n\n    // Clean up null entries from merged result\n    const cleanMerged: Record<string, object> = {};\n    for (const [docId, content] of Object.entries(merged)) {\n      if (content !== null) {\n        cleanMerged[docId] = content;\n      }\n    }\n\n    return {\n      merged: cleanMerged,\n      conflicts: allConflicts,\n      applied,\n    };