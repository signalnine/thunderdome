{\n      throw new Error(`Invalid cron minute: \"${minPart}\"`);\n    }\n    minute = { type: 'fixed', value };\n  }\n\n  // Parse hour\n  let hour: CronFields['hour'];\n  if (hourPart === '*') {\n    hour = { type: 'any' };\n  } else {\n    const value = parseInt(hourPart, 10);\n    if (isNaN(value) || value < 0 || value > 23) {\n      throw new Error(`Invalid cron hour: \"${hourPart}\"`);\n    }\n    hour = { type: 'fixed', value };\n  }\n\n  // remaining fields must be *\n  if (domPart !== '*' || monthPart !== '*' || dowPart !== '*') {\n    throw new Error(`Unsupported cron expression: \"${expression}\". Only minute and hour fields are supported.`);\n  }\n\n  return {\n    minute,\n    hour,\n    dayOfMonth: { type: 'any' },\n    month: { type: 'any' },\n    dayOfWeek: { type: 'any' },\n  };\n}\n\nfunction cronShouldRun(fields: CronFields, now: Date, lastRun: Date | undefined): boolean {\n  const currentMinute = now.getMinutes();\n  const currentHour = now.getHours();\n\n  // Check hour constraint\n  if (fields.hour.type === 'fixed' && currentHour !== fields.hour.value) {\n    return false;\n  }\n\n  // Check minute constraint\n  if (fields.minute.type === 'fixed') {\n    if (currentMinute !== fields.minute.value) {\n      return false;\n    }\n  } else if (fields.minute.type === 'every') {\n    if (currentMinute % fields.minute.interval !== 0) {\n      return false;\n    }\n  }\n\n  // Don't run twice in the same minute\n  if (lastRun) {\n    const lastMinute = lastRun.getMinutes();\n    const lastHour = lastRun.getHours();\n    const lastDate = lastRun.toDateString();\n    const nowDate = now.toDateString();\n    if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {\n      return false;\n    }\n  }\n\n  return true;\n}\n\n// ── TaskQueue class ──────────────────────────────────────────────────────────\n\nexport class TaskQueue {\n  private queues: Map<string, QueueState> = new Map();\n  private allTasks: Map<string, Task> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private shutdownInitiated = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  private static readonly DEFAULT_QUEUE = 'default';\n\n  // ── Queue management ─────────────────────────────────────────────────────\n\n  private getOrCreateQueue(name: string): QueueState {\n    let queue = this.queues.get(name);\n    if (!queue) {\n      queue = {\n        tasks: new Map(),\n        deadLetterQueue: [],\n        concurrencyLimit: null,\n        middlewares: [],\n        handler: null,\n      };\n      this.queues.set(name, queue);\n    }\n    return queue;\n  }\n\n  private resolveQueueName(name?: string): string {\n    return name ?? TaskQueue.DEFAULT_QUEUE;\n  }\n\n  // ── Phase 1 & 2: Add task ────────────────────────────────────────────────\n\n  add<T>(options: AddTaskOptions<T>): Task<T> {\n    if (this.shutdownInitiated) {\n      throw new Error('Cannot add tasks: system is shutting down');\n    }\n\n    const queueName = this.resolveQueueName(options.queue);\n\n    // Phase 3: validate priority\n    const priority = options.priority ?? 5;\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 7: validate dependencies\n    if (options.dependencies && options.dependencies.length > 0) {\n      for (const depId of options.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (!depTask) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n    }\n\n    const task = createTask({ ...options, priority }, queueName);\n\n    // Phase 7: check for circular dependencies\n    if (task.dependencies.length > 0) {\n      this.detectCircularDependencies(task);\n    }\n\n    const queue = this.getOrCreateQueue(queueName);\n    queue.tasks.set(task.id, task as Task);\n    this.allTasks.set(task.id, task as Task);\n\n    return task;\n  }\n\n  // ── Phase 7: Circular dependency detection ───────────────────────────────\n\n  private detectCircularDependencies(newTask: Task): void {\n    // BFS: check if any of newTask's dependencies transitively depend on newTask\n    // Since newTask hasn't been added yet, we only need to check if any dependency\n    // chain leads back to newTask's dependencies forming a cycle.\n    // Actually, since newTask is new, no existing task can depend on it yet,\n    // so cycles can't form. But we should check if the dependencies themselves\n    // form a chain that includes a task that depends on one of the other deps.\n    // The real check: ensure no dep transitively depends on another dep in a way\n    // that would block resolution. But actually, the real circular dep case is:\n    // Task A depends on Task B, and we're adding Task C that depends on A,\n    // while A also depends on C. But since C doesn't exist yet, A can't depend on C.\n    // So circular deps can only happen with an existing task graph.\n    // We need: if any of the dependency tasks have newTask.id in their transitive deps.\n    // But newTask hasn't been added yet, so nothing can point to it.\n    // The only real scenario: two tasks being added where A depends on B and B depends on A,\n    // but since they're added sequentially, by the time B is added, A exists and we check\n    // if A transitively depends on B - which it can't since B didn't exist when A was created.\n    // Actually, we should just verify the entire graph remains a DAG.\n\n    // Simple check: verify none of the deps are blocked on each other in a cycle\n    const visited = new Set<string>();\n    const check = (taskId: string): boolean => {\n      if (taskId === newTask.id) return true; // cycle detected (won't happen for new tasks)\n      if (visited.has(taskId)) return false;\n      visited.add(taskId);\n      const task = this.allTasks.get(taskId);\n      if (!task) return false;\n      for (const depId of task.dependencies) {\n        if (check(depId)) return true;\n      }\n      return false;\n    };\n\n    // Check if any dependency transitively leads back to... well, since newTask\n    // isn't in allTasks yet, this won't find a cycle. The cycle detection matters\n    // when deps reference each other. Let's verify deps don't have unresolvable cycles.\n    // In practice, the important check is: are any of the dependencies in a state where\n    // they themselves are blocked by something that would never resolve?\n    // For now, just ensure the dependency graph is valid.\n\n    for (const depId of newTask.dependencies) {\n      // Check this dep's transitive dependencies don't include any of newTask's other deps\n      // in a circular way. This is actually fine. The real issue is if deps are blocked\n      // on each other.\n      visited.clear();\n      // no real cycle possible for a newly added task since nothing depends on it yet.\n      check(depId);\n    }\n  }\n\n  // ── Phase 1 & 2: Retrieve next task ──────────────────────────────────────\n\n  process(queueName?: string): Task | null {\n    const name = this.resolveQueueName(queueName);\n    const queue = this.queues.get(name);\n    if (!queue) return null;\n\n    // Phase 8: check concurrency limit\n    if (queue.concurrencyLimit !== null) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= queue.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of queue.tasks.values()) {\n      if (task.status !== 'pending') continue;\n      // Phase 4: check availability\n      if (task.availableAt > now) continue;\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort by: priority ASC (lower = higher priority), then availability time, then creation time\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt += 1;\n    task.updatedAt = new Date();\n    return task;\n  }\n\n  // ── Phase 1: Count pending tasks ─────────────────────────────────────────\n\n  size(queueName?: string): number {\n    const name = this.resolveQueueName(queueName);\n    const queue = this.queues.get(name);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const task of queue.tasks.values()) {\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // ── Phase 2: List queue names ────────────────────────────────────────────\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ── Phase 5: Complete a task ─────────────────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n    task.updatedAt = new Date();\n\n    // Phase 7: unblock dependent tasks\n    this.checkDependents(taskId);\n  }\n\n  // ── Phase 5: Fail a task ─────────────────────────────────────────────────\n\n  fail(taskId: string, error?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n    task.failCount += 1;\n    task.updatedAt = new Date();\n\n    // Check if retries remain\n    if (task.attempt < task.maxRetries) {\n      // Re-add with exponential backoff delay\n      const delay = task.baseDelay * Math.pow(2, task.attempt - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n    } else {\n      // Phase 6: move to DLQ\n      task.status = 'failed';\n      const queue = this.queues.get(task.queue);\n      if (queue) {\n        queue.tasks.delete(task.id);\n        queue.deadLetterQueue.push(task);\n      }\n    }\n  }\n\n  // ── Phase 7: Check and unblock dependents ────────────────────────────────\n\n  private checkDependents(completedTaskId: string): void {\n    for (const task of this.allTasks.values()) {\n      if (task.status !== 'blocked') continue;\n      if (!task.dependencies.includes(completedTaskId)) continue;\n\n      // Check if all dependencies are now completed\n      const allCompleted = task.dependencies.every((depId) => {\n        const dep = this.allTasks.get(depId);\n        return dep && dep.status === 'completed';\n      });\n\n      if (allCompleted) {\n        task.status = 'pending';\n        task.updatedAt = new Date();\n      }\n    }\n  }\n\n  // ── Phase 7: Get dependency status ───────────────────────────────────────\n\n  getDependencyStatus(taskId: string): { taskId: string; status: string; resolved: boolean }[] {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    return task.dependencies.map((depId) => {\n      const dep = this.allTasks.get(depId);\n      return {\n        taskId: depId,\n        status: dep ? dep.status : 'unknown',\n        resolved: dep ? dep.status === 'completed' : false,\n      };\n    });\n  }\n\n  // ── Phase 6: DLQ operations ──────────────────────────────────────────────\n\n  getDeadLetterQueue(queueName?: string): Task[] {\n    const name = this.resolveQueueName(queueName);\n    const queue = this.queues.get(name);\n    if (!queue) return [];\n    return [...queue.deadLetterQueue];\n  }\n\n  requeue(taskId: string): Task {\n    // Find the task in a DLQ\n    for (const queue of this.queues.values()) {\n      const index = queue.deadLetterQueue.findIndex((t) => t.id === taskId);\n      if (index !== -1) {\n        const task = queue.deadLetterQueue.splice(index, 1)[0];\n        // Reset for fresh retries\n        task.status = 'pending';\n        task.attempt = 0;\n        task.failCount = 0;\n        task.error = undefined;\n        task.progress = 0;\n        task.availableAt = new Date();\n        task.updatedAt = new Date();\n        queue.tasks.set(task.id, task);\n        this.allTasks.set(task.id, task);\n        return task;\n      }\n    }\n    throw new Error(`Task not found in any dead letter queue: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = this.resolveQueueName(queueName);\n    const queue = this.queues.get(name);\n    if (queue) {\n      // Also remove from allTasks\n      for (const task of queue.deadLetterQueue) {\n        this.allTasks.delete(task.id);\n      }\n      queue.deadLetterQueue = [];\n    }\n  }\n\n  // ── Phase 8: Concurrency control ────────────────────────────────────────\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): number | null {\n    const name = this.resolveQueueName(queueName);\n    const queue = this.queues.get(name);\n    if (!queue) return null;\n    return queue.concurrencyLimit;\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = this.resolveQueueName(queueName);\n    const queue = this.queues.get(name);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const task of queue.tasks.values()) {\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // ── Phase 9: Progress tracking ───────────────────────────────────────────\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Progress must be between 0 and 100: ${progress}`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n    task.updatedAt = new Date();\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  // ── Phase 9: Cancellation ───────────────────────────────────────────────\n\n  cancel(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {\n      throw new Error(`Cannot cancel task in status: ${task.status}`);\n    }\n\n    task.status = 'cancelled';\n    task.updatedAt = new Date();\n\n    // Remove from queue if pending/blocked\n    const queue = this.queues.get(task.queue);\n    if (queue) {\n      queue.tasks.delete(task.id);\n    }\n  }\n\n  // ── Phase 10: Recurring tasks ────────────────────────────────────────────\n\n  addSchedule(\n    cronExpression: string,\n    queue: string,\n    payload: unknown,\n    options?: { priority?: number },\n  ): Schedule {\n    // Validate the expression\n    parseCron(cronExpression);\n\n    const schedule = createSchedule(\n      cronExpression,\n      queue,\n      payload,\n      options?.priority,\n    );\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule not found: ${scheduleId}`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      const fields = parseCron(schedule.cronExpression);\n      if (cronShouldRun(fields, currentTime, schedule.lastRun)) {\n        schedule.lastRun = currentTime;\n        const task = this.add({\n          payload: schedule.payload,\n          queue: schedule.queue,\n          priority: schedule.priority,\n          scheduleId: schedule.id,\n        });\n        created.push(task as Task);\n      }\n    }\n\n    return created;\n  }\n\n  // ── Phase 11: Middleware ─────────────────────────────────────────────────\n\n  use(queueName: string, middleware: Middleware): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: TaskHandler): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.handler = handler;\n  }\n\n  async processWithMiddleware(queueName?: string): Promise<Task | null> {\n    const task = this.process(queueName);\n    if (!task) return null;\n\n    const name = this.resolveQueueName(queueName);\n    const queue = this.queues.get(name);\n    if (!queue) return task;\n\n    const middlewares = queue.middlewares;\n    const handler = queue.handler;\n\n    try {\n      let index = 0;\n      const next = async (): Promise<void> => {\n        if (index < middlewares.length) {\n          const mw = middlewares[index++];\n          await mw(task, next);\n        } else if (handler) {\n          await handler(task);\n        }\n      };\n\n      await next();\n    } catch (err) {\n      const errorMessage = err instanceof Error ? err.message : String(err);\n      this.fail(task.id, errorMessage);\n    }\n\n    return task;\n  }\n\n  // ── Phase 12: Graceful shutdown ──────────────────────────────────────────\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout?: number): Promise<ShutdownSummary> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.shutdownInitiated = true;\n    this.shutdownPromise = this.performShutdown(timeout ?? 30000);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(timeout: number): Promise<ShutdownSummary> {\n    const startTime = Date.now();\n    let completed = 0;\n    let cancelled = 0;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Collect all processing tasks\n    const processingTasks: Task[] = [];\n    for (const queue of this.queues.values()) {\n      for (const task of queue.tasks.values()) {\n        if (task.status === 'processing') {\n          processingTasks.push(task);\n        }\n      }\n    }\n\n    if (processingTasks.length > 0) {\n      // Wait for them with timeout\n      const waitForCompletion = (): Promise<void> => {\n        return new Promise((resolve) => {\n          const checkInterval = setInterval(() => {\n            const stillProcessing = processingTasks.filter((t) => t.status === 'processing');\n            if (stillProcessing.length === 0) {\n              clearInterval(checkInterval);\n              resolve();\n            }\n          }, 10);\n\n          setTimeout(() => {\n            clearInterval(checkInterval);\n            resolve();\n          }, timeout);\n        });\n      };\n\n      await waitForCompletion();\n\n      // Force-cancel any remaining processing tasks\n      for (const task of processingTasks) {\n        if (task.status === 'processing') {\n          task.status = 'cancelled';\n          task.updatedAt = new Date();\n          cancelled++;\n        } else if (task.status === 'completed') {\n          completed++;\n        }\n      }\n    }\n\n    const duration = Date.now() - startTime;\n\n    return { completed, cancelled, duration };\n  }\n\n  // ── Utility: Get task by ID ──────────────────────────────────────────────\n\n  getTask(taskId: string): Task | undefined {\n    return this.allTasks.get(taskId);\n  }\n\n  get isShutdown(): boolean {\n    return this.shutdownInitiated;\n  }\n}\n","structuredPatch":[],"originalFile":null}}
