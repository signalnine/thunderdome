+      for (const task of queue.deadLetterQueue) {
+        this.allTasks.delete(task.id);
+      }
+      queue.deadLetterQueue = [];
+    }
+  }
+
+  // ── Phase 8: Concurrency control ────────────────────────────────────────
+
+  setConcurrency(queueName: string, limit: number | null): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName?: string): number | null {
+    const name = this.resolveQueueName(queueName);
+    const queue = this.queues.get(name);
+    if (!queue) return null;
+    return queue.concurrencyLimit;
+  }
+
+  getActiveCount(queueName?: string): number {
+    const name = this.resolveQueueName(queueName);
+    const queue = this.queues.get(name);
+    if (!queue) return 0;
+
+    let count = 0;
+    for (const task of queue.tasks.values()) {
+      if (task.status === 'processing') count++;
+    }
+    return count;
+  }
+
+  // ── Phase 9: Progress tracking ───────────────────────────────────────────
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot update progress for task in status: ${task.status}`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Progress must be between 0 and 100: ${progress}`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+    task.updatedAt = new Date();
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+        if (listeners.size === 0) {
+          this.progressListeners.delete(taskId);
+        }
+      }
+    };
+  }
+
+  // ── Phase 9: Cancellation ───────────────────────────────────────────────
+
+  cancel(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    task.status = 'cancelled';
+    task.updatedAt = new Date();
+
+    // Remove from queue if pending/blocked
+    const queue = this.queues.get(task.queue);
+    if (queue) {
+      queue.tasks.delete(task.id);
+    }
+  }
+
+  // ── Phase 10: Recurring tasks ────────────────────────────────────────────
+
+  addSchedule(
+    cronExpression: string,
+    queue: string,
+    payload: unknown,
+    options?: { priority?: number },
+  ): Schedule {
+    // Validate the expression
+    parseCron(cronExpression);
+
+    const schedule = createSchedule(
+      cronExpression,
+      queue,
+      payload,
+      options?.priority,
+    );
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule not found: ${scheduleId}`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      const fields = parseCron(schedule.cronExpression);
+      if (cronShouldRun(fields, currentTime, schedule.lastRun)) {
+        schedule.lastRun = currentTime;
+        const task = this.add({
+          payload: schedule.payload,
+          queue: schedule.queue,
+          priority: schedule.priority,
+          scheduleId: schedule.id,
+        });
+        created.push(task as Task);
+      }
+    }
+
+    return created;
+  }
+
+  // ── Phase 11: Middleware ─────────────────────────────────────────────────
+
+  use(queueName: string, middleware: Middleware): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.middlewares.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: TaskHandler): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.handler = handler;
+  }
+
+  async processWithMiddleware(queueName?: string): Promise<Task | null> {
+    const task = this.process(queueName);
+    if (!task) return null;
+
+    const name = this.resolveQueueName(queueName);
+    const queue = this.queues.get(name);
+    if (!queue) return task;
+
+    const middlewares = queue.middlewares;
+    const handler = queue.handler;
+
+    try {
+      let index = 0;
+      const next = async (): Promise<void> => {
+        if (index < middlewares.length) {
+          const mw = middlewares[index++];
+          await mw(task, next);
+        } else if (handler) {
+          await handler(task);
+        }
+      };
+
+      await next();
+    } catch (err) {
+      const errorMessage = err instanceof Error ? err.message : String(err);
+      this.fail(task.id, errorMessage);
+    }
+
+    return task;
+  }
+
+  // ── Phase 12: Graceful shutdown ──────────────────────────────────────────
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout?: number): Promise<ShutdownSummary> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.shutdownInitiated = true;
+    this.shutdownPromise = this.performShutdown(timeout ?? 30000);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(timeout: number): Promise<ShutdownSummary> {
+    const startTime = Date.now();
+    let completed = 0;
+    let cancelled = 0;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Collect all processing tasks
+    const processingTasks: Task[] = [];
+    for (const queue of this.queues.values()) {
+      for (const task of queue.tasks.values()) {
+        if (task.status === 'processing') {
+          processingTasks.push(task);
+        }
+      }
+    }
+
+    if (processingTasks.length > 0) {
+      // Wait for them with timeout
+      const waitForCompletion = (): Promise<void> => {
+        return new Promise((resolve) => {
+          const checkInterval = setInterval(() => {
+            const stillProcessing = processingTasks.filter((t) => t.status === 'processing');
+            if (stillProcessing.length === 0) {
+              clearInterval(checkInterval);
+              resolve();
+            }
+          }, 10);
+
+          setTimeout(() => {
+            clearInterval(checkInterval);
+            resolve();
+          }, timeout);
+        });
+      };
+
+      await waitForCompletion();
+
+      // Force-cancel any remaining processing tasks
+      for (const task of processingTasks) {
+        if (task.status === 'processing') {
+          task.status = 'cancelled';
+          task.updatedAt = new Date();
+          cancelled++;
+        } else if (task.status === 'completed') {
+          completed++;
+        }
+      }
+    }
+
+    const duration = Date.now() - startTime;
+
+    return { completed, cancelled, duration };
+  }
+
+  // ── Utility: Get task by ID ──────────────────────────────────────────────
+
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  get isShutdown(): boolean {
+    return this.shutdownInitiated;
+  }
+}
