@@ -0,0 +1,138 @@
+import { randomUUID } from 'node:crypto';
+
+// ── Task Status ──────────────────────────────────────────────────────────────
+
+export type TaskStatus =
+  | 'pending'
+  | 'processing'
+  | 'completed'
+  | 'failed'
+  | 'cancelled'
+  | 'blocked';
+
+// ── Task ─────────────────────────────────────────────────────────────────────
+
+export interface Task<T = unknown> {
+  id: string;
+  status: TaskStatus;
+  payload: T;
+  priority: number;
+  createdAt: Date;
+  updatedAt: Date;
+
+  // Phase 4: Delayed tasks
+  availableAt: Date;
+
+  // Phase 5: Retry
+  attempt: number;
+  maxRetries: number;
+  baseDelay: number;
+
+  // Phase 6: DLQ
+  error?: string;
+  failCount: number;
+
+  // Phase 7: Dependencies
+  dependencies: string[];
+
+  // Phase 9: Progress
+  progress: number;
+  progressMessage?: string;
+
+  // Phase 10: Recurring source
+  scheduleId?: string;
+
+  // Queue membership
+  queue: string;
+}
+
+// ── Task creation options ────────────────────────────────────────────────────
+
+export interface AddTaskOptions<T = unknown> {
+  payload: T;
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependencies?: string[];
+  scheduleId?: string;
+}
+
+// ── Create a task from options ───────────────────────────────────────────────
+
+export function createTask<T>(options: AddTaskOptions<T>, queueName: string): Task<T> {
+  const now = new Date();
+  let availableAt = now;
+
+  if (options.availableAt) {
+    availableAt = options.availableAt;
+  } else if (options.delay && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  }
+
+  const hasDependencies = options.dependencies && options.dependencies.length > 0;
+
+  return {
+    id: randomUUID(),
+    status: hasDependencies ? 'blocked' : 'pending',
+    payload: options.payload,
+    priority: options.priority ?? 5,
+    createdAt: now,
+    updatedAt: now,
+    availableAt,
+    attempt: 0,
+    maxRetries: options.maxRetries ?? 3,
+    baseDelay: options.baseDelay ?? 1000,
+    failCount: 0,
+    dependencies: options.dependencies ? [...options.dependencies] : [],
+    progress: 0,
+    queue: queueName,
+    scheduleId: options.scheduleId,
+  };
+}
+
+// ── Progress listener ────────────────────────────────────────────────────────
+
+export type ProgressListener = (progress: number, message?: string) => void;
+
+// ── Middleware ────────────────────────────────────────────────────────────────
+
+export type MiddlewareNext = () => void | Promise<void>;
+export type Middleware = (task: Task, next: MiddlewareNext) => void | Promise<void>;
+export type TaskHandler = (task: Task) => void | Promise<void>;
+
+// ── Schedule ─────────────────────────────────────────────────────────────────
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  lastRun?: Date;
+  priority?: number;
+}
+
+export function createSchedule(
+  cronExpression: string,
+  queue: string,
+  payload: unknown,
+  priority?: number,
+): Schedule {
+  return {
+    id: randomUUID(),
+    cronExpression,
+    queue,
+    payload,
+    priority,
+  };
+}
+
+// ── Shutdown summary ─────────────────────────────────────────────────────────
+
+export interface ShutdownSummary {
+  completed: number;
+  cancelled: number;
+  duration: number;
+}
