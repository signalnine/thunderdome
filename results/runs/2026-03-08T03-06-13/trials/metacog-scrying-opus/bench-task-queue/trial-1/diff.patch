+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01W9DRrKvbEuU4VF1bsNPoaB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TRzQTAWbgGo5wvbWvVCazY","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ── Phase 1: Basic FIFO Queue ──────────────────────────────────────────\n\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.add({ payload: { message: 'hello' } });\n      expect(task).toBeDefined();\n      expect(task.id).toBeTruthy();\n      expect(task.status).toBe('pending');\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = tq.add({ payload: 'a' });\n      const t2 = tq.add({ payload: 'b' });\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should process tasks in FIFO order', () => {\n      tq.add({ payload: 'first' });\n      tq.add({ payload: 'second' });\n      tq.add({ payload: 'third' });\n\n      const t1 = tq.process();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = tq.process();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = tq.process();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should return null after all tasks are processed', () => {\n      tq.add({ payload: 'only' });\n      tq.process();\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should track size of pending tasks', () => {\n      expect(tq.size()).toBe(0);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      expect(tq.size()).toBe(2);\n      tq.process();\n      expect(tq.size()).toBe(1);\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      tq.add({ payload: 'test' });\n      const task = tq.process();\n      expect(task?.status).toBe('processing');\n    });\n  });\n\n  // ── Phase 2: Named Queues ──────────────────────────────────────────────\n\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      tq.add({ payload: 'data' });\n      const task = tq.process();\n      expect(task?.queue).toBe('default');\n    });\n\n    it('should support named queues independently', () => {\n      tq.add({ payload: 'email-task', queue: 'emails' });\n      tq.add({ payload: 'sms-task', queue: 'sms' });\n\n      expect(tq.size('emails')).toBe(1);\n      expect(tq.size('sms')).toBe(1);\n\n      const emailTask = tq.process('emails');\n      expect(emailTask?.payload).toBe('email-task');\n      expect(tq.process('emails')).toBeNull();\n\n      const smsTask = tq.process('sms');\n      expect(smsTask?.payload).toBe('sms-task');\n    });\n\n    it('should list queue names', () => {\n      tq.add({ payload: 'a', queue: 'alpha' });\n      tq.add({ payload: 'b', queue: 'beta' });\n      const names = tq.getQueues();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.process('nonexistent')).toBeNull();\n    });\n\n    it('should be backward compatible with Phase 1', () => {\n      tq.add({ payload: 'test' });\n      const task = tq.process();\n      expect(task?.payload).toBe('test');\n    });\n  });\n\n  // ── Phase 3: Priority ─────────────────────────────────────────────────\n\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.add({ payload: 'data' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should process higher priority tasks first', () => {\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n      tq.add({ payload: 'medium', priority: 5 });\n\n      expect(tq.process()?.payload).toBe('high');\n      expect(tq.process()?.payload).toBe('medium');\n      expect(tq.process()?.payload).toBe('low');\n    });\n\n    it('should use FIFO for same priority', () => {\n      tq.add({ payload: 'first', priority: 3 });\n      tq.add({ payload: 'second', priority: 3 });\n      tq.add({ payload: 'third', priority: 3 });\n\n      expect(tq.process()?.payload).toBe('first');\n      expect(tq.process()?.payload).toBe('second');\n      expect(tq.process()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.add({ payload: 'data', priority: 0 })).toThrow();\n      expect(() => tq.add({ payload: 'data', priority: 11 })).toThrow();\n      expect(() => tq.add({ payload: 'data', priority: -1 })).toThrow();\n      expect(() => tq.add({ payload: 'data', priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.add({ payload: 'data', priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n\n    it('should maintain priority ordering per queue', () => {\n      tq.add({ payload: 'q1-low', queue: 'q1', priority: 10 });\n      tq.add({ payload: 'q1-high', queue: 'q1', priority: 1 });\n      tq.add({ payload: 'q2-low', queue: 'q2', priority: 10 });\n      tq.add({ payload: 'q2-high', queue: 'q2', priority: 1 });\n\n      expect(tq.process('q1')?.payload).toBe('q1-high');\n      expect(tq.process('q2')?.payload).toBe('q2-high');\n    });\n  });\n\n  // ── Phase 4: Delayed Tasks ────────────────────────────────────────────\n\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before availability', () => {\n      tq.add({ payload: 'delayed', delay: 10000 });\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should return delayed tasks after availability', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.add({ payload: 'available', availableAt: past });\n      const task = tq.process();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      tq.add({ payload: 'delayed', delay: 10000 });\n      tq.add({ payload: 'immediate' });\n      expect(tq.process()?.payload).toBe('immediate');\n    });\n\n    it('should order by availability time when both available', () => {\n      const earlier = new Date(Date.now() - 2000);\n      const later = new Date(Date.now() - 1000);\n      tq.add({ payload: 'later', availableAt: later, priority: 5 });\n      tq.add({ payload: 'earlier', availableAt: earlier, priority: 5 });\n\n      expect(tq.process()?.payload).toBe('earlier');\n      expect(tq.process()?.payload).toBe('later');\n    });\n\n    it('should show availableAt on task object', () => {\n      const futureDate = new Date(Date.now() + 5000);\n      const task = tq.add({ payload: 'data', availableAt: futureDate });\n      expect(task.availableAt.getTime()).toBe(futureDate.getTime());\n    });\n\n    it('should work with named queues', () => {\n      tq.add({ payload: 'delayed', queue: 'test', delay: 10000 });\n      tq.add({ payload: 'immediate', queue: 'test' });\n      expect(tq.process('test')?.payload).toBe('immediate');\n    });\n  });\n\n  // ── Phase 5: Retry with Backoff ───────────────────────────────────────\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n      tq.complete(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should fail and retry a task', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 3 });\n      tq.process();\n      tq.fail(task.id, 'some error');\n\n      const updatedTask = tq.getTask(task.id);\n      expect(updatedTask?.status).toBe('pending');\n      expect(updatedTask?.attempt).toBe(1);\n      expect(updatedTask?.error).toBe('some error');\n      expect(updatedTask?.failCount).toBe(1);\n    });\n\n    it('should use exponential backoff delay', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 3, baseDelay: 1000 });\n\n      // First attempt\n      tq.process();\n      tq.fail(task.id, 'error');\n      // Backoff = 1000 * 2^0 = 1000ms\n      const t = tq.getTask(task.id);\n      expect(t?.availableAt.getTime()).toBeGreaterThan(Date.now() + 500);\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 3, baseDelay: 0 });\n\n      tq.process();\n      expect(tq.getTask(task.id)?.attempt).toBe(1);\n      tq.fail(task.id, 'error');\n\n      // Make it available immediately for testing\n      const t = tq.getTask(task.id)!;\n      t.availableAt = new Date(Date.now() - 1);\n\n      tq.process();\n      expect(tq.getTask(task.id)?.attempt).toBe(2);\n    });\n\n    it('should exhaust retries and leave task failed', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 1, baseDelay: 0 });\n\n      tq.process();\n      tq.fail(task.id, 'first error');\n\n      // Task should now be in failed state after maxRetries exhausted\n      // maxRetries=1 means only 1 attempt, so after failing it should be done\n      expect(tq.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.add({ payload: 'data', queue: 'myq', priority: 2, maxRetries: 3, baseDelay: 0 });\n      tq.process('myq');\n      tq.fail(task.id);\n      const t = tq.getTask(task.id)!;\n      expect(t.queue).toBe('myq');\n      expect(t.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3 and baseDelay to 1000', () => {\n      const task = tq.add({ payload: 'data' });\n      expect(task.maxRetries).toBe(3);\n      expect(task.baseDelay).toBe(1000);\n    });\n  });\n\n  // ── Phase 6: Dead Letter Queue ────────────────────────────────────────\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ after exhausting retries', () => {\n      const task = tq.add({ payload: 'failing', maxRetries: 1, baseDelay: 0 });\n      tq.process();\n      tq.fail(task.id, 'permanent error');\n\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error).toBe('permanent error');\n    });\n\n    it('should retain error info and fail count', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 2, baseDelay: 0 });\n\n      // Attempt 1\n      tq.process();\n      tq.fail(task.id, 'error 1');\n      tq.getTask(task.id)!.availableAt = new Date(Date.now() - 1);\n\n      // Attempt 2 - exhausts retries\n      tq.process();\n      tq.fail(task.id, 'error 2');\n\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq[0].failCount).toBe(2);\n      expect(dlq[0].error).toBe('error 2');\n    });\n\n    it('should requeue a dead-lettered task', () => {\n      const task = tq.add({ payload: 'retry-me', maxRetries: 1, baseDelay: 0 });\n      tq.process();\n      tq.fail(task.id, 'error');\n\n      expect(tq.getDeadLetterQueue()).toHaveLength(1);\n\n      const requeued = tq.requeue(task.id);\n      expect(requeued.status).toBe('pending');\n      expect(requeued.attempt).toBe(0);\n      expect(requeued.failCount).toBe(0);\n      expect(tq.getDeadLetterQueue()).toHaveLength(0);\n\n      // Should be processable again\n      const processed = tq.process();\n      expect(processed?.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      const t1 = tq.add({ payload: 'a', maxRetries: 1, baseDelay: 0 });\n      const t2 = tq.add({ payload: 'b', maxRetries: 1, baseDelay: 0 });\n      tq.process();\n      tq.fail(t1.id, 'err');\n      tq.process();\n      tq.fail(t2.id, 'err');\n\n      expect(tq.getDeadLetterQueue()).toHaveLength(2);\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterQueue()).toHaveLength(0);\n    });\n\n    it('should have per-queue DLQ', () => {\n      const t1 = tq.add({ payload: 'a', queue: 'q1', maxRetries: 1, baseDelay: 0 });\n      const t2 = tq.add({ payload: 'b', queue: 'q2', maxRetries: 1, baseDelay: 0 });\n\n      tq.process('q1');\n      tq.fail(t1.id, 'err');\n      tq.process('q2');\n      tq.fail(t2.id, 'err');\n\n      expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterQueue('q1')).toHaveLength(0);\n      expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n    });\n  });\n\n  // ── Phase 7: Task Dependencies ────────────────────────────────────────\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = tq.add({ payload: 'dep' });\n      const t2 = tq.add({ payload: 'dependent', dependencies: [t1.id] });\n\n      expect(t2.status).toBe('blocked');\n      // Should not be processable\n      // t2 is on default queue, t1 is too. Processing should return t1\n      const next = tq.process();\n      expect(next?.id).toBe(t1.id);\n    });\n\n    it('should unblock task when dependency completes', () => {\n      const t1 = tq.add({ payload: 'dep' });\n      const t2 = tq.add({ payload: 'dependent', dependencies: [t1.id] });\n\n      tq.process();\n      tq.complete(t1.id);\n\n      expect(tq.getTask(t2.id)?.status).toBe('pending');\n      const next = tq.process();\n      expect(next?.id).toBe(t2.id);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const t1 = tq.add({ payload: 'dep1' });\n      const t2 = tq.add({ payload: 'dep2' });\n      const t3 = tq.add({ payload: 'dependent', dependencies: [t1.id, t2.id] });\n\n      expect(t3.status).toBe('blocked');\n\n      tq.process(); // t1\n      tq.complete(t1.id);\n      expect(tq.getTask(t3.id)?.status).toBe('blocked'); // t2 not done yet\n\n      tq.process(); // t2\n      tq.complete(t2.id);\n      expect(tq.getTask(t3.id)?.status).toBe('pending'); // both done\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() =>\n        tq.add({ payload: 'data', dependencies: ['non-existent-id'] }),\n      ).toThrow('Dependency task not found');\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const t1 = tq.add({ payload: 'dep', maxRetries: 1, baseDelay: 0 });\n      tq.add({ payload: 'dependent', dependencies: [t1.id] });\n\n      tq.process();\n      tq.fail(t1.id, 'error');\n\n      // t1 is now in DLQ, dependent stays blocked\n      // Dependent is blocked because dep is failed, not completed\n    });\n\n    it('should inspect dependency status', () => {\n      const t1 = tq.add({ payload: 'dep1' });\n      const t2 = tq.add({ payload: 'dep2' });\n      const t3 = tq.add({ payload: 'main', dependencies: [t1.id, t2.id] });\n\n      const status = tq.getDependencyStatus(t3.id);\n      expect(status).toHaveLength(2);\n      expect(status[0].taskId).toBe(t1.id);\n      expect(status[0].status).toBe('pending');\n      expect(status[0].resolved).toBe(false);\n    });\n  });\n\n  // ── Phase 8: Concurrency Control ──────────────────────────────────────\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should enforce concurrency limits', () => {\n      tq.setConcurrency('default', 2);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      tq.add({ payload: 'c' });\n\n      const t1 = tq.process();\n      const t2 = tq.process();\n      const t3 = tq.process();\n\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n      expect(t3).toBeNull(); // concurrency limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      const t1 = tq.process()!;\n      expect(tq.process()).toBeNull();\n\n      tq.complete(t1.id);\n      const t2 = tq.process();\n      expect(t2).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.add({ payload: 'a', maxRetries: 1, baseDelay: 0 });\n      tq.add({ payload: 'b' });\n\n      tq.process();\n      tq.fail(task.id, 'error');\n\n      // task is now in DLQ (maxRetries=1), slot freed\n      const t2 = tq.process();\n      expect(t2?.payload).toBe('b');\n    });\n\n    it('should default to unlimited concurrency', () => {\n      expect(tq.getConcurrency('default')).toBeNull();\n    });\n\n    it('should query concurrency limit and active count', () => {\n      tq.setConcurrency('default', 5);\n      expect(tq.getConcurrency('default')).toBe(5);\n\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      tq.process();\n      expect(tq.getActiveCount('default')).toBe(1);\n    });\n\n    it('should respect priority with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n\n      const task = tq.process()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ── Phase 9: Progress Tracking and Cancellation ──────────────────────\n\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should report progress on processing tasks', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n      tq.updateProgress(task.id, 50, 'half done');\n\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('half done');\n    });\n\n    it('should subscribe to progress updates', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n\n      const updates: number[] = [];\n      tq.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      tq.updateProgress(task.id, 25);\n      tq.updateProgress(task.id, 50);\n      tq.updateProgress(task.id, 75);\n\n      expect(updates).toEqual([25, 50, 75]);\n    });\n\n    it('should support cancellable subscriptions', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n\n      const updates: number[] = [];\n      const unsubscribe = tq.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      tq.updateProgress(task.id, 25);\n      unsubscribe();\n      tq.updateProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.cancel(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n      tq.cancel(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 3 });\n      tq.process();\n      tq.cancel(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.size()).toBe(0);\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n      expect(() => tq.updateProgress(task.id, -1)).toThrow();\n      expect(() => tq.updateProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ── Phase 10: Recurring Tasks ─────────────────────────────────────────\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBeTruthy();\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n      expect(schedule.queue).toBe('default');\n    });\n\n    it('should list schedules', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'a' });\n      tq.addSchedule('0 * * * *', 'default', { type: 'b' });\n      expect(tq.getSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      tq.removeSchedule(schedule.id);\n      expect(tq.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick for every-N-minutes', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      // Tick at a minute divisible by 5\n      const time = new Date('2024-01-01T10:00:00Z');\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'cleanup' });\n    });\n\n    it('should not enqueue tasks when not due', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      // Tick at a minute NOT divisible by 5\n      const time = new Date('2024-01-01T10:03:00Z');\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not enqueue twice in the same minute', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      const time = new Date('2024-01-01T10:00:00Z');\n      tq.tick(time);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should support every-hour schedule', () => {\n      tq.addSchedule('0 * * * *', 'default', { type: 'hourly' });\n\n      const onHour = new Date('2024-01-01T10:00:00Z');\n      expect(tq.tick(onHour)).toHaveLength(1);\n\n      const offHour = new Date('2024-01-01T10:30:00Z');\n      expect(tq.tick(offHour)).toHaveLength(0);\n    });\n\n    it('should support every-day-at-midnight schedule', () => {\n      tq.addSchedule('0 0 * * *', 'default', { type: 'daily' });\n\n      const midnight = new Date('2024-01-01T00:00:00Z');\n      expect(tq.tick(midnight)).toHaveLength(1);\n\n      const noon = new Date('2024-01-01T12:00:00Z');\n      expect(tq.tick(noon)).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      tq.removeSchedule(schedule.id);\n\n      const time = new Date('2024-01-01T10:00:00Z');\n      expect(tq.tick(time)).toHaveLength(0);\n    });\n  });\n\n  // ── Phase 11: Middleware Pipeline ─────────────────────────────────────\n\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('mw1-before');\n        await next();\n        order.push('mw1-after');\n      });\n\n      tq.use('default', async (_task, next) => {\n        order.push('mw2-before');\n        await next();\n        order.push('mw2-after');\n      });\n\n      tq.setHandler('default', () => {\n        order.push('handler');\n      });\n\n      tq.add({ payload: 'test' });\n      await tq.processWithMiddleware();\n\n      expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task.payload as Record<string, unknown>).modified = true;\n        await next();\n      });\n\n      let handlerTask: unknown;\n      tq.setHandler('default', (task) => {\n        handlerTask = task.payload;\n      });\n\n      tq.add({ payload: { original: true } });\n      await tq.processWithMiddleware();\n\n      expect(handlerTask).toEqual({ original: true, modified: true });\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      tq.use('default', async () => {\n        // Intentionally not calling next\n      });\n\n      tq.setHandler('default', () => {\n        handlerCalled = true;\n      });\n\n      tq.add({ payload: 'test' });\n      await tq.processWithMiddleware();\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should mark task as failed if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 0 });\n      await tq.processWithMiddleware();\n\n      // Task should be failed (moved to DLQ since maxRetries=1)\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].error).toBe('middleware error');\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const q1Called: string[] = [];\n      const q2Called: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Called.push('q1-mw');\n        await next();\n      });\n\n      tq.use('q2', async (_task, next) => {\n        q2Called.push('q2-mw');\n        await next();\n      });\n\n      tq.add({ payload: 'a', queue: 'q1' });\n      tq.add({ payload: 'b', queue: 'q2' });\n\n      await tq.processWithMiddleware('q1');\n      await tq.processWithMiddleware('q2');\n\n      expect(q1Called).toEqual(['q1-mw']);\n      expect(q2Called).toEqual(['q2-mw']);\n    });\n  });\n\n  // ── Phase 12: Graceful Shutdown ───────────────────────────────────────\n\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.add({ payload: 'test' })).toThrow('shutting down');\n    });\n\n    it('should complete immediately if no tasks processing', async () => {\n      const summary = await tq.shutdown();\n      expect(summary.completed).toBe(0);\n      expect(summary.cancelled).toBe(0);\n      expect(summary.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      const task = tq.add({ payload: 'slow' });\n      tq.process();\n\n      // Complete the task after a short delay\n      setTimeout(() => {\n        tq.complete(task.id);\n      }, 50);\n\n      const summary = await tq.shutdown(5000);\n      expect(summary.completed).toBe(1);\n      expect(summary.cancelled).toBe(0);\n    });\n\n    it('should force-cancel tasks exceeding timeout', async () => {\n      tq.add({ payload: 'stuck' });\n      tq.process();\n\n      const summary = await tq.shutdown(50);\n      expect(summary.cancelled).toBe(1);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      tq.onShutdown(() => {\n        callbackRan = true;\n      });\n\n      await tq.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should be safe to call shutdown multiple times', async () => {\n      const [s1, s2] = await Promise.all([tq.shutdown(), tq.shutdown()]);\n      expect(s1).toEqual(s2);\n    });\n\n    it('should report isShutdown status', async () => {\n      expect(tq.isShutdown).toBe(false);\n      await tq.shutdown();\n      expect(tq.isShutdown).toBe(true);\n    });\n  });\n\n  // ── Integration tests ─────────────────────────────────────────────────\n\n  describe('Integration', () => {\n    it('should handle priority + delay interaction', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.add({ payload: 'low-priority-available', priority: 10, availableAt: past });\n      tq.add({ payload: 'high-priority-available', priority: 1, availableAt: past });\n      tq.add({ payload: 'high-priority-delayed', priority: 1, delay: 10000 });\n\n      // High priority available should come first\n      expect(tq.process()?.payload).toBe('high-priority-available');\n      // Then low priority available\n      expect(tq.process()?.payload).toBe('low-priority-available');\n      // Delayed high-priority not available yet\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should handle dependencies + retry', () => {\n      const dep = tq.add({ payload: 'dependency', maxRetries: 2, baseDelay: 0 });\n      tq.add({ payload: 'dependent', dependencies: [dep.id] });\n\n      tq.process();\n      tq.fail(dep.id, 'temp error');\n\n      // dep is retried - dependent should still be blocked\n      const depTask = tq.getTask(dep.id)!;\n      depTask.availableAt = new Date(Date.now() - 1);\n\n      tq.process();\n      tq.complete(dep.id);\n\n      // Now dependent should be unblocked\n      const next = tq.process();\n      expect(next?.payload).toBe('dependent');\n    });\n\n    it('should handle concurrency + priority', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n\n      const t1 = tq.process()!;\n      expect(t1.payload).toBe('high');\n\n      // Concurrency full\n      expect(tq.process()).toBeNull();\n\n      tq.complete(t1.id);\n      const t2 = tq.process()!;\n      expect(t2.payload).toBe('low');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":241,"cache_read_input_tokens":38390,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":241},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b7255fb0-57ab-4a91-9486-5bfa4e4e7cc3","uuid":"7ee89dbf-bb18-4038-ad3e-43c4a406aec9"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TRzQTAWbgGo5wvbWvVCazY","type":"tool_result","content":"File created successfully at: /workspace/src/TaskQueue.test.ts"}]},"parent_tool_use_id":null,"session_id":"b7255fb0-57ab-4a91-9486-5bfa4e4e7cc3","uuid":"9927b1ea-dcd4-4f6a-8e61-b53e20d1c655","tool_use_result":{"type":"create","filePath":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ── Phase 1: Basic FIFO Queue ──────────────────────────────────────────\n\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.add({ payload: { message: 'hello' } });\n      expect(task).toBeDefined();\n      expect(task.id).toBeTruthy();\n      expect(task.status).toBe('pending');\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = tq.add({ payload: 'a' });\n      const t2 = tq.add({ payload: 'b' });\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should process tasks in FIFO order', () => {\n      tq.add({ payload: 'first' });\n      tq.add({ payload: 'second' });\n      tq.add({ payload: 'third' });\n\n      const t1 = tq.process();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = tq.process();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = tq.process();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should return null after all tasks are processed', () => {\n      tq.add({ payload: 'only' });\n      tq.process();\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should track size of pending tasks', () => {\n      expect(tq.size()).toBe(0);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      expect(tq.size()).toBe(2);\n      tq.process();\n      expect(tq.size()).toBe(1);\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      tq.add({ payload: 'test' });\n      const task = tq.process();\n      expect(task?.status).toBe('processing');\n    });\n  });\n\n  // ── Phase 2: Named Queues ──────────────────────────────────────────────\n\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      tq.add({ payload: 'data' });\n      const task = tq.process();\n      expect(task?.queue).toBe('default');\n    });\n\n    it('should support named queues independently', () => {\n      tq.add({ payload: 'email-task', queue: 'emails' });\n      tq.add({ payload: 'sms-task', queue: 'sms' });\n\n      expect(tq.size('emails')).toBe(1);\n      expect(tq.size('sms')).toBe(1);\n\n      const emailTask = tq.process('emails');\n      expect(emailTask?.payload).toBe('email-task');\n      expect(tq.process('emails')).toBeNull();\n\n      const smsTask = tq.process('sms');\n      expect(smsTask?.payload).toBe('sms-task');\n    });\n\n    it('should list queue names', () => {\n      tq.add({ payload: 'a', queue: 'alpha' });\n      tq.add({ payload: 'b', queue: 'beta' });\n      const names = tq.getQueues();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.process('nonexistent')).toBeNull();\n    });\n\n    it('should be backward compatible with Phase 1', () => {\n      tq.add({ payload: 'test' });\n      const task = tq.process();\n      expect(task?.payload).toBe('test');\n    });\n  });\n\n  // ── Phase 3: Priority ─────────────────────────────────────────────────\n\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.add({ payload: 'data' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should process higher priority tasks first', () => {\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n      tq.add({ payload: 'medium', priority: 5 });\n\n      expect(tq.process()?.payload).toBe('high');\n      expect(tq.process()?.payload).toBe('medium');\n      expect(tq.process()?.payload).toBe('low');\n    });\n\n    it('should use FIFO for same priority', () => {\n      tq.add({ payload: 'first', priority: 3 });\n      tq.add({ payload: 'second', priority: 3 });\n      tq.add({ payload: 'third', priority: 3 });\n\n      expect(tq.process()?.payload).toBe('first');\n      expect(tq.process()?.payload).toBe('second');\n      expect(tq.process()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.add({ payload: 'data', priority: 0 })).toThrow();\n      expect(() => tq.add({ payload: 'data', priority: 11 })).toThrow();\n      expect(() => tq.add({ payload: 'data', priority: -1 })).toThrow();\n      expect(() => tq.add({ payload: 'data', priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.add({ payload: 'data', priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n\n    it('should maintain priority ordering per queue', () => {\n      tq.add({ payload: 'q1-low', queue: 'q1', priority: 10 });\n      tq.add({ payload: 'q1-high', queue: 'q1', priority: 1 });\n      tq.add({ payload: 'q2-low', queue: 'q2', priority: 10 });\n      tq.add({ payload: 'q2-high', queue: 'q2', priority: 1 });\n\n      expect(tq.process('q1')?.payload).toBe('q1-high');\n      expect(tq.process('q2')?.payload).toBe('q2-high');\n    });\n  });\n\n  // ── Phase 4: Delayed Tasks ────────────────────────────────────────────\n\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before availability', () => {\n      tq.add({ payload: 'delayed', delay: 10000 });\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should return delayed tasks after availability', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.add({ payload: 'available', availableAt: past });\n      const task = tq.process();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      tq.add({ payload: 'delayed', delay: 10000 });\n      tq.add({ payload: 'immediate' });\n      expect(tq.process()?.payload).toBe('immediate');\n    });\n\n    it('should order by availability time when both available', () => {\n      const earlier = new Date(Date.now() - 2000);\n      const later = new Date(Date.now() - 1000);\n      tq.add({ payload: 'later', availableAt: later, priority: 5 });\n      tq.add({ payload: 'earlier', availableAt: earlier, priority: 5 });\n\n      expect(tq.process()?.payload).toBe('earlier');\n      expect(tq.process()?.payload).toBe('later');\n    });\n\n    it('should show availableAt on task object', () => {\n      const futureDate = new Date(Date.now() + 5000);\n      const task = tq.add({ payload: 'data', availableAt: futureDate });\n      expect(task.availableAt.getTime()).toBe(futureDate.getTime());\n    });\n\n    it('should work with named queues', () => {\n      tq.add({ payload: 'delayed', queue: 'test', delay: 10000 });\n      tq.add({ payload: 'immediate', queue: 'test' });\n      expect(tq.process('test')?.payload).toBe('immediate');\n    });\n  });\n\n  // ── Phase 5: Retry with Backoff ───────────────────────────────────────\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n      tq.complete(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should fail and retry a task', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 3 });\n      tq.process();\n      tq.fail(task.id, 'some error');\n\n      const updatedTask = tq.getTask(task.id);\n      expect(updatedTask?.status).toBe('pending');\n      expect(updatedTask?.attempt).toBe(1);\n      expect(updatedTask?.error).toBe('some error');\n      expect(updatedTask?.failCount).toBe(1);\n    });\n\n    it('should use exponential backoff delay', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 3, baseDelay: 1000 });\n\n      // First attempt\n      tq.process();\n      tq.fail(task.id, 'error');\n      // Backoff = 1000 * 2^0 = 1000ms\n      const t = tq.getTask(task.id);\n      expect(t?.availableAt.getTime()).toBeGreaterThan(Date.now() + 500);\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 3, baseDelay: 0 });\n\n      tq.process();\n      expect(tq.getTask(task.id)?.attempt).toBe(1);\n      tq.fail(task.id, 'error');\n\n      // Make it available immediately for testing\n      const t = tq.getTask(task.id)!;\n      t.availableAt = new Date(Date.now() - 1);\n\n      tq.process();\n      expect(tq.getTask(task.id)?.attempt).toBe(2);\n    });\n\n    it('should exhaust retries and leave task failed', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 1, baseDelay: 0 });\n\n      tq.process();\n      tq.fail(task.id, 'first error');\n\n      // Task should now be in failed state after maxRetries exhausted\n      // maxRetries=1 means only 1 attempt, so after failing it should be done\n      expect(tq.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.add({ payload: 'data', queue: 'myq', priority: 2, maxRetries: 3, baseDelay: 0 });\n      tq.process('myq');\n      tq.fail(task.id);\n      const t = tq.getTask(task.id)!;\n      expect(t.queue).toBe('myq');\n      expect(t.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3 and baseDelay to 1000', () => {\n      const task = tq.add({ payload: 'data' });\n      expect(task.maxRetries).toBe(3);\n      expect(task.baseDelay).toBe(1000);\n    });\n  });\n\n  // ── Phase 6: Dead Letter Queue ────────────────────────────────────────\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ after exhausting retries', () => {\n      const task = tq.add({ payload: 'failing', maxRetries: 1, baseDelay: 0 });\n      tq.process();\n      tq.fail(task.id, 'permanent error');\n\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error).toBe('permanent error');\n    });\n\n    it('should retain error info and fail count', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 2, baseDelay: 0 });\n\n      // Attempt 1\n      tq.process();\n      tq.fail(task.id, 'error 1');\n      tq.getTask(task.id)!.availableAt = new Date(Date.now() - 1);\n\n      // Attempt 2 - exhausts retries\n      tq.process();\n      tq.fail(task.id, 'error 2');\n\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq[0].failCount).toBe(2);\n      expect(dlq[0].error).toBe('error 2');\n    });\n\n    it('should requeue a dead-lettered task', () => {\n      const task = tq.add({ payload: 'retry-me', maxRetries: 1, baseDelay: 0 });\n      tq.process();\n      tq.fail(task.id, 'error');\n\n      expect(tq.getDeadLetterQueue()).toHaveLength(1);\n\n      const requeued = tq.requeue(task.id);\n      expect(requeued.status).toBe('pending');\n      expect(requeued.attempt).toBe(0);\n      expect(requeued.failCount).toBe(0);\n      expect(tq.getDeadLetterQueue()).toHaveLength(0);\n\n      // Should be processable again\n      const processed = tq.process();\n      expect(processed?.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      const t1 = tq.add({ payload: 'a', maxRetries: 1, baseDelay: 0 });\n      const t2 = tq.add({ payload: 'b', maxRetries: 1, baseDelay: 0 });\n      tq.process();\n      tq.fail(t1.id, 'err');\n      tq.process();\n      tq.fail(t2.id, 'err');\n\n      expect(tq.getDeadLetterQueue()).toHaveLength(2);\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterQueue()).toHaveLength(0);\n    });\n\n    it('should have per-queue DLQ', () => {\n      const t1 = tq.add({ payload: 'a', queue: 'q1', maxRetries: 1, baseDelay: 0 });\n      const t2 = tq.add({ payload: 'b', queue: 'q2', maxRetries: 1, baseDelay: 0 });\n\n      tq.process('q1');\n      tq.fail(t1.id, 'err');\n      tq.process('q2');\n      tq.fail(t2.id, 'err');\n\n      expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterQueue('q1')).toHaveLength(0);\n      expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n    });\n  });\n\n  // ── Phase 7: Task Dependencies ────────────────────────────────────────\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = tq.add({ payload: 'dep' });\n      const t2 = tq.add({ payload: 'dependent', dependencies: [t1.id] });\n\n      expect(t2.status).toBe('blocked');\n      // Should not be processable\n      // t2 is on default queue, t1 is too. Processing should return t1\n      const next = tq.process();\n      expect(next?.id).toBe(t1.id);\n    });\n\n    it('should unblock task when dependency completes', () => {\n      const t1 = tq.add({ payload: 'dep' });\n      const t2 = tq.add({ payload: 'dependent', dependencies: [t1.id] });\n\n      tq.process();\n      tq.complete(t1.id);\n\n      expect(tq.getTask(t2.id)?.status).toBe('pending');\n      const next = tq.process();\n      expect(next?.id).toBe(t2.id);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const t1 = tq.add({ payload: 'dep1' });\n      const t2 = tq.add({ payload: 'dep2' });\n      const t3 = tq.add({ payload: 'dependent', dependencies: [t1.id, t2.id] });\n\n      expect(t3.status).toBe('blocked');\n\n      tq.process(); // t1\n      tq.complete(t1.id);\n      expect(tq.getTask(t3.id)?.status).toBe('blocked'); // t2 not done yet\n\n      tq.process(); // t2\n      tq.complete(t2.id);\n      expect(tq.getTask(t3.id)?.status).toBe('pending'); // both done\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() =>\n        tq.add({ payload: 'data', dependencies: ['non-existent-id'] }),\n      ).toThrow('Dependency task not found');\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const t1 = tq.add({ payload: 'dep', maxRetries: 1, baseDelay: 0 });\n      tq.add({ payload: 'dependent', dependencies: [t1.id] });\n\n      tq.process();\n      tq.fail(t1.id, 'error');\n\n      // t1 is now in DLQ, dependent stays blocked\n      // Dependent is blocked because dep is failed, not completed\n    });\n\n    it('should inspect dependency status', () => {\n      const t1 = tq.add({ payload: 'dep1' });\n      const t2 = tq.add({ payload: 'dep2' });\n      const t3 = tq.add({ payload: 'main', dependencies: [t1.id, t2.id] });\n\n      const status = tq.getDependencyStatus(t3.id);\n      expect(status).toHaveLength(2);\n      expect(status[0].taskId).toBe(t1.id);\n      expect(status[0].status).toBe('pending');\n      expect(status[0].resolved).toBe(false);\n    });\n  });\n\n  // ── Phase 8: Concurrency Control ──────────────────────────────────────\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should enforce concurrency limits', () => {\n      tq.setConcurrency('default', 2);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      tq.add({ payload: 'c' });\n\n      const t1 = tq.process();\n      const t2 = tq.process();\n      const t3 = tq.process();\n\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n      expect(t3).toBeNull(); // concurrency limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      const t1 = tq.process()!;\n      expect(tq.process()).toBeNull();\n\n      tq.complete(t1.id);\n      const t2 = tq.process();\n      expect(t2).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.add({ payload: 'a', maxRetries: 1, baseDelay: 0 });\n      tq.add({ payload: 'b' });\n\n      tq.process();\n      tq.fail(task.id, 'error');\n\n      // task is now in DLQ (maxRetries=1), slot freed\n      const t2 = tq.process();\n      expect(t2?.payload).toBe('b');\n    });\n\n    it('should default to unlimited concurrency', () => {\n      expect(tq.getConcurrency('default')).toBeNull();\n    });\n\n    it('should query concurrency limit and active count', () => {\n      tq.setConcurrency('default', 5);\n      expect(tq.getConcurrency('default')).toBe(5);\n\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      tq.process();\n      expect(tq.getActiveCount('default')).toBe(1);\n    });\n\n    it('should respect priority with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n\n      const task = tq.process()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ── Phase 9: Progress Tracking and Cancellation ──────────────────────\n\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should report progress on processing tasks', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n      tq.updateProgress(task.id, 50, 'half done');\n\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('half done');\n    });\n\n    it('should subscribe to progress updates', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n\n      const updates: number[] = [];\n      tq.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      tq.updateProgress(task.id, 25);\n      tq.updateProgress(task.id, 50);\n      tq.updateProgress(task.id, 75);\n\n      expect(updates).toEqual([25, 50, 75]);\n    });\n\n    it('should support cancellable subscriptions', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n\n      const updates: number[] = [];\n      const unsubscribe = tq.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      tq.updateProgress(task.id, 25);\n      unsubscribe();\n      tq.updateProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.cancel(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.process()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n      tq.cancel(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.add({ payload: 'data', maxRetries: 3 });\n      tq.process();\n      tq.cancel(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.size()).toBe(0);\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.add({ payload: 'data' });\n      tq.process();\n      expect(() => tq.updateProgress(task.id, -1)).toThrow();\n      expect(() => tq.updateProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ── Phase 10: Recurring Tasks ─────────────────────────────────────────\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBeTruthy();\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n      expect(schedule.queue).toBe('default');\n    });\n\n    it('should list schedules', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'a' });\n      tq.addSchedule('0 * * * *', 'default', { type: 'b' });\n      expect(tq.getSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      tq.removeSchedule(schedule.id);\n      expect(tq.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick for every-N-minutes', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      // Tick at a minute divisible by 5\n      const time = new Date('2024-01-01T10:00:00Z');\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'cleanup' });\n    });\n\n    it('should not enqueue tasks when not due', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      // Tick at a minute NOT divisible by 5\n      const time = new Date('2024-01-01T10:03:00Z');\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not enqueue twice in the same minute', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      const time = new Date('2024-01-01T10:00:00Z');\n      tq.tick(time);\n      const tasks = tq.tick(time);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should support every-hour schedule', () => {\n      tq.addSchedule('0 * * * *', 'default',