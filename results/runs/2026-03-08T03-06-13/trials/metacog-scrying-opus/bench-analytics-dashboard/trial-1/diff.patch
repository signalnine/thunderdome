@@ -0,0 +1,158 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { authenticate } from "../middleware.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let query = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: string[] = [tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        query += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`);
+        params.push(String(value));
+      }
+    }
+
+    const result = db.prepare(query).get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    if (!startDate || !endDate) {
+      res.status(400).json({ error: "startDate and endDate are required" });
+      return;
+    }
+
+    // Determine the strftime format based on interval
+    let dateFormat: string;
+    const granularity = interval || "day";
+    switch (granularity) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "day":
+        dateFormat = "%Y-%m-%d";
+        break;
+      case "week":
+        dateFormat = "%Y-W%W";
+        break;
+      case "month":
+        dateFormat = "%Y-%m";
+        break;
+      default:
+        dateFormat = "%Y-%m-%d";
+    }
+
+    let query = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: string[] = [tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    query += " AND timestamp >= ? AND timestamp <= ?";
+    params.push(startDate, endDate);
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        query += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`);
+        params.push(String(value));
+      }
+    }
+
+    query += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const results = db.prepare(query).all(...params) as Array<{
+      bucket: string;
+      count: number;
+    }>;
+
+    res.json({
+      interval: granularity,
+      data: results.map((r) => ({
+        date: r.bucket,
+        count: r.count,
+      })),
+    });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, property, startDate, endDate, filters, limit: limitStr } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let query = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: string[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      query += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        query += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`);
+        params.push(String(value));
+      }
+    }
+
+    query += " GROUP BY value ORDER BY count DESC";
+
+    const limit = parseInt(limitStr as string) || 50;
+    query += " LIMIT ?";
+
+    const results = db.prepare(query).all(...params, String(limit)) as Array<{
+      value: string | null;
+      count: number;
+    }>;
+
+    res.json({
+      property,
+      data: results.map((r) => ({
+        value: r.value,
+        count: r.count,
+      })),
+    });
+  });
+
+  return router;
+}
