+++ b/src/ot.ts
@@ -0,0 +1,250 @@
+/**
+ * Operational Transformation (OT) engine for collaborative editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string at current position
+ * - number < 0: delete |N| characters
+ *
+ * The sum of retain + delete lengths must equal the document length before applying.
+ * The sum of retain + insert lengths equals the document length after applying.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  clientId: string;
+  version: number;
+  operation: Operation;
+}
+
+export interface SyncMessage {
+  type: 'sync';
+  docId: string;
+  content: string;
+  version: number;
+}
+
+export interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export type ServerMessage = SyncMessage | OperationMessage | AckMessage | ErrorMessage;
+
+/**
+ * Get the input length of an operation (document length before applying).
+ */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      else len += Math.abs(c);
+    }
+  }
+  return len;
+}
+
+/**
+ * Get the output length of an operation (document length after applying).
+ */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+    } else {
+      len += c.length;
+    }
+  }
+  return len;
+}
+
+/**
+ * Apply an operation to a document string.
+ */
+export function apply(doc: string, op: Operation): string {
+  const inLen = inputLength(op);
+  if (inLen !== doc.length) {
+    throw new Error(`Operation input length (${inLen}) doesn't match document length (${doc.length})`);
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === 'string') {
+      result += c;
+    } else if (c > 0) {
+      result += doc.slice(pos, pos + c);
+      pos += c;
+    } else {
+      pos += Math.abs(c);
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Normalize an operation by merging adjacent components of the same type
+ * and removing no-ops.
+ */
+export function normalize(op: Operation): Operation {
+  const result: Operation = [];
+
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+
+    if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+    } else if (typeof c === 'number' && typeof last === 'number') {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else {
+      result.push(c);
+    }
+  }
+
+  return result;
+}
+
+interface FlatOp {
+  type: 'retain' | 'insert' | 'delete';
+  char: string;
+}
+
+function flatten(op: Operation): FlatOp[] {
+  const result: FlatOp[] = [];
+  for (const c of op) {
+    if (typeof c === 'string') {
+      for (const ch of c) {
+        result.push({ type: 'insert', char: ch });
+      }
+    } else if (c > 0) {
+      for (let i = 0; i < c; i++) {
+        result.push({ type: 'retain', char: '' });
+      }
+    } else if (c < 0) {
+      for (let i = 0; i < Math.abs(c); i++) {
+        result.push({ type: 'delete', char: '' });
+      }
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ *
+ * Given operations A and B that were both based on the same document state,
+ * returns [A', B'] such that:
+ * - apply(apply(doc, A), B') === apply(apply(doc, B), A')
+ *
+ * Uses a flattened character-by-character approach for correctness.
+ * A has priority when both insert at the same position.
+ */
+export function transformOps(opA: Operation, opB: Operation): [Operation, Operation] {
+  const inLenA = inputLength(opA);
+  const inLenB = inputLength(opB);
+  if (inLenA !== inLenB) {
+    throw new Error(`Transform: operations have different input lengths (${inLenA} vs ${inLenB})`);
+  }
+
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  const flatA = flatten(opA);
+  const flatB = flatten(opB);
+
+  let idxA = 0;
+  let idxB = 0;
+
+  while (idxA < flatA.length || idxB < flatB.length) {
+    const a = idxA < flatA.length ? flatA[idxA] : null;
+    const b = idxB < flatB.length ? flatB[idxB] : null;
+
+    if (a === null && b === null) break;
+
+    // A inserts - A has priority
+    if (a !== null && a.type === 'insert') {
+      aPrime.push(a.char);
+      bPrime.push(1);
+      idxA++;
+      continue;
+    }
+
+    // B inserts
+    if (b !== null && b.type === 'insert') {
+      bPrime.push(b.char);
+      aPrime.push(1);
+      idxB++;
+      continue;
+    }
+
+    if (a === null || b === null) break;
+
+    if (a.type === 'retain' && b.type === 'retain') {
+      aPrime.push(1);
+      bPrime.push(1);
+    } else if (a.type === 'delete' && b.type === 'retain') {
+      aPrime.push(-1);
+    } else if (a.type === 'retain' && b.type === 'delete') {
+      bPrime.push(-1);
+    }
+    // both delete same char: no output needed
+
+    idxA++;
+    idxB++;
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/**
+ * Validate an operation against a document length.
+ */
+export function validateOperation(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) {
+    return 'Operation must be an array';
+  }
+
+  for (const c of op) {
+    if (typeof c !== 'number' && typeof c !== 'string') {
+      return `Invalid operation component: ${JSON.stringify(c)}`;
+    }
+    if (typeof c === 'number' && c === 0) {
+      return 'Operation contains zero-length component';
+    }
+    if (typeof c === 'string' && c === '') {
+      return 'Operation contains empty string insert';
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) doesn't match document length (${docLength})`;
+  }
+
+  return null;
+}
