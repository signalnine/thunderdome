@@ -0,0 +1,55 @@
+import express from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import { createDatabase, DocumentStore } from './database.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './websocket.js';
+import Database from 'better-sqlite3';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db: Database.Database = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(store);
+  app.use('/api', router);
+
+  const server: HttpServer = createServer(app);
+  const collab = new CollaborationServer(server, store);
+
+  let listening = false;
+
+  return {
+    app,
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        server.listen(port ?? 0, () => {
+          listening = true;
+          const addr = server.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : 0;
+          resolve(actualPort);
+        });
+      });
+    },
+    async stop(): Promise<void> {
+      collab.closeAll();
+      if (listening) {
+        await new Promise<void>((resolve, reject) => {
+          server.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+        listening = false;
+      }
+      db.close();
+    },
+  };
+}
