n  Operation,\n  ServerMessage,\n} from './ot.js';\nimport { randomUUID } from 'crypto';\n\ninterface ClientConnection {\n  id: string;\n  ws: WebSocket;\n  docId: string;\n}\n\ninterface DocumentSession {\n  docId: string;\n  clients: Map<string, ClientConnection>;\n  // History of operations applied since version 1\n  // operationLog[i] is the operation that transformed version i+1 to i+2\n  operationLog: Operation[];\n  currentVersion: number;\n  currentContent: string;\n}\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private sessions: Map<string, DocumentSession> = new Map();\n  private store: DocumentStore;\n\n  constructor(server: HttpServer, store: DocumentStore) {\n    this.store = store;\n    this.wss = new WebSocketServer({ server, path: undefined });\n\n    // Handle upgrade manually to support path-based routing\n    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n      const url = request.url || '';\n      const match = url.match(/^\\/documents\\/([^/]+)\\/ws$/);\n      if (!match) {\n        socket.destroy();\n        return;\n      }\n\n      const docId = match[1];\n      const doc = this.store.getDocument(docId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request, docId);\n      });\n    });\n\n    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, docId: string) => {\n      this.handleConnection(ws, docId);\n    });\n  }\n\n  private getOrCreateSession(docId: string): DocumentSession {\n    let session = this.sessions.get(docId);\n    if (!session) {\n      const doc = this.store.getDocument(docId);\n      if (!doc) {\n        throw new Error(`Document ${docId} not found`);\n      }\n      const version = this.store.getLatestVersion(docId);\n      session = {\n        docId,\n        clients: new Map(),\n        operationLog: [],\n        currentVersion: version,\n        currentContent: doc.content,\n      };\n      this.sessions.set(docId, session);\n    }\n    return session;\n  }\n\n  private handleConnection(ws: WebSocket, docId: string): void {\n    const session = this.getOrCreateSession(docId);\n    const clientId = randomUUID();\n    const client: ClientConnection = { id: clientId, ws, docId };\n\n    session.clients.set(clientId, client);\n\n    // Send sync message with current state\n    const syncMsg: ServerMessage = {\n      type: 'sync',\n      docId,\n      content: session.currentContent,\n      version: session.currentVersion,\n    };\n    ws.send(JSON.stringify(syncMsg));\n\n    ws.on('message', (data) => {\n      try {\n        const raw = data.toString();\n        const msg = JSON.parse(raw);\n\n        if (msg.type === 'operation') {\n          this.handleOperation(session, client, msg);\n        } else {\n          this.sendError(ws, `Unknown message type: ${msg.type}`);\n        }\n      } catch (e) {\n        this.sendError(ws, `Invalid message: ${(e as Error).message}`);\n      }\n    });\n\n    ws.on('close', () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        // Keep session alive for a while in case clients reconnect\n        // but clean up if needed\n      }\n    });\n\n    ws.on('error', () => {\n      session.clients.delete(clientId);\n    });\n  }\n\n  private handleOperation(\n    session: DocumentSession,\n    client: ClientConnection,\n    msg: { version: number; operation: Operation; clientId?: string }\n  ): void {\n    const { version, operation } = msg;\n\n    // Validate version\n    if (typeof version !== 'number' || version < 0) {\n      this.sendError(client.ws, 'Invalid version number');\n      return;\n    }\n\n    if (version > session.currentVersion) {\n      this.sendError(client.ws, `Version ${version} is ahead of server version ${session.currentVersion}`);\n      return;\n    }\n\n    // Validate operation against document length at the specified version\n    // We need to compute the document content at that version\n    let docLenAtVersion: number;\n    if (version === session.currentVersion) {\n      docLenAtVersion = session.currentContent.length;\n    } else {\n      // Compute document length at the given version by looking at operation history\n      // Start from current and work backwards, or compute forward from initial\n      const doc = this.store.getDocument(session.docId);\n      if (!doc) {\n        this.sendError(client.ws, 'Document not found');\n        return;\n      }\n      // Get the content at the specified version from version history\n      const versions = this.store.getVersions(session.docId);\n      const versionRecord = versions.find(v => v.version === version);\n      if (versionRecord) {\n        docLenAtVersion = versionRecord.content.length;\n      } else {\n        docLenAtVersion = session.currentContent.length;\n      }\n    }\n\n    const validationError = validateOperation(operation, docLenAtVersion);\n    if (validationError) {\n      this.sendError(client.ws, validationError);\n      return;\n    }\n\n    // Transform the operation against all operations that happened since the client's version\n    let transformedOp = operation;\n    const opsToTransformAgainst = session.operationLog.slice(version - 1);\n\n    for (const serverOp of opsToTransformAgainst) {\n      try {\n        const [clientPrime] = transformOps(transformedOp, serverOp);\n        transformedOp = clientPrime;\n      } catch (e) {\n        this.sendError(client.ws, `Transform error: ${(e as Error).message}`);\n        return;\n      }\n    }\n\n    // Apply the transformed operation to the current document\n    try {\n      session.currentContent = apply(session.currentContent, transformedOp);\n    } catch (e) {\n      this.sendError(client.ws, `Apply error: ${(e as Error).message}`);\n      return;\n    }\n\n    session.currentVersion++;\n    session.operationLog.push(transformedOp);\n\n    // Persist\n    this.store.updateDocumentContent(session.docId, session.currentContent);\n    this.store.addVersion(\n      session.docId,\n      session.currentVersion,\n      session.currentContent,\n      JSON.stringify(transformedOp)\n    );\n\n    // Ack the sender\n    const ackMsg: ServerMessage = {\n      type: 'ack',\n      version: session.currentVersion,\n    };\n    client.ws.send(JSON.stringify(ackMsg));\n\n    // Broadcast to all other clients\n    const broadcastMsg: ServerMessage = {\n      type: 'operation',\n      docId: session.docId,\n      clientId: client.id,\n      version: session.currentVersion,\n      operation: transformedOp,\n    };\n\n    for (const [id, c] of session.clients) {\n      if (id !== client.id && c.ws.readyState === WebSocket.OPEN) {\n        c.ws.send(JSON.stringify(broadcastMsg));\n      }\n    }\n  }\n\n  private sendError(ws: WebSocket, message: string): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      const errMsg: ServerMessage = { type: 'error', message };\n      ws.send(JSON.stringify(errMsg));\n    }\n  }\n\n  closeAll(): void {\n    for (const session of this.sessions.values()) {\n      for (const client of session.clients.values()) {\n        client.ws.close();\n      }\n    }\n    this.sessions.clear();\n    this.wss.close();\n  }\n}\n","numLines":251,"startLine":1,"totalLines":251}}}
