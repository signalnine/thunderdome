+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { createApp, AppInstance } from './server.js';
+import WebSocket from 'ws';
+
+let app: AppInstance;
+let port: number;
+let baseUrl: string;
+
+beforeEach(async () => {
+  app = createApp();
+  port = await app.start(0);
+  baseUrl = `http://localhost:${port}`;
+});
+
+afterEach(async () => {
+  await app.stop();
+});
+
+async function createDoc(title: string, content: string = ''): Promise<{ id: string; title: string; content: string }> {
+  const res = await fetch(`${baseUrl}/api/documents`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ title, content }),
+  });
+  return res.json();
+}
+
+interface WsClient {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  waitForMessage: (predicate?: (msg: Record<string, unknown>) => boolean) => Promise<Record<string, unknown>>;
+  close: () => void;
+}
+
+function connectWs(docId: string): Promise<WsClient> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);
+    const messages: Record<string, unknown>[] = [];
+    const waiters: Array<{
+      predicate: (msg: Record<string, unknown>) => boolean;
+      resolve: (msg: Record<string, unknown>) => void;
+    }> = [];
+
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      messages.push(msg);
+
+      // Check if any waiter matches
+      for (let i = 0; i < waiters.length; i++) {
+        if (waiters[i].predicate(msg)) {
+          const waiter = waiters.splice(i, 1)[0];
+          waiter.resolve(msg);
+          break;
+        }
+      }
+    });
+
+    ws.on('open', () => {
+      resolve({
+        ws,
+        messages,
+        waitForMessage(predicate?: (msg: Record<string, unknown>) => boolean) {
+          const pred = predicate || (() => true);
+          // Check existing messages first
+          for (let i = 0; i < messages.length; i++) {
+            if (pred(messages[i])) {
+              const msg = messages.splice(i, 1)[0];
+              return Promise.resolve(msg);
+            }
+          }
+          // Wait for new message
+          return new Promise<Record<string, unknown>>((res) => {
+            waiters.push({ predicate: pred, resolve: res });
+          });
+        },
+        close() {
+          ws.close();
+        },
+      });
+    });
+
+    ws.on('error', reject);
+  });
+}
+
+describe('REST API', () => {
+  it('should create a document', async () => {
+    const doc = await createDoc('Test Doc', 'Hello');
+    expect(doc.id).toBeDefined();
+    expect(doc.title).toBe('Test Doc');
+    expect(doc.content).toBe('Hello');
+  });
+
+  it('should list documents', async () => {
+    await createDoc('Doc 1');
+    await createDoc('Doc 2');
+
+    const res = await fetch(`${baseUrl}/api/documents`);
+    const docs = await res.json();
+    expect(docs.length).toBe(2);
+  });
+
+  it('should get a specific document', async () => {
+    const doc = await createDoc('Test', 'content');
+
+    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+    const fetched = await res.json();
+    expect(fetched.title).toBe('Test');
+    expect(fetched.content).toBe('content');
+  });
+
+  it('should return 404 for nonexistent document', async () => {
+    const res = await fetch(`${baseUrl}/api/documents/nonexistent`);
+    expect(res.status).toBe(404);
+  });
+
+  it('should update a document', async () => {
+    const doc = await createDoc('Test', 'old content');
+
+    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`, {
+      method: 'PUT',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ title: 'Updated', content: 'new content' }),
+    });
+    const updated = await res.json();
+    expect(updated.title).toBe('Updated');
+    expect(updated.content).toBe('new content');
+  });
+
+  it('should delete a document', async () => {
+    const doc = await createDoc('Test');
+
+    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`, {
+      method: 'DELETE',
+    });
+    expect(res.status).toBe(204);
+
+    const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+    expect(getRes.status).toBe(404);
+  });
+
+  it('should get version history', async () => {
+    const doc = await createDoc('Test', 'initial');
+
+    const res = await fetch(`${baseUrl}/api/documents/${doc.id}/versions`);
+    const versions = await res.json();
+    expect(versions.length).toBeGreaterThanOrEqual(1);
+    expect(versions[0].content).toBe('initial');
+  });
+
+  it('should reject document creation without title', async () => {
+    const res = await fetch(`${baseUrl}/api/documents`, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({}),
+    });
+    expect(res.status).toBe(400);
+  });
+});
+
+describe('WebSocket Collaboration', () => {
+  it('should send sync message on connect', async () => {
+    const doc = await createDoc('Test', 'hello');
+    const client = await connectWs(doc.id);
+    const msg = await client.waitForMessage((m) => m.type === 'sync');
+
+    expect(msg.type).toBe('sync');
+    expect(msg.content).toBe('hello');
+    expect(msg.version).toBe(1);
+
+    client.close();
+  });
+
+  it('should handle an insert operation', async () => {
+    const doc = await createDoc('Test', 'hello');
+    const client = await connectWs(doc.id);
+    const sync = await client.waitForMessage((m) => m.type === 'sync');
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      docId: doc.id,
+      version: sync.version,
+      operation: [5, ' world'],
+    }));
+
+    const ack = await client.waitForMessage((m) => m.type === 'ack');
+    expect(ack.type).toBe('ack');
+    expect(ack.version).toBe(2);
+
+    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+    expect(updated.content).toBe('hello world');
+
+    client.close();
+  });
+
+  it('should broadcast operations to other clients', async () => {
+    const doc = await createDoc('Test', 'hello');
+
+    const client1 = await connectWs(doc.id);
+    const sync1 = await client1.waitForMessage((m) => m.type === 'sync');
+
+    const client2 = await connectWs(doc.id);
+    await client2.waitForMessage((m) => m.type === 'sync');
+
+    client1.ws.send(JSON.stringify({
+      type: 'operation',
+      docId: doc.id,
+      version: sync1.version,
+      operation: [5, ' world'],
+    }));
+
+    const ack = await client1.waitForMessage((m) => m.type === 'ack');
+    expect(ack.type).toBe('ack');
+
+    const broadcast = await client2.waitForMessage((m) => m.type === 'operation');
+    expect(broadcast.type).toBe('operation');
+    expect(broadcast.operation).toBeDefined();
+
+    client1.close();
+    client2.close();
+  });
+
+  it('should handle concurrent edits from multiple clients', async () => {
+    const doc = await createDoc('Test', 'abcde');
+
+    const client1 = await connectWs(doc.id);
+    const sync1 = await client1.waitForMessage((m) => m.type === 'sync');
+
+    const client2 = await connectWs(doc.id);
+    const sync2 = await client2.waitForMessage((m) => m.type === 'sync');
+
+    expect(sync1.version).toBe(sync2.version);
+
+    // Both clients insert at different positions concurrently
+    client1.ws.send(JSON.stringify({
+      type: 'operation',
+      docId: doc.id,
+      version: sync1.version,
+      operation: [1, 'X', 4],
+    }));
+
+    client2.ws.send(JSON.stringify({
+      type: 'operation',
+      docId: doc.id,
+      version: sync2.version,
+      operation: [3, 'Y', 2],
+    }));
+
+    // Wait for both acks
+    await client1.waitForMessage((m) => m.type === 'ack');
+    await client2.waitForMessage((m) => m.type === 'ack');
+
+    // Verify document state via REST
+    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+
+    expect(updated.content).toContain('X');
+    expect(updated.content).toContain('Y');
+    expect(updated.content).toContain('a');
+    expect(updated.content).toContain('b');
+    expect(updated.content).toContain('c');
+    expect(updated.content).toContain('d');
+    expect(updated.content).toContain('e');
+
+    client1.close();
+    client2.close();
+  });
+
+  it('should handle 10 concurrent clients', async () => {
+    const doc = await createDoc('Test', 'start');
+    const clients: WsClient[] = [];
+
+    // Connect 10 clients
+    for (let i = 0; i < 10; i++) {
+      const client = await connectWs(doc.id);
+      await client.waitForMessage((m) => m.type === 'sync');
+      clients.push(client);
+    }
+
+    // Each client inserts a character at the end, all based on same version
+    for (let i = 0; i < 10; i++) {
+      clients[i].ws.send(JSON.stringify({
+        type: 'operation',
+        docId: doc.id,
+        version: 1,
+        operation: [5, String(i)],
+      }));
+    }
+
+    // Wait for all acks
+    for (let i = 0; i < 10; i++) {
+      await clients[i].waitForMessage((m) => m.type === 'ack');
+    }
+
+    // Verify document via REST
+    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+
+    for (let i = 0; i < 10; i++) {
+      expect(updated.content).toContain(String(i));
+    }
+    expect(updated.content).toContain('start');
+
+    for (const client of clients) {
+      client.close();
+    }
+  });
+
+  it('should reject invalid operations', async () => {
+    const doc = await createDoc('Test', 'hello');
+    const client = await connectWs(doc.id);
+    await client.waitForMessage((m) => m.type === 'sync');
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      docId: doc.id,
+      version: 1,
+      operation: [10, 'x'],
+    }));
+
+    const msg = await client.waitForMessage((m) => m.type === 'error');
+    expect(msg.type).toBe('error');
+
+    client.close();
+  });
+
+  it('should reject malformed messages', async () => {
+    const doc = await createDoc('Test', 'hello');
+    const client = await connectWs(doc.id);
+    await client.waitForMessage((m) => m.type === 'sync');
+
+    client.ws.send('not json at all {{{');
+    const msg = await client.waitForMessage((m) => m.type === 'error');
+    expect(msg.type).toBe('error');
+
+    client.close();
+  });
+
+  it('should handle delete operations', async () => {
+    const doc = await createDoc('Test', 'hello world');
+    const client = await connectWs(doc.id);
+    const sync = await client.waitForMessage((m) => m.type === 'sync');
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      docId: doc.id,
+      version: sync.version,
+      operation: [5, -6],
+    }));
+
+    const ack = await client.waitForMessage((m) => m.type === 'ack');
+    expect(ack.type).toBe('ack');
+
+    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+    const updated = await res.json();
+    expect(updated.content).toBe('hello');
+
+    client.close();
+  });
+
+  it('should persist versions across operations', async () => {
+    const doc = await createDoc('Test', 'hello');
+    const client = await connectWs(doc.id);
+    await client.waitForMessage((m) => m.type === 'sync');
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      docId: doc.id,
+      version: 1,
+      operation: [5, ' world'],
+    }));
+
+    const ack1 = await client.waitForMessage((m) => m.type === 'ack');
+    expect(ack1.type).toBe('ack');
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      docId: doc.id,
+      version: ack1.version,
+      operation: [11, '!'],
+    }));
+
+    const ack2 = await client.waitForMessage((m) => m.type === 'ack');
+    expect(ack2.type).toBe('ack');
+
+    const versionsRes = await fetch(`${baseUrl}/api/documents/${doc.id}/versions`);
+    const versions = await versionsRes.json();
+    expect(versions.length).toBe(3);
+
+    client.close();
+  });
+});
+
+describe('Persistence', () => {
+  it('should persist documents across restarts', async () => {
+    const tmpDb = '/tmp/test-collab-' + Date.now() + '.db';
+
+    const app1 = createApp(tmpDb);
+    const port1 = await app1.start(0);
+
+    const res1 = await fetch(`http://localhost:${port1}/api/documents`, {
