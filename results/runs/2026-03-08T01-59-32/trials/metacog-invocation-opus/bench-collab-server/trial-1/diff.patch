new file mode 100644
index 0000000..82ab5b3
--- /dev/null
+++ b/src/database.ts
@@ -0,0 +1,121 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join, dirname } from 'path';
+import { fileURLToPath } from 'url';
+import { randomUUID } from 'crypto';
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = dirname(__filename);
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  const schemaPath = join(__dirname, '..', 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version
+    const versionStmt = this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    );
+    versionStmt.run(id, 1, content, null);
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    const stmt = this.db.prepare('SELECT * FROM documents WHERE id = ?');
+    return stmt.get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    const stmt = this.db.prepare(
+      "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+    );
+    stmt.run(title, content, id);
+
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const stmt = this.db.prepare('DELETE FROM documents WHERE id = ?');
+    const result = stmt.run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(documentId: string): Version[] {
+    const stmt = this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    );
+    return stmt.all(documentId) as Version[];
+  }
+
+  getLatestVersion(documentId: string): number {
+    const stmt = this.db.prepare(
+      'SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?'
+    );
+    const row = stmt.get(documentId) as { max_version: number };
+    return row.max_version;
+  }
+
+  addVersion(documentId: string, version: number, content: string, operation: string | null): void {
+    const stmt = this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    );
+    stmt.run(documentId, version, content, operation);
+  }
+
+  updateDocumentContent(id: string, content: string): void {
+    const stmt = this.db.prepare(
+      "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+    );
+    stmt.run(content, id);
+  }
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..4986dab
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,193 @@
+import { describe, it, expect } from 'vitest';
+import { apply, transformOps, normalize, inputLength, outputLength, validateOperation } from './ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply insert at beginning', () => {
+      expect(apply('hello', ['world ', 5])).toBe('world hello');
+    });
+
+    it('should apply insert at end', () => {
+      expect(apply('hello', [5, ' world'])).toBe('hello world');
+    });
+
+    it('should apply insert in middle', () => {
+      expect(apply('hllo', [1, 'e', 3])).toBe('hello');
+    });
+
+    it('should apply delete', () => {
+      expect(apply('hello world', [5, -6])).toBe('hello');
+    });
+
+    it('should apply retain only (identity)', () => {
+      expect(apply('hello', [5])).toBe('hello');
+    });
+
+    it('should apply to empty document', () => {
+      expect(apply('', ['hello'])).toBe('hello');
+    });
+
+    it('should handle delete at beginning', () => {
+      expect(apply('hello world', [-6, 5])).toBe('world');
+    });
+
+    it('should throw on length mismatch', () => {
+      expect(() => apply('hello', [3])).toThrow();
+    });
+  });
+
+  describe('normalize', () => {
+    it('should merge adjacent retains', () => {
+      expect(normalize([2, 3])).toEqual([5]);
+    });
+
+    it('should merge adjacent inserts', () => {
+      expect(normalize(['he', 'llo'])).toEqual(['hello']);
+    });
+
+    it('should merge adjacent deletes', () => {
+      expect(normalize([-2, -3])).toEqual([-5]);
+    });
+
+    it('should not merge different types', () => {
+      expect(normalize([2, 'a', 3])).toEqual([2, 'a', 3]);
+    });
+
+    it('should remove zero-length components', () => {
+      expect(normalize([0, 'a', 0])).toEqual(['a']);
+    });
+  });
+
+  describe('inputLength / outputLength', () => {
+    it('should compute input length', () => {
+      expect(inputLength([3, 'abc', -2])).toBe(5); // retain 3 + delete 2
+    });
+
+    it('should compute output length', () => {
+      expect(outputLength([3, 'abc', -2])).toBe(6); // retain 3 + insert 3
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should return null for valid operation', () => {
+      expect(validateOperation([3, 'a', -2], 5)).toBeNull();
+    });
+
+    it('should reject wrong input length', () => {
+      expect(validateOperation([3], 5)).not.toBeNull();
+    });
+
+    it('should reject non-array', () => {
+      expect(validateOperation('foo' as unknown as number[], 3)).not.toBeNull();
+    });
+  });
+
+  describe('transformOps', () => {
+    it('should transform two inserts at different positions', () => {
+      // Doc: "abc" (length 3)
+      // A inserts "X" at position 1: [1, "X", 2]
+      // B inserts "Y" at position 2: [2, "Y", 1]
+      const opA = [1, 'X', 2] as const;
+      const opB = [2, 'Y', 1] as const;
+
+      const [aPrime, bPrime] = transformOps([...opA], [...opB]);
+
+      // Apply A then B'
+      const afterA = apply('abc', [...opA]);
+      const afterAB = apply(afterA, bPrime);
+
+      // Apply B then A'
+      const afterB = apply('abc', [...opB]);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toContain('X');
+      expect(afterAB).toContain('Y');
+    });
+
+    it('should transform two inserts at same position', () => {
+      // Doc: "ab" (length 2)
+      // Both insert at position 1
+      const opA = [1, 'X', 1];
+      const opB = [1, 'Y', 1];
+
+      const [aPrime, bPrime] = transformOps(opA, opB);
+
+      const afterA = apply('ab', opA);
+      const afterAB = apply(afterA, bPrime);
+
+      const afterB = apply('ab', opB);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toContain('X');
+      expect(afterAB).toContain('Y');
+    });
+
+    it('should transform insert vs delete', () => {
+      // Doc: "abcde" (length 5)
+      // A inserts "X" at position 2: [2, "X", 3]
+      // B deletes char at position 3: [3, -1, 1]
+      const opA = [2, 'X', 3];
+      const opB = [3, -1, 1];
+
+      const [aPrime, bPrime] = transformOps(opA, opB);
+
+      const afterA = apply('abcde', opA);
+      const afterAB = apply(afterA, bPrime);
+
+      const afterB = apply('abcde', opB);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toContain('X');
+      expect(afterAB).not.toContain('d');
+    });
+
+    it('should transform two deletes at same position', () => {
+      // Doc: "abcde" (length 5)
+      // Both delete char at position 2 (char 'c')
+      const opA = [2, -1, 2];
+      const opB = [2, -1, 2];
+
+      const [aPrime, bPrime] = transformOps(opA, opB);
+
+      const afterA = apply('abcde', opA);
+      const afterAB = apply(afterA, bPrime);
+
+      const afterB = apply('abcde', opB);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toBe('abde');
+    });
+
+    it('should handle identity transforms', () => {
+      const opA = [5]; // retain all
+      const opB = [5]; // retain all
+
+      const [aPrime, bPrime] = transformOps(opA, opB);
+
+      expect(apply('hello', aPrime)).toBe('hello');
+      expect(apply('hello', bPrime)).toBe('hello');
+    });
+
+    it('should handle concurrent inserts at beginning', () => {
+      // Doc: "" (empty)
+      const opA = ['hello'];
+      const opB = ['world'];
+
+      const [aPrime, bPrime] = transformOps(opA, opB);
+
+      const afterA = apply('', opA);
+      const afterAB = apply(afterA, bPrime);
+
+      const afterB = apply('', opB);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toContain('hello');
+      expect(afterAB).toContain('world');
+    });
+  });
+});
