seUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n\n    // All digits 0-9 should be present\n    for (let i = 0; i < 10; i++) {\n      expect(updated.content).toContain(String(i));\n    }\n    expect(updated.content).toContain('start');\n\n    // Clean up\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it('should reject invalid operations', async () => {\n    const doc = await createDoc('Test', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    // Send operation with wrong length\n    ws.send(JSON.stringify({\n      type: 'operation',\n      docId: doc.id,\n      version: 1,\n      operation: [10, 'x'], // 10 retain but doc is only 5 chars\n    }));\n\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject malformed messages', async () => {\n    const doc = await createDoc('Test', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send('not json at all {{{');\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle delete operations', async () => {\n    const doc = await createDoc('Test', 'hello world');\n    const ws = await connectWs(doc.id);\n    const sync = await waitForMessage(ws);\n\n    // Delete \" world\" (chars 5-10)\n    ws.send(JSON.stringify({\n      type: 'operation',\n      docId: doc.id,\n      version: sync.version,\n      operation: [5, -6],\n    }));\n\n    const ack = await waitForMessage(ws);\n    expect(ack.type).toBe('ack');\n\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content).toBe('hello');\n\n    ws.close();\n  });\n\n  it('should persist versions across operations', async () => {\n    const doc = await createDoc('Test', 'hello');\n    const ws = await connectWs(doc.id);\n    const sync = await waitForMessage(ws);\n\n    // First edit\n    ws.send(JSON.stringify({\n      type: 'operation',\n      docId: doc.id,\n      version: sync.version,\n      operation: [5, ' world'],\n    }));\n\n    const ack1 = await waitForMessage(ws);\n    expect(ack1.type).toBe('ack');\n\n    // Second edit based on new version\n    ws.send(JSON.stringify({\n      type: 'operation',\n      docId: doc.id,\n      version: ack1.version,\n      operation: [11, '!'],\n    }));\n\n    const ack2 = await waitForMessage(ws);\n    expect(ack2.type).toBe('ack');\n\n    // Check versions\n    const versionsRes = await fetch(`${baseUrl}/api/documents/${doc.id}/versions`);\n    const versions = await versionsRes.json();\n    expect(versions.length).toBe(3); // initial + 2 edits\n\n    ws.close();\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across restarts', async () => {\n    const tmpDb = '/tmp/test-collab-' + Date.now() + '.db';\n\n    // Create first instance\n    const app1 = createApp(tmpDb);\n    const port1 = await app1.start(0);\n\n    const res1 = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persistent Doc', content: 'saved data' }),\n    });\n    const doc = await res1.json();\n\n    await app1.stop();\n\n    // Create second instance with same db\n    const app2 = createApp(tmpDb);\n    const port2 = await app2.start(0);\n\n    const res2 = await fetch(`http://localhost:${port2}/api/documents/${doc.id}`);\n    const fetched = await res2.json();\n    expect(fetched.title).toBe('Persistent Doc');\n    expect(fetched.content).toBe('saved data');\n\n    await app2.stop();\n\n    // Clean up\n    const { unlinkSync } = await import('fs');\n    try { unlinkSync(tmpDb); } catch { /* ignore */ }\n  });\n});\n","numLines":413,"startLine":1,"totalLines":413}}}
