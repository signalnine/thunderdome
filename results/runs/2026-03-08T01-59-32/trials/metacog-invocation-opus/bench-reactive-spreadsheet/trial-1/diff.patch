 const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect indirect cycles', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      sheet.set('B1', '=C1');\n      expect(() => sheet.set('C1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should not prevent valid non-circular dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1');\n      sheet.set('C1', '=A1+B1');\n      expect(sheet.get('C1')).toBe(20);\n    });\n\n    it('should not modify state on circular reference error', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      sheet.set('B1', 10);\n      expect(sheet.get('A1')).toBe(10);\n\n      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);\n      // B1 should still be 10\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('complex scenarios', () => {\n    it('should handle the example from the spec', () => {\n      const sheet = new Spreadsheet();\n\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n      expect(sheet.getDisplay('A3')).toBe('30');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(70);\n\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n    });\n\n    it('should handle deeply chained formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', '=A1+1');\n      sheet.set('A3', '=A2+1');\n      sheet.set('A4', '=A3+1');\n      sheet.set('A5', '=A4+1');\n      expect(sheet.get('A5')).toBe(5);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('A2')).toBe(11);\n      expect(sheet.get('A3')).toBe(12);\n      expect(sheet.get('A4')).toBe(13);\n      expect(sheet.get('A5')).toBe(14);\n    });\n\n    it('should handle formulas referencing formulas with SUM', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=SUM(A1:A3)');\n      sheet.set('C1', '=B1*2');\n      expect(sheet.get('C1')).toBe(12);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(15);\n      expect(sheet.get('C1')).toBe(30);\n    });\n\n    it('should handle large column references like Z100', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('Z100', 42);\n      expect(sheet.get('Z100')).toBe(42);\n    });\n\n    it('should handle AA, AB style columns', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 10);\n      sheet.set('AB1', 20);\n      sheet.set('AC1', '=SUM(AA1:AB1)');\n      expect(sheet.get('AC1')).toBe(30);\n    });\n\n    it('should handle nested function calls in IF', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=IF(SUM(A1:A3)>50, MAX(A1:A3), MIN(A1:A3))');\n      expect(sheet.get('B1')).toBe(30);\n    });\n\n    it('should handle changing formula dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 20);\n      sheet.set('C1', '=A1+B1');\n      expect(sheet.get('C1')).toBe(30);\n\n      // Change C1 to only depend on A1\n      sheet.set('C1', '=A1*2');\n      expect(sheet.get('C1')).toBe(20);\n\n      // Changing B1 should not affect C1 anymore\n      sheet.set('B1', 100);\n      expect(sheet.get('C1')).toBe(20);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
