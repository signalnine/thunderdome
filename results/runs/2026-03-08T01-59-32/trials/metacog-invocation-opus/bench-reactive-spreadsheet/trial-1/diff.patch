+      this.consume();
+      return { type: 'string', value: token.value };
+    }
+
+    if (token.type === 'BOOLEAN') {
+      this.consume();
+      return { type: 'boolean', value: token.value === 'true' };
+    }
+
+    if (token.type === 'FUNCTION') {
+      this.consume();
+      this.consume(); // LPAREN
+      const args: ASTNode[] = [];
+      if (this.peek() && this.peek()!.type !== 'RPAREN') {
+        args.push(this.parseFunctionArg());
+        while (this.peek() && this.peek()!.type === 'COMMA') {
+          this.consume();
+          args.push(this.parseFunctionArg());
+        }
+      }
+      this.consume(); // RPAREN
+      return { type: 'function', name: token.value, args };
+    }
+
+    if (token.type === 'RANGE') {
+      this.consume();
+      const [start, end] = token.value.split(':');
+      return { type: 'range', start, end };
+    }
+
+    if (token.type === 'CELL_REF') {
+      this.consume();
+      return { type: 'cell_ref', ref: token.value };
+    }
+
+    if (token.type === 'LPAREN') {
+      this.consume();
+      const expr = this.parseComparison();
+      if (!this.peek() || this.peek()!.type !== 'RPAREN') {
+        throw new Error('Expected closing parenthesis');
+      }
+      this.consume();
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${token.value}`);
+  }
+
+  private parseFunctionArg(): ASTNode {
+    // Inside function args, we allow comparisons (for IF conditions)
+    return this.parseComparison();
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// ── Extract Cell References from AST ─────────────────────────────────
+
+function extractRefs(node: ASTNode): Set<string> {
+  const refs = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'cell_ref':
+        refs.add(n.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(n.start, n.end);
+        for (const c of cells) refs.add(c);
+        break;
+      }
+      case 'binary':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'comparison':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'function':
+        for (const arg of n.args) walk(arg);
+        break;
+      // number, string, boolean have no refs
+    }
+  }
+
+  walk(node);
+  return refs;
+}
+
+// ── Cell Storage ─────────────────────────────────────────────────────
+
+interface CellData {
+  rawValue: string | number | boolean;
+  formula: string | null;       // original formula string (without '=')
+  ast: ASTNode | null;          // parsed AST
+  deps: Set<string>;            // cells this cell depends on
+  computedValue: string | number | boolean | null;
+}
+
+// ── Spreadsheet Engine ───────────────────────────────────────────────
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: cell → set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const cellKey = cell.toUpperCase();
+
+    // Remove old dependency edges
+    const existing = this.cells.get(cellKey);
+    if (existing) {
+      for (const dep of existing.deps) {
+        const depSet = this.dependents.get(dep);
+        if (depSet) {
+          depSet.delete(cellKey);
+        }
+      }
+    }
+
+    let formula: string | null = null;
+    let ast: ASTNode | null = null;
+    let deps = new Set<string>();
+    let computedValue: string | number | boolean | null = null;
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = value.substring(1);
+      ast = parseFormula(formula);
+      deps = extractRefs(ast);
+
+      // Check for circular references before committing
+      this.checkCircular(cellKey, deps);
+
+      // Register new dependency edges
+      for (const dep of deps) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(cellKey);
+      }
+
+      // Store cell data
+      this.cells.set(cellKey, { rawValue: value, formula, ast, deps, computedValue: null });
+
+      // Evaluate
+      computedValue = this.evaluate(ast);
+      this.cells.get(cellKey)!.computedValue = computedValue;
+    } else {
+      // Literal value
+      computedValue = value;
+      this.cells.set(cellKey, { rawValue: value, formula: null, ast: null, deps: new Set(), computedValue });
+    }
+
+    // Propagate to dependents
+    this.propagate(cellKey);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const cellKey = cell.toUpperCase();
+    const data = this.cells.get(cellKey);
+    if (!data) return null;
+    return data.computedValue;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, string | number | boolean | null> {
+    const result = new Map<string, string | number | boolean | null>();
+    for (const [key, data] of this.cells) {
+      result.set(key, data.computedValue);
+    }
+    return result;
+  }
+
+  // ── Circular Reference Detection ────────────────────────────────
+
+  private checkCircular(cellKey: string, newDeps: Set<string>): void {
+    // DFS from each dependency to see if we can reach cellKey
+    const visited = new Set<string>();
+
+    const dfs = (current: string): boolean => {
+      if (current === cellKey) return true;
+      if (visited.has(current)) return false;
+      visited.add(current);
+
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.deps) {
+          if (dfs(dep)) return true;
+        }
+      }
+      return false;
+    };
+
+    for (const dep of newDeps) {
+      if (dep === cellKey) {
+        throw new Error(`Circular reference detected: ${cellKey} references itself`);
+      }
+      visited.clear();
+      if (dfs(dep)) {
+        throw new Error(`Circular reference detected involving ${cellKey}`);
+      }
+    }
+  }
+
+  // ── Reactive Propagation ────────────────────────────────────────
+
+  private propagate(cellKey: string): void {
+    // Get all dependents in topological order and re-evaluate them
+    const order = this.getTopologicalOrder(cellKey);
+    for (const key of order) {
+      const data = this.cells.get(key);
+      if (data && data.ast) {
+        data.computedValue = this.evaluate(data.ast);
+      }
+    }
+  }
+
+  private getTopologicalOrder(startCell: string): string[] {
+    // BFS to find all transitive dependents, then topologically sort them
+    const affected = new Set<string>();
+    const queue: string[] = [startCell];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (!affected.has(dep)) {
+            affected.add(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    // Topological sort using Kahn's algorithm over the affected cells
+    // Build in-degree counts only for affected cells
+    const inDegree = new Map<string, number>();
+    for (const cell of affected) {
+      inDegree.set(cell, 0);
+    }
+
+    for (const cell of affected) {
+      const data = this.cells.get(cell);
+      if (data) {
+        for (const dep of data.deps) {
+          // Only count edges from within the affected set or from the start cell
+          if (affected.has(dep)) {
+            inDegree.set(cell, (inDegree.get(cell) || 0) + 1);
+          }
+        }
+      }
+    }
+
+    const sorted: string[] = [];
+    const ready: string[] = [];
+
+    for (const [cell, degree] of inDegree) {
+      if (degree === 0) ready.push(cell);
+    }
+
+    while (ready.length > 0) {
+      const cell = ready.shift()!;
+      sorted.push(cell);
+      const deps = this.dependents.get(cell);
+      if (deps) {
+        for (const dep of deps) {
+          if (affected.has(dep)) {
+            const newDegree = (inDegree.get(dep) || 0) - 1;
+            inDegree.set(dep, newDegree);
+            if (newDegree === 0) ready.push(dep);
+          }
+        }
+      }
+    }
+
+    return sorted;
+  }
+
+  // ── AST Evaluation ─────────────────────────────────────────────
+
+  private evaluate(node: ASTNode): string | number | boolean {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+
+      case 'cell_ref': {
+        const val = this.get(node.ref);
+        if (val === null) return 0; // empty cells treated as 0 in formulas
+        return val;
+      }
+
+      case 'range':
+        throw new Error('Range can only be used inside functions');
+
+      case 'unary': {
+        const operand = this.evaluate(node.operand);
+        if (node.op === '-') return -(operand as number);
+        return operand;
+      }
+
+      case 'binary': {
+        const left = this.evaluate(node.left);
+        const right = this.evaluate(node.right);
+        const l = left as number;
+        const r = right as number;
+        switch (node.op) {
+          case '+': return l + r;
+          case '-': return l - r;
+          case '*': return l * r;
+          case '/': return l / r;
+          default: throw new Error(`Unknown operator: ${node.op}`);
+        }
+      }
+
+      case 'comparison': {
+        const left = this.evaluate(node.left);
+        const right = this.evaluate(node.right);
+        switch (node.op) {
+          case '>': return (left as number) > (right as number);
+          case '<': return (left as number) < (right as number);
+          case '>=': return (left as number) >= (right as number);
+          case '<=': return (left as number) <= (right as number);
+          case '=': return left === right;
+          case '<>': return left !== right;
+          default: throw new Error(`Unknown comparison: ${node.op}`);
+        }
+      }
+
+      case 'function':
+        return this.evaluateFunction(node.name, node.args);
+
+      default:
+        throw new Error(`Unknown AST node type`);
+    }
+  }
+
+  private resolveRangeValues(args: ASTNode[]): number[] {
+    const values: number[] = [];
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const cellRef of cells) {
+          const val = this.get(cellRef);
+          if (typeof val === 'number') values.push(val);
+        }
+      } else {
+        const val = this.evaluate(arg);
+        if (typeof val === 'number') values.push(val);
+      }
+    }
+    return values;
+  }
+
+  private evaluateFunction(name: string, args: ASTNode[]): string | number | boolean {
+    switch (name) {
+      case 'SUM': {
+        const values = this.resolveRangeValues(args);
+        return values.reduce((a, b) => a + b, 0);
+      }
+
+      case 'AVERAGE': {
+        const values = this.resolveRangeValues(args);
+        if (values.length === 0) return 0;
+        return values.reduce((a, b) => a + b, 0) / values.length;
+      }
+
+      case 'MIN': {
+        const values = this.resolveRangeValues(args);
+        if (values.length === 0) return 0;
+        return Math.min(...values);
+      }
+
+      case 'MAX': {
+        const values = this.resolveRangeValues(args);
+        if (values.length === 0) return 0;
+        return Math.max(...values);
+      }
+
+      case 'COUNT': {
+        const values = this.resolveRangeValues(args);
+        return values.length;
+      }
+
+      case 'IF': {
+        if (args.length !== 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evaluate(args[0]);
+        if (condition) {
+          return this.evaluate(args[1]);
+        } else {
+          return this.evaluate(args[2]);
+        }
+      }
+
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
