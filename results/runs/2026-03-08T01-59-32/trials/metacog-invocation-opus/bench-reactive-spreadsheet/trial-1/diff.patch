rwriting a value with a formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 42);\n      expect(sheet.get('B1')).toBe(42);\n\n      sheet.set('B1', '=A1+5');\n      expect(sheet.get('B1')).toBe(15);\n    });\n  });\n\n  describe('SUM function', () => {\n    it('should sum a column range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('A4', 4);\n      sheet.set('A5', 5);\n      sheet.set('B1', '=SUM(A1:A5)');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should sum a row range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 20);\n      sheet.set('C1', 30);\n      sheet.set('D1', '=SUM(A1:C1)');\n      expect(sheet.get('D1')).toBe(60);\n    });\n\n    it('should sum a block range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('B1', 3);\n      sheet.set('B2', 4);\n      sheet.set('C1', '=SUM(A1:B2)');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('should skip non-numeric values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n\n    it('should return 0 for empty range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('B1', '=SUM(A1:A5)');\n      expect(sheet.get('B1')).toBe(0);\n    });\n\n    it('should reactively update when range values change', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(6);\n\n      sheet.set('A2', 10);\n      expect(sheet.get('B1')).toBe(14);\n    });\n  });\n\n  describe('AVERAGE function',