type === 'RANGE') {\n      this.consume();\n      const [start, end] = token.value.split(':');\n      return { type: 'range', start, end };\n    }\n\n    if (token.type === 'CELL_REF') {\n      this.consume();\n      return { type: 'cell_ref', ref: token.value };\n    }\n\n    if (token.type === 'LPAREN') {\n      this.consume();\n      const expr = this.parseComparison();\n      if (!this.peek() || this.peek()!.type !== 'RPAREN') {\n        throw new Error('Expected closing parenthesis');\n      }\n      this.consume();\n      return expr;\n    }\n\n    throw new Error(`Unexpected token: ${token.value}`);\n  }\n\n  private parseFunctionArg(): ASTNode {\n    // Inside function args, we allow comparisons (for IF conditions)\n    return this.parseComparison();\n  }\n}\n\nfunction parseFormula(formula: string): ASTNode {\n  const tokens = tokenize(formula);\n  const parser = new Parser(tokens);\n  return parser.parse();\n}\n\n// ── Extract Cell References from AST ─────────────────────────────────\n\nfunction extractRefs(node: ASTNode): Set<string> {\n  const refs = new Set<string>();\n\n  function walk(n: ASTNode): void {\n    switch (n.type) {\n      case 'cell_ref':\n        refs.add(n.ref);\n        break;\n      case 'range': {\n        const cells = expandRange(n.start, n.end);\n        for (const c of cells) refs.add(c);\n        break;\n      }\n      case 'binary':\n        walk(n.left);\n        walk(n.right);\n        break;\n      case 'comparison':\n        walk(n.left);\n        walk(n.right);\n        break;\n      case 'unary':\n        walk(n.operand);\n        break;\n      case 'function':\n        for (const arg of n.args) walk(arg);\n        break;\n      // number, string, boolean have no refs\n    }\n  }\n\n  walk(node);\n  return refs;\n}\n\n// ── Cell Storage ─────────────────────────────────────────────────────\n\ninterface CellData {\n  rawValue: string | number | boolean;\n  formula: string | null;       // original formula string (without '