of deps) {\n          if (!affected.has(dep)) {\n            affected.add(dep);\n            queue.push(dep);\n          }\n        }\n      }\n    }\n\n    // Topological sort using Kahn's algorithm over the affected cells\n    // Build in-degree counts only for affected cells\n    const inDegree = new Map<string, number>();\n    for (const cell of affected) {\n      inDegree.set(cell, 0);\n    }\n\n    for (const cell of affected) {\n      const data = this.cells.get(cell);\n      if (data) {\n        for (const dep of data.deps) {\n          // Only count edges from within the affected set or from the start cell\n          if (affected.has(dep)) {\n            inDegree.set(cell, (inDegree.get(cell) || 0) + 1);\n          }\n        }\n      }\n    }\n\n    const sorted: string[] = [];\n    const ready: string[] = [];\n\n    for (const [cell, degree] of inDegree) {\n      if (degree === 0) ready.push(cell);\n    }\n\n    while (ready.length > 0) {\n      const cell = ready.shift()!;\n      sorted.push(cell);\n      const deps = this.dependents.get(cell);\n      if (deps) {\n        for (const dep of deps) {\n          if (affected.has(dep)) {\n            const newDegree = (inDegree.get(dep) || 0) - 1;\n            inDegree.set(dep, newDegree);\n            if (newDegree === 0) ready.push(dep);\n          }\n        }\n      }\n    }\n\n    return sorted;\n  }\n\n  // ── AST Evaluation ─────────────────────────────────────────────\n\n  private evaluate(node: ASTNode): string | number | boolean {\n    switch (node.type) {\n      case 'number':\n        return node.value;\n      case 'string':\n        return node.value;\n      case 'boolean':\n        return node.value;\n\n      case 'cell_ref': {\n        const val = this.get(node.ref);\n        if (val === null) return 0; // empty cells treated as 0 in formulas\n        return val;\n      }\n\n      case 'range':\n        throw new Error('Range can only be used inside functions');\n\n      case 'unary': {\n        const operand = this.evaluate(node.operand);\n        if (node.op === '-') return -(operand as number);\n        return operand;\n      }\n\n      case 'binary': {\n        const left = this.evaluate(node.left);\n        const right = this.evaluate(node.right);\n        const l = left as number;\n        const r = right as number;\n        switch (node.op) {\n          case '+': return l + r;\n          case '-': return l - r;\n          case '*': return l * r;\n          case '/': return l / r;\n          default: throw new Error(`Unknown operator: ${node.op}`);\n        }\n      }\n\n      case 'comparison': {\n        const left = this.evaluate(node.left);\n        const right = this.evaluate(node.right);\n        switch (node.op) {\n          case '>': return (left as number) > (right as number);\n          case '<': return (left as number) < (right as number);\n          case '>=': return (left as number) >= (right as number);\n          case '<=': return (left as number) <= (right as number);\n          case '=': return left === right;\n          case '<>': return left !== right;\n          default: throw new Error(`Unknown comparison: ${node.op}`);\n        }\n      }\n\n      case 'function':\n        return this.evaluateFunction(node.name, node.args);\n\n      default:\n        throw new Error(`Unknown AST node type`);\n    }\n  }\n\n  private resolveRangeValues(args: ASTNode[]): number[] {\n    const values: number[] = [];\n    for (const arg of args) {\n      if (arg.type === 'range') {\n        const cells = expandRange(arg.start, arg.end);\n        for (const cellRef of cells) {\n          const val = this.get(cellRef);\n          if (typeof val === 'number') values.push(val);\n        }\n      } else {\n        const val = this.evaluate(arg);\n        if (typeof val === 'number') values.push(val);\n      }\n    }\n    return values;\n  }\n\n  private evaluateFunction(name: string, args: ASTNode[]): string | number | boolean {\n    switch (name) {\n  