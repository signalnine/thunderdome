+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+import type { TimeEntry, TimeSummary, TimeTrackerData } from "./types.js";
+
+export class TimeTracker {
+  private entries: TimeEntry[];
+  private readonly filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = [];
+    this.load();
+  }
+
+  /**
+   * Start a new timer. If one is already running, stop it first.
+   */
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    const running = this.getRunning();
+    if (running) {
+      running.end = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      end: null,
+    };
+
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): TimeEntry {
+    const running = this.getRunning();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.end = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  /**
+   * Get the currently running entry, or null.
+   */
+  getRunning(): TimeEntry | null {
+    return this.entries.find((e) => e.end === null) ?? null;
+  }
+
+  /**
+   * Get all entries, optionally filtered by date range.
+   */
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    if (!from && !to) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter((entry) => {
+      const entryStart = new Date(entry.start).getTime();
+      if (from && entryStart < from.getTime()) {
+        return false;
+      }
+      if (to && entryStart > to.getTime()) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  /**
+   * Get a summary of total time spent per task name in milliseconds.
+   * Running tasks use the current time for their duration.
+   */
+  getSummary(from?: Date, to?: Date): TimeSummary {
+    const entries = this.getEntries(from, to);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.end ? new Date(entry.end).getTime() : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] !== undefined) {
+        summary[entry.task] += duration;
+      } else {
+        summary[entry.task] = duration;
+      }
+    }
+
+    return summary;
+  }
+
+  private load(): void {
+    if (!existsSync(this.filePath)) {
+      return;
+    }
+
+    try {
+      const raw = readFileSync(this.filePath, "utf-8");
+      const data: TimeTrackerData = JSON.parse(raw);
+      if (Array.isArray(data.entries)) {
+        this.entries = data.entries;
+      }
+    } catch {
+      // If file is corrupt or unreadable, start fresh
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    if (!existsSync(dir)) {
+      mkdirSync(dir, { recursive: true });
+    }
+
+    const data: TimeTrackerData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+}
