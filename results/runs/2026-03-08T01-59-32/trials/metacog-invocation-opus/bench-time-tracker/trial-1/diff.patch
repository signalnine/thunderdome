+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  end: string | null; // ISO 8601 or null if still running
+}
+
+export interface TimeSummary {
+  [task: string]: number; // milliseconds
+}
+
+export interface TimeTrackerData {
+  entries: TimeEntry[];
+}
