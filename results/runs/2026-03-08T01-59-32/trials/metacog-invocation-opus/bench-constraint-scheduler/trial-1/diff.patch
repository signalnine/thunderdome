 }\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // Detect cycles and get topological order\n  const topoOrder = detectCycleAndTopoSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Sort rooms by capacity ascending for best-fit matching\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Compute valid rooms for each event (rooms with sufficient capacity)\n  const validRooms = new Map<string, Room[]>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const valid = sortedRooms.filter((r) => r.capacity >= attendees);\n    validRooms.set(e.id, valid);\n  }\n\n  // Compute number of dependents for each event (events that depend on it)\n  const dependentCount = new Map<string, number>();\n  for (const e of events) {\n    dependentCount.set(e.id, 0);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (dependentCount.has(preId)) {\n          dependentCount.set(preId, (dependentCount.get(preId) ?? 0) + 1);\n        }\n      }\n    }\n  }\n\n  // Use topological order but within groups of similar depth, prioritize\n  // by constraint tightness (fewer valid rooms = more constrained)\n  // Compute topological depths\n  const depth = new Map<string, number>();\n  for (const id of topoOrder) {\n    const event = eventMap.get(id)!;\n    let maxPreDepth = -1;\n    if (event.prerequisites) {\n      for (const preId of event.prerequisites) {\n        if (depth.has(preId)) {\n          maxPreDepth = Math.max(maxPreDepth, depth.get(preId)!);\n        }\n      }\n    }\n    depth.set(id, maxPreDepth + 1);\n  }\n\n  // Sort by depth first, then by constraint tightness (fewer valid rooms first),\n  // then by more dependents first, then by longer duration first\n  const sortedEvents = [...topoOrder].sort((a, b) => {\n    const da = depth.get(a)!;\n    const db = depth.get(b)!;\n    if (da !== db) return da - db;\n\n    const va = (validRooms.get(a) ?? []).length;\n    const vb = (validRooms.get(b) ?? []).length;\n    if (va !== vb) return va - vb; // fewer valid rooms = more constrained = first\n\n    const dca = dependentCount.get(a) ?? 0;\n    const dcb = dependentCount.get(b) ?? 0;\n    if (dca !== dcb) return dcb - dca; // more dependents = first\n\n    const ea = eventMap.get(a)!;\n    const eb = eventMap.get(b)!;\n    return eb.duration - ea.duration; // longer duration = first\n  });\n\n  // Room timelines: roomId -> sorted array of {start, end}\n  const roomTimelines = new Map<string, { start: number; end: number }[]>();\n  for (const r of rooms) {\n    roomTimelines.set(r.id, []);\n  }\n\n  // Assignments and tracking\n  const assignments = new Map<\n    string,\n    { roomId: string; startTime: number; endTime: number }\n  >();\n\n  // Schedule events using backtracking to maximize the number scheduled\n  // For practical efficiency, use a greedy approach with smart ordering\n  // and attempt rescheduling when events can't fit\n\n  function getEarliestPrereqEnd(eventId: string): number {\n    const event = eventMap.get(eventId)!;\n    let earliest = startTime;\n    if (event.prerequisites) {\n      for (const preId of event.prerequisites) {\n        const preAssignment = assignments.get(preId);\n        if (preAssignment) {\n          earliest = Math.max(earliest, preAssignment.endTime + gap);\n        }\n        // If prerequisite is not scheduled (and not in events list), ignore\n      }\n    }\n    return earliest;\n  }\n\n  function tryScheduleEvent(eventId: string): boolean {\n    const event = eventMap.get(eventId)!;\n    const eventRooms = validRooms.get(eventId) ?? [];\n    if (eventRooms.l