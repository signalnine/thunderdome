+            // Temporarily remove occupant from current room
+            removeFromTimeline(
+              roomTimelines.get(room.id)!,
+              slot.start,
+              slot.end
+            );
+            const oldAssignment = assignments.get(occupantId)!;
+            assignments.delete(occupantId);
+
+            // Try to place occupant in alternative room
+            const altTimeline = roomTimelines.get(altRoom.id)!;
+            const altEarliestStart = getEarliestPrereqEnd(occupantId);
+            const altStart = findEarliestStart(
+              occupant.duration,
+              altTimeline,
+              altEarliestStart,
+              endTime,
+              gap
+            );
+
+            if (altStart !== null) {
+              // Place occupant in new room
+              insertIntoTimeline(
+                altTimeline,
+                altStart,
+                altStart + occupant.duration
+              );
+              assignments.set(occupantId, {
+                roomId: altRoom.id,
+                startTime: altStart,
+                endTime: altStart + occupant.duration,
+              });
+
+              // Now try to place our event
+              if (tryScheduleEvent(eventId)) {
+                unscheduledSet.delete(eventId);
+                scheduled = true;
+                break;
+              }
+
+              // Didn't work, undo the occupant move
+              removeFromTimeline(
+                altTimeline,
+                altStart,
+                altStart + occupant.duration
+              );
+              assignments.delete(occupantId);
+            }
+
+            // Restore occupant to original position
+            if (!assignments.has(occupantId)) {
+              insertIntoTimeline(
+                roomTimelines.get(room.id)!,
+                oldAssignment.startTime,
+                oldAssignment.endTime
+              );
+              assignments.set(occupantId, oldAssignment);
+            }
+          }
+        }
+        if (scheduled) break;
+      }
+    }
+  }
+
+  // Build result
+  const resultAssignments: Assignment[] = [];
+  for (const [eventId, assignment] of assignments) {
+    resultAssignments.push({
+      eventId,
+      roomId: assignment.roomId,
+      startTime: assignment.startTime,
+      endTime: assignment.endTime,
+    });
+  }
+
+  // Sort assignments by start time for deterministic output
+  resultAssignments.sort((a, b) => a.startTime - b.startTime || a.roomId.localeCompare(b.roomId));
+
+  return {
+    assignments: resultAssignments,
+    unscheduled: [...unscheduledSet],
+  };
+}
+
+// Also export as a class for flexibility
+export class Scheduler {
+  schedule(
+    events: Event[],
+    rooms: Room[],
+    options: ScheduleOptions
+  ): ScheduleResult {
+    return schedule(events, rooms, options);
+  }
+}
+
+export function createScheduler(): Scheduler {
+  return new Scheduler();
+}
+
+export default schedule;
