ind the earliest start time for an event in a given room,\n * considering room timeline and prerequisite finish times.\n */\nfunction findEarliestStart(\n  eventDuration: number,\n  roomTimeline: { start: number; end: number }[],\n  earliestStart: number,\n  endTime: number,\n  gap: number\n): number | null {\n  const eventEnd = earliestStart + eventDuration;\n  if (eventEnd > endTime) return null;\n\n  // If no events in this room yet, just start at earliestStart\n  if (roomTimeline.length === 0) {\n    return earliestStart;\n  }\n\n  // Try fitting before the first event\n  if (earliestStart + eventDuration + gap <= roomTimeline[0].start) {\n    return earliestStart;\n  }\n\n  // Try fitting between existing events\n  for (let i = 0; i < roomTimeline.length; i++) {\n    const candidateStart = Math.max(earliestStart, roomTimeline[i].end + gap);\n    const candidateEnd = candidateStart + eventDuration;\n\n    if (candidateEnd > endTime) return null;\n\n    if (i + 1 < roomTimeline.length) {\n      // Need to fit before the next event with gap\n      if (candidateEnd + gap <= roomTimeline[i + 1].start) {\n        return candidateStart;\n      }\n    } else {\n      // Last event in timeline, just need to fit within time window\n      return candidateStart;\n    }\n  }\n\n  return null;\n}\n\nfunction insertIntoTimeline(\n  timeline: { start: number; end: number }[],\n  start: number,\n  end: number\n): void {\n  // Insert maintaining sorted order by start time\n  let i = 0;\n  while (i < timeline.length && timeline[i].start < start) {\n    i++;\n  }\n  timeline.splice(i, 0, { start, end });\n}\n\nfunction removeFromTimeline(\n  timeline: { start: number; end: number }[],\n  start: number,\n  end: number\n): void {\n  const idx = timeline.findIndex((t) => t.start === start && t.end === end);\n  if (idx !== -1) {\n    timeline.splice(idx, 1);\n  }\n}\n\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // Detect cycles and get topological order\n  const topoOrder = detectCycleAndTopoSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Sort rooms by capacity ascending for best-fit matching\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Compute valid rooms for each event (rooms with sufficient capacity)\n  const validRooms = new Map<string, Room[]>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const valid = sortedRooms.filter((r) => r.capacity >= attendees);\n    validRooms.set(e.id, valid);\n  }\n\n  // Compute number of dependents for each event (events that depend on it)\n  const dependentCount = new Map<string, number>();\n  for (const e of events) {\n    dependentCount.set(e.id, 0);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (dependentCount.has(preId)) {\n          dependentCount.set(preId, (dependentCount.get(preId) ?? 0) + 1);\n        }\n      }\n    }\n  }\n\n  // Use topological order but within groups of similar depth, prioritize\n  // by constraint tightness (fewer valid rooms = more constrained)\n  // Compute topological depths\n  const depth = new Map<string, number>();\n  for (const id of topoOrder) {\n    const event = eventMap.get(id)!;\n    let maxPreDepth = -1;\n    if (event.prerequisites) {\n      for (const preId of event.prerequisites) {\n        if (depth.has(preId)) {\n          maxPreDepth = Math.max(maxPreDepth, depth.get(preId)!);\n        }\n      }\n    }\n    depth.set(id, maxPreDepth + 1);\n  }\n\n  // Sort by depth first, then by constraint tightness (fewer valid rooms first),\n  // then by more dependents first, then by longer duration first\n  const sortedEvents = [...topoOrder].sort((a, b) => {\n    const da = depth.get(a)!;\n    const db = depth.get(b)!;\n    if (da !== db) return da - db;\n\n    const va = (validRooms.get(a) ?? []).length;\n    const vb = (validRooms.get(b) ?? []).length;\n    if (va !== vb) return va - vb; // fewer valid rooms = more constrained = first\n\n    const dca = dependentCount.get(a) ?? 0;\n    const dcb = dependentCount.get(b) ?? 0;\n    if (dca !== dcb) return dcb - dca; // more dependents = first\n\n    const ea = eventMap.get(a)!;\n    const eb = eventMap.get(b)!;\n    return eb.duration - ea.duration; // longer duration = first\n  });\n\n  // Room timelines: roomId -> sorted array of {start, end}\n  const roomTimelines = new Map<string, { start: number; end: number }[]>();\n  for (const r of rooms) {\n    roomTimelines.set(r.id, []);\n  }\n\n  // Assignments and tracking\n  const assignments = new Map<\n    string,\n    { roomId: string; startTime: number; endTime: number }\n  >();\n\n  // Schedule events using backtracking to maximize the number scheduled\n  // For practical efficiency, use a greedy approach with smart ordering\n  // and attempt rescheduling when events can't fit\n\n  function getEarliestPrereqEnd(eventId: string): number {\n    const event = eventMap.get(eventId)!;\n    let earliest = startTime;\n    if (event.prerequisites) {\n      for (const preId of event.prerequisites) {\n        const preAssignment = assignments.get(preId);\n        if (preAssignment) {\n          earliest = Math.max(earliest, preAssignment.endTime + gap);\n        }\n        // If prerequisite is not scheduled (and not in events list), ignore\n      }\n    }\n    return earliest;\n  }\n\n  function tryScheduleEvent(eventId: string): boolean {\n    const event = eventMap.get(eventId)!;\n    const eventRooms = validRooms.get(eventId) ?? [];\n    if (eventRooms.length === 0) return false;\n\n    const earliestStart = getEarliestPrereqEnd(eventId);\n\n    // Try preferred room first\n    const roomOrder = event.preferredRoom\n      ? [\n          ...eventRooms.filter((r) => r.id === event.preferredRoom),\n          ...eventRooms.filter((r) => r.id !== event.preferredRoom),\n        ]\n      : eventRooms;\n\n    let bestStart: number | null = null;\n    let bestRoom: Room | null = null;\n\n    for (const room of roomOrder) {\n      const timeline = roomTimelines.get(room.id)!;\n      const candidateStart = findEarliestStart(\n        event.duration,\n        timeline,\n        earliestStart,\n        endTime,\n        gap\n      );\n\n      if (candidateStart !== null) {\n        // If this is the preferred room and it works, use it\n        if (event.preferredRoom && room.id === event.preferredRoom) {\n          bestStart = candidateStart;\n          bestRoom = room;\n          break;\n        }\n        // Otherwise pick the earliest start time (best-fit by capacity since rooms are sorted)\n        if (bestStart === null || candidateStart < bestStart) {\n          bestStart = candidateStart;\n          bestRoom = room;\n        }\n      }\n    }\n\n    if (bestStart !== null && bestRoom !== null) {\n      const eventEnd = bestStart + event.duration;\n      insertIntoTimeline(roomTimelines.get(bestRoom.id)!, bestStart, eventEnd);\n      assignments.set(eventId, {\n        roomId: bestRoom.id,\n        startTime: bestStart,\n        endTime: eventEnd,\n      });\n      return true;\n    }\n\n    return false;\n  }\n\n  // First pass: greedy scheduling in priority order\n  const unscheduledSet = new Set<string>();\n  for (const eventId of sortedEvents) {\n    // Check if all prerequisites are scheduled\n    const event = eventMap.get(eventId)!;\n    let prereqsMet = true;\n    if (event.prerequisites) {\n      for (const preId of event.prerequisites) {\n        if (eventMap.has(preId) && !assignments.has(preId)) {\n          prereqsMet = false;\n          break;\n        }\n      }\n    }\n\n    if (!prereqsMet) {\n      unscheduledSet.add(eventId);\n      continue;\n    }\n\n    if (!tryScheduleEvent(eventId)) {\n      unscheduledSet.add(eventId);\n    }\n  }\n\n  // Second pass: try to schedule previously failed events\n  // Some events might have failed due to ordering within the same depth level\n  // Retry them now that other events are placed\n  if (unscheduledSet.size > 0) {\n    let changed = true;\n    while (changed) {\n      changed = false;\n      for (const eventId of [...unscheduledSet]) {\n        const event = eventMap.get(eventId)!;\n        let prereqsMet = true;\n        if (event.prerequisites) {\n          for (const preId of event.prerequisites) {\n            if (eventMap.has(preId) && !assignments.has(preId)) {\n              prereqsMet = false;\n              break;\n            }\n          }\n        }\n        if (!prereqsMet) continue;\n\n        if (tryScheduleEvent(eventId)) {\n          unscheduledSet.delete(eventId);\n          changed = true;\n        }\n      }\n    }\n  }\n\n  // Third pass: try backtracking for remaining unscheduled events\n  // For each unscheduled event, see if swapping/moving a scheduled event frees space\n  if (unscheduledSet.size > 0) {\n    for (const eventId of [...unscheduledSet]) {\n      const event = eventMap.get(eventId)!;\n\n      // Check prerequisites are met\n      let prereqsMet = true;\n      if (event.prerequisites) {\n        for (const preId of event.prerequisites) {\n          if (eventMap.has(preId) && !assignments.has(preId)) {\n            prereqsMet = false;\n            break;\n          }\n        }\n      }\n      if (!prereqsMet) continue;\n\n      const eventRooms = validRooms.get(eventId) ?? [];\n      if (eventRooms.length === 0) continue;\n\n      // Try to displace a less constrained event to make room\n      let scheduled = false;\n      for (const room of eventRooms) {\n        const timeline = roomTimelines.get(room.id)!;\n\n        // Look for scheduled events in this room that could be moved elsewhere\n        for (let