+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+const enum Color {
+  White = 0,
+  Gray = 1,
+  Black = 2,
+}
+
+function detectCycleAndTopoSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  const color = new Map<string, Color>();
+  const order: string[] = [];
+
+  for (const e of events) {
+    color.set(e.id, Color.White);
+  }
+
+  function dfs(id: string): void {
+    color.set(id, Color.Gray);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const preId of event.prerequisites) {
+        const c = color.get(preId);
+        if (c === Color.Gray) {
+          throw new Error(`Prerequisite cycle detected involving event "${preId}"`);
+        }
+        if (c === Color.White) {
+          dfs(preId);
+        }
+        // If c === undefined, the prerequisite references a non-existent event — skip
+      }
+    }
+    color.set(id, Color.Black);
+    order.push(id);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === Color.White) {
+      dfs(e.id);
+    }
+  }
+
+  return order; // topological order: prerequisites come before dependents
+}
+
+/**
+ * Find the earliest start time for an event in a given room,
+ * considering room timeline and prerequisite finish times.
+ */
+function findEarliestStart(
+  eventDuration: number,
+  roomTimeline: { start: number; end: number }[],
+  earliestStart: number,
+  endTime: number,
+  gap: number
+): number | null {
+  const eventEnd = earliestStart + eventDuration;
+  if (eventEnd > endTime) return null;
+
+  // If no events in this room yet, just start at earliestStart
+  if (roomTimeline.length === 0) {
+    return earliestStart;
+  }
+
+  // Try fitting before the first event
+  if (earliestStart + eventDuration + gap <= roomTimeline[0].start) {
+    return earliestStart;
+  }
+
+  // Try fitting between existing events
+  for (let i = 0; i < roomTimeline.length; i++) {
+    const candidateStart = Math.max(earliestStart, roomTimeline[i].end + gap);
+    const candidateEnd = candidateStart + eventDuration;
+
+    if (candidateEnd > endTime) return null;
+
+    if (i + 1 < roomTimeline.length) {
+      // Need to fit before the next event with gap
+      if (candidateEnd + gap <= roomTimeline[i + 1].start) {
+        return candidateStart;
+      }
+    } else {
+      // Last event in timeline, just need to fit within time window
+      return candidateStart;
+    }
+  }
+
+  return null;
+}
+
+function insertIntoTimeline(
+  timeline: { start: number; end: number }[],
+  start: number,
+  end: number
+): void {
+  // Insert maintaining sorted order by start time
+  let i = 0;
+  while (i < timeline.length && timeline[i].start < start) {
+    i++;
+  }
+  timeline.splice(i, 0, { start, end });
+}
+
+function removeFromTimeline(
+  timeline: { start: number; end: number }[],
+  start: number,
+  end: number
+): void {
+  const idx = timeline.findIndex((t) => t.start === start && t.end === end);
+  if (idx !== -1) {
+    timeline.splice(idx, 1);
+  }
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  // Detect cycles and get topological order
+  const topoOrder = detectCycleAndTopoSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Sort rooms by capacity ascending for best-fit matching
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  // Compute valid rooms for each event (rooms with sufficient capacity)
+  const validRooms = new Map<string, Room[]>();
+  for (const e of events) {
