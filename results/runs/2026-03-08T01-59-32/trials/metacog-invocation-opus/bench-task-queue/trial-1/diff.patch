ep2.id] });\n\n      queue.next(); // get dep1\n      queue.complete(dep1.id);\n\n      // Still blocked because dep2 not done\n      // dep2 should be the next available\n      const next1 = queue.next();\n      expect(next1?.payload).toBe('dep2');\n      expect(queue.next()).toBeNull(); // dependent still blocked\n\n      queue.complete(dep2.id);\n      const dependent = queue.next();\n      expect(dependent?.payload).toBe('dependent');\n    });\n\n    it('should leave dependents blocked when dependency fails', () => {\n      const dep = queue.add('dependency', { maxRetries: 0 });\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      queue.next();\n      queue.fail(dep.id);\n\n      // Dependent remains blocked\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should provide dependency status', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('test', { dependencies: [dep1.id, dep2.id] });\n\n      let status = queue.getDependencyStatus(dependent.id);\n      expect(status.pending).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      queue.next(); // get dep1\n      queue.complete(dep1.id);\n\n      status = queue.getDependencyStatus(dependent.id);\n      expect(status.resolved).toHaveLength(1);\n      expect(status.pending).toHaveLength(1);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 8: Concurrency Control\n  // ==========================================================================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('a');\n      queue.add('b');\n      queue.add('c');\n\n      expect(queue.next()).not.toBeNull(); // 1 active\n      expect(queue.next()).not.toBeNull(); // 2 active\n      expect(queue.next()).toBeNull(); // blocked by concurrency\n    });\n\n    it('should free slot when task completes', () => {\n      queue.setConcurrency('default', 1);\n      const t1 = queue.add('a');\n      queue.add('b');\n\n      queue.next(); // t1 processing\n      expect(queue.next()).toBeNull();\n\n      queue.complete(t1.id);\n      expect(queue.next()).not.toBeNull(); // t2 now available\n    });\n\n    it('should free slot when task fails', () => {\n      queue.setConcurrency('default', 1);\n      const t1 = queue.add('a', { maxRetries: 0 });\n      queue.add('b');\n\n      queue.next();\n      expect(queue.next()).toBeNull();\n\n      queue.fail(t1.id);\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      const info = queue.getConcurrency();\n      expect(info.limit).toBeNull();\n    });\n\n    it('should report current active count', () => {\n      queue.setConcurrency('default', 5);\n      queue.add('a');\n      queue.add('b');\n\n      queue.next();\n      const info = queue.getConcurrency();\n      expect(info.active).toBe(1);\n    });\n\n    it('should still respect priority ordering with concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const task = queue.next();\n      expect(task?.payload).toBe('high');\n    });\n  });\n\n  // ==========================================================================\n  // Phase 9: Progress Tracking and Cancellation\n  // ==========================================================================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should update and report progress', () => {\n      const task = queue.add('test');\n      queue.next();\n\n      queue.updateProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = queue.add('test');\n      queue.next();\n\n      expect(() => queue.updateProgress(task.id, -1)).toThrow();\n      expect(() => queue.updateProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      const task = queue.add('test');\n      queue.next();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      queue.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      queue.updateProgress(task.id, 25, 'quarter');\n      queue.updateProgress(task.id, 75, 'three-quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribing from progress updates', () => {\n      const task = queue.add('test');\n      queue.next();\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(task.id, (p) => updates.push(p));\n\n      queue.updateProgress(task.id, 25);\n      unsub();\n      queue.updateProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = queue.add('test');\n      queue.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      const task = queue.add('test');\n      queue.next();\n      queue.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = queue.add('test', { maxRetries: 3 });\n      queue.next();\n      queue.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Should not be in pending state (no retry)\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should reject cancelling completed tasks', () => {\n      const task = queue.add('test');\n      queue.next();\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ==========================================================================\n  // Phase 10: Recurring Tasks\n  // ==========================================================================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n    });\n\n    it('should list schedules', () => {\n      queue.addSchedule('*/5 * * * *', 'a');\n      queue.addSchedule('0 * * * *', 'b');\n      expect(queue.getSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const s = queue.addSchedule('*/5 * * * *', 'test');\n      queue.removeSchedule(s.id);\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick for every-N-minutes schedule', () => {\n      queue.addSchedule('*/5 * * * *', { type: 'periodic' });\n\n      // Tick at a time where minutes % 5 === 0\n      const time = new Date('2025-01-01T00:00:00Z');\n      const tasks = queue.tick(time);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'periodic' });\n    });\n\n    it('should not double-enqueue on same tick time', () => {\n      queue.addSchedule('*/5 * * * *', 'test');\n      const time = new Date('2025-01-01T00:00:00Z');\n      queue.tick(time);\n      const tasks = queue.tick(time); // same time\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should support hourly schedule', () => {\n      queue.addSchedule('0 * * * *', 'hourly');\n      const onTheHour = new Date('2025-01-01T03:00:00Z');\n      const notOnTheHour = new Date('2025-01-01T03:30:00Z');\n\n      expect(queue.tick(onTheHour)).toHaveLength(1);\n      expect(queue.tick(notOnTheHour)).toHaveLength(0);\n    });\n\n    it('should support daily schedule', () => {\n      queue.addSchedule('0 0 * * *', 'daily');\n      const midnight = new Date('2025-01-01T00:00:00Z');\n      const noon = new Date('2025-01-01T12:00:00Z');\n\n      expect(queue.tick(midnight)).toHaveLength(1);\n      expect(queue.tick(noon)).toHaveLength(0);\n    });\n\n    it('should reject invalid cron expressions', () => {\n      expect(() => queue.addSchedule('invalid', 'test')).toThrow();\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const s = queue.addSchedule('*/5 * * * *', 'test');\n      const t1 = new Date('2025-01-01T00:00:00Z');\n      expect(queue.tick(t1)).toHaveLength(1);\n\n      queue.removeSchedule(s.id);\n      const t2 = new Date('2025-01-01T00:05:00Z');\n      expect(queue.tick(t2)).toHaveLength(0);\n    });\n\n    it('should create regular tasks subject to queue rules', () => {\n      queue.addSchedule('*/5 * * * *', 'test', { queue: 'myqueue', priority: 2 });\n      const time = new Date('2025-01-01T00:00:00Z');\n      const tasks = queue.tick(time);\n      expect(tasks[0].queue).toBe('myqueue');\n      expect(tasks[0].priority).toBe(2);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 11: Middleware Pipeline\n  // ==========================================================================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: number[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n      queue.setHandler('default', () => {\n        order.push(3);\n      });\n\n      queue.add('test');\n      await queue.process();\n\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should allow middleware to skip processing', async () => {\n      const handlerCalled = vi.fn();\n\n      queue.use('default', async (_task, _next) => {\n        // Don't call next\n      });\n      queue.setHandler('default', handlerCalled);\n\n      queue.add('test');\n      await queue.process();\n\n      expect(handlerCalled).not.toHaveBeenCalled();\n    });\n\n    it('should allow middleware to modify the task', async () => {\n      queue.use('default', async (task, next) => {\n        (task as Task & { metadata?: string }).metadata = 'injected';\n        await next();\n      });\n\n      let receivedTask: Task | null = null;\n      queue.setHandler('default', (task) => {\n        receivedTask = task;\n      });\n\n      queue.add('test');\n      await queue.process();\n\n      expect((receivedTask as unknown as { metadata: string })?.metadata).toBe('injected');\n    });\n\n    it('should fail task if middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = queue.add('test', { maxRetries: 0 });\n      await queue.process();\n\n      expect(task.status).toBe('dead-letter');\n      expect(task.error?.message).toBe('middleware error');\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const q1calls: string[] = [];\n      const q2calls: string[] = [];\n\n      queue.use('q1', async (_task, next) => {\n        q1calls.push('q1-mw');\n        await next();\n      });\n      queue.use('q2', async (_task, next) => {\n        q2calls.push('q2-mw');\n        await next();\n      });\n      queue.setHandler('q1', () => { q1calls.push('q1-handler'); });\n      queue.setHandler('q2', () => { q2calls.push('q2-handler'); });\n\n      queue.add('test', { queue: 'q1' });\n      queue.add('test', { queue: 'q2' });\n\n      await queue.process('q1');\n      await queue.process('q2');\n\n      expect(q1calls).toEqual(['q1-mw', 'q1-handler']);\n      expect(q2calls).toE