fined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const t1 = queue.next();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = queue.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should transition task to processing state on retrieval', () => {\n      const added = queue.add('test');\n      const retrieved = queue.next();\n      expect(retrieved?.id).toBe(added.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n\n    it('should not retrieve tasks already in processing state', () => {\n      queue.add('test');\n      queue.next(); // gets the task\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should report correct size', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 2: Named Queues\n  // ==========================================================================\n  describe('Phase 2: Named Queues', () => {\n    it('should support named queues', () => {\n      queue.add('email-task', { queue: 'emails' });\n      queue.add('sms-task', { queue: 'sms' });\n\n      const emailTask = queue.next('emails');\n      expect(emailTask?.payload).toBe('email-task');\n\n      const smsTask = queue.next('sms');\n      expect(smsTask?.payload).toBe('sms-task');\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.add('default-task');\n      const task = queue.next();\n      expect(task?.payload).toBe('default-task');\n    });\n\n    it('should keep queues independent', () => {\n      queue.add('task-a', { queue: 'A' });\n      expect(queue.next('B')).toBeNull();\n      expect(queue.next('A')?.payload).toBe('task-a');\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queue: 'alpha' });\n      queue.add('b', { queue: 'beta' });\n      const names = queue.getQueues();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should report size per queue', () => {\n      queue.add('a', { queue: 'x' });\n      queue.add('b', { queue: 'x' });\n      queue.add('c', { queue: 'y' });\n      expect(queue.size('x')).toBe(2);\n      expect(queue.size('y')).toBe(1);\n      expect(queue.size('z')).toBe(0);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 3: Priority\n  // ==========================================================================\n  describe('Phase 3: Priority', () => {\n    it('should return higher priority tasks first', () => {\n      queue.add('low', { priority: 8 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should default to priority 5', () => {\n      const task = queue.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 3 });\n      queue.add('second', { priority: 3 });\n      queue.add('third', { priority: 3 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => queue.add('test', { priority: 0 })).toThrow();\n      expect(() => queue.add('test', { priority: 11 })).toThrow();\n      expect(() => queue.add('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.add('test', { priority: 2 });\n      expect(task.priority).toBe(2);\n    });\n\n    it('should maintain priority per queue', () => {\n      queue.add('q1-low', { queue: 'q1', priority: 10 });\n      queue.add('q1-high', { queue: 'q1', priority: 1 });\n      queue.add('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.next('q1')?.payload).toBe('q1-high');\n      expect(queue.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ==========================================================================\n  // Phase 4: Delayed Tasks\n  // ==========================================================================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their available time', () => {\n      queue.add('delayed', { delay: 60000 }); // 60 seconds from now\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after their available time', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('ready', { processAt: past });\n      const task = queue.next();\n      expect(task?.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n      queue.add('delayed', { delay: 60000, priority: 1 }); // high priority but delayed\n      queue.add('immediate', { priority: 10 }); // low priority but available\n      expect(queue.next()?.payload).toBe('immediate');\n    });\n\n    it('should indicate when task becomes available', () => {\n      const task = queue.add('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should support processAt date', () => {\n      const futureDate = new Date(Date.now() + 60000);\n      const task = queue.add('future', { processAt: futureDate });\n      expect(task.availableAt.getTime()).toBe(futureDate.getTime());\n    });\n\n    it('should order available delayed tasks by availability time then priority', () => {\n      const t1 = new Date(Date.now() - 3000);\n      const t2 = new Date(Date.now() - 1000);\n\n      queue.add('earlier', { processAt: t1, priority: 5 });\n      queue.add('later', { processAt: t2, priority: 5 });\n\n      expect(queue.next()?.payload).toBe('earlier');\n      expect(queue.next()?.payload).toBe('later');\n    });\n  });\n\n  // ==========================================================================\n  // Phase 5: Retry with Backoff\n  // ==========================================================================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark a task as completed', () => {\n      const task = queue.add('test');\n      queue.next();\n      queue.complete(task.id);\n      expect(task.status).toBe('completed');\n    });\n\n    it('should mark a task as failed', () => {\n      const task = queue.add('test', { maxRetries: 0 });\n      queue.next();\n      queue.fail(task.id, new Error('oops'));\n      expect(task.status).toBe('dead-letter');\n      expect(task.error?.message).toBe('oops');\n    });\n\n    it('should retry failed tasks with backoff delay', () => {\n      const task = queue.add('test', { maxRetries: 3, backoffDelay: 1000 });\n      queue.next();\n      queue.fail(task.id, new Error('attempt 1'));\n\n      // Task should be pending again but delayed\n      expect(task.status).toBe('pending');\n      expect(task.attempts).toBe(1);\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should use exponential backoff', () => {\n      const task = queue.add('test', { maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt\n      queue.next();\n      const beforeFail1 = Date.now();\n      queue.fail(task.id, new Error('fail 1'));\n      // Backoff: 1000 * 2^0 = 1000ms\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail1 + 1000 - 10);\n    });\n\n    it('should track attempt count', () => {\n      const task = queue.add('test', { maxRetries: 3, backoffDelay: 0 });\n      expect(task.attempts).toBe(0);\n\n      // Process and fail with a past time so it becomes available immediately\n      queue.next();\n      task.availableAt = new Date(0); // hack for testing\n      queue.fail(task.id);\n      task.availableAt = new Date(0);\n      expect(task.attempts).toBe(1);\n    });\n\n    it('should default to 3 retries', () => {\n      const task = queue.add('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should throw when completing a non-processing task', () => {\n      const task = queue.add('test');\n      expect(() => queue.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing a non-processing task', () => {\n      const task = queue.add('test');\n      expect(() => queue.fail(task.id)).toThrow();\n    });\n  });\n\n  // ==========================================================================\n  // Phase 6: Dead Letter Queue\n  // ==========================================================================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ after exhausting retries', () => {\n      const task = queue.add('test', { maxRetries: 2, backoffDelay: 0 });\n\n      // Attempt 1: process and fail\n      queue.next();\n      queue.fail(task.id, new Error('fail'));\n      // After fail with retries remaining, status goes to pending with backoff delay\n      // Make it available immediately for testing\n      task.availableAt = new Date(0);\n\n      // Attempt 2: process and fail again\n      queue.next();\n      queue.fail(task.id, new Error('fail again'));\n\n      // Now attempts === maxRetries (2), so it goes to DLQ\n      expect(task.status).toBe('dead-letter');\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n    });\n\n    it('should retain error info on dead-lettered tasks', () => {\n      const task = queue.add('test', { maxRetries: 0 });\n      queue.next();\n      queue.fail(task.id, new Error('permanent failure'));\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].error?.message).toBe('permanent failure');\n      expect(dlq[0].attempts).toBe(1);\n    });\n\n    it('should allow retrying dead-lettered tasks', () => {\n      const task = queue.add('test', { maxRetries: 0 });\n      queue.next();\n      queue.fail(task.id, new Error('fail'));\n\n      const retried = queue.retryDeadLetterTask(task.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempts).toBe(0);\n      expect(retried.error).toBeUndefined();\n\n      const next = queue.next();\n      expect(next?.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      const t1 = queue.add('a', { maxRetries: 0 });\n      const t2 = queue.add('b', { maxRetries: 0 });\n      queue.next();\n      queue.fail(t1.id);\n      queue.next();\n      queue.fail(t2.id);\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should have independent DLQs per named queue', () => {\n      const t1 = queue.add('a', { queue: 'q1', maxRetries: 0 });\n      const t2 = queue.add('b', { queue: 'q2', maxRetries: 0 });\n\n      queue.next('q1');\n      queue.fail(t1.id);\n      queue.next('q2');\n      queue.fail(t2.id);\n\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 7: Task Dependencies\n  // ==========================================================================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = queue.add('dependency');\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      // Should get the dependency first\n      const first = queue.next();\n      expect(first?.payload).toBe('dependency');\n\n      // Dependent should not be available yet\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = queue.add('dependency');\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      const first = queue.next();\n      queue.complete(first!.id);\n\n      const second = queue.next();\n      expect(second?.payload).toBe('dependent');\n    });\n\n    it('should reject dependency on non-existent task', () => {\n      expect(() => queue.add('test', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should handle multiple dependencies', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      queue.next(); // get dep1\n      queue.complete(dep1.id);\n\n      // Still blocked because dep2 not done\n      // dep2 should be the next available\n      const next1 = queue.next();\n      expect(next1?.payload).toBe('dep2');\n      expect(queue.next()).toBeNull(); // dependent still blocked\n\n      queue.complete(dep2.id);\n      const dependent = queue.next();\n      expect(dependent?.payload).toBe('dependent');\n    });\n\n    it('should leave dependents blocked when dependency fails', () => {\n      const dep = queue.add('dependency', { maxRetries: 0 });\n      queue.add('dependent', { dependencies: [dep.id] });\n\n      queue.next();\n      queue.fail(dep.id);\n\n      // Dependent remains blocked\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should provide dependency status', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('test', { dependencies: [dep1.id, dep2.id] });\n\n      let status = queue.getDependencyStatus(dependent.id);\n      expect(status.pending).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      queue.next(); // get dep1\n      queue.complete(dep1.id);\n\n      status = queue.getDependencyStatus(dependent.id);\n      expect(status.resolved).toHaveLength(1);\n      expect(status.pending).toHaveLength(1);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 8: Concurrency Control\n  // ==========================================================================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('a');\n      queue.add('b');\n      queue.add('c');\n\n      expect(queue.next()).not.toBeNull(); // 1 active\n      expect(queue.next()).not.toBeNull(); // 2 active\n      expect(queue.next()).toBeNull(); // blocked by concurrency\n    });\n\n    it('should free slot when task completes', () => {\n      queue.setConcurrency('default', 1);\n      const t1 = queue.add('a');\n      queue.add('b');\n\n      queue.next(); // t1 processing\n      expect(queue.next()).toBeNull();\n\n      queue.complete(t1.id);\n      expect(queue.next()).not.toBeNull(); // t2 now available\n    });\n\n    it('should free slot when task fails', () => {\n      queue.setConcurrency('default', 1);\n      const t1 = queue.add('a', { maxRetries: 0 });\n      queue.add('b');\n\n      queue.next();\n      expect(queue.next()).toBeNull();\n\n      queue.fail(t1.id);\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      const info = queue.getConcurrency();\n      expect(info.limit).toBeNull();\n    });\n\n    it('should report current active count', () => {\n      queue.setConcurrency('default', 5);\n      queue.add('a');\n      queue.add('b');\n\n      queue.next();\n      const info = queue.getConcurrency();\n      expect(info.active).toBe(1);\n    });\n\n    it('should still respect priority ordering with concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const task = queue.next();\n      expect(task?.payload).toBe('high');\n    });\n  });\n\n  // ==========================================================================\n  // Phase 9: Progress Tracking and Cancellation\n  // ==========================================================================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should update and report progress', () => {\n      const task = queue.add('test');\n      queue.next();\n\n      queue.updateProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = queue.add('test');\n      queue.next();\n\n      expect(() => queue.updateProgress(task.id, -1)).toThrow();\n      expect(() => queue.updateProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      const task = queue.add('test');\n      queue.next();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      queue.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      queue.updateProgress(task.id, 25, 'quarter');\n      queue.updateProgress(task.id, 75, 'three-quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribing from progress updates', () => {\n      const task = queue.add('test');\n      queue.next();\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(task.id, (p) => updates.push(p));\n\n      queue.updateProgress(task.id, 25);\n      unsub();\n      queue.updateProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = queue.add('test');\n      queue.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      const task = queue.add('test');\n      queue.next();\n      queue.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = queue.add('test', { maxRetries: 3 });\n      queue.next();\n      queue.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Should not be in pending state (no retry)\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should reject cancelling completed tasks', () => {\n      const task = queue.add('test');\n      queue.next();\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ==========================================================================\n  // Phase 10: Recurring Tasks\n  // ==========================================================================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', { type: 'cleanup' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n    });\n\n    it('should list schedules', () => {\n      queue.addSchedule('*/5 * * * *', 'a');\n      queue.addSchedule('0 * * * *', 'b');\n      expect(queue.getSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const s = queue.addSchedule('*/5 * * * *', 'test');\n      queue.removeSchedule(s.id);\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick for every-N-minutes schedule', () => {\n      queue.addSchedule('*/5 * * * *', { type: 'periodic' });\n\n      // Tick at a time where minutes % 5 === 0\n      const time = new Date('2025-01-01T00:00:00Z');\n      const tasks = queue.tick(time);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'periodic' });\n    });\n\n    it('should not double-enqueue on same tick time', () => {\n      queue.addSchedule('*/5 * * * *', 'test');\n      const time = new Date('2025-01-01T00:00:00Z');\n      queue.tick(time);\n      const tasks = queue.tick(time); // same time\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should support hourly schedule', () => {\n      queue.addSchedule('0 * * * *', 'hourly');\n      const onTheHour = new Date('2025-01-01T03:00:00Z');\n      const notOnTheHour = new Date('2025-01-01T03:30:00Z');\n\n      expect(queue.tick(onTheHour)).toHaveLength(1);\n      expect(queue.tick(notOnTheHour)).toHaveLength(0);\n    });\n\n    it('should support daily schedule', () => {\n      queue.addSchedule('0 0 * * *', 'daily');\n      const midnight = new Date('2025-01-01T00:00:00Z');\n      const noon = new Date('2025-01-01T12:00:00Z');\n\n      expect(queue.tick(midnight)).toHaveLength(1);\n      expect(queue.tick(noon)).toHaveLength(0);\n    });\n\n    it('should reject invalid cron expressions', () => {\n      expect(() => queue.addSchedule('invalid', 'test')).toThrow();\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const s = queue.addSchedule('*/5 * * * *', 'test');\n      const t1 = new Date('2025-01-01T00:00:00Z');\n      expect(queue.tick(t1)).toHaveLength(1);\n\n      queue.removeSchedule(s.id);\n      const t2 = new Date('2025-01-01T00:05:00Z');\n      expect(queue.tick(t2)).toHaveLength(0);\n    });\n\n    it('should create regular tasks subject to queue rules', () => {\n      queue.addSchedule('*/5 * * * *', 'test', { queue: 'myqueue', priority: 2 });\n      const time = new Date('2025-01-01T00:00:00Z');\n      const tasks = queue.tick(time);\n      expect(tasks[0].queue).toBe('myqueue');\n      expect(tasks[0].priority).toBe(2);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 11: Middleware Pipeline\n  // ==========================================================================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: number[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n      queue.setHandler('default', () => {\n        order.push(3);\n      });\n\n      queue.add('test');\n      await queue.process();\n\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should allow middleware to skip processing', async () => {\n      const handlerCalled = vi.fn();\n\n      queue.use('default', async (_task, _next) => {\n        // Don't call next\n      });\n      queue.setHandler('default', handlerCalled);\n\n      queue.add('test');\n      await queue.process();\n\n      expect(handlerCalled).not.toHaveBeenCalled();\n    });\n\n    it('should allow middleware to modify the task', async () => {\n      queue.use('default', async (task, next) => {\n        (task as Task & { metadata?: string }).metadata = 'injected';\n        await next();\n      });\n\n      let receivedTask: Task | null = null;\n      queue.setHandler('default', (task) => {\n        receivedTask = task;\n      });\n\n      queue.add('test');\n      await queue.process();\n\n      expect((receivedTask as unknown as { metadata: string })?.metadata).toBe('injected');\n    });\n\n    it('should fail task if middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = queue.add('test', { maxRetries: 0 });\n      await queue.process();\n\n      expect(task.status).toBe('dead-letter');\n      expect(task.error?.message).toBe('middleware error');\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const q1calls: string[] = [];\n      const q2calls: string[] = [];\n\n      queue.use('q1', async (_task, next) => {\n        q1calls.push('q1-mw');\n        await next();\n      });\n      queue.use('q2', async (_task, next) => {\n        q2calls.push('q2-mw');\n        await next();\n      });\n      queue.setHandler('q1', () => { q1calls.push('q1-handler'); });\n      queue.setHandler('q2', () => { q2calls.push('q2-handler'); });\n\n      queue.add('test', { queue: 'q1' });\n      queue.add('test', { queue: 'q2' });\n\n      await queue.process('q1');\n      await queue.process('q2');\n\n      expect(q1calls).toEqual(['q1-mw', 'q1-handler']);\n      expect(q2calls).toEqual(['q2-mw', 'q2-handler']);\n    });\n\n    it('should complete task after successful processing', async () => {\n      queue.setHandler('default', () => { /* success */ });\n\n      const task = queue.add('test');\n      await queue.process();\n\n      expect(task.status).toBe('completed');\n    });\n\n    it('should return null when no task to process', async () => {\n      const result = await queue.process();\n      expect(result).toBeNull();\n    });\n  });\n\n  // ==========================================================================\n  // Phase 12: Graceful Shutdown\n  // ==========================================================================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.add('test')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately when no tasks are processing', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should return same result for multiple shutdown calls', async () => {\n      const r1 = queue.shutdown();\n      const r2 = queue.shutdown();\n      const [result1, result2] = await Promise.all([r1, r2]);\n      expect(result1).toBe(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      const called = vi.fn();\n      queue.onShutdown(called);\n      await queue.shutdown();\n      expect(called).toHaveBeenCalledOnce();\n    });\n\n    it('should force cancel tasks that do not complete within timeout', async () => {\n      const task = queue.add('long-running');\n      queue.next(); // set to processing\n      // Task will never complete naturally\n\n      const result = await queue.shutdown(50); // very short timeout\n      expect(result.forceCancelled).toBe(1);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('should report shutdown duration', async () => {\n      const result = await queue.shutdown();\n      expect(typeof result.durationMs).toBe('number');\n    });\n\n    it('should indicate shutdown state', async () => {\n      expect(queue.isShutdown()).toBe(false);\n      await queue.shutdown();\n      expect(queue.isShutdown()).toBe(true);\n    });\n  });\n\n  // ==========================================================================\n  // Integration: Cross-phase interactions\n  // ==========================================================================\n  describe('Integration Tests', () => {\n    it('priority + delay interaction', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('high-delayed', { priority: 1, processAt: past });\n      queue.add('low-immediate', { priority: 10 });\n\n      // Both are available, high priority should come first\n      expect(queue.next()?.payload).toBe('high-delayed');\n      expect(queue.next()?.payload).toBe('low-immediate');\n    });\n\n    it('retry keeps original queue and priority', () => {\n      const task = queue.add('test', { queue: 'myqueue', priority: 2, maxRetries: 2, backoffDelay: 0 });\n      queue.next('myqueue');\n      queue.fail(task.id);\n\n      // Task should be back in myqueue with same priority\n      expect(task.queue).toBe('myqueue');\n      expect(task.priority).toBe(2);\n      expect(task.status).toBe('pending');\n    });\n\n    it('concurrency + priority interaction', () => {\n      queue.setConcurrency('default', 1);\n      const t1 = queue.add('first', { priority: 5 });\n      queue.add('high', { priority: 1 });\n\n      queue.next(); // gets 'high' due to priority\n      expect(queue.next()).toBeNull(); // blocked by concurrency\n\n      queue.complete(queue.getTask(queue.getTask(t1.id)!.id)!.id);\n    });\n\n    it('getTask utility', () => {\n      const task = queue.add('test');\n      const retrieved = queue.getTask(task.id);\n      expect(retrieved).toBeDefined();\n      expect(retrieved?.payload).toBe('test');\n    });\n  });\n});\n","structuredPatch":[{"oldStart":853,"oldLines":13,"newStart":853,"newLines":16,"lines":[" ","     it('concurrency + priority interaction', () => {","       queue.setConcurrency('default', 1);","-      const t1 = queue.add('first', { priority: 5 });