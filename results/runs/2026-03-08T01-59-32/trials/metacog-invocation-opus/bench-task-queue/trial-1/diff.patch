+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01X6DY7iwiZ3MMR8dvpFMW4t","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012EbXMkJTyZeutA1qHPsvtr","name":"Write","input":{"file_path":"/workspace/src/index.ts","content":"import { randomUUID } from 'node:crypto';\n\n// ============================================================================\n// Types and Interfaces\n// ============================================================================\n\nexport type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'dead-letter';\n\nexport interface TaskOptions {\n  queue?: string;\n  priority?: number;\n  delay?: number;\n  processAt?: Date;\n  maxRetries?: number;\n  backoffDelay?: number;\n  dependencies?: string[];\n}\n\nexport interface Task<T = unknown> {\n  id: string;\n  payload: T;\n  status: TaskStatus;\n  queue: string;\n  priority: number;\n  createdAt: Date;\n  availableAt: Date;\n  attempts: number;\n  maxRetries: number;\n  backoffDelay: number;\n  error?: Error;\n  dependencies: string[];\n  progress: number;\n  progressMessage?: string;\n}\n\nexport interface ScheduleOptions {\n  id?: string;\n  queue?: string;\n  priority?: number;\n}\n\nexport interface Schedule {\n  id: string;\n  cronExpression: string;\n  queue: string;\n  payload: unknown;\n  priority: number;\n  lastRun: Date | null;\n}\n\nexport type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;\nexport type HandlerFn = (task: Task) => Promise<void> | void;\nexport type ProgressListener = (progress: number, message?: string) => void;\n\nexport interface ShutdownResult {\n  completed: number;\n  forceCancelled: number;\n  durationMs: number;\n}\n\n// ============================================================================\n// Internal Queue State\n// ============================================================================\n\ninterface QueueState {\n  tasks: Map<string, Task>;\n  deadLetterTasks: Map<string, Task>;\n  concurrencyLimit: number | null;\n  middlewares: MiddlewareFn[];\n  handler: HandlerFn | null;\n}\n\n// ============================================================================\n// TaskQueue System\n// ============================================================================\n\nconst DEFAULT_QUEUE = 'default';\n\nexport class TaskQueue {\n  private queues: Map<string, QueueState> = new Map();\n  private allTasks: Map<string, Task> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n\n  // --------------------------------------------------------------------------\n  // Internal helpers\n  // --------------------------------------------------------------------------\n\n  private getOrCreateQueue(name: string): QueueState {\n    let q = this.queues.get(name);\n    if (!q) {\n      q = {\n        tasks: new Map(),\n        deadLetterTasks: new Map(),\n        concurrencyLimit: null,\n        middlewares: [],\n        handler: null,\n      };\n      this.queues.set(name, q);\n    }\n    return q;\n  }\n\n  private getQueue(name: string): QueueState | undefined {\n    return this.queues.get(name);\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 1: Basic FIFO Queue\n  // --------------------------------------------------------------------------\n\n  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Queue system is shutting down. Cannot add new tasks.');\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n\n    // Phase 3: Validate priority\n    const priority = options.priority ?? 5;\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 4: Calculate availability time\n    const now = new Date();\n    let availableAt = now;\n    if (options.processAt) {\n      availableAt = options.processAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Phase 7: Validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.allTasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Check for circular dependencies\n    if (dependencies.length > 0) {\n      // We create a temporary task id to check cycles\n      const tempId = randomUUID();\n      // Check if any dependency eventually depends on tempId — but since tempId doesn't exist yet,\n      // we need to check if adding this task creates a cycle among existing deps\n      this.detectCircularDependencies(tempId, dependencies);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      dependencies,\n      progress: 0,\n    };\n\n    const queueState = this.getOrCreateQueue(queueName);\n    queueState.tasks.set(task.id, task);\n    this.allTasks.set(task.id, task);\n\n    return task;\n  }\n\n  next(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queueState = this.getQueue(queueName);\n    if (!queueState) return null;\n\n    // Phase 8: Check concurrency limit\n    if (queueState.concurrencyLimit !== null) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= queueState.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of queueState.tasks.values()) {\n      if (task.status !== 'pending') continue;\n\n      // Phase 4: Skip tasks not yet available\n      if (task.availableAt > now) continue;\n\n      // Phase 7: Skip tasks with unresolved dependencies\n      if (!this.areDependenciesResolved(task)) continue;\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Phase 3 & 4: Sort by priority (ascending = higher priority first),\n    // then by availableAt, then by creation time (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempts++;\n    return task;\n  }\n\n  size(queueName: string = DEFAULT_QUEUE): number {\n    const queueState = this.getQueue(queueName);\n    if (!queueState) return 0;\n\n    let count = 0;\n    for (const task of queueState.tasks.values()) {\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 2: Named Queues\n  // --------------------------------------------------------------------------\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 5: Retry with Backoff / Complete & Fail\n  // --------------------------------------------------------------------------\n\n  complete(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n    task.status = 'completed';\n\n    // Phase 7: Check if any blocked tasks are now unblocked\n    // (handled lazily in next())\n  }\n\n  fail(taskId: string, error?: Error): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n\n    // Check if retries remaining\n    if (task.attempts < task.maxRetries) {\n      // Re-add with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // Phase 6: Move to dead letter queue\n      task.status = 'dead-letter';\n      const queueState = this.getOrCreateQueue(task.queue);\n      queueState.tasks.delete(task.id);\n      queueState.deadLetterTasks.set(task.id, task);\n    }\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 6: Dead Letter Queue\n  // --------------------------------------------------------------------------\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n    const queueState = this.getQueue(queueName);\n    if (!queueState) return [];\n    return Array.from(queueState.deadLetterTasks.values());\n  }\n\n  retryDeadLetterTask(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'dead-letter') {\n      throw new Error(`Task is not in dead letter queue: ${task.status}`);\n    }\n\n    const queueState = this.getOrCreateQueue(task.queue);\n    queueState.deadLetterTasks.delete(task.id);\n\n    // Reset for fresh retry round\n    task.status = 'pending';\n    task.attempts = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n    task.progress = 0;\n    task.progressMessage = undefined;\n\n    queueState.tasks.set(task.id, task);\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n    const queueState = this.getQueue(queueName);\n    if (!queueState) return;\n\n    for (const taskId of queueState.deadLetterTasks.keys()) {\n      this.allTasks.delete(taskId);\n    }\n    queueState.deadLetterTasks.clear();\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 7: Task Dependencies\n  // --------------------------------------------------------------------------\n\n  private areDependenciesResolved(task: Task): boolean {\n    for (const depId of task.dependencies) {\n      const dep = this.allTasks.get(depId);\n      if (!dep || dep.status !== 'completed') {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  private detectCircularDependencies(taskId: string, dependencies: string[]): void {\n    // BFS/DFS from each dependency to see if any path leads back to taskId\n    // Since taskId doesn't exist yet, we check if any dependency chain\n    // forms a cycle among existing tasks plus this new one.\n    const visited = new Set<string>();\n\n    const hasCycle = (currentDeps: string[]): boolean => {\n      for (const depId of currentDeps) {\n        if (visited.has(depId)) continue;\n        visited.add(depId);\n\n        const depTask = this.allTasks.get(depId);\n        if (depTask && depTask.dependencies.length > 0) {\n          if (hasCycle(depTask.dependencies)) return true;\n        }\n      }\n      return false;\n    };\n\n    // Check that no dependency transitively depends on any other dependency\n    // in a way that would create a cycle. Since the new task doesn't exist yet,\n    // the only real cycle would be if we try to depend on something that\n    // already depends on one of our other deps in a circular way.\n    // Actually, since the task doesn't exist yet in allTasks, a cycle can only\n    // happen if dependencies themselves form a cycle (which shouldn't happen\n    // if we validated on insertion). But we should check for direct self-reference\n    // and transitive cycles.\n\n    // More practically: check that none of the dependencies transitively depend\n    // on each other in a cycle. This is already prevented. The real concern is:\n    // no dep should transitively depend on another dep that depends back on it.\n    // Since we validate at insertion time, existing tasks can't have cycles.\n    // The real check needed: ensure no dep has a transitive chain leading to\n    // the same dep — but that's already impossible if we validate at each add().\n\n    // The simplest correct check: all deps must be acyclic among themselves.\n    // Since we validate at insertion, this is guaranteed. So this is a no-op\n    // for most cases. But let's be thorough:\n    for (const depId of dependencies) {\n      visited.clear();\n      visited.add(depId);\n      const depTask = this.allTasks.get(depId);\n      if (depTask && depTask.dependencies.length > 0) {\n        // Check if traversing dep's dependencies leads back to any of our other deps\n        // forming a cycle\n        const stack: string[] = [...depTask.dependencies];\n        while (stack.length > 0) {\n          const current = stack.pop()!;\n          if (dependencies.includes(current) && current !== depId) {\n            // Not necessarily a cycle - one dep depending on another dep is fine\n            // A cycle would be if depId depends on X, and X depends on depId\n          }\n          if (visited.has(current)) continue;\n          visited.add(current);\n          const currentTask = this.allTasks.get(current);\n          if (currentTask) {\n            stack.push(...currentTask.dependencies);\n          }\n        }\n      }\n    }\n\n    // The main thing to check: when we later support tasks depending on this\n    // new task, we should detect if task A depends on B and B depends on A.\n    // For now, since the new task doesn't exist yet in allTasks, we can't form\n    // a cycle. But we need to be ready for future additions.\n    // Actually, I realize: a cycle can happen if:\n    // - Task A exists with deps []\n    // - Task B is added with deps [A]\n    // - Task C is added with deps [B]\n    // - Then Task D is added with deps [C, A] -- no cycle\n    // - But if we try to add Task E with deps [C] and C has deps [B] and B has deps [E] -- E doesn't exist yet\n    // So cycles can only happen if we have an existing task that depends on the new task -- but that's impossible\n    // since the new task's ID isn't known yet.\n\n    // HOWEVER: What about self-dependency? Someone could create task X, then\n    // create task Y with deps [X], then try to add another task Z with deps [Y]\n    // and also Y's deps include [Z] -- but that's impossible since Z doesn't exist\n    // when Y was created.\n\n    // The real case for circular deps: task A is added with deps [B] where B\n    // has deps [C] and we pass deps [C, A] -- but A doesn't exist yet.\n\n    // Actually, re-reading the requirement more carefully: \"Circular dependencies\n    // (direct or indirect) must be detected and rejected at task-creation time.\"\n    // This means: if task A depends on B and B depends on A, that's a cycle.\n    // Since both must exist when referenced, and the new task doesn't exist yet,\n    // the only way to create a cycle is impossible. UNLESS we allow tasks to\n    // specify deps that will be created later... but the requirement says\n    // \"Depending on a non-existent task should cause an error.\" So deps must\n    // already exist.\n\n    // Therefore, cycles among existing, validated tasks are impossible by\n    // construction. The validation is a safety check.\n  }\n\n  getDependencyStatus(taskId: string): { resolved: string[]; pending: string[] } {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    const resolved: string[] = [];\n    const pending: string[] = [];\n\n    for (const depId of task.dependencies) {\n      const dep = this.allTasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        resolved.push(depId);\n      } else {\n        pending.push(depId);\n      }\n    }\n\n    return { resolved, pending };\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 8: Concurrency Control\n  // --------------------------------------------------------------------------\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queueState = this.getOrCreateQueue(queueName);\n    queueState.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number | null; active: number } {\n    const queueState = this.getQueue(queueName);\n    if (!queueState) {\n      return { limit: null, active: 0 };\n    }\n    return {\n      limit: queueState.concurrencyLimit,\n      active: this.getActiveCount(queueName),\n    };\n  }\n\n  private getActiveCount(queueName: string): number {\n    const queueState = this.getQueue(queueName);\n    if (!queueState) return 0;\n    let count = 0;\n    for (const task of queueState.tasks.values()) {\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 9: Progress Tracking and Cancellation\n  // --------------------------------------------------------------------------\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    let listeners = this.progressListeners.get(taskId);\n    if (!listeners) {\n      listeners = new Set();\n      this.progressListeners.set(taskId, listeners);\n    }\n    listeners.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      listeners!.delete(listener);\n      if (listeners!.size === 0) {\n        this.progressListeners.delete(taskId);\n      }\n    };\n  }\n\n  cancel(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Cannot cancel task in status: ${task.status}`);\n    }\n\n    task.status = 'cancelled';\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 10: Recurring Tasks\n  // --------------------------------------------------------------------------\n\n  addSchedule(cronExpression: string, payload: unknown, options: ScheduleOptions = {}): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Queue system is shutting down. Cannot add new schedules.');\n    }\n\n    // Validate cron expression\n    this.parseCron(cronExpression);\n\n    const schedule: Schedule = {\n      id: options.id ?? randomUUID(),\n      cronExpression,\n      queue: options.queue ?? DEFAULT_QUEUE,\n      payload,\n      priority: options.priority ?? 5,\n      lastRun: null,\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule not found: ${scheduleId}`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now: Date = new Date()): Task[] {\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunSchedule(schedule, now)) {\n        const task = this.add(schedule.payload, {\n          queue: schedule.queue,\n          priority: schedule.priority,\n        });\n        schedule.lastRun = now;\n        created.push(task);\n      }\n    }\n\n    return created;\n  }\n\n  private parseCron(expression: string): { minuteInterval: number | null; minute: number; hour: number | null } {\n    const parts = expression.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${expression}. Expected 5 fields.`);\n    }\n\n    const [minuteField, hourField, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Validate the last 3 fields are wildcards (our simple subset)\n    if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {\n      throw new Error(`Unsupported cron expression: ${expression}. Only minute and hour fields are supported.`);\n    }\n\n    // Parse minute field\n    const everyNMinutes = minuteField.match(/^\\*\\/(\\d+)$/);\n    if (everyNMinutes) {\n      const n = parseInt(everyNMinutes[1], 10);\n      if (n <= 0 || n > 59) {\n        throw new Error(`Invalid minute interval: ${n}`);\n      }\n      return { minuteInterval: n, minute: 0, hour: null };\n    }\n\n    const minute = minuteField === '*' ? -1 : parseInt(minuteField, 10);\n    if (minuteField !== '*' && (isNaN(minute) || minute < 0 || minute > 59)) {\n      throw new Error(`Invalid minute value: ${minuteField}`);\n    }\n\n    // Parse hour field\n    const hour = hourField === '*' ? null : parseInt(hourField, 10);\n    if (hourField !== '*' && (hour === null || isNaN(hour) || hour < 0 || hour > 23)) {\n      throw new Error(`Invalid hour value: ${hourField}`);\n    }\n\n    return { minuteInterval: null, minute, hour };\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parsed = this.parseCron(schedule.cronExpression);\n\n    // Every N minutes pattern\n    if (parsed.minuteInterval !== null) {\n      if (now.getMinutes() % parsed.minuteInterval !== 0) return false;\n      // Check if we already ran at this time\n      if (schedule.lastRun) {\n        const lastMinute = Math.floor(schedule.lastRun.getTime() / 60000);\n        const nowMinute = Math.floor(now.getTime() / 60000);\n        if (lastMinute === nowMinute) return false;\n      }\n      return true;\n    }\n\n    // Specific minute and/or hour pattern\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Check minute match\n    if (parsed.minute !== -1 && currentMinute !== parsed.minute) return false;\n\n    // Check hour match\n    if (parsed.hour !== null && currentHour !== parsed.hour) return false;\n\n    // Check if we already ran at this matching time\n    if (schedule.lastRun) {\n      const lastMinute = Math.floor(schedule.lastRun.getTime() / 60000);\n      const nowMinute = Math.floor(now.getTime() / 60000);\n      if (lastMinute === nowMinute) return false;\n    }\n\n    return true;\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 11: Middleware Pipeline\n  // --------------------------------------------------------------------------\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const queueState = this.getOrCreateQueue(queueName);\n    queueState.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: HandlerFn): void {\n    const queueState = this.getOrCreateQueue(queueName);\n    queueState.handler = handler;\n  }\n\n  async process(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {\n    const task = this.next(queueName);\n    if (!task) return null;\n\n    const queueState = this.getQueue(queueName);\n    if (!queueState) return null;\n\n    try {\n      await this.runMiddlewarePipeline(queueState, task);\n      this.complete(task.id);\n    } catch (err) {\n      this.fail(task.id, err instanceof Error ? err : new Error(String(err)));\n    }\n\n    return task;\n  }\n\n  private async runMiddlewarePipeline(queueState: QueueState, task: Task): Promise<void> {\n    const middlewares = [...queueState.middlewares];\n    const handler = queueState.handler;\n\n    let index = 0;\n    const executeNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        await mw(task, executeNext);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    await executeNext();\n  }\n\n  // --------------------------------------------------------------------------\n  // Phase 12: Graceful Shutdown\n  // --------------------------------------------------------------------------\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(timeout);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(timeout: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const callback of this.shutdownCallbacks) {\n      await callback();\n    }\n\n    // Collect all processing tasks\n    const processingTasks: Task[] = [];\n    for (const queueState of this.queues.values()) {\n      for (const task of queueState.tasks.values()) {\n        if (task.status === 'processing') {\n          processingTasks.push(task);\n        }\n      }\n    }\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    if (processingTasks.length === 0) {\n      return {\n        completed,\n        forceCancelled,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to finish, up to timeout\n    const deadline = startTime + timeout;\n    await new Promise<void>((resolve) => {\n      const checkInterval = setInterval(() => {\n        const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n        const completedCount = processingTasks.filter(t => t.status === 'completed' || t.status === 'failed').length;\n        completed = completedCount;\n\n        if (stillProcessing.length === 0 || Date.now() >= deadline) {\n          clearInterval(checkInterval);\n          // Force cancel remaining\n          for (const task of stillProcessing) {\n            task.status = 'cancelled';\n            forceCancelled++;\n          }\n          resolve();\n        }\n      }, 10);\n    });\n\n    return {\n      completed,\n      forceCancelled,\n      durationMs: Date.now() - startTime,\n    };\n  }\n\n  // --------------------------------------------------------------------------\n  // Utility methods\n  // --------------------------------------------------------------------------\n\n  getTask(taskId: string): Task | undefi