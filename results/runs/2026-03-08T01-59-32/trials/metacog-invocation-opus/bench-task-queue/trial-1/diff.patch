ribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ==========================================================================\n  // Phase 1: Basic FIFO Queue\n  // ==========================================================================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = queue.add({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const t1 = queue.next();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = queue.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should transition task to processing state on retrieval', () => {\n      const added = queue.add('test');\n      const retrieved = queue.next();\n      expect(retrieved?.id).toBe(added.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n\n    it('should not retrieve tasks already in processing state', () => {\n      queue.add('test');\n      queue.next(); // gets the task\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should report correct size', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 2: Named Queues\n  // ==========================================================================\n  describe('Phase 2: Named Queues', () => {\n    it('should support named queues', () => {\n      queue.add('email-task', { queue: 'emails' });\n      queue.add('sms-task', { queue: 'sms' });\n\n      const emailTask = queue.next('emails');\n      expect(emailTask?.payload).toBe('email-task');\n\n      const smsTask = queue.next('sms');\n      expect(smsTask?.payload).toBe('sms-task');\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.add('default-task');\n      const task = queue.next();\n      expect(task?.payload).toBe('default-task');\n    });\n\n    it('should keep queues independent', () => {\n      queue.add('task-a', { queue: 'A' });\n      expect(queue.next('B')).toBeNull();\n      expect(queue.next('A')?.payload).toBe('task-a');\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queue: 'alpha' });\n      queue.add('b', { queue: 'beta' });\n      const names = queue.getQueues();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should report size per queue', () => {\n      queue.add('a', { queue: 'x' });\n      queue.add('b', { queue: 'x' });\n      queue.add('c', { queue: 'y' });\n      expect(queue.size('x')).toBe(2);\n      expect(queue.size('y')).toBe(1);\n      expect(queue.size('z')).toBe(0);\n    });\n  });\n\n  // ==========================================================================\n  // Phase 3: Priority\n  // ==========================================================================\n  describe('Phase 3: Priority', () => {\n    it('should return higher priority tasks first', () => {\n      queue.add('low', { priority: 8 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should default to priority 5', () => {\n      const task = queue.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 3 });\n      queue.add('second', { priority: 3 });\n      queue.add('third', { priority: 3 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => queue.add('test', { priority: 0 })).toThrow();\n      expect(() => queue.add('test', { priority: 11 })).toThrow();\n      expect(() => queue.add('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.add('test', { priority: 2 });\n      expect(task.priority).toBe(2);\n    });\n\n    it('should maintain priority per queue', () => {\n      queue.add('q1-low', { queue: 'q1', priority: 10 });\n      queue.add('q1-high', { queue: 'q1', priority: 1 });\n      queue.add('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.next('q1')?.payload).toBe('q1-high');\n      expect(queue.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ==========================================================================\n  // Phase 4: Delayed Tasks\n  // ==========================================================================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their available time', () => {\n      queue.add('delayed', { delay: 60000 }); // 60 seconds from now\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after their available time', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('ready', { processAt: past });\n      const task = queue.next();\n      expect(task?.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n      queue.add('delayed', { delay: 60000, priority: 1 }); // high priority but delayed\n      queue.add('immediate', { priority: 10 }); // low priority but available\n      expect(queue.next()?.payload).toBe('immediate');\n    });\n\n    it('should indicate when task becomes available', () => {\n      const task = queue.add('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should support processAt date', () => {\n      const futureDate = new Date(Date.now() + 60000);\n      const task = queue.add('future', { processAt: futureDate });\n      expect(task.availableAt.getTime()).toBe(futureDate.getTime());\n    });\n\n    it('should order available delayed tasks by availability time then priority', () => {\n      const t1 = new Date(Date.now() - 3000);\n      const t2 = new Date(Date.now() - 1000);\n\n      queue.add('earlier', { processAt: t1, priority: 5 });\n      queue.add('later', { processAt: t2, priority: 5 });\n\n      expect(queue.next()?.payload).toBe('earlier');\n      expect(queue.next()?.payload).toBe('later');\n    });\n  });\n\n  // ==========================================================================\n  // Phase 5: Retry with Backoff\n  // ==========================================================================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark a task as completed', () => {\n      const task = queue.add('test');\n      queue.next();\n      queue.complete(task.id);\n      expect(task.status).toBe('completed');\n    });\n\n    it('should mark a task as failed', () => {\n      const task = queue.add('test', { maxRetries: 0 });\n      queue.next();\n      queue.fail(task.id, new Error('oops'));\n      expect(task.status).toBe('dead-letter');\n      expect(task.error?.message).toBe('oops');\n    });\n\n    it('should retry failed tasks with backoff delay', () => {\n      const task = queue.add('test', { maxRetries: 3, backoffDelay: 1000 });\n      queue.next();\n      queue.fail(task.id, new Error('attempt 1'));\n\n      // Task should be pending again but delayed\n      expect(task.status).toBe('pending');\n      expect(task.attempts).toBe(1);\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should use exponential backoff', () => {\n      const task = queue.add('test', { maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt\n      queue.next();\n      const beforeFail1 = Date.now();\n      queue.fail(task.id, new Error('fail 1'));\n      // Backoff: 1000 * 2^0 = 1000ms\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail1 + 1000 - 10);\n    });\n\n    it('should track attempt count', () => {\n      const task = queue.add('test', { maxRetries: 3, backoffDelay: 0 });\n      expect(task.attempts).toBe(0);\n\n      // Process and fail with a past time so it becomes available immediately\n      queue.next();\n      task.availableAt = new Date(0); // hack for testing\n      queue.fail(task.id);\n      task.availableAt = new Date(0);\n      expect(task.attempts).toBe(1);\n    });\n\n    it('should default to 3 retries', () => {\n      const task = queue.add('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should throw when completing a non-processing task', () => {\n      const task = queue.add('test');\n      expect(() => queue.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing a non-processing task', () => {\n      const task = queue.add('test');\n      expect(() => queue.fail(task.id)).toThrow();\n    });\n  });\n\n  // ==========================================================================\n  // Phase 6: Dead Letter Queue\n  // ==========================================================================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ after exhausting retries', () => {\n      const task = queue.add('test', { maxRetries: 1, backoffDelay: 0 });\n\n      // Attempt 1\n      queue.next();\n      queue.fail(task.id, new Error('fail'));\n      task.availableAt = new Date(0); // make available immediately\n\n      // Attempt 2 (last retry)\n      queue.next();\n      queue.fail(task.id, new Error('fail again'));\n\n      // Should now be in DLQ\n      expect(task.status).toBe('dead-letter');\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n    });\n\n    it('should retain error info on dead-lettered tasks', () => {\n      const task = queue.add('test', { maxRetries: 0 });\n      queue.next();\n      queue.fail(task.id, new Error('permanent failure'));\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].error?.message).toBe('permanent failure');\n      expect(dlq[0].attempts).toBe(1);\n    });\n\n    it('should allow retrying dead-lettered tasks', () => {\n      const task = queue.add('test', { maxRetries: 0 });\n      queue.next();\n      queue.fail(task.id, new Error('fail'));\n\n      const retried = queue.retryDeadLetterTask(task.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempts).toBe(0);\n      expect(retried.error).toBeUndefined();\n\n      const next = queue.next();\n      expect(next?.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      const t1 = queue.add('a', { maxRetries: 0 });\n      const t2 = queue.add('b', { maxRetries: 0 });\n      queue.next();\n      queue.fail(t1.id