@@ -0,0 +1,142 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  throw new Error('No source found');
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visited = new Set<string>();
+  visited.add(`${sr},${sc}`);
+
+  const beams: Beam[] = [{ row: sr, col: sc, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const nextBeams: Beam[] = [];
+
+    for (const beam of beams) {
+      const [nr, nc] = advance(beam.row, beam.col, beam.dir);
+
+      if (!inBounds(nr, nc, rows, cols)) continue;
+
+      visited.add(`${nr},${nc}`);
+
+      if (grid[nr][nc] === '^') {
+        nextBeams.push({ row: nr, col: nc, dir: 'down-left' });
+        nextBeams.push({ row: nr, col: nc, dir: 'down-right' });
+      } else {
+        nextBeams.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+
+    beams.length = 0;
+    beams.push(...nextBeams);
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  // Trace a beam from a position in a direction until it hits a splitter or exits.
+  // Returns: the splitter index it hits (or -1 if it exits the grid),
+  // plus a boolean indicating if the path exits the grid (true) or hits a splitter (false).
+  function traceBeam(
+    startRow: number,
+    startCol: number,
+    dir: Direction,
+    splitterIndex: Map<string, number>
+  ): number {
+    let r = startRow;
+    let c = startCol;
+
+    for (let step = 0; step < rows; step++) {
+      const [nr, nc] = advance(r, c, dir);
+      if (!inBounds(nr, nc, rows, cols)) {
+        return -1; // exits grid
+      }
+      const key = `${nr},${nc}`;
+      if (grid[nr][nc] === '^' && splitterIndex.has(key)) {
+        return splitterIndex.get(key)!;
+      }
+      r = nr;
+      c = nc;
+    }
+    return -1; // should not reach here in valid grids
+  }
+
+  // Collect all splitters
+  const splitters: [number, number][] = [];
+  const splitterIndex = new Map<string, number>();
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === '^') {
+        const key = `${r},${c}`;
+        splitterIndex.set(key, splitters.length);
+        splitters.push([r, c]);
+      }
+    }
+  }
+
+  if (splitters.length === 0) {
+    // No splitters: just one straight-down path (if it exits)
+    // The beam goes straight down from source. It always exits at the bottom.
+    return 1n;
+  }
+
+  // For each splitter, compute which splitter (or exit) its left and right children reach
+  const leftChild: number[] = new Array(splitters.length);
+  const rightChild: number[] = new Array(splitters.length);
+
+  for (let i = 0; i < splitters.length; i++) {
+    const [r, c] = splitters[i];
+    leftChild[i] = traceBeam(r, c, 'down-left', splitterIndex);
+    rightChild[i] = traceBeam(r, c, 'down-right', splitterIndex);
+  }
+
+  // Compute path count for each splitter using memoization
+  // pathCount(splitter) = pathCount(leftChild) + pathCount(rightChild)
+  // where pathCount(exit) = 1n
+  const memo = new Map<number, bigint>();
+
+  function pathCount(splitterIdx: number): bigint {
+    if (splitterIdx === -1) return 1n; // exit
+    if (memo.has(splitterIdx)) return memo.get(splitterIdx)!;
+
+    const result = pathCount(leftChild[splitterIdx]) + pathCount(rightChild[splitterIdx]);
+    memo.set(splitterIdx, result);
+    return result;
+  }
+
+  // Find which splitter the source beam hits first
+  const firstSplitter = traceBeam(sr, sc, 'down', splitterIndex);
+
+  return pathCount(firstSplitter);
+}
