+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example 2: two splitters', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('beam exits left boundary', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Source at (0,0), moves down to (1,0) hits splitter.
+    // down-left: (2,-1) absorbed. down-right: (2,1).
+    // Visited: (0,0), (1,0), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example 2: two splitters', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('beam exits boundary', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // From (1,0) splitter: left exits, right exits -> 2 paths
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('chain of splitters', () => {
+    // Three levels of splitting: 2^3 = 8 paths
+    const grid = [
+      ['.', '.', '.', '.', 'S', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '^', '.', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(8n);
+  });
+});
