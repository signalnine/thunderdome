chine: Machine = {\n      target: [true, false],\n      buttons: [[0], [1]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('returns empty array when target is all off', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('finds minimum button presses', () => {\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles overlapping buttons', () => {\n    const machine: Machine = {\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0, 1]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('returns lexicographically smallest when tied', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles a single button that toggles all lights', () => {\n    const machine: Machine = {\n      target: [true, true, true],\n      buttons: [[0, 1, 2]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles no buttons', () => {\n    expect(solveToggle({ target: [false], buttons: [] })).toEqual([]);\n    expect(solveToggle({ target: [true], buttons: [] })).toBeNull();\n  });\n\n  it('handles empty target', () => {\n    const result = solveToggle({ target: [], buttons: [[]] });\n    expect(result).toEqual([]);\n  });\n\n  it('handles multiple free variables and picks minimum weight', () => {\n    // 1 light, 3 buttons all toggle light 0\n    // Pressing any odd number of them works (1 press is min)\n    // Lex smallest with 1 press: [0]\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0], [0]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles buttons that affect no lights', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [[], [0]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([1]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles larger system', () => {\n    // 5 lights, 5 buttons, identity-like mapping\n    const machine: Machine = {\n      target: [true, true, true, true, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0, 1, 2, 3, 4]);\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n\n  it('handles performance with moderate free variables', () => {\n    // 3 lights, 15 buttons that all affect the same light\n    // Lots of free variables but solution should be found quickly\n    const buttons: number[][] = [];\n    for (let i = 0; i < 15; i++) buttons.push([0]);\n    const machine: Machine = {\n      target: [true],\n      buttons,\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(1); // Minimum is 1 press\n    expect(verifyToggle(machine, result)).toBe(true);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('solves a simple case', () => {\n    const result = solveCounter([1, 0], [[0], [1]], 2);\n    expect(result).toEqual([1, 0]);\n    expect(verifyCounter([1, 0], [[0], [1]], 2, result)).toBe(true);\n  });\n\n  it('returns null when no solution exists', () => {\n    const result = solveCounter([1, 0], [[0, 1]], 2);\n    expect(result).toBeNull();\n  });\n\n  it('handles modular arithmetic', () => {\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n    expect(verifyCounter([3], [[0]], 5, result)).toBe(true);\n  });\n\n  it('finds minimum total presses', () => {\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('handles multiple buttons and counters', () => {\n    const result = solveCounter([1, 1], [[0], [1]], 3);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 1], [[0], [1]], 3, result)).toBe(true);\n  });\n\n  it('handles mod 7 with larger values', () => {\n    // target: [6], mod 7, button 0: affects [0]\n    // Press 6 times → counter = 6\n    const result = solveCounter([6], [[0]], 7);\n    expect(result).toEqual([6]);\n    expect(verifyCounter([6], [[0]], 7, result)).toBe(true);\n  });\n\n  it('returns empty array for zero targets with no buttons', () => {\n    expect(solveCounter([0, 0], [], 5)).toEqual([]);\n    expect(solveCounter([1], [], 5)).toBeNull();\n  });\n\n  it('minimizes total presses with free variables', () => {\n    // target: [0], mod 3\n    // button 0: affects [0]\n    // button 1: affects [0]\n    // Solutions: (0,0)→sum=0, (1,2)→sum=3, (2,1)→sum=3\n    // Minimum is [0, 0]\n    const result = solveCounter([0], [[0], [0]], 3);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('picks lex smallest when tied on total presses', () => {\n    // target: [1], mod 3\n    // button 0: affects [0]\n    // button 1: affects [0]\n    // Solutions: (0,1)→sum=1, (1,0)→sum=1, (2,2)→sum=4\n    // Minimum sum is 1; lex smallest is [0, 1]\n    const result = solveCounter([1], [[0], [0]], 3);\n    expect(result).toEqual([0, 1]);\n    expect(verifyCounter([1], [[0], [0]], 3, result)).toBe(true);\n  });\n\n  it('handles overlapping button effects', () => {\n    // target: [1, 2], mod 5\n    // button 0: affects [0, 1] (both counters get +1 per press)\n    // button 1: affects [1] (only counter 1 gets +1 per press)\n    // System: b0 = 1 (mod 5), b0 + b1 = 2 (mod 5) → b1 = 1\n    // Solution: [1, 1]\n    const result = solveCounter([1, 2], [[0, 1], [1]], 5);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 2], [[0, 1], [1]], 5, result)).toBe(true);\n  });\n\n  it('handles larger prime modulus', () => {\n    // target: [10], mod 97\n    // button 0: affects [0]\n    const result = solveCounter([10], [[0]], 97);\n    expect(result).toEqual([10]);\n    expect(verifyCounter([10], [[0]], 97, result)).toBe(true);\n  });\n\n  it('handles mod 2 equivalently to toggle', () => {\n    // target: [1, 0, 1], mod 2\n    // button 0: affects [0, 1]\n    // button 1: affects [1, 2]\n    const result = solveCounter([1, 0, 1], [[0, 1], [1, 2]], 2);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 0, 1], [[0, 1], [1, 2]], 2, result)).toBe(true);\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":9,"newStart":1,"newLines":39,"lines":[" import { describe, it, expect } from 'vitest';","-import { solveToggle, solveCounter } from './index.js';","+import { solveToggle, solveCounter, Machine } from './index.js';"," ","+// Helper to verify a toggle solution","+function verifyToggle(machine: Machine, solution: number[] | null): boolean {","+  if (solution === null) return true; // Can't verify null","+  const state = new Array(machine.target.length).fill(false);","+  for (const btn of solution) {","+    for (const light of machine.buttons[btn]) {","+      state[light] = !state[light];","+    }","+  }","+  return machine.target.every((t, i) => t === state[i]);","+}","+","+// Helper to verify a counter solution","+function verifyCounter(","+  lights: number[],","+  buttons: number[][],","+  modulus: number,","+  solution: number[] | null","+): boolean {","+  if (solution === null) return true;","+  const state = new Array(lights.length).fill(0);","+  for (let i = 0; i < solution.length; i++) {","+    for (let press = 0; press < so