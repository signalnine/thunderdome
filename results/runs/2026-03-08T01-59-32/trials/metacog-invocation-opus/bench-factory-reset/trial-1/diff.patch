 (let row = curRow; row < numEqs; row++) {\n      if (aug[row][col] !== 0) {\n        pivotRow = row;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue; // No pivot in this column, it's a free variable\n\n    // Swap rows\n    [aug[curRow], aug[pivotRow]] = [aug[pivotRow], aug[curRow]];\n\n    // Scale pivot row\n    const inv = modInverse(aug[curRow][col], p);\n    for (let j = col; j <= numVars; j++) {\n      aug[curRow][j] = mod(aug[curRow][j] * inv, p);\n    }\n\n    // Eliminate column in all other rows\n    for (let row = 0; row < numEqs; row++) {\n      if (row === curRow || aug[row][col] === 0) continue;\n      const factor = aug[row][col];\n      for (let j = col; j <= numVars; j++) {\n        aug[row][j] = mod(aug[row][j] - factor * aug[curRow][j], p);\n      }\n    }\n\n    pivotCol.push(col);\n    curRow++;\n  }\n\n  const rank = curRow;\n\n  // Check consistency: any row with all-zero coefficients but non-zero RHS\n  for (let row = rank; row < numEqs; row++) {\n    if (aug[row][numVars] !== 0) {\n      return null; // Inconsistent system\n    }\n  }\n\n  // Identify pivot and free variables\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numVars; j++) {\n    if (!pivotColSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // Build particular solution (set all free variables to 0)\n  const particular = new Array(numVars).fill(0);\n  for (let i = rank - 1; i >= 0; i--) {\n    particular[pivotCol[i]] = aug[i][numVars];\n  }\n\n  // Build nullspace basis vectors\n  const nullspace: number[][] = [];\n  for (const fv of freeVars) {\n    const vec = new Array(numVars).fill(0);\n    vec[fv] = 1;\n    // For each pivot variable, compute its value when this free var = 1\n    for (let i = 0; i < rank; i++) {\n      vec[pivotCol[i]] = mod(-aug[i][fv], p);\n    }\n    nullspace.push(vec);\n  }\n\n  return { particular, freeVars, nullspace };\n}\n\n/**\n * Solve the toggle puzzle over GF(2).\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build matrix A where A[light][button] = 1 if button toggles light\n  const A: number[][] = [];\n  const b: number[] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons).fill(0);\n    A.push(row);\n    b.push(target[i] ? 1 : 0);\n  }\n  for (let j = 0; j < numButtons; j++) {\n    for (const light of buttons[j]) {\n      if (light >= 0 && light < numLights) {\n        A[light][j] = 1;\n      }\n    }\n  }\n\n  const result = solveLinearSystem(A, b, numButtons, 2);\n  if (result === null) return null;\n\n  const { particular, freeVars, nullspace } = result;\n  const numFree = freeVars.length;\n\n  // Enumerate all 2^numFree combinations to find minimum-weight, lex-smallest solution\n  let bestSolution: number[] | null = null;\n  let bestCount = Infinity;\n\n  // For large number of free variables, use meet-in-the-middle\n  if (numFree <= 25) {\n    // Direct enumeration\n    const total = 1 << numFree;\n    for (let mask = 0; mask < total; mask++) {\n      const sol = particular.slice();\n      for (let k = 0; k < numFree; k++) {\n        if (mask & (1 << k)) {\n          for (let j = 0; j < numButtons; j++) {\n            sol[j] = mod(sol[j] + nullspace[k][j], 2);\n          }\n        }\n      }\n\n      const pressed: number[] = [];\n      for (let j = 0; j < numButtons; j++) {\n        if (sol[j] === 1) pressed.push(j);\n      }\n\n      if (pressed.length < bestCount ||\n          (pressed.length === bestCount && bestSolution !== null && lexSmaller(pressed, bestSolution))) {\n        bestCount = pressed.length;\n        bestSolution = pressed;\n      }\n    }\n  } else {\n    // Meet-in-the-middle approach for large free variable count\n    const half1 = Math.floor(numFree / 2);\n    const half2 = numFree - half1;\n\n    // For each combination o