@@ -0,0 +1,436 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function mod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+function modInverse(a: number, p: number): number {
+  a = mod(a, p);
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return mod(old_s, p);
+}
+
+interface LinearSolution {
+  particular: number[];
+  freeVars: number[];
+  nullspace: number[][];
+}
+
+function solveLinearSystem(
+  A: number[][],
+  b: number[],
+  numVars: number,
+  p: number
+): LinearSolution | null {
+  const numEqs = A.length;
+
+  const aug: number[][] = [];
+  for (let i = 0; i < numEqs; i++) {
+    const row = new Array(numVars + 1).fill(0);
+    for (let j = 0; j < numVars; j++) {
+      row[j] = mod(A[i][j], p);
+    }
+    row[numVars] = mod(b[i], p);
+    aug.push(row);
+  }
+
+  const pivotCol: number[] = [];
+  let curRow = 0;
+  for (let col = 0; col < numVars && curRow < numEqs; col++) {
+    let pivotRow = -1;
+    for (let row = curRow; row < numEqs; row++) {
+      if (aug[row][col] !== 0) {
+        pivotRow = row;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [aug[curRow], aug[pivotRow]] = [aug[pivotRow], aug[curRow]];
+
+    const inv = modInverse(aug[curRow][col], p);
+    for (let j = col; j <= numVars; j++) {
+      aug[curRow][j] = mod(aug[curRow][j] * inv, p);
+    }
+
+    for (let row = 0; row < numEqs; row++) {
+      if (row === curRow || aug[row][col] === 0) continue;
+      const factor = aug[row][col];
+      for (let j = col; j <= numVars; j++) {
+        aug[row][j] = mod(aug[row][j] - factor * aug[curRow][j], p);
+      }
+    }
+
+    pivotCol.push(col);
+    curRow++;
+  }
+
+  const rank = curRow;
+
+  for (let row = rank; row < numEqs; row++) {
+    if (aug[row][numVars] !== 0) {
+      return null;
+    }
+  }
+
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < numVars; j++) {
+    if (!pivotColSet.has(j)) {
+      freeVars.push(j);
+    }
+  }
+
+  const particular = new Array(numVars).fill(0);
+  for (let i = 0; i < rank; i++) {
+    particular[pivotCol[i]] = aug[i][numVars];
+  }
+
+  const nullspace: number[][] = [];
+  for (const fv of freeVars) {
+    const vec = new Array(numVars).fill(0);
+    vec[fv] = 1;
+    for (let i = 0; i < rank; i++) {
+      vec[pivotCol[i]] = mod(-aug[i][fv], p);
+    }
+    nullspace.push(vec);
+  }
+
+  return { particular, freeVars, nullspace };
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  const A: number[][] = [];
+  const b: number[] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons).fill(0);
+    A.push(row);
+    b.push(target[i] ? 1 : 0);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const light of buttons[j]) {
+      if (light >= 0 && light < numLights) {
+        A[light][j] ^= 1;
+      }
+    }
+  }
+
+  const result = solveLinearSystem(A, b, numButtons, 2);
+  if (result === null) return null;
+
+  const { particular, freeVars, nullspace } = result;
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const pressed: number[] = [];
+    for (let j = 0; j < numButtons; j++) {
+      if (particular[j] === 1) pressed.push(j);
+    }
+    return pressed;
+  }
+
+  // For GF(2), use meet-in-the-middle when numFree is large
+  let bestSolution: number[] | null = null;
+  let bestCount = Infinity;
+
+  if (numFree <= 20) {
+    // Direct enumeration: 2^20 = ~1M, fast enough
+    const total = 1 << numFree;
+    for (let mask = 0; mask < total; mask++) {
+      const sol = particular.slice();
+      for (let k = 0; k < numFree; k++) {
+        if (mask & (1 << k)) {
+          const ns = nullspace[k];
+          for (let j = 0; j < numButtons; j++) {
+            sol[j] ^= ns[j];
+          }
+        }
+      }
+
+      let count = 0;
+      for (let j = 0; j < numButtons; j++) {
+        count += sol[j];
+      }
+
+      if (count < bestCount) {
+        bestCount = count;
+        const pressed: number[] = [];
+        for (let j = 0; j < numButtons; j++) {
+          if (sol[j] === 1) pressed.push(j);
+        }
+        bestSolution = pressed;
+      } else if (count === bestCount) {
+        const pressed: number[] = [];
+        for (let j = 0; j < numButtons; j++) {
+          if (sol[j] === 1) pressed.push(j);
+        }
+        if (bestSolution !== null && lexSmaller(pressed, bestSolution)) {
+          bestSolution = pressed;
+        }
+      }
+    }
+  } else {
+    // For large free variable counts, use greedy coordinate descent.
+    // Start from the particular solution and greedily flip nullspace vectors.
+    // Restart from multiple starting points to increase chance of finding global optimum.
+    const sol = particular.slice();
+
+    // Greedy: repeatedly flip the nullspace vector that gives biggest weight reduction
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let k = 0; k < numFree; k++) {
+        // Count how many 1s would flip to 0 vs 0s that would flip to 1
+        let delta = 0;
+        const ns = nullspace[k];
+        for (let j = 0; j < numButtons; j++) {
+          if (ns[j] === 1) {
+            delta += sol[j] === 1 ? -1 : 1;
+          }
+        }
+        if (delta < 0) {
+          // Flipping reduces weight
+          for (let j = 0; j < numButtons; j++) {
+            sol[j] ^= ns[j];
+          }
+          improved = true;
+        }
+      }
+    }
+
+    // Also try flipping pairs for better results
+    improved = true;
+    while (improved) {
+      improved = false;
+      for (let k1 = 0; k1 < numFree; k1++) {
+        for (let k2 = k1 + 1; k2 < numFree; k2++) {
+          let delta = 0;
+          for (let j = 0; j < numButtons; j++) {
+            const flip = nullspace[k1][j] ^ nullspace[k2][j];
+            if (flip === 1) {
+              delta += sol[j] === 1 ? -1 : 1;
+            }
+          }
+          if (delta < 0) {
+            for (let j = 0; j < numButtons; j++) {
+              sol[j] ^= nullspace[k1][j];
+              sol[j] ^= nullspace[k2][j];
+            }
+            improved = true;
+          }
+        }
+      }
+    }
+
+    const pressed: number[] = [];
+    for (let j = 0; j < numButtons; j++) {
+      if (sol[j] === 1) pressed.push(j);
+    }
+    bestCount = pressed.length;
+    bestSolution = pressed;
+  }
+
+  return bestSolution;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every(v => mod(v, modulus) === 0) ? [] : null;
+  }
+
+  const A: number[][] = [];
+  const b: number[] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons).fill(0);
+    A.push(row);
+    b.push(mod(lights[i], modulus));
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const counter of buttons[j]) {
+      if (counter >= 0 && counter < numCounters) {
+        A[counter][j] = mod(A[counter][j] + 1, modulus);
+      }
+    }
+  }
+
+  const result = solveLinearSystem(A, b, numButtons, modulus);
+  if (result === null) return null;
+
+  const { particular, freeVars, nullspace } = result;
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    return particular.map(v => mod(v, modulus));
+  }
+
+  // Estimate total enumeration cost
+  let totalCombinations = 1;
+  let overflow = false;
+  for (let k = 0; k < numFree; k++) {
+    totalCombinations *= modulus;
+    if (totalCombinations > 1_500_000) {
+      overflow = true;
+      break;
+    }
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  if (!overflow) {
+    // Direct enumeration using incremental solution updates.
+    // Instead of recomputing from scratch, maintain a running solution
+    // and update it when a free variable changes.
+    const freeValues = new Array(numFree).fill(0);
+    const sol = particular.map(v => mod(v, modulus));
+
+    // Evaluate initial solution
+    let sum = 0;
+    for (let j = 0; j < numButtons; j++) sum += sol[j];
+    bestSum = sum;
+    bestSolution = sol.slice();
+
+    for (let iter = 1; iter < totalCombinations; iter++) {
+      // Increment odometer and update solution incrementally
+      for (let k = numFree - 1; k >= 0; k--) {
+        const oldVal = freeValues[k];
+        freeValues[k]++;
+        if (freeValues[k] >= modulus) {
+          freeValues[k] = 0;
+          // This free variable wrapped: subtract oldVal * nullspace[k] and continue carry
+          const ns = nullspace[k];
+          for (let j = 0; j < numButtons; j++) {
+            if (ns[j] !== 0) {
+              sol[j] = mod(sol[j] - oldVal * ns[j], modulus);
+            }
+          }
+        } else {
+          // This free variable incremented by 1: add nullspace[k]
+          const ns = nullspace[k];
+          for (let j = 0; j < numButtons; j++) {
+            if (ns[j] !== 0) {
+              sol[j] = mod(sol[j] + ns[j], modulus);
+            }
+          }
+          break;
+        }
+      }
+
+      sum = 0;
+      for (let j = 0; j < numButtons; j++) sum += sol[j];
+
+      if (sum < bestSum || (sum === bestSum && bestSolution !== null && lexSmallerArr(sol, bestSolution))) {
+        bestSum = sum;
+        bestSolution = sol.slice();
+      }
+    }
+  } else {
+    // For large search spaces with GF(p), use coordinate descent optimization.
+    // Optimize one free variable at a time while holding others fixed.
+    // Restart from multiple points to escape local optima.
+    const numRestarts = Math.min(modulus * 2, 200);
+
+    for (let restart = 0; restart < numRestarts; restart++) {
+      const currentFreeValues = new Array(numFree).fill(0);
+
+      if (restart > 0) {
+        for (let k = 0; k < numFree; k++) {
+          currentFreeValues[k] = (restart * (k + 1) * 7 + k * 13) % modulus;
+        }
+      }
+
+      let improved = true;
+      while (improved) {
+        improved = false;
+        for (let k = 0; k < numFree; k++) {
+          // Compute base solution without free var k's contribution
+          const baseSol = particular.slice();
+          for (let fk = 0; fk < numFree; fk++) {
+            if (fk !== k && currentFreeValues[fk] !== 0) {
+              const ns = nullspace[fk];
+              const fv = currentFreeValues[fk];
+              for (let j = 0; j < numButtons; j++) {
+                baseSol[j] += fv * ns[j];
+              }
+            }
+          }
+
+          let bestVal = currentFreeValues[k];
+          let bestLocalSum = Infinity;
+          let bestLocalSol: number[] | null = null;
+
+          const ns = nullspace[k];
+          for (let v = 0; v < modulus; v++) {
+            let sum = 0;
+            const sol = new Array(numButtons);
+            for (let j = 0; j < numButtons; j++) {
+              sol[j] = mod(baseSol[j] + v * ns[j], modulus);
+              sum += sol[j];
+            }
+
+            if (sum < bestLocalSum || (sum === bestLocalSum && bestLocalSol !== null && lexSmallerArr(sol, bestLocalSol))) {
+              bestLocalSum = sum;
+              bestVal = v;
+              bestLocalSol = sol;
+            }
+          }
+
+          if (bestVal !== currentFreeValues[k]) {
+            currentFreeValues[k] = bestVal;
+            improved = true;
+          }
+
+          if (bestLocalSol !== null && (bestLocalSum < bestSum ||
+              (bestLocalSum === bestSum && bestSolution !== null && lexSmallerArr(bestLocalSol, bestSolution)))) {
+            bestSum = bestLocalSum;
+            bestSolution = bestLocalSol;
+          }
+        }
+      }
+    }
+  }
+
+  return bestSolution;
+}
