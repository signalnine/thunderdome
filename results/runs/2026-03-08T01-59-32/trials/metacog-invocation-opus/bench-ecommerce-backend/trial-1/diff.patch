+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_015WxX1uQsymrfTrpGTE46ta","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014eyw4FuBH89CUrFsRPYg44","name":"Write","input":{"file_path":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\n\ndescribe('Catalog Service', () => {\n  let bus: EventBus;\n  let catalog: ReturnType<typeof createCatalogService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    catalog = createCatalogService(bus);\n  });\n\n  it('should create a product and return an id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeTruthy();\n  });\n\n  it('should get a product by id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for unknown product', () => {\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products by category', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n  });\n\n  it('should search products by name', () => {\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Gizmo', 2, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('should search products by category', () => {\n    catalog.createProduct('A', 1, 'electronics');\n    catalog.createProduct('B', 2, 'clothing');\n    const results = catalog.searchProducts('electron');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { price: 14.99 });\n    expect(catalog.getProduct(id)!.price).toBe(14.99);\n  });\n\n  it('should remove a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n  });\n\n  it('should return false when removing nonexistent product', () => {\n    expect(catalog.removeProduct('nope')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // Wait for async emit\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('should set and get stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve insufficient stock', () => {\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n  });\n\n  it('should release reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', async () => {\n    let alertFired = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(alertFired).toBe(true);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('should create a cart', () => {\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n  });\n\n  it('should add items to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n  });\n\n  it('should consolidate same product items', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove item from cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([]);\n  });\n\n  it('should clear cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.clearCart(id);\n    expect(cart.getCart(id)!.items).toEqual([]);\n  });\n\n  it('should update quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)!.items[0].quantity).toBe(10);\n  });\n\n  it('should return null for unknown cart', () => {\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('should calculate total with tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of 90\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product creation events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 25, category: 'cat' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('should create an order in pending status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const order = orders.getOrder(id);\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('should update order status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order:created event', async () => {\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n  });\n\n  it('should emit status change event with previous status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvent).toBeTruthy();\n    const payload = statusEvent!.payload as { previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders by user', () => {\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user1', 'c2', 20);\n    orders.createOrder('user2', 'c3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n  });\n\n  it('should cancel an order', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund unknown transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('Notification Service', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n  });\n\n  it('should subscribe a user', () => {\n    notifications.subscribe('user1');\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n\n  it('should receive notifications on order creation', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBe(1);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should receive notifications on order status change', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBe(2);\n    expect(notifs[1].type).toBe('order_status');\n  });\n\n  it('should receive notifications on payment processed', async () => {\n    notifications.subscribe('user1');\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1' });\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not notify unsubscribed users', async () => {\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n  });\n\n  it('should count events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'A', price: 10, category: 'cat' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'B', price: 20, category: 'cat' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 't1', amount: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o2', status: PaymentStatus.SUCCESS, transactionId: 't2', amount: 50 });\n    expect(analytics.getRevenue()).toBe(150);\n  });\n\n  it('should not count failed payments as revenue', async () => {\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products', async () => {\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n});\n\ndescribe('Integration: Full E2E Flow', () => {\n  it('should process a complete order flow', async () => {\n    const bus = new EventBus();\n\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');\n\n    // Wait for product creation events to propagate\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n\n    // Wait for cart events to propagate\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Calculate pricing\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const total = pricing.calculateTotal(items);\n\n    expect(total.subtotal).toBe(1059.97); // 999.99 + 2*29.99\n    expect(total.tax).toBeCloseTo(106, 0);\n\n    // Reserve inventory\n    for (const item of cart.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, total.total);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.CONFIRMED);\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n\n    // Check inventory was reduced\n    expect(inventory.getStock(p1)).toBe(9);\n    expect(inventory.getStock(p2)).toBe(48);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":284,"cache_read_input_tokens":29198,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":284},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1bba643d-9f6b-4ba7-a5db-312bc59a79f5","uuid":"0750958f-4927-42b1-aa2e-3933c6075477"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014eyw4FuBH89CUrFsRPYg44","type":"tool_result","content":"File created successfully at: /workspace/tests/services.test.ts"}]},"parent_tool_use_id":null,"session_id":"1bba643d-9f6b-4ba7-a5db-312bc59a79f5","uuid":"68ba4673-de11-40a9-ad9d-83add5b88f58","tool_use_result":{"type":"create","filePath":"/workspace/tests/services.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/bus.js';\nimport { Events, OrderStatus, PaymentStatus } from '../src/types.js';\nimport { createCatalogService } from '../src/catalog/index.js';\nimport { createInventoryService } from '../src/inventory/index.js';\nimport { createCartService } from '../src/cart/index.js';\nimport { createPricingService } from '../src/pricing/index.js';\nimport { createOrderService } from '../src/orders/index.js';\nimport { createPaymentService } from '../src/payment/index.js';\nimport { createNotificationService } from '../src/notifications/index.js';\nimport { createAnalyticsService } from '../src/analytics/index.js';\n\ndescribe('Catalog Service', () => {\n  let bus: EventBus;\n  let catalog: ReturnType<typeof createCatalogService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    catalog = createCatalogService(bus);\n  });\n\n  it('should create a product and return an id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeTruthy();\n  });\n\n  it('should get a product by id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for unknown product', () => {\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products by category', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n  });\n\n  it('should search products by name', () => {\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Gizmo', 2, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('should search products by category', () => {\n    catalog.createProduct('A', 1, 'electronics');\n    catalog.createProduct('B', 2, 'clothing');\n    const results = catalog.searchProducts('electron');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { price: 14.99 });\n    expect(catalog.getProduct(id)!.price).toBe(14.99);\n  });\n\n  it('should remove a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n  });\n\n  it('should return false when removing nonexistent product', () => {\n    expect(catalog.removeProduct('nope')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // Wait for async emit\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('should set and get stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve insufficient stock', () => {\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n  });\n\n  it('should release reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', async () => {\n    let alertFired = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(alertFired).toBe(true);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('should create a cart', () => {\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n  });\n\n  it('should add items to cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n  });\n\n  it('should consolidate same product items', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove item from cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([]);\n  });\n\n  it('should clear cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.clearCart(id);\n    expect(cart.getCart(id)!.items).toEqual([]);\n  });\n\n  it('should update quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)!.items[0].quantity).toBe(10);\n  });\n\n  it('should return null for unknown cart', () => {\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('should calculate total with tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of 90\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product creation events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 25, category: 'cat' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('Order Service', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('should create an order in pending status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const order = orders.getOrder(id);\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('should update order status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order:created event', async () => {\n    orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n  });\n\n  it('should emit status change event with previous status', async () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const log = bus.getLog();\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvent).toBeTruthy();\n    const payload = statusEvent!.payload as { previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders by user', () => {\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user1', 'c2', 20);\n    orders.createOrder('user2', 'c3', 30);\n    expect(o