@@ -0,0 +1,92 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  Events,
+  PaymentProcessedEvent,
+  PaymentStatus,
+  OrderCreatedEvent,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let totalRevenue = 0;
+  const uniqueCarts = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>(); // productId -> total quantity ordered
+
+  // Track cart creation events
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as { cartId: string };
+    increment(Events.CART_UPDATED);
+    uniqueCarts.add(event.cartId);
+  });
+
+  // Track order created events to count orders and product quantities
+  bus.on(Events.ORDER_CREATED, () => {
+    increment(Events.ORDER_CREATED);
+    orderCount++;
+  });
+
+  // Track payment events for revenue
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent & { amount?: number };
+    increment(Events.PAYMENT_PROCESSED);
+    if (event.status === PaymentStatus.SUCCESS && event.amount) {
+      totalRevenue += event.amount;
+    }
+  });
+
+  // Track all other events
+  bus.on(Events.PRODUCT_CREATED, () => { increment(Events.PRODUCT_CREATED); });
+  bus.on(Events.INVENTORY_UPDATED, () => { increment(Events.INVENTORY_UPDATED); });
+  bus.on(Events.LOW_STOCK_ALERT, () => { increment(Events.LOW_STOCK_ALERT); });
+  bus.on(Events.PRICE_CALCULATED, () => { increment(Events.PRICE_CALCULATED); });
+  bus.on(Events.ORDER_STATUS_CHANGED, () => { increment(Events.ORDER_STATUS_CHANGED); });
+  bus.on(Events.NOTIFICATION_SENT, () => { increment(Events.NOTIFICATION_SENT); });
+  bus.on(Events.ANALYTICS_EVENT, () => { increment(Events.ANALYTICS_EVENT); });
+
+  function increment(eventType: string): void {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  // Track product quantities from order events by listening to the bus event log
+  // We need to track items per order - listen to cart updated events to map carts
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as { cartId: string; items: Array<{ productId: string; quantity: number }> };
+    cartItems.set(event.cartId, event.items);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    const items = cartItems.get(event.cartId);
+    if (items) {
+      for (const item of items) {
+        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+      }
+    }
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return totalRevenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCarts.size === 0) return 0;
+      return orderCount / uniqueCarts.size;
+    },
+
+    getTopProducts(limit: number) {
+      return Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
