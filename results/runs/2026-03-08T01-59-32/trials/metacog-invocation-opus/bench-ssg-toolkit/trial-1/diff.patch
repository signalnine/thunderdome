+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): string {
+  // Collect footnote definitions: [^N]: text
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  const footnotes: { id: string; text: string }[] = [];
+  let match: RegExpExecArray | null;
+
+  while ((match = footnoteDefRegex.exec(content)) !== null) {
+    footnotes.push({ id: match[1], text: match[2] });
+  }
+
+  // Remove footnote definitions from content
+  let result = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+  // Replace inline footnote references [^N] with superscript links
+  result = result.replace(/\[\^(\d+)\]/g, '<sup><a href="#fn-$1">$1</a></sup>');
+
+  // Append footnotes section if any
+  if (footnotes.length > 0) {
+    result += '\n<section class="footnotes">\n<ol>\n';
+    for (const fn of footnotes) {
+      result += `<li id="fn-${fn.id}">${fn.text}</li>\n`;
+    }
+    result += '</ol>\n</section>';
+  }
+
+  return result;
+}
+
+function processAdmonitions(content: string): string {
+  // Match :::type\ncontent\n:::
+  return content.replace(/^:::(\w+)\n([\s\S]*?)^:::/gm, (_match, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+function markdownToHtml(content: string): string {
+  // Process admonitions first (before markdown conversion)
+  let result = processAdmonitions(content);
+
+  // Process footnotes
+  result = processFootnotes(result);
+
+  // Convert headers
+  result = result.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  result = result.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  result = result.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  result = result.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  result = result.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  result = result.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Convert bold and italic
+  result = result.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  result = result.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Convert code blocks
+  result = result.replace(/```(\w+)?\n([\s\S]*?)```/g, (_match, lang: string | undefined, code: string) => {
+    if (lang) {
+      return `<pre><code class="language-${lang}">${code.trim()}</code></pre>`;
+    }
+    return `<pre><code>${code.trim()}</code></pre>`;
+  });
+
+  // Convert inline code
+  result = result.replace(/`([^`]+)`/g, '<code>$1</code>');
+
+  // Convert paragraphs: non-empty lines that aren't already HTML
+  const lines = result.split('\n');
+  const processed: string[] = [];
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (trimmed === '') {
+      processed.push('');
+    } else if (
+      trimmed.startsWith('<') ||
+      trimmed.startsWith('#') ||
+      trimmed === ''
+    ) {
+      processed.push(line);
+    } else {
+      processed.push(`<p>${trimmed}</p>`);
+    }
+  }
+  result = processed.join('\n');
+
+  // Clean up extra blank lines
+  result = result.replace(/\n{3,}/g, '\n\n');
+  result = result.trim();
+
+  return result;
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        const html = markdownToHtml(file.content);
+        return { ...file, content: html };
+      },
+    },
+  };
+}
diff --git a/src/plugins/rss-feed.ts b/src/plugins/rss-feed.ts
