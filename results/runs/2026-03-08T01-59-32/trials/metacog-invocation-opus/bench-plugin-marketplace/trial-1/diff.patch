@@ -0,0 +1,121 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    if (visited.has(name)) {
+      return node;
+    }
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      node.dependencies.push(buildTreeInternal(depName, registry, new Set(visited)));
+    }
+
+    return node;
+  }
+
+  function collectAllDeps(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    path: string[]
+  ): string[][] {
+    const cycles: string[][] = [];
+    const manifest = registry.get(name);
+    if (!manifest) return cycles;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (path.includes(depName)) {
+        const cycleStart = path.indexOf(depName);
+        cycles.push([...path.slice(cycleStart), depName]);
+      } else if (!visited.has(depName)) {
+        visited.add(depName);
+        const subCycles = collectAllDeps(depName, registry, visited, [...path, depName]);
+        cycles.push(...subCycles);
+      }
+    }
+
+    return cycles;
+  }
+
+  function topoSort(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[]
+  ): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        topoSort(depName, registry, visited, result);
+      }
+    }
+
+    result.push(name);
+  }
+
+  function flattenDepsInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>
+  ): string[] {
+    const deps: string[] = [];
+    const manifest = registry.get(name);
+    if (!manifest) return deps;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!visited.has(depName)) {
+        visited.add(depName);
+        deps.push(depName);
+        deps.push(...flattenDepsInternal(depName, registry, visited));
+      }
+    }
+
+    return deps;
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeInternal(name, registry, new Set<string>());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles = collectAllDeps(name, registry, new Set<string>(), [name]);
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      topoSort(name, registry, visited, result);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      return flattenDepsInternal(name, registry, new Set<string>());
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const cycles = collectAllDeps(name, registry, new Set<string>(), [name]);
+      return cycles.length > 0;
+    },
+  };
+}
