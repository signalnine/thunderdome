+
+  it('should throw when updating non-existent plugin', () => {
+    expect(() => registry.update('nope', '1.0.0', {})).toThrow();
+  });
+
+  it('should return empty versions for non-existent plugin', () => {
+    expect(registry.listVersions('nope')).toEqual([]);
+  });
+});
