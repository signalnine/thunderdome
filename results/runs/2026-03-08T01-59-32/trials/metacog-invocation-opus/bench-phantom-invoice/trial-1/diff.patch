ct to an ISO date string (YYYY-MM-DD).\n * Uses UTC methods to avoid timezone-related shifts.\n */\n// TODO: fix timezone\nexport function formatDate(date: Date): string {\n  const year = date.getUTCFullYear();\n  const month = String(date.getUTCMonth() + 1).padStart(2, '0');\n  const day = String(date.getUTCDate()).padStart(2, '0');\n  return `${year}-${month}-${day}`;\n}\n\n/**\n * Parse an ISO date string (YYYY-MM-DD) into a Date object.\n * Creates the date in UTC to avoid timezone issues.\n */\nexport function parseDate(str: string): Date {\n  const [year, month, day] = str.split('-').map(Number);\n  return new Date(Date.UTC(year, month - 1, day));\n}\n\n/**\n * Get the start and end dates for a given month.\n * Returns ISO date strings for the first and last day of the month.\n */\nexport function getMonthRange(year: number, month: number): { start: string; end: string } {\n  const start = new Date(Date.UTC(year, month - 1, 1));\n  const end = new Date(Date.UTC(year, month, 0)); // last day of the month\n  return {\n    start: formatDate(start),\n    end: formatDate(end),\n  };\n}\n\n/**\n * Check if a date string falls within a range (inclusive).\n */\nexport function isDateInRange(date: string, start: string, end: string): boolean {\n  return date >= start && date <= end;\n}\n","numLines":41,"startLine":1,"totalLines":41}}}
