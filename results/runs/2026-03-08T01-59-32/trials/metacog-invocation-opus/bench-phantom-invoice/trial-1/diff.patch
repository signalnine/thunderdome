\n  const invoice: Invoice & { line_items: LineItem[] } = {\n    customer_id: input.customer_id,\n    date: input.date,\n    subtotal,\n    discount_rate: input.discount_rate,\n    tax_rate: input.tax_rate,\n    total,\n    status: input.status || 'draft',\n    line_items: input.line_items,\n  };\n\n  return createInvoice(db, invoice);\n}\n","structuredPatch":[{"oldStart":15,"oldLines":7,"newStart":15,"newLines":7,"lines":["   taxRate: number,"," ): number {","   const discounted = subtotal * (1 - discountRate);","-  const total = discounted + subtotal * taxRate;","+  const total = discounted + discounted * taxRate;","   return Math.round(total * 100) / 100;"," }"," "]}],"userModified":false,"replaceAll":false}}
