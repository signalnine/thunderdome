@@ -0,0 +1,227 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { authenticate } from "../middleware/auth.js";
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post("/", authenticate, (req: Request, res: Response): void => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const now = new Date().toISOString();
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenantId: req.user!.tenantId,
+      name,
+      ownerId: req.user!.userId,
+      config: config || {},
+      createdAt: now,
+      updatedAt: now,
+    });
+  });
+
+  // List dashboards
+  router.get("/", authenticate, (req: Request, res: Response): void => {
+    const rows = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(req.user!.tenantId) as DashboardRow[];
+
+    const dashboards = rows.map((row) => ({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+    }));
+
+    res.json({ dashboards });
+  });
+
+  // Get single dashboard
+  router.get("/:id", authenticate, (req: Request, res: Response): void => {
+    const row = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(row.id) as WidgetRow[];
+
+    res.json({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+      widgets: widgets.map((w) => ({
+        id: w.id,
+        dashboardId: w.dashboard_id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        positionX: w.position_x,
+        positionY: w.position_y,
+        width: w.width,
+        height: w.height,
+      })),
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", authenticate, (req: Request, res: Response): void => {
+    const { name, config } = req.body;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare("UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?").run(
+      updatedName,
+      updatedConfig,
+      now,
+      req.params.id
+    );
+
+    res.json({
+      id: existing.id,
+      tenantId: existing.tenant_id,
+      name: updatedName,
+      ownerId: existing.owner_id,
+      config: JSON.parse(updatedConfig),
+      createdAt: existing.created_at,
+      updatedAt: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", authenticate, (req: Request, res: Response): void => {
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(req.params.id);
+
+    res.json({ message: "Dashboard deleted", id: req.params.id });
+  });
+
+  // Add widget to dashboard
+  router.post("/:id/widgets", authenticate, (req: Request, res: Response): void => {
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const { type, config, positionX, positionY, width, height } = req.body;
+
+    if (!type || !["counter", "timeseries", "breakdown", "funnel"].includes(type)) {
+      res.status(400).json({ error: "Valid widget type required (counter, timeseries, breakdown, funnel)" });
+      return;
+    }
+
+    const id = uuidv4();
+    const widgetConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, req.params.id, type, widgetConfig, positionX || 0, positionY || 0, width || 1, height || 1);
+
+    res.status(201).json({
+      id,
+      dashboardId: req.params.id,
+      type,
+      config: config || {},
+      positionX: positionX || 0,
+      positionY: positionY || 0,
+      width: width || 1,
+      height: height || 1,
+    });
+  });
+
+  // Delete widget
+  router.delete("/:dashboardId/widgets/:widgetId", authenticate, (req: Request, res: Response): void => {
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.dashboardId, req.user!.tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widget = db
+      .prepare("SELECT * FROM widgets WHERE id = ? AND dashboard_id = ?")
+      .get(req.params.widgetId, req.params.dashboardId) as WidgetRow | undefined;
+
+    if (!widget) {
+      res.status(404).json({ error: "Widget not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM widgets WHERE id = ?").run(req.params.widgetId);
+
+    res.json({ message: "Widget deleted", id: req.params.widgetId });
+  });
+
+  return router;
+}
diff --git a/src/routes/events.ts b/src/routes/events.ts
