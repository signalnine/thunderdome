+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01XfkLTUNqpwcGmLFnf3nQ6E","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014owVGYdHzVaVZHRgxwLGnK","name":"Write","input":{"file_path":"/workspace/tests/api.test.ts","content":"import { describe, it, expect, beforeAll } from \"vitest\";\nimport request from \"supertest\";\nimport { createApp } from \"../src/app.js\";\nimport type { Express } from \"express\";\n\ndescribe(\"Analytics Dashboard API\", () => {\n  let app: Express;\n  let authToken: string;\n  let adminToken: string;\n  let userId: string;\n\n  beforeAll(() => {\n    app = createApp(\":memory:\");\n  });\n\n  describe(\"Health Check\", () => {\n    it(\"should return ok\", async () => {\n      const res = await request(app).get(\"/health\");\n      expect(res.status).toBe(200);\n      expect(res.body.status).toBe(\"ok\");\n    });\n  });\n\n  describe(\"User Management\", () => {\n    it(\"should register a new user\", async () => {\n      const res = await request(app).post(\"/auth/register\").send({\n        email: \"admin@tenant1.com\",\n        password: \"password123\",\n        tenantId: \"tenant1\",\n        role: \"admin\",\n      });\n      expect(res.status).toBe(201);\n      expect(res.body.token).toBeDefined();\n      expect(res.body.role).toBe(\"admin\");\n      adminToken = res.body.token;\n    });\n\n    it(\"should register a viewer user\", async () => {\n      const res = await request(app).post(\"/auth/register\").send({\n        email: \"viewer@tenant1.com\",\n        password: \"password123\",\n        tenantId: \"tenant1\",\n      });\n      expect(res.status).toBe(201);\n      expect(res.body.role).toBe(\"viewer\");\n      userId = res.body.id;\n      authToken = res.body.token;\n    });\n\n    it(\"should reject duplicate email\", async () => {\n      const res = await request(app).post(\"/auth/register\").send({\n        email: \"admin@tenant1.com\",\n        password: \"password123\",\n        tenantId: \"tenant1\",\n      });\n      expect(res.status).toBe(409);\n    });\n\n    it(\"should login\", async () => {\n      const res = await request(app).post(\"/auth/login\").send({\n        email: \"admin@tenant1.com\",\n        password: \"password123\",\n      });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it(\"should reject bad credentials\", async () => {\n      const res = await request(app).post(\"/auth/login\").send({\n        email: \"admin@tenant1.com\",\n        password: \"wrong\",\n      });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should get profile\", async () => {\n      const res = await request(app)\n        .get(\"/auth/profile\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"admin@tenant1.com\");\n      expect(res.body.tenantId).toBe(\"tenant1\");\n    });\n\n    it(\"should reject unauthenticated profile request\", async () => {\n      const res = await request(app).get(\"/auth/profile\");\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should allow admin to change roles\", async () => {\n      const res = await request(app)\n        .put(`/auth/users/${userId}/role`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"should reject non-admin role change\", async () => {\n      const res = await request(app)\n        .put(`/auth/users/${userId}/role`)\n        .set(\"Authorization\", `Bearer ${authToken}`)\n        .send({ role: \"admin\" });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Tenant Isolation\", () => {\n    let tenant2Token: string;\n\n    it(\"should register user in different tenant\", async () => {\n      const res = await request(app).post(\"/auth/register\").send({\n        email: \"user@tenant2.com\",\n        password: \"password123\",\n        tenantId: \"tenant2\",\n      });\n      expect(res.status).toBe(201);\n      tenant2Token = res.body.token;\n    });\n\n    it(\"should not see other tenant events\", async () => {\n      // Ingest event for tenant1\n      await request(app)\n        .post(\"/events\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n\n      // Query from tenant2 should see nothing\n      const res = await request(app)\n        .get(\"/events\")\n        .set(\"Authorization\", `Bearer ${tenant2Token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(0);\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    it(\"should ingest single event\", async () => {\n      const res = await request(app)\n        .post(\"/events\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          name: \"click\",\n          properties: { button: \"signup\" },\n          timestamp: \"2024-01-15T10:00:00Z\",\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.id).toBeDefined();\n      expect(res.body.name).toBe(\"click\");\n    });\n\n    it(\"should ingest batch events\", async () => {\n      const res = await request(app)\n        .post(\"/events/batch\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/pricing\" }, timestamp: \"2024-01-15T10:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-15T11:00:00Z\" },\n            { name: \"click\", properties: { button: \"login\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n          ],\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it(\"should reject unauthenticated event\", async () => {\n      const res = await request(app).post(\"/events\").send({ name: \"test\" });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"should list events\", async () => {\n      const res = await request(app)\n        .get(\"/events\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBeGreaterThan(0);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    it(\"should count events\", async () => {\n      const res = await request(app)\n        .post(\"/queries/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\" });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBeGreaterThanOrEqual(2);\n    });\n\n    it(\"should count with filters\", async () => {\n      const res = await request(app)\n        .post(\"/queries/count\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          eventName: \"page_view\",\n          filters: { url: \"/home\" },\n        });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"should return timeseries\", async () => {\n      const res = await request(app)\n        .post(\"/queries/timeseries\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\", interval: \"day\" });\n      expect(res.status).toBe(200);\n      expect(res.body.timeseries).toBeDefined();\n      expect(Array.isArray(res.body.timeseries)).toBe(true);\n    });\n\n    it(\"should return breakdown\", async () => {\n      const res = await request(app)\n        .post(\"/queries/breakdown\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\", property: \"url\" });\n      expect(res.status).toBe(200);\n      expect(res.body.breakdown).toBeDefined();\n      expect(Array.isArray(res.body.breakdown)).toBe(true);\n      expect(res.body.breakdown.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"should reject breakdown without property\", async () => {\n      const res = await request(app)\n        .post(\"/queries/breakdown\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ eventName: \"page_view\" });\n      expect(res.status).toBe(400);\n    });\n  });\n\n  describe(\"Dashboards\", () => {\n    let dashboardId: string;\n\n    it(\"should create a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"My Dashboard\", config: { theme: \"dark\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.id).toBeDefined();\n      expect(res.body.name).toBe(\"My Dashboard\");\n      dashboardId = res.body.id;\n    });\n\n    it(\"should list dashboards\", async () => {\n      const res = await request(app)\n        .get(\"/dashboards\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBeGreaterThanOrEqual(1);\n    });\n\n    it(\"should get single dashboard\", async () => {\n      const res = await request(app)\n        .get(`/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"My Dashboard\");\n      expect(res.body.widgets).toBeDefined();\n    });\n\n    it(\"should update dashboard\", async () => {\n      const res = await request(app)\n        .put(`/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({ name: \"Updated Dashboard\" });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe(\"Updated Dashboard\");\n    });\n\n    it(\"should add widget to dashboard\", async () => {\n      const res = await request(app)\n        .post(`/dashboards/${dashboardId}/widgets`)\n        .set(\"Authorization\", `Bearer ${adminToken}`)\n        .send({\n          type: \"counter\",\n          config: { eventName: \"page_view\" },\n          positionX: 0,\n          positionY: 0,\n          width: 2,\n          height: 1,\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.type).toBe(\"counter\");\n    });\n\n    it(\"should delete dashboard\", async () => {\n      const res = await request(app)\n        .delete(`/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n    });\n\n    it(\"should return 404 for deleted dashboard\", async () => {\n      const res = await request(app)\n        .get(`/dashboards/${dashboardId}`)\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe(\"Export\", () => {\n    it(\"should export events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/json\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events).toBeDefined();\n      expect(Array.isArray(res.body.events)).toBe(true);\n    });\n\n    it(\"should export events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"should export dashboards as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/export/dashboards/json\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards).toBeDefined();\n    });\n\n    it(\"should export dashboards as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/export/dashboards/csv\")\n        .set(\"Authorization\", `Bearer ${adminToken}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"should reject unauthenticated export\", async () => {\n      const res = await request(app).get(\"/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":676,"cache_read_input_tokens":37621,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":676},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c40bfb0f-c88a-4bac-88e6-e6aa89677bf1","uuid":"f65b7f70-f723-47b1-b4fa-3084b5169cea"}
