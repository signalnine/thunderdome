+++ b/src/routes/export.ts
@@ -0,0 +1,192 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { authenticate } from "../middleware/auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "tenant_id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const rows = events.map((e) =>
+    headers
+      .map((h) => {
+        const val = e[h as keyof EventRow];
+        if (val === null || val === undefined) return "";
+        const strVal = String(val);
+        if (strVal.includes(",") || strVal.includes('"') || strVal.includes("\n")) {
+          return `"${strVal.replace(/"/g, '""')}"`;
+        }
+        return strVal;
+      })
+      .join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: Array<DashboardRow & { widgets?: WidgetRow[] }>): string {
+  const headers = ["id", "tenant_id", "name", "owner_id", "config", "created_at", "updated_at"];
+  const rows = dashboards.map((d) =>
+    headers
+      .map((h) => {
+        const val = d[h as keyof DashboardRow];
+        if (val === null || val === undefined) return "";
+        const strVal = String(val);
+        if (strVal.includes(",") || strVal.includes('"') || strVal.includes("\n")) {
+          return `"${strVal.replace(/"/g, '""')}"`;
+        }
+        return strVal;
+      })
+      .join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authenticate, (req: Request, res: Response): void => {
+    const { name, startDate, endDate } = req.query;
+
+    let query = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const rows = db.prepare(query).all(...params) as EventRow[];
+
+    const events = rows.map((row) => ({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      properties: JSON.parse(row.properties),
+      timestamp: row.timestamp,
+      userId: row.user_id,
+      sessionId: row.session_id,
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json({ events });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authenticate, (req: Request, res: Response): void => {
+    const { name, startDate, endDate } = req.query;
+
+    let query = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const rows = db.prepare(query).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(rows));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authenticate, (req: Request, res: Response): void => {
+    const rows = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(req.user!.tenantId) as DashboardRow[];
+
+    const dashboards = rows.map((row) => {
+      const widgets = db
+        .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+        .all(row.id) as WidgetRow[];
+
+      return {
+        id: row.id,
+        tenantId: row.tenant_id,
+        name: row.name,
+        ownerId: row.owner_id,
+        config: JSON.parse(row.config),
+        createdAt: row.created_at,
+        updatedAt: row.updated_at,
+        widgets: widgets.map((w) => ({
+          id: w.id,
+          dashboardId: w.dashboard_id,
+          type: w.type,
+          config: JSON.parse(w.config),
+          positionX: w.position_x,
+          positionY: w.position_y,
+          width: w.width,
+          height: w.height,
+        })),
+      };
+    });
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.json");
+    res.json({ dashboards });
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authenticate, (req: Request, res: Response): void => {
