--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,42 @@
+import express from "express";
+import { createDatabase } from "./db.js";
+import { createUserRoutes } from "./routes/users.js";
+import { createEventRoutes } from "./routes/events.js";
+import { createQueryRoutes } from "./routes/queries.js";
+import { createDashboardRoutes } from "./routes/dashboards.js";
+import { createExportRoutes } from "./routes/export.js";
+import Database from "better-sqlite3";
+
+export function createApp(dbOrPath?: Database.Database | string): express.Express {
+  const app = express();
+
+  const db =
+    dbOrPath instanceof Database
+      ? dbOrPath
+      : createDatabase(typeof dbOrPath === "string" ? dbOrPath : ":memory:");
+
+  app.use(express.json());
+
+  // Health check
+  app.get("/health", (_req, res) => {
+    res.json({ status: "ok" });
+  });
+
+  // Mount routes
+  app.use("/auth", createUserRoutes(db));
+  app.use("/events", createEventRoutes(db));
+  app.use("/queries", createQueryRoutes(db));
+  app.use("/dashboards", createDashboardRoutes(db));
+  app.use("/export", createExportRoutes(db));
+
+  return app;
+}
+
+// Start server when run directly
+if (require.main === module) {
+  const port = process.env.PORT || 3000;
+  const app = createApp();
+  app.listen(port, () => {
+    console.log(`Analytics dashboard API running on port ${port}`);
+  });
+}
