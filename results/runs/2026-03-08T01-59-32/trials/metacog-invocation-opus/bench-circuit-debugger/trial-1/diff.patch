teMap.get(`${op}|${a}|${b}`);\n  }\n\n  function findGatesWithInput(wire: string, op: string): Gate[] {\n    return (gatesByInput.get(wire) || []).filter((g) => g.op === op);\n  }\n\n  function isXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function isZ(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function consumedByOp(wire: string, op: string): boolean {\n    return (gatesByInput.get(wire) || []).some((g) => g.op === op);\n  }\n\n  const swapped = new Set<string>();\n\n  // ===== PHASE 1: Structural rule violations =====\n  for (const gate of gates) {\n    const out = gate.out;\n    const takesXY = isXY(gate.in1) && isXY(gate.in2);\n\n    if (gate.op === 'XOR') {\n      if (takesXY) {\n        const bitNum = parseInt(gate.in1.replace(/^[xy]/, ''), 10);\n        if (bitNum === 0) {\n          if (out !== 'z00') {\n            swapped.add(out);\n            swapped.add('z00');\n          }\n        } else {\n          if (isZ(out)) {\n            swapped.add(out);\n          } else if (!consumedByOp(out, 'XOR') || !consumedByOp(out, 'AND')) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        if (!isZ(out)) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'AND') {\n      if (isZ(out) && out !== lastZ) {\n        swapped.add(out);\n      }\n      if (takesXY) {\n        const bitNum = parseInt(gate.in1.replace(/^[xy]/, ''), 10);\n        if (bitNum !== 0) {\n          if (!isZ(out) && !consumedByOp(out, 'OR')) {\n            swapped.add(out);\n          }\n        }\n      } else {\n        if (!isZ(out) && !consumedByOp(out, 'OR')) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'OR') {\n      if (isZ(out) && out !== lastZ) {\n        swapped.add(out);\n      }\n      if (out !== lastZ) {\n        if (!consumedByOp(out, 'XOR') || !consumedByOp(out, 'AND')) {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // ===== PHASE 2: Carry-chain tracing =====\n  // This catches swaps between structurally-similar wires (same role, different bits)\n  // that the structural rules can't distinguish.\n\n  // Create a swap mapping from phase 1 to virtually undo known swaps\n  // This helps the carry-chain trace work through already-identified swaps.\n  // We trace with the original gate definitions but apply known fixes.\n\n  // Actually, a simpler approach: trace the carry chain bit by bit.\n  // At each bit, identify the gates by their inputs (which are determined by\n  // the carry from the previous bit). When we find a mismatch, we know\n  // which outputs are swapped.\n\n  // For the trace, we need to handle the case where the carry wire itself\n  // was swapped. In that case, we need to find the real carry.\n\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const x = `x${pad2(bit)}`;\n    const y = `y${pad2(bit)}`;\n    const z = `z${pad2(bit)}`;\n\n    if (bit === 0) {\n      const xorGate = findGate('XOR', x, y);\n      const andGate = findGate('AND', x, y);\n      if (!xorGate || !andGate) break;\n\n      if (xorGate.out !== z) {\n        swapped.add(xorGate.out);\n        swapped.add(z);\n      }\n      carry = andGate.out;\n      // If carry is a z-wire, it was likely swapped\n      if (carry === z && xorGate.out !== z) {\n        // andGate.out == z, but z was also added to swapped from the xorGate check.\n        // The real carry name is whatever xorGate.out is (the name that should have been z)\n        // Actually no — the swap was between xorGate.out and z.\n        // andGate.out is z, meaning the AND gate's output IS z after the swap.\n        // We need the \"real\" carry. Since z should have been the XOR output,\n        // and the AND gate currently outputs z, the AND gate was swapped too\n        // (or not — maybe only the XOR gate's output was swapped with z).\n        // If only XOR