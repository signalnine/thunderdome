rd<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  let changed = true;\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nfunction pad2(n: number): string {\n  return n.toString().padStart(2, '0');\n}\n\n/**\n * Find the 8 wires involved in 4 output-wire swaps in a broken ripple-carry adder.\n *\n * Uses iterative carry-chain tracing: trace the adder structure from bit 0,\n * detect the first structural violation (which reveals a swap pair), repair it,\n * and repeat until all 4 swaps are found.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));\n    }\n  }\n  const numBits = maxBit + 1;\n\n  const allSwapped: string[] = [];\n  let workingGates = gates.map((g) => ({ ...g }));\n\n  for (let iter = 0; iter < 4; iter++) {\n    const pair = traceAndFindSwap(workingGates, numBits);\n    if (!pair) break;\n\n    allSwapped.push(pair[0], pair[1]);\n\n    // Repair this swap\n    workingGates = workingGates.map((g) => {\n      if (g.out === pair[0]) return { ...g, out: pair[1] };\n      if (g.out === pair[1]) return { ...g, out: pair[0] };\n      return g;\n    });\n  }\n\n  return allSwapped.sort();\n}\n\n/**\n * Trace the carry chain of a ripple-carry adder and find the first swap.\n * Returns the pair of swapped wire names, or null if the circuit is correct.\n */\nfunction traceAndFindSwap(gates: Gate[], numBits: number): [string, string] | null {\n  const lastZ = `z${pad2(numBits)}`;\n\n  // Build lookups\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  const gatesByInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      if (!gatesByInput.has(inp)) gatesByInput.set(inp, []);\n      gatesByInput.get(inp)!.push(g);\n    }\n  }\n\n  const gateMap = new Map<string, Gate>();\n  for (const g of gates) {\n    const k1 = `${g.op}|${g.in1}|${g.in2}`;\n    const k2 = `${g.op}|${g.in2}|${g.in1}`;\n    gateMap.set(k1, g);\n    gateMap.set(k2, g);\n  }\n\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    return gateMap.get(`${op}|${a}|${b}`);\n  }\n\n  function findGatesWithInput(wire: string, op: string): Gate[] {\n    return (gatesByInput.get(wire) || []).filter((g) => g.op === op);\n  }\n\n  function isXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function isZ(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const x = `x${pad2(bit)}`;\n    const y = `y${pad2(bit)}`;\n    const z = `z${pad2(bit)}`;\n\n    if (bit === 0) {\n      // Half adder\n      const xorGate = findGate('XOR', x, y);\n      const andGate = findGate('AND', x, y);\n      if (!xorGate || !andGate) return null;\n\n      if (xorGate.out !== z) {\n        // XOR(x00,y00) should output z00\n        return [xorGate.out, z];\n      }\n      carry = andGate.out;\n\n      // Validate carry: should not be a z wire (or if it is, it's suspicious)\n      if (isZ(carry) && carry !== lastZ) {\n        // AND(x00,y00) should output carry, not z\n        // Find what gate output