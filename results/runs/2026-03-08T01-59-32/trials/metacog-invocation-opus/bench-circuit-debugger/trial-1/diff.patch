ires are found or no more progress can be made.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${pad2(numBits)}`;\n\n  const allSwapped = new Set<string>();\n\n  // We'll work on a mutable copy of gates, repairing as we go\n  let workingGates = gates.map((g) => ({ ...g }));\n\n  // Run up to a few iterations of detect-and-repair\n  for (let iteration = 0; iteration < 4 && allSwapped.size < 8; iteration++) {\n    const found = detectSwaps(workingGates, numBits, lastZ);\n    if (found.length === 0) break;\n\n    for (const wire of found) {\n      allSwapped.add(wire);\n    }\n\n    // Repair found swaps: they come in pairs, swap them back\n    // The pairs are from the carry-chain trace or structural rules\n    for (let i = 0; i < found.length - 1; i += 2) {\n      workingGates = swapGateOutputs(workingGates, found[i], found[i + 1]);\n    }\n  }\n\n  return [...allSwapped].sort();\n}\n\nfunction swapGateOutputs(gates: Gate[], out1: string, out2: string): Gate[] {\n  return gates.map((g) => {\n    if (g.out === out1) return { ...g, out: out2 };\n    if (g.out === out2) return { ...g, out: out1 };\n    return g;\n  });\n}\n\n/**\n * Detect swapped wires using structural rules + carry-chain trace.\n * Returns pairs of swapped wires as a flat array [a, b, c, d, ...]\n * where (a,b) and (c,d) are swap pairs.\n */\nfunction detectSwaps(gates: Gate[], numBits: number, lastZ: string): string[] {\n  // Build lookups\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  const gatesByInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      if (!gatesByI