+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values,
+ * propagate all signals and return all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+function pad2(n: number): string {
+  return n.toString().padStart(2, '0');
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a broken ripple-carry adder.
+ *
+ * Uses iterative carry-chain tracing: trace the adder structure from bit 0,
+ * detect the first structural violation (which reveals a swap pair), repair it,
+ * and repeat until all 4 swaps are found.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2, g.out]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));
+    }
+  }
+  const numBits = maxBit + 1;
+
+  const allSwapped: string[] = [];
+  let workingGates = gates.map((g) => ({ ...g }));
+
+  for (let iter = 0; iter < 4; iter++) {
+    const pair = traceAndFindSwap(workingGates, numBits);
+    if (!pair) break;
+
+    allSwapped.push(pair[0], pair[1]);
+
+    workingGates = workingGates.map((g) => {
+      if (g.out === pair[0]) return { ...g, out: pair[1] };
+      if (g.out === pair[1]) return { ...g, out: pair[0] };
+      return g;
+    });
+  }
+
+  return allSwapped.sort();
+}
+
+/**
+ * Trace the carry chain of a ripple-carry adder and find the first swap.
+ * Returns the pair of swapped wire names, or null if the circuit is correct.
+ */
+function traceAndFindSwap(gates: Gate[], numBits: number): [string, string] | null {
+  const lastZ = `z${pad2(numBits)}`;
+
+  const gatesByInput = new Map<string, Gate[]>();
+  for (const g of gates) {
+    for (const inp of [g.in1, g.in2]) {
+      if (!gatesByInput.has(inp)) gatesByInput.set(inp, []);
+      gatesByInput.get(inp)!.push(g);
+    }
+  }
+
+  const gateMap = new Map<string, Gate>();
+  for (const g of gates) {
+    const k1 = `${g.op}|${g.in1}|${g.in2}`;
+    const k2 = `${g.op}|${g.in2}|${g.in1}`;
+    gateMap.set(k1, g);
+    gateMap.set(k2, g);
+  }
+
+  function findGate(op: string, a: string, b: string): Gate | undefined {
+    return gateMap.get(`${op}|${a}|${b}`);
+  }
+
+  function findGatesWithInput(wire: string, op: string): Gate[] {
+    return (gatesByInput.get(wire) || []).filter((g) => g.op === op);
+  }
+
+  function isXY(w: string): boolean {
+    return /^[xy]\d+$/.test(w);
+  }
+
+  function isZ(w: string): boolean {
+    return /^z\d+$/.test(w);
+  }
+
+  let carry = '';
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const x = `x${pad2(bit)}`;
+    const y = `y${pad2(bit)}`;
+    const z = `z${pad2(bit)}`;
+
+    if (bit === 0) {
+      const xorGate = findGate('XOR', x, y);
+      const andGate = findGate('AND', x, y);
+      if (!xorGate || !andGate) return null;
+
+      if (xorGate.out !== z) {
+        return [xorGate.out, z];
+      }
+      carry = andGate.out;
+
+      if (isZ(carry) && carry !== lastZ) {
+        // AND(x00,y00) shouldn't output a z wire — find its swap partner
+        const zBit = parseInt(carry.substring(1), 10);
+        const xk = `x${pad2(zBit)}`;
+        const yk = `y${pad2(zBit)}`;
+        const xorXYk = findGate('XOR', xk, yk);
+        if (xorXYk) {
+          const psK = xorXYk.out;
+          const sumXORs = findGatesWithInput(psK, 'XOR').filter(
+            (g) => !(isXY(g.in1) && isXY(g.in2))
+          );
+          if (sumXORs.length === 1 && sumXORs[0].out !== carry) {
+            return [carry, sumXORs[0].out];
+          }
+        }
+        return null;
+      }
+    } else {
+      if (!carry) return null;
+
+      const xorXY = findGate('XOR', x, y);
+      if (!xorXY) return null;
+      const partialSum = xorXY.out;
+
+      // Find XOR(partialSum, carry) -> z_i
+      let xorSumCarry = findGate('XOR', partialSum, carry);
+
+      if (!xorSumCarry) {
+        // partialSum or carry is wrong — find the mismatch
+        const carryXORs = findGatesWithInput(carry, 'XOR').filter(
+          (g) => !(isXY(g.in1) && isXY(g.in2))
+        );
+
+        if (carryXORs.length === 1) {
+          const g = carryXORs[0];
+          const otherInput = g.in1 === carry ? g.in2 : g.in1;
+          if (otherInput !== partialSum) {
+            return [partialSum, otherInput];
+          }
+          xorSumCarry = g;
+        } else if (carryXORs.length === 0) {
+          // carry doesn't feed into any sum XOR — maybe carry was swapped
+          const psXORs = findGatesWithInput(partialSum, 'XOR').filter(
+            (g) => !(isXY(g.in1) && isXY(g.in2))
+          );
+          if (psXORs.length === 1) {
+            const g = psXORs[0];
+            const realCarry = g.in1 === partialSum ? g.in2 : g.in1;
+            if (realCarry !== carry) {
+              return [carry, realCarry];
+            }
+            xorSumCarry = g;
+          }
+        }
+        if (!xorSumCarry) return null;
+      }
+
+      if (xorSumCarry.out !== z) {
+        return [xorSumCarry.out, z];
+      }
+
+      // AND(x_i, y_i) -> generate
+      const andXY = findGate('AND', x, y);
+      if (!andXY) return null;
+      const generate = andXY.out;
+
+      // AND(partialSum, carry) -> propagate
+      const andPC = findGate('AND', partialSum, carry);
+      if (!andPC) return null;
+      const propagate = andPC.out;
+
+      // OR(generate, propagate) -> carry_out
+      const orGate = findGate('OR', generate, propagate);
+      if (orGate) {
+        carry = orGate.out;
+
+        // Carry should not be a non-final z wire
+        if (isZ(carry) && carry !== lastZ) {
+          // OR output was swapped with a z wire — find the partner
+          // The XOR that should produce z_k currently has the real carry name
+          const zBit = parseInt(carry.substring(1), 10);
+          const xk = `x${pad2(zBit)}`;
+          const yk = `y${pad2(zBit)}`;
+          const xorXYk = findGate('XOR', xk, yk);
+          if (xorXYk) {
+            const psK = xorXYk.out;
+            const sumXORs = findGatesWithInput(psK, 'XOR').filter(
+              (g) => !(isXY(g.in1) && isXY(g.in2))
+            );
+            if (sumXORs.length === 1 && sumXORs[0].out !== carry) {
+              return [carry, sumXORs[0].out];
+            }
+          }
+          return null;
+        }
+      } else {
+        // OR(generate, propagate) doesn't exist — one was swapped to a different OR
+        const orWithGen = findGatesWithInput(generate, 'OR');
+        const orWithProp = findGatesWithInput(propagate, 'OR');
+
+        if (orWithGen.length === 1 && orWithProp.length === 0) {
+          const g = orWithGen[0];
+          const realProp = g.in1 === generate ? g.in2 : g.in1;
+          return [propagate, realProp];
+        } else if (orWithProp.length === 1 && orWithGen.length === 0) {
+          const g = orWithProp[0];
+          const realGen = g.in1 === propagate ? g.in2 : g.in1;
+          return [generate, realGen];
+        } else if (orWithGen.length === 1 && orWithProp.length === 1) {
+          // Both feed into different OR gates. The OR gate containing propagate
+          // is the correct one for this bit (propagate's inputs were verified).
+          // Its other input is the expected generate.
+          const pOr = orWithProp[0];
+          const expectedGen = pOr.in1 === propagate ? pOr.in2 : pOr.in1;
+          return [generate, expectedGen];
+        } else {
+          return null;
+        }
+      }
+    }
+  }
+
+  return null;
+}
