o catch swaps between structurally-similar wires\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${pad2(numBits)}`;\n\n  // Build lookup: output wire -> gate\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Build lookup: wire -> gates that use it as input\n  const gatesByInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      if (!gatesByInput.has(inp)) gatesByInput.set(inp, []);\n      gatesByInput.get(inp)!.push(g);\n    }\n  }\n\n  function isXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function isZ(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function consumedByOp(wire: string, op: string): boolean {\n    return (gatesByInput.get(wire) || []).some((g) => g.op === op);\n  }\n\n  const swapped = new Set<string>();\n\n  // ===== PHASE 1: Structural rule violations =====\n  // Each gate type in a correct adder has invariants about what its output can be.\n\n  for (const gate of gates) {\n    const out = gate.out;\n    const takesXY = isXY(gate.in1) && isXY(gate.in2);\n\n    if (gate.op === 'XOR') {\n      if (takesXY) {\n        // XOR(x_i, y_i): partial sum for bit i\n        // Bit 0: output should be z00\n        // Bit > 0: output should NOT be z, and should feed into another XOR and AND\n        const bitNum = parseInt(gate.in1.replace(/^[xy]/, ''), 10);\n        if (bitNum === 0) {\n          if (out !== 'z00') {\n            swapped.add(out);\n            swapped.add('z00');\n          }\n        } else {\n          if (isZ(out)) {\n            swapped.add(out);\n          } else if (