it('handles dependency chains', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result.c).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('simulates a 4-bit adder (5+3=8)', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    const result = simulate(gates, {\n      x00: 1, x01: 0, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 0, y03: 0,\n    });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function makeNBitAdder(n: number): Gate[] {\n    const gates: Gate[] = [];\n    // Bit 0\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n    // Bits 1 to n-1\n    for (let i = 1; i < n; i++) {\n      const b = pad(i);\n      const pb = pad(i - 1);\n      gates.push({ op: 'XOR', in1: `x${b}`, in2: `y${b}`, out: `t${b}` });\n      gates.push({ op: 'XOR', in1: `t${b}`, in2: `c${pb}`, out: `z${b}` });\n      gates.push({ op: 'AND', in1: `x${b}`, in2: `y${b}`, out: `a${b}` });\n      gates.push({ op: 'AND', in1: `t${b}`, in2: `c${pb}`, out: `b${b}` });\n      if (i < n - 1) {\n        gates.push({ op: 'OR', in1: `a${b}`, in2: `b${b}`, out: `c${b}` });\n      } else {\n        // Last bit: carry out is z_{n}\n        gates.push({ op: 'OR', in1: `a${b}`, in2: `b${b}`, out: `z${pad(n)}` });\n      }\n    }\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], out1: string, out2: string): Gate[] {\n    return gates.map((g) => {\n      if (g.out === out1) return { ...g, out: out2 };\n      if (g.out === out2) return { ...g, out: out1 };\n      return { ...g };\n    });\n  }\n\n  it('finds z-wire and internal wire swaps', () => {\n    // 8-bit adder with 4 swaps involving z wires and various internal wires\n    let gates = makeNBitAdder(8);\n    // Swap 1: z01 <-> a01 (z output swapped with generate carry)\n    gates = swapOutputs(gates, 'z01', 'a01');\n    // Swap 2: z03 <-> c02 (z output swapped with carry)\n    gates = swapOutputs(gates, 'z03', 'c02');\n    // Swap 3: z05 <-> t05 (z output swapped with partial sum)\n    gates = swapOutputs(gates, 'z05', 't05');\n    // Swap 4: z07 <-> b07 (z output swapped with propagate carry)\n    gates = swapOutputs(gates, 'z07', 'b07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b07', 'c02', 't05', 'z01', 'z03', 'z05', 'z07']);\n  });\n\n  it('finds carry-chain swaps', () => {\n    // 8-bit adder with swaps including carry wire <-> z wire\n    let gates = makeNBitAdder(8);\n    // Swap 1: c01 <-> z02 (carry swapped with z)\n    gates = swapOutputs(gates, 'c01', 'z02');\n    // Swap 2: c03 <-> z04 (carry swapped with z)\n    gates = swapOutputs(gates, 'c03', 'z04');\n    // Swap 3: c05 <-> z06 (carry swapped with z)\n    gates = swapOutputs(gates, 'c05', 'z06');\n    // Swap 4: c06 <-> z07 (carry swapped with z)\n    gates = swapOutputs(gates, 'c06', 'z07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['c01', 'c03', 'c05', 'c06', 'z02', 'z04', 'z06', 'z07']);\n  });\n\n  it('finds mixed swap types', () => {\n    // 10-bit adder with various swap types\n    let gates = makeNBitAdder(10);\n    // Swap 1: z02 <-> t02 (z with partial sum)\n    gates = swapOutputs(gates, 'z02', 't02');\n    // Swap 2: z05 <-> c04 (z with carry)\n    gates = swapOutputs(gates, 'z05', 'c04');\n    // Swap 3: a03 <-> z03 (generate with z)\n    gates = swapOutputs(gates, 'a03', 'z03');\n    // Swap 4: b07 <-> z07 (propagate with z)\n    gates = swapOutputs(gates, 'b07', 'z07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a03', 'b07', 'c04', 't02', 'z02', 'z03', 'z05', 'z07']);\n  });\n\n  it('handles cross-bit swaps', () => {\n    // 8-bit adder with swaps across different bit positions\n    let gates = makeNBitAdder(8);\n    // Swap 1: t01 <-> z03 (partial sum of bit 1 with z output of bit 3)\n    gates = swapOutputs(gates, 't01', 'z03');\n    // Swap 2: a02 <-> z05 (generate of bit 2 with z of bit 5)\n    gates = swapOutputs(gates, 'a02', 'z05');\n    // Swap 3: c04 <-> z06 (carry of bit 4 with z of bit 6)\n    gates = swapOutputs(gates, 'c04', 'z06');\n    // Swap 4: b06 <-> z07 (propagate of bit 6 with z of bit 7)\n    gates = swapOutputs(gates, 'b06', 'z07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'b06', 'c04', 't01', 'z03', 'z05', 'z06', 'z07']);\n  });\n});\n\nfunction pad(n: number): string {\n  return n.toString().padStart(2, '0');\n}\n","structuredPatch":[{"oldStart":34,"oldLines":50,"newStart":34,"newLines":15,"lines":["     expect(result.e).toBe(1);","   });"," ","-  it('simulates a 2-bit adder (0+0)', () => {","-    // 2-bit adder: