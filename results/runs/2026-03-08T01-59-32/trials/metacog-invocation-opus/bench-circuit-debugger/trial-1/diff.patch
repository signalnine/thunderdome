ile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a circuit: given gates and initial wire values,\n * propagate all signals and return all wire values.\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  let changed = true;\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nfunction pad2(n: number): string {\n  return n.toString().padStart(2, '0');\n}\n\n/**\n * Find the 8 wires involved in 4 output-wire swaps in a broken ripple-carry adder.\n *\n * Uses two complementary approaches:\n * 1. Local structural rules that each gate in a correct adder must satisfy\n * 2. Carry-chain tracing with swap detection and repair\n *\n * The structural rules catch all swaps where the two wires have different\n * structural roles (e.g., z<->carry, z<->generate, partial_sum<->z).\n * The carry-chain trace catches swaps between same-role wires at different\n * bit positions by actually following the logical structure of the adder.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1], 10));\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${pad2(numBits)}`;\n\n  // Build lookup: output wire -> gate\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Build lookup: wire -> gates that use it as input\n  const gatesByInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      if (!gatesByInput.has(inp)) gatesByInput.set(inp, []);\n      gatesByInput.get(inp)!.push(g);\n    }\n  }\n\n  // Build fast gate lookup by op and inputs\n  const gateMap = new Map<string, Gate>();\n  for (const g of gates) {\n    const k1 = `${g.op}|${g.in1}|${g.in2}`;\n    const k2 = `${g.op}|${g.in2}|${g.in1}`;\n    gateMap.set(k1, g);\n    gateMap.set(k2, g);\n  }\n\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    return gateMap.get(`${op}|${a}|${b}`);\n  }\n\n  function findGatesWithInput(wire: string, op: string): Gate[] {\n    return (gatesByInput.get(wire) || []).filter((g) => g.op === op);\n  }\n\n  function isXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function isZ(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function consumedByOp(wire: string, op: string): boolean {\n    return (gatesByInput.get(wire) || []).some((g) => g.op === op);\n  }\n\n  const swapped = new Set<string>();\n\n  // ===== PHASE 1: Structural rule violations =====\n  for (const gate of gates) {\n    const out = gate.out;\n    const takesXY = isXY(gate.in1) && isXY(gate.in2);\n\n    if (gate.op === 'XOR') {\n      if (takesXY) {\n        const bitNum = parseInt(gate.in1.replace(/^[xy]/, ''), 10);\n        if (bitNum === 0) {\n          if (out !== 'z00') {\n            swapped.add(out);\n            swapped.add('z00');\n          }\n        } else {\n          if (isZ(out)) {\n            swapped.add(o