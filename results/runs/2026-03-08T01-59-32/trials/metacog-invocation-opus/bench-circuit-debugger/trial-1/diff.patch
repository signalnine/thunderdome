edCarryXORs.length === 0) {\n          // carry wire doesn't feed into any non-XY XOR.\n          // Maybe carry itself was swapped and we need to find the real carry.\n          // Try: look for an XOR gate that takes partialSum and some non-XY wire\n          const psXORs = findGatesWithInput(partialSum, 'XOR').filter(\n            (g) => !(isXY(g.in1) && isXY(g.in2))\n          );\n          if (psXORs.length === 1) {\n            const g = psXORs[0];\n            const realCarry = g.in1 === partialSum ? g.in2 : g.in1;\n            if (realCarry !== carry) {\n              swapped.add(carry);\n              swapped.add(realCarry);\n              carry = realCarry;\n            }\n            xorSumCarry = g;\n          }\n        }\n        if (!xorSumCarry) break;\n      }\n\n      // Check that xorSumCarry outputs z_i\n      if (xorSumCarry.out !== z) {\n        swapped.add(xorSumCarry.out);\n        swapped.add(z);\n      }\n\n      // AND(x, y) -> generate\n      const andXY = findGate('AND', x, y);\n      if (!andXY) break;\n      const generate = andXY.out;\n\n      // AND(partialSum, carry) -> propagate\n      const andPC = findGate('AND', partialSum, carry);\n      if (!andPC) break;\n      const propagate = andPC.out;\n\n      // OR(generate, propagate) -> carry_out\n      const orGate = findGate('OR', generate, propagate);\n      if (orGate) {\n        carry = orGate.out;\n      } else {\n        // generate or propagate was swapped away from the OR gate\n        const orWithGen = findGatesWithInput(generate, 'OR');\n        const orWithProp = findGatesWithInput(propagate, 'OR');\n\n        if (orWithGen.length === 1 && orWithProp.length === 0) {\n          const g = orWithGen[0];\n          const realProp = g.in1 === generate ? g.in2 : g.in1;\n          swapped.add(propagate);\n          swapped.add(realProp);\n          carry = g.out;\n        } else if (orWithProp.length === 1 && orWithGen.length === 0) {\n          const g = orWithProp[0];\n          const realGen = g.in1 === propagate ? g.in2 : g.in1;\n          swapped.add(generate);\n          swapped.add(realGen);\n          carry = g.out;\n        } else if (orWithGen.length === 1 && orWithProp.length === 1) {\n          // Both generate and propagate each feed into a different OR gate.\n          // This means they were swapped with each other's counterparts\n          // at different bit positions.\n          // Need to figure out which OR gate is the correct one for this bit.\n          // The correct OR gate should have its output consumed by XOR and AND\n          // at the next bit, or be the last carry.\n\n          // Try generate's OR gate\n          const gOr = orWithGen[0];\n          const pOr = orWithProp[0];\n\n          // The correct OR for this bit should use one output from AND(x_i,y_i)\n          // and one from AND(partial_i, carry_in). We know generate comes from\n          // AND(x_i,y_i) and propagate from AND(partial_i, carry_in).\n          // But they don't share an OR gate. One is at the wrong OR.\n          // The one at the wrong OR has been swapped there.\n\n          // Check which OR gate's other input is the generate/propagate of THIS bit\n          const gOrOther = gOr.in1 === generate ? gOr.in2 : gOr.in1;\n          const pOrOther = pOr.in1 === propagate ? pOr.in2 : pOr.in1;\n\n          // gOrOther should be the propagate for this bit = propagate\n          // pOrOther should be the generate for this bit = generate\n          // But they're not (otherwise findGate would have worked)\n          // So: generate was swapped with pOrOther, or propagate was swapped with gOrOther\n\n          // The correct gate for this bit is the one where the \"other\" input\n          // is what we expect. Since generate = AND(x_i,y_i).out, the correct\n          // OR should have generate and the real propagate.\n          // If gOrOther is the real propagate for this bit, then gOr is correct.\n          // But gOrOther != propagate (we already checked).\n\n          // Heuristic: check what produced gOrOther and pOrOther\n          const gOrOtherGate = gateByOutput.get(gOrOther);\n          const pOrOtherGate = gateByOutput.get(pOrOther);\n\n          if (gOrOtherGate && gOrOtherGate.op === 'AND') {\n            // gOrOther is an AND output — it's a generate or propagate\n            // If it shares an AND(partial,carry) pattern consistent with this bit,\n            // then gOr is the correct gate for this bit\n            swapped.add(propagate);\n            swapped.add(gOrOther);\n            carry = gOr.out;\n          } else if (pOrOtherGate && pOrOtherGate.op === 'AND') {\n            swapped.add(generate);\n            swapped.add(pOrOther);\n            carry = pOr.out;\n          } else {\n            break;\n          }\n        } else {\n          break;\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":53,"oldLines":7,"newStart":53,"newLines":12,"lines":["  *","  * Uses two complementary approaches:","  * 1. Local structural rules that each gate in a correct adder must satisfy","- * 2. Carry-chain tracing to catch swaps between structurally-similar wires","+ * 2. Carry-chain tracing with swap detection and repair","+ *","+ * The structural rules catch all swaps where the two wires have different","+ * structural roles (e.g., z<->carry, z<->generate, partial_sum<->z).","+ * The carry-chain trace catches swaps between same-role wires at different","+ * bit positions by actually following the logical structure of the adder.","  */"," export function findSwappedWires(gates: Gate[]): string[] {","   // Determine number of input bits"]},{"oldStart":82,"oldLines":6,"newStart":87,"newLines":23,"lines":["     }","   }"," ","+  // Build fast gate lookup by op and inputs","+  const gateMap = new Map<string, Gate>();","+  for (const g of gates) {","+    const k1 = `${g.op}|${g.in1}|${g.in2}`;","+    const k2 = `${g.op}|${g.in2}|${g.in1}`;","+    