utput.set(g.out, g);\n  }\n\n  const gatesByInput = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      if (!gatesByInput.has(inp)) gatesByInput.set(inp, []);\n      gatesByInput.get(inp)!.push(g);\n    }\n  }\n\n  const gateMap = new Map<string, Gate>();\n  for (const g of gates) {\n    const k1 = `${g.op}|${g.in1}|${g.in2}`;\n    const k2 = `${g.op}|${g.in2}|${g.in1}`;\n    gateMap.set(k1, g);\n    gateMap.set(k2, g);\n  }\n\n  function findGate(op: string, a: string, b: string): Gate | undefined {\n    return gateMap.get(`${op}|${a}|${b}`);\n  }\n\n  function findGatesWithInput(wire: string, op: string): Gate[] {\n    return (gatesByInput.get(wire) || []).filter((g) => g.op === op);\n  }\n\n  function isXY(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function isZ(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const x = `x${pad2(bit)}`;\n    const y = `y${pad2(bit)}`;\n    const z = `z${pad2(bit)}`;\n\n    if (bit === 0) {\n      // Half adder\n      const xorGate = findGate('XOR', x, y);\n      const andGate = findGate('AND', x, y);\n      if (!xorGate || !andGate) return null;\n\n      if (xorGate.out !== z) {\n        // XOR(x00,y00) should output z00\n        return [xorGate.out, z];\n      }\n      carry = andGate.out;\n\n      // Validate carry: should not be a z wire (or if it is, it's suspicious)\n      if (isZ(carry) && carry !== lastZ) {\n        // AND(x00,y00) should output carry, not z\n        // Find what gate outputs z00... no, z00 was correct.\n        // But carry being a z wire means there's a swap.\n        // The z wire that carry equals should have been produced by something else.\n        const realCarryGate = gateByOutput.get(carry);\n        if (realCarryGate && realCarryGate !== andGate) {\n          // Something else also outputs this z wire? No, outputs are unique.\n          // carry IS a z wire. So AND(x00,y00)->z_N, which is wrong.\n          // We need to find the correct carry wire.\n          // For bit 0, carry should not be z. Find the gate that should output this z.\n          return [carry, andGate.out]; // This is the same... we need to find the partner.\n        }\n      }\n    } else {\n      // Full adder\n      if (!carry) return null;\n\n      // Step 1: XOR(x_i, y_i) -> partial sum\n      const xorXY = findGate('XOR', x, y);\n      if (!xorXY) return null;\n      let partialSum = xorXY.out;\n\n      // Validate partial sum\n      // It should NOT be a z wire (for bit > 0)\n      if (isZ(partialSum) && partialSum !== z) {\n        // partial sum ended up as some other z wire — it was swapped\n        // Find what should be at this z position\n        // The gate that should output z_partialSum is something else\n        // The XOR(x_i,y_i) gate's real output should go into another XOR and AND\n        // This z wire should have been output by a different gate\n        // We can find the partner by looking at what the z wire should have come from\n        const zGate = gateByOutput.get(z); // what currently outputs z_i?\n        if (zGate) {\n          // If zGate is a non-XOR, or an XOR that takes x,y, then z_i is wrong too\n          // But partialSum being z_something is the clear violation\n          // partialSum was swapped with whatever should have been at partialSum's z position\n          // Actually, let's find it via structural rules\n        }\n      }\n\n      // Step 2: XOR(partial_sum, carry) -> z_i\n      let xorSumCarry = findGate('XOR', partialSum, carry);\n\n      if (!xorSumCarry) {\n        // Can't find XOR(partialSum, carry). Either partialSum or carry is wrong.\n\n        // Try 1: Find non-XY XOR gates that use carry\n        const carryXORs = findGatesWithInput(carry, 'XOR').filter(\n          (g) => !(isXY(g.in1) && isXY(g.in2))\n        );\n\n        if (carryXORs.length === 1) {\n          const g = carryXORs[0];\n          const otherInput = g.in1 === carry ? g.in2 : g.in1;\n          if (otherInput !== partialSum) {\n            // partialSum was swapped with otherInput\n            return [partialSum, otherInput];\n          }\n          xorSumCarry = g;\n        } else if (carryXORs.length === 0) {\n          // carry doesn't feed into any non-XY XOR. Maybe carry was swapped.\n          // Try: find non-XY XOR that uses partialSum\n          const psXORs = findGatesWithInput(partialSum, 'XOR').filter(\n            (g) => !(isXY(g.in1) && isXY(g.in2))\n          );\n          if (psXORs.length === 1) {\n            const g = psXORs[0];\n            const realCarry = g.in1 === partialSum ? g.in2 : g.in1;\n            if (realCarry !== carry) {\n              return [carry, realCarry];\n            }\n            xorSumCarry = g;\n          }\n        }\n        if (!xorSumCarry) return null;\n      }\n\n      // Step 3: Check output is z_i\n      if (xorSumCarry.out !== z) {\n        return [xorSumCarry.out, z];\n      }\n\n      // Step 4: AND(x_i, y_i) -> generate\n      const andXY = findGate('AND', x, y);\n      if (!andXY) return null;\n      const generate = andXY.out;\n\n      // Step 5: AND(partial_sum, carry) -> propagate\n      const andPC = findGate('AND', partialSum, carry);\n      if (!andPC) return null;\n      const propagate = andPC.out;\n\n      // Step 6: OR(generate, propagate) -> carry_out\n      const orGate = findGate('OR', generate, propagate);\n      if (orGate) {\n        carry = orGate.out;\n\n        // Validate carry: should not be a non-last z wire\n        if (isZ(carry) && carry !== lastZ) {\n          // OR gate outputting a z wire (not the last one) means its output\n          // was swapped with whatever should have produced this z.\n          // Find the gate that should output 'carry' (the non-z wire)\n          // Actually, we need to find what this carry was swapped with.\n          // The z wire that carry equals should come from a XOR gate.\n          // The real carry should be produced by something else.\n          // We can find it by looking at the gate that currently has the real carry name.\n          // The problem is we don't know the real carry name.\n          // But we know the z wire should come from a XOR gate, and the OR output\n          // should not be a z wire. So this is a swap between carry and z.\n          // We need to find the partner. The partner is the wire that should be\n          // at the OR gate's output position — but what wire is that?\n          // The partner is the non-z wire that currently outputs the z value.\n          // Actually, let's look at it differently:\n          // OR outputs z_k (for some k). The gate that should output z_k is a XOR.\n          // That XOR gate currently outputs some wire W (which is the real carry name).\n          // So carry (=z_k) was swapped with W.\n          // Find W: the gate currently tagged z_k is this OR gate. The gate that\n          // should produce z_k is... we can identify it by looking at what XOR gate\n          // has the right inputs. But we don't know that easily.\n          // Simpler: we found the OR gate outputs z_k. z_k should come from a XOR.\n          // The XOR for bit k should output z_k but currently outputs something else.\n          // That \"something else\" is the correct carry name.\n          const zBit = parseInt(carry.substring(1), 10);\n          // Find the gate that SHOULD produce z_{zBit}:\n          // It's XOR(partial_sum_{zBit}, carry_{zBit-1}).\n          // We don't easily know those, but we can find the XOR gate that\n          // currently has output z_{zBit}... wait, the OR gate has output z_k.\n          // So no other gate has output z_k.\n          // The gate that should output z_k currently outputs the real carry name.\n          // But we can't find it directly without the carry chain trace for bit k.\n          // However, we CAN use the gateByOutput: the gate at z_k is the OR gate.\n          // And the gate that should be at z_k... hmm.\n\n          // Alternative approach: just report the swap and let the next iteration fix it.\n          // But we need to find the partner wire.\n          // Use structural rules: find which wire should be at this position.\n          // The OR gate shouldn't output z. Find the non-XY XOR gate that should output z_k.\n          // That XOR gate currently outputs something else (the real carry).\n\n          // Find XOR gates whose output is NOT a z wire and who don't take x,y inputs\n          // and whose bit number matches zBit.\n          // Actually, we can look at the XOR gate that takes inputs corresponding to bit zBit.\n          const xk = `x${pad2(zBit)}`;\n          const yk = `y${pad2(zBit)}`;\n          const xorXYk = findGate('XOR', xk, yk);\n          if (xorXYk) {\n            // The partial sum for bit zBit. Find the XOR that uses it.\n            const psK = xorXYk.out;\n            const sumXORs = findGatesWithInput(psK, 'XOR').filter(\n              (g) => !(isXY(g.in1) && isXY(g.in2))\n            );\n            if (sumXORs.length === 1 && sumXORs[0].out !== carry) {\n              return [carry, sumXORs[0].out];\n            }\n          }\n          // Fallback: report carry as bad and continue\n          return null;\n        }\n      } else {\n        // OR(generate, propagate) doesn't exist — one of them was swapped\n        const orWithGen = findGatesWithInput(generate, 'OR');\n        const orWithProp = findGatesWithInput(propagate, 'OR');\n\n        if (orWithGen.length === 1 && orWithProp.length === 0) {\n          const g = orWithGen[0];\n          const realProp = g.in1 === generate ? g.in2 : g.in1;\n          return [propagate, realProp];\n        } else if (orWithProp.length === 1 && orWithGen.length === 0) {\n          const g = orWithProp[0];\n          const realGen = g.in1 === propagate ? g.in2 : g.in1;\n          return [generate, realGen];\n        } else if (orWithGen.length === 1 && orWithProp.length === 1) {\n          const gOr = orWithGen[0];\n          const gOrOther = gOr.in1 === generate ? gOr.in2 : gOr.in1;\n          const pOr = orWithProp[0];\n          const pOrOther = pOr.in1 === propagate ? pOr.in2 : pOr.in1;\n\n          const gOrOtherGate = gateByOutput.get(gOrOther);\n          const pOrOtherGate = gateByOutput.get(pOrOther);\n\n          if (gOrOtherGate && gOrOtherGate.op === 'AND') {\n            return [propagate, gOrOther];\n          } else if (pOrOtherGate && pOrOtherGate.op === 'AND') {\n            return [generate, pOrOther];\n          }\n          return null;\n        } else if (orWithGen.length === 0 && orWithProp.length === 0) {\n          // Neither feeds into OR. Both were swapped? Unlikely with only 4 swaps.\n          // But let's try to find the OR gate for this bit by other means.\n          // There should be an OR gate whose inputs are the correct generate and propagate.\n          // Since we know the bit, we can look for OR gates and check if their inputs\n          // trace back to the right x,y inputs.\n          return null;\n        } else {\n          return null;\n        }\n      }\n    }\n  }\n\n  // Check the final carry: it should be the last z\n  if (carry && carry !== lastZ) {\n    // The final carry doesn't match — but this would be caught at the z output check\n    // unless the last bit's carry output is misnamed\n    return null;\n  }\n\n  return null;\n}\n","structuredPatch":[{"oldStart":51,"oldLines":14,"newStart":51,"newLines":11,"lines":[" /**","  * Find the 8 wires involved in 4 output-wire swaps in a broken ripple-carry adder.","  *","- * Strategy:","- * 1. Use structural rules to find obviously misplaced wires and pair them.","- * 2. Undo those swaps to get a partially-repaired circuit.","- * 3. Run a carry-chain trace on the repaired circuit to find remaining swaps.","- * 4. Repeat until all 8 wires are found or no more progress can be mad