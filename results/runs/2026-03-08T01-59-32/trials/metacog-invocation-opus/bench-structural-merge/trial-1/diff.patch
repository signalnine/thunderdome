ged view, favor ours (deleted) - don't include in merged\n          mergedEntries.set(docId, {\n            content: deepClone(theirsEntry!.content),\n            versions: theirsEntry!.versions.map(v => ({ ...v, content: deepClone(v.content) })),\n            deleted: true,\n          });\n          continue;\n        }\n      }\n\n      // Both exist and base exists - three-way merge of content\n      if (baseExists && oursExists && theirsExists) {\n        const docConflicts: Conflict[] = [];\n        const mergedContent = collectConflictsAndMerge(\n          baseEntry!.content, oursEntry!.content, theirsEntry!.content,\n          '', docId, docConflicts\n        ) as object;\n        conflicts.push(...docConflicts);\n        merged[docId] = mergedContent;\n\n        // Merge version histories\n        const mergedVersions = [...oursEntry!.versions.map(v => ({ ...v, content: deepClone(v.content) }))];\n        // Add new version for the merge result\n        mergedEntries.set(docId, {\n          content: deepClone(mergedContent),\n          versions: mergedVersions,\n          deleted: false,\n        });\n        continue;\n      }\n    }\n\n    const applied = conflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge\n      for (const [docId, entry] of mergedEntries) {\n        if (entry.deleted) {\n          const existing = targetBranchData.documents.get(docId);\n          if (existing) {\n            existing.deleted = true;\n          }\n        } else {\n          const existing = targetBranchData.documents.get(docId);\n          if (existing) {\n            // Check if content actually changed\n            if (!deepEqual(existing.content, entry.content)) {\n              const version: Version = {\n                id: generateId(),\n                timestamp: Date.now(),\n                content: deepClone(entry.content),\n              };\n              existing.content = deepClone(entry.content);\n              existing.versions.push(versi