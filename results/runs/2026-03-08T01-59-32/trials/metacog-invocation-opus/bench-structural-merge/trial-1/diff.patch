+      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 30 });
+    });
+
+    it('should throw when creating a document with an existing id', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.create('doc1', { a: 2 })).toThrow();
+    });
