@@ -0,0 +1,253 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve a toggle puzzle over GF(2) using Gaussian elimination.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx < numLights) {
+        matrix[lightIdx][j] = 1;
+      }
+    }
+  }
+
+  const result = solveSystem(matrix, numLights, numButtons, 2, 'toggle');
+  return result;
+}
+
+/**
+ * Solve a counter puzzle over GF(p) using Gaussian elimination.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const counterIdx of buttons[j]) {
+      if (counterIdx < numCounters) {
+        matrix[counterIdx][j] = 1;
+      }
+    }
+  }
+
+  const result = solveSystem(matrix, numCounters, numButtons, modulus, 'counter');
+  return result;
+}
+
+function modPow(base: number, exp: number, m: number): number {
+  let result = 1;
+  base = ((base % m) + m) % m;
+  while (exp > 0) {
+    if (exp & 1) {
+      result = (result * base) % m;
+    }
+    exp >>= 1;
+    base = (base * base) % m;
+  }
+  return result;
+}
+
+function modInverse(a: number, p: number): number {
+  return modPow(a, p - 2, p);
+}
+
+/**
+ * For toggle mode: cost = number of 1s, tiebreak by lex order of sorted index set.
+ * For counter mode: cost = sum of values, tiebreak by lex order of value array.
+ */
+function solveSystem(
+  matrix: number[][],
+  numRows: number,
+  numCols: number,
+  p: number,
+  mode: 'toggle' | 'counter'
+): number[] | null {
+  const cols = numCols;
+  const augCol = cols;
+
+  const pivotCol: number[] = new Array(numRows).fill(-1);
+  const pivotRow: number[] = new Array(cols).fill(-1);
+
+  let currentRow = 0;
+  for (let col = 0; col < cols && currentRow < numRows; col++) {
+    let pivot = -1;
+    for (let row = currentRow; row < numRows; row++) {
+      if (matrix[row][col] !== 0) {
+        pivot = row;
+        break;
+      }
+    }
+    if (pivot === -1) continue;
+
+    if (pivot !== currentRow) {
+      [matrix[currentRow], matrix[pivot]] = [matrix[pivot], matrix[currentRow]];
+    }
+
+    pivotCol[currentRow] = col;
+    pivotRow[col] = currentRow;
+
+    const pivotVal = matrix[currentRow][col];
+    if (pivotVal !== 1) {
+      const inv = modInverse(pivotVal, p);
+      for (let j = col; j <= augCol; j++) {
+        matrix[currentRow][j] = (matrix[currentRow][j] * inv) % p;
+      }
+    }
+
+    for (let row = 0; row < numRows; row++) {
+      if (row === currentRow) continue;
+      const factor = matrix[row][col];
+      if (factor === 0) continue;
+      for (let j = col; j <= augCol; j++) {
+        matrix[row][j] = (((matrix[row][j] - factor * matrix[currentRow][j]) % p) + p) % p;
+      }
+    }
+
+    currentRow++;
+  }
+
+  const rank = currentRow;
+
+  for (let row = rank; row < numRows; row++) {
+    if (matrix[row][augCol] !== 0) {
+      return null;
+    }
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < cols; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  // Pre-compute pivot info
+  const pivotInfo: { col: number; constant: number; freeCoeffs: number[] }[] = [];
+  for (let row = 0; row < rank; row++) {
+    const col = pivotCol[row];
+    if (col === -1) continue;
+    const freeCoeffs: number[] = [];
+    for (const fv of freeVars) {
+      freeCoeffs.push(matrix[row][fv]);
+    }
+    pivotInfo.push({ col, constant: matrix[row][augCol], freeCoeffs });
+  }
+
+  if (freeVars.length === 0) {
+    const solution = new Array(cols).fill(0);
+    for (const info of pivotInfo) {
+      solution[info.col] = info.constant;
+    }
+    return formatResult(solution, mode);
+  }
+
+  const numFree = freeVars.length;
+
+  let bestSolution: number[] | null = null;
+  let bestCost = Infinity;
+
+  // Enumerate all p^k combinations of free variable values using an odometer pattern
+  const freeVals = new Array(numFree).fill(0);
+  let done = false;
+
+  while (!done) {
+    const solution = new Array(cols).fill(0);
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = freeVals[i];
+    }
+
+    for (const info of pivotInfo) {
+      let val = info.constant;
+      for (let i = 0; i < numFree; i++) {
+        val = (((val - info.freeCoeffs[i] * freeVals[i]) % p) + p) % p;
+      }
+      solution[info.col] = val;
+    }
+
+    const cost = solution.reduce((a: number, b: number) => a + b, 0);
+    if (cost < bestCost) {
+      bestCost = cost;
+      bestSolution = solution;
+    } else if (cost === bestCost && bestSolution !== null) {
+      if (isBetter(solution, bestSolution, mode)) {
+        bestSolution = solution;
+      }
+    }
+
+    // Increment odometer (rightmost digit first)
+    let carry = true;
+    for (let i = numFree - 1; i >= 0 && carry; i--) {
+      freeVals[i]++;
+      if (freeVals[i] >= p) {
+        freeVals[i] = 0;
+      } else {
+        carry = false;
+      }
+    }
+    if (carry) done = true;
+  }
+
+  if (bestSolution === null) return null;
+  return formatResult(bestSolution, mode);
+}
+
+/**
+ * Check if solution a is better (lex smaller) than b for tiebreaking.
+ */
+function isBetter(a: number[], b: number[], mode: 'toggle' | 'counter'): boolean {
+  if (mode === 'counter') {
+    // Lex compare value arrays
+    for (let i = 0; i < a.length; i++) {
+      if (a[i] !== b[i]) return a[i] < b[i];
+    }
+    return false;
+  } else {
+    // Toggle: lex compare sorted index sets
+    // Two sets have the same size (same cost), so compare element by element
+    const aIndices: number[] = [];
+    const bIndices: number[] = [];
+    for (let i = 0; i < a.length; i++) {
+      if (a[i] === 1) aIndices.push(i);
+      if (b[i] === 1) bIndices.push(i);
+    }
+    for (let i = 0; i < aIndices.length; i++) {
+      if (aIndices[i] !== bIndices[i]) return aIndices[i] < bIndices[i];
+    }
+    return false;
+  }
+}
+
+function formatResult(solution: number[], mode: 'toggle' | 'counter'): number[] {
+  if (mode === 'toggle') {
+    const result: number[] = [];
+    for (let i = 0; i < solution.length; i++) {
+      if (solution[i] === 1) result.push(i);
+    }
+    return result;
+  }
+  return solution;
+}
