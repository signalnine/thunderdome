@@ -0,0 +1,324 @@
+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from '../src/index.js';
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // From the TASK example: target [T, T, F, T]
+    // b0 XOR b2 = 1, b0 XOR b1 = 1, b1 = 0, b1 XOR b2 = 1
+    // b1=0, b0=1, b2=0, but check: b1 XOR b2 = 0 ≠ 1 → no solution
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should solve a simple toggle puzzle', () => {
+    // 2 lights, 2 buttons
+    // Button 0 toggles light 0, Button 1 toggles light 1
+    // Target: [true, true]
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('should find minimum presses', () => {
+    // 2 lights, 3 buttons
+    // Button 0 toggles [0, 1], Button 1 toggles [0], Button 2 toggles [1]
+    // Target: [true, true]
+    // Solutions: {0} (1 press) or {1, 2} (2 presses)
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should break ties lexicographically', () => {
+    // 1 light, 2 buttons that both toggle light 0
+    // Target: [true]
+    // Solutions: {0} or {1}, both 1 press. Lex smallest is {0}
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle single button', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle button toggling all lights', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle identity-like system', () => {
+    // Each button toggles exactly one light
+    const machine: Machine = {
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 2, 4]);
+  });
+
+  it('should handle overlapping buttons', () => {
+    // 3 lights, 3 buttons
+    // b0: [0,1], b1: [1,2], b2: [0,2]
+    // Target: [true, true, true]
+    // Equations: b0+b2=1, b0+b1=1, b1+b2=1 (mod 2)
+    // Add all: 2b0+2b1+2b2 = 3 → 0 = 1 (mod 2)? No, 3 mod 2 = 1
+    // So 0 = 1 mod 2 → no solution... wait
+    // Actually: from eq1+eq2+eq3: 2(b0+b1+b2) = 3 mod 2 → 0 = 1 → no solution
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle more buttons than lights', () => {
+    // 2 lights, 4 buttons
+    // b0: [0], b1: [1], b2: [0,1], b3: [0]
+    // Target: [true, false]
+    // Need: b0+b2+b3=1 (mod2), b1+b2=0 (mod2)
+    // Solutions include {0}, {3}, {1,2}, etc. Min presses = 1: {0} or {3}. Lex: {0}
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0], [1], [0, 1], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle no buttons needed', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [[0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should handle empty buttons array', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should return null with empty buttons but non-zero target', () => {
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should solve a simple counter puzzle', () => {
+    // 2 counters, 2 buttons, mod 3
+    // Button 0 affects counter 0, Button 1 affects counter 1
+    // Target: [2, 1]
+    const result = solveCounter([2, 1], [[0], [1]], 3);
+    expect(result).toEqual([2, 1]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // 2 counters, 1 button, mod 3
+    // Button 0 affects both counters → pressing it x times gives [x, x] mod 3
+    // Target: [1, 2] → need x=1 and x=2 simultaneously → impossible
+    const result = solveCounter([1, 2], [[0, 1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    // 1 counter, 2 buttons both affecting counter 0, mod 5
+    // Target: [1]
+    // Solutions: [1,0], [0,1], [2,4], [3,3], [4,2]... sum 1,1,6,6,6
+    // Min sum = 1, lex smallest: [0,1]... wait [1,0] < [0,1]? No, [0,1] < [1,0]
+    // Actually lex comparison: [0,1] vs [1,0]: [0,1] is smaller since 0 < 1
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should handle modular arithmetic correctly', () => {
+    // 1 counter, 1 button affecting counter 0, mod 7
+    // Target: [5]
+    // Press button 0 five times
+    const result = solveCounter([5], [[0]], 7);
+    expect(result).toEqual([5]);
+  });
+
+  it('should handle multiple buttons affecting same counter', () => {
+    // 2 counters, 3 buttons, mod 5
+    // b0: [0], b1: [1], b2: [0, 1]
+    // Target: [3, 2]
+    // Need: b0+b2 = 3 (mod5), b1+b2 = 2 (mod5)
+    // Free var possibilities or unique solution
+    const result = solveCounter([3, 2], [[0], [1], [0, 1]], 5);
+    expect(result).not.toBeNull();
+    if (result) {
+      // Verify solution
+      const counters = [0, 0];
+      const buttons = [[0], [1], [0, 1]];
+      for (let i = 0; i < result.length; i++) {
+        for (const ci of buttons[i]) {
+          counters[ci] = (counters[ci] + result[i]) % 5;
+        }
+      }
+      expect(counters).toEqual([3, 2]);
+    }
+  });
+
+  it('should handle mod 2 (behaves like toggle)', () => {
+    const result = solveCounter([1, 1], [[0], [1]], 2);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('should handle empty buttons and zero target', () => {
+    const result = solveCounter([0, 0], [], 3);
+    expect(result).toEqual([]);
+  });
+
+  it('should return null for empty buttons and non-zero target', () => {
+    const result = solveCounter([1, 0], [], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should prefer lexicographically smallest on tie', () => {
+    // Verify lex ordering when multiple solutions have same total
+    // 1 counter, 2 buttons both affecting counter 0, mod 3
+    // Target: [0] → need b0+b1 = 0 mod 3
+    // Solutions: [0,0] sum 0, [1,2] sum 3, [2,1] sum 3
+    // Min sum = 0: [0,0]
+    const result = solveCounter([0], [[0], [0]], 3);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should handle larger modulus', () => {
+    // mod 97 (a prime)
+    // 1 counter, 1 button
+    // Target: [50]
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+
+  it('should handle mod 2 with free variables correctly', () => {
+    // 1 counter, 2 buttons both affecting counter 0, mod 2
+    // Target: [1]
+    // Need: b0 + b1 = 1 mod 2
+    // Solutions: [1,0] sum=1, [0,1] sum=1
+    // Lex smallest value array: [0,1]
+    const result = solveCounter([1], [[0], [0]], 2);
+    expect(result).toEqual([0, 1]);
+  });
+});
+
+describe('solveToggle - verification', () => {
+  function verifyToggleSolution(machine: Machine, solution: number[] | null): boolean {
+    if (solution === null) return true; // can't verify null
+    const lights = new Array(machine.target.length).fill(false);
+    for (const btnIdx of solution) {
+      for (const lightIdx of machine.buttons[btnIdx]) {
+        lights[lightIdx] = !lights[lightIdx];
+      }
+    }
+    return lights.every((val, i) => val === machine.target[i]);
+  }
+
+  it('should produce valid solutions for various configs', () => {
+    const configs: Machine[] = [
+      { target: [true], buttons: [[0]] },
+      { target: [true, false], buttons: [[0, 1], [1]] },
+      { target: [true, true, true], buttons: [[0], [1], [2]] },
+      { target: [false, true], buttons: [[0, 1], [0]] },
+    ];
+    for (const machine of configs) {
+      const result = solveToggle(machine);
+      if (result !== null) {
+        expect(verifyToggleSolution(machine, result)).toBe(true);
+      }
+    }
+  });
+});
+
+describe('solveCounter - verification', () => {
+  function verifyCounterSolution(
+    lights: number[],
+    buttons: number[][],
+    modulus: number,
+    solution: number[] | null
+  ): boolean {
+    if (solution === null) return true;
+    const counters = new Array(lights.length).fill(0);
+    for (let i = 0; i < solution.length; i++) {
+      for (const ci of buttons[i]) {
