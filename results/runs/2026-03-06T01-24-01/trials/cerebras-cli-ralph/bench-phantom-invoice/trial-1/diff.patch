 tax_rate: 0.08,\n50:       total: 194.40,\n51:       status: 'sent',\n52:     });\n53:     const invoice = getInvoiceById(db, id);\n54:     expect(invoice).toBeDefined();\n55:     expect(invoice!.customer_id).toBe('cust-1');\n56:     expect(invoice!.subtotal).toBe(200);\n57:   });\n58: \n59:   it('returns undefined for non-existent invoice', () => {\n60:     const invoice = getInvoiceById(db, 999);\n61:     expect(invoice).toBeUndefined();\n62:   });\n63: \n64:   it('creates an invoice with line items', () => {\n65:     const id = createInvoice(db, {\n66:       customer_id: 'cust-2',\n67:       date: '2024-04-01',\n68:       subtotal: 250,\n69:       discount_rate: 0,\n70:       tax_rate: 0.05,\n71:       total: 262.50,\n72:       status: 'draft',\n73:       line_items: [\n74:         { description: 'Widget A', quantity: 5, unit_price: 30 },\n75:         { description: 'Widget B', quantity: 2, unit_price: 50 },\n76:       ],\n77:     });\n78:     const invoice = getInvoiceById(db, id);\n79:     expect(invoice!.line_items).toHaveLength(2);\n80:     expect(invoice!.line_items[0].description).toBe('Widget A');\n81:   });\n82: \n83:   it('lists invoices by customer', () => {\n84:     createInvoice(db, {\n85:       customer_id: 'cust-A',\n86:       date: '2024-01-10',\n87:       subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n88:     });\n89:     createInvoice(db, {\n90:       customer_id: 'cust-B',\n91:       date: '2024-01-12',\n92:       subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n93:     });\n94:     createInvoice(db, {\n95:       customer_id: 'cust-A',\n96:       date: '2024-02-05',\n97:       subtotal: 150, discount_rate: 0, tax_rate: 0, total: 150, status: 'draft',\n98:     });\n99: \n100:     const invoices = getInvoicesByCustomer(db, 'cust-A');\n101:     expect(invoices).toHaveLength(2);\n102:     expect(invoices.every(inv => inv.customer_id === 'cust-A')).toBe(true);\n103:   });\n104: \n105:   it('returns invoices sorted by date', () => {\n106:     createInvoice(db, {\n107:       customer_id: 'cust-1',\n108:       date: '2024-03-15',\n109:       subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'draft',\n110:     });\n111:     createInvoice(db, {\n112:       customer_id: 'cust-1',\n113:       date: '2024-01-10',\n114:       subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'draft',\n115:     });\n116:     createInvoice(db, {\n117:       customer_id: 'cust-1',\n118:       date: '2024-02-20',\n119:       subtotal: 150, discount_rate: 0, tax_rate: 0, total: 150, status: 'draft',\n120:     });\n121: \n122:     const invoices = getInvoicesByDateRange(db, '2024-01-01', '2024-12-31');\n123:     expect(invoices[0].date).toBe('2024-01-10');\n124:     expect(invoices[1].date).toBe('2024-02-20');\n125:     expect(invoices[2].date).toBe('2024-03-15');\n126:   });\n127: \n128:   it('stores invoice status correctly', () => {\n129:     const id = createInvoice(db, {\n130:       customer_id: 'cust-1',\n131:       date: '2024-06-01',\n132:       subtotal: 500, discount_rate: 0.05, tax_rate: 0.1, total: 522.50,\n133:       status: 'paid',\n134:     });\n135:     const invoice = getInvoiceById(db, id);\n136:     expect(invoice!.status).toBe('paid');\n137:   });\n138: \n139:   it('calculates subtotal from line items', () => {\n140:     const items = [\n141:       { description: 'Item A', quantity: 3, unit_price: 10 },\n142:       { description: 'Item B', quantity: 1, unit_price: 25.50 },\n143:       { description: 'Item C', quantity: 2, unit_price: 7.25 },\n144:     ];\n145:     expect(calculateSubtotal(items)).toBe(70);\n146:   });\n147: });\n148: \n149: // ─── Billing Calculations (8 tests) ────────────────────────────────\n150: \n151: describe('Billing Calculations', () => {\n152:   it('calculates total without discount', () => {\n153:     // subtotal=100, no discount, 10% tax => 110\n154:     const total = calculateInvoiceTotal(100, 0, 0.1);\n155:     expect(total).toBe(110);\n156:   });\n157: \n158:   it('calculates total with 10% discount', () => {\n159:     // subtotal=200, 10% discount => 180, then 8% tax => 194.40\n160:     const total = calculateInvoiceTotal(200, 0.1, 0.08);\n161:     expect(total).toBe(194.40);\n162:   });\n163: \n164:   it('calculates total with 25% discount and 8% tax', () => {\n165:     // subtotal=400, 25% discount => 300, 8% tax => 324\n166:     const total = calculateInvoiceTotal(400, 0.25, 0.08);\n167:     expect(total).toBe(324);\n168:   });\n169: \n170:   it('applies discount correctly', () => {\n171:     expect(applyDiscount(200, 0.15)).toBe(170);\n172:   });\n173: \n174:   it('handles zero tax rate', () => {\n175:     const total = calculateInvoiceTotal(500, 0.2, 0);\n176:     expect(total).toBe(400);\n177:   });\n178: \n179:   it('handles zero subtotal', () => {\n180:     const total = calculateInvoiceTotal(0, 0.1, 0.08);\n181:     expect(total).toBe(0);\n182:   });\n183: \n184:   it('generates invoice with correct total', () => {\n185:     const id = generateInvoice(db, {\n186:       customer_id: 'cust-1',\n187:       date: '2024-05-10',\n188:       discount_rate: 0,\n189:       tax_rate: 0.08,\n190:       line_items: [\n191:         { description: 'Service', quantity: 1, unit_price: 1000 },\n192:       ],\n193:     });\n194:     const invoice = getInvoiceById(db, id);\n195:     // 1000 * 1.0 * 1.08 = 1080\n196:     expect(invoice!.total).toBe(1080);\n197:   });\n198: \n199:   it('generates invoice with multiple line items and discount', () => {\n200:     const id = generateInvoice(db, {\n201:       customer_id: 'cust-2',\n202:       date: '2024-07-20',\n203:       discount_rate: 0.15,\n204:       tax_rate: 0,\n205:       line_items: [\n206:         { description: 'Product A', quantity: 10, unit_price: 50 },\n207:         { description: 'Product B', quantity: 5, unit_price: 100 },\n208:       ],\n209:     });\n210:     const invoice = getInvoiceById(db, id);\n211:     // s