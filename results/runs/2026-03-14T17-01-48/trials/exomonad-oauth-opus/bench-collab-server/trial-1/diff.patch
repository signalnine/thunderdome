@@ -0,0 +1,222 @@
+import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp, AppInstance } from '../src/server.js';
+
+interface MessageQueue {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  waiters: ((msg: Record<string, unknown>) => void)[];
+}
+
+function createClient(port: number, docId: string): Promise<MessageQueue> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);
+    const mq: MessageQueue = { ws, messages: [], waiters: [] };
+
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (mq.waiters.length > 0) {
+        mq.waiters.shift()!(msg);
+      } else {
+        mq.messages.push(msg);
+      }
+    });
+
+    ws.on('open', () => resolve(mq));
+    ws.on('error', reject);
+  });
+}
+
+function nextMessage(mq: MessageQueue): Promise<Record<string, unknown>> {
+  if (mq.messages.length > 0) {
+    return Promise.resolve(mq.messages.shift()!);
+  }
+  return new Promise((resolve) => {
+    mq.waiters.push(resolve);
+  });
+}
+
+function nextMessageOfType(mq: MessageQueue, type: string): Promise<Record<string, unknown>> {
+  // Check buffered messages first
+  const idx = mq.messages.findIndex(m => m.type === type);
+  if (idx !== -1) {
+    return Promise.resolve(mq.messages.splice(idx, 1)[0]);
+  }
+  return new Promise((resolve) => {
+    const originalPush = mq.waiters.push.bind(mq.waiters);
+    // Register a waiter that filters by type, re-buffering non-matching messages
+    const handler = (msg: Record<string, unknown>) => {
+      if (msg.type === type) {
+        resolve(msg);
+      } else {
+        mq.messages.push(msg);
+        mq.waiters.push(handler);
+      }
+    };
+    mq.waiters.push(handler);
+  });
+}
+
+describe('WebSocket collaboration', () => {
+  let instance: AppInstance;
+  let port: number;
+  let baseUrl: string;
+
+  beforeAll(async () => {
+    instance = createApp();
+    port = await instance.start(0);
+    baseUrl = `http://localhost:${port}`;
+  });
+
+  afterAll(async () => {
+    await instance.stop();
+  });
+
+  let docId: string;
+
+  beforeEach(async () => {
+    const res = await request(baseUrl)
+      .post('/api/documents')
+      .send({ title: 'Collab Doc', content: 'hello' });
+    docId = res.body.id;
+  });
+
+  it('sends sync message on connect', async () => {
+    const client = await createClient(port, docId);
+    const msg = await nextMessage(client);
+    expect(msg.type).toBe('sync');
+    expect(msg.content).toBe('hello');
+    expect(msg.version).toBeDefined();
+    expect(msg.clientId).toBeDefined();
+    client.ws.close();
+  });
+
+  it('sends error for non-existent document', async () => {
+    const client = await createClient(port, 'nonexistent');
+    const msg = await nextMessage(client);
+    expect(msg.type).toBe('error');
+    client.ws.close();
+  });
+
+  it('broadcasts operations to other clients', async () => {
+    const c1 = await createClient(port, docId);
+    const sync1 = await nextMessage(c1);
+
+    const c2 = await createClient(port, docId);
+    await nextMessage(c2); // sync
+
+    // Client 1 sends an insert
+    c1.ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', position: 5, text: ' world' },
+      version: (sync1 as { version: number }).version,
+    }));
+
+    // Wait for ack to client 1
+    const ack = await nextMessage(c1);
+    expect(ack.type).toBe('ack');
+
+    // Client 2 should receive the broadcast
+    const broadcast = await nextMessage(c2);
+    expect(broadcast.type).toBe('operation');
+    expect((broadcast.op as { type: string }).type).toBe('insert');
+
+    // Verify document state via REST
+    const doc = await request(baseUrl).get(`/api/documents/${docId}`);
+    expect(doc.body.content).toBe('hello world');
+
+    c1.ws.close();
+    c2.ws.close();
+  });
+
+  it('handles concurrent operations with OT', async () => {
+    const c1 = await createClient(port, docId);
+    const sync1 = await nextMessage(c1) as { version: number };
+
+    const c2 = await createClient(port, docId);
+    const sync2 = await nextMessage(c2) as { version: number };
+
+    // Both clients send inserts based on the same version
+    c1.ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', position: 0, text: 'A' },
+      version: sync1.version,
+    }));
+
+    const ack1 = await nextMessageOfType(c1, 'ack');
+    expect(ack1.type).toBe('ack');
+
+    // Client 2 also based on original version (concurrent)
+    c2.ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', position: 5, text: 'B' },
+      version: sync2.version,
+    }));
+
+    const ack2 = await nextMessageOfType(c2, 'ack');
+    expect(ack2.type).toBe('ack');
+
+    // Both inserts should be present
+    const doc = await request(baseUrl).get(`/api/documents/${docId}`);
+    expect(doc.body.content).toContain('A');
+    expect(doc.body.content).toContain('B');
+    expect(doc.body.content).toContain('hello');
+
+    c1.ws.close();
+    c2.ws.close();
+  });
+
+  it('rejects invalid operations', async () => {
+    const client = await createClient(port, docId);
+    await nextMessage(client); // sync
+
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'replace', position: 0, text: 'x' },
+      version: 1,
+    }));
+
+    const error = await nextMessage(client);
+    expect(error.type).toBe('error');
+    client.ws.close();
+  });
+
+  it('handles 10 concurrent clients', async () => {
+    const clients: MessageQueue[] = [];
+    const syncs: { version: number }[] = [];
+
+    // Connect 10 clients
+    for (let i = 0; i < 10; i++) {
+      const c = await createClient(port, docId);
+      const sync = await nextMessage(c) as { version: number };
+      clients.push(c);
+      syncs.push(sync);
+    }
+
+    // Each client sends an insert at position 0, sequentially to avoid race
+    for (let i = 0; i < 10; i++) {
+      clients[i].ws.send(JSON.stringify({
+        type: 'operation',
+        op: { type: 'insert', position: 0, text: String(i) },
+        version: syncs[i].version,
+      }));
+
+      // Wait for ack
+      const ack = await nextMessageOfType(clients[i], 'ack');
+      expect(ack.type).toBe('ack');
+    }
+
+    // Verify final document contains all digits
+    const doc = await request(baseUrl).get(`/api/documents/${docId}`);
+    for (let i = 0; i < 10; i++) {
+      expect(doc.body.content).toContain(String(i));
+    }
+    // Original content should still be there
+    expect(doc.body.content).toContain('hello');
+
+    for (const c of clients) {
+      c.ws.close();
+    }
+  }, 15000);
+});
