@@ -0,0 +1,130 @@
+import Database from 'better-sqlite3';
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  created_at: string;
+}
+
+export function createDatabase(dbPath: string = ':memory:'): Database.Database {
+  const db = new Database(dbPath);
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      version INTEGER NOT NULL DEFAULT 1,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE,
+      UNIQUE(document_id, version)
+    );
+  `);
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  private stmts: {
+    insert: Database.Statement;
+    getById: Database.Statement;
+    getAll: Database.Statement;
+    update: Database.Statement;
+    delete: Database.Statement;
+    insertVersion: Database.Statement;
+    getVersions: Database.Statement;
+    getVersion: Database.Statement;
+  };
+
+  constructor(db: Database.Database) {
+    this.db = db;
+
+    this.stmts = {
+      insert: db.prepare(
+        `INSERT INTO documents (id, title, content, version) VALUES (?, ?, ?, 1)`
+      ),
+      getById: db.prepare(`SELECT * FROM documents WHERE id = ?`),
+      getAll: db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`),
+      update: db.prepare(
+        `UPDATE documents SET content = ?, version = version + 1, updated_at = datetime('now') WHERE id = ? RETURNING *`
+      ),
+      delete: db.prepare(`DELETE FROM documents WHERE id = ?`),
+      insertVersion: db.prepare(
+        `INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)`
+      ),
+      getVersions: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+      ),
+      getVersion: db.prepare(
+        `SELECT * FROM versions WHERE document_id = ? AND version = ?`
+      ),
+    };
+  }
+
+  create(id: string, title: string, content: string = ''): DocumentRow {
+    this.stmts.insert.run(id, title, content);
+    this.stmts.insertVersion.run(id, 1, content);
+    return this.stmts.getById.get(id) as DocumentRow;
+  }
+
+  getById(id: string): DocumentRow | undefined {
+    return this.stmts.getById.get(id) as DocumentRow | undefined;
+  }
+
+  getAll(): DocumentRow[] {
+    return this.stmts.getAll.all() as DocumentRow[];
+  }
+
+  update(id: string, content: string): DocumentRow | undefined {
+    const doc = this.getById(id);
+    if (!doc) return undefined;
+    this.stmts.update.run(content, id);
+    const updated = this.getById(id)!;
+    this.stmts.insertVersion.run(id, updated.version, content);
+    return updated;
+  }
+
+  updateTitle(id: string, title: string): DocumentRow | undefined {
+    const doc = this.getById(id);
+    if (!doc) return undefined;
+    this.db.prepare(`UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?`).run(title, id);
+    return this.getById(id);
+  }
+
+  delete(id: string): boolean {
+    const result = this.stmts.delete.run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(documentId: string): VersionRow[] {
+    return this.stmts.getVersions.all(documentId) as VersionRow[];
+  }
+
+  getVersion(documentId: string, version: number): VersionRow | undefined {
+    return this.stmts.getVersion.get(documentId, version) as VersionRow | undefined;
+  }
+}
