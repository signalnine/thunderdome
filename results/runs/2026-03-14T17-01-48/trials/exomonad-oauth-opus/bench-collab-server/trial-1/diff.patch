@@ -0,0 +1,91 @@
+import { Router, Request, Response } from 'express';
+import crypto from 'node:crypto';
+import { DocumentStore } from './database.js';
+
+export function createRouter(store: DocumentStore): Router {
+  const router = Router();
+
+  // List all documents
+  router.get('/documents', (_req: Request, res: Response) => {
+    const docs = store.getAll();
+    res.json(docs);
+  });
+
+  // Create a document
+  router.post('/documents', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'title is required and must be a string' });
+      return;
+    }
+    const id = crypto.randomUUID();
+    const doc = store.create(id, title, typeof content === 'string' ? content : '');
+    res.status(201).json(doc);
+  });
+
+  // Get a document
+  router.get('/documents/:id', (req: Request, res: Response) => {
+    const doc = store.getById(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document (full content replacement via REST)
+  router.put('/documents/:id', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+    const doc = store.getById(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (title !== undefined) {
+      store.updateTitle(req.params.id, title);
+    }
+    if (content !== undefined) {
+      store.update(req.params.id, content);
+    }
+    const updated = store.getById(req.params.id)!;
+    res.json(updated);
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req: Request, res: Response) => {
+    const deleted = store.delete(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get version history
+  router.get('/documents/:id/versions', (req: Request, res: Response) => {
+    const doc = store.getById(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = store.getVersions(req.params.id);
+    res.json(versions);
+  });
+
+  // Get a specific version
+  router.get('/documents/:id/versions/:version', (req: Request, res: Response) => {
+    const doc = store.getById(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const version = store.getVersion(req.params.id, parseInt(req.params.version, 10));
+    if (!version) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+    res.json(version);
+  });
+
+  return router;
+}
