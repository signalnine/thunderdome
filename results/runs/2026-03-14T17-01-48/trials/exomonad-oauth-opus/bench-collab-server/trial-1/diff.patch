@@ -0,0 +1,126 @@
+/**
+ * Operational Transformation engine.
+ *
+ * Operations are either:
+ *   { type: 'insert', position: number, text: string }
+ *   { type: 'delete', position: number, length: number }
+ *
+ * transform(op1, op2) returns [op1', op2'] such that
+ *   apply(apply(doc, op1), op2') === apply(apply(doc, op2), op1')
+ */
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  length: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export function applyOp(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    if (op.position < 0 || op.position > doc.length) {
+      throw new Error(`Insert position ${op.position} out of bounds [0, ${doc.length}]`);
+    }
+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);
+  } else {
+    if (op.position < 0 || op.position + op.length > doc.length) {
+      throw new Error(`Delete range [${op.position}, ${op.position + op.length}) out of bounds [0, ${doc.length}]`);
+    }
+    return doc.slice(0, op.position) + doc.slice(op.position + op.length);
+  }
+}
+
+/**
+ * Transform op1 against op2. Returns transformed op1 (op1').
+ * op1' is the version of op1 that should be applied after op2 has been applied.
+ */
+export function transformOp(op1: Operation, op2: Operation): Operation {
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    // Both inserts: if op1 is at or after op2's position, shift op1 right
+    if (op1.position <= op2.position) {
+      return { ...op1 };
+    } else {
+      return { ...op1, position: op1.position + op2.text.length };
+    }
+  }
+
+  if (op1.type === 'insert' && op2.type === 'delete') {
+    if (op1.position <= op2.position) {
+      return { ...op1 };
+    } else if (op1.position >= op2.position + op2.length) {
+      return { ...op1, position: op1.position - op2.length };
+    } else {
+      // Insert is inside the deleted range — move to delete start
+      return { ...op1, position: op2.position };
+    }
+  }
+
+  if (op1.type === 'delete' && op2.type === 'insert') {
+    if (op2.position <= op1.position) {
+      return { ...op1, position: op1.position + op2.text.length };
+    } else if (op2.position >= op1.position + op1.length) {
+      return { ...op1 };
+    } else {
+      // Insert is inside our delete range — expand our delete to account for inserted text
+      return { ...op1, length: op1.length + op2.text.length };
+    }
+  }
+
+  // Both deletes
+  const d1 = op1 as DeleteOp;
+  const d2 = op2 as DeleteOp;
+  const d1End = d1.position + d1.length;
+  const d2End = d2.position + d2.length;
+
+  if (d1End <= d2.position) {
+    // op1 is entirely before op2
+    return { ...d1 };
+  } else if (d1.position >= d2End) {
+    // op1 is entirely after op2
+    return { ...d1, position: d1.position - d2.length };
+  } else if (d2.position <= d1.position && d2End >= d1End) {
+    // op2 entirely covers op1 — nothing left to delete
+    return { type: 'delete', position: d2.position, length: 0 };
+  } else if (d1.position <= d2.position && d1End >= d2End) {
+    // op1 entirely covers op2 — shrink by overlap
+    return { type: 'delete', position: d1.position, length: d1.length - d2.length };
+  } else if (d1.position < d2.position) {
+    // Partial overlap, op1 starts before op2
+    const overlap = d1End - d2.position;
+    return { type: 'delete', position: d1.position, length: d1.length - overlap };
+  } else {
+    // Partial overlap, op1 starts inside op2
+    const overlap = d2End - d1.position;
+    return { type: 'delete', position: d2.position, length: d1.length - overlap };
+  }
+}
+
+/**
+ * Transform op1 against a sequence of operations.
+ */
+export function transformAgainst(op: Operation, ops: Operation[]): Operation {
+  let result = op;
+  for (const other of ops) {
+    result = transformOp(result, other);
+  }
+  return result;
+}
+
+export function validateOp(op: unknown): op is Operation {
+  if (!op || typeof op !== 'object') return false;
+  const o = op as Record<string, unknown>;
+  if (o.type === 'insert') {
+    return typeof o.position === 'number' && o.position >= 0 && typeof o.text === 'string' && o.text.length > 0;
+  }
+  if (o.type === 'delete') {
+    return typeof o.position === 'number' && o.position >= 0 && typeof o.length === 'number' && o.length > 0;
+  }
+  return false;
+}
