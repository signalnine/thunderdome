@@ -0,0 +1,62 @@
+import express from 'express';
+import http from 'node:http';
+import { createDatabase, DocumentStore } from './database.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath || ':memory:');
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+  app.use('/api', createRouter(store));
+
+  let server: http.Server | null = null;
+  let collab: CollaborationServer | null = null;
+
+  return {
+    app,
+
+    start(port: number = 0): Promise<number> {
+      return new Promise((resolve, reject) => {
+        server = http.createServer(app);
+        collab = new CollaborationServer(server, store);
+
+        server.on('error', reject);
+        server.listen(port, () => {
+          const addr = server!.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            resolve(port);
+          }
+        });
+      });
+    },
+
+    stop(): Promise<void> {
+      return new Promise((resolve) => {
+        if (collab) {
+          collab.closeAll();
+          collab = null;
+        }
+        if (server) {
+          server.close(() => {
+            db.close();
+            resolve();
+          });
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    },
+  };
+}
