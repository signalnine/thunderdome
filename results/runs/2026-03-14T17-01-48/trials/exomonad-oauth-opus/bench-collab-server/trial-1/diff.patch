+import { describe, it, expect } from 'vitest';
+import { applyOp, transformOp, validateOp, Operation } from '../src/ot.js';
+
+describe('applyOp', () => {
+  it('inserts text at position', () => {
+    expect(applyOp('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+  });
+
+  it('inserts at beginning', () => {
+    expect(applyOp('world', { type: 'insert', position: 0, text: 'hello ' })).toBe('hello world');
+  });
+
+  it('deletes text at position', () => {
+    expect(applyOp('hello world', { type: 'delete', position: 5, length: 6 })).toBe('hello');
+  });
+
+  it('throws on out-of-bounds insert', () => {
+    expect(() => applyOp('hi', { type: 'insert', position: 10, text: 'x' })).toThrow();
+  });
+
+  it('throws on out-of-bounds delete', () => {
+    expect(() => applyOp('hi', { type: 'delete', position: 1, length: 5 })).toThrow();
+  });
+});
+
+describe('transformOp', () => {
+  it('transforms insert vs insert (op1 before op2)', () => {
+    const op1: Operation = { type: 'insert', position: 2, text: 'A' };
+    const op2: Operation = { type: 'insert', position: 5, text: 'B' };
+    const t1 = transformOp(op1, op2);
+    expect(t1.type === 'insert' && t1.position).toBe(2);
+  });
+
+  it('transforms insert vs insert (op1 after op2)', () => {
+    const op1: Operation = { type: 'insert', position: 5, text: 'A' };
+    const op2: Operation = { type: 'insert', position: 2, text: 'BB' };
+    const t1 = transformOp(op1, op2);
+    expect(t1.type === 'insert' && t1.position).toBe(7);
+  });
+
+  it('transforms insert vs delete (insert before delete)', () => {
+    const op1: Operation = { type: 'insert', position: 1, text: 'X' };
+    const op2: Operation = { type: 'delete', position: 3, length: 2 };
+    const t1 = transformOp(op1, op2);
+    expect(t1.type === 'insert' && t1.position).toBe(1);
+  });
+
+  it('transforms insert vs delete (insert after delete)', () => {
+    const op1: Operation = { type: 'insert', position: 5, text: 'X' };
+    const op2: Operation = { type: 'delete', position: 1, length: 2 };
+    const t1 = transformOp(op1, op2);
+    expect(t1.type === 'insert' && t1.position).toBe(3);
+  });
+
+  it('preserves convergence for concurrent inserts', () => {
+    const doc = 'abcdef';
+    const op1: Operation = { type: 'insert', position: 2, text: 'X' };
+    const op2: Operation = { type: 'insert', position: 4, text: 'Y' };
+
+    const t1 = transformOp(op1, op2);
+    const t2 = transformOp(op2, op1);
+
+    const path1 = applyOp(applyOp(doc, op1), t2);
+    const path2 = applyOp(applyOp(doc, op2), t1);
+    expect(path1).toBe(path2);
+  });
+
+  it('preserves convergence for concurrent delete and insert', () => {
+    const doc = 'abcdef';
+    const op1: Operation = { type: 'delete', position: 1, length: 2 };
+    const op2: Operation = { type: 'insert', position: 3, text: 'XY' };
+
+    const t1 = transformOp(op1, op2);
+    const t2 = transformOp(op2, op1);
+
+    const path1 = applyOp(applyOp(doc, op1), t2);
+    const path2 = applyOp(applyOp(doc, op2), t1);
+    expect(path1).toBe(path2);
+  });
+
+  it('preserves convergence for overlapping deletes', () => {
+    const doc = 'abcdefgh';
+    const op1: Operation = { type: 'delete', position: 2, length: 3 };
+    const op2: Operation = { type: 'delete', position: 4, length: 3 };
+
+    const t1 = transformOp(op1, op2);
+    const t2 = transformOp(op2, op1);
+
+    const path1 = applyOp(applyOp(doc, op1), t2);
+    const path2 = applyOp(applyOp(doc, op2), t1);
+    expect(path1).toBe(path2);
+  });
+});
+
+describe('validateOp', () => {
+  it('accepts valid insert', () => {
+    expect(validateOp({ type: 'insert', position: 0, text: 'hi' })).toBe(true);
+  });
+
+  it('accepts valid delete', () => {
+    expect(validateOp({ type: 'delete', position: 0, length: 5 })).toBe(true);
+  });
+
+  it('rejects empty text insert', () => {
+    expect(validateOp({ type: 'insert', position: 0, text: '' })).toBe(false);
+  });
+
+  it('rejects zero-length delete', () => {
+    expect(validateOp({ type: 'delete', position: 0, length: 0 })).toBe(false);
+  });
+
+  it('rejects negative position', () => {
+    expect(validateOp({ type: 'insert', position: -1, text: 'x' })).toBe(false);
+  });
+
+  it('rejects unknown type', () => {
+    expect(validateOp({ type: 'replace', position: 0 })).toBe(false);
+  });
+
+  it('rejects null', () => {
+    expect(validateOp(null)).toBe(false);
+  });
+});
diff --git a/tests/websocket.test.ts b/tests/websocket.test.ts
