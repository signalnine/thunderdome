@@ -0,0 +1,208 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'node:http';
+import { Server as HttpServer } from 'node:http';
+import { DocumentStore } from './database.js';
+import { Operation, applyOp, transformOp, validateOp } from './ot.js';
+
+interface ClientInfo {
+  ws: WebSocket;
+  documentId: string;
+  clientId: string;
+}
+
+interface OperationEntry {
+  op: Operation;
+  clientId: string;
+  version: number;
+}
+
+/**
+ * Per-document state tracking for OT.
+ */
+interface DocumentSession {
+  /** Operations applied since the document was loaded, in order */
+  history: OperationEntry[];
+  /** Current server version (starts at the DB version when first loaded) */
+  serverVersion: number;
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private store: DocumentStore;
+  /** documentId -> Set<ClientInfo> */
+  private rooms: Map<string, Set<ClientInfo>> = new Map();
+  /** documentId -> DocumentSession */
+  private sessions: Map<string, DocumentSession> = new Map();
+
+  constructor(server: HttpServer, store: DocumentStore) {
+    this.store = store;
+    this.wss = new WebSocketServer({ noServer: true });
+
+    server.on('upgrade', (request: IncomingMessage, socket, head) => {
+      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);
+      const match = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+      if (!match) {
+        socket.destroy();
+        return;
+      }
+      const documentId = match[1];
+      this.wss.handleUpgrade(request, socket, head, (ws) => {
+        this.onConnection(ws, documentId);
+      });
+    });
+  }
+
+  private getOrCreateSession(documentId: string, dbVersion: number): DocumentSession {
+    let session = this.sessions.get(documentId);
+    if (!session) {
+      session = { history: [], serverVersion: dbVersion };
+      this.sessions.set(documentId, session);
+    }
+    return session;
+  }
+
+  private onConnection(ws: WebSocket, documentId: string) {
+    const doc = this.store.getById(documentId);
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    const clientId = Math.random().toString(36).slice(2, 10);
+    const client: ClientInfo = { ws, documentId, clientId };
+
+    if (!this.rooms.has(documentId)) {
+      this.rooms.set(documentId, new Set());
+    }
+    this.rooms.get(documentId)!.add(client);
+
+    const session = this.getOrCreateSession(documentId, doc.version);
+
+    // Send sync message with current content
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: doc.content,
+      version: session.serverVersion,
+      clientId,
+    }));
+
+    ws.on('message', (data) => {
+      try {
+        const message = JSON.parse(data.toString());
+        this.handleMessage(client, message);
+      } catch {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+      }
+    });
+
+    ws.on('close', () => {
+      const room = this.rooms.get(documentId);
+      if (room) {
+        room.delete(client);
+        if (room.size === 0) {
+          this.rooms.delete(documentId);
+          this.sessions.delete(documentId);
+        }
+      }
+    });
+  }
+
+  private handleMessage(client: ClientInfo, message: Record<string, unknown>) {
+    if (message.type !== 'operation') {
+      client.ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${message.type}` }));
+      return;
+    }
+
+    const op = message.op as unknown;
+    if (!validateOp(op)) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation' }));
+      return;
+    }
+
+    const clientVersion = message.version;
+    if (typeof clientVersion !== 'number') {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'version is required' }));
+      return;
+    }
+
+    const doc = this.store.getById(client.documentId);
+    if (!doc) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      return;
+    }
+
+    const session = this.getOrCreateSession(client.documentId, doc.version);
+
+    // Transform the incoming op against all operations that happened since client's version
+    let transformedOp = op as Operation;
+    const startIdx = clientVersion - (session.serverVersion - session.history.length);
+    if (startIdx < 0) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Client version too old' }));
+      return;
+    }
+
+    for (let i = startIdx; i < session.history.length; i++) {
+      transformedOp = transformOp(transformedOp, session.history[i].op);
+    }
+
+    // Apply the transformed operation to the document
+    try {
+      // Skip no-op deletes
+      if (transformedOp.type === 'delete' && transformedOp.length === 0) {
+        // No-op after transform, still ack the client
+        session.serverVersion++;
+        session.history.push({ op: transformedOp, clientId: client.clientId, version: session.serverVersion });
+
+        client.ws.send(JSON.stringify({
+          type: 'ack',
+          version: session.serverVersion,
+        }));
+        return;
+      }
+
+      const newContent = applyOp(doc.content, transformedOp);
+      this.store.update(client.documentId, newContent);
+      session.serverVersion++;
+      session.history.push({ op: transformedOp, clientId: client.clientId, version: session.serverVersion });
+
+      // Ack the sender
+      client.ws.send(JSON.stringify({
+        type: 'ack',
+        version: session.serverVersion,
+      }));
+
+      // Broadcast to other clients
+      const room = this.rooms.get(client.documentId);
+      if (room) {
+        const broadcast = JSON.stringify({
+          type: 'operation',
+          op: transformedOp,
+          version: session.serverVersion,
+          clientId: client.clientId,
+        });
+        for (const other of room) {
+          if (other.clientId !== client.clientId && other.ws.readyState === WebSocket.OPEN) {
+            other.ws.send(broadcast);
+          }
+        }
+      }
+    } catch (err) {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: err instanceof Error ? err.message : 'Failed to apply operation',
+      }));
+    }
+  }
+
+  closeAll() {
+    for (const room of this.rooms.values()) {
+      for (const client of room) {
+        client.ws.close();
+      }
+    }
+    this.rooms.clear();
+    this.sessions.clear();
+    this.wss.close();
+  }
+}
