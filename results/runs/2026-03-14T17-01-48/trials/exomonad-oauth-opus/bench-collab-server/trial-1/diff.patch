+import { describe, it, expect, beforeAll, afterAll } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+describe('REST API', () => {
+  let instance: AppInstance;
+  let port: number;
+  let baseUrl: string;
+
+  beforeAll(async () => {
+    instance = createApp();
+    port = await instance.start(0);
+    baseUrl = `http://localhost:${port}`;
+  });
+
+  afterAll(async () => {
+    await instance.stop();
+  });
+
+  it('creates a document', async () => {
+    const res = await request(baseUrl)
+      .post('/api/documents')
+      .send({ title: 'Test Doc', content: 'Hello' });
+    expect(res.status).toBe(201);
+    expect(res.body.title).toBe('Test Doc');
+    expect(res.body.content).toBe('Hello');
+    expect(res.body.version).toBe(1);
+    expect(res.body.id).toBeDefined();
+  });
+
+  it('rejects document without title', async () => {
+    const res = await request(baseUrl)
+      .post('/api/documents')
+      .send({ content: 'Hello' });
+    expect(res.status).toBe(400);
+  });
+
+  it('lists documents', async () => {
+    const res = await request(baseUrl).get('/api/documents');
+    expect(res.status).toBe(200);
+    expect(Array.isArray(res.body)).toBe(true);
+    expect(res.body.length).toBeGreaterThanOrEqual(1);
+  });
+
+  it('gets a document by id', async () => {
+    const create = await request(baseUrl)
+      .post('/api/documents')
+      .send({ title: 'Fetch Me' });
+    const res = await request(baseUrl).get(`/api/documents/${create.body.id}`);
+    expect(res.status).toBe(200);
+    expect(res.body.title).toBe('Fetch Me');
+  });
+
+  it('returns 404 for missing document', async () => {
+    const res = await request(baseUrl).get('/api/documents/nonexistent');
+    expect(res.status).toBe(404);
+  });
+
+  it('updates a document', async () => {
+    const create = await request(baseUrl)
+      .post('/api/documents')
+      .send({ title: 'Update Me', content: 'v1' });
+    const res = await request(baseUrl)
+      .put(`/api/documents/${create.body.id}`)
+      .send({ content: 'v2', title: 'Updated' });
+    expect(res.status).toBe(200);
+    expect(res.body.content).toBe('v2');
+    expect(res.body.title).toBe('Updated');
+  });
+
+  it('deletes a document', async () => {
+    const create = await request(baseUrl)
+      .post('/api/documents')
+      .send({ title: 'Delete Me' });
+    const del = await request(baseUrl).delete(`/api/documents/${create.body.id}`);
+    expect(del.status).toBe(204);
+    const get = await request(baseUrl).get(`/api/documents/${create.body.id}`);
+    expect(get.status).toBe(404);
+  });
+
+  it('tracks version history', async () => {
+    const create = await request(baseUrl)
+      .post('/api/documents')
+      .send({ title: 'Versioned', content: 'v1' });
+    await request(baseUrl)
+      .put(`/api/documents/${create.body.id}`)
+      .send({ content: 'v2' });
+    await request(baseUrl)
+      .put(`/api/documents/${create.body.id}`)
+      .send({ content: 'v3' });
+
+    const versions = await request(baseUrl).get(`/api/documents/${create.body.id}/versions`);
+    expect(versions.status).toBe(200);
+    expect(versions.body.length).toBe(3);
+    expect(versions.body[0].content).toBe('v1');
+    expect(versions.body[2].content).toBe('v3');
+  });
+
+  it('gets a specific version', async () => {
+    const create = await request(baseUrl)
+      .post('/api/documents')
+      .send({ title: 'VersionGet', content: 'initial' });
+    await request(baseUrl)
+      .put(`/api/documents/${create.body.id}`)
+      .send({ content: 'second' });
+
+    const v1 = await request(baseUrl).get(`/api/documents/${create.body.id}/versions/1`);
+    expect(v1.status).toBe(200);
+    expect(v1.body.content).toBe('initial');
+
+    const v2 = await request(baseUrl).get(`/api/documents/${create.body.id}/versions/2`);
+    expect(v2.status).toBe(200);
+    expect(v2.body.content).toBe('second');
+  });
+});
