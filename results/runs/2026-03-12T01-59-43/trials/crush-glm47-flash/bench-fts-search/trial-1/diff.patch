@@ -118,5 +118,83 @@ export function createRoutes(db: Database.Database): Router {
     }
   });
 
+  // GET /notes/search - Full-text search
+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      console.log(`[search] Received request for query: ${req.query.q}`);
+      const query = req.query.q as string | undefined;
+
+      if (!query || query.trim() === '') {
+        console.log(`[search] Missing or empty query`);
+        throw new ValidationError('Query parameter "q" is required');
+      }
+
+      const searchQuery = query.trim();
+      const page = parseInt(req.query.page as string || '1');
+      const perPage = 20;
+      const offset = (page - 1) * perPage;
+
+      // Get total count
+      const countStmt = db.prepare(`
+        SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?
+      `);
+      const countResult = countStmt.all(searchQuery) as { total: number }[];
+      const total = countResult[0]?.total || 0;
+
+      // Get paginated results with BM25 ranking
+      const searchStmt = db.prepare(`
+        SELECT
+          notes.id,
+          notes.title,
+          snippet(notes_fts, 1, '<mark>', '</mark>', '...', 30) as snippet,
+          bm25(notes_fts) as rank
+        FROM notes_fts
+        INNER JOIN notes ON notes_fts.id = notes.id
+        WHERE notes_fts MATCH ?
+        ORDER BY rank
+        LIMIT ? OFFSET ?
+      `);
+      const results = searchStmt.all(searchQuery, perPage, offset) as any[];
+
+      res.json({
+        results,
+        total,
+        page,
+        perPage
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /notes/search/suggest - Autocomplete suggestions
+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const query = req.query.q as string | undefined;
+
+      if (!query || query.trim() === '') {
+        throw new ValidationError('Query parameter "q" is required');
+      }
+
+      const prefix = query.trim();
+
+      const suggestStmt = db.prepare(`
+        SELECT
+          notes.id,
+          notes.title
+        FROM notes_fts
+        INNER JOIN notes ON notes_fts.id = notes.id
+        WHERE notes_fts MATCH ? || '*'
+        LIMIT 5
+      `);
+
+      const results = suggestStmt.all(prefix) as { id: number; title: string }[];
+
+      res.json({ results });
+    } catch (err) {
+      next(err);
+    }
+  });
+
   return router;
 }
