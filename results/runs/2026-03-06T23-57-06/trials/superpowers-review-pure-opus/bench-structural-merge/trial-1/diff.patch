+import type { Version, MergeResult, Conflict, DocumentState, BranchState } from './types.js';
+import { deepClone, generateId, threeWayMerge, deepEqual } from './utils.js';
+
+export type { Version, MergeResult, Conflict };
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      forkPoint: null,
+      forkedFrom: null,
+    });
+  }
+
+  // ── Document CRUD ──────────────────────────────────────────────────
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  // ── Version History ────────────────────────────────────────────────
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ── Branching ──────────────────────────────────────────────────────
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" does not exist`);
+    }
+
+    // Deep clone the source branch's documents
+    const clonedDocs = this.cloneDocuments(source.documents);
+    const forkSnapshot = this.cloneDocuments(source.documents);
+
+    this.branches.set(name, {
+      documents: clonedDocs,
+      forkPoint: forkSnapshot,
+      forkedFrom: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ── Merging ────────────────────────────────────────────────────────
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    const target = this.getCurrentBranchState();
+
+    // Find the common ancestor (base):
+    // The base is the fork point. We need to find the common ancestor state.
+    // If the source was forked from the current branch, use the source's fork point.
+    // If the current branch was forked from the source, use the current branch's fork point.
+    // Otherwise, use an empty state as base.
+    const base = this.findCommonAncestor(sourceBranch);
+
+    // Collect all document IDs from base, source, and target
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const id of source.documents.keys()) allDocIds.add(id);
+    for (const id of target.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseDoc = base.get(docId);
+      const ourDoc = target.documents.get(docId);
+      const theirDoc = source.documents.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content as Record<string, unknown> : null;
+      const ourContent = ourDoc && !ourDoc.deleted ? ourDoc.content as Record<string, unknown> : null;
+      const theirContent = theirDoc && !theirDoc.deleted ? theirDoc.content as Record<string, unknown> : null;
+
+      // Both sides are the same as base - no change needed
+      if (this.contentEqual(baseContent, ourContent) && this.contentEqual(baseContent, theirContent)) {
+        if (ourContent !== null) {
+          merged[docId] = deepClone(ourContent);
+        }
+        continue;
+      }
+
+      const ourChanged = !this.contentEqual(baseContent, ourContent);
+      const theirChanged = !this.contentEqual(baseContent, theirContent);
+
+      if (!ourChanged && theirChanged) {
+        // Only source changed - take theirs
+        if (theirContent !== null) {
+          merged[docId] = deepClone(theirContent);
+        }
+        // If they deleted it (theirContent is null), don't include in merged
+      } else if (ourChanged && !theirChanged) {
+        // Only target changed - keep ours
+        if (ourContent !== null) {
+          merged[docId] = deepClone(ourContent);
+        }
+      } else {
+        // Both changed
+        if (this.contentEqual(ourContent, theirContent)) {
+          // Both changed to the same - no conflict
+          if (ourContent !== null) {
+            merged[docId] = deepClone(ourContent);
+          }
+        } else if (ourContent === null && theirContent !== null) {
+          // We deleted, they modified — conflict at document level
+          allConflicts.push({
+            documentId: docId,
+            path: '',
+            base: baseContent !== null ? deepClone(baseContent) : undefined,
+            ours: undefined,
+            theirs: deepClone(theirContent),
+          });
+          // "ours" wins for merged preview — document stays deleted, so don't add to merged
+        } else if (ourContent !== null && theirContent === null) {
+          // They deleted, we modified — conflict at document level
+          allConflicts.push({
+            documentId: docId,
+            path: '',
+            base: baseContent !== null ? deepClone(baseContent) : undefined,
+            ours: deepClone(ourContent),
+            theirs: undefined,
+          });
+          // "ours" wins — keep our version
+          merged[docId] = deepClone(ourContent);
+        } else if (ourContent !== null && theirContent !== null) {
+          // Both modified — three-way merge at field level
+          const baseObj = baseContent ?? {};
+          const { result, conflicts } = threeWayMerge(
+            baseObj,
+            ourContent,
+            theirContent,
+            docId
+          );
+          merged[docId] = result;
+          allConflicts.push(...conflicts);
+        }
+        // Both deleted — no conflict, document stays deleted
+      }
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existingDoc = target.documents.get(docId);
+          if (existingDoc && !existingDoc.deleted) {
+            // Check if content actually changed
+            if (!deepEqual(existingDoc.content, merged[docId])) {
+              const version: Version = {
+                id: generateId(),
+                timestamp: Date.now(),
+                content: deepClone(merged[docId]),
+              };
+              existingDoc.content = deepClone(merged[docId]);
+              existingDoc.versions.push(version);
+            }
+          } else if (!existingDoc) {
+            // Document is new to this branch
+            const cloned = deepClone(merged[docId]);
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(cloned),
+            };
+            target.documents.set(docId, {
+              content: cloned,
+              versions: [version],
+              deleted: false,
+            });
+          } else {
+            // Was deleted on our side but merge brings it back (no-conflict case)
+            const cloned = deepClone(merged[docId]);
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(cloned),
+            };
+            existingDoc.content = cloned;
+            existingDoc.deleted = false;
+            existingDoc.versions.push(version);
+          }
+        } else {
+          // Not in merged means it should be deleted
+          const existingDoc = target.documents.get(docId);
+          if (existingDoc && !existingDoc.deleted) {
+            existingDoc.deleted = true;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  // ── Private Helpers ────────────────────────────────────────────────
+
+  private getCurrentBranchState(): BranchState {
+    const branch = this.branches.get(this.currentBranch);
+    if (!branch) {
+      throw new Error(`Branch "${this.currentBranch}" does not exist`);
+    }
+    return branch;
+  }
+
+  private cloneDocuments(docs: Map<string, DocumentState>): Map<string, DocumentState> {
+    const cloned = new Map<string, DocumentState>();
+    for (const [id, doc] of docs) {
+      cloned.set(id, {
+        content: deepClone(doc.content),
+        versions: doc.versions.map(v => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+        deleted: doc.deleted,
+      });
+    }
+    return cloned;
+  }
+
+  private contentEqual(a: object | null, b: object | null): boolean {
+    if (a === null && b === null) return true;
+    if (a === null || b === null) return false;
+    return deepEqual(a, b);
+  }
+
+  /**
+   * Find the common ancestor state for merging sourceBranch into the current branch.
+   * Returns a Map of document states representing the base.
+   *
+   * For sibling branches (both forked from the same parent), the common ancestor
+   * is the earlier fork point, since the earlier snapshot represents the state
+   * both branches diverged from.
+   */
+  private findCommonAncestor(sourceBranch: string): Map<string, DocumentState> {
+    const source = this.branches.get(sourceBranch)!;
+    const target = this.getCurrentBranchState();
+
+    // If source was forked from current branch, use source's fork point
+    if (source.forkedFrom === this.currentBranch && source.forkPoint) {
+      return source.forkPoint;
+    }
+
+    // If current branch was forked from source, use current branch's fork point
+    if (target.forkedFrom === sourceBranch && target.forkPoint) {
+      return target.forkPoint;
+    }
+
+    // Walk up both fork chains to find the common ancestor branch.
+    // Build source's ancestor chain with the fork points at each step
+    const sourceChain = new Map<string, BranchState>();
+    let cur: string | null = sourceBranch;
+    while (cur) {
+      const branch = this.branches.get(cur);
+      if (!branch) break;
+      sourceChain.set(cur, branch);
+      cur = branch.forkedFrom;
+    }
+
+    // Walk up target's chain to find common ancestor
+    cur = this.currentBranch;
+    while (cur) {
+      if (sourceChain.has(cur)) {
+        // `cur` is the common ancestor branch.
+        // We need the fork point of the branch that was forked from `cur`.
+        // Find the source-side branch that was forked from `cur`
+        let sourceForkFromAncestor: BranchState | null = null;
+        let walk: string | null = sourceBranch;
+        while (walk) {
+          const b = this.branches.get(walk);
+          if (!b) break;
+          if (b.forkedFrom === cur) {
+            sourceForkFromAncestor = b;
+            break;
+          }
+          walk = b.forkedFrom;
+        }
+
+        // Find the target-side branch that was forked from `cur`
+        let targetForkFromAncestor: BranchState | null = null;
+        walk = this.currentBranch;
+        while (walk) {
+          const b = this.branches.get(walk);
+          if (!b) break;
+          if (b.forkedFrom === cur) {
+            targetForkFromAncestor = b;
+            break;
+          }
+          walk = b.forkedFrom;
+        }
+
+        // Use the earlier fork point as the common ancestor
+        const sourceFP = sourceForkFromAncestor?.forkPoint;
+        const targetFP = targetForkFromAncestor?.forkPoint;
+
+        if (sourceFP && targetFP) {
+          // Compare by picking the earlier snapshot. We use the fork point
+          // from the branch that was created first (has fewer/earlier versions).
+          // Since both are snapshots of the same parent branch, the earlier
+          // one is the true common ancestor.
+          // We determine "earlier" by checking document version counts -
+          // the earlier fork point will have fewer or equal versions.
+          return this.earlierForkPoint(sourceFP, targetFP);
+        }
+        if (sourceFP) return sourceFP;
+        if (targetFP) return targetFP;
+        break;
+      }
+      const branch = this.branches.get(cur);
+      cur = branch?.forkedFrom ?? null;
+    }
+
+    // Fallback: empty state as base
+    return new Map();
+  }
+
+  /**
+   * Compare two fork points and return the one that represents an earlier state.
+   * We compare by total version count across all documents — the earlier fork
+   * has fewer total versions since fewer updates had been made at that point.
+   */
+  private earlierForkPoint(
+    a: Map<string, DocumentState>,
+    b: Map<string, DocumentState>
+  ): Map<string, DocumentState> {
+    let aVersions = 0;
+    let bVersions = 0;
+    for (const doc of a.values()) {
+      aVersions += doc.versions.length;
+    }
+    for (const doc of b.values()) {
+      bVersions += doc.versions.length;
+    }
+    return aVersions <= bVersions ? a : b;
+  }
+}
