 });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Charlie', age: 31 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      // merged should show ours for conflicting field, theirs for non-conflicting\n      expect(result.merged['doc1']).toEqual({ name: 'Bob', age: 31 });\n    });\n\n    it('should handle deep nested object merging', () => {\n      store.create('doc1', {\n        user: {\n          name: 'Alice',\n          address: {\n            city: 'NYC',\n            zip: '10001',\n          },\n        },\n      });\n      store.createBranch('feature');\n\n      // Modify city on main\n      store.update('doc1', {\n        user: {\n          name: 'Alice',\n          address: {\n            city: 'LA',\n            zip: '10001',\n          },\n        },\n      });\n\n      // Modify zip on feature\n      store.switchBranch('feature');\n      store.update('doc1', {\n        user: {\n          name: 'Alice',\n          address: {\n            city: 'NYC',\n            zip: '90001',\n          },\n        },\n      });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({\n        user: {\n          name: 'Alice',\n          address: {\n            city: 'LA',\n            zip: '90001',\n          },\n        },\n      });\n    });\n\n    it('should report deep nested conflicts with dot-separated path', () => {\n      store.create('doc1', {\n        user: {\n          address: {\n            city: 'NYC',\n          },\n        },\n      });\n      store.createBranch('feature');\n\n      store.update('doc1', { user: { address: { city: 'LA' } } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { user: { address: { city: 'Chicago' } } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('user.address.city');\n      expect(result.conflicts[0].base).toBe('NYC');\n      expect(result.conflicts[0].ours).toBe('LA');\n      expect(result.conflicts[0].theirs).toBe('Chicago');\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Charlie' });\n\n      store.switchBranch('main');\n      store.merge('feature');\n\n      // Main should be unchanged\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should handle adding new fields on source branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice', email: 'alice@example.com' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'Alice', email: 'alice@example.com' });\n    });\n\n    it('should handle removing fields on source branch', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should merge with new documents on both branches without conflict', () => {\n      store.createBranch('feature');\n\n      store.create('doc1', { name: 'Alice' });\n\n      store.switchBranch('feature');\n      store.create('doc2', { name: 'Bob' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n      expect(store.get('doc2')).toEqual({ name: 'Bob' });\n    });\n\n    it('should handle array values in documents', () => {\n      store.create('doc1', { tags: ['a', 'b'], name: 'test' });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { tags: ['a', 'b', 'c'], name: 'test' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ tags: ['a', 'b', 'c'], name: 'test' });\n    });\n\n    it('should conflict on array values changed differently', () => {\n      store.create('doc1', { tags: ['a', 'b'] });\n      store.createBranch('feature');\n\n      store.update('doc1', { tags: ['a', 'b', 'c'] });\n\n      store.switchBranch('feature');\n      store.update('doc1', { tags: ['a', 'b', 'd'] });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('tags');\n    });\n\n    it('should throw when merging from non-existent branch', () => {\n      expect(() => store.merge('nonexistent')).toThrow();\n    });\n\n    it('should create a new version when merge is applied', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n\n      store.switchBranch('main');\n      const historyBefore = store.getHistory('doc1');\n      store.merge('feature');\n      const historyAfter = store.getHistory('doc1');\n\n      expect(historyAfter.length).toBe(historyBefore.length + 1);\n      expect(historyAfter[historyAfter.length - 1].content).toEqual({ name: 'Bob' });\n    });\n\n    it('should handle merge with document created on both branches (conflict)', () => {\n      store.createBranch('feature');\n\n      store.create('doc1', { name: 'Alice' });\n\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'Bob' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      // Both sides created the same doc with different content - conflict\n      expect(result.applied).toBe(false);\n      expect(result.conflicts.length).toBeGreaterThan(0);\n    });\n  });\n\n  // ── Edge Cases ─────────────────────────────────────────────────────\n\n  describe('Edge Cases', () => {\n    it('should handle empty objects', () => {\n      store.create('doc1', {});\n      expect(store.get('doc1')).toEqual({});\n    });\n\n    it('should handle complex nested structures', () => {\n      const complex = {\n        users: [\n          { name: 'Alice', age: 30 },\n          { name: 'Bob', age: 25 },\n        ],\n        metadata: {\n          version: 1,\n          tags: ['important', 'reviewed'],\n          nested: {\n            deep: {\n              value: true,\n            },\n          },\n        },\n      };\n      store.create('doc1', complex);\n      expect(store.get('doc1')).toEqual(complex);\n    });\n\n    it('should handle multiple sequential merges', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature1');\n      store.switchBranch('feature1');\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      store.switchBranch('main');\n      store.merge('feature1');\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n\n      store.createBranch('feature2');\n      store.switchBranch('feature2');\n      store.update('doc1', { name: 'Bob', age: 31 });\n\n      store.switchBranch('main');\n      store.merge('feature2');\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 31 });\n    });\n\n    it('should handle many documents', () => {\n      for (let i = 0; i < 100; i++) {\n        store.create(`doc${i}`, { index: i });\n      }\n      for (let i = 0; i < 100; i++) {\n        expect(store.get(`doc${i}`)).toEqual({ index: i });\n      }\n    });\n\n    it('should handle multiple branches', () => {\n      store.create('doc1', { value: 0 });\n      store.createBranch('b1');\n      store.createBranch('b2');\n      store.createBranch('b3');\n\n      store.switchBranch('b1');\n      store.update('doc1', { value: 1 });\n\n      store.switchBranch('b2');\n      store.update('doc1', { value: 2 });\n\n      store.switchBranch('b3');\n      store.update('doc1', { value: 3 });\n\n      // Each branch should have its own value\n      store.switchBranch('b1');\n      expect(store.get('doc1')).toEqual({ value: 1 });\n      store.switchBranch('b2');\n      expect(store.get('doc1')).toEqual({ value: 2 });\n      store.switchBranch('b3');\n      expect(store.get('doc1')).toEqual({ value: 3 });\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ value: 0 });\n    });\n\n    it('should handle null values in documents', () => {\n      store.create('doc1', { name: null, age: 30 });\n      expect(store.get('doc1')).toEqual({ name: null, age: 30 });\n    });\n\n    it('should handle boolean values in documents', () => {\n      store.create('doc1', { active: true, deleted: false });\n      expect(store.get('doc1')).toEqual({ active: true, deleted: false });\n    });\n\n    it('should handle numeric values including zero', () => {\n      store.create('doc1', { count: 0, total: -1, ratio: 0.5 });\n      expect(store.get('doc1')).toEqual({ count: 0, total: -1, ratio: 0.5 });\n    });\n  });\n});\n","numLines":363,"startLine":370,"totalLines":732}}}
