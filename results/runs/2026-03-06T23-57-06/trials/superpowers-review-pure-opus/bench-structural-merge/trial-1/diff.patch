ocument states representing the base.\n   336→   */\n   337→  private findCommonAncestor(sourceBranch: string): Map<string, DocumentState> {\n   338→    const source = this.branches.get(sourceBranch)!;\n   339→    const target = this.getCurrentBranchState();\n   340→\n   341→    // If source was forked from current branch, use source's fork point\n   342→    if (source.forkedFrom === this.currentBranch && source.forkPoint) {\n   343→      return source.forkPoint;\n   344→    }\n   345→\n   346→    // If current branch was forked from source, use current branch's fork point\n   347→    if (target.forkedFrom === sourceBranch && target.forkPoint) {\n   348→      return target.forkPoint;\n   349→    }\n   350→\n   351→    // If both were forked from the same branch, we need to find the common state.\n   352→    // For simplicity, if they share a common ancestor through fork chains, try to find it.\n   353→    // Walk up source's fork chain\n   354→    const sourceAncestors = new Set<string>();\n   355→    let current: string | null = sourceBranch;\n   356→    while (current) {\n   357→      sourceAncestors.add(current);\n   358→      const branch = this.branches.get(current);\n   359→      current = branch?.forkedFrom ?? null;\n   360→    }\n   361→\n   362→    // Walk up target's fork chain to find common ancestor\n   363→    current = this.currentBranch;\n   364→    while (current) {\n   365→      if (sourceAncestors.has(current)) {\n   366→        // Found common ancestor branch\n   367→        // Use the fork point of whichever branch was forked from this common ancestor\n   368→        if (source.forkedFrom === current && source.forkPoint) {\n   369→          return source.forkPoint;\n   370→        }\n   371→        if (target.forkedFrom === current && target.forkPoint) {\n   372→          return target.forkPoint;\n   373→        }\n   374→        break;\n   375→      }\n   376→      const branch = this.branches.get(current);\n   377→      current = branch?.forked