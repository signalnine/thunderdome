47→    const val = obj[key];\n   148→    if (val !== null && typeof val === 'object' && !Array.isArray(val)) {\n   149→      paths.push(...collectAllPaths(val as Record<string, unknown>, path));\n   150→    }\n   151→  }\n   152→  return paths;\n   153→}\n   154→\n   155→/**\n   156→ * Three-way structural merge of two objects against a common base.\n   157→ * Returns the merged result and any conflicts.\n   158→ */\n   159→export function threeWayMerge(\n   160→  base: Record<string, unknown>,\n   161→  ours: Record<string, unknown>,\n   162→  theirs: Record<string, unknown>,\n   163→  documentId: string\n   164→): { result: Record<string, unknown>; conflicts: Conflict[] } {\n   165→  const conflicts: Conflict[] = [];\n   166→\n   167→  // Collect all leaf paths from all three versions\n   168→  const basePaths = new Set(collectPaths(base, ''));\n   169→  const ourPaths = new Set(collectPaths(ours, ''));\n   170→  const theirPaths = new Set(collectPaths(theirs, ''));\n   171→\n   172→  // Also collect intermediate object paths to detect structural conflicts\n   173→  // (e.g., one side changed a leaf to an object or vice versa)\n   174→  const baseAllPaths = new Set(collectAllPaths(base, ''));\n   175→  const ourAllPaths = new Set(collectAllPaths(ours, ''));\n   176→  const theirAllPaths = new Set(collectAllPaths(theirs, ''));\n   177→\n   178→  const allPaths = new Set([...basePaths, ...ourPaths, ...theirPaths]);\n   179→  // Also include paths from allPaths sets for structural changes\n   180→  for (const p of [...baseAllPaths, ...ourAllPaths, ...theirAllPaths]) {\n   181→    allPaths.add(p);\n   182→  }\n   183→\n   184→  // Start with a clone of ours as the base result (conflicts resolve in favor of ours)\n   185→  const result = deepClone(ours);\n   186→\n   187→  // Track which paths we've already processed (to avoid double-handling parent/child)\n   188→  const processedConflictPaths = new Set<string>();\n   189→\n   190→  for (const path of allPaths) {\n   191→    // Skip if a parent path was already processed as a conflict\n   192→    const parts = path.split('.');\n   193→    let skipDueToParent = false;\n   194→    for (let i = 1; i < parts.length; i++) {\n   195→      if (processedConflictPaths.has(parts.slice(0, i).join('.'))) {\n   196→        skipDueToParent = true;\n   197→        break;\n   198→      }\n   199→    }\n   200→    if (skipDueToParent) continue;\n   201→\n   202→    const baseVal = getAtPath(base, path);\n   203→    const ourVal = getAtPath(ours, path);\n   204→    const theirVal = getAtPath(theirs, path);\n   205→\n   206→    const baseHas = hasPath(base, path);\n   207→    const ourHas = hasPath(ours, path);\n   208→    const theirHas = hasPath(theirs, path);\n   209→\n   210→    // Check if this path is an intermediate object in any version\n   211→    const baseIsObj = baseVal !== null && typeof baseVal === 'object' && !Array.isArray(baseVal) && baseHas;\n   212→    const ourIsObj = ourVal !== null && typeof ourVal === 'object' && !Array.isArray(ourVal) && ourHas;\n   213→    const theirIsObj = theirVal !== null && typeof theirVal === 'object' && !Array.isArray(theirVal) && theirHas;\n   214→\n   215→    // If it's an intermediate object in all versions (or absent), let child paths handle it\n   216→    if ((baseIsObj || !baseHas) && (ourIsObj || !ourHas) && (theirIsObj || !theirHas)) {\n   217→      // Check if one side deleted and the other kept\n   218→      if (baseHas && !ourHas && theirHas && !theirIsObj) {\n   219→        // We deleted, they have a leaf value — conflict\n   220→        const baseLeaf = baseIsObj ? undefined : baseVal;\n   221→        conflicts.push({ documentId, path, base: baseLeaf, ours: undefined, theirs: theirVal });\n   222→        processedConflictPaths.add(path);\n   223→        continue;\n   224→      }\n   225→      if (baseHas && ourHas && !theirHas && !ourIsObj) {\n   226→        // They deleted, we have a leaf value — take ours (already in result)\n   227→        continue;\n   228→      }\n   229→      continue;\n   230→    }\n   231→\n   232→    // Both sides unchanged from base\n   233→    if (deepEqual(baseVal, ourVal) && deepEqual(baseVal, theirVal) && baseHas === ourHas && baseHas === theirHas) {\n   234→      continue;\n   235→    }\n   236→\n   237→    const ourChanged = !deepEqual(baseVal, ourVal) || baseHas !== ourHas;\n   238→    const theirChanged = !deepEqual(baseVal, theirVal) || baseHas !== theirHas;\n   239→\n   240→    if (ourChanged && theirChanged) {\n   241→      // Both sides changed\n   242→      if (deepEqual(ourVal, theirVal) && ourHas === theirHas) {\n   243→        // Both changed to the same value - no conflict\n   244→        if (theirHas) {\n   245→          setAtPath(result, path, deepClone(theirVal));\n   246→        } else {\n   247→          deleteAtPath(result, path);\n   248→        }\n   249→      } else {\n   250→        // Conflict: different changes on both sides\n   251→        conflicts.push({\n   252→          documentId,\n   253→          path,\n   254→          base: baseHas ? deepClone(baseVal) : undefined,\n   255→          ours: ourHas ? deepClone(ourVal) : undefined,\n   256→          theirs: theirHas ? deepClone(theirVal) : undefined,\n   257→        });\n   258→        processedConflictPaths.add(path);\n   259→        // Result keeps ours (already there)\n   260→      }\n   261→    } else if (theirChanged && !ourChanged) {\n   262→      // Only theirs changed - take theirs\n   263→      if (theirHas) {\n   264→        setAtPath(result, path, deepClone(theirVal));\n   265→      } else {\n   266→        deleteAtPath(result, path);\n   267→      }\n   268→    }\n   269→    // If only ours changed, result already has our value\n   270→  }\n   271→\n   272→  return { result, conflicts };\n   273→}\n   274→"}]},"parent_tool_use_id":"toolu_01F4738N8oc4YrVdbC3txgV6","session_id":"bf0a514d-aaff-4f3d-a9ea-9c651d6e47fb","uuid":"27f7febb-a932-4216-bf99-d638486b081b"}
