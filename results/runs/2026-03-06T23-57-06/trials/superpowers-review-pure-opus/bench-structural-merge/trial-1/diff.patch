 store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n\n    it('should deep clone content on create', () => {\n      const content = { name: 'Alice', nested: { x: 1 } };\n      store.create('doc1', content);\n      content.name = 'Bob';\n      content.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should deep clone content on get', () => {\n      store.create('doc1', { name: 'Alice', nested: { x: 1 } });\n      const doc = store.get('doc1') as Record<string, unknown>;\n      (doc as { name: string }).name = 'modified';\n      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should deep clone content on update', () => {\n      store.create('doc1', { name: 'Alice' });\n      const newContent = { name: 'Bob', items: [1, 2, 3] };\n      store.update('doc1', newContent);\n      newContent.items.push(4);\n      expect(store.get('doc1')).toEqual({ name: 'Bob', items: [1, 2, 3] });\n    });\n\n    it('should allow creating a document after it was deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      store.create('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should throw when updating a deleted document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.update('doc1', { name: 'Bob' })).toThrow();\n    });\n  });\n\n  // ── Version History ────────────────────────────────────────────────\n\n  describe('Version History', () => {\n    it('should create a version on create', () => {\n      store.create('doc1', { name: 'Alice' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(1);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(history[0].id).toBeTruthy();\n      expect(typeof history[0].timestamp).toBe('number');\n    });\n\n    it('should create a version on update', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(2);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(history[1].content).toEqual({ name: 'Bob' });\n    });\n\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n      // timestamps should be non-decreasing\n      for (let i = 1; i < history.length; i++) {\n        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);\n      }\n    });\n\n    it('should get a specific version by ID', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      const v1Content = store.getVersion('doc1', history[0].id);\n      expect(v1Content).toEqual({ v: 1 });\n      const v2Content = store.getVersion('doc1', history[1].id);\n      expect(v2Content).toEqual({ v: 2 });\n    });\n\n    it('should throw for non-existent version ID', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n    });\n\n    it('should throw for non-existent document on getHistory', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should deep clone version content', () => {\n      store.create('doc1', { nested: { x: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as Record<string, unknown>).nested = 'modified';\n      const history2 = store.getHistory('doc1');\n      expect(history2[0].content).toEqual({ nested: { x: 1 } });\n    });\n\n    it('should have unique version IDs', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      const ids = history.map(v => v.id);\n      expect(new Set(ids).size).toBe(3);\n    });\n  });\n\n  // ── Branching ──────────────────────────────────────────────────────\n\n  describe('Branching', () => {\n    it('should start on the main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should list branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n    });\n\n    it('should create and switch to a new branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n      expect(store.listBranches()).toContain('feature');\n    });\n\n    it('should throw when creating a branch that already exists', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to a non-existent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should isolate documents between branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n\n      // doc1 should be visible on feature (copied from main)\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n\n      // Modify on feature branch\n      store.update('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n\n      // Switch back to main - should still be Alice\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' 