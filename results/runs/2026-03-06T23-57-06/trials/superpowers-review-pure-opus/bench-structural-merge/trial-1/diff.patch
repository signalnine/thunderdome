          );\n   238→          merged[docId] = result;\n   239→          allConflicts.push(...conflicts);\n   240→        }\n   241→        // Both deleted — no conflict, document stays deleted\n   242→      }\n   243→    }\n   244→\n   245→    const applied = allConflicts.length === 0;\n   246→\n   247→    if (applied) {\n   248→      // Apply the merge to the current branch\n   249→      for (const docId of allDocIds) {\n   250→        if (docId in merged) {\n   251→          const existingDoc = target.documents.get(docId);\n   252→          if (existingDoc && !existingDoc.deleted) {\n   253→            // Check if content actually changed\n   254→            if (!deepEqual(existingDoc.content, merged[docId])) {\n   255→              const version: Version = {\n   256→                id: generateId(),\n   257→                timestamp: Date.now(),\n   258→                content: deepClone(merged[docId]),\n   259→              };\n   260→              existingDoc.content = deepClone(merged[docId]);\n   261→              existingDoc.versions.push(version);\n   262→            }\n   263→          } else if (!existingDoc) {\n   264→            // Document is new to this branch\n   265→            const cloned = deepClone(merged[docId]);\n   266→            const version: Version = {\n   267→              id: generateId(),\n   268→              timestamp: Date.now(),\n   269→              content: deepClone(cloned),\n   270→            };\n   271→            target.documents.set(docId, {\n   272→              content: cloned,\n   273→              versions: [version],\n   274→              deleted: false,\n   275→            });\n   276→          } else {\n   277→            // Was deleted on our side but merge brings it back (no-conflict case)\n   278→            const cloned = deepClone(merged[docId]);\n   279→            const version: Version = {\n   280→              id: generateId(),\n   281→              timestamp: Date.now(),\n   282→              content: dee