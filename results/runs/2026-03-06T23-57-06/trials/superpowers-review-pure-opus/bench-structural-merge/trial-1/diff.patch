+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QgKtvy9MCYNCvgikMdSkcq","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { DocumentStore } from '../src/index.js';\n     3→\n     4→describe('DocumentStore', () => {\n     5→  let store: DocumentStore;\n     6→\n     7→  beforeEach(() => {\n     8→    store = new DocumentStore();\n     9→  });\n    10→\n    11→  // ── Document CRUD ──────────────────────────────────────────────────\n    12→\n    13→  describe('CRUD operations', () => {\n    14→    it('should create and get a document', () => {\n    15→      store.create('doc1', { name: 'Alice', age: 30 });\n    16→      const doc = store.get('doc1');\n    17→      expect(doc).toEqual({ name: 'Alice', age: 30 });\n    18→    });\n    19→\n    20→    it('should throw when creating a document with an existing ID', () => {\n    21→      store.create('doc1', { name: 'Alice' });\n    22→      expect(() => store.create('doc1', { name: 'Bob' })).toThrow();\n    23→    });\n    24→\n    25→    it('should throw when getting a non-existent document', () => {\n    26→      expect(() => store.get('nonexistent')).toThrow();\n    27→    });\n    28→\n    29→    it('should update a document', () => {\n    30→      store.create('doc1', { name: 'Alice', age: 30 });\n    31→      store.update('doc1', { name: 'Alice', age: 31 });\n    32→      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 31 });\n    33→    });\n    34→\n    35→    it('should throw when updating a non-existent document', () => {\n    36→      expect(() => store.update('nonexistent', { foo: 'bar' })).toThrow();\n    37→    });\n    38→\n    39→    it('should delete a document', () => {\n    40→      store.create('doc1', { name: 'Alice' });\n    41→      store.delete('doc1');\n    42→      expect(() => store.get('doc1')).toThrow();\n    43→    });\n    44→\n    45→    it('should throw when deleting a non-existent document', () => {\n    46→      expect(() => store.delete('nonexistent')).toThrow();\n    47→    });\n    48→\n    49→    it('should throw when deleting an already deleted document', () => {\n    50→      store.create('doc1', { name: 'Alice' });\n    51→      store.delete('doc1');\n    52→      expect(() => store.delete('doc1')).toThrow();\n    53→    });\n    54→\n    55→    it('should deep clone content on create', () => {\n    56→      const content = { name: 'Alice', nested: { x: 1 } };\n    57→      store.create('doc1', content);\n    58→      content.name = 'Bob';\n    59→      content.nested.x = 999;\n    60→      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    61→    });\n    62→\n    63→    it('should deep clone content on get', () => {\n    64→      store.create('doc1', { name: 'Alice', nested: { x: 1 } });\n    65→      const doc = store.get('doc1') as Record<string, unknown>;\n    66→      (doc as { name: string }).name = 'modified';\n    67→      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    68→    });\n    69→\n    70→    it('should deep clone content on update', () => {\n    71→      store.create('doc1', { name: 'Alice' });\n    72→      const newContent = { name: 'Bob', items: [1, 2, 3] };\n    73→      store.update('doc1', newContent);\n    74→      newContent.items.push(4);\n    75→      expect(store.get('doc1')).toEqual({ name: 'Bob', items: [1, 2, 3] });\n    76→    });\n    77→\n    78→    it('should allow creating a document after it was deleted', () => {\n    79→      store.create('doc1', { name: 'Alice' });\n    80→      store.delete('doc1');\n    81→      store.create('doc1', { name: 'Bob' });\n    82→      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    83→    });\n    84→\n    85→    it('should throw when updating a deleted document', () => {\n    86→      store.create('doc1', { name: 'Alice' });\n    87→      store.delete('doc1');\n    88→      expect(() => store.update('doc1', { name: 'Bob' })).toThrow();\n    89→    });\n    90→  });\n    91→\n    92→  // ── Version History ────────────────────────────────────────────────\n    93→\n    94→  describe('Version History', () => {\n    95→    it('should create a version on create', () => {\n    96→      store.create('doc1', { name: 'Alice' });\n    97→      const history = store.getHistory('doc1');\n    98→      expect(history).toHaveLength(1);\n    99→      expect(history[0].content).toEqual({ name: 'Alice' });\n   100→      expect(history[0].id).toBeTruthy();\n   101→      expect(typeof history[0].timestamp).toBe('number');\n   102→    });\n   103→\n   104→    it('should create a version on update', () => {\n   105→      store.create('doc1', { name: 'Alice' });\n   106→      store.update('doc1', { name: 'Bob' });\n   107→      const history = store.getHistory('doc1');\n   108→      expect(history).toHaveLength(2);\n   109→      expect(history[0].content).toEqual({ name: 'Alice' });\n   110→      expect(history[1].content).toEqual({ name: 'Bob' });\n   111→    });\n   112→\n   113→    it('should return versions in chronological order', () => {\n   114→      store.create('doc1', { v: 1 });\n   115→      store.update('doc1', { v: 2 });\n   116→      store.update('doc1', { v: 3 });\n   117→      const history = store.getHistory('doc1');\n   118→      expect(history).toHaveLength(3);\n   119→      expect(history[0].content).toEqual({ v: 1 });\n   120→      expect(history[1].content).toEqual({ v: 2 });\n   121→      expect(history[2].content).toEqual({ v: 3 });\n   122→      // timestamps should be non-decreasing\n   123→      for (let i = 1; i < history.length; i++) {\n   124→        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);\n   125→      }\n   126→    });\n   127→\n   128→    it('should get a specific version by ID', () => {\n   129→      store.create('doc1', { v: 1 });\n   130→      store.update('doc1', { v: 2 });\n   131→      const history = store.getHistory('doc1');\n   132→      const v1Content = store.getVersion('doc1', history[0].id);\n   133→      expect(v1Content).toEqual({ v: 1 });\n   134→      const v2Content = store.getVersion('doc1', history[1].id);\n   135→      expect(v2Content).toEqual({ v: 2 });\n   136→    });\n   137→\n   138→    it('should throw for non-existent version ID', () => {\n   139→      store.create('doc1', { v: 1 });\n   140→      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n   141→    });\n   142→\n   143→    it('should throw for non-existent document on getHistory', () => {\n   144→      expect(() => store.getHistory('nonexistent')).toThrow();\n   145→    });\n   146→\n   147→    it('should deep clone version content', () => {\n   148→      store.create('doc1', { nested: { x: 1 } });\n   149→      const history = store.getHistory('doc1');\n   150→      (history[0].content as Record<string, unknown>).nested = 'modified';\n   151→      const history2 = store.getHistory('doc1');\n   152→      expect(history2[0].content).toEqual({ nested: { x: 1 } });\n   153→    });\n   154→\n   155→    it('should have unique version IDs', () => {\n   156→      store.create('doc1', { v: 1 });\n   157→      store.update('doc1', { v: 2 });\n   158→      store.update('doc1', { v: 3 });\n   159→      const history = store.getHistory('doc1');\n   160→      const ids = history.map(v => v.id);\n   161→      expect(new Set(ids).size).toBe(3);\n   162→    });\n   163→  });\n   164→\n   165→  // ── Branching ──────────────────────────────────────────────────────\n   166→\n   167→  describe('Branching', () => {\n   168→    it('should start on the main branch', () => {\n   169→      expect(store.getBranch()).toBe('main');\n   170→    });\n   171→\n   172→    it('should list branches', () => {\n   173→      expect(store.listBranches()).toEqual(['main']);\n   174→    });\n   175→\n   176→    it('should create and switch to a new branch', () => {\n   177→      store.createBranch('feature');\n   178→      store.switchBranch('feature');\n   179→      expect(store.getBranch()).toBe('feature');\n   180→      expect(store.listBranches()).toContain('feature');\n   181→    });\n   182→\n   183→    it('should throw when creating a branch that already exists', () => {\n   184→      store.createBranch('feature');\n   185→      expect(() => store.createBranch('feature')).toThrow();\n   186→    });\n   187→\n   188→    it('should throw when switching to a non-existent branch', () => {\n   189→      expect(() => store.switchBranch('nonexistent')).toThrow();\n   190→    });\n   191→\n   192→    it('should isolate documents between branches', () => {\n   193→      store.create('doc1', { name: 'Alice' });\n   194→      store.createBranch('feature');\n   195→      store.switchBranch('feature');\n   196→\n   197→      // doc1 should be visible on feature (copied from main)\n   198→      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n   199→\n   200→      // Modify on feature branch\n   201→      store.update('doc1', { name: 'Bob' });\n   202→      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n   203→\n   204→      // Switch back to main - should still be Alice\n   205→      store.switchBranch('main');\n   206→      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n   207→    });\n   208→\n   209→    it('should isolate new documents between branches', () => {\n   210→      store.createBranch('feature');\n   211→      store.switchBranch('feature');\n   212→      store.create('doc1', { name: 'Alice' });\n   213→\n   214→      store.switchBranch('main');\n   215→      expect(() => store.get('doc1')).toThrow();\n   216→    });\n   217→\n   218→    it('should create a branch from a specific branch', () => {\n   219→      store.create('doc1', { name: 'Alice' });\n   220→      store.createBranch('feature');\n   221→      store.switchBranch('feature');\n   222→      store.update('doc1', { name: 'Bob' });\n   223→\n   224→      // Create branch from feature, not from m