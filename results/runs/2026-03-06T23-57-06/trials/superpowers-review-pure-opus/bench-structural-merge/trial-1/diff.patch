ify name on main\n   318→      store.update('doc1', { name: 'Bob', age: 30 });\n   319→\n   320→      // Modify name differently on feature\n   321→      store.switchBranch('feature');\n   322→      store.update('doc1', { name: 'Charlie', age: 30 });\n   323→\n   324→      store.switchBranch('main');\n   325→      const result = store.merge('feature');\n   326→\n   327→      expect(result.applied).toBe(false);\n   328→      expect(result.conflicts).toHaveLength(1);\n   329→      expect(result.conflicts[0]).toEqual({\n   330→        documentId: 'doc1',\n   331→        path: 'name',\n   332→        base: 'Alice',\n   333→        ours: 'Bob',\n   334→        theirs: 'Charlie',\n   335→      });\n   336→      // Current branch should remain unchanged\n   337→      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n   338→    });\n   339→\n   340→    it('should not conflict when both branches change the same field to the same value', () => {\n   341→      store.create('doc1', { name: 'Alice', age: 30 });\n   342→      store.createBranch('feature');\n   343→\n   344→      store.update('doc1', { name: 'Bob', age: 30 });\n   345→\n   346→      store.switchBranch('feature');\n   347→      store.update('doc1', { name: 'Bob', age: 30 });\n   348→\n   349→      store.switchBranch('main');\n   350→      const result = store.merge('feature');\n   351→\n   352→      expect(result.applied).toBe(true);\n   353→      expect(result.conflicts).toHaveLength(0);\n   354→      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n   355→    });\n   356→\n   357→    it('should merge a new document from source branch', () => {\n   358→      store.createBranch('feature');\n   359→      store.switchBranch('feature');\n   360→      store.create('doc1', { name: 'Alice' });\n   361→\n   362→      store.switchBranch('main');\n   363→      const result = store.merge('feature');\n   364→\n   365→      expect(result.applied).toBe(true);\n   366→      expect(result.merged['doc1']).