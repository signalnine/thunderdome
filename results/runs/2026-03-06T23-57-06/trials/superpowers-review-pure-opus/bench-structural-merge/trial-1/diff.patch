tes had been made at that point.\n   */\n  private earlierForkPoint(\n    a: Map<string, DocumentState>,\n    b: Map<string, DocumentState>\n  ): Map<string, DocumentState> {\n    let aVersions = 0;\n    let bVersions = 0;\n    for (const doc of a.values()) {\n      aVersions += doc.versions.length;\n    }\n    for (const doc of b.values()) {\n      bVersions += doc.versions.length;\n    }\n    return aVersions <= bVersions ? a : b;\n  }","originalFile":"import type { Version, MergeResult, Conflict, DocumentState, BranchState } from './types.js';\nimport { deepClone, generateId, threeWayMerge, deepEqual } from './utils.js';\n\nexport type { Version, MergeResult, Conflict };\n\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      forkPoint: null,\n      forkedFrom: null,\n    });\n  }\n\n  // ── Document CRUD ──────────────────────────────────────────────────\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchState();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const version: Version = {\n      id: generateId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    branch.documents.set(id, {\n      content: deepClone(content),\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchState();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return deepClone(doc.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchState();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted)