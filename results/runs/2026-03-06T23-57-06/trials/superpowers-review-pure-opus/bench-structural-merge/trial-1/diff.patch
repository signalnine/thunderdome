 }\n    51→  return true;\n    52→}\n    53→\n    54→/**\n    55→ * Collect all leaf paths from an object. For nested objects, paths are dot-separated.\n    56→ * Non-object values (including arrays) are treated as leaf values.\n    57→ */\n    58→function collectPaths(obj: Record<string, unknown>, prefix: string): string[] {\n    59→  const paths: string[] = [];\n    60→  for (const key of Object.keys(obj)) {\n    61→    const path = prefix ? `${prefix}.${key}` : key;\n    62→    const val = obj[key];\n    63→    if (val !== null && typeof val === 'object' && !Array.isArray(val)) {\n    64→      paths.push(...collectPaths(val as Record<string, unknown>, path));\n    65→    } else {\n    66→      paths.push(path);\n    67→    }\n    68→  }\n    69→  return paths;\n    70→}\n    71→\n    72→/**\n    73→ * Get a value at a dot-separated path.\n    74→ */\n    75→function getAtPath(obj: Record<string, unknown>, path: string): unknown {\n    76→  const parts = path.split('.');\n    77→  let current: unknown = obj;\n    78→  for (const part of parts) {\n    79→    if (current === null || typeof current !== 'object' || Array.isArray(current)) {\n    80→      return undefined;\n    81→    }\n    82→    current = (current as Record<string, unknown>)[part];\n    83→  }\n    84→  return current;\n    85→}\n    86→\n    87→/**\n    88→ * Set a value at a dot-separated path, creating intermediate objects as needed.\n    89→ */\n    90→function setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n    91→  const parts = path.split('.');\n    92→  let current = obj;\n    93→  for (let i = 0; i < parts.length - 1; i++) {\n    94→    const part = parts[i];\n    95→    if (current[part] === undefined || current[part] === null || typeof current[part] !== 'object' || Array.isArray(current[part])) {\n    96→      current[part] = {};\n    97→    }\n    98→    current = current[part] as Record<string, unknown>;\n    99→  }\n   100→  current[parts[parts.length - 1