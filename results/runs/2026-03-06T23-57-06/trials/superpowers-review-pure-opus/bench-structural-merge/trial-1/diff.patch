+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  base: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  ours: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  theirs: any;
+}
+
+export interface DocumentState {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+export interface BranchState {
+  documents: Map<string, DocumentState>;
+  /** The snapshot of documents at the time this branch was created */
+  forkPoint: Map<string, DocumentState> | null;
+  /** The name of the branch this was forked from */
+  forkedFrom: string | null;
+}
diff --git a/src/utils.ts b/src/utils.ts
new file mode 100644
index 0000000..557d6b2
--- /dev/null
+++ b/src/utils.ts
@@ -0,0 +1,273 @@
+import type { Conflict } from './types.js';
+
+export function deepClone<T>(obj: T): T {
+  if (obj === null || typeof obj !== 'object') {
+    return obj;
+  }
+  if (Array.isArray(obj)) {
+    return obj.map(item => deepClone(item)) as T;
+  }
+  const cloned: Record<string, unknown> = {};
+  for (const key of Object.keys(obj as Record<string, unknown>)) {
+    cloned[key] = deepClone((obj as Record<string, unknown>)[key]);
+  }
+  return cloned as T;
+}
+
+let counter = 0;
+
+export function generateId(): string {
+  counter++;
+  return `v_${Date.now()}_${counter}`;
+}
+
+/**
+ * Deeply compare two values for equality.
+ */
+export function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return false;
+
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    for (let i = 0; i < a.length; i++) {
+      if (!deepEqual(a[i], b[i])) return false;
+    }
+    return true;
+  }
+
+  const aObj = a as Record<string, unknown>;
+  const bObj = b as Record<string, unknown>;
+  const aKeys = Object.keys(aObj);
+  const bKeys = Object.keys(bObj);
+  if (aKeys.length !== bKeys.length) return false;
+  for (const key of aKeys) {
+    if (!Object.prototype.hasOwnProperty.call(bObj, key)) return false;
+    if (!deepEqual(aObj[key], bObj[key])) return false;
+  }
+  return true;
+}
+
+/**
+ * Collect all leaf paths from an object. For nested objects, paths are dot-separated.
+ * Non-object values (including arrays) are treated as leaf values.
+ */
+function collectPaths(obj: Record<string, unknown>, prefix: string): string[] {
+  const paths: string[] = [];
+  for (const key of Object.keys(obj)) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    const val = obj[key];
+    if (val !== null && typeof val === 'object' && !Array.isArray(val)) {
+      paths.push(...collectPaths(val as Record<string, unknown>, path));
+    } else {
+      paths.push(path);
+    }
+  }
+  return paths;
+}
+
+/**
+ * Get a value at a dot-separated path.
+ */
+function getAtPath(obj: Record<string, unknown>, path: string): unknown {
+  const parts = path.split('.');
+  let current: unknown = obj;
+  for (const part of parts) {
+    if (current === null || typeof current !== 'object' || Array.isArray(current)) {
+      return undefined;
+    }
+    current = (current as Record<string, unknown>)[part];
+  }
+  return current;
+}
+
+/**
+ * Set a value at a dot-separated path, creating intermediate objects as needed.
+ */
+function setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (current[part] === undefined || current[part] === null || typeof current[part] !== 'object' || Array.isArray(current[part])) {
+      current[part] = {};
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+/**
+ * Delete a value at a dot-separated path.
+ */
+function deleteAtPath(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split('.');
+  let current: unknown = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (current === null || typeof current !== 'object' || Array.isArray(current)) {
+      return;
+    }
+    current = (current as Record<string, unknown>)[parts[i]];
+  }
+  if (current !== null && typeof current === 'object' && !Array.isArray(current)) {
+    delete (current as Record<string, unknown>)[parts[parts.length - 1]];
+  }
+}
+
+/**
+ * Check if a path exists in an object (the key is present, even if value is undefined).
+ */
+function hasPath(obj: Record<string, unknown>, path: string): boolean {
+  const parts = path.split('.');
+  let current: unknown = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (current === null || typeof current !== 'object' || Array.isArray(current)) {
+      return false;
+    }
+    current = (current as Record<string, unknown>)[parts[i]];
+  }
+  if (current === null || typeof current !== 'object' || Array.isArray(current)) {
+    return false;
+  }
+  return Object.prototype.hasOwnProperty.call(current, parts[parts.length - 1]);
+}
+
+/**
+ * Collect all paths from an object, including intermediate object paths.
+ * For a structure like { a: { b: 1, c: 2 } }, this returns ["a", "a.b", "a.c"].
+ */
+function collectAllPaths(obj: Record<string, unknown>, prefix: string): string[] {
+  const paths: string[] = [];
+  for (const key of Object.keys(obj)) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    paths.push(path);
+    const val = obj[key];
+    if (val !== null && typeof val === 'object' && !Array.isArray(val)) {
+      paths.push(...collectAllPaths(val as Record<string, unknown>, path));
+    }
+  }
+  return paths;
+}
+
+/**
+ * Three-way structural merge of two objects against a common base.
+ * Returns the merged result and any conflicts.
+ */
+export function threeWayMerge(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  documentId: string
+): { result: Record<string, unknown>; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+
+  // Collect all leaf paths from all three versions
+  const basePaths = new Set(collectPaths(base, ''));
+  const ourPaths = new Set(collectPaths(ours, ''));
+  const theirPaths = new Set(collectPaths(theirs, ''));
+
+  // Also collect intermediate object paths to detect structural conflicts
+  // (e.g., one side changed a leaf to an object or vice versa)
+  const baseAllPaths = new Set(collectAllPaths(base, ''));
+  const ourAllPaths = new Set(collectAllPaths(ours, ''));
+  const theirAllPaths = new Set(collectAllPaths(theirs, ''));
+
+  const allPaths = new Set([...basePaths, ...ourPaths, ...theirPaths]);
+  // Also include paths from allPaths sets for structural changes
+  for (const p of [...baseAllPaths, ...ourAllPaths, ...theirAllPaths]) {
+    allPaths.add(p);
+  }
+
+  // Start with a clone of ours as the base result (conflicts resolve in favor of ours)
+  const result = deepClone(ours);
+
+  // Track which paths we've already processed (to avoid double-handling parent/child)
+  const processedConflictPaths = new Set<string>();
+
+  for (const path of allPaths) {
+    // Skip if a parent path was already processed as a conflict
+    const parts = path.split('.');
+    let skipDueToParent = false;
+    for (let i = 1; i < parts.length; i++) {
+      if (processedConflictPaths.has(parts.slice(0, i).join('.'))) {
+        skipDueToParent = true;
+        break;
+      }
+    }
+    if (skipDueToParent) continue;
+
+    const baseVal = getAtPath(base, path);
+    const ourVal = getAtPath(ours, path);
+    const theirVal = getAtPath(theirs, path);
+
+    const baseHas = hasPath(base, path);
+    const ourHas = hasPath(ours, path);
+    const theirHas = hasPath(theirs, path);
+
+    // Check if this path is an intermediate object in any version
+    const baseIsObj = baseVal !== null && typeof baseVal === 'object' && !Array.isArray(baseVal) && baseHas;
+    const ourIsObj = ourVal !== null && typeof ourVal === 'object' && !Array.isArray(ourVal) && ourHas;
+    const theirIsObj = theirVal !== null && typeof theirVal === 'object' && !Array.isArray(theirVal) && theirHas;
+
+    // If it's an intermediate object in all versions (or absent), let child paths handle it
+    if ((baseIsObj || !baseHas) && (ourIsObj || !ourHas) && (theirIsObj || !theirHas)) {
+      // Check if one side deleted and the other kept
+      if (baseHas && !ourHas && theirHas && !theirIsObj) {
+        // We deleted, they have a leaf value — conflict
+        const baseLeaf = baseIsObj ? undefined : baseVal;
+        conflicts.push({ documentId, path, base: baseLeaf, ours: undefined, theirs: theirVal });
+        processedConflictPaths.add(path);
+        continue;
+      }
+      if (baseHas && ourHas && !theirHas && !ourIsObj) {
+        // They deleted, we have a leaf value — take ours (already in result)
+        continue;
+      }
+      continue;
+    }
+
+    // Both sides unchanged from base
+    if (deepEqual(baseVal, ourVal) && deepEqual(baseVal, theirVal) && baseHas === ourHas && baseHas === theirHas) {
+      continue;
+    }
+
+    const ourChanged = !deepEqual(baseVal, ourVal) || baseHas !== ourHas;
+    const theirChanged = !deepEqual(baseVal, theirVal) || baseHas !== theirHas;
+
+    if (ourChanged && theirChanged) {
+      // Both sides changed
+      if (deepEqual(ourVal, theirVal) && ourHas === theirHas) {
+        // Both changed to the same value - no conflict
+        if (theirHas) {
+          setAtPath(result, path, deepClone(theirVal));
+        } else {
+          deleteAtPath(result, path);
+        }
+      } else {
+        // Conflict: different changes on both sides
+        conflicts.push({
+          documentId,
+          path,
+          base: baseHas ? deepClone(baseVal) : undefined,
+          ours: ourHas ? deepClone(ourVal) : undefined,
+          theirs: theirHas ? deepClone(theirVal) : undefined,
+        });
+        processedConflictPaths.add(path);
+        // Result keeps ours (already there)
+      }
+    } else if (theirChanged && !ourChanged) {
+      // Only theirs changed - take theirs
+      if (theirHas) {
+        setAtPath(result, path, deepClone(theirVal));
+      } else {
+        deleteAtPath(result, path);
+      }
+    }
+    // If only ours changed, result already has our value
+  }
+
+  return { result, conflicts };
+}
