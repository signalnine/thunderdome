pect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    it('should throw when deleting an already deleted document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n\n    it('should deep clone content on create', () => {\n      const content = { name: 'Alice', nested: { x: 1 } };\n      store.create('doc1', content);\n      content.name = 'Bob';\n      content.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should deep clone content on get', () => {\n      store.create('doc1', { name: 'Alice', nested: { x: 1 } });\n      const doc = store.get('doc1') as Record<string, unknown>;\n      (doc as { name: string }).name = 'modified';\n      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should deep clone content on update', () => {\n      store.create('doc1', { name: 'Alice' });\n      const newContent = { name: 'Bob', items: [1, 2, 3] };\n      store.update('doc1', newContent);\n      newContent.items.push(4);\n      expect(store.get('doc1')).toEqual({ name: 'Bob', items: [1, 2, 3] });\n    });\n\n    it('should allow creating a document after it was deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      store.create('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should throw when updating a deleted document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.update('doc1', { name: 'Bob' })).toThrow();\n    });\n  });\n\n  // ── Version History ────────────────────────────────────────────────\n\n  describe('Version History', () => {\n    it('should create a version on create', () => {\n      store.create('doc1', { name: 'Alice' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(1);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(history[0].id).toBeTruthy();\n      expect(typeof history[0].timestamp).toBe('number');\n    });\n\n    it('should create a version on update', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(2);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(history[1].content).toEqual({ name: 'Bob' });\n    });\n\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n      // timestamps should be non-decreasing\n      for (let i = 1; i < history.length; i++) {\n        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);\n      }\n    });\n\n    it('should get a specific version by ID', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      const v1Content = store.getVersion('doc1', history[0].id);\n      expect(v1Content).toEqual({ v: 1 });\n      const v2Content = store.getVersion('doc1', history[1].id);\n      expect(v2Content).toEqual({ v: 2 });\n    });\n\n    it('should throw for non-existent version ID', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n    });\n\n    it('should throw for non-existent document on getHistory', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should deep clone version content', () => {\n      store.create('doc1', { nested: { x: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as Record<string, unknown>).nested = 'modified';\n      const history2 = store.getHistory('doc1');\n      expect(history2[0].content).toEqual({ nested: { x: 1 } });\n    });\n\n    it('should have unique version IDs', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      const ids = history.map(v => v.id);\n      expect(new Set(ids).size).toBe(3);\n    });\n  });\n\n  // ── Branching ──────────────────────────────────────────────────────\n\n  describe('Branching', () => {\n    it('should start on the main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should list branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n    });\n\n    it('should create and switch to a new branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n      expect(store.listBranches()).toContain('feature');\n    });\n\n    it('should throw when creating a branch that already exists', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to a non-existent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should isolate documents between branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n\n      // doc1 should be visible on feature (copied from main)\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n\n      // Modify on feature branch\n      store.update('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n\n      // Switch back to main - should still be Alice\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should isolate new documents between branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'Alice' });\n\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should create a branch from a specific branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n\n      // Create branch from feature, not from main (current)\n      store.switchBranch('main');\n      store.createBranch('feature2', 'feature');\n      store.switchBranch('feature2');\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should isolate deletes between branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      expect(() => store.get('doc1')).toThrow();\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should throw when creating branch from non-existent source', () => {\n      expect(() => store.createBranch('feature', 'nonexistent')).toThrow();\n    });\n  });\n\n  // ── Merging ────────────────────────────────────────────────────────\n\n  describe('Merging', () => {\n    it('should merge a simple non-conflicting change', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ name: 'Bob', age: 30 });\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n    });\n\n    it('should merge when only source branch changed a document', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice', age: 31 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 31 });\n    });\n\n    it('should merge when only target branch changed a document', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n\n      // Modify on main (target)\n      store.update('doc1', { name: 'Alice', age: 31 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 31 });\n    });\n\n    it('should merge non-conflicting changes to different fields', () => {\n      store.create('doc1', { name: 'Alice', age: 30, city: 'NYC' });\n      store.createBranch('feature');\n\n      // Modify age on main\n      store.update('doc1', { name: 'Alice', age: 31, city: 'NYC' });\n\n      // Modify city on feature\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice', age: 30, city: 'LA' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 31, city: 'LA' });\n    });\n\n    it('should detect conflicts when both branches change the same field differently', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n\n      // Modify name on main\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      // Modify name differently on feature\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Charlie', age: 30 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'name',\n        base: 'Alice',\n        ours: 'Bob',\n        theirs: 'Charlie',\n      });\n      // Current branch should remain unchanged\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n    });\n\n    it('should not conflict when both branches change the same field to the same value', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n    });\n\n    it('should merge a new document from source branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'Alice' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ name: 'Alice' });\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should handle multiple documents independently', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.create('doc2', { name: 'Bob' });\n      store.createBranch('feature');\n\n      // Modify doc1 on main\n      store.update('doc1', { name: 'Alice2' });\n\n      // Modify doc2 on feature\n      store.switchBranch('feature');\n      store.update('doc2', { name: 'Bob2' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ name: 'Alice2' });\n      expect(store.get('doc2')).toEqual({ name: 'Bob2' });\n    });\n\n    it('should handle deletion on source branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should handle no changes (fast-forward)', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should provide merged field with conflicts resolved in favor of ours', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Charlie', age: 31 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      // merged should show ours for conflicting field, theirs for non-conflicting\n      expect(result.merged['doc1']).toEqual({ name: 'Bob', age: 31 });\n    });\n\n    it('should handle deep nested object merging', () => {\n      store.create('doc1', {\n        user: {\n          name: 'Alice',\n          address: {\n            city: 'NYC',\n            zip: '10001',\n          },\n        },\n      });\n      store.createBranch('feature');\n\n      // Modify city on main\n      store.update('doc1', {\n        user: {\n          name: 'Alice',\n          address: {\n            city: 'LA',\n            zip: '10001',\n          },\n        },\n      });\n\n      // Modify zip on feature\n      store.switchBranch('feature');\n      store.update('doc1', {\n        user: {\n          name: 'Alice',\n          address: {\n            city: 'NYC',\n            zip: '90001',\n          },\n        },\n      });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({\n        user: {\n          name: 'Alice',\n          address: {\n            city: 'LA',\n            zip: '90001',\n          },\n        },\n      });\n    });\n\n    it('should report deep nested conflicts with dot-separated path', () => {\n      store.create('doc1', {\n        user: {\n          address: {\n            city: 'NYC',\n          },\n        },\n      });\n      store.createBranch('feature');\n\n      store.update('doc1', { user: { address: { city: 'LA' } } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { user: { address: { city: 'Chicago' } } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('user.address.city');\n      expect(result.conflicts[0].base).toBe('NYC');\n      expect(result.conflicts[0].ours).toBe('LA');\n      expect(result.conflicts[0].theirs).toBe('Chicago');\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Charlie' });\n\n      store.switchBranch('main');\n      store.merge('feature');\n\n      // Main should be unchanged\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should handle adding new fields on source branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice', email: 'alice@example.com' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'Alice', email: 'alice@example.com' });\n    });\n\n    it('should handle removing fields on source branch', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should merge with new documents on both branches without conflict', () => {\n      store.createBranch('feature');\n\n      store.create('doc1', { name: 'Alice' });\n\n      store.switchBranch('feature');\n      store.create('doc2', { name: 'Bob' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n      expect(store.get('doc2')).toEqual({ name: 'Bob' });\n    });\n\n    it('should handle array values in documents', () => {\n      store.create('doc1', { tags: ['a', 'b'], name: 'test' });\n      store.createBranch(