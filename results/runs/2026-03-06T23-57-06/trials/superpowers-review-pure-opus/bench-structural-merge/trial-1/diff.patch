re.update('doc1', { name: 'Alice', email: 'alice@example.com' });\n   530→\n   531→      store.switchBranch('main');\n   532→      const result = store.merge('feature');\n   533→\n   534→      expect(result.applied).toBe(true);\n   535→      expect(store.get('doc1')).toEqual({ name: 'Alice', email: 'alice@example.com' });\n   536→    });\n   537→\n   538→    it('should handle removing fields on source branch', () => {\n   539→      store.create('doc1', { name: 'Alice', age: 30 });\n   540→      store.createBranch('feature');\n   541→      store.switchBranch('feature');\n   542→      store.update('doc1', { name: 'Alice' });\n   543→\n   544→      store.switchBranch('main');\n   545→      const result = store.merge('feature');\n   546→\n   547→      expect(result.applied).toBe(true);\n   548→      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n   549→    });\n   550→\n   551→    it('should merge with new documents on both branches without conflict', () => {\n   552→      store.createBranch('feature');\n   553→\n   554→      store.create('doc1', { name: 'Alice' });\n   555→\n   556→      store.switchBranch('feature');\n   557→      store.create('doc2', { name: 'Bob' });\n   558→\n   559→      store.switchBranch('main');\n   560→      const result = store.merge('feature');\n   561→\n   562→      expect(result.applied).toBe(true);\n   563→      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n   564→      expect(store.get('doc2')).toEqual({ name: 'Bob' });\n   565→    });\n   566→\n   567→    it('should handle array values in documents', () => {\n   568→      store.create('doc1', { tags: ['a', 'b'], name: 'test' });\n   569→      store.createBranch('feature');\n   570→\n   571→      store.switchBranch('feature');\n   572→      store.update('doc1', { tags: ['a', 'b', 'c'], name: 'test' });\n   573→\n   574→      store.switchBranch('main');\n   575→      const result = store.merge('feature');\n   576→\n   577→      expect(result.applied).toBe(true);\n   578→ 