+import { describe, it, expect } from 'vitest';
+import {
+  columnLetterToNumber,
+  columnNumberToLetter,
+  parseCellRef,
+  cellRefToString,
+  isCellRef,
+  expandRange,
+  extractCellRefs,
+} from '../src/cell-utils.js';
+
+describe('columnLetterToNumber', () => {
+  it('converts single letters', () => {
+    expect(columnLetterToNumber('A')).toBe(1);
+    expect(columnLetterToNumber('B')).toBe(2);
+    expect(columnLetterToNumber('Z')).toBe(26);
+  });
+
+  it('converts double letters', () => {
+    expect(columnLetterToNumber('AA')).toBe(27);
+    expect(columnLetterToNumber('AB')).toBe(28);
+    expect(columnLetterToNumber('AZ')).toBe(52);
+    expect(columnLetterToNumber('BA')).toBe(53);
+    expect(columnLetterToNumber('ZZ')).toBe(702);
+  });
+
+  it('converts triple letters', () => {
+    expect(columnLetterToNumber('AAA')).toBe(703);
+  });
+});
+
+describe('columnNumberToLetter', () => {
+  it('converts single-letter columns', () => {
+    expect(columnNumberToLetter(1)).toBe('A');
+    expect(columnNumberToLetter(2)).toBe('B');
+    expect(columnNumberToLetter(26)).toBe('Z');
+  });
+
+  it('converts double-letter columns', () => {
+    expect(columnNumberToLetter(27)).toBe('AA');
+    expect(columnNumberToLetter(28)).toBe('AB');
+    expect(columnNumberToLetter(52)).toBe('AZ');
+    expect(columnNumberToLetter(53)).toBe('BA');
+    expect(columnNumberToLetter(702)).toBe('ZZ');
+  });
+
+  it('converts triple-letter columns', () => {
+    expect(columnNumberToLetter(703)).toBe('AAA');
+  });
+
+  it('roundtrips with columnLetterToNumber', () => {
+    for (let i = 1; i <= 100; i++) {
+      expect(columnLetterToNumber(columnNumberToLetter(i))).toBe(i);
+    }
+  });
+});
+
+describe('parseCellRef', () => {
+  it('parses simple cell references', () => {
+    expect(parseCellRef('A1')).toEqual({ col: 1, row: 1 });
+    expect(parseCellRef('B2')).toEqual({ col: 2, row: 2 });
+    expect(parseCellRef('Z100')).toEqual({ col: 26, row: 100 });
+  });
+
+  it('parses multi-letter column references', () => {
+    expect(parseCellRef('AA1')).toEqual({ col: 27, row: 1 });
+    expect(parseCellRef('AB10')).toEqual({ col: 28, row: 10 });
+  });
+
+  it('is case-insensitive', () => {
+    expect(parseCellRef('a1')).toEqual({ col: 1, row: 1 });
+    expect(parseCellRef('aa1')).toEqual({ col: 27, row: 1 });
+  });
+
+  it('returns null for invalid references', () => {
+    expect(parseCellRef('')).toBeNull();
+    expect(parseCellRef('1A')).toBeNull();
+    expect(parseCellRef('A')).toBeNull();
+    expect(parseCellRef('123')).toBeNull();
+    expect(parseCellRef('A0')).toBeNull();
+    expect(parseCellRef('hello')).toBeNull();
+  });
+});
+
+describe('cellRefToString', () => {
+  it('converts CellRef to string', () => {
+    expect(cellRefToString({ col: 1, row: 1 })).toBe('A1');
+    expect(cellRefToString({ col: 26, row: 100 })).toBe('Z100');
+    expect(cellRefToString({ col: 27, row: 1 })).toBe('AA1');
+  });
+});
+
+describe('isCellRef', () => {
+  it('returns true for valid cell references', () => {
+    expect(isCellRef('A1')).toBe(true);
+    expect(isCellRef('Z100')).toBe(true);
+    expect(isCellRef('AA1')).toBe(true);
+  });
+
+  it('returns false for invalid references', () => {
+    expect(isCellRef('')).toBe(false);
+    expect(isCellRef('1A')).toBe(false);
+    expect(isCellRef('A')).toBe(false);
+  });
+});
+
+describe('expandRange', () => {
+  it('expands a column range', () => {
+    expect(expandRange('A1:A3')).toEqual(['A1', 'A2', 'A3']);
+  });
+
+  it('expands a row range', () => {
+    expect(expandRange('A1:C1')).toEqual(['A1', 'B1', 'C1']);
+  });
+
+  it('expands a block range', () => {
+    const result = expandRange('A1:C3');
+    expect(result).toEqual([
+      'A1', 'B1', 'C1',
+      'A2', 'B2', 'C2',
+      'A3', 'B3', 'C3',
+    ]);
+  });
+
+  it('handles reversed ranges', () => {
+    expect(expandRange('C3:A1')).toEqual([
+      'A1', 'B1', 'C1',
+      'A2', 'B2', 'C2',
+      'A3', 'B3', 'C3',
+    ]);
+  });
+
+  it('handles single-cell range', () => {
+    expect(expandRange('A1:A1')).toEqual(['A1']);
+  });
+
+  it('returns empty array for invalid ranges', () => {
+    expect(expandRange('invalid')).toEqual([]);
+    expect(expandRange('A1')).toEqual([]);
+    expect(expandRange('A1:B2:C3')).toEqual([]);
+  });
+
+  it('expands a range with multi-letter columns', () => {
+    expect(expandRange('AA1:AB2')).toEqual(['AA1', 'AB1', 'AA2', 'AB2']);
+  });
+});
+
+describe('extractCellRefs', () => {
+  it('extracts single cell references', () => {
+    expect(extractCellRefs('A1+B1')).toEqual(['A1', 'B1']);
+  });
+
+  it('extracts cell references from a formula', () => {
+    const refs = extractCellRefs('=A1+B2*C3');
+    expect(refs).toContain('A1');
+    expect(refs).toContain('B2');
+    expect(refs).toContain('C3');
+  });
+
+  it('expands ranges into individual cell references', () => {
+    const refs = extractCellRefs('=SUM(A1:A3)');
+    expect(refs).toContain('A1');
+    expect(refs).toContain('A2');
+    expect(refs).toContain('A3');
+  });
+
+  it('handles mixed refs and ranges', () => {
+    const refs = extractCellRefs('=SUM(A1:A3)+D1');
+    expect(refs).toContain('A1');
+    expect(refs).toContain('A2');
+    expect(refs).toContain('A3');
+    expect(refs).toContain('D1');
+  });
+
+  it('deduplicates references', () => {
+    const refs = extractCellRefs('=A1+A1');
+    expect(refs).toEqual(['A1']);
+  });
+
+  it('handles case-insensitive references', () => {
+    const refs = extractCellRefs('=a1+B1');
+    expect(refs).toContain('A1');
+    expect(refs).toContain('B1');
+  });
+});
