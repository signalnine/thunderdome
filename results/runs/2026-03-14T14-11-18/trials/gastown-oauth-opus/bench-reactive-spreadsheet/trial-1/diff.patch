+/**
+ * Reactive Spreadsheet Engine
+ *
+ * Main Spreadsheet class that ties together cell-utils, dependency-graph,
+ * and formula modules to provide a reactive spreadsheet with automatic
+ * dependency tracking and recalculation.
+ */
+
+import { normalizeRef } from './cell-utils.js';
+import { DependencyGraph } from './dependency-graph.js';
+import {
+  SpreadsheetError,
+  parseFormula,
+  collectRefs,
+  evalNode,
+  type ASTNode,
+  type CellData,
+} from './formula.js';
+
+export { SpreadsheetError } from './formula.js';
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private graph: DependencyGraph = new DependencyGraph();
+
+  /**
+   * Set a cell's value. Can be a raw value or a formula string starting with '='.
+   * Parses formulas, updates the dependency graph, detects circular references
+   * (throws if found), computes the cell's value, and reactively recomputes
+   * all transitive dependents in topological order.
+   */
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+
+    // Parse the value
+    let formula: ASTNode | null = null;
+    let dependencies = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const exprStr = value.substring(1);
+      formula = parseFormula(exprStr);
+      dependencies = collectRefs(formula);
+    }
+
+    // Save old cell data for rollback
+    const oldCell = this.cells.get(ref);
+
+    // Create new cell data
+    const cellData: CellData = {
+      rawValue: value,
+      formula,
+      computed: null,
+      dependencies,
+    };
+
+    // Update the cell in storage
+    this.cells.set(ref, cellData);
+
+    // Update dependency graph
+    this.graph.setDependencies(ref, dependencies);
+
+    // Check for circular references before evaluating
+    if (formula) {
+      if (this.graph.hasCycle(ref)) {
+        // Roll back: restore old cell or remove
+        if (oldCell) {
+          this.cells.set(ref, oldCell);
+          this.graph.setDependencies(ref, oldCell.dependencies);
+        } else {
+          this.cells.delete(ref);
+          this.graph.clearDependencies(ref);
+        }
+        throw new Error('Circular reference detected');
+      }
+    }
+
+    // Evaluate this cell
+    this.evaluateCell(ref);
+
+    // Propagate changes to all transitive dependents in topological order
+    const dependents = this.graph.getTopologicalDependents(ref);
+    for (const depRef of dependents) {
+      this.evaluateCell(depRef);
+    }
+  }
+
+  /**
+   * Get a cell's computed value. Returns null for empty cells.
+   */
+  get(cell: string): string | number | boolean | null {
+    const ref = normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    if (data.computed instanceof SpreadsheetError) return data.computed.toString();
+    return data.computed;
+  }
+
+  /**
+   * Get the display string for a cell's computed value.
+   */
+  getDisplay(cell: string): string {
+    const ref = normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return '';
+    if (data.computed === null) return '';
+    if (data.computed instanceof SpreadsheetError) return data.computed.toString();
+    return String(data.computed);
+  }
+
+  /**
+   * Get all non-empty cells as a Map from cell reference to computed value.
+   */
+  getCells(): Map<string, string | number | boolean | null> {
+    const result = new Map<string, string | number | boolean | null>();
+    for (const [ref, data] of this.cells) {
+      if (data.computed instanceof SpreadsheetError) {
+        result.set(ref, data.computed.toString());
+      } else {
+        result.set(ref, data.computed);
+      }
+    }
+    return result;
+  }
+
+  /**
+   * Evaluate a single cell, computing its value from its formula or raw value.
+   */
+  private evaluateCell(ref: string): void {
+    const data = this.cells.get(ref);
+    if (!data) return;
+
+    if (data.formula) {
+      data.computed = evalNode(data.formula, (cellRef: string) => this.cells.get(cellRef));
+    } else {
+      data.computed = data.rawValue;
+    }
+  }
+}
