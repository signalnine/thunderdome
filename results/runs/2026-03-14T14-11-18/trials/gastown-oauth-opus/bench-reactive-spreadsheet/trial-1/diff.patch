+  // ─── Reactive Updates ────────────────────────────────────────────────
+
+  describe('reactive updates', () => {
+    describe('direct dependency', () => {
+      it('should update formula when referenced cell changes', () => {
+        sheet.set('A1', 5);
+        sheet.set('B1', '=A1+1');
+        expect(sheet.get('B1')).toBe(6);
+
+        sheet.set('A1', 10);
+        expect(sheet.get('B1')).toBe(11);
+      });
+
+      it('should update multiple dependents when a cell changes', () => {
+        sheet.set('A1', 10);
+        sheet.set('B1', '=A1*2');
+        sheet.set('C1', '=A1+5');
+        expect(sheet.get('B1')).toBe(20);
+        expect(sheet.get('C1')).toBe(15);
+
+        sheet.set('A1', 20);
+        expect(sheet.get('B1')).toBe(40);
+        expect(sheet.get('C1')).toBe(25);
+      });
+
+      it('should update SUM when a cell in the range changes', () => {
+        sheet.set('A1', 10);
+        sheet.set('A2', 20);
+        sheet.set('A3', 30);
+        sheet.set('B1', '=SUM(A1:A3)');
+        expect(sheet.get('B1')).toBe(60);
+
+        sheet.set('A2', 50);
+        expect(sheet.get('B1')).toBe(90);
+      });
+
+      it('should follow the spec example', () => {
+        sheet.set('A1', 10);
+        sheet.set('A2', 20);
+        sheet.set('A3', '=A1+A2');
+        expect(sheet.get('A3')).toBe(30);
+
+        sheet.set('A1', 50);
+        expect(sheet.get('A3')).toBe(70);
+      });
+    });
+
+    describe('transitive dependency', () => {
+      it('should propagate updates through a chain of dependencies', () => {
+        sheet.set('A1', 1);
+        sheet.set('B1', '=A1+1');
+        sheet.set('C1', '=B1+1');
+        sheet.set('D1', '=C1+1');
+        expect(sheet.get('D1')).toBe(4);
+
+        sheet.set('A1', 10);
+        expect(sheet.get('B1')).toBe(11);
+        expect(sheet.get('C1')).toBe(12);
+        expect(sheet.get('D1')).toBe(13);
+      });
+
+      it('should handle diamond-shaped dependencies', () => {
+        sheet.set('A1', 5);
+        sheet.set('B1', '=A1*2');
+        sheet.set('C1', '=A1*3');
+        sheet.set('D1', '=B1+C1');
+        expect(sheet.get('D1')).toBe(25);
+
+        sheet.set('A1', 10);
+        expect(sheet.get('B1')).toBe(20);
+        expect(sheet.get('C1')).toBe(30);
+        expect(sheet.get('D1')).toBe(50);
+      });
+
+      it('should reactively update transitive SUM dependencies', () => {
+        sheet.set('A1', 1);
+        sheet.set('A2', 2);
+        sheet.set('A3', 3);
+        sheet.set('B1', '=SUM(A1:A3)');
+        sheet.set('C1', '=B1*10');
+        expect(sheet.get('C1')).toBe(60);
+
+        sheet.set('A1', 10);
+        expect(sheet.get('B1')).toBe(15);
+        expect(sheet.get('C1')).toBe(150);
+      });
+    });
+  });
+
+  // ─── Circular Reference Detection ───────────────────────────────────
+
+  describe('circular reference detection', () => {
+    it('should detect a direct self-reference', () => {
+      expect(() => {
+        sheet.set('A1', '=A1');
+      }).toThrow();
+    });
+
+    it('should detect a direct two-cell cycle', () => {
+      sheet.set('A1', '=B1');
+      expect(() => {
+        sheet.set('B1', '=A1');
+      }).toThrow();
+    });
+
+    it('should detect an indirect cycle through three cells', () => {
+      sheet.set('A1', '=C1');
+      sheet.set('B1', '=A1');
+      expect(() => {
+        sheet.set('C1', '=B1');
+      }).toThrow();
+    });
+
+    it('should detect an indirect cycle through many cells', () => {
+      sheet.set('A1', '=E1');
+      sheet.set('B1', '=A1');
+      sheet.set('C1', '=B1');
+      sheet.set('D1', '=C1');
+      expect(() => {
+        sheet.set('E1', '=D1');
+      }).toThrow();
+    });
+
+    it('should not throw for valid (non-circular) references', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1');
+      sheet.set('C1', '=B1');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should allow rewriting a formula to remove a cycle risk', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1');
+      // This should be fine - B1 now has a plain value
+      sheet.set('B1', 20);
+      // Now A1 can reference B1 without cycle
+      sheet.set('A1', '=B1');
+      expect(sheet.get('A1')).toBe(20);
+    });
+  });
+
+  // ─── Edge Cases ──────────────────────────────────────────────────────
+
+  describe('edge cases', () => {
+    describe('empty cells', () => {
+      it('should return null for an empty cell', () => {
+        expect(sheet.get('A1')).toBeNull();
+      });
+
+      it('should return null for a cell that was never set', () => {
+        expect(sheet.get('Z99')).toBeNull();
+      });
+    });
+
+    describe('overwriting formulas', () => {
+      it('should overwrite a formula with a plain value', () => {
+        sheet.set('A1', 10);
+        sheet.set('B1', '=A1*2');
+        expect(sheet.get('B1')).toBe(20);
+
+        sheet.set('B1', 99);
+        expect(sheet.get('B1')).toBe(99);
+
+        // After overwriting, B1 should no longer react to A1 changes
+        sheet.set('A1', 100);
+        expect(sheet.get('B1')).toBe(99);
+      });
+
+      it('should overwrite a value with a formula', () => {
+        sheet.set('A1', 10);
+        sheet.set('B1', 42);
+        expect(sheet.get('B1')).toBe(42);
+
+        sheet.set('B1', '=A1+5');
+        expect(sheet.get('B1')).toBe(15);
+      });
+
+      it('should overwrite a formula with another formula', () => {
+        sheet.set('A1', 10);
+        sheet.set('A2', 20);
+        sheet.set('B1', '=A1');
+        expect(sheet.get('B1')).toBe(10);
+
+        sheet.set('B1', '=A2');
+        expect(sheet.get('B1')).toBe(20);
+
+        // Should no longer depend on A1
+        sheet.set('A1', 999);
+        expect(sheet.get('B1')).toBe(20);
+
+        // Should now depend on A2
+        sheet.set('A2', 50);
+        expect(sheet.get('B1')).toBe(50);
+      });
+    });
+
+    describe('getDisplay', () => {
+      it('should display a number as a string', () => {
+        sheet.set('A1', 42);
+        expect(sheet.getDisplay('A1')).toBe('42');
+      });
+
+      it('should display a floating point number', () => {
+        sheet.set('A1', 3.14);
+        expect(sheet.getDisplay('A1')).toBe('3.14');
+      });
+
+      it('should display a string value', () => {
+        sheet.set('A1', 'hello');
+        expect(sheet.getDisplay('A1')).toBe('hello');
+      });
+
+      it('should display a boolean as a string', () => {
+        sheet.set('A1', true);
+        expect(sheet.getDisplay('A1')).toBe('true');
+      });
+
+      it('should display false as a string', () => {
+        sheet.set('A1', false);
+        expect(sheet.getDisplay('A1')).toBe('false');
+      });
+
+      it('should display an empty cell as empty string', () => {
+        expect(sheet.getDisplay('A1')).toBe('');
+      });
+
+      it('should display a formula result', () => {
+        sheet.set('A1', 10);
+        sheet.set('A2', 20);
+        sheet.set('A3', '=A1+A2');
+        expect(sheet.getDisplay('A3')).toBe('30');
+      });
+
+      it('should match the spec example', () => {
+        sheet.set('A1', 10);
+        sheet.set('A2', 20);
+        sheet.set('A3', '=A1+A2');
+        expect(sheet.getDisplay('A3')).toBe('30');
+      });
+    });
+
+    describe('getCells', () => {
+      it('should return an empty map for an empty spreadsheet', () => {
+        const cells = sheet.getCells();
+        expect(cells).toBeInstanceOf(Map);
+        expect(cells.size).toBe(0);
+      });
+
+      it('should return all non-empty cells', () => {
+        sheet.set('A1', 10);
+        sheet.set('B1', 20);
+        sheet.set('C1', '=A1+B1');
+
+        const cells = sheet.getCells();
+        expect(cells.size).toBe(3);
+        expect(cells.get('A1')).toBe(10);
+        expect(cells.get('B1')).toBe(20);
+        expect(cells.get('C1')).toBe(30);
+      });
+
+      it('should return computed values for formula cells', () => {
+        sheet.set('A1', 5);
+        sheet.set('A2', '=A1*10');
+        const cells = sheet.getCells();
+        expect(cells.get('A2')).toBe(50);
+      });
+
+      it('should not include empty cells', () => {
+        sheet.set('A1', 10);
+        const cells = sheet.getCells();
+        expect(cells.has('B1')).toBe(false);
+      });
+
+      it('should reflect the latest values after updates', () => {
+        sheet.set('A1', 1);
+        sheet.set('B1', '=A1+1');
+
+        let cells = sheet.getCells();
+        expect(cells.get('B1')).toBe(2);
+
+        sheet.set('A1', 100);
+        cells = sheet.getCells();
+        expect(cells.get('A1')).toBe(100);
+        expect(cells.get('B1')).toBe(101);
+      });
+    });
+
+    describe('formula with SUM used in arithmetic', () => {
+      it('should use SUM result in arithmetic', () => {
+        sheet.set('A1', 10);
+        sheet.set('A2', 20);
+        sheet.set('B1', '=SUM(A1:A2)');
+        expect(sheet.get('B1')).toBe(30);
+      });
+
+      it('should follow the spec SUM example', () => {
+        sheet.set('A1', 50);
+        sheet.set('A2', 20);
+        sheet.set('B1', '=SUM(A1:A2)');
+        expect(sheet.get('B1')).toBe(70);
+      });
+    });
+  });
+
+  // ─── Integration / Spec Examples ─────────────────────────────────────
+
+  describe('spec examples', () => {
+    it('should handle the full example from the spec', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+      expect(sheet.getDisplay('A3')).toBe('30');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(70);
+
+      sheet.set('C1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('C1')).toBe('big');
+    });
+  });
+});
