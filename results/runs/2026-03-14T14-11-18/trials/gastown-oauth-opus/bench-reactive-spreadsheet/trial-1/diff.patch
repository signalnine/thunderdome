@@ -0,0 +1,387 @@
+import { describe, it, expect } from 'vitest';
+import {
+  parseFormula,
+  evalNode,
+  collectRefs,
+  SpreadsheetError,
+  toNumber,
+  type CellValue,
+  type ASTNode,
+  type CellData,
+} from './formula.js';
+import {
+  expandRange,
+  colToIndex,
+  indexToCol,
+} from './cell-utils.js';
+
+// Helper: create a CellData lookup from a plain object
+function makeLookup(cells: Record<string, CellValue>): (ref: string) => CellData | undefined {
+  return (ref: string) => {
+    if (!(ref in cells)) return undefined;
+    const val = cells[ref];
+    return {
+      rawValue: val as string | number | boolean,
+      formula: null,
+      computed: val,
+      dependencies: new Set<string>(),
+    };
+  };
+}
+
+// Helper: parse and evaluate in one step
+function evalFormula(formula: string, cells: Record<string, CellValue> = {}): CellValue {
+  const ast = parseFormula(formula);
+  const result = evalNode(ast, makeLookup(cells));
+  if (result instanceof SpreadsheetError) {
+    throw new Error(result.message);
+  }
+  return result;
+}
+
+// ─── Column utilities ────────────────────────────────────────────────────────
+
+describe('colToIndex / indexToCol', () => {
+  it('converts single letters', () => {
+    expect(colToIndex('A')).toBe(1);
+    expect(colToIndex('Z')).toBe(26);
+  });
+
+  it('converts multi-letter columns', () => {
+    expect(colToIndex('AA')).toBe(27);
+    expect(colToIndex('AB')).toBe(28);
+    expect(colToIndex('AZ')).toBe(52);
+    expect(colToIndex('BA')).toBe(53);
+  });
+
+  it('round-trips correctly', () => {
+    for (let i = 1; i <= 100; i++) {
+      expect(colToIndex(indexToCol(i))).toBe(i);
+    }
+  });
+});
+
+// ─── expandRange ─────────────────────────────────────────────────────────────
+
+describe('expandRange', () => {
+  it('expands a column range', () => {
+    const ast = parseFormula('SUM(A1:A3)');
+    expect(ast.kind).toBe('call');
+    if (ast.kind === 'call' && ast.args[0].kind === 'range') {
+      const refs = expandRange(ast.args[0].start, ast.args[0].end);
+      expect(refs).toEqual(['A1', 'A2', 'A3']);
+    }
+  });
+
+  it('expands a row range', () => {
+    const ast = parseFormula('SUM(A1:C1)');
+    if (ast.kind === 'call' && ast.args[0].kind === 'range') {
+      const refs = expandRange(ast.args[0].start, ast.args[0].end);
+      expect(refs).toEqual(['A1', 'B1', 'C1']);
+    }
+  });
+
+  it('expands a block range', () => {
+    const ast = parseFormula('SUM(A1:B2)');
+    if (ast.kind === 'call' && ast.args[0].kind === 'range') {
+      const refs = expandRange(ast.args[0].start, ast.args[0].end);
+      expect(refs.sort()).toEqual(['A1', 'A2', 'B1', 'B2'].sort());
+    }
+  });
+});
+
+// ─── Parser ──────────────────────────────────────────────────────────────────
+
+describe('parseFormula', () => {
+  it('parses a simple number', () => {
+    const ast = parseFormula('42');
+    expect(ast).toEqual({ kind: 'number', value: 42 });
+  });
+
+  it('parses a decimal number', () => {
+    const ast = parseFormula('3.14');
+    expect(ast).toEqual({ kind: 'number', value: 3.14 });
+  });
+
+  it('parses a string literal', () => {
+    const ast = parseFormula('"hello"');
+    expect(ast).toEqual({ kind: 'string', value: 'hello' });
+  });
+
+  it('parses boolean TRUE', () => {
+    const ast = parseFormula('TRUE');
+    expect(ast).toEqual({ kind: 'boolean', value: true });
+  });
+
+  it('parses boolean FALSE', () => {
+    const ast = parseFormula('FALSE');
+    expect(ast).toEqual({ kind: 'boolean', value: false });
+  });
+
+  it('parses a cell reference', () => {
+    const ast = parseFormula('A1');
+    expect(ast).toEqual({ kind: 'cellref', ref: 'A1' });
+  });
+
+  it('parses a multi-letter column reference', () => {
+    const ast = parseFormula('AA100');
+    expect(ast).toEqual({ kind: 'cellref', ref: 'AA100' });
+  });
+
+  it('parses a range reference', () => {
+    const ast = parseFormula('SUM(A1:C3)');
+    expect(ast.kind).toBe('call');
