+/**
+ * Formula parsing, tokenization, AST construction, and evaluation.
+ */
+
+import { expandRange } from './cell-utils.js';
+
+// ---- Error types ----
+
+export class SpreadsheetError {
+  constructor(public readonly type: string, public readonly message: string) {}
+  toString(): string { return `#${this.type}!`; }
+}
+
+export const DIV0 = () => new SpreadsheetError('DIV/0', 'Division by zero');
+export const VALUE = (msg = 'Invalid value') => new SpreadsheetError('VALUE', msg);
+
+// ---- Type coercion helpers ----
+
+export function toNumber(value: string | number | boolean): number | SpreadsheetError {
+  if (typeof value === 'number') return value;
+  if (typeof value === 'boolean') return value ? 1 : 0;
+  if (typeof value === 'string') {
+    const n = parseFloat(value);
+    if (!isNaN(n)) return n;
+    return VALUE(`Cannot convert "${value}" to number`);
+  }
+  return VALUE('Cannot convert to number');
+}
+
+export function toBool(value: string | number | boolean): boolean {
+  if (typeof value === 'boolean') return value;
+  if (typeof value === 'number') return value !== 0;
+  if (typeof value === 'string') return value.length > 0;
+  return false;
+}
+
+// ---- Tokenizer ----
+
+export type CellValue = string | number | boolean | SpreadsheetError | null;
+
+enum TokenType {
+  Number,
+  String,
+  Boolean,
+  CellRef,
+  Function,
+  Operator,
+  LParen,
+  RParen,
+  Comma,
+  Colon,
+  Comparison,
+  EOF,
+}
+
+interface Token {
+  type: TokenType;
+  value: string;
+  numValue?: number;
+}
+
+function tokenize(expr: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < expr.length) {
+    const ch = expr[i];
+
+    if (ch === ' ' || ch === '\t') { i++; continue; }
+
+    if (ch === '"') {
+      let str = '';
+      i++;
+      while (i < expr.length && expr[i] !== '"') {
+        str += expr[i];
+        i++;
+      }
+      i++;
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    if (ch >= '0' && ch <= '9') {
+      let num = '';
+      while (i < expr.length && ((expr[i] >= '0' && expr[i] <= '9') || expr[i] === '.')) {
+        num += expr[i];
+        i++;
+      }
+      tokens.push({ type: TokenType.Number, value: num, numValue: parseFloat(num) });
+      continue;
+    }
+
+    if (ch === '<' && i + 1 < expr.length && expr[i + 1] === '>') {
+      tokens.push({ type: TokenType.Comparison, value: '<>' }); i += 2; continue;
+    }
+    if (ch === '<' && i + 1 < expr.length && expr[i + 1] === '=') {
+      tokens.push({ type: TokenType.Comparison, value: '<=' }); i += 2; continue;
+    }
+    if (ch === '>' && i + 1 < expr.length && expr[i + 1] === '=') {
+      tokens.push({ type: TokenType.Comparison, value: '>=' }); i += 2; continue;
+    }
+    if (ch === '<') { tokens.push({ type: TokenType.Comparison, value: '<' }); i++; continue; }
+    if (ch === '>') { tokens.push({ type: TokenType.Comparison, value: '>' }); i++; continue; }
+
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: TokenType.Operator, value: ch }); i++; continue;
+    }
+
+    if (ch === '=') { tokens.push({ type: TokenType.Comparison, value: '=' }); i++; continue; }
+
+    if (ch === '(') { tokens.push({ type: TokenType.LParen, value: '(' }); i++; continue; }
+    if (ch === ')') { tokens.push({ type: TokenType.RParen, value: ')' }); i++; continue; }
+    if (ch === ',') { tokens.push({ type: TokenType.Comma, value: ',' }); i++; continue; }
+    if (ch === ':') { tokens.push({ type: TokenType.Colon, value: ':' }); i++; continue; }
+
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z') || ch === '_') {
+      let ident = '';
+      while (i < expr.length && (
+        (expr[i] >= 'A' && expr[i] <= 'Z') ||
+        (expr[i] >= 'a' && expr[i] <= 'z') ||
+        (expr[i] >= '0' && expr[i] <= '9') ||
+        expr[i] === '_'
+      )) {
+        ident += expr[i];
+        i++;
+      }
+
+      const upper = ident.toUpperCase();
+
+      if (upper === 'TRUE') { tokens.push({ type: TokenType.Boolean, value: 'TRUE' }); continue; }
+      if (upper === 'FALSE') { tokens.push({ type: TokenType.Boolean, value: 'FALSE' }); continue; }
+
+      // Check if next non-space char is '(' → function
+      let peek = i;
+      while (peek < expr.length && expr[peek] === ' ') peek++;
+      if (peek < expr.length && expr[peek] === '(') {
+        tokens.push({ type: TokenType.Function, value: upper });
+        continue;
+      }
+
+      // Cell reference or unknown identifier
+      tokens.push({ type: TokenType.CellRef, value: upper });
+      continue;
+    }
+
+    i++;
+  }
+
+  tokens.push({ type: TokenType.EOF, value: '' });
+  return tokens;
+}
+
+// ---- AST nodes ----
+
+export type ASTNode =
+  | { kind: 'number'; value: number }
+  | { kind: 'string'; value: string }
+  | { kind: 'boolean'; value: boolean }
+  | { kind: 'cellref'; ref: string }
+  | { kind: 'range'; start: string; end: string }
+  | { kind: 'binop'; op: string; left: ASTNode; right: ASTNode }
+  | { kind: 'unary'; op: string; operand: ASTNode }
+  | { kind: 'call'; name: string; args: ASTNode[] }
+  | { kind: 'comparison'; op: string; left: ASTNode; right: ASTNode };
+
+// ---- Recursive Descent Parser ----
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private expect(type: TokenType): Token {
+    const t = this.peek();
+    if (t.type !== type) {
+      throw VALUE(`Expected ${TokenType[type]} but got ${TokenType[t.type]}: "${t.value}"`);
+    }
+    return this.advance();
+  }
+
+  parse(): ASTNode {
+    return this.parseComparison();
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAdditive();
+    while (this.peek().type === TokenType.Comparison) {
+      const op = this.advance().value;
+      const right = this.parseAdditive();
+      left = { kind: 'comparison', op, left, right };
+    }
+    return left;
+  }
+
+  private parseAdditive(): ASTNode {
+    let left = this.parseMultiplicative();
+    while (
+      this.peek().type === TokenType.Operator &&
+      (this.peek().value === '+' || this.peek().value === '-')
+    ) {
+      const op = this.advance().value;
+      const right = this.parseMultiplicative();
+      left = { kind: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  private parseMultiplicative(): ASTNode {
+    let left = this.parseUnary();
+    while (
+      this.peek().type === TokenType.Operator &&
+      (this.peek().value === '*' || this.peek().value === '/')
+    ) {
+      const op = this.advance().value;
+      const right = this.parseUnary();
+      left = { kind: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek().type === TokenType.Operator && this.peek().value === '-') {
+      this.advance();
+      const operand = this.parseUnary();
+      return { kind: 'unary', op: '-', operand };
+    }
+    if (this.peek().type === TokenType.Operator && this.peek().value === '+') {
+      this.advance();
+      return this.parseUnary();
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const token = this.peek();
+
+    if (token.type === TokenType.Number) {
+      this.advance();
+      return { kind: 'number', value: token.numValue! };
+    }
+
+    if (token.type === TokenType.String) {
+      this.advance();
+      return { kind: 'string', value: token.value };
+    }
+
+    if (token.type === TokenType.Boolean) {
+      this.advance();
+      return { kind: 'boolean', value: token.value === 'TRUE' };
+    }
+
+    if (token.type === TokenType.Function) {
+      const name = this.advance().value;
+      this.expect(TokenType.LParen);
+      const args: ASTNode[] = [];
+      if (this.peek().type !== TokenType.RParen) {
+        args.push(this.parseComparison());
+        while (this.peek().type === TokenType.Comma) {
+          this.advance();
+          args.push(this.parseComparison());
+        }
+      }
+      this.expect(TokenType.RParen);
+      return { kind: 'call', name, args };
+    }
+
+    if (token.type === TokenType.CellRef) {
+      const ref = this.advance().value;
+      if (this.peek().type === TokenType.Colon) {
+        this.advance();
+        const endRef = this.expect(TokenType.CellRef).value;
+        return { kind: 'range', start: ref, end: endRef };
+      }
+      return { kind: 'cellref', ref };
+    }
+
+    if (token.type === TokenType.LParen) {
+      this.advance();
+      const node = this.parseComparison();
+      this.expect(TokenType.RParen);
+      return node;
+    }
+
+    throw VALUE(`Unexpected token: ${TokenType[token.type]} "${token.value}"`);
+  }
+}
+
+export function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+/**
+ * Collect all cell references from an AST node (including range expansions).
+ */
+export function collectRefs(node: ASTNode): Set<string> {
+  const refs = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.kind) {
+      case 'cellref':
+        refs.add(n.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(n.start, n.end);
+        for (const c of cells) refs.add(c);
+        break;
+      }
+      case 'binop':
+      case 'comparison':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'call':
+        for (const arg of n.args) walk(arg);
+        break;
+    }
+  }
+
+  walk(node);
+  return refs;
+}
+
+// ---- Cell data interface ----
+
+export interface CellData {
+  rawValue: string | number | boolean;
+  formula: ASTNode | null;
+  computed: string | number | boolean | SpreadsheetError | null;
+  dependencies: Set<string>;
+}
+
+/**
+ * Evaluate an AST node given a cell lookup function.
+ */
+export function evalNode(
+  node: ASTNode,
+  getCellData: (ref: string) => CellData | undefined
+): string | number | boolean | SpreadsheetError {
+  switch (node.kind) {
+    case 'number':
+      return node.value;
+
+    case 'string':
+      return node.value;
+
+    case 'boolean':
+      return node.value;
+
+    case 'cellref': {
+      const data = getCellData(node.ref);
+      if (!data) return 0;
+      if (data.computed instanceof SpreadsheetError) return data.computed;
+      if (data.computed === null) return 0;
+      return data.computed;
+    }
+
+    case 'range':
+      return VALUE('Range used outside of function');
+
+    case 'unary': {
+      const operand = evalNode(node.operand, getCellData);
+      if (operand instanceof SpreadsheetError) return operand;
+      const num = toNumber(operand);
+      if (num instanceof SpreadsheetError) return num;
+      return -num;
+    }
+
+    case 'binop': {
+      const left = evalNode(node.left, getCellData);
+      if (left instanceof SpreadsheetError) return left;
+      const right = evalNode(node.right, getCellData);
+      if (right instanceof SpreadsheetError) return right;
+
+      const lNum = toNumber(left);
+      const rNum = toNumber(right);
+      if (lNum instanceof SpreadsheetError) return lNum;
+      if (rNum instanceof SpreadsheetError) return rNum;
+
+      switch (node.op) {
+        case '+': return lNum + rNum;
+        case '-': return lNum - rNum;
+        case '*': return lNum * rNum;
+        case '/':
+          if (rNum === 0) return DIV0();
+          return lNum / rNum;
+        default:
+          return VALUE(`Unknown operator: ${node.op}`);
+      }
+    }
+
+    case 'comparison': {
+      const left = evalNode(node.left, getCellData);
+      if (left instanceof SpreadsheetError) return left;
+      const right = evalNode(node.right, getCellData);
+      if (right instanceof SpreadsheetError) return right;
+
+      return evalComparison(node.op, left, right);
+    }
+
+    case 'call':
+      return evalFunction(node.name, node.args, getCellData);
+
+    default:
+      return VALUE('Unknown AST node');
+  }
+}
+
+function evalComparison(
+  op: string,
+  left: string | number | boolean,
+  right: string | number | boolean
+): boolean | SpreadsheetError {
+  const lNum = toNumber(left);
+  const rNum = toNumber(right);
+
+  if (!(lNum instanceof SpreadsheetError) && !(rNum instanceof SpreadsheetError)) {
+    switch (op) {
+      case '>': return lNum > rNum;
+      case '<': return lNum < rNum;
+      case '>=': return lNum >= rNum;
+      case '<=': return lNum <= rNum;
+      case '=': return lNum === rNum;
+      case '<>': return lNum !== rNum;
+    }
+  }
+
+  const lStr = String(left);
+  const rStr = String(right);
+  switch (op) {
+    case '>': return lStr > rStr;
+    case '<': return lStr < rStr;
+    case '>=': return lStr >= rStr;
+    case '<=': return lStr <= rStr;
+    case '=': return lStr === rStr;
+    case '<>': return lStr !== rStr;
+  }
+
+  return VALUE(`Unknown comparison operator: ${op}`);
+}
+
+function evalFunction(
+  name: string,
+  args: ASTNode[],
+  getCellData: (ref: string) => CellData | undefined
+): string | number | boolean | SpreadsheetError {
+  switch (name) {
+    case 'SUM':
+      return evalAggregate(args, getCellData, (values) => {
+        let sum = 0;
+        for (const v of values) sum += v;
+        return sum;
+      });
+
+    case 'AVERAGE':
+      return evalAggregate(args, getCellData, (values) => {
+        if (values.length === 0) return DIV0();
+        let sum = 0;
+        for (const v of values) sum += v;
+        return sum / values.length;
+      });
+
+    case 'MIN':
+      return evalAggregate(args, getCellData, (values) => {
+        if (values.length === 0) return 0;
+        return Math.min(...values);
+      });
+
+    case 'MAX':
+      return evalAggregate(args, getCellData, (values) => {
+        if (values.length === 0) return 0;
+        return Math.max(...values);
+      });
+
+    case 'COUNT':
+      return evalCount(args, getCellData);
+
+    case 'IF':
+      return evalIf(args, getCellData);
+
+    default:
+      return VALUE(`Unknown function: ${name}`);
+  }
+}
+
+function evalAggregate(
+  args: ASTNode[],
+  getCellData: (ref: string) => CellData | undefined,
+  fn: (values: number[]) => number | SpreadsheetError
+): number | SpreadsheetError {
+  const values: number[] = [];
+
+  for (const arg of args) {
+    if (arg.kind === 'range') {
+      const cells = expandRange(arg.start, arg.end);
+      for (const cellRef of cells) {
+        const data = getCellData(cellRef);
+        if (data && data.computed !== null && !(data.computed instanceof SpreadsheetError)) {
+          const num = toNumber(data.computed);
+          if (!(num instanceof SpreadsheetError)) {
+            values.push(num);
+          }
+        }
+      }
+    } else {
+      const val = evalNode(arg, getCellData);
+      if (val instanceof SpreadsheetError) return val;
+      const num = toNumber(val);
+      if (!(num instanceof SpreadsheetError)) {
+        values.push(num);
+      }
+    }
+  }
+
+  return fn(values);
+}
+
+function evalCount(
+  args: ASTNode[],
+  getCellData: (ref: string) => CellData | undefined
+): number | SpreadsheetError {
+  let count = 0;
+
+  for (const arg of args) {
+    if (arg.kind === 'range') {
+      const cells = expandRange(arg.start, arg.end);
+      for (const cellRef of cells) {
+        const data = getCellData(cellRef);
+        if (data && data.computed !== null && !(data.computed instanceof SpreadsheetError)) {
+          if (typeof data.computed === 'number') {
+            count++;
+          } else if (typeof data.computed === 'string') {
+            const n = parseFloat(data.computed);
+            if (!isNaN(n)) count++;
+          }
+        }
+      }
+    } else {
+      const val = evalNode(arg, getCellData);
+      if (val instanceof SpreadsheetError) return val;
+      if (typeof val === 'number') count++;
+    }
+  }
+
+  return count;
+}
+
+function evalIf(
+  args: ASTNode[],
+  getCellData: (ref: string) => CellData | undefined
+): string | number | boolean | SpreadsheetError {
+  if (args.length < 2 || args.length > 3) {
+    return VALUE('IF requires 2 or 3 arguments');
+  }
+
+  const condition = evalNode(args[0], getCellData);
+  if (condition instanceof SpreadsheetError) return condition;
+
+  const isTruthy = toBool(condition);
+
+  if (isTruthy) {
+    return evalNode(args[1], getCellData);
+  } else {
+    if (args.length === 3) {
+      return evalNode(args[2], getCellData);
+    }
+    return false;
+  }
+}
