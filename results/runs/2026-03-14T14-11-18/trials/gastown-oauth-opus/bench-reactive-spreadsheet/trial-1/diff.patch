+import { describe, it, expect, beforeEach } from 'vitest';
+import { DependencyGraph } from '../src/dependency-graph.js';
+
+describe('DependencyGraph', () => {
+  let graph: DependencyGraph;
+
+  beforeEach(() => {
+    graph = new DependencyGraph();
+  });
+
+  describe('setDependencies', () => {
+    it('sets dependencies for a cell', () => {
+      graph.setDependencies('B1', ['A1', 'A2']);
+      expect(graph.getDependencies('B1')).toEqual(new Set(['A1', 'A2']));
+    });
+
+    it('updates dependents (reverse lookup)', () => {
+      graph.setDependencies('B1', ['A1', 'A2']);
+      expect(graph.getDependents('A1')).toEqual(new Set(['B1']));
+      expect(graph.getDependents('A2')).toEqual(new Set(['B1']));
+    });
