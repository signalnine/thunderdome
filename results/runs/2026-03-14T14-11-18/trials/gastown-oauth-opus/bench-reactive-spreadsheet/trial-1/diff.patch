new file mode 100644
index 0000000..5f2766c
--- /dev/null
+++ b/src/dependency-graph.ts
@@ -0,0 +1,183 @@
+/**
+ * Dependency graph management: tracks which cells depend on which,
+ * provides cycle detection and topological ordering of dependents.
+ */
+
+export class DependencyGraph {
+  // Forward deps: cell -> set of cells it depends on
+  private dependencies: Map<string, Set<string>> = new Map();
+  // Reverse deps: cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  /**
+   * Update the dependencies for a cell. Removes old reverse links
+   * and registers new ones.
+   */
+  setDependencies(cell: string, deps: Set<string> | string[]): void {
+    cell = cell.toUpperCase();
+    const depSet = deps instanceof Set
+      ? new Set([...deps].map(d => d.toUpperCase()))
+      : new Set(deps.map(d => d.toUpperCase()));
+
+    // Remove old reverse links
+    const oldDeps = this.dependencies.get(cell);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.dependents.get(dep)?.delete(cell);
+      }
+    }
+
+    // Store forward deps
+    this.dependencies.set(cell, depSet);
+
+    // Register reverse links
+    for (const dep of depSet) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(cell);
+    }
+  }
+
+  /**
+   * Remove all dependency info for a cell (when clearing deps).
+   */
+  clearDependencies(cell: string): void {
+    cell = cell.toUpperCase();
+    const oldDeps = this.dependencies.get(cell);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.dependents.get(dep)?.delete(cell);
+      }
+    }
+    this.dependencies.set(cell, new Set());
+  }
+
+  /**
+   * Alias for clearDependencies.
+   */
+  removeDependencies(cell: string): void {
+    this.clearDependencies(cell);
+  }
+
+  /**
+   * Get the direct dependencies of a cell (cells it references in its formula).
+   */
+  getDependencies(cell: string): Set<string> {
+    return this.dependencies.get(cell.toUpperCase()) ?? new Set();
+  }
+
+  /**
+   * Get the direct dependents of a cell (cells whose formulas reference this cell).
+   */
+  getDependents(cell: string): Set<string> {
+    return this.dependents.get(cell.toUpperCase()) ?? new Set();
+  }
+
+  /**
+   * Detect if there's a cycle starting from the given cell,
+   * following its forward dependencies.
+   */
+  hasCycle(startRef_: string): boolean {
+    const startRef = startRef_.toUpperCase();
+    const visited = new Set<string>();
+    const inStack = new Set<string>();
+
+    const dfs = (ref: string): boolean => {
+      if (inStack.has(ref)) return true;
+      if (visited.has(ref)) return false;
+
+      visited.add(ref);
+      inStack.add(ref);
+
+      const deps = this.dependencies.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          if (dfs(dep)) return true;
+        }
+      }
+
+      inStack.delete(ref);
+      return false;
+    };
+
+    return dfs(startRef);
+  }
+
+  /**
+   * Alias for getTopologicalDependents.
+   */
+  getRecalculationOrder(startRef: string): string[] {
+    return this.getTopologicalDependents(startRef);
+  }
+
+  /**
+   * Get all transitive dependents of a cell in topological order
+   * (each cell appears after all cells it depends on).
+   */
+  getTopologicalDependents(startRef_: string): string[] {
+    const startRef = startRef_.toUpperCase();
+    // BFS to collect all affected cells
+    const affected = new Set<string>();
+    const queue: string[] = [startRef];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const d of deps) {
+          if (!affected.has(d)) {
+            affected.add(d);
+            queue.push(d);
+          }
+        }
+      }
+    }
+
+    // Topological sort of affected cells
+    const sorted: string[] = [];
+    const visited = new Set<string>();
+    const temp = new Set<string>();
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      if (temp.has(ref)) return; // cycle — already caught earlier
+      temp.add(ref);
+
+      const cellDeps = this.dependencies.get(ref);
+      if (cellDeps) {
+        for (const dep of cellDeps) {
+          if (affected.has(dep)) {
+            visit(dep);
+          }
+        }
+      }
+
+      temp.delete(ref);
+      visited.add(ref);
+      sorted.push(ref);
+    };
+
+    for (const ref of affected) {
+      visit(ref);
+    }
+
+    return sorted;
+  }
+
+  /**
+   * Check if a cell has any dependents (is referenced by any other cell).
+   */
+  hasDependents(cell: string): boolean {
+    const deps = this.dependents.get(cell.toUpperCase());
+    return deps !== undefined && deps.size > 0;
+  }
+
+  /**
+   * Clear all dependency information.
+   */
+  clear(): void {
+    this.dependencies.clear();
+    this.dependents.clear();
+  }
+}
