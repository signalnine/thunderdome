new file mode 100644
index 0000000..1133233
--- /dev/null
+++ b/src/cell-utils.ts
@@ -0,0 +1,107 @@
+/**
+ * Cell reference utilities: parsing, normalization, and range expansion.
+ */
+
+export function colToIndex(col: string): number {
+  col = col.toUpperCase();
+  let idx = 0;
+  for (let i = 0; i < col.length; i++) {
+    idx = idx * 26 + (col.charCodeAt(i) - 64);
+  }
+  return idx; // 1-based: A=1, B=2, ..., Z=26, AA=27
+}
+
+export const columnLetterToNumber = colToIndex;
+
+export function indexToCol(idx: number): string {
+  let result = '';
+  while (idx > 0) {
+    idx--;
+    result = String.fromCharCode(65 + (idx % 26)) + result;
+    idx = Math.floor(idx / 26);
+  }
+  return result;
+}
+
+export const columnNumberToLetter = indexToCol;
+
+export function parseCellRef(ref: string): { col: number; row: number } | null {
+  const match = ref.toUpperCase().match(/^([A-Z]+)(\d+)$/);
+  if (!match) return null;
+  const row = parseInt(match[2], 10);
+  if (row < 1) return null;
+  return { col: colToIndex(match[1]), row };
+}
+
+export function cellRefToString(ref: { col: number; row: number }): string {
+  return indexToCol(ref.col) + ref.row;
+}
+
+export function isCellRef(str: string): boolean {
+  return parseCellRef(str) !== null;
+}
+
+export function normalizeRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+export function expandRange(start: string, end: string): string[];
+export function expandRange(rangeStr: string): string[];
+export function expandRange(startOrRange: string, end?: string): string[] {
+  let s: { col: number; row: number } | null;
+  let e: { col: number; row: number } | null;
+
+  if (end !== undefined) {
+    s = parseCellRef(startOrRange);
+    e = parseCellRef(end);
+  } else {
+    const parts = startOrRange.split(':');
+    if (parts.length !== 2) return [];
+    s = parseCellRef(parts[0]);
+    e = parseCellRef(parts[1]);
+  }
+
+  if (!s || !e) return [];
+
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+
+  const cells: string[] = [];
+  for (let r = minRow; r <= maxRow; r++) {
+    for (let c = minCol; c <= maxCol; c++) {
+      cells.push(indexToCol(c) + r);
+    }
+  }
+  return cells;
+}
+
+export function extractCellRefs(formula: string): string[] {
+  const refs = new Set<string>();
+  const cellRefPattern = /([A-Za-z]+)(\d+)/g;
+  const rangePattern = /([A-Za-z]+\d+):([A-Za-z]+\d+)/g;
+
+  // First extract ranges and expand them
+  let match: RegExpExecArray | null;
+  const rangeSpans: Array<[number, number]> = [];
+  while ((match = rangePattern.exec(formula)) !== null) {
+    rangeSpans.push([match.index, match.index + match[0].length]);
+    const expanded = expandRange(match[1].toUpperCase(), match[2].toUpperCase());
+    for (const ref of expanded) refs.add(ref);
+  }
+
+  // Then extract individual cell refs not part of ranges
+  while ((match = cellRefPattern.exec(formula)) !== null) {
+    const pos = match.index;
+    const inRange = rangeSpans.some(([start, end]) => pos >= start && pos < end);
+    if (inRange) continue;
+    const upper = match[0].toUpperCase();
+    // Verify it's a valid cell ref (not a function name like SUM, IF, etc.)
+    if (parseCellRef(upper)) {
+      refs.add(upper);
+    }
+  }
+
+  return Array.from(refs);
+}
