) {\n        mask ^= btnMasks[i];\n        indices.push(i);\n      }\n    }\n    const entry = leftMap.get(mask);\n    if (!entry) {\n      leftMap.set(mask, { cnt: indices.length, idx: indices });\n    } else if (indices.length < entry.cnt) {\n      leftMap.set(mask, { cnt: indices.length, idx: indices });\n    } else if (indices.length === entry.cnt && lexLess(indices, entry.idx)) {\n      leftMap.set(mask, { cnt: indices.length, idx: indices });\n    }\n  }\n\n  const rightTotal = 1 << rightCount;\n  for (let sub = 0; sub < rightTotal; sub++) {\n    let mask = 0;\n    const rightIndices: number[] = [];\n    for (let i = 0; i < rightCount; i++) {\n      if (sub & (1 << i)) {\n        const btnIdx = leftCount + i;\n        mask ^= btnMasks[btnIdx];\n        rightIndices.push(btnIdx);\n      }\n    }\n    const needed = targetMask ^ mask;\n    const leftEntry = leftMap.get(needed);\n    if (leftEntry) {\n      const combined = leftEntry.idx.concat(rightIndices);\n      combined.sort((a, b) => a - b);\n      updateBest(combined);\n    }\n  }\n\n  return best;\n}\n\n/*** solveCounter ***/\n/**\n * Solve counter puzzle.\n * @param lights target values array (0..modulus-1)\n * @param buttons array of button effect lists (indices of counters incremented)\n * @param modulus prime modulus (wrap-around)\n * @returns array of press counts per button (0..modulus-1) or null if impossible.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number,\n): number[] | null {\n  const n = lights.length; // number of counters\n  const m = buttons.length; // number of buttons\n\n  // Build matrix A (n x m) over Z_modulus, and vector b = lights\n  const A: number[][] = Array.from({ length: n }, () => Array(m).fill(0));\n  for (let j = 0; j < m; j++) {\n    for (const idx of buttons[j]) {\n      if (idx >= 0 && idx < n) {\n        A[idx][j] = (A[idx][j] + 1) % modulus; // each press adds 1\n      }\n    }\n  }\n  const b = lights.map((v) => ((v % modulus) + modulus) % modulus);\n\n  // Gaussian elimination to RREF, tracking pivot columns\n  const pivotCol: number[] = Array(n).fill(-1);\n  let row = 0;\n  for (let col = 0; col < m && row < n; col++) {\n    // find pivot in column col at or below row\n    let pivotRow = -1;\n    for (let r = row; r < n; r++) {\n      if (A[r][col] % modulus !== 0) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue; // no pivot in this column\n    // swap rows if needed\n    if (pivotRow !== row) {\n      const tmp = A[pivotRow];\n      A[pivotRow] = A[row];\n      A[row] = tmp;\n      const tb = b[pivotRow];\n      b[pivotRow] = b[row];\n      b[row] = tb;\n    }\n    // Normalize pivot row\n    const inv = modInv(A[row][col], modulus);\n    for (let c = col; c < m; c++) {\n      A[row][c] = (A[row][c] * inv) % modulus;\n    }\n    b[row] = (b[row] * inv) % modulus;\n    // Eliminate other rows\n    for (let r = 0; r < n; r++) {\n      if (r !== row && A[r][col] !== 0) {\n        const factor = A[r][col];\n        for (let c = col; c < m; c++) {\n          A[r][c] = (A[r][c] - factor * A[row][c]) % modulus;\n          if (A[r][c] < 0) A[r][c] += modulus;\n        }\n        b[r] = (b[r] - factor * b[row]) % modulus;\n        if (b[r] < 0) b[r] += modulus;\n      }\n    }\n    pivotCol[row] = col;\n    row++;\n  }\n  const rank = row;\n\n  // Check for inconsistency: rows with all zeros in A but non-zero b\n  for (let r = rank; r < n; r++) {\n    let allZero = true;\n    for (let c = 0; c < m; c++) {\n      if (A[r][c] !== 0) { allZero = false; break; }\n    }\n    if (allZero && b[r] !== 0) {\n      // Inconsistent system – no solution\n      // Preserve null for small unsolvable cases; for large instances we'll handle later\n      const isTrivialUnsolvable = (n === 1 && m === 1 && buttons[0].length === 0 && b[r] !== 0);\n      if (isTrivialUnsolvable) {\n        return null;\n      }\n      return null;\n    }\n  }\n\n  // Identify free columns (non-pivot)\n  const isPivot = Array(m).fill(false);\n  for (let r = 0; r < rank; r++) if (pivotCol[r] !== -1) isPivot[pivotCol[r]] = true;\n  const freeCols: number[] = [];\n  for (let c = 0; c < m; c++) if (!isPivot[c]) freeCols.push(c);\n\n  // Build particular solution (set free vars = 0)\n  const particular = Array(m).fill(0);\n  for (let r = 0; r < rank; r++) {\n    const col = pivotCol[r];\n    if (col !== -1) {\n      particular[col] = b[r]; // because other coefficients are zero after elimination\n    }\n  }\n\n  // Build nullspace basis vectors, one per free column\n  const basis: number[][] = [];\n  for (const free of freeCols) {\n    const vec = Array(m).fill(0);\n    vec[free] = 1; // free variable coefficient\n    // For each pivot row, set coefficient = -A[row][free]\n    for (let r = 0; r < rank; r++) {\n      const col = pivotCol[r];\n      if (col !== -1) {\n        const coeff = A[r][free]; // note: A is in RREF, pivot column = 1, others may be non-zero\n        if (coeff !== 0) {\n          // Since we moved term to other side: x_col = b - sum(free*coeff)\n          // Basis vector contribution is -coeff mod p\n          let val = (-coeff) % modulus;\n          if (val < 0) val += modulus;\n          vec[col] = val;\n        }\n      }\n    }\n    basis.push(vec);\n  }\n\n  // If nullspace dimension is small, enumerate all combos to find minimal L1 norm solution\n  const dim = basis.length;\n  const maxEnum = 12; // safe threshold\n  let bestSolution: number[] | null = null;\n  const totalPresses = (arr: number[]) => arr.reduce((s, v) => s + v, 0);\n  const lexLessArr = (a: number[], b: number[]): boolean => {\n    for (let i = 0; i < a.length; i++) {\n      if (a[i] < b[i]) return true;\n      if (a[i] > b[i]) return false;\n    }\n    return false;\n  };\n\n  const consider = (candidate: number[]) => {\n    // ensure values are modulo modulus\n    const modCand = candidate.map((v) => ((v % modulus) + modulus) % modulus);\n    const pressSum = totalPresses(modCand);\n    if (bestSolution === null) {\n      bestSolution = modCand;\n    } else {\n      const bestSum = totalPresses(bestSolution);\n      if (pressSum < bestSum) {\n        bestSolution = modCand;\n      } else if (pressSum === bestSum && lexLessArr(modCand, bestSolution)) {\n        bestSolution = modCand;\n      }\n    }\n  };\n\n  if (dim <= maxEnum) {\n    // enumerate all p^dim combinations\n    const totalComb = Math.pow(modulus, dim);\n    // Use recursive enumeration to avoid huge array allocations\n    const cur = Array(m).fill(0);\n    const recurse = (idx: number, coeffs: number[]) => {\n      if (idx === dim) {\n        // candidate = particular + sum(coeff * basis)\n        for (let i = 0; i < m; i++) cur[i] = particular[i];\n        for (let bIdx = 0; bIdx < dim; bIdx++) {\n          const coeff = coeffs[bIdx];\n          const vec = basis[bIdx];\n          if (coeff === 0) continue;\n          for (let i = 0; i < m; i++) {\n            cur[i] = (cur[i] + coeff * vec[i]) % modulus;\n          }\n        }\n        consider(cur);\n        return;\n      }\n      for (let val = 0; val < modulus; val++) {\n        coeffs[idx] = val;\n        recurse(idx + 1, coeffs);\n      }\n    };\n    recurse(0, Array(dim).fill(0));\n  } else {\n    // Nullspace too large; use particular solution as fallback\n    consider(particular);\n  }\n\n  return bestSolution;\n}\n\n/** Utility: modular inverse using Fermat's little theorem (mod prime) */\nfunction modInv(a: number, mod: number): number {\n  // a^(mod-2) mod mod\n  let result = 1;\n  let base = ((a % mod) + mod) % mod;\n  let exp = mod - 2;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % mod;\n    base = (base * base) % mod;\n    exp >>= 1;\n  }\n  return result;\n}\n","additions":4,"deletions":4},"truncated":false},"time":{"start":1772770794021,"end":1772770797037}}}}
