+{"type":"tool_use","timestamp":1772770762556,"sessionID":"ses_33ea110b8ffexxetK9WcglA5aM","part":{"id":"prt_cc15f1c6f001XlY4mra7YEJMDR","sessionID":"ses_33ea110b8ffexxetK9WcglA5aM","messageID":"msg_cc15f19ec002Nx5HPpjPC9Ioba","type":"tool","callID":"0a3e79535","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/index.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter, Machine } from './index';\n\n/** Helper to generate random int in [0, max) */\nfunction randInt(max: number): number {\n  return Math.floor(Math.random() * max);\n}\n\n/** Brute-force solver for toggle (for small sizes) */\nfunction bruteToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const n = target.length;\n  const m = buttons.length;\n  const targetMask = target.reduce((mask, bit, i) => mask | (bit ? 1 << i : 0), 0);\n  const btnMasks = buttons.map((list) => list.reduce((mask, idx) => mask | (1 << idx), 0));\n  let best: number[] | null = null;\n  const lexLess = (a: number[], b: number[]): boolean => {\n    const len = Math.min(a.length, b.length);\n    for (let i = 0; i < len; i++) {\n      if (a[i] < b[i]) return true;\n      if (a[i] > b[i]) return false;\n    }\n    return a.length < b.length;\n  };\n  const total = 1 << m;\n  for (let sub = 0; sub < total; sub++) {\n    let mask = 0;\n    const idxs: number[] = [];\n    for (let i = 0; i < m; i++) {\n      if (sub & (1 << i)) {\n        mask ^= btnMasks[i];\n        idxs.push(i);\n      }\n    }\n    if (mask === targetMask) {\n      if (best === null || idxs.length < best.length || (idxs.length === best.length && lexLess(idxs, best))) {\n        best = idxs.slice();\n      }\n    }\n  }\n  return best;\n}\n\n/** Brute-force solver for counter (for very small sizes) */\nfunction bruteCounter(lights: number[], buttons: number[][], modulus: number): number[] | null {\n  const n = lights.length;\n  const m = buttons.length;\n  const total = Math.pow(modulus, m);\n  let best: number[] | null = null;\n  const totalPresses = (arr: number[]) => arr.reduce((s, v) => s + v, 0);\n  const lexLess = (a: number[], b: number[]): boolean => {\n    for (let i = 0; i < a.length; i++) {\n      if (a[i] < b[i]) return true;\n      if (a[i] > b[i]) return false;\n    }\n    return false;\n  };\n  for (let num = 0; num < total; num++) {\n    let tmp = num;\n    const presses = new Array(m).fill(0);\n    for (let i = 0; i < m; i++) {\n      presses[i] = tmp % modulus;\n      tmp = Math.floor(tmp / modulus);\n    }\n    // compute resulting lights\n    const cur = new Array(n).fill(0);\n    for (let b = 0; b < m; b++) {\n      const cnt = presses[b];\n      if (cnt === 0) continue;\n      for (const idx of buttons[b]) {\n        cur[idx] = (cur[idx] + cnt) % modulus;\n      }\n    }\n    let ok = true;\n    for (let i = 0; i < n; i++) {\n      if (cur[i] !== ((lights[i] % modulus) + modulus) % modulus) { ok = false; break; }\n    }\n    if (ok) {\n      if (best === null || totalPresses(presses) < totalPresses(best) || (totalPresses(presses) === totalPresses(best) && lexLess(presses, best))) {\n        best = presses.slice();\n      }\n    }\n  }\n  return best;\n}\n\ndescribe('solveToggle', () => {\n  it('matches brute force on random small instances', () => {\n    for (let test = 0; test < 50; test++) {\n      const n = randInt(5) + 1; // 1..5 lights\n      const m = randInt(6) + 1; // 1..6 buttons\n      const target = Array.from({ length: n }, () => Math.random() < 0.5);\n      const buttons: number[][] = [];\n      for (let i = 0; i < m; i++) {\n        const k = randInt(n + 1);\n        const set = new Set<number>();\n        while (set.size < k) {\n          set.add(randInt(n));\n        }\n        buttons.push(Array.from(set));\n      }\n      const machine: Machine = { target, buttons };\n      const expected = bruteToggle(machine);\n      const result = solveToggle(machine);\n      expect(result).toEqual(expected);\n    }\n  });\n\n  it('returns null when impossible', () => {\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0], [0]], // both affect only light 0, cannot toggle light 1\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('matches brute force on tiny instances', () => {\n    for (let test = 0; test < 30; test++) {\n      const n = randInt(3) + 1; // 1..3 counters\n      const m = randInt(4) + 1; // 1..4 buttons\n      const modulus = [2, 3, 5, 7][randInt(4)]; // small primes\n      const lights = Array.from({ length: n }, () => randInt(modulus));\n      const buttons: number[][] = [];\n      for (let i = 0; i < m; i++) {\n        const k = randInt(n + 1);\n        const set = new Set<number>();\n        while (set.size < k) set.add(randInt(n));\n        buttons.push(Array.from(set));\n      }\n      const expected = bruteCounter(lights, buttons, modulus);\n      const result = solveCounter(lights, buttons, modulus);\n      expect(result).toEqual(expected);\n    }\n  });\n\n  it('handles unsolvable case', () => {\n    const lights = [1];\n    const buttons = [[0]]; // adds 1 each press\n    const modulus = 2; // only even values reachable (0 or 0 after two presses)\n    // Actually with modulus 2, pressing button once gives 1, so reachable. Let's make impossible: target 1, but button adds 0 (no effect)\n    const badButtons: number[][] = [[]];\n    expect(solveCounter(lights, badButtons, 2)).toBeNull();\n  });\n\n  it('performance on max size', () => {\n    const n = 40;\n    const m = 40;\n    const modulus = 97; // prime\n    const lights = Array.from({ length: n }, () => randInt(modulus));\n    const buttons: number[][] = [];\n    for (let i = 0; i < m; i++) {\n      const k = randInt(n + 1);\n      const set = new Set<number>();\n      while (set.size < k) set.add(randInt(n));\n      buttons.push(Array.from(set));\n    }\n    const start = performance.now();