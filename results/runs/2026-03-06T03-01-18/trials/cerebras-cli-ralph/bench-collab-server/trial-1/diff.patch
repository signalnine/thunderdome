 db.prepare('SELECT id, title, content FROM documents WHERE id = ?').get(docId);\n    if (!row) return res.status(404).json({ error: 'Document not found' });\n    const versionRow: any = db\n      .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n      .get(docId);\n    const version = versionRow?.version ?? 1;\n    res.json({ id: row.id, title: row.title, content: row.content, version });\n  });\n\n  // Update document (replace content)\n  app.put('/documents/:id', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const { title, content } = req.body;\n    if (typeof title !== 'string' || typeof content !== 'string') {\n      return res.status(400).json({ error: 'Invalid title or content' });\n    }\n    const info = db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?').run(title, content, docId);\n    if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n    const versionRow: any = db\n      .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n      .get(docId);\n    const nextVersion = (versionRow?.version ?? 0) + 1;\n    insertVersion(docId, nextVersion, content);\n    res.json({ id: docId, title, content, version: nextVersion });\n  });\n\n  // Delete document\n  app.delete('/documents/:id', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const info = db.prepare('DELETE FROM documents WHERE id = ?').run(docId);\n    if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n    res.status(204).send();\n  });\n\n  // List version history\n  app.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const rows = db.prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version ASC').all(docId);\n    res.json(rows);\n  });\n\n  // Get specific version content\n  app.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const version = Number(req.params.version);\n    const row: any = db.prepare('SELECT content FROM versions WHERE doc_id = ? AND version = ?').get(docId, version);\n    if (!row) return res.status(404).json({ error: 'Version not found' });\n    res.json({ version, content: row.content });\n  });\n\n  // ---- WebSocket collaboration --------------------------------------\n\n  const docClients = new Map<number, Set<WebSocket>>();\n\n  const applyOperation = (text: string, op: Operation): string => {\n    if (op.type === 'insert') {\n      return text.slice(0, op.pos) + op.text + text.slice(op.pos);\n    }\n    // delete\n    return text.slice(0, op.pos) + text.slice(op.pos + op.length);\n  };\n\n  const httpServer = createServer(app);\n  // Use a noServer WebSocketServer to handle dynamic paths\nconst wss = new WebSocketServer({ noServer: true });\n// Upgrade HTTP connections to WebSocket for paths like /ws/:docId\nhttpServer.on('upgrade', (request, socket, head) => {\n  console.log('Upgrade request:', request.url);\n\n  // Construct a URL using the request URL; fallback base if host header missing\n  const url = new URL(request.url ?? '', `http://localhost`);\n  if (!url.pathname.startsWith('/ws')) {\n    socket.write('HTTP/1.1 400 Bad Request\\r\\n\\r\\n');\n    socket.destroy();\n    return;\n  }\n  wss.handleUpgrade(request, socket, head, (ws) => {\n    wss.emit('connection', ws, request);\n  });\n});\n\n  wss.on('connection', (ws: WebSocket, request) => {\n    console.log('New WebSocket connection', request.url);\n    const url = new URL(request.url ?? '', `http://${request.headers.host}`);\n    // Expected path format: /ws/:docId\n    const parts = url.pathname.split('/');\n    const docId = Number(parts[2]);\n    if (!docId || Number.isNaN(docId)) {\n      ws.send(JSON.stringify({ error: 'Invalid document id' }));\n      ws.close();\n      return;\n    }\n    if (!docClients.has(docId)) docClients.set(docId, new Set());\n    docClients.get(docId)!.add(ws);\n    console.log('Added ws to docClients set, size now', docClients.get(docId)!.size);\n\n    const docRow: any = db.prepare('SELECT content FROM documents WHERE id = ?').get(docId);\n    if (!docRow) {\n      ws.send(JSON.stringify({ error: 'Document not found' }));\n      ws.close();\n      return;\n    }\n    const versionRow: any = db\n      .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n      .get(docId);\n    let currentVersion = versionRow?.version ?? 1;\n    ws.send(JSON.stringify({ type: 'sync', content: docRow.content, version: currentVersion }));\n\n    ws.on('message', (data) => {\n      console.log('Server handling message data:', data.toString());\n      let msg: any;\n      try { msg = JSON.parse(data.toString()); console.log('Received op message', msg); } catch { ws.send(JSON.stringify({ error: 'Invalid JSON' })); return; }\n      if (msg.type !== 'op' || typeof msg.version !== 'number' || !msg.op) {\n        ws.send(JSON.stringify({ error: 'Invalid operation format' }));\n        return;\n      }\n      if (msg.version !== currentVersion) {\n        ws.send(JSON.stringify({ error: 'Version mismatch', serverVersion: currentVersion }));\n        return;\n      }\n      const op: Operation = msg.op;\n      const newContent = applyOperation(docRow.content, op);\n      db.prepare('UPDATE documents SET content = ? WHERE id = ?').run(newContent, docId);\n      const newVersion = currentVersion + 1;\n      insertVersion(docId, newVersion, newContent);\n      docRow.content = newContent;\n      currentVersion = newVersion;\n      const broadcast = JSON.stringify({ type: 'op', op, version: newVersion });\n      console.log('Broadcasting op to other clients', broadcast);\n      for (const client of docClients.get(docId)!) {\n        if (client !== ws) {\n          setTimeout(() => client.send(broadcast), 10);\n        }\n      }\n    });\n\n    ws.on('close', () => {\n      const set = docClients.get(docId);\n      if (set) {\n        set.delete(ws);\n        if (set.size === 0) docClients.delete(docId);\n      }\n    });\n  });\n\n  // ---- Lifecycle ------------------------------------------------------\n\n  const start = async (port = 0): Promise<number> => {\n    return new Promise((resolve, reject) => {\n      httpServer.listen(port, () => {\n        console.log('httpServer listening callback, addr:', httpServer.address());\n        const addr = httpServer.address();\n        if (addr && typeof addr !== 'string') {\n          const actualPort = (addr as any).port;\n          if (actualPort) {\n            resolve(actualPort);\n            return;\n          }\n        }\n        reject(new Error('Failed to obtain port'));\n      });\n    });\n  };\n\nconst stop = async (): Promise<void> => {\n      // Close all WebSocket client connections gracefully\n      for (const [, clientSet] of docClients) {\n        for (const client of clientSet) {\n          try {\n            client.terminate();\n          } catch {}\n        }\n      }\n      docClients.clear();\n      return new Promise<void>((resolve, reject) => {\n        wss.close((err) => {\n          if (err) return reject(err);\n          httpServer.close((err2) => {\n            if (err2) return reject(err2);\n            db.close();\n            resolve();\n        });\n      });\n    });\n  };\n\n  return { app, start, stop };\n}\n\nif (import.meta.url === `file://${process.argv[1]}`) {\n  const instance = createApp();\n  instance.start(3000).then((p) => console.log(`Server listening on port ${p}`));\n}\n","after":"import express, { Request, Response } from 'express';\nimport { createServer } from 'http';\nimport { WebSocketServer, WebSocket } from 'ws';\nimport Database from 'better-sqlite3';\nimport path from 'path';\n\n/** Operational Transform operation definitions */\ninterface OpInsert {\n  type: 'insert';\n  pos: nu