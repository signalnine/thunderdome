+      .expect(201);
+    const docId = createRes.body.id;
+
+    // Helper to connect ws client
+    const connectWs = (clientName: string) => {
+      return new Promise<WebSocket>((resolve, reject) => {
+        const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+        ws.on('open', () => resolve(ws));
+        ws.on('error', (err) => reject(err));
+        ws.on('close', () => console.log(`${clientName} closed`));
+      });
+    };
+
+    const ws1 = await connectWs('client1');
+    const ws2 = await connectWs('client2');
+
+    // Helper to wait for a single message
+    const waitMessage = (ws: WebSocket) => {
+      return new Promise<any>((resolve) => {
+        ws.once('message', (data) => {
+          try {
+            resolve(JSON.parse(data.toString()));
+          } catch {
+            resolve(null);
+          }
+        });
+      });
+    };
+
+    // Both clients should receive initial sync
+    const sync1 = await waitMessage(ws1);
+    const sync2 = await waitMessage(ws2);
+    expect(sync1.type).toBe('sync');
+    expect(sync2.type).toBe('sync');
+    const version = sync1.version;
+
+    // Client1 sends an insert operation at position 0
+    const opMessage = {
+      type: 'op',
+      op: { type: 'insert', pos: 0, text: 'Hello' },
+      version,
+    };
+    ws1.send(JSON.stringify(opMessage));
+
+    // Client2 should receive the operation broadcast
+    const broadcast = await waitMessage(ws2);
+    expect(broadcast.type).toBe('op');
+    expect(broadcast.op).toEqual(opMessage.op);
+    expect(broadcast.version).toBe(version + 1);
+
+    // Close ws connections
+    ws1.close();
+    ws2.close();
+
+    // Verify document content via REST
+    const getRes = await request(serverInstance.app).get(`/documents/${docId}`).expect(200);
