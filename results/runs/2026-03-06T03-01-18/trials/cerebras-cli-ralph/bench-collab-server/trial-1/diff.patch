+const supertest = require('supertest');
+const { createApp } = require('./dist/server');
+(async () => {
+  const appInstance = createApp();
+  const port = await appInstance.start();
+  console.log('Server started port', port);
+  const request = supertest(`http://localhost:${port}`);
+  // create doc
+  const createRes = await request.post('/documents').send({title:'Test', content:''}).expect(201);
+  const docId = createRes.body.id;
+  console.log('Created doc', docId);
+  const WebSocket = require('ws');
+  const ws1 = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+  const ws2 = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+  await new Promise(r=>ws1.on('open', r));
+  await new Promise(r=>ws2.on('open', r));
+  console.log('Both ws open');
+  const waitMessage = (ws)=>new Promise(res=>ws.once('message', data=>res(JSON.parse(data.toString()))));
+  const sync1 = await waitMessage(ws1);
+  const sync2 = await waitMessage(ws2);
+  console.log('Sync received', sync1, sync2);
+  const version = sync1.version;
+  const opMessage = {type:'op', op:{type:'insert', pos:0, text:'Hello'}, version};
+  ws1.send(JSON.stringify(opMessage));
+  console.log('Sent op from ws1');
+  const broadcast = await waitMessage(ws2);
+  console.log('Broadcast received on ws2', broadcast);
+  ws1.close(); ws2.close();
+  const getRes = await request.get(`/documents/${docId}`).expect(200);
+  console.log('Final doc content', getRes.body.content);
+  await appInstance.stop();
+  console.log('Server stopped');
+})();
