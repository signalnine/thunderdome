+{"type":"tool_use","timestamp":1772766085678,"sessionID":"ses_33ee852e0ffejbvyovPis5KfIx","part":{"id":"prt_cc117bf30001JkdB1JFyPaFKMX","sessionID":"ses_33ee852e0ffejbvyovPis5KfIx","messageID":"msg_cc117bd6c002HWvT4CW4wosZUr","type":"tool","callID":"474086c75","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/server.ts","content":"import express, { Request, Response } from 'express';\nimport { createServer, Server as HttpServer } from 'http';\nimport { WebSocketServer, WebSocket } from 'ws';\nimport Database from 'better-sqlite3';\nimport path from 'path';\n\n/**\n * Simple Operational Transform operation definition.\n */\ninterface OpInsert {\n  type: 'insert';\n  pos: number; // zero‑based index\n  text: string;\n}\ninterface OpDelete {\n  type: 'delete';\n  pos: number; // zero‑based index\n  length: number; // number of characters to delete\n}\ntype Operation = OpInsert | OpDelete;\n\n/**\n * Server instance returned by createApp.\n */\nexport interface AppInstance {\n  app: ReturnType<typeof express>;\n  start: (port?: number) => Promise<number>;\n  stop: () => Promise<void>;\n}\n\n/**\n * Factory function to create the collaborative editing server.\n * @param dbFilePath optional path to SQLite file; defaults to in‑memory.\n */\nexport function createApp(dbFilePath?: string): AppInstance {\n  const app = express();\n  app.use(express.json());\n\n  // Initialise SQLite database\n  const dbPath = dbFilePath ? path.resolve(dbFilePath) : ':memory:';\n  const db = new Database(dbPath);\n\n  // Create tables if they do not exist\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS documents (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      title TEXT NOT NULL,\n      content TEXT NOT NULL,\n      created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    );\n    CREATE TABLE IF NOT EXISTS versions (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      doc_id INTEGER NOT NULL,\n      version INTEGER NOT NULL,\n      content TEXT NOT NULL,\n      timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,\n      FOREIGN KEY (doc_id) REFERENCES documents(id) ON DELETE CASCADE\n    );\n  `);\n\n  /** Helper to insert a new version row */\n  const insertVersion = (docId: number, version: number, content: string) => {\n    const stmt = db.prepare(`INSERT INTO versions (doc_id, version, content) VALUES (?, ?, ?)`);\n    stmt.run(docId, version, content);\n  };\n\n  // --- REST API routes ----------------------------------------------------\n\n  // Create a new document\n  app.post('/documents', (req: Request, res: Response) => {\n    const { title, content } = req.body;\n    if (typeof title !== 'string' || typeof content !== 'string') {\n      return res.status(400).json({ error: 'Invalid title or content' });\n    }\n    const insert = db.prepare('INSERT INTO documents (title, content) VALUES (?, ?)');\n    const info = insert.run(title, content);\n    const docId = Number(info.lastInsertRowid);\n    // version 1\n    insertVersion(docId, 1, content);\n    res.status(201).json({ id: docId, title, content, version: 1 });\n  });\n\n  // List all documents (metadata only)\n  app.get('/documents', (req: Request, res: Response) => {\n    const rows = db.prepare('SELECT id, title, created_at FROM documents').all();\n    res.json(rows);\n  });\n\n  // Get a document by id\n  app.get('/documents/:id', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const row = db.prepare('SELECT id, title, content FROM documents WHERE id = ?').get(docId);\n    if (!row) return res.status(404).json({ error: 'Document not found' });\n    // Get latest version number\n    const versionRow = db.prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1').get(docId);\n    const version = versionRow?.version ?? 1;\n    res.json({ id: row.id, title: row.title, content: row.content, version });\n  });\n\n  // Update a document (replace whole content)\n  app.put('/documents/:id', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const { title, content } = req.body;\n    if (typeof title !== 'string' || typeof content !== 'string') {\n      return res.status(400).json({ error: 'Invalid title or content' });\n    }\n    const update = db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?');\n    const info = update.run(title, content, docId);\n    if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n    // Determine next version number\n    const versionRow = db.prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1').get(docId);\n    const nextVersion = (versionRow?.version ?? 0) + 1;\n    insertVersion(docId, nextVersion, content);\n    res.json({ id: docId, title, content, version: nextVersion });\n  });\n\n  // Delete a document\n  app.delete('/documents/:id', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const del = db.prepare('DELETE FROM documents WHERE id = ?');\n    const info = del.run(docId);\n    if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n    // cascade deletes versions via foreign key\n    res.status(204).send();\n  });\n\n  // List version history for a document\n  app.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const rows = db\n      .prepare('SELECT version, timestamp FROM versions WHERE doc_id = ? ORDER BY version ASC')\n      .all(docId);\n    res.json(rows);\n  });\n\n  // Get specific version content\n  app.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const version = Number(req.params.version);\n    const row = db\n      .prepare('SELECT content FROM versions WHERE doc_id = ? AND version = ?')\n      .get(docId, version);\n    if (!row) return res.status(404).json({ error: 'Version not found' });\n    res.json({ version, content: row.content });\n  });\n\n  // --- WebSocket collaboration ------------------------------------------\n\n  // Map of documentId -> Set of WebSocket connections\n  const docClients = new Map<number, Set<WebSocket>>();\n\n  // Helper to apply an operation to a string\n  const applyOperation = (text: string, op: Operation): string => {\n    if (op.type === 'insert') {\n      const before = text.slice(0, op.pos);\n      const after = text.slice(op.pos);\n      return before + op.text + after;\n    } else {\n      // delete\n      const before = text.slice(0, op.pos);\n      const after = text.slice(op.pos + op.length);\n      return before + after;\n    }\n  };\n\n  const httpServer = createServer(app);\n  const wss = new WebSocketServer({ server: httpServer, path: '/ws' });\n\n  wss.on('connection', (ws: WebSocket, request) => {\n    // Expected URL: /ws/:docId (e.g., ws://host/ws/5)\n    const urlParts = request.url?.split('/') ?? [];\n    // urlParts[0] is '' (because leading slash), [1] is 'ws', [2] is docId\n    const docIdStr = urlParts[2];\n    const docId = Number(docIdStr);\n    if (!docIdStr || Number.isNaN(docId)) {\n      ws.send(JSON.stringify({ error: 'Invalid document id in URL' }));\n      ws.close();\n      return;\n    }\n\n    // Register client\n    if (!docClients.has(docId)) docClients.set(docId, new Set());\n    docClients.get(docId)!.add(ws);\n\n    // Send current document state\n    const docRow = db.prepare('SELECT content FROM documents WHERE id = ?').get(docId);\n    if (!docRow) {\n      ws.send(JSON.stringify({ error: 'Document not found' }));\n      ws.close();\n      return;\n    }\n    const versionRow = db.prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1').get(docId);\n    const currentVersion = versionRow?.version ?? 1;\n    ws.send(\n      JSON.stringify({ type: 'sync', content: docRow.content, version: currentVersion })\n    );\n\n    ws.on('message', (data) => {\n      let msg: any;\n      try {\n        msg = JSON.parse(data.toString());\n      } catch (e) {\n        ws.send(JSON.stringify({ error: 'Invalid JSON' }));\n        return;\n      }\n      // Expected message: { type: 'op', op: Operation, version: number }\n      if (msg.type !== 'op' || typeof msg.version !== 'number' || !msg.op) {\n        ws.send(JSON.stringify({ error: 'Invalid operation format' }));\n        return;\n      }\n\n      // Simple version check – if client version differs, reject for now\n      if (msg.version !== currentVersion) {\n        ws.send(JSON.stringify({ error: 'Version mismatch', serverVersion: currentVersion }));\n        return;\n      }\n\n      const op: Operation = msg.op;\n      // Apply operation\n      const newContent = applyOperation(docRow.content, op);\n      // Update DB\n      const updateStmt = db.prepare('UPDATE documents SET content = ? WHERE id = ?');\n      updateStmt.run(newContent, docId);\n      const newVersion = currentVersion + 1;\n      insertVersion(docId, newVersion, newContent);\n\n      // Update local cache variable\n      docRow.content = newContent;\n      // Increment stored version\n      // Broadcast to other clients\n      const broadcastMsg = JSON.stringify({ type: 'op', op, version: newVersion });\n      for (const client of docClients.get(docId)!) {\n        if (client !== ws && client.readyState === WebSocket.OPEN) {\n          client.send(broadcastMsg);\n        }\n      }\n    });\n\n    ws.on('close', () => {\n      const set = docClients.get(docId);\n      if (set) {\n        set.delete(ws);\n        if (set.size === 0) docClients.delete(docId);\n      }\n    });\n  });\n\n  // --- Lifecycle methods ---------------------------------------------------\n\n  const start = async (port = 0): Promise<number> => {\n    return new Promise((resolve, reject) => {\n      httpServer.listen(port, () => {\n        const addr = httpServer.address();\n        const actualPort = typeof addr === 'string' ? parseInt(addr) : addr?.port;\n        if (actualPort) resolve(actualPort);\n        else reject(new Error('Failed to obtain port'));\n      });\n    });\n  };\n\n  const stop = async (): Promise<void> => {\n    return new Promise((resolve, reject) => {\n      wss.close((err) => {\n        if (err) return reject(err);\n        httpServer.close((err2) => {\n          if (err2) return reject(err2);\n          // Close DB\n          db.close();\n          resolve();\n        });\n      });\n    });\n  };\n\n  return { app, start, stop };\n}\n\n// If this file is executed directly, start server on a default port.\nif (import.meta.url === `file://${process.argv[1]}`) {\n  const instance = createApp();\n  instance.start(3000).then((port) => console.log(`Server listening on port ${port}`));\n}\n"},"output":"Wrote file successfully.","title":"src/server.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/server.ts","exists":false,"truncated":false},"time":{"start":1772766085665,"end":1772766085677}}}}
