+{"type":"tool_use","timestamp":1772767783736,"sessionID":"ses_33ece5ba5ffetaMB7DVaUI4gRM","part":{"id":"prt_cc131ab30001vqzIPVhYK4eszM","sessionID":"ses_33ece5ba5ffetaMB7DVaUI4gRM","messageID":"msg_cc131aa0d002qsFB4ZSDeT84n5","type":"tool","callID":"6b8b1872a","tool":"read","state":{"status":"completed","input":{"filePath":"/workspace/src/server.ts","offset":1,"limit":2000},"output":"<path>/workspace/src/server.ts</path>\n<type>file</type>\n<content>1: import express, { Request, Response } from 'express';\n2: import { createServer } from 'http';\n3: import { WebSocketServer, WebSocket } from 'ws';\n4: import Database from 'better-sqlite3';\n5: import path from 'path';\n6: \n7: /** Operational Transform operation definitions */\n8: interface OpInsert {\n9:   type: 'insert';\n10:   pos: number; // zero‑based index\n11:   text: string;\n12: }\n13: interface OpDelete {\n14:   type: 'delete';\n15:   pos: number; // zero‑based index\n16:   length: number; // characters to delete\n17: }\n18: type Operation = OpInsert | OpDelete;\n19: \n20: export interface AppInstance {\n21:   app: ReturnType<typeof express>;\n22:   start: (port?: number) => Promise<number>;\n23:   stop: () => Promise<void>;\n24: }\n25: \n26: /** Create the collaborative editing server */\n27: export function createApp(dbFilePath?: string): AppInstance {\n28:   const app = express();\n29:   app.use(express.json());\n30: \n31:   const dbPath = dbFilePath ? path.resolve(dbFilePath) : ':memory:';\n32:   const db = new Database(dbPath);\n33: \n34:   // Initialise tables\n35:   db.exec(`\n36:     CREATE TABLE IF NOT EXISTS documents (\n37:       id INTEGER PRIMARY KEY AUTOINCREMENT,\n38:       title TEXT NOT NULL,\n39:       content TEXT NOT NULL DEFAULT ''\n40:     );\n41:     CREATE TABLE IF NOT EXISTS versions (\n42:       id INTEGER PRIMARY KEY AUTOINCREMENT,\n43:       doc_id INTEGER NOT NULL,\n44:       version INTEGER NOT NULL,\n45:       content TEXT NOT NULL,\n46:       FOREIGN KEY (doc_id) REFERENCES documents(id) ON DELETE CASCADE\n47:     );\n48:   `);\n49: \n50:   const insertVersion = (docId: number, version: number, content: string) => {\n51:     const stmt = db.prepare('INSERT INTO versions (doc_id, version, content) VALUES (?, ?, ?)');\n52:     stmt.run(docId, version, content);\n53:   };\n54: \n55:   // ---- REST API -----------------------------------------------------\n56: \n57:   // Create document\n58:   app.post('/documents', (req: Request, res: Response) => {\n59:     const { title, content } = req.body;\n60:     if (typeof title !== 'string' || typeof content !== 'string') {\n61:       return res.status(400).json({ error: 'Invalid title or content' });\n62:     }\n63:     const info = db.prepare('INSERT INTO documents (title, content) VALUES (?, ?)').run(title, content);\n64:     const docId = Number(info.lastInsertRowid);\n65:     insertVersion(docId, 1, content);\n66:     res.status(201).json({ id: docId, title, content, version: 1 });\n67:   });\n68: \n69:   // List documents metadata\n70:   app.get('/documents', (req: Request, res: Response) => {\n71:     const rows = db.prepare('SELECT id, title FROM documents').all();\n72:     res.json(rows);\n73:   });\n74: \n75:   // Get document\n76:   app.get('/documents/:id', (req: Request, res: Response) => {\n77:     const docId = Number(req.params.id);\n78:     const row: any = db.prepare('SELECT id, title, content FROM documents WHERE id = ?').get(docId);\n79:     if (!row) return res.status(404).json({ error: 'Document not found' });\n80:     const versionRow: any = db\n81:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n82:       .get(docId);\n83:     const version = versionRow?.version ?? 1;\n84:     res.json({ id: row.id, title: row.title, content: row.content, version });\n85:   });\n86: \n87:   // Update document (replace content)\n88:   app.put('/documents/:id', (req: Request, res: Response) => {\n89:     const docId = Number(req.params.id);\n90:     const { title, content } = req.body;\n91:     if (typeof title !== 'string' || typeof content !== 'string') {\n92:       return res.status(400).json({ error: 'Invalid title or content' });\n93:     }\n94:     const info = db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?').run(title, content, docId);\n95:     if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n96:     const versionRow: any = db\n97:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n98:       .get(docId);\n99:     const nextVersion = (versionRow?.version ?? 0) + 1;\n100:     insertVersion(docId, nextVersion, content);\n101:     res.json({ id: docId, title, content, version: nextVersion });\n102:   });\n103: \n104:   // Delete document\n105:   app.delete('/documents/:id', (req: Request, res: Response) => {\n106:     const docId = Number(req.params.id);\n107:     const info = db.prepare('DELETE FROM documents WHERE id = ?').run(docId);\n108:     if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n109:     res.status(204).send();\n110:   });\n111: \n112:   // List version history\n113:   app.get('/documents/:id/versions', (req: Request, res: Response) => {\n114:     const docId = Number(req.params.id);\n115:     const rows = db.prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version ASC').all(docId);\n116:     res.json(rows);\n117:   });\n118: \n119:   // Get specific version content\n120:   app.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n121:     const docId = Number(req.params.id);\n122:     const version = Number(req.params.version);\n123:     const row: any = db.prepare('SELECT content FROM versions WHERE doc_id = ? AND version = ?').get(docId, version);\n124:     if (!row) return res.status(404).json({ error: 'Version not found' });\n125:     res.json({ version, content: row.content });\n126:   });\n127: \n128:   // ---- WebSocket collaboration --------------------------------------\n129: \n130:   const docClients = new Map<number, Set<WebSocket>>();\n131: \n132:   const applyOperation = (text: string, op: Operation): string => {\n133:     if (op.type === 'insert') {\n134:       return text.slice(0, op.pos) + op.text + text.slice(op.pos);\n135:     }\n136:     // delete\n137:     return text.slice(0, op.pos) + text.slice(op.pos + op.length);\n138:   };\n139: \n140:   const httpServer = createServer(app);\n141:   // Use a noServer WebSocketServer to handle dynamic paths\n142: const wss = new WebSocketServer({ noServer: true });\n143: // Upgrade HTTP connections to WebSocket for paths like /ws/:docId\n144: httpServer.on('upgrade', (request, socket, head) => {\n145:   // Construct a URL using the request URL; fallback base if host header missing\n146:   const url = new URL(request.url ?? '', `http://localhost`);\n147:   if (!url.pathname.startsWith('/ws')) {\n148:     socket.write('HTTP/1.1 400 Bad Request\\r\\n\\r\\n');\n149:     socket.destroy();\n150:     return;\n151:   }\n152:   wss.handleUpgrade(request, socket, head, (ws) => {\n153:     wss.emit('connection', ws, request);\n154:   });\n155: });\n156: \n157:   wss.on('connection', (ws: WebSocket, request) => {\n158:   const url = new URL(request.url ?? '', `http://${request.headers.host}`);\n159:   // Expected path format: /ws/:docId\n160:   const parts = url.pathname.split('/');\n161:   const docId = Number(parts[2]);\n162:   if (!docId || Number.isNaN(docId)) {\n163:       ws.send(JSON.stringify({ error: 'Invalid document id' }));\n164:       ws.close();\n165:       return;\n166:     }\n167:     if (!docClients.has(docId)) docClients.set(docId, new Set());\n168:     docClients.get(docId)!.add(ws);\n169: \n170:     const docRow: any = db.prepare('SELECT content FROM documents WHERE id = ?').get(docId);\n171:     if (!docRow) {\n172:       ws.send(JSON.stringify({ error: 'Document not found' }));\n173:       ws.close();\n174:       return;\n175:     }\n176:     const versionRow: any = db\n177:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n178:       .get(docId);\n179:     let currentVersion = versionRow?.version ?? 1;\n180:     ws.send(JSON.stringify({ type: 'sync', content: docRow.content, version: currentVersion }));\n181: \n182:     ws.on('message', (data) => {\n183:       let msg: any;\n184:       try { msg = JSON.parse(data.toString()); } catch { ws.send(JSON.stringify({ error: 'Invalid JSON' })); return; }\n185:       if (msg.type !== 'op' || typeof msg.version !== 'number' || !msg.op) {\n186:         ws.send(JSON.stringify({ error: 'Invalid operation format' }));\n187:         return;\n188:       }\n189:       if (msg.version !== currentVersion) {\n190:         ws.send(JSON.stringify({ error: 'Version mismatch', serverVersion: currentVersion }));\n191:         return;\n192:       }\n193:       const op: Operation = msg.op;\n194:       const newContent = applyOperation(docRow.content, op);\n195:       db.prepare('UPDATE documents SET content = ? WHERE id = ?').run(newContent, docId);\n196:       const newVersion = currentVersion + 1;\n197:       insertVersion(docId, newVersion, newContent);\n198:       docRow.content = newContent;\n199:       currentVersion = newVersion;\n200:       const broadcast = JSON.stringify({ type: 'op', op, version: newVersion });\n201:       for (const client of docClients.get(docId)!) {\n202:         if (client !== ws && client.readyState === WebSocket.OPEN) {\n203:           setTimeout(() => client.send(broadcast), 0);\n204:         }\n205:       }\n206:     });\n207: \n208:     ws.on('close', () => {\n209:       const set = docClients.get(docId);\n210:       if (set) {\n211:         set.delete(ws);\n212:         if (set.size === 0) docClients.delete(docId);\n213:       }\n214:     });\n215:   });\n216: \n217:   // ---- Lifecycle ------------------------------------------------------\n218: \n219:   const start = async (port = 0): Promise<number> => {\n220:     return new Promise((resolve, reject) => {\n221:       httpServer.listen(port, () => {\n222:         const addr = httpServer.address();\n223:         const actualPort = typeof addr === 'string' ? parseInt(addr) : (addr as any)?.port;\n224:         if (actualPort) resolve(actualPort);\n225:         else reject(new Error('Failed to obtain port'));\n226:       });\n227:     });\n228:   };\n229: \n230:   const stop = async (): Promise<void> => {\n231:     return new Promise((resolve, reject) => {\n232:       wss.close((err) => {\n233:         if (err) return reject(err);\n234:         httpServer.close((err2) => {\n235:           if (err2) return reject(err2);\n236:           db.close();\n237:           resolve();\n238:         });\n239:       });\n240:     });\n241:   };\n242: \n243:   return { app, start, stop };\n244: }\n245: \n246: if (import.meta.url === `file://${process.argv[1]}`) {\n247:   const instance = createApp();\n248:   instance.start(3000).then((p) => console.log(`Server listening on port ${p}`));\n249: }\n250: \n\n(End of file - total 250 lines)\n</content>","title":"src/server.ts","metadata":{"preview":"import express, { Request, Response } from 'express';\nimport { createServer } from 'http';\nimport { WebSocketServer, WebSocket } from 'ws';\nimport Database from 'better-sqlite3';\nimport path from 'path';\n\n/** Operational Transform operation definitions */\ninterface OpInsert {\n  type: 'insert';\n  pos: number; // zero‑based index\n  text: string;\n}\ninterface OpDelete {\n  type: 'delete';\n  pos: number; // zero‑based index\n  length: number; // characters to delete\n}\ntype Operation = OpInsert | OpDelete;\n\nexport interface AppInstance {","truncated":false,"loaded":[]},"time":{"start":1772767783730,"end":1772767783735}}}}
