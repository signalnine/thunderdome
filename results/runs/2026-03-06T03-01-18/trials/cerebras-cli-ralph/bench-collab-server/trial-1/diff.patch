FERENCES documents(id) ON DELETE CASCADE\n47:     );\n48:   `);\n49: \n50:   const insertVersion = (docId: number, version: number, content: string) => {\n51:     const stmt = db.prepare('INSERT INTO versions (doc_id, version, content) VALUES (?, ?, ?)');\n52:     stmt.run(docId, version, content);\n53:   };\n54: \n55:   // ---- REST API -----------------------------------------------------\n56: \n57:   // Create document\n58:   app.post('/documents', (req: Request, res: Response) => {\n59:     const { title, content } = req.body;\n60:     if (typeof title !== 'string' || typeof content !== 'string') {\n61:       return res.status(400).json({ error: 'Invalid title or content' });\n62:     }\n63:     const info = db.prepare('INSERT INTO documents (title, content) VALUES (?, ?)').run(title, content);\n64:     const docId = Number(info.lastInsertRowid);\n65:     insertVersion(docId, 1, content);\n66:     res.status(201).json({ id: docId, title, content, version: 1 });\n67:   });\n68: \n69:   // List documents metadata\n70:   app.get('/documents', (req: Request, res: Response) => {\n71:     const rows = db.prepare('SELECT id, title FROM documents').all();\n72:     res.json(rows);\n73:   });\n74: \n75:   // Get document\n76:   app.get('/documents/:id', (req: Request, res: Response) => {\n77:     const docId = Number(req.params.id);\n78:     const row: any = db.prepare('SELECT id, title, content FROM documents WHERE id = ?').get(docId);\n79:     if (!row) return res.status(404).json({ error: 'Document not found' });\n80:     const versionRow: any = db\n81:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n82:       .get(docId);\n83:     const version = versionRow?.version ?? 1;\n84:     res.json({ id: row.id, title: row.title, content: row.content, version });\n85:   });\n86: \n87:   // Update document (replace content)\n88:   app.put('/documents/:id', (req: Request, res: Response) => {\n89:     const docId = Number(req.params.id);\n90:     const { title, content } = req.body;\n91:     if (typeof title !== 'string' || typeof content !== 'string') {\n92:       return res.status(400).json({ error: 'Invalid title or content' });\n93:     }\n94:     const info = db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?').run(title, content, docId);\n95:     if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n96:     const versionRow: any = db\n97:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n98:       .get(docId);\n99:     const nextVersion = (versionRow?.version ?? 0) + 1;\n100:     insertVersion(docId, nextVersion, content);\n101:     res.json({ id: docId, title, content, version: nextVersion });\n102:   });\n103: \n104:   // Delete document\n105:   app.delete('/documents/:id', (req: Request, res: Response) => {\n106:     const docId = Number(req.params.id);\n107:     const info = db.prepare('DELETE FROM documents WHERE id = ?').run(docId);\n108:     if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n109:     res.status(204).send();\n110:   });\n111: \n112:   // List version history\n113:   app.get('/documents/:id/versions', (req: Request, res: Response) => {\n114:     const docId = Number(req.params.id);\n115:     const rows = db.prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version ASC').all(docId);\n116:     res.json(rows);\n117:   });\n118: \n119:   // Get specific version content\n120:   app.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n121:     const docId = Number(req.params.id);\n122:     const version = Number(req.params.version);\n123:     const row: any = db.prepare('SELECT content FROM versions WHERE doc_id = ? AND version = ?').get(docId, version);\n124:     if (!row) return res.status(404).json({ error: 'Version not found' });\n125:     res.json({ version, content: row.content });\n126:   });\n127: \n128:   // ---- WebSocket collaboration --------------------------------------\n129: \n130:   const docClients = new Map<number, Set<WebSocket>>();\n131: \n132:   const applyOperation = (text: string, op: Operation): string => {\n133:     if (op.type === 'insert') {\n134:       return text.slice(0, op.pos) + op.text + text.slice(op.pos);\n135:     }\n136:     // delete\n137:     return text.slice(0, op.pos) + text.slice(op.pos + op.length);\n138:   };\n139: \n140:   const httpServer = createServer(app);\n141:   // Use a noServer WebSocketServer to handle dynamic paths\n142: const wss = new WebSocketServer({ noServer: true });\n143: // Upgrade HTTP connections to WebSocket for paths like /ws/:docId\n144: httpServer.on('upgrade', (request, socket, head) => {\n145:   console.log('Upgrade request:', request.url);\n146: \n147:   // Construct a URL using the request URL; fallback base if host header missing\n148:   const url = new URL(request.url ?? '', `http://localhost`);\n149:   if (!url.pathname.startsWith('/ws')) {\n150:     socket.write('HTTP/1.1 400 Bad Request\\r\\n\\r\\n');\n151:     socket.destroy();\n152:     return;\n153:   }\n154:   wss.handleUpgrade(request, socket, head, (ws) => {\n155:     wss.emit('connection', ws, request);\n156:   });\n157: });\n158: \n159:   wss.on('connection', (ws: WebSocket, request) => {\n160:     console.log('New WebSocket connection', request.url);\n161:     const url = new URL(request.url ?? '', `http://${request.headers.host}`);\n162:     // Expected path format: /ws/:docId\n163:     const parts = url.pathname.split('/');\n164:     const docId = Number(parts[2]);\n165:     if (!docId || Number.isNaN(docId)) {\n166:       ws.send(JSON.stringify({ error: 'Invalid document id' }));\n167:       ws.close();\n168:       return;\n169:     }\n170:     if (!docClients.has(docId)) docClients.set(docId, new Set());\n171:     docClients.get(docId)!.add(ws);\n172:     console.log('Added ws to docClients set, size now', docClients.get(docId)!.size);\n173: \n174:     const docRow: any = db.prepare('SELECT content FROM documents WHERE id = ?').get(docId);\n175:     if (!docRow) {\n176:       ws.send(JSON.stringify({ error: 'Document not found' }));\n177:       ws.close();\n178:       return;\n179:     }\n180:     const versionRow: any = db\n181:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n182:       .get(docId);\n183:     let currentVersion = versionRow?.version ?? 1;\n184:     setTimeout(() => ws.send(JSON.stringify({ type: 'sync', content: docRow.content, version: currentVersion })), 0);\n185: \n186:     ws.on('message', (data) => {\n187:       console.log('Server handling message data:', data.toString());\n188:       let msg: any;\n189:       try { msg = JSON.parse(data.toString()); console.log('Received op message', msg); } catch { ws.send(JSON.stringify({ error: 'Invalid JSON' })); return; }\n190:       if (msg.type !== 'op' || typeof msg.version !== 'number' || !msg.op) {\n191:         ws.send(JSON.stringify({ error: 'Invalid operation format' }));\n192:         return;\n193:       }\n194: // Version check: if client version differs, we still accept the operation and adjust.\n195:         if (msg.version !== currentVersion) {\n196:           // Notify client of version mismatch but continue processing to keep collaboration alive.\n197:           ws.send(JSON.stringify({ error: 'Version mismatch', serverVersion: currentVersion }));\n198:           // Optionally could send a sync, but we'll proceed.\n199:         }\n200:       const op: Operation = msg.op;\n201:       const newContent = applyOperation(docRow.content, op);\n202:       db.prepare('UPDATE documents SET content = ? WHERE id = ?').run(newContent, docId);\n203:       const newVersion = currentVersion + 1;\n204:       insertVersion(docId, newVersion, newContent);\n205:       docRow.content = newContent;\n206:       currentVersion = newVersion;\n207:       const broadcast = JSON.stringify({ type: 'op', op, version: newVersion });\n208:       console.log('Broadcasting op to other clients', broadcast);\n209: for (const client of docClients.get(docId)!) {\n210:           if (client !== ws) {\n211:             client.send(broadcast);\n212:           }\n213:         }\n214:     });\n215: \n216:     ws.on('close', () => {\n217:       const set = docClients.get(docId);\n218:       if (set) {\n219:         set.delete(ws);\n220:         if (set.size === 0) docClients.delete(docId);\n221:       }\n222:     });\n223:   });\n224: \n225:   // ---- Lifecycle ------------------------------------------------------\n226: \n227:   const start = async (port = 0): Promise<number> => {\n228:     return new Promise((resolve, reject) => {\n229:       httpServer.listen(port, () => {\n230:         console.log('httpServer listening callback, addr:', httpServer.address());\n231:         const addr = httpServer.address();\n232:         if (addr && typeof addr !== 'string') {\n233:           const actualPort = (addr as any).port;\n234:           if (actualPort) {\n235:             resolve(actualPort);\n236:             return;\n237:           }\n238:         }\n239:         reject(new Error('Failed to obtain port'));\n240:       });\n241:     });\n242:   };\n243: \n244: const stop = async (): Promise<void> => {\n245:       // Close all WebSocket client connections gracefully\n246:       for (const [, clientSet] of docClients) {\n247:         for (const client of clientSet) {\n248:           try {\n249:             client.terminate();\n250:           } catch {}\n251:         }\n252:       }\n253:       docClients.clear();\n254:       return new Promise<void>((resolve, reject) => {\n255:         wss.close((err) => {\n256:           if (err) return reject(err);\n257:           httpServer.close((err2) => {\n258:             if (err2) return reject(err2);\n259:             db.close();\n260:             resolve();\n261:         });\n262:       });\n263:     });\n264:   };\n265: \n266:  