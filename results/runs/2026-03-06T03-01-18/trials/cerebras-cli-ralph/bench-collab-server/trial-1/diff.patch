:     const { title, content } = req.body;\n91:     if (typeof title !== 'string' || typeof content !== 'string') {\n92:       return res.status(400).json({ error: 'Invalid title or content' });\n93:     }\n94:     const info = db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?').run(title, content, docId);\n95:     if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n96:     const versionRow: any = db\n97:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n98:       .get(docId);\n99:     const nextVersion = (versionRow?.version ?? 0) + 1;\n100:     insertVersion(docId, nextVersion, content);\n101:     res.json({ id: docId, title, content, version: nextVersion });\n102:   });\n103: \n104:   // Delete document\n105:   app.delete('/documents/:id', (req: Request, res: Response) => {\n106:     const docId = Number(req.params.id);\n107:     const info = db.prepare('DELETE FROM documents WHERE id = ?').run(docId);\n108:     if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n109:     res.status(204).send();\n110:   });\n111: \n112:   // List version history\n113:   app.get('/documents/:id/versions', (req: Request, res: Response) => {\n114:     const docId = Number(req.params.id);\n115:     const rows = db.prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version ASC').all(docId);\n116:     res.json(rows);\n117:   });\n118: \n119:   // Get specific version content\n120:   app.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n121:     const docId = Number(req.params.id);\n122:     const version = Number(req.params.version);\n123:     const row: any = db.prepare('SELECT content FROM versions WHERE doc_id = ? AND version = ?').get(docId, version);\n124:     if (!row) return res.status(404).json({ error: 'Version not found' });\n125:     res.json({ version, content: row.content });\n126:   });\n127: \n128:   // ---- WebSocket collaboration --------------------------------------\n129: \n130:   const docClients = new Map<number, Set<WebSocket>>();\n131: \n132:   const applyOperation = (text: string, op: Operation): string => {\n133:     if (op.type === 'insert') {\n134:       return text.slice(0, op.pos) + op.text + text.slice(op.pos);\n135:     }\n136:     // delete\n137:     return text.slice(0, op.pos) + text.slice(op.pos + op.length);\n138:   };\n139: \n140:   const httpServer = createServer(app);\n141:   // Use a noServer WebSocketServer to handle dynamic paths\n142: const wss = new WebSocketServer({ noServer: true });\n143: // Upgrade HTTP connections to WebSocket for paths like /ws/:docId\n144: httpServer.on('upgrade', (request, socket, head) => {\n145:   console.log('Upgrade request:', request.url);\n146: \n147:   // Construct a URL using the request URL; fallback base if host header missing\n148:   const url = new URL(request.url ?? '', `http://localhost`);\n149:   if (!url.pathname.startsWith('/ws')) {\n150:     socket.write('HTTP/1.1 400 Bad Request\\r\\n\\r\\n');\n151:     socket.destroy();\n152:     return;\n153:   }\n154:   wss.handleUpgrade(request, socket, head, (ws) => {\n155:     wss.emit('connection', ws, request);\n156:   });\n157: });\n158: \n159:   wss.on('connection', (ws: WebSocket, request) => {\n160:     console.log('New WebSocket connection', request.url);\n161:     const url = new URL(request.url ?? '', `http://${request.headers.host}`);\n162:     // Expected path format: /ws/:docId\n163:     const parts = url.pathname.split('/');\n164:     const docId = Number(parts[2]);\n165:     if (!docId || Number.isNaN(docId)) {\n166:       ws.send(JSON.stringify({ error: 'Invalid document id' }));\n167:       ws.close();\n168:       return;\n169:     }\n170:     if (!docClients.has(docId)) docClients.set(docId, new Set());\n171:     docClients.get(docId)!.add(ws);\n172:     console.log('Added ws to docClients set, size now', docClients.get(docId)!.size);\n173: \n174:     const docRow: any = db.prepare('SELECT content FROM documents WHERE id = ?').get(docId);\n175:     if (!docRow) {\n176:       ws.send(JSON.stringify({ error: 'Document not found' }));\n177:       ws.close();\n178:       return;\n179:     }\n180:     const versionRow: any = db\n181:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n182:       .get(docId);\n183:     let currentVersion = versionRow?.version ?? 1;\n184:     ws.send(JSON.stringify({ type: 'sync', content: docRow.content, version: currentVersion }));\n185: \n186:     ws.on('message', (data) => {\n187:       console.log('Server handling message data:', data.toString());\n188:       let msg: any;\n189:       try { msg = JSON.parse(data.toString()); console.log('Received op message', msg); } catch { ws.send(JSON.stringify({ error: 'Invalid JSON' })); return; }\n190:       if (msg.type !== 'op' || typeof msg.version !== 'number' || !msg.op) {\n191:         ws.send(JSON.stringify({ error: 'Invalid operation format' }));\n192:         return;\n193:       }\n194:       if (msg.version !== currentVersion) {\n195:         ws.send(JSON.stringify({ error: 'Version mismatch', serverVersion: currentVersion }));\n196:         return;\n197:       }\n198:       const op: Operation = msg.op;\n199:       const newContent = applyOperation(docRow.content, op);\n200:       db.prepare('UPDATE documents SET content = ? WHERE id = ?').run(newContent, docId);\n201:       const newVersion = currentVersion + 1;\n202:       insertVersion(docId, newVersion, newContent);\n203:       docRow.content = newContent;\n204:       currentVersion = newVersion;\n205:       const broadcast = JSON.stringify({ type: 'op', op, version: newVersion });\n206:       console.log('Broadcasting op to other clients', broadcast);\n207:       for (const client of docClients.get(docId)!) {\n208:         if (client !== ws) {\n209: setTimeout(() => client.send(broadcast), 0);\n210:         }\n211:       }\n212:     });\n213: \n214:     ws.on('close', () => {\n215:       const set = docClients.get(docId);\n216:       if (set) {\n217:         set.delete(ws);\n218:         if (set.size === 0) docClients.delete(docId);\n219:       }\n220:     });\n221:   });\n222: \n223:   // ---- Lifecycle ------------------------------------------------------\n224: \n225:   const start = async (port = 0): Promise<number> => {\n226:     return new Promise((resolve, reject) => {\n227:       httpServer.listen(port, () => {\n228:         console.log('httpServer listening callback, addr:', httpServer.address());\n229:         const addr = httpServer.address();\n230:         if (addr && typeof addr !== 'string') {\n231:           const actualPort = (addr as any).port;\n232:           if (actualPort) {\n233:             resolve(actualPort);\n234:             return;\n235:           }\n236:         }\n237:         reject(new Error('Failed to obtain port'));\n238:       });\n239:     });\n240:   };\n241: \n242: const stop = async (): Promise<void> => {\n243:       // Close all WebSocket client connections gracefully\n244:       for (const [, clientSet] of docClients) {\n245:         for (const client of clientSet) {\n246:           try {\n247:             client.terminate();\n248:           } catch {}\n249:         }\n250:       }\n251:       docClients.clear();\n252:       return new Promise<void>((resolve, reject) => {\n253:         wss.close((err) => {\n254:           if (err) return reject(err);\n255:           httpServer.close((err2) => {\n256:             if (err2) return reject(err2);\n257:             db.close();\n258:             resolve();\n259:         });\n260:       });\n261:     });\n262:   };\n263: \n264:   return { app, start, stop };\n265: }\n266: \n267: if (import.meta.url === `file://${process.argv[1]}`) {\n268:   const instance = createApp();\n269:   instance.start(3000).then((p) => console.log(`Server listening on port ${p}`));\n270: }\n271: \n\n(End of file - total 