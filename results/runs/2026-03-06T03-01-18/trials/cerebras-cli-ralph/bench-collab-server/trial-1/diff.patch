documents(id) ON DELETE CASCADE\n47:     );\n48:   `);\n49: \n50:   const insertVersion = (docId: number, version: number, content: string) => {\n51:     const stmt = db.prepare('INSERT INTO versions (doc_id, version, content) VALUES (?, ?, ?)');\n52:     stmt.run(docId, version, content);\n53:   };\n54: \n55:   // ---- REST API -----------------------------------------------------\n56: \n57:   // Create document\n58:   app.post('/documents', (req: Request, res: Response) => {\n59:     const { title, content } = req.body;\n60:     if (typeof title !== 'string' || typeof content !== 'string') {\n61:       return res.status(400).json({ error: 'Invalid title or content' });\n62:     }\n63:     const info = db.prepare('INSERT INTO documents (title, content) VALUES (?, ?)').run(title, content);\n64:     const docId = Number(info.lastInsertRowid);\n65:     insertVersion(docId, 1, content);\n66:     res.status(201).json({ id: docId, title, content, version: 1 });\n67:   });\n68: \n69:   // List documents metadata\n70:   app.get('/documents', (req: Request, res: Response) => {\n71:     const rows = db.prepare('SELECT id, title FROM documents').all();\n72:     res.json(rows);\n73:   });\n74: \n75:   // Get document\n76:   app.get('/documents/:id', (req: Request, res: Response) => {\n77:     const docId = Number(req.params.id);\n78:     const row: any = db.prepare('SELECT id, title, content FROM documents WHERE id = ?').get(docId);\n79:     if (!row) return res.status(404).json({ error: 'Document not found' });\n80:     const versionRow: any = db\n81:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n82:       .get(docId);\n83:     const version = versionRow?.version ?? 1;\n84:     res.json({ id: row.id, title: row.title, content: row.content, version });\n85:   });\n86: \n87:   // Update document (replace content)\n88:   app.put('/documents/:id', (req: Request, res: Response) => {\n89:     const docId = Number(req.params.id);\n90:     const { title, content } = req.body;\n91:     if (typeof title !== 'string' || typeof content !== 'string') {\n92:       return res.status(400).json({ error: 'Invalid title or content' });\n93:     }\n94:     const info = db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?').run(title, content, docId);\n95:     if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n96:     const versionRow: any = db\n97:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n98:       .get(docId);\n99:     const nextVersion = (versionRow?.version ?? 0) + 1;\n100:     insertVersion(docId, nextVersion, content);\n101:     res.json({ id: docId, title, content, version: nextVersion });\n102:   });\n103: \n104:   // Delete document\n105:   app.delete('/documents/:id', (req: Request, res: Response) => {\n106:     const docId = Number(req.params.id);\n107:     const info = db.prepare('DELETE FROM documents WHERE id = ?').run(docId);\n108:     if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n109:     res.status(204).send();\n110:   });\n111: \n112:   // List version history\n113:   app.get('/documents/:id/versions', (req: Request, res: Response) => {\n114:     const docId = Number(req.params.id);\n115:     const rows = db.prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version ASC').all(docId);\n116:     res.json(rows);\n117:   });\n118: \n119:   // Get specific version content\n120:   app.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n121:     const docId = Number(req.params.id);\n122:     const version = Number(req.params.version);\n123:     const row: any = db.prepare('SELECT content FROM versions WHERE doc_id = ? AND version = ?').get(docId, version);\n124:     if (!row) return res.status(404).json({ error: 'Version not found' });\n125:     res.json({ version, content: row.content });\n126:   });\n127: \n128:   /