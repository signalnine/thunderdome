    }\n176:     const versionRow: any = db\n177:       .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n178:       .get(docId);\n179:     let currentVersion = versionRow?.version ?? 1;\n180:     setTimeout(() => ws.send(JSON.stringify({ type: 'sync', content: docRow.content, version: currentVersion })), 0);\n181: \n182:     ws.on('message', (data) => {\n183:       let msg: any;\n184:       try { msg = JSON.parse(data.toString()); } catch { ws.send(JSON.stringify({ error: 'Invalid JSON' })); return; }\n185:       if (msg.type !== 'op' || typeof msg.version !== 'number' || !msg.op) {\n186:         ws.send(JSON.stringify({ error: 'Invalid operation format' }));\n187:         return;\n188:       }\n189:       if (msg.version !== currentVersion) {\n190:         ws.send(JSON.stringify({ error: 'Version mismatch', serverVersion: currentVersion }));\n191:         return;\n192:       }\n193:       const op: Operation = msg.op;\n194:       const newContent = applyOperation(docRow.content, op);\n195:       db.prepare('UPDATE documents SET content = ? WHERE id = ?').run(newContent, docId);\n196:       const newVersion = currentVersion + 1;\n197:       insertVersion(docId, newVersion, newContent);\n198:       docRow.content = newContent;\n199:       currentVersion = newVersion;\n200:       const broadcast = JSON.stringify({ type: 'op', op, version: newVersion });\n201:       for (const client of docClients.get(docId)!) {\n202:         if (client !== ws && client.readyState === WebSocket.OPEN) {\n203:           client.send(broadcast);\n204:         }\n205:       }\n206:     });\n207: \n208:     ws.on('close', () => {\n209:       const set = docClients.get(docId);\n210:       if (set) {\n211:         set.delete(ws);\n212:         if (set.size === 0) docClients.delete(docId);\n213:       }\n214:     });\n215:   });\n216: \n217:   // ---- Lifecycle ------------------------------------------------------\n218: \n219:   const start = async (port 