onse) => {\n    const docId = Number(req.params.id);\n    const row: any = db.prepare('SELECT id, title, content FROM documents WHERE id = ?').get(docId);\n    if (!row) return res.status(404).json({ error: 'Document not found' });\n    const versionRow: any = db\n      .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n      .get(docId);\n    const version = versionRow?.version ?? 1;\n    res.json({ id: row.id, title: row.title, content: row.content, version });\n  });\n\n  // Update document (replace whole content)\n  app.put('/documents/:id', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const { title, content } = req.body;\n    if (typeof title !== 'string' || typeof content !== 'string') {\n      return res.status(400).json({ error: 'Invalid title or content' });\n    }\n    const update = db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?');\n    const info = update.run(title, content, docId);\n    if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n    const versionRow: any = db\n      .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n      .get(docId);\n    const nextVersion = (versionRow?.version ?? 0) + 1;\n    insertVersion(docId, nextVersion, content);\n    res.json({ id: docId, title, content, version: nextVersion });\n  });\n\n  // Delete document\n  app.delete('/documents/:id', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const del = db.prepare('DELETE FROM documents WHERE id = ?');\n    const info = del.run(docId);\n    if (info.changes === 0) return res.status(404).json({ error: 'Document not found' });\n    res.status(204).send();\n  });\n\n  // List version history\n  app.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const rows = db\n      .prepare('SELECT version, datetime(timestamp, \"unixepoch\") as timestamp FROM versions WHERE doc_id = ? ORDER BY version ASC')\n      .all(docId);\n    res.json(rows);\n  });\n\n  // Get specific version content\n  app.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n    const docId = Number(req.params.id);\n    const version = Number(req.params.version);\n    const row: any = db.prepare('SELECT content FROM versions WHERE doc_id = ? AND version = ?').get(docId, version);\n    if (!row) return res.status(404).json({ error: 'Version not found' });\n    res.json({ version, content: row.content });\n  });\n\n  // ---- WebSocket collaboration ---------------------------------------\n\n  const docClients = new Map<number, Set<WebSocket>>();\n\n  const applyOperation = (text: string, op: Operation): string => {\n    if (op.type === 'insert') {\n      return text.slice(0, op.pos) + op.text + text.slice(op.pos);\n    }\n    // delete\n    return text.slice(0, op.pos) + text.slice(op.pos + op.length);\n  };\n\n  const httpServer = createServer(app);\n  const wss = new WebSocketServer({ server: httpServer });\n\n  wss.on('connection', (ws: WebSocket, request) => {\n    // Expect URL like /ws/<docId>\n    const parts = request.url?.split('/') ?? [];\n    const docId = Number(parts[parts.length - 1]);\n    if (!docId || Number.isNaN(docId)) {\n      ws.send(JSON.stringify({ error: 'Invalid document id in URL' }));\n      ws.close();\n      return;\n    }\n    if (!docClients.has(docId)) docClients.set(docId, new Set());\n    docClients.get(docId)!.add(ws);\n\n    // Send current state\n    const docRow: any = db.prepare('SELECT content FROM documents WHERE id = ?').get(docId);\n    if (!docRow) {\n      ws.send(JSON.stringify({ error: 'Document not found' }));\n      ws.close();\n      return;\n    }\n    const versionRow: any = db\n      .prepare('SELECT version FROM versions WHERE doc_id = ? ORDER BY version DESC LIMIT 1')\n      .get(docId);\n    const currentVersion = versionRow?.version 