+{"type":"tool_use","timestamp":1772769123140,"sessionID":"ses_33eba47e8fferfmn4gcfgzNSAO","part":{"id":"prt_cc1461a7a001MHyDoyLtWZnUP5","sessionID":"ses_33eba47e8fferfmn4gcfgzNSAO","messageID":"msg_cc1461783001aIFGg9GI3N1HSx","type":"tool","callID":"e7a9f8a51","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/plugins/syntax-highlight.ts","content":"// src/plugins/syntax-highlight.ts\nimport { Plugin, ContentFile, BuildContext } from '../core/types.js';\n\n/**\n * Adds language classes and data-language attributes to code blocks.\n */\nexport function createSyntaxHighlightPlugin(): Plugin {\n  return {\n    name: 'syntax-highlight',\n    version: '1.0.0',\n    dependencies: [],\n    hooks: {\n      async transformContent(file: ContentFile, _ctx: BuildContext): Promise<ContentFile> {\n        // Regex to match <pre><code class=\"language-xyz\">...</code></pre>\n        const regex = /<pre><code\\s+class=[\"']([^\"']*)[\"']>([\\s\\S]*?)<\\/code><\\/pre>/g;\n        const newContent = file.content.replace(regex, (match, classes, inner) => {\n          const languageMatch = classes.match(/language-([\\w-]+)/);\n          if (!languageMatch) {\n            // No language class, return unchanged\n            return match;\n          }\n          const lang = languageMatch[1];\n          // Add highlighted class and data-language attribute to pre tag\n          const preTag = `<pre data-language=\"${lang}\">`;\n          const codeTag = `<code class=\"${classes} highlighted\">`;\n          return `${preTag}${codeTag}${inner}</code></pre>`;\n        });\n        return { ...file, content: newContent };\n      },\n    },\n  };\n}\n"},"output":"Wrote file successfully.","title":"src/plugins/syntax-highlight.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/plugins/syntax-highlight.ts","exists":false,"truncated":false},"time":{"start":1772769123133,"end":1772769123139}}}}
