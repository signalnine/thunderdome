e)} RSS Feed</description>\n    ${items}\n  </channel>\n</rss>`;\n        ctx.output.set('feed.xml', rss);\n      },\n    },\n  };\n}\n"},"output":"Wrote file successfully.","title":"src/plugins/rss-feed.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/plugins/rss-feed.ts","exists":false,"truncated":false},"time":{"start":1772769126057,"end":1772769126067}}}}
