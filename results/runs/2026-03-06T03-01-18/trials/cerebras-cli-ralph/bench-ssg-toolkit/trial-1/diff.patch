+// src/plugins/rss-feed.ts
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+
+/**
+ * Generates an RSS 2.0 feed after the build.
+ * Depends on markdown-ext (content already HTML) and taxonomy (tags available).
+ */
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const siteTitle = ctx.config.title;
+        const baseUrl = ctx.config.baseUrl.replace(/\/+$/, ''); // trim trailing slash
+        const items = ctx.files
+          .slice()
+          .sort((a, b) => {
+            const da = a.date ? new Date(a.date).getTime() : 0;
+            const db = b.date ? new Date(b.date).getTime() : 0;
+            return db - da;
+          })
+          .map(file => {
+            const link = `${baseUrl}/${file.slug}.html`;
+            const pubDate = file.date ? new Date(file.date).toUTCString() : undefined;
+            const categories = file.tags?.map(t => `<category>${t}</category>`).join('') ?? '';
+            const description = `<![CDATA[${file.content}]]>`;
+            return `
+      <item>
+        <title>${file.title}</title>
+        <link>${link}</link>
+        ${pubDate ? `<pubDate>${pubDate}</pubDate>` : ''}
+        ${categories}
+        <description>${description}</description>
+      </item>`;
+          })
+          .join('');
+        const rss = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${siteTitle}</title>
+    <link>${baseUrl}</link>
+    <description>${siteTitle} RSS Feed</description>
+    ${items}
+  </channel>
+</rss>`;
+        ctx.output.set('feed.xml', rss);
+      },
+    },
+  };
+}
