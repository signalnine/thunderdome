new file mode 100644
index 0000000..78c05e3
--- /dev/null
+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,35 @@
+// src/plugins/asset-pipeline.ts
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import path from 'path';
+
+/**
+ * Asset pipeline plugin rewrites relative URLs to /assets/ and generates a manifest.
+ */
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: ContentFile, ctx: BuildContext): Promise<ContentFile> {
+        const assetRegex = /(src|href)=["']([^"']+)["']/g;
+        let newContent = file.content;
+        const manifest = (ctx.data.get('asset-manifest') as { assets: string[] }) || { assets: [] };
+        newContent = newContent.replace(assetRegex, (match, attr, url) => {
+          if (url.startsWith('http') || url.startsWith('/assets/')) {
+            return `${attr}="${url}"`;
+          }
+          // Normalize relative path
+          const assetName = path.basename(url);
+          if (!manifest.assets.includes(assetName)) {
+            manifest.assets.push(assetName);
+          }
+          const newUrl = `/assets/${assetName}`;
+          return `${attr}="${newUrl}"`;
+        });
+        ctx.data.set('asset-manifest', manifest);
+        return { ...file, content: newContent };
+      },
+    },
+  };
+}
