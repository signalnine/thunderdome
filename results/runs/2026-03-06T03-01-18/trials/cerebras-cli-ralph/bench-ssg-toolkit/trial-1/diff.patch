+// src/plugins/taxonomy.ts
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+/**
+ * Builds tag/category indices and generates tag pages.
+ */
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async beforeBuild(ctx: BuildContext): Promise<void> {
+        const tagMap = new Map<string, ContentFile[]>();
+        for (const file of ctx.files) {
+          if (file.tags && file.tags.length > 0) {
+            for (let tag of file.tags) {
+              const normalized = String(tag).toLowerCase();
+              const list = tagMap.get(normalized) || [];
+              list.push(file);
+              tagMap.set(normalized, list);
+            }
+          }
+        }
+        ctx.data.set('taxonomy-tags', tagMap);
+        // Generate tag pages after build (use afterBuild hook via afterBuild? we'll add afterBuild here)
+      },
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+        if (!tagMap) return;
+        for (const [tag, files] of tagMap.entries()) {
+          const lines = files.map(f => `<li><a href="${f.slug}.html">${f.title}</a></li>`).join('');
+          const html = `<!DOCTYPE html><html><head><title>Tag: ${tag}</title></head><body><h1>Tag: ${tag}</h1><ul>${lines}</ul></body></html>`;
+          ctx.output.set(`tags/${tag}.html`, html);
+        }
+      },
+    },
+  };
+}
