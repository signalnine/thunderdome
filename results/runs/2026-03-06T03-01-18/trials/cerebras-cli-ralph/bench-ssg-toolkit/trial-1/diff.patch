+// src/plugins/search-index.ts
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import { stripHtml } from 'string-strip-html';
+
+/**
+ * Generates a searchable JSON index after build.
+ * Depends on markdown-ext (HTML content) and syntax-highlight (code classes).
+ */
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const index = ctx.files.map(file => {
+          const plain = stripHtml(file.content).result.trim();
+          const entry: { slug: string; title: string; content: string; tags?: string[] } = {
+            slug: file.slug,
+            title: file.title,
+            content: plain,
+          };
+          if (file.tags) entry.tags = file.tags;
+          return entry;
+        });
+        ctx.output.set('search-index.json', JSON.stringify(index));
+      },
+    },
+  };
+}
