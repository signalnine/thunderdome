+// src/plugins/sitemap.ts
+import { Plugin, BuildContext, ContentFile } from '../core/types.js';
+
+/**
+ * Generates sitemap.xml including page URLs, tag pages, and RSS feed.
+ * Depends on taxonomy and rss-feed.
+ */
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const base = ctx.config.baseUrl.replace(/\/+$/, '');
+        const urls: string[] = [];
+        // content pages
+        for (const [path] of ctx.output) {
+          if (path.endsWith('.html')) {
+            urls.push(`${base}/${path}`);
+          }
+        }
+        // tag pages (assume they are stored in output as tags/?.html)
+        // already added above because they are .html
+        // rss feed
+        if (ctx.output.has('feed.xml')) {
+          urls.push(`${base}/feed.xml`);
+        }
+        const urlEntries = urls
+          .map(u => `  <url><loc>${u}</loc></url>`)
+          .join('\n');
+        const sitemap = `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n${urlEntries}\n</urlset>`;
+        ctx.output.set('sitemap.xml', sitemap);
+      },
+    },
+  };
+}
