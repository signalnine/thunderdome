+// src/plugins/dev-server.ts
+import { Plugin, BuildContext } from '../core/types.js';
+
+/**
+ * Generates dev server configuration after build.
+ * Depends on asset-pipeline and search-index.
+ */
+export interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      async afterBuild(ctx: BuildContext): Promise<void> {
+        const config: DevServerConfig = {
+          port: 3000,
+          routes: [],
+          assetPaths: [],
+          searchIndexPath: '/search-index.json',
+        };
+        // static content routes (all .html files)
+        for (const [path] of ctx.output) {
+          if (path.endsWith('.html')) {
+            config.routes.push({ path: `/${path}`, handler: 'static' });
+          }
+        }
+        // asset routes from manifest
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (manifest && manifest.assets.length) {
+          config.assetPaths = manifest.assets.slice();          for (const asset of manifest.assets) {
+            config.routes.push({ path: `/assets/${asset}`, handler: 'asset' });
+          }
+        }
+        // search index route
+        if (ctx.output.has('search-index.json')) {
+          config.routes.push({ path: '/search-index.json', handler: 'static' });
+        }
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
