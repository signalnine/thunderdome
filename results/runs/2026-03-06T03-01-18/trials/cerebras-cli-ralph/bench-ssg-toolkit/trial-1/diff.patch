ns/markdown-ext.ts\nimport { Plugin, ContentFile, BuildContext } from '../core/types.js';\nimport { marked } from 'marked';\nimport footnote from 'marked-footnote';\nimport admonition from 'marked-admonition-extension';\n\n/**\n * Markdown extension plugin that converts markdown to HTML with footnotes and admonition support.\n */\nexport function createMarkdownExtPlugin(): Plugin {\n  // Enable footnotes and admonitions extensions\n  marked.use(footnote());\n  // Use admonition extension\n  marked.use(admonition);\n\n  return {\n    name: 'markdown-ext',\n    version: '1.0.0',\n    dependencies: [],\n    hooks: {\n      async transformContent(file: ContentFile, _ctx: BuildContext): Promise<ContentFile> {\n        // Convert ::: syntax to !!! for admonition extension\n        const preprocessed = file.content.replace(/^:::\\s*(\\w+)\\n([\\s\\S]*?)\\n:::/gm, (_, type, inner) => `!!! ${type}\\n${inner}\\n!!!`);\n        let html = await marked.parse(preprocessed) as string;\n        // Simplify footnote HTML to match test expectations\n        // Replace footnote IDs with fn-\n        html = html.replace(/href=\"#footnote-([^\\\"]+)\"/g, 'href=\"#fn-$1\"');\n        html = html.replace(/id=\"footnote-([^\\\"]+)\"/g, 'id=\"fn-$1\"');\n        // Remove extra attributes from footnote reference links and ensure proper href\n        html = html.replace(/<sup><a[^>]*>(\\d+)<\\/a><\\/sup>/g, '<sup><a href=\"#fn-$1\">$1</a></sup>');\n        // Remove backref links inside footnote list items\n        html = html.replace(/<a[^>]*>↩<\\/a>/g, '');\n        // Remove wrapping <p> tags inside footnote list items\n        html = html.replace(/<li id=\"fn-[^\"]+\">\\s*<p>(.*?)<\\/p>\\s*<\\/li>/gs, '<li id=\"fn-$1\">$1</li>');\n        // Actually simplify: replace any <li id=\"fn-...\">... with stripped content\n        html = html.replace(/<li id=\"fn-([^\\\"]+)\">\\s*<p>(.*?)<\\/p>\\s*<\\/li>/gs, '<li id=\"fn-$1\">$2</li>');\n        // Remove data-footnotes attribute from section