{\n    const tracker1 = new TimeTracker({ filePath: tempFile });\n    await tracker1.start('Persisted Task');\n    await tracker1.stop();\n    const entries1 = tracker1.getEntries();\n    expect(entries1).toHaveLength(1);\n    // Create a new instance pointing at same file.\n    const tracker2 = new TimeTracker({ filePath: tempFile });\n    const entries2 = tracker2.getEntries();\n    expect(entries2).toHaveLength(1);\n    expect(entries2[0].task).toBe('Persisted Task');\n  });\n\n  it('filters entries by date range', async () => {\n    const tracker = new TimeTracker({ filePath: tempFile });\n    const now = new Date();\n    // Create entry 1\n    await tracker.start('Old Task');\n    await tracker.stop();\n    // Simulate later entry by waiting briefly.\n    await new Promise(r => setTimeout(r, 10));\n    await tracker.start('New Task');\n    await tracker.stop();\n    const entries = tracker.getEntries({ from: new Date(now.getTime() + 5) });\n    // Only the second entry should be after the 'from' date.\n    expect(entries.map(e => e.task)).toContain('New Task');\n    expect(entries.map(e => e.task)).not.toContain('Old Task');\n  });\n\n  it('provides summary including running timer', async () => {\n    const tracker = new TimeTracker({ filePath: tempFile });\n    await tracker.start('Running Task');\n    // Wait a bit to accumulate time.\n    await new Promise(r => setTimeout(r, 20));\n    const summary = tracker.getSummary();\n    expect(summary['Running Task']).toBeGreaterThan(0);\n    // Stop and check that duration remains the same or higher.\n    await tracker.stop();\n    const summaryAfter = tracker.getSummary();\n    expect(summaryAfter['Running Task']).toBeGreaterThanOrEqual(summary['Running Task']);\n  });\n\n  it('handles Unicode task names', async () => {\n    const tracker = new TimeTracker({ filePath: tempFile });\n    const name = '🚀 🌟 Unicode 😊';\n    await tracker.start(name);\n    await tracker.stop();\n    const entries = tracker.getEntries();