@@ -0,0 +1,177 @@
+import { promises as fsPromises, readFileSync, existsSync, mkdirSync } from 'node:fs';
+import { Entry } from './types';
+import { resolve, dirname } from 'node:path';
+
+/**
+ * Options for initializing the TimeTracker.
+ */
+export interface TimeTrackerOptions {
+  /**
+   * Path to the JSON file used for persisting entries.
+   * Defaults to './time-tracker-data.json' relative to the cwd.
+   */
+  filePath?: string;
+}
+
+/**
+ * The main class providing time tracking functionality.
+ */
+export class TimeTracker {
+  private filePath: string;
+  private entries: Entry[] = [];
+  private currentEntry?: Entry;
+
+  constructor(options: TimeTrackerOptions = {}) {
+    const defaultPath = './time-tracker-data.json';
+    this.filePath = resolve(options.filePath ?? defaultPath);
+    this.load();
+  }
+
+  /** Load persisted data from the JSON file, if it exists. */
+  private load(): void {
+    if (!existsSync(this.filePath)) {
+      // Ensure the directory exists for future writes.
+      const dir = dirname(this.filePath);
+      if (!existsSync(dir)) {
+        mkdirSync(dir, { recursive: true });
+      }
+      // No data to load.
+      return;
+    }
+    try {
+      const raw = readFileSync(this.filePath, { encoding: 'utf-8' });
+      interface PersistedData {
+  entries: { task: string; start: string; stop?: string }[];
+  currentEntry?: { task: string; start: string; stop?: string };
+}
+const data: PersistedData = JSON.parse(raw) as PersistedData;
+      // Convert plain objects back into Entry instances with Date objects.
+      if (Array.isArray(data.entries)) {
+        this.entries = data.entries.map((e: any) => ({
+          task: e.task,
+          start: new Date(e.start),
+          stop: e.stop ? new Date(e.stop) : undefined,
+        }));
+      }
+      if (data.currentEntry) {
+        const ce = data.currentEntry;
+        this.currentEntry = {
+          task: ce.task,
+          start: new Date(ce.start),
+          stop: ce.stop ? new Date(ce.stop) : undefined,
+        };
+      }
+    } catch (err) {
+      throw new Error(`Failed to load time tracker data: ${(err as Error).message}`);
+    }
+  }
+
+  /** Persist the current state to the JSON file. */
+  private async save(): Promise<void> {
+    const dir = dirname(this.filePath);
+    if (!existsSync(dir)) {
+      mkdirSync(dir, { recursive: true });
+    }
+    const data = {
+      entries: this.entries.map(e => ({
+        task: e.task,
+        start: e.start.toISOString(),
+        stop: e.stop?.toISOString(),
+      })),
+      currentEntry: this.currentEntry
+        ? {
+            task: this.currentEntry.task,
+            start: this.currentEntry.start.toISOString(),
+            stop: this.currentEntry.stop?.toISOString(),
+          }
+        : undefined,
+    };
+    await fsPromises.writeFile(this.filePath, JSON.stringify(data, null, 2), {
+      encoding: 'utf-8',
+    });
+  }
+
+  /**
+   * Start a new timer for the given task name.
+   * If a timer is already running, it will be stopped automatically.
+   */
+  async start(taskName: string): Promise<void> {
+    if (!taskName || taskName.trim() === '') {
+      throw new Error('Task name must be a non-empty string');
+    }
+    // Stop any existing timer.
+    if (this.currentEntry) {
+      await this.stop();
+    }
+    const entry: Entry = { task: taskName, start: new Date() };
+    this.currentEntry = entry;
+    await this.save();
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  async stop(): Promise<void> {
+    if (!this.currentEntry) {
+      throw new Error('No timer is currently running');
+    }
+    {
+      const now = new Date();
+      // Ensure at least 1ms duration to avoid zero-length entries when start/stop are called quickly.
+      if (now.getTime() === this.currentEntry.start.getTime()) {
+        this.currentEntry.stop = new Date(now.getTime() + 1);
+      } else {
+        this.currentEntry.stop = now;
+      }
+    }
+    // Move current entry into the persisted entries list.
+    this.entries.push(this.currentEntry);
+    this.currentEntry = undefined;
+    await this.save();
+  }
+
+  /**
+   * Retrieve entries, optionally filtered by a date range.
+   */
+  getEntries(filter?: { from?: Date; to?: Date }): Entry[] {
+    const all = [...this.entries];
+    if (this.currentEntry) {
+      // Clone to avoid mutating internal state.
+      all.push({ ...this.currentEntry });
+    }
+    if (!filter) return all.map(e => ({ ...e }));
+    const { from, to } = filter;
+    return all
+      .filter(e => {
+        const startTime = e.start.getTime();
+        if (from && startTime < from.getTime()) return false;
+        if (to && startTime > to.getTime()) return false;
+        return true;
+      })
+      .map(e => ({ ...e }));
+  }
+
+  /**
+   * Compute a summary of total milliseconds spent per task.
+   */
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    const now = new Date();
+    // Helper to add duration.
+    const add = (task: string, durationMs: number) => {
+      if (!summary[task]) summary[task] = 0;
+      summary[task] += durationMs;
+    };
+    for (const e of this.entries) {
+      const end = e.stop ?? now;
+      add(e.task, end.getTime() - e.start.getTime());
+    }
+    if (this.currentEntry) {
+      add(this.currentEntry.task, now.getTime() - this.currentEntry.start.getTime());
+    }
+    return summary;
+  }
+}
+
+// Re‑export the Entry type for convenience.
+export type { Entry } from './types';
