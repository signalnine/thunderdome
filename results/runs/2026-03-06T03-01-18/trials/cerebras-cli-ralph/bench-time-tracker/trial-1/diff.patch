+/**
+ * Represents a single time tracking entry.
+ */
+export interface Entry {
+  /**
+   * The name of the task being tracked.
+   */
+  task: string;
+
+  /**
+   * The timestamp when the task was started.
+   */
+  start: Date;
+
+  /**
+   * The timestamp when the task was stopped. Undefined if the task is still running.
+   */
+  stop?: Date;
+}
