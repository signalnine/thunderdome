     id: v.id,\n      timestamp: v.timestamp,\n      content: v.content === null ? null : deepClone(v.content as any),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const docState = this.resolveDocumentState(id);\n    if (!docState) {\n      throw new Error(`Document '${id}' does not exist on branch '${this.currentBranch}'`);\n    }\n    const version = docState.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version '${versionId}' not found for document '${id}'`);\n    }\n    if (version.content === null) {\n      throw new Error(`Version '${versionId}' represents a deletion`);\n    }\n    return deepClone(version.content as any);\n  }\n\n  /** Branching **/\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch '${name}' already exists`);\n    }\n    const source = fromBranch ?? this.currentBranch;\n    const sourceState = this.getBranchState(source);\n    const newDocs = new Map<string, DocumentState>();\n    for (const [id, state] of sourceState.documents.entries()) {\n      newDocs.set(id, {\n        current: state.current === null ? null : deepClone(state.current),\n        versions: state.versions.map(v => ({\n          id: v.id,\n          timestamp: v.timestamp,\n          content: v.content === null ? null : deepClone(v.content as any),\n        })),\n      });\n    }\n    this.branches.set(name, { documents: newDocs, parent: source });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch '${name}' does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  /** Merging **/\n  merge(sourceBranch: string): MergeResult {\n    if (!this.branches.has(sourceBranch)) {\n      throw new Error(`Source branch '${sourceB