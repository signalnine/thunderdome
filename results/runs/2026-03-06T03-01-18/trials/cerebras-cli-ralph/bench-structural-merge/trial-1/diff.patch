;\n}\n\n// Simple deep equality check for JSON‑compatible values\nfunction isEqual(a: any, b: any): boolean {\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n// Retrieve value at dot‑separated path (e.g. \"a.b.c\"). Returns undefined if any segment missing.\nfunction getValueAtPath(obj: any, path: string): any {\n  if (obj === undefined || obj === null) return undefined;\n  const parts = path.split('.');\n  let cur = obj;\n  for (const p of parts) {\n    if (cur == null) return undefined;\n    cur = cur[p];\n  }\n  return cur;\n}\n\n// Set value at dot‑separated path, creating intermediate objects as needed.\nfunction setValueAtPath(obj: any, path: string, value: any): void {\n  const parts = path.split('.');\n  let cur = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const p = parts[i];\n    if (cur[p] == null || typeof cur[p] !== 'object') {\n      cur[p] = {};\n    }\n    cur = cur[p];\n  }\n  cur[parts[parts.length - 1]] = value;\n}\n\n// Generate all leaf paths of a JSON object (arrays are treated as leaf values).\nfunction getAllPaths(obj: any, prefix = ''): string[] {\n  if (obj === null || typeof obj !== 'object' || Array.isArray(obj)) {\n    return [prefix];\n  }\n  const paths: string[] = [];\n  for (const key of Object.keys(obj)) {\n    const newPrefix = prefix ? `${prefix}.${key}` : key;\n    paths.push(...getAllPaths(obj[key], newPrefix));\n  }\n  return paths;\n}\n\n/** Three‑way merge implementation **/\nfunction threeWayMerge(\n  base: any,\n  ours: any,\n  theirs: any,\n  documentId: string,\n): { merged: any; conflicts: Conflict[] } {\n  // Normalise undefined to null for easier comparison\n  const b = base === undefined ? null : base;\n  const o = ours === undefined ? null : ours;\n  const t = theirs === undefined ? null : theirs;\n\n  // If all three are null/undefined, nothing to merge\n  if (b === null && o === null && t === null) {\n    return { merged: null, conflicts: [] };\n  }\n\n  // Creation case – base does not exist\n  if (b === null) {\n    if (o !== null && t !== null && !isEqual(o, t)) {\n      const conflict: Conflict = { documentId, path: '', base: null, ours: deepClone(o), theirs: deepClone(t) };\n      return { merged: deepClone(o), conflicts: [conflict] };\n    }\n    return { merged: o !== null ? deepClone(o) : deepClone(t), conflicts: [] };\n  }\n\n  // Deletion cases\n  if (o === null && isEqual(b, t)) {\n    return { merged: null, conflicts: [] };\n  }\n  if (t === null && isEqual(b, o)) {\n    return { merged: null, conflicts: [] };\n  }\n  if (o === null && t === null) {\n    return { merged: null, conflicts: [] };\n  }\n\n  // Normal merge when base exists and no simple deletion applies\n  const allPathsSet = new Set<string>([\n    ...getAllPaths(b),\n    ...getAllPaths(o),\n    ...getAllPaths(t),\n  ]);\n  const allPaths = Array.from(allPathsSet);\n\n  const merged = deepClone(b);\n  const conflicts: Conflict[] = [];\n\n  for (const path of allPaths) {\n    const baseVal = getValueAtPath(b, path);\n    const oursVal = getValueAtPath(o, path);\n    const theirsVal = getValueAtPath(t, path);\n\n    const baseEqOurs = isEqual(baseVal, oursVal);\n    const baseEqTheirs = isEqual(baseVal, theirsVal);\n    const oursEqTheirs = isEqual(oursVal, theirsVal);\n\n    if (baseEqOurs && baseEqTheirs) {\n      continue; // unchanged on both sides\n    }\n    if (!baseEqOurs && baseEqTheirs) {\n      setValueAtPath(merged, path, deepClone(oursVal));\n      continue;\n    }\n    if (baseEqOurs && !baseEqTheirs) {\n      setValueAtPath(merged, path, deepClone(theirsVal));\n      continue;\n    }\n    // Both changed\n    if (oursEqTheirs) {\n      setValueAtPath(merged, path, deepClone(oursVal));\n    } else {\n      conflicts.push({ documentId, path, base: deepClone(baseVal), ours: deepClone(oursVal), theirs: deepClone(theirsVal) });\n      // Keep ours in merged as per spec\n      setValueAtPath(merged, path, deepClone(oursVal));\n    }\n  }\n\n  // Remove undefined leaves (e.g., deletions)\n  function pruneUndefined(obj: any): void {\n    if (obj && typeof obj === 'object') {\n      for (const key of Object.keys(obj)) {\n        if (obj[key] === undefined) {\n          delete obj[key];\n        } else {\n          pruneUndefined(obj[key]);\n        }\n      }\n    }\n  }\n  pruneUndefined(merged);\n\n  return { merged, conflicts };\n}\n\n/** Internal Types **/\ninterface DocumentState {\n  current: any; // null indicates deleted\n  versions: Version[];\n}\n\ninterface BranchState {\n  documents: Map<string, DocumentState>;\n  parent?: string; // name of branch we were created from\n}\n\n/** DocumentStore Implementation **/\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n  private versionCounter: number = 0;\n\n  constructor() {\n    // Initialize main branch with empty state\n    this.branches.set('main', { documents: new Map() });\n  }\n\n  /** Helper to generate a unique version id */\n  private nextVersionId(): string {\n    this.versionCounter += 1;\n    return `v${this.versionCounter}`;\n  }\n\n  /** Retrieve the BranchState for the active branch */\n  private getBranchState(name: string): BranchState {\n    const state = this.branches.get(name);\n    if (!state) {\n      throw new Error(`Branch '${name}' does not exist`);\n    }\n    return state;\n  }\n\n  /** Document CRUD **/\n  create(id: string, content: object): void {\n    const branch = this.getBranchState(this.currentBranch);\n    if (branch.documents.has(id) && branch.documents.get(id)!.current !== null) {\n      throw new Error(`Document with id '${id}' already exists on branch '${this.currentBranch}'`);\n    }\n    const cloned = deepClone(content);\n    const version: Version = { id: this.nextVersionId(), timestamp: Date.now(), content: cloned };\n    branch.documents.set(id, { current: cloned, versions: [version] });\n  }\n\n  get(id: string): object {\n    const doc = this.resolveDocument(id);\n    if (doc === null) {\n      throw new Error(`Document '${id}' does not exist or has been deleted on branch '${this.currentBranch}'`);\n    }\n    return deepClone(doc);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getBranchState(this.currentBranch);\n    const state = branch.documents.get(id);\n    if (!state || state.current === null) {\n      throw new Error(`Cannot update non‑existent document '${id}' on branch '${this.currentBranch}'`);\n    }\n    const cloned = deepClone(content);\n    const version: Version = { id: this.nextVersionId(), timestamp: Date.now(), content: cloned };\n    state.current = cloned;\n    state.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getBranchState(this.currentBranch);\n    const state = branch.documents.get(id);\n    if (!state || state.current === null) {\n      throw new Error(`Cannot delete non‑existent document '${id}' on branch '${this.currentBranch}'`);\n    }\n    const version: Version = { id: this.nextVersionId(), timestamp: Date.now(), content: null };\n    state.current = null;\n    state.versions.push(version);\n  }\n\n  /** Version History **/\n  getHistory(id: string): Version[] {\n    const docState = this.resolveDocumentState(id);\n    if (!docState) {\n      throw new Error(`Document '${id}' does not exist on branch '${this.currentBranch}'`);\n    }\n    return docState.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: v.content === null ? null : deepClone(v.content as any),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const docState = this.resolveDocumentState(id);\n    if (!docState) {\n      throw new Error(`Document '${id}' does not exist on branch '${this.currentBranch}'`);\n    }\n    const version = docState.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version '${versionId}' not found for document '${id}'`);\n    }\n    if (version.content === null) {\n      throw new Error(`Version '${versionId}' represents a deletion`);\n    }\n    return deepClone(version.content as any);\n  }\n\n  /** Branching **/\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch '${name}' already exists`);\n    }\n    const source = fromBranch ?? this.currentBranch;\n    const sourceState = this.getBranchState(source);\n    const newDocs = new Map<string, DocumentState>();\n    for (const [id, state] of sourceState.documents.entries()) {\n      newDocs.set(id, {\n        current: state.current === null ? null : deepClone(state.current),\n        versions: state.versions.map(v => ({ id: v.id, timestamp: v.timestamp, content: v.content === null ? null : deepClone(v.content as any) })),\n      });\n    }\n    this.branches.set(name, { documents: newDocs, parent: source });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch '${name}' does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  /** Merging **/\n  merge(sourceBranch: string): MergeResult {\n    if (!this.branches.has(sourceBranch)) {\n      throw new Error(`Source branch '${sourceBranch}' does not exist`);\n    }\n    if (sourceBranch === this.currentBranch) {\n      return { merged: {}, conflicts: [], applied: true };\n    }\n    const ancestor = this.findCommonAncestor(this.currentBranch, sourceBranch);\n    const baseBranch = ancestor ?? 'main';\n    const baseState = this.getBranchState(baseBranch);\n    const oursState = this.getBranchState(this.currentBranch);\n    const theirsState = this.getBranchState(sourceBranch);\n\n    const allDocIds = new Set<string>([\n      ...Array.from(baseState.documents.keys()),\n      ...Array.from(oursState.documents.keys()),\n      ...Array.from(theirsState.documents.keys()),\n    ]);\n\n    const mergedResult: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n    let anyConflicts = false;\n\n    for (const docId of allDocIds) {\n      const baseDoc = baseState.documents.get(docId)?.current ?? null;\n      const oursDoc = oursState.documents.get(docId)?.current ?? null;\n      const theirsDoc = theirsState.documents.get(docId)?.current ?? null;\n\n      const { merged, conflicts: docConflicts } = threeWayMerge(baseDoc, oursDoc, theirsDoc, docId);\n      if (merged !== null) {\n        mergedResult[docId] = merged;\n      }\n      if (docConflicts.length > 0) {\n        anyConflicts = true;\n        conflicts.push(...docConflicts);\n      }\n    }\n\n    if (!anyConflicts) {\n      const currDocs = oursState.documents;\n      // Apply merged documents (non-deleted)\n      for (const [id, content] of Object.entries(mergedResult)) {\n        const state = currDocs.get(id);\n        if (state) {\n          state.current = deepClone(content);\n          const version: Version = { id: this.nextVersionId(), timestamp: Date.now(), content: deepClone(content) };\n          state.versions.push(version);\n        } else {\n          const version: Version = { id: this.nextVersionId(), timestamp: Date.now(), content: deepClone(content) };\n          currDocs.set(id, { current: deepClone(content), versions: [version] });\n        }\n      }\n      // Apply deletions where merged was null\n      for (const docId of Object.keys(mergedResult)) {\n        // No action needed, already handled above\n      }\n      // Handle deletions: documents that were present in base or ours but resulted in null after merge\n      const allDocIdsArray = Array.from(allDocIds);\n      for (const docId of allDocIdsArray) {\n        const merged = (mergedResult as any)[docId];\n        if (merged === undefined && !mergedResult.hasOwnProperty(docId)) {\n          // mergedResult does not have