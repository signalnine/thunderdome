ix ? `${prefix}.${key}` : key;\n    paths.push(...getAllPaths(obj[key], newPrefix));\n  }\n  return paths;\n}\n\n/** Three‑way merge implementation **/\nfunction threeWayMerge(\n  base: any,\n  ours: any,\n  theirs: any,\n  documentId: string,\n): { merged: any; conflicts: Conflict[] } {\n  // Normalise undefined to null for easier comparison\n  const b = base === undefined ? null : base;\n  const o = ours === undefined ? null : ours;\n  const t = theirs === undefined ? null : theirs;\n\n  // If all three are null/undefined, nothing to merge\n  if (b === null && o === null && t === null) {\n    return { merged: null, conflicts: [] };\n  }\n\n  // If base is null (document did not exist), treat the union of o and t as creations\n  if (b === null) {\n    if (o !== null && t !== null && !isEqual(o, t)) {\n      // both added different content -> conflict on root\n      const conflict: Conflict = {\n        documentId,\n        path: '',\n        base: null,\n        ours: deepClone(o),\n        theirs: deepClone(t),\n      };\n      return { merged: deepClone(o), conflicts: [conflict] };\n    }\n    // either only one side added or both added identical\n    return { merged: o !== null ? deepClone(o) : deepClone(t), conflicts: [] };\n  }\n\n  // Normal merge when base exists\n  const allPathsSet = new Set<string>([\n    ...getAllPaths(b),\n    ...getAllPaths(o),\n    ...getAllPaths(t),\n  ]);\n  const allPaths = Array.from(allPathsSet);\n\n  const merged = deepClone(b);\n  const conflicts: Conflict[] = [];\n\n  for (const path of allPaths) {\n    const baseVal = getValueAtPath(b, path);\n    const oursVal = getValueAtPath(o, path);\n    const theirsVal = getValueAtPath(t, path);\n\n    const baseEqOurs = isEqual(baseVal, oursVal);\n    const baseEqTheirs = isEqual(baseVal, theirsVal);\n    const oursEqTheirs = isEqual(oursVal, theirsVal);\n\n    if (baseEqOurs && baseEqTheirs) {\n      // unchanged on both sides – keep base (already in merged)\n      continue;\n    }\n 