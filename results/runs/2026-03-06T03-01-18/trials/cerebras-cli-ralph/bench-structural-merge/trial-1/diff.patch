alueAtPath(t, path);\n\n    const baseEqOurs = isEqual(baseVal, oursVal);\n    const baseEqTheirs = isEqual(baseVal, theirsVal);\n    const oursEqTheirs = isEqual(oursVal, theirsVal);\n\n    if (baseEqOurs && baseEqTheirs) {\n      continue; // unchanged on both sides\n    }\n    if (!baseEqOurs && baseEqTheirs) {\n      setValueAtPath(merged, path, deepClone(oursVal));\n      continue;\n    }\n    if (baseEqOurs && !baseEqTheirs) {\n      setValueAtPath(merged, path, deepClone(theirsVal));\n      continue;\n    }\n    // Both changed\n    if (oursEqTheirs) {\n      setValueAtPath(merged, path, deepClone(oursVal));\n    } else {\n      conflicts.push({ documentId, path, base: deepClone(baseVal), ours: deepClone(oursVal), theirs: deepClone(theirsVal) });\n      // Keep ours in merged as per spec\n      setValueAtPath(merged, path, deepClone(oursVal));\n    }\n  }\n\n  // Remove undefined leaves (e.g., deletions)\n  function pruneUndefined(obj: any): void {\n    if (obj && typeof obj === 'object') {\n      for (const key of Object.keys(obj)) {\n        if (obj[key] === undefined) {\n          delete obj[key];\n        } else {\n          pruneUndefined(obj[key]);\n        }\n      }\n    }\n  }\n  pruneUndefined(merged);\n\n  return { merged, conflicts };\n}\n\n/** Internal Types **/\ninterface DocumentState {\n  current: any; // null indicates deleted\n  versions: Version[];\n}\n\ninterface BranchState {\n  documents: Map<string, DocumentState>;\n  parent?: string; // name of branch we were created from\n}\n\n/** DocumentStore Implementation **/\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n  private versionCounter: number = 0;\n\n  constructor() {\n    // Initialize main branch with empty state\n    this.branches.set('main', { documents: new Map() });\n  }\n\n  /** Helper to generate a unique version id */\n  private nextVersionId(): string {\n    this.versionCounter += 1;\n    return `v${this.versionCounter}`;\n  }\n\n  /** Retrieve the BranchState for the active branch */\n  private getBranchState(name: string): BranchState {\n    const state = this.branches.get(name);\n    if (!state) {\n      throw new Error(`Branch '${name}' does not exist`);\n    }\n    return state;\n  }\n\n  /** Document CRUD **/\n  create(id: string, content: object): void {\n    const branch = this.getBranchState(this.currentBranch);\n    if (branch.documents.has(id) && branch.documents.get(id)!.current !== null) {\n      throw new Error(`Document with id '${id}' already exists on branch '${this.currentBranch}'`);\n    }\n    const cloned = deepClone(content);\n    const version: Version = { id: this.nextVersionId(), timestamp: Date.now(), content: cloned };\n    branch.documents.set(id, { current: cloned, versions: [version] });\n  }\n\n  get(id: string): object {\n    const doc = this.resolveDocument(id);\n    if (doc === null) {\n      throw new Error(`Document '${id}' does not exist or has been deleted on branch '${this.currentBranch}'`);\n    }\n    return deepClone(doc);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getBranchState(this.currentBranch);\n    const state = branch.documents.get(id);\n    if (!state || state.current === null) {\n      throw new Error(`Cannot update non‑existent document '${id}' on branch '${this.currentBranch}'`);\n    }\n    const cloned = deepClone(content);\n    const version: Version = { id: this.nextVersionId(), timestamp: Date.now(), content: cloned };\n    state.current = cloned;\n    state.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getBranchState(this.currentBranch);\n    const state = branch.documents.get(id);\n    if (!state || state.current === null) {\n      throw new Error(`Cannot delete non‑existent document '${id}' on branch '${this.currentBranch}'`);\n    }\n    const version: Version = { id: this.nextVersionId(), timestamp: Date.now(), content: null };\n    state.current = null;\n    state.versions.push(version);\n  }\n\n  /** Version History **/\n  getHistory(id: string): Version[] {\n    const docState = this.resolveDocumentState(id);\n    if (!docState) {\n      throw new Error(`Document '${id}' does not exist on branch '${this.currentBranch}'`);\n    }\n    return docState.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: v.content === null ? null : deepClone(v.content as any),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const docState = this.resolveDocumentState(id);\n    if (!docState) {\n      throw new Error(`Document '${id}' does not exist on branch '${this.currentBranch}'`);\n    }\n    const version = docState.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version '${versionId}' not found for document '${id}'`);\n    }\n    if (version.content === null) {\n      throw new Error(`Version '${versionId}' represents a deletion`);\n    }\n    return deepClone(version.content as any);\n  }\n\n  /** Branching **/\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch '${name}' already exists`);\n    }\n    const source = fromBranch ?? this.currentBranch;\n    const sourceState = this.getBranchState(source);\n    const newDocs = new Map<string, DocumentState>();\n    for (const [id, state] of sourceState.documents.entries()) {\n      newDocs.set(id, {\n        current: state.current === null ? null : deepClone(state.current),\n        versions: state.versions.map(v => ({ id: v.id, timestamp: v.timestamp, content: v.content === null ? null : deepClone(v.content as any) })),\n      });\n    }\n    this.branches.set(name, { documents: newDocs, parent: source });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch '${name}' does not exist`);\n    }\n    this.currentBr