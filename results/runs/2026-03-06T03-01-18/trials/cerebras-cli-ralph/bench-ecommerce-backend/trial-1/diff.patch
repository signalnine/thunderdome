ap(([productId, quantity]) => ({\n      productId,\n      quantity,\n    }));\n    return { id: cart.id, userId: cart.userId, items: itemsArray };\n  };\n\n  const clearCart = (cartId: string): void => {\n    const cart = carts.get(cartId);\n    if (!cart) return;\n    cart.items.clear();\n    emitCartUpdated(cartId);\n  };\n\n  const updateQuantity = (cartId: string, productId: string, quantity: number): void => {\n    const cart = carts.get(cartId);\n    if (!cart) return;\n    if (quantity <= 0) {\n      cart.items.delete(productId);\n    } else {\n      cart.items.set(productId, quantity);\n    }\n    emitCartUpdated(cartId);\n  };\n\n  return {\n    createCart,\n    addItem,\n    removeItem,\n    getCart,\n    clearCart,\n    updateQuantity,\n  };\n}\n"},"output":"Wrote file successfully.","title":"src/cart/index.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/cart/index.ts","exists":false,"truncated":false},"time":{"start":1772769323314,"end":1772769323327}}}}
