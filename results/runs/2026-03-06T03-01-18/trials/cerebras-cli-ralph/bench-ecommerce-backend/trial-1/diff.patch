+import { EventBus } from "../bus.js";
+import { InventoryService, Events, InventoryUpdatedEvent, LowStockAlertEvent } from "../types.js";
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  const stock = new Map<string, number>();
+  const lowStockThreshold = new Map<string, number>();
+
+  const emitInventoryUpdated = (productId: string, quantity: number) => {
+    const payload: InventoryUpdatedEvent = { productId, quantity };
+    bus.emit(Events.INVENTORY_UPDATED, payload);
+  };
+
+  const checkLowStock = (productId: string, quantity: number) => {
+    const threshold = lowStockThreshold.get(productId);
+    if (threshold !== undefined && quantity < threshold) {
+      const payload: LowStockAlertEvent = { productId, currentQuantity: quantity, threshold };
+      bus.emit(Events.LOW_STOCK_ALERT, payload);
+    }
+  };
+
+  const setStock = (productId: string, quantity: number): void => {
+    stock.set(productId, quantity);
+    emitInventoryUpdated(productId, quantity);
+    checkLowStock(productId, quantity);
+  };
+
+  const getStock = (productId: string): number => {
+    return stock.get(productId) ?? 0;
+  };
+
+  const reserve = (productId: string, quantity: number): boolean => {
+    const available = getStock(productId);
+    if (available < quantity) return false;
+    const newQty = available - quantity;
+    stock.set(productId, newQty);
+    emitInventoryUpdated(productId, newQty);
+    checkLowStock(productId, newQty);
+    return true;
+  };
+
+  const release = (productId: string, quantity: number): void => {
+    const current = getStock(productId);
+    const newQty = current + quantity;
+    stock.set(productId, newQty);
+    emitInventoryUpdated(productId, newQty);
+    // No low stock check on release (stock increased)
+  };
+
+  const setLowStockThreshold = (productId: string, threshold: number): void => {
+    lowStockThreshold.set(productId, threshold);
+    // Immediately evaluate current stock
+    const current = getStock(productId);
+    checkLowStock(productId, current);
+  };
+
+  return {
+    setStock,
+    getStock,
+    reserve,
+    release,
+    setLowStockThreshold,
+  };
+}
