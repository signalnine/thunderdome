@@ -0,0 +1,72 @@
+import { EventBus } from "../bus.js";
+import {
+  NotificationService,
+  Events,
+  NotificationSentEvent,
+  OrderStatusChangedEvent,
+  PaymentProcessedEvent,
+  OrderCreatedEvent,
+} from "../types.js";
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  // Map of userId to array of notifications
+  const notifications = new Map<
+    string,
+    Array<{ type: string; message: string; timestamp: number }>
+  >();
+
+  const addNotification = (userId: string, type: string, message: string) => {
+    const list = notifications.get(userId) ?? [];
+    const timestamp = Date.now();
+    list.push({ type, message, timestamp });
+    notifications.set(userId, list);
+    const payload: NotificationSentEvent = { userId, type, message };
+    bus.emit(Events.NOTIFICATION_SENT, payload);
+  };
+
+  // Subscribe placeholder – not used directly; could store subscription list if needed
+  const subscribe = (userId: string) => {
+    // Ensure a notifications array exists for the user
+    if (!notifications.has(userId)) {
+      notifications.set(userId, []);
+    }
+  };
+
+  const getNotifications = (userId: string) => {
+    return notifications.get(userId) ?? [];
+  };
+
+  // Map orderId to userId for notification purposes
+  const orderUserMap = new Map<string, string>();
+
+  // Listen to order creation to store mapping
+  const handleOrderCreated = (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderUserMap.set(event.orderId, event.userId);
+  };
+
+  // Listen to order status changes
+  const handleOrderStatus = (payload: unknown) => {
+    const event = payload as OrderStatusChangedEvent;
+    const userId = orderUserMap.get(event.orderId);
+    if (!userId) return;
+    const message = `Order ${event.orderId} status changed from ${event.previousStatus} to ${event.status}`;
+    addNotification(userId, 'order_status', message);
+  };
+
+  // Listen to payment processed events
+  const handlePayment = (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    const userId = orderUserMap.get(event.orderId);
+    if (!userId) return;
+    const message = `Payment for order ${event.orderId} ${event.status}`;
+    addNotification(userId, 'payment', message);
+  };
+
+  bus.on(Events.ORDER_CREATED, handleOrderCreated);
+  bus.on(Events.ORDER_STATUS_CHANGED, handleOrderStatus);
+  bus.on(Events.PAYMENT_PROCESSED, handlePayment);
+
+  // For simplicity, expose a method to manually trigger notifications from elsewhere.
+  return { subscribe, getNotifications };
+}
