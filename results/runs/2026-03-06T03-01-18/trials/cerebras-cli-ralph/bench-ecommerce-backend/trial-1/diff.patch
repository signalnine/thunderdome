licity, we cannot know product quantities here.\n    incrementEvent(Events.ORDER_CREATED);\n  };\n\n  const handleOrderStatus = (payload: unknown) => {\n    const ev = payload as OrderStatusChangedEvent;\n    incrementEvent(Events.ORDER_STATUS_CHANGED);\n  };\n\n  // Register listeners\n  bus.on(Events.PAYMENT_PROCESSED, handlePayment);\n  bus.on(Events.ORDER_CREATED, handleOrderCreated);\n  bus.on(Events.ORDER_STATUS_CHANGED, handleOrderStatus);\n  bus.on(Events.ANALYTICS_EVENT, handleAnalytics);\n\n  const getEventCount = (eventType: string) => {\n    return eventCounts.get(eventType) ?? 0;\n  };\n\n  const getRevenue = () => revenue;\n\n  const getConversionRate = () => {\n    if (carts.size === 0) return 0;\n    return orders.size / carts.size;\n  };\n\n  const getTopProducts = (limit: number) => {\n    const sorted = Array.from(productOrderCounts.entries())\n      .sort((a, b) => b[1] - a[1])\n      .slice(0, limit)\n      .map(([productId, count]) => ({ productId, count }));\n    return sorted;\n  };\n\n  return { getEventCount, getRevenue, getConversionRate, getTopProducts };\n}\n","after":"import { EventBus } from \"../bus.js\";\nimport {\n  AnalyticsService,\n  Events,\n  AnalyticsEvent,\n  PaymentProcessedEvent,\n  OrderCreatedEvent,\n  OrderStatusChangedEvent,\n  PaymentStatus,\n} from \"../types.js\";\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  // Counters\n  const eventCounts = new Map<string, number>();\n  const revenue = 0;\n  const orders = new Set<string>();\n  const carts = new Set<string>();\n  const productOrderCounts = new Map<string, number>();\n\n  const incrementEvent = (eventName: string) => {\n    eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);\n  };\n\n  // Listen to generic analytics events if any (not used now)\n  const handleAnalytics = (payload: unknown) => {\n    const event = payload as AnalyticsEvent;\n    incrementEvent(event.event);\n  };\n\n  // Track revenue from successful 