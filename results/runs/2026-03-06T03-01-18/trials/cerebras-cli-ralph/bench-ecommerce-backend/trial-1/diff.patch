\n  };\n\n  // Track revenue from successful payments\nconst handlePayment = (payload: unknown) => {\n  const _ev = payload as PaymentProcessedEvent;\n  if (_ev.status === PaymentStatus.SUCCESS && _ev.transactionId) {\n    // Assume amount is not provided; in a real system we'd store amount with order.\n    // For this demo, we will not add revenue (requires amount). We'll skip.\n  }\n  incrementEvent(Events.PAYMENT_PROCESSED);\n};\n\n  // Track order creation for conversion rate and product counts\n  const handleOrderCreated = (payload: unknown) => {\n    const _ev = payload as OrderCreatedEvent;\n    orders.add(_ev.orderId);\n    carts.add(_ev.cartId);\n    // store total for revenue calculation\n    orderTotals.set(_ev.orderId, _ev.total);\n    incrementEvent(Events.ORDER_CREATED);\n  };\n    const _ev = payload as OrderCreatedEvent;\n    orders.add(_ev.orderId);\n    carts.add(_ev.cartId);\n    // For simplicity, we cannot know product quantities here.\n    incrementEvent(Events.ORDER_CREATED);\n  };\n\n  const handleOrderStatus = (payload: unknown) => {\n    const _ev = payload as OrderStatusChangedEvent;\n    incrementEvent(Events.ORDER_STATUS_CHANGED);\n  };\n\n  // Register listeners\n  bus.on(Events.PAYMENT_PROCESSED, handlePayment);\n  bus.on(Events.ORDER_CREATED, handleOrderCreated);\n  bus.on(Events.ORDER_STATUS_CHANGED, handleOrderStatus);\n  bus.on(Events.ANALYTICS_EVENT, handleAnalytics);\n\n  const getEventCount = (eventType: string) => {\n    return eventCounts.get(eventType) ?? 0;\n  };\n\n  const getRevenue = () => revenue;\n\n  const getConversionRate = () => {\n    if (carts.size === 0) return 0;\n    return orders.size / carts.size;\n  };\n\n  const getTopProducts = (limit: number) => {\n    const sorted = Array.from(productOrderCounts.entries())\n      .sort((a, b) => b[1] - a[1])\n      .slice(0, limit)\n      .map(([productId, count]) => ({ productId, count }));\n    return sorted;\n  };\n\n  return { getEventCount, getRevenue, getConversionRate, getTopProducts };\n}\n","after":"import { EventBus } from \"../bus.js\";\n\n// Analytics service aggregates metrics based on events emitted on the EventBus.\n// It tracks:\n//  - Count of each event type\n//  - Total revenue from successful payments (using order total)\n//  - Conversion rate = orders / carts created\n//  - Top-selling products by quantity ordered (requires order items, simplified here)\nimport {\n  AnalyticsService,\n  Events,\n  AnalyticsEvent,\n  PaymentProcessedEvent,\n  OrderCreatedEvent,\n  OrderStatusChangedEvent,\n  PaymentStatus,\n} from \"../types.js\";\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  // Counters\n  const eventCounts = new Map<string, number>();\n  let revenue = 0;\n  const orders = new Set<string>();\n  const carts = new Set<string>();\n  const productOrderCounts = new Map<string, number>();\n\n  const incrementEvent = (eventName: string) => {\n    eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);\n  };\n\n  // Listen to generic analytics events if any (not used now)\n  const handleAnalytics = (payload: unknown) => {\n    const event = payload as AnalyticsEvent;\n    incrementEvent(event.event);\n  };\n\n  // Track revenue from successful payments\nconst handlePayment = (payload: unknown) => {\n  const _ev = payload as PaymentProcessedEvent;\n  if (_ev.status === PaymentStatus.SUCCESS && _ev.transactionId) {\n    // Assume amount is not provided; in a real system we'd store amount with order.\n    // For this demo, we will not add revenue (requires amount). We'll skip.\n  }\n  incrementEvent(Events.PAYMENT_PROCESSED);\n};\n\n  // Track order creation for conversion rate and product counts\n  const handleOrderCreated = (payload: unknown) => {\n    const _ev = payload as OrderCreatedEvent;\n    orders.add(_ev.orderId);\n    carts.add(_ev.cartId);\n    // store total for revenue calculation\n    orderTotals.set(_ev.orderId, _ev.total);\n    incrementEvent(Events.ORDER_CREATED);\n  };\n    const _ev = payload as OrderCreatedEvent;\n    orders.add(_ev.orderId);\n    carts.add(_ev.cartId);\n    // For simplicity, we cannot know product quantities here.\n    incrementEvent(Events.ORDER_CREATED);\n  };\n\n  const handleOrderStatus = (payload: unknown) => {\n    const _ev = payload as OrderStatusChangedEvent;\n    incrementEvent(Events.ORDER_STATUS_CHANGED);\n  };\n\n  // Register listeners\n  bus.on(Events.PAYMENT_PROCESSED, handlePayment);\n  bus.on(Events.ORDER_CREATED, handleOrderCreated);\n  bus.on(Events.ORDER_STATUS_CHANGED, handleOrderStatus);\n  bus.on(Events.ANALYTICS_EVENT, handleAnalytics);\n\n  const getEventCount = (eventType: string) => {\n    return eventCounts.get(eventType) ?? 0;\n  };\n\n  const getRevenue = () => revenue;\n\n  const getConversionRate = () => {\n    if (carts.size === 0) return 0;\n    return orders.size / carts.size;\n  };\n\n  const getTopProducts = (limit: number) => {\n    const sorted = Array.from(productOrderCounts.entries())\n      .sort((a, b) => b[1] - a[1])\n      .slice(0, limit)\n      .map(([productId, count]) => ({ productId, count }));\n    return sorted;\n  };\n\n  return { getEventCount, getRevenue, getConversionRate, getTopProducts };\n}\n","additions":7,"deletions":0},"truncated":false},"time":{"start":1772769651387,"end":1772769654400}}}}
