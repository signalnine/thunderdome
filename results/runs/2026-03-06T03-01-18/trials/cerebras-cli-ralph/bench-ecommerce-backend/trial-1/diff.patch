+import { EventBus } from "../bus.js";
+import { OrderService, Events, OrderCreatedEvent, OrderStatusChangedEvent, OrderStatus } from "../types.js";
+import { v4 as uuidv4 } from "uuid";
+
+export function createOrderService(bus: EventBus): OrderService {
+  const orders = new Map<
+    string,
+    { id: string; userId: string; cartId: string; status: OrderStatus; total: number }
+  >();
+
+  const emitOrderCreated = (orderId: string, userId: string, cartId: string, total: number) => {
+    const payload: OrderCreatedEvent = { orderId, userId, cartId, total };
+    bus.emit(Events.ORDER_CREATED, payload);
+  };
+
+  const emitStatusChanged = (
+    orderId: string,
+    newStatus: OrderStatus,
+    previousStatus: OrderStatus
+  ) => {
+    const payload: OrderStatusChangedEvent = { orderId, status: newStatus, previousStatus };
+    bus.emit(Events.ORDER_STATUS_CHANGED, payload);
+  };
+
+  const createOrder = (userId: string, cartId: string, total: number): string => {
+    const id = uuidv4();
+    const order = { id, userId, cartId, status: OrderStatus.PENDING, total };
+    orders.set(id, order);
+    emitOrderCreated(id, userId, cartId, total);
+    emitStatusChanged(id, OrderStatus.PENDING, OrderStatus.PENDING);
+    return id;
+  };
+
+  const getOrder = (orderId: string) => {
+    const order = orders.get(orderId);
+    if (!order) return null;
+    const { id, userId, status, total } = order;
+    return { id, userId, status, total };
+  };
+
+  const updateStatus = (orderId: string, status: OrderStatus): void => {
+    const order = orders.get(orderId);
+    if (!order) return;
+    const previous = order.status;
+    if (previous === status) return; // no change
+    order.status = status;
+    emitStatusChanged(orderId, status, previous);
+  };
+
+  const listOrders = (userId: string) => {
+    const result: Array<{ id: string; status: OrderStatus; total: number }> = [];
+    for (const order of orders.values()) {
+      if (order.userId === userId) {
+        result.push({ id: order.id, status: order.status, total: order.total });
+      }
+    }
+    return result;
+  };
+
+  return { createOrder, getOrder, updateStatus, listOrders };
+}
