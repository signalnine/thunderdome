@@ -0,0 +1,85 @@
+import { EventBus } from "../bus.js";
+import { CartService, Events, CartUpdatedEvent } from "../types.js";
+import { v4 as uuidv4 } from "uuid";
+
+export function createCartService(bus: EventBus): CartService {
+  // Store carts: map from cartId to cart object
+  const carts = new Map<
+    string,
+    { id: string; userId: string; items: Map<string, number> }
+  >();
+
+  const emitCartUpdated = (cartId: string) => {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    const itemsArray = Array.from(cart.items.entries()).map(([productId, quantity]) => ({
+      productId,
+      quantity,
+    }));
+    const payload: CartUpdatedEvent = {
+      cartId,
+      userId: cart.userId,
+      items: itemsArray,
+    };
+    bus.emit(Events.CART_UPDATED, payload);
+  };
+
+  const createCart = (userId: string): string => {
+    const id = uuidv4();
+    carts.set(id, { id, userId, items: new Map() });
+    emitCartUpdated(id);
+    return id;
+  };
+
+  const addItem = (cartId: string, productId: string, quantity: number): void => {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    const current = cart.items.get(productId) ?? 0;
+    cart.items.set(productId, current + quantity);
+    emitCartUpdated(cartId);
+  };
+
+  const removeItem = (cartId: string, productId: string): void => {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    cart.items.delete(productId);
+    emitCartUpdated(cartId);
+  };
+
+  const getCart = (cartId: string) => {
+    const cart = carts.get(cartId);
+    if (!cart) return null;
+    const itemsArray = Array.from(cart.items.entries()).map(([productId, quantity]) => ({
+      productId,
+      quantity,
+    }));
+    return { id: cart.id, userId: cart.userId, items: itemsArray };
+  };
+
+  const clearCart = (cartId: string): void => {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    cart.items.clear();
+    emitCartUpdated(cartId);
+  };
+
+  const updateQuantity = (cartId: string, productId: string, quantity: number): void => {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    if (quantity <= 0) {
+      cart.items.delete(productId);
+    } else {
+      cart.items.set(productId, quantity);
+    }
+    emitCartUpdated(cartId);
+  };
+
+  return {
+    createCart,
+    addItem,
+    removeItem,
+    getCart,
+    clearCart,
+    updateQuantity,
+  };
+}
