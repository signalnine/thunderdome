@@ -0,0 +1,61 @@
+import { EventBus } from "../bus.js";
+import { PaymentService, Events, PaymentProcessedEvent, PaymentStatus } from "../types.js";
+
+export interface PaymentOptions {
+  // Simulate success, failure, timeout probabilities (0-1)
+  successRate?: number;
+  failureRate?: number;
+  timeoutRate?: number;
+  processingDelayMs?: number;
+}
+
+export function createPaymentService(
+  bus: EventBus,
+  options: PaymentOptions = {}
+): PaymentService {
+  const {
+    successRate = 0.9,
+    failureRate = 0.05,
+    timeoutRate: _timeoutRate = 0.05,
+    processingDelayMs = 100,
+  } = options;
+
+  const simulate = (): PaymentStatus => {
+    const rand = Math.random();
+    if (rand < successRate) return PaymentStatus.SUCCESS;
+    if (rand < successRate + failureRate) return PaymentStatus.FAILED;
+    return PaymentStatus.TIMEOUT;
+  };
+
+  const processPayment = async (
+    orderId: string,
+    _amount: number
+  ): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> => {
+    // Simulate async delay
+    await new Promise((res) => setTimeout(res, processingDelayMs));
+    const status = simulate();
+    const transactionId = status === PaymentStatus.SUCCESS ? `txn_${Date.now()}` : undefined;
+    const error =
+      status === PaymentStatus.FAILED
+        ? "Payment declined"
+        : status === PaymentStatus.TIMEOUT
+        ? "Payment timed out"
+        : undefined;
+    const payload: PaymentProcessedEvent = {
+      orderId,
+      status,
+      transactionId,
+      error,
+    };
+    bus.emit(Events.PAYMENT_PROCESSED, payload);
+    return { status, transactionId, error };
+  };
+
+  const refund = async (_transactionId: string): Promise<boolean> => {
+    // Simple refund simulation: always succeeds after delay
+    await new Promise((res) => setTimeout(res, processingDelayMs));
+    return true;
+  };
+
+  return { processPayment, refund };
+}
