+import { EventBus } from "../bus.js";
+import { PricingService, Events, ProductCreatedEvent, PriceCalculatedEvent } from "../types.js";
+
+export function createPricingService(bus: EventBus): PricingService {
+  // Store known product prices
+  const prices = new Map<string, number>();
+  // Discount codes: code -> percentage (e.g., 10 for 10%)
+  const discounts = new Map<string, number>();
+  const TAX_RATE = 0.1; // 10%
+
+  // Listen to product creation to capture price
+  const handleProductCreated = (payload: unknown) => {
+    const event = payload as ProductCreatedEvent;
+    prices.set(event.productId, event.price);
+  };
+  bus.on(Events.PRODUCT_CREATED, handleProductCreated);
+
+  const addDiscountCode = (code: string, percentage: number): void => {
+    discounts.set(code, percentage);
+  };
+
+  const getPrice = (productId: string): number => {
+    return prices.get(productId) ?? 0;
+  };
+
+  const calculateTotal = (
+    items: Array<{ productId: string; quantity: number; price: number }>,
+    discountCode?: string
+  ) => {
+    // Compute subtotal based on provided price (fallback to stored price)
+    let subtotal = 0;
+    for (const item of items) {
+      const unitPrice = item.price ?? getPrice(item.productId);
+      subtotal += unitPrice * item.quantity;
+    }
+    let discount = 0;
+    if (discountCode && discounts.has(discountCode)) {
+      const perc = discounts.get(discountCode)!;
+      discount = (subtotal * perc) / 100;
+    }
+    const afterDiscount = subtotal - discount;
+    const tax = afterDiscount * TAX_RATE;
+    const total = afterDiscount + tax;
+
+    // Emit price calculated event
+    const payload: PriceCalculatedEvent = {
+      cartId: "", // Caller may include cartId via context; not required here
+      subtotal,
+      discount,
+      tax,
+      total,
+    };
+    // Emit without cartId (empty) as spec does not require it here
+    bus.emit(Events.PRICE_CALCULATED, payload);
+
+    return { subtotal, discount, tax, total };
+  };
+
+  return {
+    calculateTotal,
+    addDiscountCode,
+    getPrice,
+  };
+}
