t_secret';\n\n// Middleware to protect routes\nfunction authMiddleware(req: AuthRequest, res: Response, next: NextFunction) {\n  const authHeader = req.headers.authorization;\n  if (!authHeader || !authHeader.startsWith('Bearer ')) {\n    return res.sendStatus(401);\n  }\n  const token = authHeader.substring(7);\n  try {\n    const payload = jwt.verify(token, JWT_SECRET) as { id: string; tenant_id: string; role: string };\n    req.user = { id: payload.id, tenant_id: payload.tenant_id, role: payload.role };\n    next();\n  } catch (e) {\n    return res.sendStatus(401);\n  }\n}\n\n// Helper to hash password\nfunction hashPassword(password: string): string {\n  return crypto.createHash('sha256').update(password).digest('hex');\n}\n\nexport function createApp() {\n  const app = express();\n  app.use(express.json());\n\n  // Registration\n  app.post('/register', (req: Request, res: Response) => {\n    const { email, password, tenant_id, role } = req.body;\n    if (!email || !password || !tenant_id) {\n      return res.status(400).json({ error: 'Missing fields' });\n    }\n    const id = uuidv4();\n    const password_hash = hashPassword(password);\n    const userRole = role && ['admin', 'editor', 'viewer'].includes(role) ? role : 'viewer';\n    try {\n      const stmt = db.prepare('INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)');\n      stmt.run(id, email, password_hash, tenant_id, userRole);\n      const token = jwt.sign({ id, tenant_id, role: userRole }, JWT_SECRET);\n      res.json({ token });\n    } catch (e) {\n      res.status(500).json({ error: 'Registration failed' });\n    }\n  });\n\n  // Login\n  app.post('/login', (req: Request, res: Response) => {\n    const { email, password } = req.body;\n    if (!email || !password) {\n      return res.status(400).json({ error: 'Missing fields' });\n    }\n    const password_hash = hashPassword(password);\n    const stmt = db.prepare('SELECT * FROM users WHERE email = ? AND password_hash = ?');\n    const user = stmt.get(email, password_hash) as User | undefined;\n    if (!user) {\n      return res.status(401).json({ error: 'Invalid credentials' });\n    }\n    const token = jwt.sign({ id: user.id, tenant_id: user.tenant_id, role: user.role }, JWT_SECRET);\n    res.json({ token });\n  });\n\n  // Profile\n  app.get('/profile', authMiddleware, (req: AuthRequest, res: Response) => {\n    const userId = req.user!.id;\n    const stmt = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?');\n    const user = stmt.get(userId);\n    res.json(user);\n  });\n\n  // Change user role (admin only)\n  app.put('/admin/users/:id/role', authMiddleware, (req: AuthRequest, res: Response) => {\n    if (req.user!.role !== 'admin') return res.sendStatus(403);\n    const targetId = req.params.id;\n    const { role } = req.body;\n    if (!['admin', 'editor', 'viewer'].includes(role)) {\n      return res.status(400).json({ error: 'Invalid role' });\n    }\n    const stmt = db.prepare('UPDATE users SET role = ? WHERE id = ? AND tenant_id = ?');\n    const info = stmt.run(role, targetId, req.user!.tenant_id);\n    if (info.changes === 0) return res.status(404).json({ error: 'User not found' });\n    res.json({ success: true });\n  });\n\n  // Ingest events (single or batch)\n  app.post('/events', authMiddleware, (req: AuthRequest, res: Response) => {\n    const events = Array.isArray(req.body) ? req.body : [req.body];\n    const insert = db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)');\n    const now = new Date().toISOString();\n    interface EventInput { name: string; properties?: Record<string, unknown>; timestamp?: string; }\nconst insertMany = db.transaction((evts: EventInput[]) => {\n      for (const ev of evts) {\n        const id = uuidv4();\n        const name = ev.name;\n        const properties = JSON.stringify(ev.properties || {});\n        const timestamp = ev.timestamp || now;\n        const user_id = req.user!.id;\n        insert.run(id, req.user!.tenant_id, name, properties, timestamp, user_id);\n      }\n    });\n    try {\n      insertMany(events);\n      res.json({ success: true, inserted: events.length });\n    } catch (e) {\n      res.status(500).json({ error: 'Failed to ingest events' });\n    }\n  });\n\n  // Query count\n  // type QueryParams removed as unused\napp.get('/query/count', authMiddleware, (req: AuthRequest, res: Response) => {\n    const { name, start, end } = req.query as unknown as { name?: string; start?: string; end?: string; }\n    let sql = 'SELECT COUNT(*) as cnt FROM events WHERE tenant_id = ?';\n    const params: any[] = [req.user!.tenant_id];\n    if (name) { sql += ' AND name = ?'; params.push(name); }\n    if (start) { sql += ' AND timestamp >= ?'; params.push(start); }\n    if (end) { sql += ' AND timestamp <= ?'; params.push(end); }\n    const row = db.prepare(sql).get(...params) as { cnt: number } | undefined;\n    const count = row ? row.cnt : 0;\n    res.json({ count });\n  });\n\n  // Query timeseries (daily bucket)\n  app.get('/query/timeseries', authMiddleware, (req: AuthRequest, res: Response) => {\n    const { name, start, end } = req.query as unknown as { name?: string; start?: string; end?: string; }\n    let sql = `SELECT date(timestamp) as day, COUNT(*) as cnt FROM events WHERE tenant_id = ?`;\n    const params: any[] = [req.user!.tenant_id];\n    if (name) { sql += ' AND name = ?'; params.push(name); }\n    if (start) { sql += ' AND timestamp >= ?'; params.push(start); }\n    if (end) { sql += ' AND timestamp <= ?'; params.push(end); }\n    sql += ' GROUP BY day ORDER BY day';\n    const rows = db.prepare(sql).all(...params);\n    res.json(rows);\n  });\n\n  // Query breakdown by property key\n  app.get('/query/breakdown', authMiddleware, (req: AuthRequest, res: Response) => {\n    const { name, key, start, end } = req.query as unknown as { name?: string; key?: string; start?: 