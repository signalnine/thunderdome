leware, (req: AuthRequest, res: Response) => {\n173:     const { name, key, start, end } = req.query as any;\n174:     if (!key) return res.status(400).json({ error: 'Missing property key' });\n175:     // SQLite does not have JSON_VALUE in older versions; use json_extract\n176:     let sql = `SELECT json_extract(properties, '$.${key}') as prop, COUNT(*) as cnt FROM events WHERE tenant_id = ?`;\n177:     const params: any[] = [req.user!.tenant_id];\n178:     if (name) { sql += ' AND name = ?'; params.push(name); }\n179:     if (start) { sql += ' AND timestamp >= ?'; params.push(start); }\n180:     if (end) { sql += ' AND timestamp <= ?'; params.push(end); }\n181:     sql += ' GROUP BY prop';\n182:     const rows = db.prepare(sql).all(...params);\n183:     res.json(rows);\n184:   });\n185: \n186:   // Dashboards CRUD\n187:   app.post('/dashboards', authMiddleware, (req: AuthRequest, res: Response) => {\n188:     const { name, config } = req.body;\n189:     if (!name) return res.status(400).json({ error: 'Missing name' });\n190:     const id = uuidv4();\n191:     const stmt = db.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)');\n192:     stmt.run(id, req.user!.tenant_id, name, req.user!.id, JSON.stringify(config || {}));\n193:     res.json({ id });\n194:   });\n195: \n196:   app.get('/dashboards', authMiddleware, (req: AuthRequest, res: Response) => {\n197:     const rows = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(req.user!.tenant_id);\n198:     res.json(rows);\n199:   });\n200: \n201:   app.get('/dashboards/:id', authMiddleware, (req: AuthRequest, res: Response) => {\n202:     const row = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, req.user!.tenant_id);\n203:     if (!row) return res.sendStatus(404);\n204:     res.json(row);\n205:   });\n206: \n207:   app.put('/dashboards/:id', authMiddleware, (req: AuthRequest, res: Response) => {\n208:     const { name