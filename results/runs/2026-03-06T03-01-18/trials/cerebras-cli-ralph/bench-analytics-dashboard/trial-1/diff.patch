+{"type":"tool_use","timestamp":1772768850372,"sessionID":"ses_33ebe24afffeU5MlnvT0t15uBK","part":{"id":"prt_cc141ed7b001osVpXhNM5n3mdY","sessionID":"ses_33ebe24afffeU5MlnvT0t15uBK","messageID":"msg_cc141ea9600241wPtrQGdmHz5S","type":"tool","callID":"9c0859d9c","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/app.ts","content":"import express, { Request, Response, NextFunction } from 'express';\nimport Database from 'better-sqlite3';\nimport jwt from 'jsonwebtoken';\nimport { v4 as uuidv4 } from 'uuid';\nimport crypto from 'crypto';\nimport path from 'path';\n\n// Types\ninterface User {\n  id: string;\n  email: string;\n  password_hash: string;\n  tenant_id: string;\n  role: 'admin' | 'editor' | 'viewer';\n}\n\ninterface AuthRequest extends Request {\n  user?: { id: string; tenant_id: string; role: string };\n}\n\n// Initialize SQLite DB\nconst dbPath = path.resolve(process.cwd(), 'data.sqlite');\nconst db = new Database(dbPath);\n// Run schema\nconst schemaSql = require('fs').readFileSync(path.resolve(process.cwd(), 'schema.sql'), 'utf-8');\n// Split on semicolons to execute statements\nschemaSql.split(/;\\s*\\n/).forEach(stmt => {\n  const trimmed = stmt.trim();\n  if (trimmed) {\n    db.exec(trimmed + ';');\n  }\n});\n\n// JWT secret\nconst JWT_SECRET = process.env.JWT_SECRET || 'default_secret';\n\n// Middleware to protect routes\nfunction authMiddleware(req: AuthRequest, res: Response, next: NextFunction) {\n  const authHeader = req.headers.authorization;\n  if (!authHeader || !authHeader.startsWith('Bearer ')) {\n    return res.sendStatus(401);\n  }\n  const token = authHeader.substring(7);\n  try {\n    const payload = jwt.verify(token, JWT_SECRET) as any;\n    req.user = { id: payload.id, tenant_id: payload.tenant_id, role: payload.role };\n    next();\n  } catch (e) {\n    return res.sendStatus(401);\n  }\n}\n\n// Helper to hash password\nfunction hashPassword(password: string): string {\n  return crypto.createHash('sha256').update(password).digest('hex');\n}\n\nexport function createApp() {\n  const app = express();\n  app.use(express.json());\n\n  // Registration\n  app.post('/register', (req: Request, res: Response) => {\n    const { email, password, tenant_id, role } = req.body;\n    if (!email || !password || !tenant_id) {\n      return res.status(400).json({ error: 'Missing fields' });\n    }\n    const id = uuidv4();\n    const password_hash = hashPassword(password);\n    const userRole = role && ['admin', 'editor', 'viewer'].includes(role) ? role : 'viewer';\n    try {\n      const stmt = db.prepare('INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)');\n      stmt.run(id, email, password_hash, tenant_id, userRole);\n      const token = jwt.sign({ id, tenant_id, role: userRole }, JWT_SECRET);\n      res.json({ token });\n    } catch (e) {\n      res.status(500).json({ error: 'Registration failed' });\n    }\n  });\n\n  // Login\n  app.post('/login', (req: Request, res: Response) => {\n    const { email, password } = req.body;\n    if (!email || !password) {\n      return res.status(400).json({ error: 'Missing fields' });\n    }\n    const password_hash = hashPassword(password);\n    const stmt = db.prepare('SELECT * FROM users WHERE email = ? AND password_hash = ?');\n    const user: User = stmt.get(email, password_hash);\n    if (!user) {\n      return res.status(401).json({ error: 'Invalid credentials' });\n    }\n    const token = jwt.sign({ id: user.id, tenant_id: user.tenant_id, role: user.role }, JWT_SECRET);\n    res.json({ token });\n  });\n\n  // Profile\n  app.get('/profile', authMiddleware, (req: AuthRequest, res: Response) => {\n    const userId = req.user!.id;\n    const stmt = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?');\n    const user = stmt.get(userId);\n    res.json(user);\n  });\n\n  // Change user role (admin only)\n  app.put('/admin/users/:id/role', authMiddleware, (req: AuthRequest, res: Response) => {\n    if (req.user!.role !== 'admin') return res.sendStatus(403);\n    const targetId = req.params.id;\n    const { role } = req.body;\n    if (!['admin', 'editor', 'viewer'].includes(role)) {\n      return res.status(400).json({ error: 'Invalid role' });\n    }\n    const stmt = db.prepare('UPDATE users SET role = ? WHERE id = ? AND tenant_id = ?');\n    const info = stmt.run(role, targetId, req.user!.tenant_id);\n    if (info.changes === 0) return res.status(404).json({ error: 'User not found' });\n    res.json({ success: true });\n  });\n\n  // Ingest events (single or batch)\n  app.post('/events', authMiddleware, (req: AuthRequest, res: Response) => {\n    const events = Array.isArray(req.body) ? req.body : [req.body];\n    const insert = db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)');\n    const now = new Date().toISOString();\n    const insertMany = db.transaction((evts: any[]) => {\n      for (const ev of evts) {\n        const id = uuidv4();\n        const name = ev.name;\n        const properties = JSON.stringify(ev.properties || {});\n        const timestamp = ev.timestamp || now;\n        const user_id = req.user!.id;\n        insert.run(id, req.user!.tenant_id, name, properties, timestamp, user_id);\n      }\n    });\n    try {\n      insertMany(events);\n      res.json({ success: true, inserted: events.length });\n    } catch (e) {\n      res.status(500).json({ error: 'Failed to ingest events' });\n    }\n  });\n\n  // Query count\n  app.get('/query/count', authMiddleware, (req: AuthRequest, res: Response) => {\n    const { name, start, end } = req.query as any;\n    let sql = 'SELECT COUNT(*) as cnt FROM events WHERE tenant_id = ?';\n    const params: any[] = [req.user!.tenant_id];\n    if (name) { sql += ' AND name = ?'; params.push(name); }\n    if (start) { sql += ' AND timestamp >= ?'; params.push(start); }\n    if (end) { sql += ' AND timestamp <= ?'; params.push(end); }\n    const row = db.prepare(sql).get(...params);\n    res.json({ count: row.cnt });\n  });\n\n  // Query timeseries (daily bucket)\n  app.get('/query/timeseries', authMiddleware, (req: AuthRequest, res: Response) => {\n    const { name, start, end } = req.query as any;\n    let sql = `SELECT date(timestamp) as day, COUNT(*) as cnt FROM events WHERE tenant_id = ?`;\n    const params: any[] = [req.user!.tenant_id];\n    if (name) { sql += ' AND name = ?'; params.push(name); }\n    if (start) { sql += ' AND timestamp >= ?'; params.push(start); }\n    if (end) { sql += ' AND timestamp <= ?'; params.push(end); }\n    sql += ' GROUP BY day ORDER BY day';\n    const rows = db.prepare(sql).all(...params);\n    res.json(rows);\n  });\n\n  // Query breakdown by property key\n  app.get('/query/breakdown', authMiddleware, (req: AuthRequest, res: Response) => {\n    const { name, key, start, end } = req.query as any;\n    if (!key) return res.status(400).json({ error: 'Missing property key' });\n    // SQLite does not have JSON_VALUE in older versions; use json_extract\n    let sql = `SELECT json_extract(properties, '$.${key}') as prop, COUNT(*) as cnt FROM events WHERE tenant_id = ?`;\n    const params: any[] = [req.user!.tenant_id];\n    if (name) { sql += ' AND name = ?'; params.push(name); }\n    if (start) { sql += ' AND timestamp >= ?'; params.push(start); }\n    if (end) { sql += ' AND timestamp <= ?'; params.push(end); }\n    sql += ' GROUP BY prop';\n    const rows = db.prepare(sql).all(...params);\n    res.json(rows);\n  });\n\n  // Dashboards CRUD\n  app.post('/dashboards', authMiddleware, (req: AuthRequest, res: Response) => {\n    const { name, config } = req.body;\n    if (!name) return res.status(400).json({ error: 'Missing name' });\n    const id = uuidv4();\n    const stmt = db.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)');\n    stmt.run(id, req.user!.tenant_id, name, req.user!.id, JSON.stringify(config || {}));\n    res.json({ id });\n  });\n\n  app.get('/dashboards', authMiddleware, (req: AuthRequest, res: Response) => {\n    const rows = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(req.user!.tenant_id);\n    res.json(rows);\n  });\n\n  app.get('/dashboards/:id', authMiddleware, (req: AuthRequest, res: Response) => {\n    const row = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, req.user!.tenant_id);\n    if (!row) return res.sendStatus(404);\n    res.json(row);\n  });\n\n  app.put('/dashboards/:id', authMiddleware, (req: AuthRequest, res: Response) => {\n    const { name, config } = req.body;\n    const stmt = db.prepare('UPDATE dashboards SET name = COALESCE(?, name), config = COALESCE(?, config), updated_at = CURRENT_TIMESTAMP WHERE id = ? AND tenant_id = ?');\n    const info = stmt.run(name, JSON.stringify(config || {}), req.params.id, req.user!.tenant_id);\n    if (info.changes === 0) return res.sendStatus(404);\n    res.json({ success: true });\n  });\n\n  app.delete('/dashboards/:id', authMiddleware, (req: AuthRequest, res: Response) => {\n    const stmt = db.prepare('DELETE FROM dashboards WHERE id = ? AND tenant_id = ?');\n    const info = stmt.run(req.params.id, req.user!.tenant_id);\n    if (info.changes === 0) return res.sendStatus(404);\n    res.json({ success: true });\n  });\n\n  // Export events\n  app.get('/export/events', authMiddleware, (req: AuthRequest, res: Response) => {\n    const format = req.query.format === 'csv' ? 'csv' : 'json';\n    const rows = db.prepare('SELECT * FROM events WHERE tenant_id = ?').all(req.user!.tenant_id);\n    if (format === 'csv') {\n      const header = ['id','tenant_id','name','properties','timestamp','user_id','session_id'].join(',');\n      const lines = rows.map((r: any) => {\n        return [r.id, r.tenant_id, r.name, JSON.stringify(r.properties), r.timestamp, r.user_id || '', r.session_id || ''].join(',');\n      });\n      res.type('text/csv').s