s { id: string; tenant_id: string; role: string };\n47:     req.user = { id: payload.id, tenant_id: payload.tenant_id, role: payload.role };\n48:     next();\n49:   } catch (e) {\n50:     return res.sendStatus(401);\n51:   }\n52: }\n53: \n54: // Helper to hash password\n55: function hashPassword(password: string): string {\n56:   return crypto.createHash('sha256').update(password).digest('hex');\n57: }\n58: \n59: export function createApp() {\n60:   const app = express();\n61:   app.use(express.json());\n62: \n63:   // Registration\n64:   app.post('/register', (req: Request, res: Response) => {\n65:     const { email, password, tenant_id, role } = req.body;\n66:     if (!email || !password || !tenant_id) {\n67:       return res.status(400).json({ error: 'Missing fields' });\n68:     }\n69:     const id = uuidv4();\n70:     const password_hash = hashPassword(password);\n71:     const userRole = role && ['admin', 'editor', 'viewer'].includes(role) ? role : 'viewer';\n72:     try {\n73:       const stmt = db.prepare('INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)');\n74:       stmt.run(id, email, password_hash, tenant_id, userRole);\n75:       const token = jwt.sign({ id, tenant_id, role: userRole }, JWT_SECRET);\n76:       res.json({ token });\n77:     } catch (e) {\n78:       res.status(500).json({ error: 'Registration failed' });\n79:     }\n80:   });\n81: \n82:   // Login\n83:   app.post('/login', (req: Request, res: Response) => {\n84:     const { email, password } = req.body;\n85:     if (!email || !password) {\n86:       return res.status(400).json({ error: 'Missing fields' });\n87:     }\n88:     const password_hash = hashPassword(password);\n89:     const stmt = db.prepare('SELECT * FROM users WHERE email = ? AND password_hash = ?');\n90:     const user = stmt.get(email, password_hash) as User | undefined;\n91:     if (!user) {\n92:       return res.status(401).json({ error: 'Invalid credentials' });\n93:     }\n94:     const token = jwt.sign({ id: user.id, tenant_id: user.tenant_id, role: user.role }, JWT_SECRET);\n95:     res.json({ token });\n96:   });\n97: \n98:   // Profile\n99:   app.get('/profile', authMiddleware, (req: AuthRequest, res: Response) => {\n100:     const userId = req.user!.id;\n101:     const stmt = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?');\n102:     const user = stmt.get(userId);\n103:     res.json(user);\n104:   });\n105: \n106:   // Change user role (admin only)\n107:   app.put('/admin/users/:id/role', authMiddleware, (req: AuthRequest, res: Response) => {\n108:     if (req.user!.role !== 'admin') return res.sendStatus(403);\n109:     const targetId = req.params.id;\n110:     const { role } = req.body;\n111:     if (!['admin', 'editor', 'viewer'].includes(role)) {\n112:       return res.status(400).json({ error: 'Invalid role' });\n113:     }\n114:     const stmt = db.prepare('UPDATE users SET role = ? WHERE id = ? AND tenant_id = ?');\n115:     const info = stmt.run(role, targetId, req.user!.tenant_id);\n116:     if (info.changes === 0) return res.status(404).json({ error: 'User not found' });\n117:     res.json({ success: true });\n118:   });\n119: \n120:   // Ingest events (single or batch)\n121:   app.post('/events', authMiddleware, (req: AuthRequest, res: Response) => {\n122:     const events = Array.isArray(req.body) ? req.body : [req.body];\n123:     const insert = db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)');\n124:     const now = new Date().toISOString();\n125:     interface EventInput { name: string; properties?: Record<string, any>; timestamp?: string; }\n126: const insertMany = db.transaction((evts: EventInput[]) => {\n127:       for (const ev of evts) {\n128:         const id = uuidv4();\n129:         const name = ev.name;\n130:         const properties = JSON.stringify(ev.properties || {});\n131:         const timestamp = ev.timestamp ||