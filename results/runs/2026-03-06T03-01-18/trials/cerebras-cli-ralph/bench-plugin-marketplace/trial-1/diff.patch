+{"type":"tool_use","timestamp":1772767012239,"sessionID":"ses_33eda463fffewa5bgxbO68k0ye","part":{"id":"prt_cc125e42f001Pi6119xhiZz4x0","sessionID":"ses_33eda463fffewa5bgxbO68k0ye","messageID":"msg_cc125e261002GS9Aj0mxPbL2f1","type":"tool","callID":"b8f5f5791","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/reviews/reviewService.ts","content":"// Review Service implementation using better-sqlite3\nimport Database from 'better-sqlite3';\nimport { Review, ReviewService } from '../types';\n\nexport class SqliteReviewService implements ReviewService {\n  private db: Database.Database;\n  private static nextId = 1;\n\n  constructor(dbPath: string = 'marketplace.db') {\n    this.db = new Database(dbPath);\n    this.initialize();\n  }\n\n  private initialize() {\n    const stmt = this.db.prepare(`\n      CREATE TABLE IF NOT EXISTS reviews (\n        id INTEGER PRIMARY KEY,\n        pluginName TEXT NOT NULL,\n        pluginVersion TEXT NOT NULL,\n        userId TEXT NOT NULL,\n        rating INTEGER NOT NULL,\n        comment TEXT,\n        flagged INTEGER DEFAULT 0,\n        createdAt TEXT NOT NULL\n      )\n    `);\n    stmt.run();\n  }\n\n  addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {\n    const id = SqliteReviewService.nextId++;\n    const createdAt = new Date().toISOString();\n    const flagged = 0;\n    const stmt = this.db.prepare(`\n      INSERT INTO reviews (id, pluginName, pluginVersion, userId, rating, comment, flagged, createdAt)\n      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n    `);\n    stmt.run(id, review.pluginName, review.pluginVersion, review.userId, review.rating, review.comment, flagged, createdAt);\n    return { ...review, id, createdAt, flagged: false };\n  }\n\n  getReviews(pluginName: string): Review[] {\n    const rows = this.db.prepare(`SELECT * FROM reviews WHERE pluginName = ?`).all(pluginName);\n    return rows.map(this.rowToReview);\n  }\n\n  getAverageRating(pluginName: string): number {\n    const row = this.db.prepare(`SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0`).get(pluginName);\n    return row?.avg ?? 0;\n  }\n\n  flagReview(reviewId: number): void {\n    this.db.prepare(`UPDATE reviews SET flagged = 1 WHERE id = ?`).run(reviewId);\n  }\n\n  getFlaggedReviews(): Review[] {\n    const rows = this.db.prepare(`SELECT * FROM reviews WHERE flagged = 1`).all();\n    return rows.map(this.rowToReview);\n  }\n\n  removeReview(reviewId: number): boolean {\n    const info = this.db.prepare(`DELETE FROM reviews WHERE id = ?`).run(reviewId);\n    return info.changes > 0;\n  }\n\n  getReviewsByUser(userId: string): Review[] {\n    const rows = this.db.prepare(`SELECT * FROM reviews WHERE userId = ?`).all(userId);\n    return rows.map(this.rowToReview);\n  }\n\n  getReviewCount(pluginName: string): number {\n    const row = this.db.prepare(`SELECT COUNT(*) as cnt FROM reviews WHERE pluginName = ?`).get(pluginName);\n    return row?.cnt ?? 0;\n  }\n\n  private rowToReview(row: any): Review {\n    return {\n      id: row.id,\n      pluginName: row.pluginName,\n      pluginVersion: row.pluginVersion,\n      userId: row.userId,\n      rating: row.rating,\n      comment: row.comment,\n      flagged: !!row.flagged,\n      createdAt: row.createdAt,\n    };\n  }\n}\n"},"output":"Wrote file successfully.","title":"src/reviews/reviewService.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/reviews/reviewService.ts","exists":false,"truncated":false},"time":{"start":1772767012229,"end":1772767012238}}}}
