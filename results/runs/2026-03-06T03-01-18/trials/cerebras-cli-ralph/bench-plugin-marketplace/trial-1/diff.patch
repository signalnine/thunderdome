@@ -0,0 +1,91 @@
+// Dependency Service implementation using registry data
+import { DepsService, DependencyNode, RegistryService } from '../types.js';
+
+export class SimpleDepsService implements DepsService {
+  // Build full dependency tree for a plugin (including transitive)
+  buildTree(name: string, registry: RegistryService): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) throw new Error(`Plugin ${name} not found`);
+    const visited = new Set<string>();
+    const build = (pluginName: string): DependencyNode => {
+      if (visited.has(pluginName)) {
+        // Prevent infinite recursion on cycles
+        return { name: pluginName, version: '', dependencies: [] };
+      }
+      visited.add(pluginName);
+      const man = registry.get(pluginName);
+      if (!man) throw new Error(`Dependency ${pluginName} not found`);
+      const deps: DependencyNode[] = [];
+      for (const depName of Object.keys(man.dependencies)) {
+        deps.push(build(depName));
+      }
+      return { name: pluginName, version: man.version, dependencies: deps };
+    };
+    return build(name);
+  }
+
+  // Detect cycles using DFS; return list of cycles (each as array of plugin names) or null if none
+  detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const cycles: string[][] = [];
+    const visited = new Set<string>();
+    const stack: string[] = [];
+    const dfs = (node: string) => {
+      if (stack.includes(node)) {
+        const idx = stack.indexOf(node);
+        cycles.push(stack.slice(idx).concat(node));
+        return;
+      }
+      if (visited.has(node)) return;
+      visited.add(node);
+      stack.push(node);
+      const manifest = registry.get(node);
+      if (manifest) {
+        for (const dep of Object.keys(manifest.dependencies)) {
+          dfs(dep);
+        }
+      }
+      stack.pop();
+    };
+    dfs(name);
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  topologicalSort(name: string, registry: RegistryService): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+    const visit = (node: string) => {
+      if (visited.has(node)) return;
+      visited.add(node);
+      const manifest = registry.get(node);
+      if (manifest) {
+        for (const dep of Object.keys(manifest.dependencies)) {
+          visit(dep);
+        }
+      }
+      result.push(node);
+    };
+    visit(name);
+    return result.reverse();
+  }
+
+  flattenDependencies(name: string, registry: RegistryService): string[] {
+    // Return list of all transitive dependency names (no duplicates) in any order
+    const deps = new Set<string>();
+    const collect = (pluginName: string) => {
+      const manifest = registry.get(pluginName);
+      if (!manifest) return;
+      for (const dep of Object.keys(manifest.dependencies)) {
+        if (!deps.has(dep)) {
+          deps.add(dep);
+          collect(dep);
+        }
+      }
+    };
+    collect(name);
+    return Array.from(deps);
+  }
+
+  hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return this.detectCycles(name, registry) !== null;
+  }
+}
