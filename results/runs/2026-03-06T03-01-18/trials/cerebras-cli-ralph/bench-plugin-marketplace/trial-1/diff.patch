@@ -0,0 +1,60 @@
+// Marketplace composition and install workflow
+import { PluginManifest, ResolvedVersion, SandboxResult, RegistryService, ResolverService, RunnerService, ReviewService, DepsService } from './types.js';
+import { SqliteRegistry } from './registry/registry.js';
+import { SemverResolver } from './resolver/resolver.js';
+import { VmRunner } from './runner/runner.js';
+import { SqliteReviewService } from './reviews/reviewService.js';
+import { SimpleDepsService } from './deps/depsService.js';
+
+export interface Marketplace {
+  registry: RegistryService;
+  resolver: ResolverService;
+  runner: RunnerService;
+  reviews: ReviewService;
+  deps: DepsService;
+  installPlugin(manifest: PluginManifest): Promise<{ resolved: ResolvedVersion[]; result: SandboxResult }>;
+}
+
+export function createMarketplace(): Marketplace {
+  const registry = new SqliteRegistry();
+  const resolver = new SemverResolver();
+  const runner = new VmRunner();
+  const reviews = new SqliteReviewService();
+  const deps = new SimpleDepsService();
+
+  async function installPlugin(manifest: PluginManifest) {
+    // Basic validation
+    if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+      throw new Error('Plugin manifest must include name, version, and entryPoint');
+    }
+
+    // Register plugin
+    registry.register(manifest);
+
+    // Resolve dependencies
+    const constraints = Object.entries(manifest.dependencies || {}).map(([name, range]) => ({ name, range }));
+    const available: Record<string, string[]> = {};
+    for (const name of Object.keys(manifest.dependencies || {})) {
+      available[name] = registry.listVersions(name);
+    }
+    const resolved = resolver.resolve(constraints, available);
+    // Verify all dependencies resolved
+    for (const r of resolved) {
+      if (!r.version) {
+        throw new Error(`Unable to resolve dependency ${r.name}`);
+      }
+    }
+
+    // Detect circular dependencies (including transitive)
+    if (deps.hasCircularDependency(manifest.name, registry)) {
+      throw new Error('Circular dependency detected');
+    }
+
+    // Execute entry point code
+    const result = await runner.executeWithTimeout(manifest.entryPoint, 2000);
+
+    return { resolved, result };
+  }
+
+  return { registry, resolver, runner, reviews, deps, installPlugin };
+}
