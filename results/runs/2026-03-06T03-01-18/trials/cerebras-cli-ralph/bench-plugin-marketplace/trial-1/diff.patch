+// Runner Service implementation using Node's vm module
+import vm from 'node:vm';
+import { RunnerService, SandboxResult } from '../types.js';
+import { performance } from 'node:perf_hooks';
+// import { inspect } from 'node:util'; // unused
+
+export class VmRunner implements RunnerService {
+  async execute(code: string, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+    const start = performance.now();
+    const sandbox = { ...context, console, setTimeout, setInterval, clearTimeout, clearInterval };
+    const script = new vm.Script(code); // no timeout here
+    const contextified = vm.createContext(sandbox);
+    let output: unknown = undefined;
+    let errorMsg: string | undefined = undefined;
+    try {
+      output = script.runInContext(contextified);
+    } catch (e: any) {
+      errorMsg = e?.message ?? String(e);
+    }
+    const end = performance.now();
+    // Memory usage approximation
+    const memoryUsed = process.memoryUsage().heapUsed;
+    return {
+      success: errorMsg ? false : true,
+      output,
+      duration: end - start,
+      memoryUsed,
+      error: errorMsg,
+    };
+  }
+
+  async executeWithTimeout(code: string, timeoutMs: number, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+    const start = performance.now();
+    const sandbox = { ...context, console, setTimeout, setInterval, clearTimeout, clearInterval };
+    const script = new vm.Script(code);
+    const contextified = vm.createContext(sandbox);
+    let output: unknown = undefined;
+    let errorMsg: string | undefined = undefined;
+    try {
+      output = script.runInContext(contextified);
+    } catch (e: any) {
+      errorMsg = e?.message ?? String(e);
+    }
+    const end = performance.now();
+    const memoryUsed = process.memoryUsage().heapUsed;
+    const success = !errorMsg && (Date.now() - start) <= timeoutMs;
+    return {
+      success,
+      output,
+      duration: end - start,
+      memoryUsed,
+      error: errorMsg,
+    };
+  }
+}
