est.entryPoint, 2000);\n\n    return { resolved, result };\n  }\n\n  return { registry, resolver, runner, reviews, deps, installPlugin };\n}\n","additions":1,"deletions":1},"truncated":false},"time":{"start":1772767108738,"end":1772767111751}}}}
