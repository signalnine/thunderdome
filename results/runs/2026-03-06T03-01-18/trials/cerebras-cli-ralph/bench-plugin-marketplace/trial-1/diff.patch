@@ -0,0 +1,98 @@
+// Registry Service implementation using better-sqlite3
+import Database from 'better-sqlite3';
+import { PluginManifest, RegistryService } from '../types.js';
+
+export class SqliteRegistry implements RegistryService {
+  private db: Database.Database;
+
+  constructor(dbPath: string = 'marketplace.db') {
+    this.db = new Database(dbPath);
+    this.initialize();
+  }
+
+  private initialize() {
+    const stmt = this.db.prepare(`
+      CREATE TABLE IF NOT EXISTS plugins (
+        name TEXT NOT NULL,
+        version TEXT NOT NULL,
+        description TEXT,
+        author TEXT,
+        dependencies TEXT,
+        entryPoint TEXT,
+        permissions TEXT,
+        PRIMARY KEY (name, version)
+      )
+    `);
+    stmt.run();
+  }
+
+  register(manifest: PluginManifest): void {
+    const stmt = this.db.prepare(`
+      INSERT OR REPLACE INTO plugins (name, version, description, author, dependencies, entryPoint, permissions)
+      VALUES (@name, @version, @description, @author, @dependencies, @entryPoint, @permissions)
+    `);
+    stmt.run({
+      name: manifest.name,
+      version: manifest.version,
+      description: manifest.description,
+      author: manifest.author,
+      dependencies: JSON.stringify(manifest.dependencies),
+      entryPoint: manifest.entryPoint,
+      permissions: JSON.stringify(manifest.permissions),
+    });
+  }
+
+  get(name: string): PluginManifest | null {
+    // eslint-disable-next-line @typescript-eslint/no-explicit-any
+    const row = this.db.prepare(`SELECT * FROM plugins WHERE name = ? LIMIT 1`).get(name) as any;
+    return row ? this.rowToManifest(row) : null;
+  }
+
+  getVersion(name: string, version: string): PluginManifest | null {
+    // eslint-disable-next-line @typescript-eslint/no-explicit-any
+    const row = this.db.prepare(`SELECT * FROM plugins WHERE name = ? AND version = ?`).get(name, version) as any;
+    return row ? this.rowToManifest(row) : null;
+  }
+
+  list(): PluginManifest[] {
+    const rows = this.db.prepare(`SELECT * FROM plugins`).all();
+    // eslint-disable-next-line @typescript-eslint/no-explicit-any
+    return rows.map((row: any) => this.rowToManifest(row));
+  }
+
+  search(query: string): PluginManifest[] {
+    const pattern = `%${query}%`;
+    const rows = this.db.prepare(`SELECT * FROM plugins WHERE name LIKE ? OR description LIKE ?`).all(pattern, pattern);
+    // eslint-disable-next-line @typescript-eslint/no-explicit-any
+    return rows.map((row: any) => this.rowToManifest(row));
+  }
+
+  remove(name: string, version: string): boolean {
+    const info = this.db.prepare(`DELETE FROM plugins WHERE name = ? AND version = ?`).run(name, version);
+    return info.changes > 0;
+  }
+
+  listVersions(name: string): string[] {
+    const rows = this.db.prepare(`SELECT version FROM plugins WHERE name = ?`).all(name);
+    return rows.map((r: any) => r.version);
+  }
+
+  update(name: string, version: string, updates: Partial<PluginManifest>): void {
+    const existing = this.getVersion(name, version);
+    if (!existing) return;
+    const merged: PluginManifest = { ...existing, ...updates };
+    this.register(merged);
+  }
+
+  private rowToManifest(row: { name: string; version: string; description: string; author: string; dependencies: string; entryPoint: string; permissions: string; }): PluginManifest {
+    return {
+      name: row.name,
+      version: row.version,
+      description: row.description,
+      author: row.author,
+      dependencies: JSON.parse(row.dependencies || '{}'),
+      entryPoint: row.entryPoint,
+      permissions: JSON.parse(row.permissions || '[]'),
+    };
+  }
+}
