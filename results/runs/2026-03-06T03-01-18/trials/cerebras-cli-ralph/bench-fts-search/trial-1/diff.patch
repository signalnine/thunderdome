age as string) || '1');\n39:       const perPage = 20;\n40:       const offset = (page - 1) * perPage;\n41: \n42:       const countStmt = db.prepare('SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?');\n43:       const totalRow = countStmt.get(q) as { total: number };\n44:       const total = totalRow.total;\n45: \n46:       const searchStmt = db.prepare(`\n47:         SELECT notes.id, notes.title,\n48:                snippet(notes_fts, 1, '<mark>', '</mark>', '...', 10) AS snippet,\n49:                bm25(notes_fts) AS rank\n50:         FROM notes_fts JOIN notes ON notes.id = notes_fts.rowid\n51:         WHERE notes_fts MATCH ?\n52:         ORDER BY rank\n53:         LIMIT ? OFFSET ?\n54:       `);\n55:       const rows = searchStmt.all(q, perPage, offset) as any[];\n56:       const results: SearchResult[] = rows.map(row => ({\n57:         id: row.id,\n58:         title: row.title,\n59:         snippet: row.snippet || '',\n60:         rank: row.rank,\n61:       }));\n62:       res.json({ results, total, page, perPage });\n63:     } catch (err) {\n64:       next(err);\n65:     }\n66:   });\n67: \n68:   // GET /notes/search/suggest - Autocomplete suggestions\n69:   router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n70:     try {\n71:       const q = (req.query.q as string | undefined)?.trim();\n72:       if (!q) {\n73:         throw new ValidationError('Missing required query parameter \"q\"');\n74:       }\n75:       const suggestStmt = db.prepare(`\n76:         SELECT id, title FROM notes\n77:         WHERE LOWER(title) LIKE LOWER(?) || '%' OR LOWER(body) LIKE LOWER(?) || '%'\n78:         LIMIT 5\n79:       `);\n80:       const rows = suggestStmt.all(q, q) as any[];\n81:       const results: SuggestResult[] = rows.map(row => ({ id: row.id, title: row.title }));\n82:       res.json({ results });\n83:     } catch (err) {\n84:       next(err);\n85:     }\n86:   });\n87: \n88:   // POST /notes - Create a new note