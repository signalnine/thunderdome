   `);\n132:       const rows = searchStmt.all(q, perPage, offset) as any[];\n133:       const results: SearchResult[] = rows.map(row => ({\n134:         id: row.id,\n135:         title: row.title,\n136:         snippet: row.snippet || '',\n137:         rank: row.rank,\n138:       }));\n139:       res.json({ results, total, page, perPage });\n140:     } catch (err) {\n141:       next(err);\n142:     }\n143:   });\n144: \n145:   // GET /notes/search/suggest - Autocomplete suggestions\n146:   router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n147:     try {\n148:       const q = (req.query.q as string | undefined)?.trim();\n149:       if (!q) {\n150:         throw new ValidationError('Missing required query parameter \"q\"');\n151:       }\n152:       const suggestStmt = db.prepare(`\n153:         SELECT id, title FROM notes\n154:         WHERE LOWER(title) LIKE LOWER(?) || '%' OR LOWER(body) LIKE LOWER(?) || '%'\n155:         LIMIT 5\n156:       `);\n157:       const rows = suggestStmt.all(q, q) as any[];\n158:       const results: SuggestResult[] = rows.map(row => ({ id: row.id, title: row.title }));\n159:       res.json({ results });\n160:     } catch (err) {\n161:       next(err);\n162:     }\n163:   });\n164: \n165:   // PUT /notes/:id - Update a note\n166:   router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n167:     try {\n168:       const id = parseInt(req.params.id);\n169:       const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n170:       if (!existing) {\n171:         throw new NotFoundError('Note not found');\n172:       }\n173:       const input = req.body as Partial<NoteInput>;\n174:       const title = input.title ?? existing.title;\n175:       const body = input.body ?? existing.body;\n176:       const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n177:       const stmt = db.prepare('UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime(\\'now\\') WHERE id = ?');\n178:       stmt.run(title, body, tags, id);\n179:       const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n180:       res.json({ note });\n181:     } catch (err) {\n182:       next(err);\n183:     }\n184:   });\n185: \n186:   // GET /notes/search - Full-text search\n187:   router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n188:     try {\n189:       const q = (req.query.q as string | undefined)?.trim();\n190:       if (!q) {\n191:         throw new ValidationError('Missing required query parameter \"q\"');\n192:       }\n193:       const page = parseInt((req.query.page as string) || '1');\n194:       const perPage = 20;\n195:       const offset = (page - 1) * perPage;\n196: \n197:       const countStmt = db.prepare('SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?');\n198:       const totalRow = countStmt.get(q) as { total: number };\n199:       const total = totalRow.total;\n200: \n201:       const searchStmt = db.prepare(`\n202:         SELECT notes.id, notes.title,\n203:                snippet(notes_fts, 1, '<mark>', '</mark>', '...', 10) AS snippet,\n204:                bm25(notes_fts) AS rank\n205:         FROM notes_fts JOIN notes ON notes.id = notes_fts.rowid\n206:         WHERE notes_fts MATCH ?\n207:         ORDER BY rank\n208:         LIMIT ? OFFSET ?\n209:       `);\n210:       const rows = searchStmt.all(q, perPage, offset) as any[];\n211:       const results: SearchResult[] = rows.map(row => ({\n212:         id: row.id,\n213:         title: row.title,\n214:         snippet: row.snippet || '',\n215:         rank: row.rank,\n216:       }));\n217:       res.json({ results, total, page, perPage });\n218:     } catch (err) {\n219:       next(err);\n220:     }\n221:   });\n222: \n223:   // GET /notes/search/suggest - Autocomplete suggestions\n224:   router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n225:     try {\n226:       const q = (req.query.q as string | undefined)?.trim();\n227:       if (!q) {\n228:         throw new ValidationError('Missing required query parameter \"q\"');\n229:       }\n230:       const suggestStmt = db.prepare(`\n231:         SELECT id, title FROM notes\n232:         WHERE LOWER(title) LIKE LOWER(?) || '%' OR LOWER(body) LIKE LOWER(?) || '%'\n233:         LIMIT 5\n234:       `);\n235:       const rows = suggestStmt.all(q, q) as any[];\n236:       const results: SuggestResult[] = rows.map(row => ({ id: row.id, title: row.title }));\n237:       res.json({ results });\n238:     } catch (err) {\n239:       next(err);\n240:     }\n241:   });\n242: \n243:   // DELETE /notes/:id - Delete a note\n244:   router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n245:     try {\n246:       const id = parseInt(req.params.id);\n247:       const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n248:       if (!existing) {\n249:         throw new NotFoundError('Note not found');\n250:       }\n\n(File has more lines. Use 'offset' parameter to read beyond line 250)\n</content>","title":"src/routes.ts","metadata":{"preview":"import { Router, Request, Response, NextFunction } from 'express';\nimport Database from 'better-sqlite3';\nimport { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\nimport { NotFoundError, ValidationError } from './errors.js';\n\nexport function createRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // GET /notes - List all notes (optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const tag = req.query.tag as string | undefined;\n      let notes: Note[];\n      if (tag) {\n        const tagStmt = db.prepare(`\n          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n          WHERE json_each.value = ?\n          ORDER BY created_at 