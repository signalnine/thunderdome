press';\nimport Database from 'better-sqlite3';\nimport { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\nimport { NotFoundError, ValidationError } from './errors.js';\n\nexport function createRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // GET /notes - List all notes (optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const tag = req.query.tag as string | undefined;\n      let notes: Note[];\n      if (tag) {\n        const tagStmt = db.prepare(`\n          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n          WHERE json_each.value = ?\n          ORDER BY created_at DESC\n        `);\n        notes = tagStmt.all(tag) as Note[];\n      } else {\n        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n        notes = stmt.all() as Note[];\n      }\n      res.json({ notes });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/:id - Retrieve a single note\n  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n      const note = stmt.get(id) as Note | undefined;\n      if (!note) {\n        throw new NotFoundError('Note not found');\n      }\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // POST /notes - Create a new note\n  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const input = req.body as NoteInput;\n      if (!input.title || input.title.trim() === '') {\n        throw new ValidationError('Title is required');\n      }\n      if (!input.body || input.body.trim() === '') {\n        throw new ValidationError('Body is required');\n      }\n      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n      const stmt = db.prepare('INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)');\n      const result = stmt.run(input.title, input.body, tags);\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n      res.status(201).json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // PUT /notes/:id - Update a note\n  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n      const input = req.body as Partial<NoteInput>;\n      const title = input.title ?? existing.title;\n      const body = input.body ?? existing.body;\n      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n      const stmt = db.prepare('UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime(\\'now\\') WHERE id = ?');\n      stmt.run(title, body, tags, id);\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // DELETE /notes/:id - Delete a note\n  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n      res.status(204).send();\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/search - Full-text search\n  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = (req.query.q as string | undefined)?.trim();\n      if (!q) {\n        throw new ValidationError('Missing required query parameter \"q\"');\n      }\n      const page = parseInt((req.query.page as string) || '1');\n      const perPage = 20;\n      const offset = (page - 1) * perPage;\n\n      const countStmt = db.prepare('SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?');\n      const totalRow = countStmt.get(q) as { total: number };\n      const total = totalRow.total;\n\n      const searchStmt = db.prepare(`\n        SELECT notes.id, notes.title,\n               snippet(notes_fts, 1, '<mark>', '</mark>', '...', 10) AS snippet,\n               bm25(notes_fts) AS rank\n        FROM notes_fts JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY rank\n        LIMIT ? OFFSET ?\n      `);\n      const rows = searchStmt.all(q, perPage, offset) as any[];\n      const results: SearchResult[] = rows.map(row => ({\n        id: row.id,\n        title: row.title,\n        snippet: row.snippet || '',\n        rank: row.rank,\n      }));\n      res.json({ results, total, page, perPage });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/search/suggest - Autocomplete suggestions\n  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = (req.query.q as string | undefined)?.trim();\n      if (!q) {\n        throw new ValidationError('Missing required query parameter \"q\"');\n      }\n      const suggestStmt = db.prepare(`\n        SELECT id, title FROM notes\n        WHERE LOWER(title) LIKE LOWER(?) || '%' OR LOWER(body) LIKE LOWER(?) || '%'\n        LIMIT 5\n      `);\n      const rows = suggestStmt.all(q, q) as any[];\n      const results: SuggestResult[] = rows.map(row => ({ id: row.id, title: row.title }));\n      res.json({ results });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  return router;\n}\n","after":"import { Router, Request, Response, NextFunction } from 'express';\nimport Database from 'better-sqlite3';\nimport { Note, 