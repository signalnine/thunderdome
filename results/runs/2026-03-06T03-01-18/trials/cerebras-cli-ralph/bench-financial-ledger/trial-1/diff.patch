bits) {\n65:       if (!this.accounts.has(d.account)) {\n66:         throw new Error(`Account not found: ${d.account}`);\n67:       }\n68:     }\n69:     for (const c of credits) {\n70:       if (!this.accounts.has(c.account)) {\n71:         throw new Error(`Account not found: ${c.account}`);\n72:       }\n73:     }\n74: \n75:     const totalDebits = debits.reduce((sum, d) => sum + d.amount, 0);\n76:     const totalCredits = credits.reduce((sum, c) => sum + c.amount, 0);\n77:     if (totalDebits !== totalCredits) {\n78:       throw new Error(`Debits (${totalDebits}) must equal credits (${totalCredits})`);\n79:     }\n80: \n81:     for (const d of debits) {\n82:       if (d.amount <= 0) throw new Error('Amounts must be positive');\n83:     }\n84:     for (const c of credits) {\n85:       if (c.amount <= 0) throw new Error('Amounts must be positive');\n86:     }\n87: \n88:     const entry: JournalEntry = {\n89:       id: this.nextId++,\n90:       description,\n91:       debits: [...debits],\n92:       credits: [...credits],\n93:       date: date ?? new Date(),\n94:     };\n95:     this.entries.push(entry);\n96:     return entry;\n97:   }\n98: \n99:   getBalance(accountName: string): number {\n100:     const account = this.accounts.get(accountName);\n101:     if (!account) throw new Error(`Account not found: ${accountName}`);\n102: \n103:     let balance = 0;\n104:     for (const entry of this.entries) {\n105:       for (const d of entry.debits) {\n106:         if (d.account === accountName) balance += d.amount;\n107:       }\n108:       for (const c of entry.credits) {\n109:         if (c.account === accountName) balance -= c.amount;\n110:       }\n111:     }\n112: \n113:     return balance;\n114:   }\n115: \n116:   getTrialBalance(): BalanceEntry[] {\n117:     const result: BalanceEntry[] = [];\n118: \n119:     for (const [name, account] of this.accounts) {\n120:       let totalDebits = 0;\n121:       // eslint-disable-next-line prefer-const\n122:       let totalCredits = 0;\n123: \n124:       for (const entry of this.entries) {\n125:         for (const d of entry.debits) {\n126:           if (d.account === name) totalDebits += d.amount;\n127:         }\n128:         for (const c of entry.credits) {\n129:           if (c.account === name) totalDebits += c.amount;\n130:         }\n131:       }\n132: \n133:       result.push({\n134:         account: name,\n135:         type: account.type,\n136:         debit: totalDebits,\n137:         credit: totalCredits,\n138:       });\n139:     }\n140: \n141:     return result;\n142:   }\n143: \n144:   getStatement(\n145:     accountName: string,\n146:     startDate?: Date,\n147:     endDate?: Date\n148:   ): StatementLine[] {\n149:     const account = this.accounts.get(accountName);\n150:     if (!account) throw new Error(`Account not found: ${accountName}`);\n151: \n152:     const lines: StatementLine[] = [];\n153:     let runningBalance = 0;\n154: \n155:     const sorted = [...this.entries].sort(\n156:       (a, b) => a.date.getTime() - b.date.getTime()\n157:     );\n158: \n159:     for (const entry of sorted) {\n160:       if (startDate && entry.date.getTime() <= startDate.getTime()) continue;\n161:       if (endDate && entry.date.getTime() > endDate.getTime()) continue;\n162: \n163:       let debit = 0;\n164:       let credit = 0;\n165: \n166:       for (const d of entry.debits) {\n167:         if (d.account === accountName) debit += d.amount;\n168:       }\n169:       for (const c of entry.credits) {\n170:         if (c.account === accountName) credit += c.amount;\n171:       }\n172: \n173:       if (debit === 0 && credit === 0) continue;\n174: \n175:       runningBalance += debit + credit;\n176: \n177:       lines.push({\n178:         date: entry.date,\n179:         description: entry.description,\n180:         debit,\n181:         credit,\n182:         balance: runningBalance,\n183:       });\n184:     }\n185: \n186:     return lines;\n187:   }\n188: \n189:   splitEntry(\n190:     de