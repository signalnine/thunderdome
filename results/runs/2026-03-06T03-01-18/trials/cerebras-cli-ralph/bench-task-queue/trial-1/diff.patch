+import { describe, it, expect } from 'vitest';
+import { TaskQueue, TaskStatus } from '../src';
+
+describe('Phase 3: Priority Queue', () => {
+  it('processes higher priority tasks first', () => {
+    const queue = new TaskQueue();
+    const low = queue.add({ data: 'low' }, 8); // lower priority
+    const high = queue.add({ data: 'high' }, 2);
+    const mid = queue.add({ data: 'mid' }, 5);
+
+    const next1 = queue.getNextTask();
+    expect(next1?.id).toBe(high.id);
+    expect(next1?.status).toBe(TaskStatus.Processing);
+
+    const next2 = queue.getNextTask();
+    expect(next2?.id).toBe(mid.id);
+
+    const next3 = queue.getNextTask();
+    expect(next3?.id).toBe(low.id);
+  });
+
+  it('uses default priority when not provided', () => {
+    const queue = new TaskQueue();
+    const defaultTask = queue.add({ data: 'default' });
+    const high = queue.add({ data: 'high' }, 1);
+
+    expect(queue.getNextTask()?.id).toBe(high.id);
+    expect(queue.getNextTask()?.id).toBe(defaultTask.id);
+  });
+
+  it('throws on invalid priority values', () => {
+    const queue = new TaskQueue();
+    expect(() => queue.add({ data: 'bad' }, 0)).toThrow();
+    expect(() => queue.add({ data: 'bad' }, 11)).toThrow();
+    expect(() => queue.add({ data: 'bad' }, 3.5)).toThrow();
+  });
+});
