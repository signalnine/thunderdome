+import { TaskQueue } from './queue.js';
+
+/**
+ * Manages multiple named task queues (Phase 2).
+ * Each queue operates independently.
+ */
+export class QueueManager {
+  private queues: Map<string, TaskQueue> = new Map();
+
+  /** Retrieve an existing queue or create a new one with the given name. */
+  getQueue(name: string): TaskQueue {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, new TaskQueue());
+    }
+    // Non-null assertion because we just ensured existence
+    return this.queues.get(name)!;
+  }
+
+  /** List all registered queue names. */
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+}
