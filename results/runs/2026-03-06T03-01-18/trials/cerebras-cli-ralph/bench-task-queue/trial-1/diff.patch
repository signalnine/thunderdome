+/**
+ * Task definition and status enumeration for the in-memory task queue.
+ */
+export type TaskPayload = unknown;
+
+export enum TaskStatus {
+  Pending = 'pending',
+  Processing = 'processing',
+  Completed = 'completed',
+  Failed = 'failed',
+  Cancelled = 'cancelled',
+}
+
+export interface Task {
+  /** Optional priority (higher value = higher priority) */
+  priority?: number;
+  /** Unique identifier for the task */
+  id: string;
+  /** Payload provided when the task was added */
+  payload: TaskPayload;
+  /** Current status of the task */
+  status: TaskStatus;
+  /** Timestamp of creation */
+  createdAt: number;
+  /** Timestamp when processing started (optional) */
+  processingStartedAt?: number;
+}
