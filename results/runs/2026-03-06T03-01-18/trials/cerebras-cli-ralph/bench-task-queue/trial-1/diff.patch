+import { describe, it, expect } from 'vitest';
+import { TaskQueue, TaskStatus } from '../src';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  it('adds a task and retrieves it in order', () => {
+    const queue = new TaskQueue();
+    const task1 = queue.add({ data: 'first' });
+    const task2 = queue.add({ data: 'second' });
+
+    expect(queue.pendingCount()).toBe(2);
+
+    const next1 = queue.getNextTask();
+    expect(next1).not.toBeNull();
+    expect(next1?.id).toBe(task1.id);
+    expect(next1?.status).toBe(TaskStatus.Processing);
+
+    const next2 = queue.getNextTask();
+    expect(next2?.id).toBe(task2.id);
+    expect(next2?.status).toBe(TaskStatus.Processing);
+
+    // No more pending tasks
+    expect(queue.getNextTask()).toBeNull();
+  });
+});
