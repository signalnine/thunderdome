n highest priority first; for equal priority,\n * the earliest added task is returned.\n */\nexport class TaskQueue {\n  /** Internal storage of all tasks in insertion order */\n  private tasks: Task[] = [];\n\n  /** Add a new task with the given payload and optional priority. */\n  add(payload: unknown, priority?: number): Task {\n    const task: Task = {\n      id: randomUUID(),\n      payload,\n      status: TaskStatus.Pending,\n      createdAt: Date.now(),\n      priority,\n    };\n    this.tasks.push(task);\n    return task;\n  }\n\n  /** Retrieve the next pending task based on priority, marking it as processing. */\n  getNextTask(): Task | null {\n    // Filter pending tasks\n    const pending = this.tasks.filter(t => t.status === TaskStatus.Pending);\n    if (pending.length === 0) return null;\n    // Find task with highest priority (default 0). Preserve FIFO for equal priority.\n    let next = pending[0];\n    let maxPriority = next.priority ?? 0;\n    for (const t of pending) {\n      const p = t.priority ?? 0;\n      if (p > maxPriority) {\n        next = t;\n        maxPriority = p;\n      }\n    }\n    next.status = TaskStatus.Processing;\n    next.processingStartedAt = Date.now();\n    return next;\n  }\n\n  /** Number of tasks currently pending. */\n  pendingCount(): number {\n    return this.tasks.filter(t => t.status === TaskStatus.Pending).length;\n  }\n}\n","after":"import { Task, TaskStatus } from './task';\nimport { randomUUID } from 'crypto';\n\n/**\n * Simple FIFO in-memory task queue (Phase 1) with priority support (Phase 3).\n * Tasks are retrieved based on highest priority first; for equal priority,\n * the earliest added task is returned.\n */\nexport class TaskQueue {\n  /** Internal storage of all tasks in insertion order */\n  private tasks: Task[] = [];\n\n  /** Add a new task with the given payload and optional priority.\n   * Priority must be an integer between 1 (highest) and 10 (lowest).\n   * If omitted, defaults to 5.\n   */\n  add(payload: unknown, priority?: number): Task {\n    // Validate priority if provided\n    let p: number | undefined = priority;\n    if (p !== undefined) {\n      if (!Number.isInteger(p) || p < 1 || p > 10) {\n        throw new Error('Priority must be an integer between 1 and 10');\n      }\n    } else {\n      p = 5; // default priority\n    }\n    const task: Task = {\n      id: randomUUID(),\n      payload,\n      status: TaskStatus.Pending,\n      createdAt: Date.now(),\n      priority: p,\n    };\n    this.tasks.push(task);\n    return task;\n  }\n\n  /** Retrieve the next pending task based on priority, marking it as processing. */\n  getNextTask(): Task | null {\n    // Filter pending tasks\n    const pending = this.tasks.filter(t => t.status === TaskStatus.Pending);\n    if (pending.length === 0) return null;\n    // Find task with highest priority (default 0). Preserve FIFO for equal priority.\n    let next = pending[0];\n    let maxPriority = next.priority ?? 0;\n    for (const t of pending) {\n      const p = t.priority ?? 0;\n      if (p > maxPriority) {\n        next = t;\n        maxPriority = p;\n      }\n    }\n    next.status = TaskStatus.Processing;\n    next.processingStartedAt = Date.now();\n    return next;\n  }\n\n  /** Number of tasks currently pending. */\n  pendingCount(): number {\n    return this.tasks.filter(t => t.status === TaskStatus.Pending).length;\n  }\n}\n","additions":14,"deletions":2},"truncated":false},"time":{"start":1772766639579,"end":1772766649165}}}}
