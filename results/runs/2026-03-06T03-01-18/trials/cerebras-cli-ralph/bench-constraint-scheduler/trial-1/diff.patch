+/**
+ * Constraint‑Based Event Scheduler
+ *
+ * Implements a greedy scheduler that respects capacity, time windows, gaps,
+ * prerequisite ordering, and preferred rooms. It maximizes the number of
+ * scheduled events by attempting to place each event at the earliest possible
+ * time in any suitable room.
+ */
+
+export interface Event {
+  id: string;
+  name: string;
+  duration: number; // minutes
+  attendees?: number; // default 1
+  prerequisites?: string[]; // event ids that must finish before this starts
+  preferredRoom?: string; // optional hint
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number; // minutes from midnight
+  endTime: number; // minutes from midnight
+  gap?: number; // minutes between events in same room (default 15)
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detects cycles in the prerequisite graph. Throws an Error if a cycle is found.
+ */
+function detectCycle(events: Map<string, Event>): void {
+  const visited = new Set<string>();
+  const recStack = new Set<string>();
+
+  const dfs = (id: string): boolean => {
+    if (recStack.has(id)) {
+      // cycle detected
+      return true;
+    }
+    if (visited.has(id)) return false;
+    visited.add(id);
+    recStack.add(id);
+    const ev = events.get(id);
+    if (ev && ev.prerequisites) {
+      for (const pre of ev.prerequisites) {
+        // self‑reference also counts as cycle
+        if (!events.has(pre)) continue; // unknown prerequisite will be ignored later
+        if (dfs(pre)) return true;
+      }
+    }
+    recStack.delete(id);
+    return false;
+  };
+
+  for (const id of events.keys()) {
+    if (dfs(id)) {
+      throw new Error('Prerequisite cycle detected');
+    }
+  }
+}
+
+/** Returns a topological ordering of events using Kahn's algorithm. */
+function topologicalOrder(events: Map<string, Event>): Event[] {
+  // compute indegree
+  const indegree = new Map<string, number>();
+  for (const id of events.keys()) indegree.set(id, 0);
+  for (const ev of events.values()) {
+    if (ev.prerequisites) {
+      for (const pre of ev.prerequisites) {
+        if (!events.has(pre)) continue; // ignore missing
+        indegree.set(ev.id, (indegree.get(ev.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of indegree.entries()) {
+    if (deg === 0) queue.push(id);
+  }
+  const ordered: Event[] = [];
+  while (queue.length) {
+    const id = queue.shift()!;
+    const ev = events.get(id)!;
+    ordered.push(ev);
+    if (ev.prerequisites) {
+      // actually need to reduce indegree of events that depend on this
+    }
+    // find events that have this as prerequisite
+    for (const [eid, e] of events.entries()) {
+      if (e.prerequisites && e.prerequisites.includes(id)) {
+        indegree.set(eid, (indegree.get(eid) ?? 0) - 1);
+        if (indegree.get(eid) === 0) queue.push(eid);
+      }
+    }
+  }
+
+  // If not all events are ordered, there was a cycle but we already checked earlier.
+  return ordered;
+}
+
+/** Helper to find earliest start time for an event in a particular room. */
+function findEarliestSlot(
+  roomSchedule: Assignment[],
+  event: Event,
+  earliestFrom: number,
+  options: ScheduleOptions,
+): number | null {
+  const gap = options.gap ?? 15;
+  const duration = event.duration;
+  // sort schedule by start time (should already be sorted)
+  const sorted = roomSchedule.slice().sort((a, b) => a.startTime - b.startTime);
+
+  // Helper to check gap constraints around a candidate start
+  const canPlace = (start: number): boolean => {
+    const end = start + duration;
+    if (end > options.endTime) return false;
+    // check previous assignment
+    const prev = sorted.filter(a => a.endTime + gap <= start).pop();
+    if (prev && start < prev.endTime + gap) return false;
+    // check next assignment
+    const next = sorted.find(a => a.startTime - gap < end && a.startTime > start);
+    if (next && end + gap > next.startTime) return false;
+    return true;
+  };
+
+  // Try to fit before first assignment
+  if (sorted.length === 0) {
+    const candidate = Math.max(earliestFrom, options.startTime);
+    if (candidate + duration <= options.endTime) return candidate;
+    return null;
+  }
+
+  // Check gaps between existing assignments
+  // First possible slot is before first assignment
+  const first = sorted[0];
+  let candidate = Math.max(earliestFrom, options.startTime);
+  if (candidate + duration + gap <= first.startTime) {
+    if (canPlace(candidate)) return candidate;
+  }
+
+  // Iterate over gaps
+  for (let i = 0; i < sorted.length - 1; i++) {
+    const cur = sorted[i];
+    const nxt = sorted[i + 1];
+    candidate = Math.max(earliestFrom, cur.endTime + gap);
+    // ensure enough room before nxt
+    if (candidate + duration + gap <= nxt.startTime) {
+      if (canPlace(candidate)) return candidate;
+    }
+  }
+
+  // After last assignment
+  const last = sorted[sorted.length - 1];
+  candidate = Math.max(earliestFrom, last.endTime + gap);
+  if (candidate + duration <= options.endTime) {
+    if (canPlace(candidate)) return candidate;
+  }
+  return null;
+}
+
+/** Main scheduler function */
+export function schedule(
+  eventsInput: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+  // Map events for fast lookup
+  const eventsMap = new Map<string, Event>();
+  for (const ev of eventsInput) {
+    eventsMap.set(ev.id, { ...ev, attendees: ev.attendees ?? 1, prerequisites: ev.prerequisites ?? [] });
+  }
+
+  // Detect cycles early
+  detectCycle(eventsMap);
+
+  // Topological order ensures prerequisites are scheduled first
+  const orderedEvents = topologicalOrder(eventsMap);
+
+  // Prepare room schedules
+  const roomSchedules = new Map<string, Assignment[]>();
+  for (const room of rooms) {
+    roomSchedules.set(room.id, []);
+  }
+
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  // Helper to get end time of a prerequisite
+  const getPrereqEnd = (preId: string): number => {
+    const assign = assignments.find(a => a.eventId === preId);
+    return assign ? assign.endTime : options.startTime; // if not scheduled, treat as startTime (will cause fail later)
+  };
+
+  for (const ev of orderedEvents) {
+    // If any prerequisite couldn't be scheduled, this event must be unscheduled.
+    const unmetPrereq = (ev.prerequisites ?? []).some(preId => unscheduled.includes(preId));
+    if (unmetPrereq) {
+      unscheduled.push(ev.id);
+      continue;
+    }
+    // compute earliest start based on prerequisites
+    let earliestFrom = options.startTime;
+    for (const preId of ev.prerequisites ?? []) {
+      const preEnd = getPrereqEnd(preId);
+      earliestFrom = Math.max(earliestFrom, preEnd + gap);
+    }
+    // Filter rooms by capacity
+    const suitableRooms = rooms.filter(r => (ev.attendees ?? 1) <= r.capacity);
+    let bestRoomId: string | null = null;
+    let bestStart: number | null = null;
+
+    // Try preferred room first
+    if (ev.preferredRoom) {
+      const prefRoom = rooms.find(r => r.id === ev.preferredRoom && (ev.attendees ?? 1) <= r.capacity);
+      if (prefRoom) {
+        const slot = findEarliestSlot(roomSchedules.get(prefRoom.id)!, ev, earliestFrom, options);
+        if (slot !== null) {
+          bestRoomId = prefRoom.id;
+          bestStart = slot;
+        }
+      }
+    }
+
+    // If not placed yet, try all suitable rooms and pick earliest start
+    if (bestStart === null) {
+      for (const room of suitableRooms) {
+        const slot = findEarliestSlot(roomSchedules.get(room.id)!, ev, earliestFrom, options);
+        if (slot !== null) {
+          if (bestStart === null || slot < bestStart) {
+            bestStart = slot;
+            bestRoomId = room.id;
+          }
+        }
+      }
+    }
+
+    if (bestRoomId !== null && bestStart !== null) {
+      const assignment: Assignment = {
+        eventId: ev.id,
+        roomId: bestRoomId,
+        startTime: bestStart,
+        endTime: bestStart + ev.duration,
+      };
+      assignments.push(assignment);
+      const schedule = roomSchedules.get(bestRoomId)!;
+      schedule.push(assignment);
+    } else {
+      unscheduled.push(ev.id);
+    }
+  }
+
+  // Sort assignments by start time for deterministic output
+  assignments.sort((a, b) => a.startTime - b.startTime);
+
+  return { assignments, unscheduled };
+}
+
+export default schedule;
