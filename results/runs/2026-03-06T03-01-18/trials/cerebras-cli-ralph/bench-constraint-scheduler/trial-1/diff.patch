+import { describe, it, expect } from 'vitest';
+import { schedule } from '../scheduler.js';
+
+describe('Scheduler basic functionality', () => {
+  it('schedules simple events', () => {
+    const events = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+      { id: 'e2', name: 'Event 2', duration: 30, attendees: 3, prerequisites: ['e1'] },
+    ];
+    const rooms = [{ id: 'r1', name: 'Room 1', capacity: 10 }];
+    const options = { startTime: 540, endTime: 1020, gap: 15 };
+    const result = schedule(events, rooms, options);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments).toHaveLength(2);
+    // Ensure e2 starts after e1 ends + gap
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + options.gap);
+  });
+});
