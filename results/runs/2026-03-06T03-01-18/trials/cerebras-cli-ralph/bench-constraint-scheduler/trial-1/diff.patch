if (recStack.has(id)) {\n52:       // cycle detected\n53:       return true;\n54:     }\n55:     if (visited.has(id)) return false;\n56:     visited.add(id);\n57:     recStack.add(id);\n58:     const ev = events.get(id);\n59:     if (ev && ev.prerequisites) {\n60:       for (const pre of ev.prerequisites) {\n61:         // self‑reference also counts as cycle\n62:         if (!events.has(pre)) continue; // unknown prerequisite will be ignored later\n63:         if (dfs(pre)) return true;\n64:       }\n65:     }\n66:     recStack.delete(id);\n67:     return false;\n68:   };\n69: \n70:   for (const id of events.keys()) {\n71:     if (dfs(id)) {\n72:       throw new Error('Prerequisite cycle detected');\n73:     }\n74:   }\n75: }\n76: \n77: /** Returns a topological ordering of events using Kahn's algorithm. */\n78: function topologicalOrder(events: Map<string, Event>): Event[] {\n79:   // compute indegree\n80:   const indegree = new Map<string, number>();\n81:   for (const id of events.keys()) indegree.set(id, 0);\n82:   for (const ev of events.values()) {\n83:     if (ev.prerequisites) {\n84:       for (const pre of ev.prerequisites) {\n85:         if (!events.has(pre)) continue; // ignore missing\n86:         indegree.set(ev.id, (indegree.get(ev.id) ?? 0) + 1);\n87:       }\n88:     }\n89:   }\n90: \n91:   const queue: string[] = [];\n92:   for (const [id, deg] of indegree.entries()) {\n93:     if (deg === 0) queue.push(id);\n94:   }\n95:   const ordered: Event[] = [];\n96:   while (queue.length) {\n97:     const id = queue.shift()!;\n98:     const ev = events.get(id)!;\n99:     ordered.push(ev);\n100:     if (ev.prerequisites) {\n101:       // actually need to reduce indegree of events that depend on this\n102:     }\n103:     // find events that have this as prerequisite\n104:     for (const [eid, e] of events.entries()) {\n105:       if (e.prerequisites && e.prerequisites.includes(id)) {\n106:         indegree.set(eid, (indegree.get(eid) ?? 0) - 1);\n107:         if (indegree.get(eid) === 0) queue.push(eid);\n108:       }\n109:     }\n110:   }\n111: \n112:   // If not all events are ordered, there was a cycle but we already checked earlier.\n113:   return ordered;\n114: }\n115: \n116: /** Helper to find earliest start time for an event in a particular room. */\n117: function findEarliestSlot(\n118:   roomSchedule: Assignment[],\n119:   event: Event,\n120:   earliestFrom: number,\n121:   options: ScheduleOptions,\n122: ): number | null {\n123:   const gap = options.gap ?? 15;\n124:   const duration = event.duration;\n125:   // sort schedule by start time (should already be sorted)\n126:   const sorted = roomSchedule.slice().sort((a, b) => a.startTime - b.startTime);\n127: \n128:   // Helper to check gap constraints around a candidate start\n129:   const canPlace = (start: number): boolean => {\n130:     const end = start + duration;\n131:     if (end > options.endTime) return false;\n132:     // check previous assignment\n133:     const prev = sorted.filter(a => a.endTime + gap <= start).pop();\n134:     if (prev && start < prev.endTime + gap) return false;\n135:     // check next assignment\n136:     const next = sorted.find(a => a.startTime - gap < end && a.startTime > start);\n137:     if (next && end + gap > next.startTime) return false;\n138:     return true;\n139:   };\n140: \n141:   // Try to fit before first assignment\n142:   if (sorted.length === 0) {\n143:     const candidate = Math.max(earliestFrom, options.startTime);\n144:     if (candidate + duration <= options.endTime) return candidate;\n145:     return null;\n146:   }\n147: \n148:   // Check gaps between existing assignments\n149:   // First possible slot is before first assignment\n150:   const first = sorted[0];\n151:   let candidate = Math.max(earliestFrom, options.startTime);\n152:   if (candidate + duration + gap <= first.startTime) {\n153:     if (canPlace(candidate)) return candidate;\n154:   }\n155: \n156:   // Iterate over gaps\n157:   for (let i = 0