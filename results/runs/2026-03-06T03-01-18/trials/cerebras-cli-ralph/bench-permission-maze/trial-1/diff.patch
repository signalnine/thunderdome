+import { describe, it, beforeEach, expect } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/index';
+import { resetData } from '../src/app';
+
+let app = createApp();
+
+beforeEach(() => {
+  // recreate app and reset in‑memory stores
+  app = createApp();
+  // clear data stores
+  resetData();
+});
+
+describe('User registration and authentication', () => {
+  it('should register and login users', async () => {
+    const regRes = await request(app).post('/auth/register').send({ username: 'alice', password: 'pw' });
+    expect(regRes.status).toBe(201);
+    const loginRes = await request(app).post('/auth/login').send({ username: 'alice', password: 'pw' });
+    expect(loginRes.status).toBe(200);
+    expect(loginRes.body).toHaveProperty('token');
+  });
+});
+
+describe('Folder and document CRUD with permissions', () => {
+  let tokenAlice: string;
+  let tokenBob: string;
+  let folderId: string;
+  let docId: string;
+
+  beforeEach(async () => {
+    // register two users and capture their IDs
+    const regAlice = await request(app).post('/auth/register').send({ username: 'alice', password: 'pw' });
+    const regBob = await request(app).post('/auth/register').send({ username: 'bob', password: 'pw' });
+    const loginAlice = await request(app).post('/auth/login').send({ username: 'alice', password: 'pw' });
+    tokenAlice = loginAlice.body.token;
+    const loginBob = await request(app).post('/auth/login').send({ username: 'bob', password: 'pw' });
+    tokenBob = loginBob.body.token;
+    // store user IDs for sharing
+    const aliceId = regAlice.body.id;
+    const bobId = regBob.body.id;
+    // expose via closure variables
+    (global as any).aliceUserId = aliceId;
+    (global as any).bobUserId = bobId;
+  });
+
+  it('alice creates folder and document, shares with bob as viewer, bob can read but not edit', async () => {
+    // create folder
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${tokenAlice}`)
+      .send({ name: 'MyFolder' });
+    expect(folderRes.status).toBe(201);
+    folderId = folderRes.body.id;
+
+    // create document
+    const docRes = await request(app)
+      .post(`/folders/${folderId}/documents`)
+      .set('Authorization', `Bearer ${tokenAlice}`)
+      .send({ title: 'Doc1', content: 'Hello' });
+    expect(docRes.status).toBe(201);
+    docId = docRes.body.id;
+
+    // share folder with bob as viewer
+    const bobId = (global as any).bobUserId as string;
+    const shareRes = await request(app)
+      .post(`/folders/${folderId}/share`)
+      .set('Authorization', `Bearer ${tokenAlice}`)
+      .send({ userId: bobId, role: 'viewer' });
+    expect(shareRes.status).toBe(200);
+    // bob should be able to read the folder
+    const folderGet = await request(app)
+      .get(`/folders/${folderId}`)
+      .set('Authorization', `Bearer ${tokenBob}`);
+    expect(folderGet.status).toBe(200);
+    // bob should be able to read the document
+    const docGet = await request(app)
+      .get(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${tokenBob}`);
+    expect(docGet.status).toBe(200);
+    // bob should NOT be able to edit the document
+    const docPatch = await request(app)
+      .patch(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${tokenBob}`)
+      .send({ title: 'Edited' });
+    expect(docPatch.status).toBe(403);
+  });
+});
