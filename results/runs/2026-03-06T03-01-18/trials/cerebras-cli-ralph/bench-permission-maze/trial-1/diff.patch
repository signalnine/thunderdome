f (!userId) return res.status(401).json({ error: 'Invalid token' });\n34:   (req as any).userId = userId;\n35:   next();\n36: }\n37: \n38: function getUserRoleForFolder(userId: string, folderId: string): Role | null {\n39:   const shares = folderShares.get(folderId) || [];\n40:   const direct = shares.find(s => s.userId === userId);\n41:   // Check inheritance from parent folders\n42:   const folder = folders.get(folderId);\n43:   let inherited: Role | null = null;\n44:   if (folder && folder.parentId) {\n45:     const parentRole = getUserRoleForFolder(userId, folder.parentId);\n46:     inherited = parentRole;\n47:   }\n48:   const role = direct?.role || inherited || null;\n49:   // Owner override\n50:   if (folder && folder.ownerId === userId) return 'owner';\n51:   return role;\n52: }\n53: \n54: function getUserRoleForDocument(userId: string, docId: string): Role | null {\n55:   const doc = documents.get(docId);\n56:   if (!doc) return null;\n57:   // Owner check\n58:   if (doc.ownerId === userId) return 'owner';\n59:   // Direct shares on document\n60:   const shares = documentShares.get(docId) || [];\n61:   const direct = shares.find(s => s.userId === userId);\n62:   // Inherit from folder hierarchy\n63:   const folderRole = getUserRoleForFolder(userId, doc.folderId);\n64:   const roles = [direct?.role, folderRole].filter(Boolean) as Role[];\n65:   if (roles.length === 0) return null;\n66:   // Resolve most permissive\n67:   if (roles.includes('owner')) return 'owner';\n68:   if (roles.includes('editor')) return 'editor';\n69:   return 'viewer';\n70: }\n71: \n72: function requireRole(minRole: Role) {\n73:   return (req: Request, res: Response, next: NextFunction) => {\n74:     const userId = (req as any).userId as string;\n75:     const { resourceType, id } = req.params;\n76:     let role: Role | null = null;\n77:     if (resourceType === 'folders') {\n78:       role = getUserRoleForFolder(userId, id);\n79:     } else if (resourceType === 'documents') {\n80:       role = getUserRoleForDocument(userId, id);\n81:     } else {\n82:       return res.status(400).json({ error: 'Invalid resource type' });\n83:     }\n84:     const hierarchy = { viewer: 1, editor: 2, owner: 3 };\n85:     if (!role || hierarchy[role] < hierarchy[minRole]) {\n86:       return res.status(403).json({ error: 'Insufficient permissions' });\n87:     }\n88:     (req as any).role = role;\n89:     next();\n90:   };\n91: }\n92: \n93: const app = express();\n94: app.use(express.json());\n95: \n96: // Auth routes\n97: app.post('/auth/register', (req, res) => {\n98:   const { username, password } = req.body;\n99:   if (!username || !password) return res.status(400).json({ error: 'Missing fields' });\n100:   // simple uniqueness check\n101:   if ([...users.values()].some(u => u.username === username)) {\n102:     return res.status(409).json({ error: 'User exists' });\n103:   }\n104:   const id = randomUUID();\n105:   const user: User = { id, username, password };\n106:   users.set(id, user);\n107:   logActivity(id, 'register', `user:${id}`);\n108:   res.status(201).json({ id, username });\n109: });\n110: \n111: app.post('/auth/login', (req, res) => {\n112:   const { username, password } = req.body;\n113:   const user = [...users.values()].find(u => u.username === username && u.password === password);\n114:   if (!user) return res.status(401).json({ error: 'Invalid credentials' });\n115:   const token = randomUUID();\n116:   tokens.set(token, user.id);\n117:   logActivity(user.id, 'login', `user:${user.id}`);\n118:   res.json({ token });\n119: });\n120: \n121: // Folder CRUD\n122: app.post('/folders', authenticate, (req, res) => {\n123:   const { name, parentId } = req.body;\n124:   const userId = (req as any).userId as string;\n125:   if (!name) return res.status(400).json({ error: 'Name required' });\n126:   // Validate parent exists if provided\n127:   if (parentId && !folders.has(parentId)) {\n128:     return res.status(400).json({ error: 'Parent folder not found' });\n129:   }\n130:   const id = randomUUID();\n131:   const folder: Folder = { id, name, parentId, ownerId: userId };\n132:   folders.set(id, folder);\n133:   // Owner share automatically\n134:   const ownerShare: Share = { userId, role: 'owner' };\n135:   folderShares.set(id, [ownerShare]);\n136:   logActivity(userId, 'create_folder', `folder:${id}`);\n137:   res.status(201).json(folder);\n138: });\n139: \n140: app.get('/folders/:id', authenticate, (req, res) => {\n141:   const { id } = req.params;\n142:   const folder = folders.get(id);\n143:   if (!folder) return res.status(404).json({ error: 'Folder not found' });\n144:   const userId = (req as any).userId as string;\n145:   const role = getUserRoleForFolder(userId, id);\n146:   if (!role) return res.status(403).json({ error: 'No access' });\n147:   res.json(folder);\n148: });\n149: \n150: app.patch('/folders/:id', authenticate, requireRole('editor'), (req, res) => {\n151:   const { id } = req.params;\n152:   const folder = folders.get(id);\n153:   if (!folder) return res.status(404).json({ error: 'Folder not found' });\n154:   const { name, parentId } = req.body;\n155:   if (name) folder.name = name;\n156:   if (parentId !== undefined) {\n157:     if (parentId && !folders.has(parentId)) {\n158:       return res.status(400).json({ error: 'Parent not found' });\n159:     }\n160:     // Prevent cycles\n161:     let cur = parentId;\n162:     while (cur) {\n163:       if (cur === id) return res.status(400).json({ error: 'Cycle detected' });\n164:       const p = folders.get(cur);\n165:       cur = p?.parentId;\n166:     }\n167:     folder.parentId = parentId;\n168:   }\n169:   logActivity((req as any).userId, 'update_folder', `folder:${id}`);\n170:   res.json(folder);\n171: });\n172: \n173: app.delete('/folders/:id', authenticate, requireRole('owner'), (req, res) => {\n174:   const { id } = req.params;\n175:   if (!folders.has(id)) return res.status(404).json({ error: 'Folder not found' });\n176:   // Delete 