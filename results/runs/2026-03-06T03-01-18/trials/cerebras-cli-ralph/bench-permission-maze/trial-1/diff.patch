diff --git a/src/app.ts b/src/app.ts
new file mode 100644
index 0000000..e1b01cc
--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,307 @@
+import express, { Request, Response, NextFunction } from 'express';
+import { randomUUID } from 'crypto';
+
+// Types
+type Role = 'viewer' | 'editor' | 'owner';
+interface User { id: string; username: string; password: string; }
+interface Folder { id: string; name: string; parentId?: string; ownerId: string; }
+interface Document { id: string; title: string; content: string; folderId: string; ownerId: string; }
+interface Share { userId: string; role: Role; }
+interface Activity { timestamp: number; userId: string; action: string; target: string; }
+
+// In‑memory stores
+const users = new Map<string, User>();
+const tokens = new Map<string, string>(); // token -> userId
+const folders = new Map<string, Folder>();
+const documents = new Map<string, Document>();
+const folderShares = new Map<string, Share[]>(); // folderId -> shares
+const documentShares = new Map<string, Share[]>(); // documentId -> shares
+const activityLog: Activity[] = [];
+
+// Helpers
+function logActivity(userId: string, action: string, target: string) {
+  activityLog.push({ timestamp: Date.now(), userId, action, target });
+}
+
+function authenticate(req: Request, res: Response, next: NextFunction) {
+  const auth = req.header('Authorization');
+  if (!auth || !auth.startsWith('Bearer ')) {
+    return res.status(401).json({ error: 'Missing token' });
+  }
+  const token = auth.slice(7);
+  const userId = tokens.get(token);
+  if (!userId) return res.status(401).json({ error: 'Invalid token' });
+  (req as Request).userId = userId;
+  next();
+}
+
+function getUserRoleForFolder(userId: string, folderId: string): Role | null {
+  const shares = folderShares.get(folderId) || [];
+  const direct = shares.find(s => s.userId === userId);
+  // Check inheritance from parent folders
+  const folder = folders.get(folderId);
+  let inherited: Role | null = null;
+  if (folder && folder.parentId) {
+    const parentRole = getUserRoleForFolder(userId, folder.parentId);
+    inherited = parentRole;
+  }
+  const role = direct?.role || inherited || null;
+  // Owner override
+  if (folder && folder.ownerId === userId) return 'owner';
+  return role;
+}
+
+function getUserRoleForDocument(userId: string, docId: string): Role | null {
+  const doc = documents.get(docId);
+  if (!doc) return null;
+  // Owner check
+  if (doc.ownerId === userId) return 'owner';
+  // Direct shares on document
+  const shares = documentShares.get(docId) || [];
+  const direct = shares.find(s => s.userId === userId);
+  // Inherit from folder hierarchy
+  const folderRole = getUserRoleForFolder(userId, doc.folderId);
+  const roles = [direct?.role, folderRole].filter(Boolean) as Role[];
+  if (roles.length === 0) return null;
+  // Resolve most permissive
+  if (roles.includes('owner')) return 'owner';
+  if (roles.includes('editor')) return 'editor';
+  return 'viewer';
+}
+
+function requireRole(minRole: Role) {
+  return (req: Request, res: Response, next: NextFunction) => {
+    const userId = (req as Request).userId as string;
+    const { resourceType, id } = req.params;
+    let role: Role | null = null;
+    if (resourceType === 'folders') {
+      role = getUserRoleForFolder(userId, id);
+    } else if (resourceType === 'documents') {
+      role = getUserRoleForDocument(userId, id);
+    } else {
+      return res.status(400).json({ error: 'Invalid resource type' });
+    }
+    const hierarchy = { viewer: 1, editor: 2, owner: 3 };
+    if (!role || hierarchy[role] < hierarchy[minRole]) {
+      return res.status(403).json({ error: 'Insufficient permissions' });
+    }
+    (req as Request).role = role;
+    next();
+  };
+}
+
+const app = express();
+app.use(express.json());
+
+// Auth routes
+app.post('/auth/register', (req, res) => {
+  const { username, password } = req.body;
+  if (!username || !password) return res.status(400).json({ error: 'Missing fields' });
+  // simple uniqueness check
+  if ([...users.values()].some(u => u.username === username)) {
+    return res.status(409).json({ error: 'User exists' });
+  }
+  const id = randomUUID();
+  const user: User = { id, username, password };
+  users.set(id, user);
+  logActivity(id, 'register', `user:${id}`);
+  res.status(201).json({ id, username });
+});
+
+app.post('/auth/login', (req, res) => {
+  const { username, password } = req.body;
+  const user = [...users.values()].find(u => u.username === username && u.password === password);
+  if (!user) return res.status(401).json({ error: 'Invalid credentials' });
+  const token = randomUUID();
+  tokens.set(token, user.id);
+  logActivity(user.id, 'login', `user:${user.id}`);
+  res.json({ token });
+});
+
+// Folder CRUD
+app.post('/folders', authenticate, (req, res) => {
+  const { name, parentId } = req.body;
+  const userId = (req as Request).userId as string;
+  if (!name) return res.status(400).json({ error: 'Name required' });
+  // Validate parent exists if provided
+  if (parentId && !folders.has(parentId)) {
+    return res.status(400).json({ error: 'Parent folder not found' });
+  }
+  const id = randomUUID();
+  const folder: Folder = { id, name, parentId, ownerId: userId };
+  folders.set(id, folder);
+  // Owner share automatically
+  const ownerShare: Share = { userId, role: 'owner' };
+  folderShares.set(id, [ownerShare]);
+  logActivity(userId, 'create_folder', `folder:${id}`);
+  res.status(201).json(folder);
+});
+
+app.get('/folders/:id', authenticate, (req, res) => {
+  const { id } = req.params;
+  const folder = folders.get(id);
+  if (!folder) return res.status(404).json({ error: 'Folder not found' });
+  const userId = (req as Request).userId as string;
+  const role = getUserRoleForFolder(userId, id);
+  if (!role) return res.status(403).json({ error: 'No access' });
+  res.json(folder);
+});
+
+app.patch('/folders/:id', authenticate, requireRole('editor'), (req, res) => {
+  const { id } = req.params;
+  const folder = folders.get(id);
+  if (!folder) return res.status(404).json({ error: 'Folder not found' });
+  const { name, parentId } = req.body;
+  if (name) folder.name = name;
+  if (parentId !== undefined) {
+    if (parentId && !folders.has(parentId)) {
+      return res.status(400).json({ error: 'Parent not found' });
+    }
+    // Prevent cycles
+    let cur = parentId;
+    while (cur) {
+      if (cur === id) return res.status(400).json({ error: 'Cycle detected' });
+      const p = folders.get(cur);
+      cur = p?.parentId;
+    }
+    folder.parentId = parentId;
+  }
+  logActivity((req as Request).userId, 'update_folder', `folder:${id}`);
+  res.json(folder);
+});
+
+app.delete('/folders/:id', authenticate, requireRole('owner'), (req, res) => {
+  const { id } = req.params;
+  if (!folders.has(id)) return res.status(404).json({ error: 'Folder not found' });
+  // Delete child folders/documents recursively
+  const deleteRecursive = (fid: string) => {
+    // delete documents within this folder
+    for (const [docId, doc] of documents) {
+      if (doc.folderId === fid) {
+        documents.delete(docId);
+        documentShares.delete(docId);
+        logActivity((req as Request).userId, 'delete_document', `document:${docId}`);
+      }
+    }
+    // delete subfolders
+    for (const [subId, sub] of folders) {
+      if (sub.parentId === fid) {
+        deleteRecursive(subId);
+      }
+    }
+    folderShares.delete(fid);
+    folders.delete(fid);
+    logActivity((req as Request).userId, 'delete_folder', `folder:${fid}`);
+  };
+  deleteRecursive(id);
+  res.sendStatus(204);
+});
+
+// Document CRUD
+app.post('/folders/:folderId/documents', authenticate, (req, res) => {
+  const { folderId } = req.params;
+  const folder = folders.get(folderId);
+  if (!folder) return res.status(404).json({ error: 'Folder not found' });
+  const userId = (req as Request).userId as string;
+  const role = getUserRoleForFolder(userId, folderId);
+  if (!role) return res.status(403).json({ error: 'No access to folder' });
+  const { title, content } = req.body;
+  if (!title) return res.status(400).json({ error: 'Title required' });
+  const id = randomUUID();
+  const doc: Document = { id, title, content: content ?? '', folderId, ownerId: userId };
+  documents.set(id, doc);
+  // Owner share automatically
+  const ownerShare: Share = { userId, role: 'owner' };
+  documentShares.set(id, [ownerShare]);
+  logActivity(userId, 'create_document', `document:${id}`);
+  res.status(201).json(doc);
+});
+
+app.get('/documents/:id', authenticate, (req, res) => {
+  const { id } = req.params;
+  const doc = documents.get(id);
+  if (!doc) return res.status(404).json({ error: 'Document not found' });
+  const userId = (req as Request).userId as string;
+  const role = getUserRoleForDocument(userId, id);
+  if (!role) return res.status(403).json({ error: 'No access' });
+  res.json(doc);
+});
+
+app.patch('/documents/:id', authenticate, (req, res) => {
+  const { id } = req.params;
+  const doc = documents.get(id);
+  if (!doc) return res.status(404).json({ error: 'Document not found' });
+  const userId = (req as Request).userId as string;
+  const role = getUserRoleForDocument(userId, id);
+  if (!role || (role !== 'owner' && role !== 'editor')) {
+    return res.status(403).json({ error: 'Insufficient permissions' });
+  }
+  const { title, content } = req.body;
+  if (title) doc.title = title;
+  if (content) doc.content = content;
+  logActivity(userId, 'update_document', `document:${id}`);
+  res.json(doc);
+});
+
+app.delete('/documents/:id', authenticate, (req, res) => {
+  const { id } = req.params;
+  const doc = documents.get(id);
+  if (!doc) return res.status(404).json({ error: 'Document not found' });
+  const userId = (req as Request).userId as string;
+  const role = getUserRoleForDocument(userId, id);
+  if (role !== 'owner') return res.status(403).json({ error: 'Only owner can delete' });
+  documents.delete(id);
+  documentShares.delete(id);
+  logActivity(userId, 'delete_document', `document:${id}`);
+  res.sendStatus(204);
+});
+
+// Sharing endpoint
+app.post('/:resourceType/:id/share', authenticate, (req, res) => {
+  const { resourceType, id } = req.params;
+  const { userId: targetUserId, role } = req.body;
+  if (!targetUserId || !role) return res.status(400).json({ error: 'Missing fields' });
+  if (!['viewer', 'editor', 'owner'].includes(role)) return res.status(400).json({ error: 'Invalid role' });
+  const requesterId = (req as Request).userId as string;
+  // Only owner/editor of resource can share
+  let currentRole: Role | null = null;
+  if (resourceType === 'folders') {
+    currentRole = getUserRoleForFolder(requesterId, id);
+  } else if (resourceType === 'documents') {
+    currentRole = getUserRoleForDocument(requesterId, id);
+  } else {
+    return res.status(400).json({ error: 'Invalid resource type' });
+  }
+  const hierarchy = { viewer: 1, editor: 2, owner: 3 };
+  if (!currentRole || hierarchy[currentRole] < hierarchy['editor']) {
+    return res.status(403).json({ error: 'Insufficient permissions to share' });
+  }
+  // Add share
+  const shareObj: Share = { userId: targetUserId, role };
+  const map = resourceType === 'folders' ? folderShares : documentShares;
+  const existing = map.get(id) || [];
+  // replace if already exists
+  const filtered = existing.filter(s => s.userId !== targetUserId);
+  filtered.push(shareObj);
+  map.set(id, filtered);
+  logActivity(requesterId, 'share', `${resourceType}:${id}->${targetUserId}:${role}`);
+  res.status(200).json({ success: true });
+});
+
+// Activity log endpoint
+app.get('/activity', authenticate, (req, res) => {
+  // For simplicity, return all logs. Could filter later.
+  res.json(activityLog);
+});
+
+export const resetData = () => {
+  users.clear();
+  tokens.clear();
+  folders.clear();
+  documents.clear();
+  folderShares.clear();
+  documentShares.clear();
+  activityLog.length = 0;
+};
+
+export default app;
