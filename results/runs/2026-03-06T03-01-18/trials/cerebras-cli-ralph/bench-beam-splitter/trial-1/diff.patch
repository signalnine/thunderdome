+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index';
+
+describe('Beam Splitter Simulation', () => {
+  it('counts cells and paths for simple splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('handles multiple splitters correctly', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Expected visited cells: (0,1),(1,1),(2,0),(2,2),(3,1),(3,3) => 6
+    expect(countBeamCells(grid)).toBe(6);
+    // Paths: 4 distinct exit paths
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('returns zero for empty grid', () => {
+    const grid: string[][] = [];
+    expect(countBeamCells(grid)).toBe(0);
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it('handles source on bottom row', () => {
+    const grid = [
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+      ['.', 'S', '.'],
+    ];
+    // Source at bottom, beam immediately exits
+    expect(countBeamCells(grid)).toBe(1);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+});
