+// Beam Splitter Simulation
+// Exported functions:
+//   countBeamCells(grid) -> number of distinct cells visited by any beam
+//   countBeamPaths(grid) -> bigint total number of distinct source-to-exit paths
+
+/**
+ * Count distinct cells visited by any beam.
+ * The source cell 'S' counts, as do splitter cells '^' when hit.
+ */
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  // Find source position
+  let srcRow = -1,
+    srcCol = -1;
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === 'S') {
+        srcRow = r;
+        srcCol = c;
+        break;
+      }
+    }
+    if (srcRow !== -1) break;
+  }
+  if (srcRow === -1) return 0; // no source
+
+  // Directions: 0 = down (dr=1, dc=0), 1 = down-left (dr=1, dc=-1), 2 = down-right (dr=1, dc=1)
+  const dr = [1, 1, 1];
+  const dc = [0, -1, 1];
+
+  // DP array storing number of ways to arrive at a cell with a given direction
+  const dp: bigint[][][] = Array.from({ length: rows }, () =>
+    Array.from({ length: cols }, () => [0n, 0n, 0n])
+  );
+
+  dp[srcRow][srcCol][0] = 1n; // start moving downwards from source
+  const visited = new Set<string>();
+  let totalExitPaths = 0n;
+
+  for (let r = srcRow; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      for (let dir = 0; dir < 3; dir++) {
+        const ways = dp[r][c][dir];
+        if (ways === 0n) continue;
+        // Mark cell as visited (any beam reaches it)
+        visited.add(`${r},${c}`);
+        const cell = grid[r][c];
+        if (cell === '^') {
+          // split into down-left and down-right regardless of incoming direction
+          for (const outDir of [1, 2]) {
+            const nr = r + dr[outDir];
+            const nc = c + dc[outDir];
+            if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+              totalExitPaths += ways;
+            } else {
+              dp[nr][nc][outDir] += ways;
+            }
+          }
+        } else {
+          // continue in same direction
+          const nr = r + dr[dir];
+          const nc = c + dc[dir];
+          if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+            totalExitPaths += ways;
+          } else {
+            dp[nr][nc][dir] += ways;
+          }
+        }
+      }
+    }
+  }
+
+  // No need to consider exits after the last row loop because they were already added when stepping out of bounds.
+  return visited.size;
+}
+
+/**
+ * Count total distinct source-to-exit paths.
+ * Returns a bigint because the number can be huge (2^K with K splitters).
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  // Find source
+  let srcRow = -1,
+    srcCol = -1;
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === 'S') {
+        srcRow = r;
+        srcCol = c;
+        break;
+      }
+    }
+    if (srcRow !== -1) break;
+  }
+  if (srcRow === -1) return 0n;
+
+  const dr = [1, 1, 1];
+  const dc = [0, -1, 1];
+  const dp: bigint[][][] = Array.from({ length: rows }, () =>
+    Array.from({ length: cols }, () => [0n, 0n, 0n])
+  );
+  dp[srcRow][srcCol][0] = 1n;
+  let total = 0n;
+
+  for (let r = srcRow; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      for (let dir = 0; dir < 3; dir++) {
+        const ways = dp[r][c][dir];
+        if (ways === 0n) continue;
+        const cell = grid[r][c];
+        if (cell === '^') {
+          for (const outDir of [1, 2]) {
+            const nr = r + dr[outDir];
+            const nc = c + dc[outDir];
+            if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+              total += ways;
+            } else {
+              dp[nr][nc][outDir] += ways;
+            }
+          }
+        } else {
+          const nr = r + dr[dir];
+          const nc = c + dc[dir];
+          if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+            total += ways;
+          } else {
+            dp[nr][nc][dir] += ways;
+          }
+        }
+      }
+    }
+  }
+
+  return total;
+}
