if (cell === '^') {\n          // split into down-left and down-right regardless of incoming direction\n          for (const outDir of [1, 2]) {\n            const nr = r + dr[outDir];\n            const nc = c + dc[outDir];\n            if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {\n              totalExitPaths += ways;\n            } else {\n              dp[nr][nc][outDir] += ways;\n            }\n          }\n        } else {\n          // continue in same direction\n          const nr = r + dr[dir];\n          const nc = c + dc[dir];\n          if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {\n            totalExitPaths += ways;\n          } else {\n            dp[nr][nc][dir] += ways;\n          }\n        }\n      }\n    }\n  }\n\n  // No need to consider exits after the last row loop because they were already added when stepping out of bounds.\n  return visited.size;\n}\n\n/**\n * Count total distinct source-to-exit paths.\n * Returns a bigint because the number can be huge (2^K with K splitters).\n */\nexport function countBeamPaths(grid: string[][]): bigint {\n  const rows = grid.length;\n  if (rows === 0) return 0n;\n  const cols = grid[0].length;\n  // Find source\n  let srcRow = -1,\n    srcCol = -1;\n  for (let r = 0; r < rows; r++) {\n    for (let c = 0; c < cols; c++) {\n      if (grid[r][c] === 'S') {\n        srcRow = r;\n        srcCol = c;\n        break;\n      }\n    }\n    if (srcRow !== -1) break;\n  }\n  if (srcRow === -1) return 0n;\n\n  const dr = [1, 1, 1];\n  const dc = [0, -1, 1];\n  const dp: bigint[][][] = Array.from({ length: rows }, () =>\n    Array.from({ length: cols }, () => [0n, 0n, 0n])\n  );\n  dp[srcRow][srcCol][0] = 1n;\n  let total = 0n;\n\n  for (let r = srcRow; r < rows; r++) {\n    for (let c = 0; c < cols; c++) {\n      for (let dir = 0; dir < 3; dir++) {\n        const ways = dp[r][c][dir];\n        if (ways === 0n) continue;\n        const cell = grid[r][c];\n        if (cell === '^') {\n          for (const 