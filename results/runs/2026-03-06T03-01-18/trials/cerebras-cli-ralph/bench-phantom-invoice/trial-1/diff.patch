     VALUES (?, ?, ?, ?, ?, ?, ?)\n48:   `);\n49: \n50:   const insertLineItem = db.prepare(`\n51:     INSERT INTO line_items (invoice_id, description, quantity, unit_price)\n52:     VALUES (?, ?, ?, ?)\n53:   `);\n54: \n55:   const result = insertInvoice.run(\n56:     data.customer_id,\n57:     data.date,\n58:     data.subtotal,\n59:     data.discount_rate,\n60:     data.tax_rate,\n61:     data.total,\n62:     data.status || 'draft',\n63:   );\n64: \n65:   const invoiceId = result.lastInsertRowid as number;\n66: \n67:   if (data.line_items) {\n68:     for (const item of data.line_items) {\n69:       insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n70:     }\n71:   }\n72: \n73:   return invoiceId;\n74: }\n75: \n76: /**\n77:  * Retrieve all invoices for a specific customer.\n78:  */\n79: export function getInvoicesByCustomer(\n80:   db: Database.Database,\n81:   customerId: string,\n82: ): Invoice[] {\n83:   const stmt = db.prepare(`\n84:     SELECT * FROM invoices\n85:     WHERE customer_id = ?\n86:     ORDER BY date ASC\n87:   `);\n88:   return stmt.all(customerId) as Invoice[];\n89: }\n90: \n\n(End of file - total 90 lines)\n</content>","title":"src/db/queries.ts","metadata":{"preview":"import type Database from 'better-sqlite3';\nimport type { Invoice, LineItem } from '../models/invoice.js';\n\n/**\n * Retrieve invoices within a date range (inclusive on both ends).\n */\nexport function getInvoicesByDateRange(\n  db: Database.Database,\n  startDate: string,\n  endDate: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE date >= ? AND date < ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(startDate, endDate) as Invoice[];\n}\n\n/**","truncated":false,"loaded":[]},"time":{"start":1772766526027,"end":1772766526029}}}}
