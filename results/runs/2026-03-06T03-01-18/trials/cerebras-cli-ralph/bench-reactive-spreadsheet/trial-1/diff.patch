+// src/index.ts
+// Reactive Spreadsheet Engine implementation
+
+type CellKey = string;
+
+export class Spreadsheet {
+  private rawValues: Map<CellKey, string | number | boolean> = new Map();
+  private computedValues: Map<CellKey, any> = new Map();
+
+  /** Set a cell's raw value (value or formula) */
+  set(cell: string, value: string | number | boolean): void {
+    this.rawValues.set(cell.toUpperCase(), value);
+    this.recomputeAll();
+  }
+
+  /** Get computed value of a cell */
+  get(cell: string): string | number | boolean | null {
+    const key = cell.toUpperCase();
+    if (!this.computedValues.has(key)) return null;
+    return this.computedValues.get(key);
+  }
+
+  /** Get display string */
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    return val === null || val === undefined ? '' : String(val);
+  }
+
+  /** Get map of all non-empty cells */
+  getCells(): Map<string, any> {
+    return new Map(this.computedValues);
+  }
+
+  // ---- internal helpers ----
+
+  private recomputeAll(): void {
+    this.computedValues.clear();
+    const visited = new Set<CellKey>();
+    for (const cell of this.rawValues.keys()) {
+      this.evaluateCell(cell, visited, []);
+    }
+  }
+
+  private evaluateCell(cell: CellKey, visited: Set<CellKey>, stack: CellKey[]): any {
+    const key = cell.toUpperCase();
+    if (this.computedValues.has(key)) return this.computedValues.get(key);
+    if (stack.includes(key)) {
+      throw new Error(`Circular reference detected: ${[...stack, key].join(' -> ')}`);
+    }
+    const raw = this.rawValues.get(key);
+    if (raw === undefined) return null;
+    if (typeof raw === 'string' && raw.startsWith('=')) {
+      const formula = raw.slice(1).trim();
+      const value = this.evaluateFormula(formula, [...stack, key]);
+      this.computedValues.set(key, value);
+      return value;
+    } else {
+      this.computedValues.set(key, raw);
+      return raw;
+    }
+  }
+
+  private evaluateFormula(formula: string, stack: CellKey[]): any {
+    // Handle functions first
+    const funcMatch = formula.match(/^([A-Z]+)\((.*)\)$/i);
+    if (funcMatch) {
+      const fn = funcMatch[1].toUpperCase();
+      const argsStr = funcMatch[2];
+      const args = this.splitArgs(argsStr);
+      switch (fn) {
+        case 'SUM':
+          return this.aggregate(args, stack, (arr) => arr.reduce((a, b) => a + b, 0));
+        case 'AVERAGE':
+          return this.aggregate(args, stack, (arr) => arr.reduce((a, b) => a + b, 0) / arr.length);
+        case 'MIN':
+          return this.aggregate(args, stack, (arr) => Math.min(...arr));
+        case 'MAX':
+          return this.aggregate(args, stack, (arr) => Math.max(...arr));
+        case 'COUNT':
+          return this.aggregate(args, stack, (arr) => arr.length);
+        case 'IF':
+          if (args.length !== 3) throw new Error('IF requires 3 arguments');
+          const condition = this.evalExpression(args[0], stack);
+          return condition ? this.evalExpression(args[1], stack) : this.evalExpression(args[2], stack);
+        default:
+          throw new Error(`Unsupported function ${fn}`);
+      }
+    }
+    // Otherwise treat as arithmetic/comparison expression
+    return this.evalExpression(formula, stack);
+  }
+
+  private splitArgs(argStr: string): string[] {
+    // Simple split on commas not inside quotes
+    const parts: string[] = [];
+    let current = '';
+    let inQuotes = false;
+    for (let i = 0; i < argStr.length; i++) {
+      const ch = argStr[i];
+      if (ch === '"') {
+        inQuotes = !inQuotes;
+        current += ch;
+      } else if (ch === ',' && !inQuotes) {
+        parts.push(current.trim());
+        current = '';
+      } else {
+        current += ch;
+      }
+    }
+    if (current.length) parts.push(current.trim());
+    return parts;
+  }
+
+  private aggregate(argList: string[], stack: CellKey[], reducer: (arr: number[]) => any): any {
+    const numbers: number[] = [];
+    for (const arg of argList) {
+      if (this.isRange(arg)) {
+        const cells = this.expandRange(arg);
+        for (const c of cells) {
+          const val = this.evaluateCell(c, new Set(), stack);
+          if (typeof val === 'number') numbers.push(val);
+        }
+      } else {
+        const val = this.evalExpression(arg, stack);
+        if (typeof val === 'number') numbers.push(val);
+      }
+    }
+    if (numbers.length === 0) return 0;
+    return reducer(numbers);
+  }
+
+  private evalExpression(expr: string, stack: CellKey[]): any {
+    // Replace cell references with their computed literals
+    const replaced = expr.replace(/\b([A-Z]+[0-9]+)\b/g, (full, ref) => {
+      const val = this.evaluateCell(ref, new Set(), stack);
+      return this.literalForJS(val);
+    });
+    // eslint-disable-next-line no-new-func
+    try {
+      // Use Function to evaluate safely (no access to globals except Math)
+      const fn = new Function('Math', `return (${replaced});`);
+      return fn(Math);
+    } catch (e) {
+      throw new Error(`Failed to evaluate expression \"${expr}\": ${e instanceof Error ? e.message : e}`);
+    }
+  }
+
+  private literalForJS(val: any): string {
+    if (val === null || val === undefined) return 'null';
+    if (typeof val === 'string') return JSON.stringify(val);
+    if (typeof val === 'number' || typeof val === 'boolean') return String(val);
+    // fallback
+    return JSON.stringify(val);
+  }
+
+  private isRange(str: string): boolean {
+    return /^[A-Z]+[0-9]+:[A-Z]+[0-9]+$/i.test(str.trim());
+  }
+
+  private expandRange(rangeStr: string): string[] {
+    const [start, end] = rangeStr.split(':').map((s) => s.trim().toUpperCase());
+    const startColRow = this.colRowFromCell(start);
+    const endColRow = this.colRowFromCell(end);
+    const cells: string[] = [];
+    for (let col = startColRow.col; col <= endColRow.col; col++) {
+      for (let row = startColRow.row; row <= endColRow.row; row++) {
+        cells.push(this.cellFromColRow(col, row));
+      }
+    }
+    return cells;
+  }
+
+  private colRowFromCell(cell: string): { col: number; row: number } {
+    const match = cell.match(/^([A-Z]+)([0-9]+)$/i);
+    if (!match) throw new Error(`Invalid cell reference ${cell}`);
+    const colLetters = match[1].toUpperCase();
+    const row = parseInt(match[2], 10);
+    let col = 0;
+    for (let i = 0; i < colLetters.length; i++) {
+      col *= 26;
+      col += colLetters.charCodeAt(i) - 64; // A=1
+    }
+    return { col, row };
+  }
+
+  private cellFromColRow(col: number, row: number): string {
+    let letters = '';
+    let c = col;
+    while (c > 0) {
+      const rem = (c - 1) % 26;
+      letters = String.fromCharCode(65 + rem) + letters;
+      c = Math.floor((c - 1) / 26);
+    }
+    return `${letters}${row}`;
+  }
+}
+
+export default Spreadsheet;
diff --git a/src/spreadsheet.test.ts b/src/spreadsheet.test.ts
new file mode 100644
index 0000000..686b8ff
--- /dev/null
+++ b/src/spreadsheet.test.ts
@@ -0,0 +1,50 @@
+import { describe, it, expect } from 'vitest';
+import Spreadsheet from './index';
+
+describe('Spreadsheet basic operations', () => {
+  it('sets and gets raw values', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 10);
+    sheet.set('B1', 'hello');
+    sheet.set('C1', true);
+    expect(sheet.get('A1')).toBe(10);
+    expect(sheet.get('B1')).toBe('hello');
+    expect(sheet.get('C1')).toBe(true);
+    expect(sheet.getDisplay('A1')).toBe('10');
+    expect(sheet.getDisplay('B1')).toBe('hello');
+  });
+
+  it('evaluates simple arithmetic formulas', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 5);
+    sheet.set('B1', 3);
+    sheet.set('C1', '=A1+B1');
+    expect(sheet.get('C1')).toBe(8);
+    sheet.set('A1', 10);
+    expect(sheet.get('C1')).toBe(13);
+  });
+
+  it('supports SUM function over range', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 1);
+    sheet.set('A2', 2);
+    sheet.set('A3', 3);
+    sheet.set('B1', '=SUM(A1:A3)');
+    expect(sheet.get('B1')).toBe(6);
+  });
+
+  it('supports IF function with comparison', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', 5);
+    sheet.set('B1', '=IF(A1>3, "big", "small")');
+    expect(sheet.get('B1')).toBe('big');
+    sheet.set('A1', 2);
+    expect(sheet.get('B1')).toBe('small');
+  });
+
+  it('detects circular references', () => {
+    const sheet = new Spreadsheet();
+    sheet.set('A1', '=B1');
+    expect(() => sheet.set('B1', '=A1')).toThrowError(/Circular reference/);
+  });
+});
