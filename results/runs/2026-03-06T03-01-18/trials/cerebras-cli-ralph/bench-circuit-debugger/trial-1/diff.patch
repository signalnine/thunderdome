+import type { Gate } from './types.js';
+
+/**
+ * Simulate a circuit defined by gates and initial input wire values.
+ * Returns a map of all wire names to their computed binary values (0 or 1).
+ */
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wireValues: Record<string, number> = { ...inputs };
+  // Keep track of gates that have not been processed yet.
+  const remaining = new Set<number>();
+  gates.forEach((_, idx) => remaining.add(idx));
+
+  // We'll iterate until no progress can be made.
+  let progress = true;
+  while (progress && remaining.size > 0) {
+    progress = false;
+    for (const idx of Array.from(remaining)) {
+      const gate = gates[idx];
+      const v1 = wireValues[gate.in1];
+      const v2 = wireValues[gate.in2];
+      if (v1 === undefined || v2 === undefined) continue; // inputs not ready yet
+      let out: number;
+      switch (gate.op) {
+        case 'AND':
+          out = v1 & v2;
+          break;
+        case 'OR':
+          out = v1 | v2;
+          break;
+        case 'XOR':
+          out = v1 ^ v2;
+          break;
+        default:
+          throw new Error(`Unsupported gate operation: ${gate.op}`);
+      }
+      wireValues[gate.out] = out;
+      remaining.delete(idx);
+      progress = true;
+    }
+  }
+
+  if (remaining.size > 0) {
+    // Circuit is not fully resolvable (should not happen for valid input)
+    throw new Error('Unresolved gates remain, possibly due to missing inputs or cycles');
+  }
+  return wireValues;
+}
+
+/**
+ * Detect swapped output wires in a binary adder circuit.
+ * The circuit is expected to be a correct N‑bit adder with exactly four pairs of output wires swapped.
+ * Returns a sorted array of the eight involved wire names.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Determine bit width N from the inputs present in the circuit (x?? and y?? wires).
+  const bitCount = detectBitCount(gates);
+  const reference = generateReferenceGates(bitCount);
+
+  // Map from a gate signature (op,in1,in2) to its output wire in the provided circuit.
+  // Map from a gate signature (op,in1,in2) to a list of its output wires in the provided circuit.
+  const providedMap = new Map<string, string[]>();
+  for (const g of gates) {
+    const key = `${g.op}|${g.in1}|${g.in2}`;
+    const arr = providedMap.get(key) ?? [];
+    arr.push(g.out);
+    providedMap.set(key, arr);
+  }
+
+  const mismatchedOutputs = new Set<string>();
+  for (const refGate of reference) {
+    const key = `${refGate.op}|${refGate.in1}|${refGate.in2}`;
+    const providedOuts = providedMap.get(key) ?? [];
+    // If there is exactly one matching output and it equals the expected, it's correct.
+    if (providedOuts.length === 1 && providedOuts[0] === refGate.out) {
+      continue;
+    }
+    // Otherwise, all provided outputs for this signature are considered mismatched.
+    for (const po of providedOuts) {
+      mismatchedOutputs.add(po);
+    }
+    mismatchedOutputs.add(refGate.out);
+  }
+
+  const result = Array.from(mismatchedOutputs).sort();
+  // Sanity check: should be exactly 8 wires (four swapped pairs)
+  if (result.length !== 8) {
+    throw new Error(`Expected 8 swapped wires, found ${result.length}`);
+  }
+  return result;
+}
+
+/** Helper: infer bit count N from highest index of x?? or y?? wires. */
+function detectBitCount(gates: Gate[]): number {
+  let maxIdx = -1;
+  const regex = /^(x|y)(\d{2})$/;
+  for (const g of gates) {
+    for (const name of [g.in1, g.in2]) {
+      const m = regex.exec(name);
+      if (m) {
+        const idx = parseInt(m[2], 10);
+        if (idx > maxIdx) maxIdx = idx;
+      }
+    }
+  }
+  // Bit count is maxIdx + 1 (since bits start at 0)
+  return maxIdx + 1;
+}
+
+/** Generate the correct gate list for an N‑bit ripple‑carry adder. */
+function generateReferenceGates(N: number): Gate[] {
+  const gates: Gate[] = [];
+  // Helper to name wires
+  const x = (i: number) => `x${i.toString().padStart(2, '0')}`;
+  const y = (i: number) => `y${i.toString().padStart(2, '0')}`;
+  const t = (i: number) => `t${i.toString().padStart(2, '0')}`; // partial sum
+  const a = (i: number) => `a${i.toString().padStart(2, '0')}`; // generate carry
+  const b = (i: number) => `b${i.toString().padStart(2, '0')}`; // propagate carry
+  const c = (i: number) => `c${i.toString().padStart(2, '0')}`; // carry out
+  const z = (i: number) => `z${i.toString().padStart(2, '0')}`;
+
+  // Bit 0 uses half adder (no previous carry)
+  gates.push({ op: 'XOR', in1: x(0), in2: y(0), out: z(0) });
+  gates.push({ op: 'AND', in1: x(0), in2: y(0), out: c(0) });
+
+  for (let i = 1; i < N; i++) {
+    // partial sum
+    gates.push({ op: 'XOR', in1: x(i), in2: y(i), out: t(i) });
+    // final sum
+    gates.push({ op: 'XOR', in1: t(i), in2: c(i - 1), out: z(i) });
+    // generate carry
+    gates.push({ op: 'AND', in1: x(i), in2: y(i), out: a(i) });
+    // propagate carry
+    gates.push({ op: 'AND', in1: t(i), in2: c(i - 1), out: b(i) });
+    // carry out
+    gates.push({ op: 'OR', in1: a(i), in2: b(i), out: c(i) });
+  }
+  // final carry becomes most significant output bit
+  gates.push({ op: 'OR', in1: c(N - 1), in2: c(N - 1), out: z(N) }); // effectively a wire copy
+  return gates;
+}
+
+// Types definition – kept in separate file for clarity
+// In this repository we expose the type directly to avoid extra imports.
+export type { Gate } from './types.js';
