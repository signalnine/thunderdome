it is not fully resolvable (should not happen for valid input)\n44:     throw new Error('Unresolved gates remain, possibly due to missing inputs or cycles');\n45:   }\n46:   return wireValues;\n47: }\n48: \n49: /**\n50:  * Detect swapped output wires in a binary adder circuit.\n51:  * The circuit is expected to be a correct N‑bit adder with exactly four pairs of output wires swapped.\n52:  * Returns a sorted array of the eight involved wire names.\n53:  */\n54: export function findSwappedWires(gates: Gate[]): string[] {\n55:   // Determine bit width N from the inputs present in the circuit (x?? and y?? wires).\n56:   const bitCount = detectBitCount(gates);\n57:   const reference = generateReferenceGates(bitCount);\n58: \n59:   // Map from a gate signature (op,in1,in2) to its output wire in the provided circuit.\n60:   const providedMap = new Map<string, string>();\n61:   for (const g of gates) {\n62:     const key = `${g.op}|${g.in1}|${g.in2}`;\n63:     providedMap.set(key, g.out);\n64:   }\n65: \n66:   const mismatchedOutputs = new Set<string>();\n67:   for (const refGate of reference) {\n68:     const key = `${refGate.op}|${refGate.in1}|${refGate.in2}`;\n69:     const providedOut = providedMap.get(key);\n70:     if (!providedOut) continue; // should not happen\n71:     if (providedOut !== refGate.out) {\n72:       mismatchedOutputs.add(providedOut);\n73:       mismatchedOutputs.add(refGate.out);\n74:     }\n75:   }\n76: \n77:   const result = Array.from(mismatchedOutputs).sort();\n78:   // Sanity check: should be exactly 8 wires (four swapped pairs)\n79:   if (result.length !== 8) {\n80:     throw new Error(`Expected 8 swapped wires, found ${result.length}`);\n81:   }\n82:   return result;\n83: }\n84: \n85: /** Helper: infer bit count N from highest index of x?? or y?? wires. */\n86: function detectBitCount(gates: Gate[]): number {\n87:   let maxIdx = -1;\n88:   const regex = /^(x|y)(\\d{2})$/;\n89:   for (const g of gates) {\n90:     for (const name of [g.in1, g.in2]) {\n91:       const m = regex.exec(name);\n92:       if (m) {\n93:         const idx = parseInt(m[2], 10);\n94:         if (idx > maxIdx) maxIdx = idx;\n95:       }\n96:     }\n97:   }\n98:   // Bit count is maxIdx + 1 (since bits start at 0)\n99:   return maxIdx + 1;\n100: }\n101: \n102: /** Generate the correct gate list for an N‑bit ripple‑carry adder. */\n103: function generateReferenceGates(N: number): Gate[] {\n104:   const gates: Gate[] = [];\n105:   // Helper to name wires\n106:   const x = (i: number) => `x${i.toString().padStart(2, '0')}`;\n107:   const y = (i: number) => `y${i.toString().padStart(2, '0')}`;\n108:   const t = (i: number) => `t${i.toString().padStart(2, '0')}`; // partial sum\n109:   const a = (i: number) => `a${i.toString().padStart(2, '0')}`; // generate carry\n110:   const b = (i: number) => `b${i.toString().padStart(2, '0')}`; // propagate carry\n111:   const c = (i: number) => `c${i.toString().padStart(2, '0')}`; // carry out\n112:   const z = (i: number) => `z${i.toString().padStart(2, '0')}`;\n113: \n114:   // Bit 0 uses half adder (no previous carry)\n115:   gates.push({ op: 'XOR', in1: x(0), in2: y(0), out: z(0) });\n116:   gates.push({ op: 'AND', in1: x(0), in2: y(0), out: c(0) });\n117: \n118:   for (let i = 1; i < N; i++) {\n119:     // partial sum\n120:     gates.push({ op: 'XOR', in1: x(i), in2: y(i), out: t(i) });\n121:     // final sum\n122:     gates.push({ op: 'XOR', in1: t(i), in2: c(i - 1), out: z(i) });\n123:     // generate carry\n124:     gates.push({ op: 'AND', in1: x(i), in2: y(i), out: a(i) });\n125:     // propagate carry\n126:     gates.push({ op: 'AND', in1: t(i), in2: c(i - 1), out: b(i) });\n127:     // carry out\n128:     gates.push({ op: 'OR', in1: a(i), in2: b(i), out: c(i) });\n129:   }\n130:   // final carry becomes most significant output bit\n131:   gates.push({ op: 'OR', in1: c(N - 1), in2: c(N - 1), out: z(N) }); // effectively a wire copy\n132:   return gates;\n133: }\n134: \n135: // Types defin