index 0000000..18fd827
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,565 @@
+import { randomUUID } from "crypto";
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentState {
+  content: object | null; // null means deleted
+  versions: Version[];
+}
+
+interface BranchState {
+  documents: Map<string, DocumentState>;
+  parent?: string;
+  forkSnapshot?: Map<string, DocumentState>; // snapshot of parent at fork time
+}
+
+function deepClone<T>(obj: T): T {
+  if (obj === null || obj === undefined || typeof obj !== "object") {
+    return obj;
+  }
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function isPlainObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === "object" && !Array.isArray(val);
+}
+
+/**
+ * Recursively diff two objects against a base and detect conflicts.
+ * Returns the merged object and any conflicts found.
+ */
+function threeWayMergeObjects(
+  base: unknown,
+  ours: unknown,
+  theirs: unknown,
+  path: string,
+  documentId: string,
+  conflicts: Conflict[]
+): unknown {
+  // If both sides are identical, no conflict
+  if (JSON.stringify(ours) === JSON.stringify(theirs)) {
+    return deepClone(ours);
+  }
+
+  // If only one side changed from base
+  const oursChanged = JSON.stringify(base) !== JSON.stringify(ours);
+  const theirsChanged = JSON.stringify(base) !== JSON.stringify(theirs);
+
+  if (!oursChanged && !theirsChanged) {
+    return deepClone(base);
+  }
+  if (!oursChanged && theirsChanged) {
+    return deepClone(theirs);
+  }
+  if (oursChanged && !theirsChanged) {
+    return deepClone(ours);
+  }
+
+  // Both sides changed from base. If both are objects, recurse.
+  if (isPlainObject(base) && isPlainObject(ours) && isPlainObject(theirs)) {
+    return mergeObjectFields(
+      base as Record<string, unknown>,
+      ours as Record<string, unknown>,
+      theirs as Record<string, unknown>,
+      path,
+      documentId,
+      conflicts
+    );
+  }
+
+  // If both are plain objects but base isn't (e.g., base was a scalar, both sides set objects)
+  if (isPlainObject(ours) && isPlainObject(theirs)) {
+    return mergeObjectFields(
+      {} as Record<string, unknown>,
+      ours as Record<string, unknown>,
+      theirs as Record<string, unknown>,
+      path,
+      documentId,
+      conflicts
+    );
+  }
+
+  // Both changed to different non-object values => conflict
+  conflicts.push({
+    documentId,
+    path,
+    base: deepClone(base),
+    ours: deepClone(ours),
+    theirs: deepClone(theirs),
+  });
+  // Resolve in favor of ours for the merged preview
+  return deepClone(ours);
+}
+
+function mergeObjectFields(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  path: string,
+  documentId: string,
+  conflicts: Conflict[]
+): Record<string, unknown> {
+  const result: Record<string, unknown> = {};
+  const allKeys = new Set([
+    ...Object.keys(base),
+    ...Object.keys(ours),
+    ...Object.keys(theirs),
+  ]);
+
+  for (const key of allKeys) {
+    const subPath = path ? `${path}.${key}` : key;
+    const baseVal = base[key];
+    const oursVal = ours[key];
+    const theirsVal = theirs[key];
+
+    const inBase = key in base;
+    const inOurs = key in ours;
+    const inTheirs = key in theirs;
+
+    // Handle key presence/absence
+    if (!inBase && !inOurs && inTheirs) {
+      // theirs added a new key
+      result[key] = deepClone(theirsVal);
+    } else if (!inBase && inOurs && !inTheirs) {
+      // ours added a new key
+      result[key] = deepClone(oursVal);
+    } else if (!inBase && inOurs && inTheirs) {
+      // both added the same key
+      result[key] = threeWayMergeObjects(
+        undefined,
+        oursVal,
+        theirsVal,
+        subPath,
+        documentId,
+        conflicts
+      );
+    } else if (inBase && !inOurs && !inTheirs) {
+      // both deleted
+      // don't include in result
+    } else if (inBase && !inOurs && inTheirs) {
+      // ours deleted, theirs kept (possibly modified)
+      const theirsChanged =
+        JSON.stringify(baseVal) !== JSON.stringify(theirsVal);
+      if (theirsChanged) {
+        // conflict: ours deleted, theirs modified
+        conflicts.push({
+          documentId,
+          path: subPath,
+          base: deepClone(baseVal),
+          ours: undefined,
+          theirs: deepClone(theirsVal),
+        });
+        // ours wins (deleted) — don't include
+      }
+      // if theirs didn't change, ours' deletion wins
+    } else if (inBase && inOurs && !inTheirs) {
+      // theirs deleted, ours kept (possibly modified)
+      const oursChanged =
+        JSON.stringify(baseVal) !== JSON.stringify(oursVal);
+      if (oursChanged) {
+        // conflict: theirs deleted, ours modified
+        conflicts.push({
+          documentId,
+          path: subPath,
+          base: deepClone(baseVal),
+          ours: deepClone(oursVal),
+          theirs: undefined,
+        });
+        result[key] = deepClone(oursVal); // ours wins
+      }
+      // if ours didn't change, theirs' deletion wins — don't include
+    } else {
+      // key in all three (or base + both)
+      result[key] = threeWayMergeObjects(
+        baseVal,
+        oursVal,
+        theirsVal,
+        subPath,
+        documentId,
+        conflicts
+      );
+    }
+  }
+
+  return result;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch = "main";
+
+  constructor() {
+    this.branches.set("main", {
+      documents: new Map(),
+    });
+  }
+
+  // --- CRUD ---
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const existing = branch.documents.get(id);
+    if (existing && existing.content !== null) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: randomUUID(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.content === null) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.content === null) {
+      throw new Error(`Document "${id}" not found`);
+    }
+
+    const version: Version = {
+      id: randomUUID(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.content === null) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    doc.content = null;
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return doc.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchState();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = doc.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found`);
+    }
+    return deepClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+
+    const snapshot = this.cloneBranchDocuments(source.documents);
+
+    this.branches.set(name, {
+      documents: this.cloneBranchDocuments(source.documents),
+      parent: sourceName,
+      forkSnapshot: snapshot,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+
+    const target = this.getCurrentBranchState();
+
+    // Find the common ancestor (base).
+    // The base is the fork snapshot of the source branch if source was forked from current,
+    // or the fork snapshot of the current branch if current was forked from source,
+    // or we need to find the common state.
+    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const id of target.documents.keys()) allDocIds.add(id);
+    for (const id of source.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    let hasChanges = false;
+
+    for (const docId of allDocIds) {
+      const baseDoc = base.get(docId);
+      const oursDoc = target.documents.get(docId);
+      const theirsDoc = source.documents.get(docId);
+
+      const baseContent = baseDoc?.content ?? undefined;
+      const oursContent = oursDoc?.content ?? undefined;
+      const theirsContent = theirsDoc?.content ?? undefined;
+
+      // Skip if nothing changed
+      if (
+        JSON.stringify(baseContent) === JSON.stringify(oursContent) &&
+        JSON.stringify(baseContent) === JSON.stringify(theirsContent)
+      ) {
+        // No changes on either side for this document
+        if (oursContent != null) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+        continue;
+      }
+
+      hasChanges = true;
+
+      // If document only exists/changed on one side
+      const oursChanged =
+        JSON.stringify(baseContent) !== JSON.stringify(oursContent);
+      const theirsChanged =
+        JSON.stringify(baseContent) !== JSON.stringify(theirsContent);
+
+      if (!oursChanged && theirsChanged) {
+        // Only source changed — take theirs
+        if (theirsContent != null) {
+          merged[docId] = deepClone(theirsContent) as object;
+        }
+        // if theirs is null/undefined, document was deleted on source
+        continue;
+      }
+
+      if (oursChanged && !theirsChanged) {
+        // Only target changed — keep ours
+        if (oursContent != null) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+        continue;
+      }
+
+      // Both changed
+      if (
+        JSON.stringify(oursContent) === JSON.stringify(theirsContent)
+      ) {
+        // Both changed to same thing
+        if (oursContent != null) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+        continue;
+      }
+
+      // Handle deletion conflicts
+      if (oursContent == null && theirsContent != null) {
+        // We deleted, they modified
+        conflicts.push({
+          documentId: docId,
+          path: "",
+          base: deepClone(baseContent),
+          ours: undefined,
+          theirs: deepClone(theirsContent),
+        });
+        // ours wins: document stays deleted, not in merged
+        continue;
+      }
+
+      if (oursContent != null && theirsContent == null) {
+        // They deleted, we modified
+        conflicts.push({
+          documentId: docId,
+          path: "",
+          base: deepClone(baseContent),
+          ours: deepClone(oursContent),
+          theirs: undefined,
+        });
+        merged[docId] = deepClone(oursContent) as object;
+        continue;
+      }
+
+      if (oursContent == null && theirsContent == null) {
+        // Both deleted
+        continue;
+      }
+
+      // Both are objects — do structural merge
+      const mergedContent = threeWayMergeObjects(
+        baseContent ?? {},
+        oursContent as object,
+        theirsContent as object,
+        "",
+        docId,
+        conflicts
+      );
+      merged[docId] = mergedContent as object;
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied && hasChanges) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existing = target.documents.get(docId);
+          if (existing) {
+            const contentChanged =
+              JSON.stringify(existing.content) !==
+              JSON.stringify(merged[docId]);
+            if (contentChanged) {
+              const version: Version = {
+                id: randomUUID(),
+                timestamp: Date.now(),
+                content: deepClone(merged[docId]),
+              };
+              existing.content = deepClone(merged[docId]);
+              existing.versions.push(version);
+            }
+          } else {
+            // Document was created on source branch
+            const version: Version = {
+              id: randomUUID(),
+              timestamp: Date.now(),
+              content: deepClone(merged[docId]),
+            };
+            target.documents.set(docId, {
+              content: deepClone(merged[docId]),
+              versions: [version],
+            });
+          }
+        } else {
+          // Document was deleted (not in merged)
+          const existing = target.documents.get(docId);
+          if (existing && existing.content !== null) {
+            existing.content = null;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts, applied };
+  }
+
+  // --- Private helpers ---
+
+  private getCurrentBranchState(): BranchState {
+    const state = this.branches.get(this.currentBranch);
+    if (!state) {
+      throw new Error(`Branch "${this.currentBranch}" not found`);
+    }
+    return state;
+  }
+
+  private cloneBranchDocuments(
+    docs: Map<string, DocumentState>
+  ): Map<string, DocumentState> {
+    const clone = new Map<string, DocumentState>();
+    for (const [id, state] of docs) {
+      clone.set(id, {
+        content: state.content !== null ? deepClone(state.content) : null,
+        versions: state.versions.map((v) => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+      });
+    }
+    return clone;
+  }
+
+  private findCommonAncestor(
+    sourceBranchName: string,
+    targetBranchName: string
+  ): Map<string, DocumentState> {
+    const source = this.branches.get(sourceBranchName)!;
+
+    // If source was forked from target, the fork snapshot is the common ancestor
+    if (source.parent === targetBranchName && source.forkSnapshot) {
+      return source.forkSnapshot;
+    }
+
+    // If target was forked from source
+    const target = this.branches.get(targetBranchName)!;
+    if (target.parent === sourceBranchName && target.forkSnapshot) {
+      return target.forkSnapshot;
+    }
+
+    // If both were forked from the same parent, try to find a common point
+    // For simplicity, use an empty state as the base if we can't find a common ancestor
+    // This handles the case where branches share a common grandparent etc.
+    if (source.parent && target.parent && source.parent === target.parent) {
+      // Both forked from the same branch — find the earlier fork snapshot
+      // Use source's fork snapshot as they both diverged from the same parent
+      if (source.forkSnapshot) {
+        return source.forkSnapshot;
+      }
+    }
+
+    // Fallback: empty base (treat everything as new)
+    return new Map();
+  }
+}
