+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve toggle puzzle using meet-in-the-middle for minimum weight solution.
+ * System is over GF(2) - binary field.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const n = machine.target.length;
+  const m = machine.buttons.length;
+
+  if (n === 0) return [];
+  if (m === 0) {
+    return machine.target.every(v => !v) ? [] : null;
+  }
+
+  // Convert buttons to bit masks for efficiency
+  const targetMask = boolArrayToMask(machine.target);
+  const buttonMasks: number[] = [];
+  for (const btn of machine.buttons) {
+    buttonMasks.push(indicesToMask(btn));
+  }
+
+  // Split buttons into two halves
+  const half = Math.floor(m / 2);
+
+  // Enumerate all possible combinations for first half
+  const firstHalf = new Map<number, number[]>();
+  for (let mask = 0; mask < (1 << half); mask++) {
+    let result = 0;
+    const buttons: number[] = [];
+    for (let i = 0; i < half; i++) {
+      if (mask & (1 << i)) {
+        result ^= buttonMasks[i];
+        buttons.push(i);
+      }
+    }
+    // Keep the solution with fewest buttons for each result
+    const existing = firstHalf.get(result);
+    if (!existing || buttons.length < existing.length ||
+        (buttons.length === existing.length && isLexSmaller(buttons, existing))) {
+      firstHalf.set(result, buttons);
+    }
+  }
+
+  // Enumerate second half and look for matches
+  let bestSolution: number[] | null = null;
+  const secondCount = m - half;
+  for (let mask = 0; mask < (1 << secondCount); mask++) {
+    let result = 0;
+    const buttons: number[] = [];
+    for (let i = 0; i < secondCount; i++) {
+      if (mask & (1 << i)) {
+        result ^= buttonMasks[half + i];
+        buttons.push(half + i);
+      }
+    }
+    const needed = targetMask ^ result;
+    const firstButtons = firstHalf.get(needed);
+    if (firstButtons !== undefined) {
+      const combined = [...firstButtons, ...buttons];
+      combined.sort((a, b) => a - b);
+      if (bestSolution === null ||
+          combined.length < bestSolution.length ||
+          (combined.length === bestSolution.length && isLexSmaller(combined, bestSolution))) {
+        bestSolution = combined;
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+/**
+ * Solve counter puzzle using Gaussian elimination with enumeration of free variables.
+ * System is over GF(p) where p is prime.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (n === 0) return new Array(m).fill(0);
+  if (m === 0) {
+    return lights.every(v => v === 0) ? [] : null;
+  }
+
+  // Normalize lights to [0, modulus-1]
+  const target = lights.map(v => ((v % modulus) + modulus) % modulus);
+
+  // Build augmented matrix [A | b] where Ax = b (mod modulus)
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    matrix.push(new Array(m + 1).fill(0));
+    matrix[i][m] = target[i];
+  }
+
+  // Fill matrix: matrix[i][j] = count of how many times button j affects light i
+  for (let j = 0; j < m; j++) {
+    for (const idx of buttons[j]) {
+      if (idx >= 0 && idx < n) {
+        matrix[idx][j] = (matrix[idx][j] + 1) % modulus;
+      }
+    }
+  }
+
+  // Perform Gaussian elimination with tracking of pivot columns
+  const { rank, pivotCols } = gaussianEliminationMod(matrix, modulus);
+
+  // Check for inconsistency
+  for (let i = rank; i < n; i++) {
+    let allZero = true;
+    for (let j = 0; j < m; j++) {
+      if (matrix[i][j] !== 0) {
+        allZero = false;
+        break;
+      }
+    }
+    if (allZero && matrix[i][m] !== 0) {
+      return null; // Inconsistent: 0 = non-zero
+    }
+  }
+
+  // Identify free variables (columns without pivots)
+  const isPivotCol = new Array(m).fill(false);
+  for (const col of pivotCols) {
+    isPivotCol[col] = true;
+  }
+  const freeVars: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (!isPivotCol[col]) {
+      freeVars.push(col);
+    }
+  }
+
+  const freeCount = freeVars.length;
+
+  // If no free variables, there's exactly one solution
+  if (freeCount === 0) {
+    const solution = extractSolution(matrix, rank, m, new Map(), modulus);
+    return solution;
+  }
+
+  // Use meet-in-the-middle for free variables if there are enough
+  // Otherwise just enumerate all possibilities
+  const threshold = 10; // If more than 10 free vars, use meet-in-the-middle
+  if (freeCount > threshold) {
+    return solveWithMeetInMiddle(matrix, rank, m, freeVars, modulus);
+  } else {
+    return solveByEnumeratingFreeVars(matrix, rank, m, freeVars, modulus);
+  }
+}
+
+/**
+ * Enumerate all combinations of free variables to find optimal solution.
+ * Suitable when number of free variables is small (<= 10).
+ */
+function solveByEnumeratingFreeVars(
+  matrix: number[][],
+  rank: number,
+  m: number,
+  freeVars: number[],
+  modulus: number
+): number[] | null {
+  const freeCount = freeVars.length;
+  const totalCombinations = Math.pow(modulus, freeCount);
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  for (let encoded = 0; encoded < totalCombinations; encoded++) {
+    let temp = encoded;
+    const freeVarMap = new Map<number, number>();
+    let freeTotal = 0;
+
+    for (let i = 0; i < freeCount; i++) {
+      const val = temp % modulus;
+      freeVarMap.set(freeVars[i], val);
+      freeTotal += val;
+      temp = Math.floor(temp / modulus);
+    }
+
+    // Quick pruning: if free vars already exceed best, skip
+    // Note: must use > not >= because we need to check lex ordering when equal
+    if (freeTotal > bestTotal) continue;
+
+    const solution = extractSolution(matrix, rank, m, freeVarMap, modulus);
+    if (solution !== null) {
+      const total = solution.reduce((a, b) => a + b, 0);
+      if (bestSolution === null || total < bestTotal ||
+          (total === bestTotal && isLexSmaller(solution, bestSolution))) {
+        bestSolution = solution;
+        bestTotal = total;
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+/**
+ * Use meet-in-the-middle for many free variables.
+ */
+function solveWithMeetInMiddle(
+  matrix: number[][],
+  rank: number,
+  m: number,
+  freeVars: number[],
+  modulus: number
+): number[] | null {
+  const freeCount = freeVars.length;
+  const half = Math.floor(freeCount / 2);
+  const firstFree = freeVars.slice(0, half);
+  const secondFree = freeVars.slice(half);
+
+  // Precompute the coefficient of each free var in each pivot equation
+  // matrix is in reduced row echelon form, so for pivot row i:
+  // x_pivot[i] = rhs[i] - sum(matrix[i][j] * x[j] for j free)
+
+  // For first half: enumerate and store the vector of contributions to each pivot eq
+  const firstHalfMap = new Map<string, { values: Map<number, number>; totalPresses: number }>();
+  const firstTotal = Math.pow(modulus, firstFree.length);
+
+  for (let encoded = 0; encoded < firstTotal; encoded++) {
+    let temp = encoded;
+    const freeVarMap = new Map<number, number>();
+    let totalPresses = 0;
+
+    for (let i = 0; i < firstFree.length; i++) {
+      const val = temp % modulus;
+      freeVarMap.set(firstFree[i], val);
+      totalPresses += val;
+      temp = Math.floor(temp / modulus);
+    }
+
+    // Compute contribution vector: for each pivot row, what is sum(matrix[i][j] * x[j])
+    const contribution: number[] = [];
+    for (let i = 0; i < rank; i++) {
+      let val = 0;
+      for (let j = 0; j < firstFree.length; j++) {
+        const freeCol = firstFree[j];
+        val = (val + matrix[i][freeCol] * (freeVarMap.get(freeCol) || 0)) % modulus;
+      }
+      contribution.push(val);
+    }
+
+    const key = contribution.join(',');
+    const existing = firstHalfMap.get(key);
+    if (!existing || totalPresses < existing.totalPresses) {
+      firstHalfMap.set(key, { values: freeVarMap, totalPresses });
+    }
+  }
+
+  // Enumerate second half and find matches
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+  const secondTotal = Math.pow(modulus, secondFree.length);
+
+  for (let encoded = 0; encoded < secondTotal; encoded++) {
+    let temp = encoded;
+    const freeVarMap = new Map<number, number>();
+    let totalPresses = 0;
+
+    for (let i = 0; i < secondFree.length; i++) {
+      const val = temp % modulus;
+      freeVarMap.set(secondFree[i], val);
+      totalPresses += val;
+      temp = Math.floor(temp / modulus);
+    }
+
+    // Compute what contribution second half provides
+    const contribution: number[] = [];
+    for (let i = 0; i < rank; i++) {
+      let val = 0;
+      for (let j = 0; j < secondFree.length; j++) {
+        const freeCol = secondFree[j];
+        val = (val + matrix[i][freeCol] * (freeVarMap.get(freeCol) || 0)) % modulus;
+      }
+      contribution.push(val);
+    }
+
+    // What do we need from first half?
+    // We need: first_contrib + second_contrib ≡ rhs (mod modulus)
+    // So: first_contrib ≡ rhs - second_contrib (mod modulus)
+    const needed: number[] = [];
+    for (let i = 0; i < rank; i++) {
+      needed.push((matrix[i][m] - contribution[i] + modulus) % modulus);
+    }
+
+    const key = needed.join(',');
+    const firstMatch = firstHalfMap.get(key);
+    if (firstMatch !== undefined) {
+      const combinedTotal = firstMatch.totalPresses + totalPresses;
+      if (combinedTotal >= bestTotal) continue;
+
+      // Merge free variable maps
+      const mergedMap = new Map(firstMatch.values);
+      for (const [k, v] of freeVarMap) {
+        mergedMap.set(k, v);
+      }
+
+      const solution = extractSolution(matrix, rank, m, mergedMap, modulus);
+      if (solution !== null) {
+        const total = solution.reduce((a, b) => a + b, 0);
+        if (bestSolution === null || total < bestTotal ||
+            (total === bestTotal && isLexSmaller(solution, bestSolution))) {
+          bestSolution = solution;
+          bestTotal = total;
+        }
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+/**
+ * Extract full solution from reduced matrix given free variable values.
+ */
+function extractSolution(
+  matrix: number[][],
+  rank: number,
+  m: number,
+  freeVarMap: Map<number, number>,
+  modulus: number
+): number[] | null {
+  const solution = new Array(m).fill(0);
+
+  // Copy free variable values
+  for (const [col, val] of freeVarMap) {
+    solution[col] = val;
+  }
+
+  // For each pivot row, the pivot variable value is:
+  // rhs - sum(coeff * free_var_value)
+  for (let i = 0; i < rank; i++) {
+    // Find pivot column in this row
+    let pivotCol = -1;
+    for (let j = 0; j < m; j++) {
+      if (matrix[i][j] !== 0) {
+        pivotCol = j;
+        break;
+      }
+    }
+
+    if (pivotCol === -1) continue;
+
+    // Compute value: rhs - sum of free variable contributions
+    let val = matrix[i][m];
+    for (let j = pivotCol + 1; j < m; j++) {
+      if (matrix[i][j] !== 0 && !freeVarMap.has(j)) {
+        // This shouldn't happen if matrix is in RREF
+        // but just in case, it's a free var we haven't processed
+      }
+      if (matrix[i][j] !== 0) {
+        val = (val - matrix[i][j] * (freeVarMap.get(j) || 0) + modulus * modulus) % modulus;
+      }
+    }
+
+    solution[pivotCol] = val;
+  }
+
+  return solution;
+}
+
+/**
+ * Perform Gaussian elimination over GF(p) where p is prime.
+ * Returns the rank and list of pivot column indices.
+ */
+function gaussianEliminationMod(matrix: number[][], modulus: number): { rank: number; pivotCols: number[] } {
+  const n = matrix.length;
+  const m = matrix[0].length - 1; // Exclude augmented column
+  let row = 0;
+  const pivotCols: number[] = [];
+
+  for (let col = 0; col < m && row < n; col++) {
+    // Find pivot in this column
+    let pivotRow = -1;
+    for (let i = row; i < n; i++) {
+      if (matrix[i][col] !== 0) {
+        pivotRow = i;
+        break;
+      }
+    }
+
+    if (pivotRow === -1) continue; // No pivot in this column
+
+    // Swap rows
+    if (pivotRow !== row) {
+      [matrix[pivotRow], matrix[row]] = [matrix[row], matrix[pivotRow]];
+    }
+
+    // Normalize pivot row (make pivot = 1)
+    const pivotVal = matrix[row][col];
+    if (pivotVal !== 1) {
+      const inv = modInverse(pivotVal, modulus);
+      for (let j = col; j <= m; j++) {
+        matrix[row][j] = (matrix[row][j] * inv) % modulus;
+      }
+    }
+
+    // Eliminate this column from all other rows
+    for (let i = 0; i < n; i++) {
+      if (i !== row && matrix[i][col] !== 0) {
+        const factor = matrix[i][col];
+        for (let j = col; j <= m; j++) {
+          matrix[i][j] = (matrix[i][j] - factor * matrix[row][j] + modulus * modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    row++;
+  }
+
+  return { rank: row, pivotCols };
+}
+
+function modInverse(a: number, modulus: number): number {
+  // Fermat's little theorem: a^(p-2) ≡ a^(-1) (mod p) for prime p
+  return modPow(a, modulus - 2, modulus);
+}
+
+function modPow(base: number, exp: number, modulus: number): number {
+  let result = 1;
+  let b = ((base % modulus) + modulus) % modulus;
+  let e = exp;
+  while (e > 0) {
+    if (e & 1) result = (result * b) % modulus;
+    b = (b * b) % modulus;
+    e >>= 1;
+  }
+  return result;
+}
+
+// Helper functions
+
+function boolArrayToMask(arr: boolean[]): number {
+  let mask = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (arr[i]) mask |= (1 << i);
+  }
+  return mask;
+}
+
+function indicesToMask(indices: number[]): number {
+  let mask = 0;
+  for (const idx of indices) {
+    mask |= (1 << idx);
+  }
+  return mask;
+}
+
+function isLexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < Math.min(a.length, b.length); i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
