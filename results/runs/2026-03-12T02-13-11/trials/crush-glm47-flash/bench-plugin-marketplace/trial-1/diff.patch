@@ -0,0 +1,111 @@
+import { PluginManifest, DependencyNode } from '../types.js';
+
+export interface RegistryService {
+  get(name: string): PluginManifest | null;
+  list(): PluginManifest[];
+  getVersion(name: string, version: string): PluginManifest | null;
+}
+
+export class DependencyGraph {
+  private visited = new Set<string>();
+  private recursionStack = new Set<string>();
+
+  buildTree(name: string, registry: RegistryService): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      throw new Error(`Plugin ${name} not found`);
+    }
+
+    const dependencies: DependencyNode[] = [];
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (registry.get(depName)) {
+        dependencies.push(this.buildTree(depName, registry));
+      }
+    }
+
+    return {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies
+    };
+  }
+
+  detectCycles(name: string, registry: RegistryService): string[][] | null {
+    this.visited.clear();
+    this.recursionStack.clear();
+
+    const result: string[][] = [];
+
+    const performDFS = (current: string, stack: string[]): void => {
+      this.visited.add(current);
+      this.recursionStack.add(current);
+
+      const manifest = registry.get(current);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          if (!this.visited.has(depName)) {
+            performDFS(depName, [...stack, current]);
+          } else if (this.recursionStack.has(depName)) {
+            result.push([...stack, current]);
+            return;
+          }
+        }
+      }
+
+      this.recursionStack.delete(current);
+    };
+
+    performDFS(name, []);
+    return result.length > 0 ? result : null;
+  }
+
+  topologicalSort(name: string, registry: RegistryService): string[] {
+    this.visited.clear();
+    this.recursionStack.clear();
+
+    const result: string[] = [];
+
+    const performDFS = (current: string): void => {
+      if (!this.visited.has(current)) {
+        this.visited.add(current);
+
+        const manifest = registry.get(current);
+        if (manifest) {
+          for (const depName of Object.keys(manifest.dependencies)) {
+            performDFS(depName);
+          }
+        }
+
+        result.unshift(current);
+      }
+    };
+
+    performDFS(name);
+    return result;
+  }
+
+  flattenDependencies(name: string, registry: RegistryService): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const traverse = (current: string): void => {
+      if (visited.has(current)) return;
+      visited.add(current);
+      result.push(current);
+
+      const manifest = registry.get(current);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          traverse(depName);
+        }
+      }
+    };
+
+    traverse(name);
+    return result;
+  }
+
+  hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return this.detectCycles(name, registry) !== null;
+  }
+}
