@@ -0,0 +1,168 @@
+import Database from 'better-sqlite3';
+import { Review } from '../types.js';
+
+let db: Database.Database | null = null;
+
+let currentDbFile = 'plugins.db';
+
+export function getDB(): Database.Database {
+  if (!db) {
+    db = new Database(currentDbFile);
+    db.pragma('journal_mode = WAL');
+  }
+  return db;
+}
+
+export function initReviews(dbFile?: string) {
+  currentDbFile = dbFile || currentDbFile;
+
+  const database = getDB();
+  database.exec(`
+    CREATE TABLE IF NOT EXISTS reviews (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      pluginName TEXT NOT NULL,
+      pluginVersion TEXT NOT NULL,
+      userId TEXT NOT NULL,
+      rating INTEGER NOT NULL CHECK(rating BETWEEN 1 AND 5),
+      comment TEXT NOT NULL,
+      flagged BOOLEAN DEFAULT FALSE,
+      createdAt TEXT NOT NULL
+    )
+  `);
+
+  database.exec(`
+    CREATE UNIQUE INDEX IF NOT EXISTS idx_reviews_plugin_user
+    ON reviews(pluginName, userId)
+  `);
+}
+
+export function addReview(
+  review: Omit<Review, 'id' | 'createdAt'> & { flagged: boolean }
+): Review {
+  const database = getDB();
+  const stmt = database.prepare(`
+    INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `);
+  const result = stmt.run(
+    String(review.pluginName),
+    String(review.pluginVersion),
+    String(review.userId),
+    Number(review.rating),
+    String(review.comment),
+    review.flagged ? 1 : 0,
+    new Date().toISOString()
+  );
+  return getReviewById(result.lastInsertRowid as number);
+}
+
+export function getReviewById(id: number): Review {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT rating, comment, flagged, createdAt
+    FROM reviews WHERE id = ?
+  `);
+  const row: any = stmt.get(id);
+  if (!row) throw new Error('Review not found');
+
+  return {
+    id,
+    pluginName: '',
+    pluginVersion: '',
+    userId: '',
+    rating: row.rating as number,
+    comment: row.comment as string,
+    flagged: row.flagged as boolean,
+    createdAt: row.createdAt as string
+  };
+}
+
+export function getReviews(pluginName: string): Review[] {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT rating, comment, flagged, createdAt
+    FROM reviews WHERE pluginName = ? ORDER BY createdAt DESC
+  `);
+  const rows: any[] = stmt.all(pluginName);
+  return rows.map((row: any) => ({
+    id: 0,
+    pluginName,
+    pluginVersion: '',
+    userId: '',
+    rating: row.rating as number,
+    comment: row.comment as string,
+    flagged: row.flagged as boolean,
+    createdAt: row.createdAt as string
+  }));
+}
+
+export function getAverageRating(pluginName: string): number {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT AVG(rating) as avg
+    FROM reviews WHERE pluginName = ? AND flagged = 0
+  `);
+  const row: any = stmt.get(pluginName);
+  return row.avg ? Math.round((row.avg as number) * 100) / 100 : 0;
+}
+
+export function getFlaggedReviews(): Review[] {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT rating, comment, flagged, createdAt
+    FROM reviews WHERE flagged = 1 ORDER BY createdAt DESC
+  `);
+  const rows: any[] = stmt.all();
+  return rows.map((row: any) => ({
+    id: 0,
+    pluginName: '',
+    pluginVersion: '',
+    userId: '',
+    rating: row.rating,
+    comment: row.comment,
+    flagged: true,
+    createdAt: row.createdAt
+  }));
+}
+
+export function flagReview(reviewId: number): void {
+  const database = getDB();
+  const stmt = database.prepare(`UPDATE reviews SET flagged = 1 WHERE id = ?`);
+  stmt.run(reviewId);
+}
+
+export function removeReview(reviewId: number): boolean {
+  const database = getDB();
+  const stmt = database.prepare(`DELETE FROM reviews WHERE id = ?`);
+  const result = stmt.run(reviewId);
+  return result.changes > 0;
+}
+
+export function getReviewsByUser(userId: string): Review[] {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT rating, comment, flagged, createdAt
+    FROM reviews WHERE userId = ? ORDER BY createdAt DESC
+  `);
+  const rows: any[] = stmt.all(userId);
+  return rows.map((row: any) => ({
+    id: 0,
+    pluginName: '',
+    pluginVersion: '',
+    userId,
+    rating: row.rating,
+    comment: row.comment,
+    flagged: row.flagged,
+    createdAt: row.createdAt
+  }));
+}
+
+export function getReviewCount(pluginName: string): number {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT COUNT(*) as count
+    FROM reviews WHERE pluginName = ?
+  `);
+  const row: any = stmt.get(pluginName);
+  return row.count as number;
+}
