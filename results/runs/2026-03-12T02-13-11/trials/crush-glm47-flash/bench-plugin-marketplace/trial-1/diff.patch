+++ b/src/runner/index.ts
@@ -0,0 +1,101 @@
+// @ts-ignore - vm module doesn't have TypeScript definitions
+const vmscript = require('vm');
+
+export class SandboxedRunner {
+  async execute(
+    code: string,
+    _context: Record<string, unknown> = {}
+  ): Promise<any> {
+    const sandboxContext = {
+      console,
+      ..._context
+    };
+
+    try {
+      const result = await this.executeWithTimeout(code, 10000, sandboxContext);
+      return result;
+    } catch (error) {
+      return {
+        success: false,
+        output: null,
+        duration: 0,
+        memoryUsed: 0,
+        error: error instanceof Error ? error.message : String(error)
+      };
+    }
+  }
+
+  async executeWithTimeout(
+    code: string,
+    timeoutMs: number,
+    _context: Record<string, unknown> = {}
+  ): Promise<any> {
+    const sandboxContext = {
+      console,
+      ..._context
+    };
+
+    const startTime = process.hrtime.bigint();
+    const memoryStart = process.memoryUsage();
+
+    const vmInstance = vmscript.Sandbox(sandboxContext as any);
+    let result: unknown;
+
+    return new Promise((resolve, reject) => {
+      const timer = setTimeout(() => {
+        reject(new Error('Execution timeout'));
+      }, timeoutMs);
+
+      try {
+        vmscript.runInContext(code, vmInstance, {
+          timeout: timeoutMs,
+          breakOnSigint: false
+        });
+
+        const endTime = process.hrtime.bigint();
+        const memoryEnd = process.memoryUsage();
+
+        clearTimeout(timer);
+
+        const durationMs = Number((endTime - startTime) / 1000000n);
+        const memoryUsed = memoryEnd.heapUsed - memoryStart.heapUsed;
+
+        result = vmInstance.result;
+
+        if (result === undefined) {
+          result = null;
+        }
+
+        resolve({
+          success: true,
+          output: result,
+          duration: durationMs,
+          memoryUsed
+        });
+      } catch (error) {
+        clearTimeout(timer);
+        const endTime = process.hrtime.bigint();
+        const memoryEnd = process.memoryUsage();
+
+        const durationMs = Number((endTime - startTime) / 1000000n);
+        const memoryUsed = memoryEnd.heapUsed - memoryStart.heapUsed;
+
+        resolve({
+          success: false,
+          output: null,
+          duration: durationMs,
+          memoryUsed,
+          error: error instanceof Error ? error.message : String(error)
+        });
+      }
+    });
+  }
+}
+
+export type SandboxResult = {
+  success: boolean;
+  output: unknown;
+  duration: number;
+  memoryUsed: number;
+  error?: string;
+};
