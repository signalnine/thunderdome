@@ -0,0 +1,187 @@
+import Database from 'better-sqlite3';
+import { PluginManifest } from '../types.js';
+// @ts-ignore - better-sqlite3 doesn't have perfect TypeScript defs
+import { fs } from 'fs';
+
+let db: Database.Database | null = null;
+
+let currentDbFile = 'plugins.db';
+
+export function getDB(): Database.Database {
+  if (!db) {
+    db = new Database(currentDbFile);
+    db.pragma('journal_mode = WAL');
+  }
+  return db;
+}
+
+export function initRegistry(dbFile?: string) {
+  currentDbFile = dbFile || currentDbFile;
+  if (currentDbFile !== dbFile && db) {
+    db.close();
+    db = null;
+  }
+  const database = getDB();
+  database.exec(`
+    CREATE TABLE IF NOT EXISTS plugins (
+      name TEXT PRIMARY KEY,
+      version TEXT NOT NULL,
+      description TEXT,
+      author TEXT,
+      dependencies TEXT NOT NULL,
+      entryPoint TEXT NOT NULL,
+      permissions TEXT NOT NULL,
+      UNIQUE(name, version)
+    )
+  `);
+}
+
+export function register(manifest: PluginManifest) {
+  const database = getDB();
+  const stmt = database.prepare(`
+    INSERT INTO plugins (name, version, description, author, dependencies, entryPoint, permissions)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `);
+  stmt.run(
+    manifest.name,
+    manifest.version,
+    manifest.description,
+    manifest.author,
+    JSON.stringify(manifest.dependencies),
+    manifest.entryPoint,
+    JSON.stringify(manifest.permissions)
+  );
+}
+
+// @ts-ignore - better-sqlite3 doesn't have perfect TypeScript defs
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+export function get(name: string): PluginManifest | null {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT dependencies, entryPoint, permissions, name, version, description, author
+    FROM plugins WHERE name = ?
+  `);
+  const row: any = stmt.get(name);
+  if (!row) return null;
+
+  return {
+    name: row.name!,
+    version: row.version!,
+    description: row.description!,
+    author: row.author!,
+    dependencies: JSON.parse(row.dependencies!),
+    entryPoint: row.entryPoint!,
+    permissions: JSON.parse(row.permissions!)
+  };
+}
+
+export function getVersion(name: string, version: string): PluginManifest | null {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT dependencies, entryPoint, permissions, name, version, description, author
+    FROM plugins WHERE name = ? AND version = ?
+  `);
+  const row: any = stmt.get(name, version);
+  if (!row) return null;
+
+  return {
+    name: row.name!,
+    version: row.version!,
+    description: row.description!,
+    author: row.author!,
+    dependencies: JSON.parse(row.dependencies!),
+    entryPoint: row.entryPoint!,
+    permissions: JSON.parse(row.permissions!)
+  };
+}
+
+export function list(): PluginManifest[] {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT dependencies, entryPoint, permissions, name, version, description, author
+    FROM plugins ORDER BY name, version
+  `);
+  const rows: any[] = stmt.all();
+  return rows.map((row: any) => ({
+    name: row.name,
+    version: row.version!,
+    description: row.description!,
+    author: row.author!,
+    dependencies: JSON.parse(row.dependencies!),
+    entryPoint: row.entryPoint!,
+    permissions: JSON.parse(row.permissions!)
+  }));
+}
+
+export function search(query: string): PluginManifest[] {
+  const database = getDB();
+  const stmt = database.prepare(`
+    SELECT dependencies, entryPoint, permissions, name, version, description, author
+    FROM plugins WHERE name LIKE ? OR description LIKE ? ORDER BY name, version
+  `);
+  const searchTerm = `%${query}%`;
+  const rows: any[] = stmt.all(searchTerm, searchTerm);
+  return rows.map((row: any) => ({
+    name: row.name,
+    version: row.version!,
+    description: row.description!,
+    author: row.author!,
+    dependencies: JSON.parse(row.dependencies!),
+    entryPoint: row.entryPoint!,
+    permissions: JSON.parse(row.permissions!)
+  }));
+}
+
+export function remove(name: string, _version: string): boolean {
+  const database = getDB();
+  const stmt = database.prepare(`DELETE FROM plugins WHERE name = ? AND version = ?`);
+  const result: any = stmt.run(name, _version);
+  return result.changes > 0;
+}
+
+export function listVersions(name: string): string[] {
+  const database = getDB();
+  const stmt = database.prepare(`SELECT version FROM plugins WHERE name = ? ORDER BY version DESC`);
+  const rows = stmt.all(name) as any[];
+  return rows.map(row => row.version!);
+}
+
+export function update(name: string, _version: string, updates: Partial<PluginManifest>) {
+  const database = getDB();
+  const setClause: string[] = [];
+  const values: any[] = [];
+
+  if (updates.description !== undefined) {
+    setClause.push('description = ?');
+    values.push(updates.description);
+  }
+  if (updates.author !== undefined) {
+    setClause.push('author = ?');
+    values.push(updates.author);
+  }
+  if (updates.dependencies !== undefined) {
+    setClause.push('dependencies = ?');
+    values.push(JSON.stringify(updates.dependencies));
+  }
+  if (updates.entryPoint !== undefined) {
+    setClause.push('entryPoint = ?');
+    values.push(updates.entryPoint);
+  }
+  if (updates.permissions !== undefined) {
+    setClause.push('permissions = ?');
+    values.push(JSON.stringify(updates.permissions));
+  }
+
+  if (setClause.length === 0) return;
+
+  values.push(name, _version);
+  const stmt = database.prepare(`UPDATE plugins SET ${setClause.join(', ')} WHERE name = ? AND version = ?`);
+  stmt.run(...values);
+}
+
+export function close() {
+  if (db) {
+    db.close();
+    db = null;
+  }
+}
