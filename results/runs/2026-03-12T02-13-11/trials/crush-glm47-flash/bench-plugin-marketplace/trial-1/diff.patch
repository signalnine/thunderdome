@@ -0,0 +1,64 @@
+import semver from 'semver';
+import { VersionConstraint, ResolvedVersion } from '../types.js';
+
+export interface AvailableVersions {
+  [name: string]: string[];
+}
+
+export class VersionResolver {
+  resolve(constraints: VersionConstraint[], available: AvailableVersions): ResolvedVersion[] {
+    const resolved: ResolvedVersion[] = [];
+
+    for (const constraint of constraints) {
+      const versions = available[constraint.name];
+      if (!versions) continue;
+
+      const selected = this.selectBestVersion(versions, constraint.range);
+      if (selected) {
+        resolved.push({
+          name: constraint.name,
+          version: selected,
+          satisfies: constraint.range
+        });
+      }
+    }
+
+    return resolved;
+  }
+
+  private selectBestVersion(versions: string[], range: string): string | null {
+    const satisfying = versions.filter(v => this.satisfies(v, range));
+    if (satisfying.length === 0) return null;
+
+    // Find the greatest version that satisfies the range
+    const max = satisfying.reduce((best: string, current: string) => {
+      const a = semver.parse(best, true) || { major: 0, minor: 0, patch: 0 } as semver.SemVer;
+      const b = semver.parse(current, true) || { major: 0, minor: 0, patch: 0 } as semver.SemVer;
+      const cmp = semver.compare(a, b);
+      return cmp >= 0 ? best : current;
+    }, satisfying[0]);
+
+    return max;
+  }
+
+  satisfies(version: string, range: string): boolean {
+    return semver.satisfies(version, range);
+  }
+
+  maxSatisfying(versions: string[], range: string): string | null {
+    const satisfying = versions.filter(v => this.satisfies(v, range));
+    if (satisfying.length === 0) return null;
+
+    return satisfying.reduce((max, current) => {
+      return semver.compare(max, current) > 0 ? max : current;
+    });
+  }
+
+  validRange(range: string): boolean {
+    try {
+      return semver.validRange(range) !== null;
+    } catch {
+      return false;
+    }
+  }
+}
