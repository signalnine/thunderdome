@@ -0,0 +1,144 @@
+import { PluginManifest } from './types.js';
+import { RegistryService, ResolverService, ReviewService, DepsService, VersionConstraint } from './types.js';
+import {
+  initRegistry,
+  register,
+  get,
+  getVersion,
+  list,
+  remove,
+  listVersions,
+  update
+} from './registry/index.js';
+import { VersionResolver } from './resolver/index.js';
+import { SandboxedRunner } from './runner/index.js';
+import {
+  initReviews,
+  addReview,
+  getReviews,
+  getAverageRating,
+  flagReview,
+  getFlaggedReviews,
+  removeReview,
+  getReviewsByUser,
+  getReviewCount
+} from './reviews/index.js';
+import { DependencyGraph } from './deps/index.js';
+
+export interface CreateMarketplaceOptions {
+  dbFile?: string;
+}
+
+export function createMarketplace(_config: CreateMarketplaceOptions = {}): {
+  registry: RegistryService;
+  resolver: ResolverService;
+  runner: ResolverService extends { runner: any } ? never : any;
+  reviews: ReviewService;
+  deps: DepsService;
+} {
+  // Initialize modules
+  initRegistry();
+  initReviews();
+
+  // Create instance
+  const registryService: RegistryService = {
+    register,
+    get,
+    getVersion,
+    list,
+    search(query: string): PluginManifest[] {
+      return list().filter(p => 
+        (p.name as unknown as string).toLowerCase().includes(query.toLowerCase()) ||
+        (p.description as unknown as string).toLowerCase().includes(query.toLowerCase())
+      );
+    },
+    remove,
+    listVersions,
+    update
+  };
+
+  const resolverService = new VersionResolver();
+  const runnerService = new SandboxedRunner();
+  const reviewService: ReviewService = {
+    addReview,
+    getReviews,
+    getAverageRating,
+    flagReview,
+    getFlaggedReviews,
+    removeReview,
+    getReviewsByUser,
+    getReviewCount
+  };
+  const depsService = new DependencyGraph();
+
+  return {
+    registry: registryService,
+    resolver: resolverService,
+    runner: runnerService as any as ResolverService extends { runner: any } ? never : any,
+    reviews: reviewService,
+    deps: depsService
+  };
+}
+
+export interface InstallContext {
+  variables?: Record<string, unknown>;
+  timeout?: number;
+}
+
+export async function installPlugin(
+  marketplace: ReturnType<typeof createMarketplace>,
+  manifest: PluginManifest,
+  context: InstallContext = {}
+): Promise<{
+  dependencies: { name: string; version: string; satisfies: string }[];
+  executionResult: Parameters<typeof marketplace.runner.executeWithTimeout>[1];
+  }> {
+  const { registry, resolver, runner, deps } = marketplace;
+
+  // Validate required fields
+  if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+    throw new Error('Plugin manifest must have name, version, and entryPoint');
+  }
+
+  // Register the plugin
+  registry.register(manifest);
+
+  // Resolve dependencies
+  const dependencies = Object.entries(manifest.dependencies).map(([name, range]) => ({
+    name,
+    range
+  } as VersionConstraint));
+
+  const availableVersions: Record<string, string[]> = {};
+  for (const plugin of list()) {
+    if (!availableVersions[plugin.name]) {
+      availableVersions[plugin.name] = [];
+    }
+    availableVersions[plugin.name].push(plugin.version);
+  }
+
+  const resolved = resolver.resolve(dependencies, availableVersions);
+
+  // Check for circular dependencies across all resolved dependencies
+  for (const constraintName of resolved.map(r => r.name)) {
+    if (deps.hasCircularDependency(constraintName, registry)) {
+      throw new Error(`Circular dependency detected in ${constraintName}`);
+    }
+  }
+
+  // Execute the plugin entry point
+  const codeToExecute = await registry
+    .getVersion(manifest.name, manifest.version)
+    ?.entryPoint || '';
+
+  const executionResult = await runner.executeWithTimeout(
+    codeToExecute,
+    context.timeout || 10000,
+    context.variables || {}
+  );
+
+  return {
+    dependencies: resolved,
+    executionResult
+  };
+}
