+function sanitizeFtsQuery(query: string): string {
+  // Preserve user-supplied double-quoted phrases, sanitize the rest
+  const parts: string[] = [];
+  const regex = /"([^"]*)"|(\S+)/g;
+  let match;
+  while ((match = regex.exec(query)) !== null) {
+    if (match[1] !== undefined) {
+      // Quoted phrase — keep as quoted
+      parts.push(`"${match[1]}"`);
+    } else if (match[2]) {
+      // Unquoted term — strip FTS5 special chars and quote it
+      const term = match[2].replace(/["\(\)\*\+\-\:\^]/g, '');
+      if (term.length > 0) {
+        parts.push(`"${term}"`);
+      }
+    }
+  }
+  return parts.join(' ');
+}
