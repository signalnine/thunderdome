hould flag a review', () => {\n    const review = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'bad' });\n    reviews.flagReview(review.id);\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged).toHaveLength(1);\n    expect(flagged[0].id).toBe(review.id);\n  });\n\n  it('should remove a review', () => {\n    const review = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'good' });\n    expect(reviews.removeReview(review.id)).toBe(true);\n    expect(reviews.getReviews('p')).toHaveLength(0);\n  });\n\n  it('should return false when removing nonexistent review', () => {\n    expect(reviews.removeReview(999)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user-a', rating: 5, comment: 'a' });\n    reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'user-a', rating: 4, comment: 'b' });\n    reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user-b', rating: 3, comment: 'c' });\n\n    const userAReviews = reviews.getReviewsByUser('user-a');\n    expect(userAReviews).toHaveLength(2);\n    expect(userAReviews.every((r) => r.userId === 'user-a')).toBe(true);\n  });\n\n  it('should count reviews for a plugin', () => {\n    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: 'b' });\n    reviews.addReview({ pluginName: 'other', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'c' });\n    expect(reviews.getReviewCount('p')).toBe(2);\n  });\n\n  it('should assign unique incrementing IDs', () => {\n    const r1 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n    const r2 = reviews.addReview({ pluginName: 'p', pluginVersion