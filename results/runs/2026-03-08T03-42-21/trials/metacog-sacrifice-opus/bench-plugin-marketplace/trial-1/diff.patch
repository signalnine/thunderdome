depsService.topologicalSort('a', registry);\n      // c should come before b, b before a\n      expect(order.indexOf('c')).toBeLessThan(order.indexOf('b'));\n      expect(order.indexOf('b')).toBeLessThan(order.indexOf('a'));\n    });\n\n    it('should return single element for no deps', () => {\n      registry.register(makeManifest('solo'));\n      const order = depsService.topologicalSort('solo', registry);\n      expect(order).toEqual(['solo']);\n    });\n  });\n\n  describe('flattenDependencies', () => {\n    it('should return empty array for no deps', () => {\n      registry.register(makeManifest('solo'));\n      expect(depsService.flattenDependencies('solo', registry)).toEqual([]);\n    });\n\n    it('should flatten transitive dependencies', () => {\n      registry.register(makeManifest('a', { b: '^1.0.0' }));\n      registry.register(makeManifest('b', { c: '^1.0.0' }));\n      registry.register(makeManifest('c'));\n      const flat = depsService.flattenDependencies('a', registry);\n      expect(flat).toContain('b');\n      expect(flat).toContain('c');\n      expect(flat).not.toContain('a');\n    });\n\n    it('should not include duplicates', () => {\n      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));\n      registry.register(makeManifest('b', { c: '^1.0.0' }));\n      registry.register(makeManifest('c'));\n      const flat = depsService.flattenDependencies('a', registry);\n      const unique = new Set(flat);\n      expect(flat.length).toBe(unique.size);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1504,"cache_read_input_tokens":32581,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1504},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"59029eb3-f95e-4444-a17f-4718a3dfdd0a","uuid":"026e158c-a6a9-4197-b318-36ef55c4f