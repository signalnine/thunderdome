@@ -0,0 +1,134 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      const manifest = registry.get(name);
+      if (!manifest) {
+        return { name, version: 'unknown', dependencies: [] };
+      }
+
+      const visited = new Set<string>();
+
+      function build(pluginName: string): DependencyNode {
+        const m = registry.get(pluginName);
+        if (!m) {
+          return { name: pluginName, version: 'unknown', dependencies: [] };
+        }
+
+        if (visited.has(pluginName)) {
+          return { name: pluginName, version: m.version, dependencies: [] };
+        }
+        visited.add(pluginName);
+
+        const deps: DependencyNode[] = [];
+        for (const depName of Object.keys(m.dependencies)) {
+          deps.push(build(depName));
+        }
+
+        visited.delete(pluginName);
+        return { name: pluginName, version: m.version, dependencies: deps };
+      }
+
+      return build(name);
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles: string[][] = [];
+      const visited = new Set<string>();
+      const path: string[] = [];
+
+      function dfs(current: string): void {
+        if (path.includes(current)) {
+          const cycleStart = path.indexOf(current);
+          cycles.push([...path.slice(cycleStart), current]);
+          return;
+        }
+
+        if (visited.has(current)) return;
+
+        path.push(current);
+        const m = registry.get(current);
+        if (m) {
+          for (const depName of Object.keys(m.dependencies)) {
+            dfs(depName);
+          }
+        }
+        path.pop();
+        visited.add(current);
+      }
+
+      dfs(name);
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const result: string[] = [];
+      const visited = new Set<string>();
+      const visiting = new Set<string>();
+
+      function visit(current: string): void {
+        if (visited.has(current)) return;
+        if (visiting.has(current)) return; // cycle, skip
+
+        visiting.add(current);
+        const m = registry.get(current);
+        if (m) {
+          for (const depName of Object.keys(m.dependencies)) {
+            visit(depName);
+          }
+        }
+        visiting.delete(current);
+        visited.add(current);
+        result.push(current);
+      }
+
+      visit(name);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const deps = new Set<string>();
+      const visited = new Set<string>();
+
+      function collect(current: string): void {
+        if (visited.has(current)) return;
+        visited.add(current);
+
+        const m = registry.get(current);
+        if (m) {
+          for (const depName of Object.keys(m.dependencies)) {
+            deps.add(depName);
+            collect(depName);
+          }
+        }
+      }
+
+      collect(name);
+      return [...deps];
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const visiting = new Set<string>();
+      const visited = new Set<string>();
+
+      function hasCycle(current: string): boolean {
+        if (visiting.has(current)) return true;
+        if (visited.has(current)) return false;
+
+        visiting.add(current);
+        const m = registry.get(current);
+        if (m) {
+          for (const depName of Object.keys(m.dependencies)) {
+            if (hasCycle(depName)) return true;
+          }
+        }
+        visiting.delete(current);
+        visited.add(current);
+        return false;
+      }
+
+      return hasCycle(name);
+    },
+  };
+}
