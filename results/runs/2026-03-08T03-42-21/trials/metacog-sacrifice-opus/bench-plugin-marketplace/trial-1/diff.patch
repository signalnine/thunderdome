+import { describe, it, expect } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '"hello"',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  it('should create a marketplace with all services', () => {
+    const mp = createMarketplace();
+    expect(mp.registry).toBeDefined();
+    expect(mp.resolver).toBeDefined();
+    expect(mp.runner).toBeDefined();
+    expect(mp.reviews).toBeDefined();
+    expect(mp.deps).toBeDefined();
+    expect(mp.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin', async () => {
+      const mp = createMarketplace();
+      const result = await mp.installPlugin(makeManifest({ entryPoint: '1 + 1' }));
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe(2);
+      expect(result.resolvedDependencies).toEqual([]);
+    });
+
+    it('should reject plugin without name', async () => {
+      const mp = createMarketplace();
+      await expect(mp.installPlugin(makeManifest({ name: '' }))).rejects.toThrow(
+        'Plugin manifest must have name, version, and entryPoint'
+      );
+    });
+
+    it('should reject plugin without version', async () => {
+      const mp = createMarketplace();
+      await expect(mp.installPlugin(makeManifest({ version: '' }))).rejects.toThrow();
+    });
+
+    it('should reject plugin without entryPoint', async () => {
+      const mp = createMarketplace();
+      await expect(mp.installPlugin(makeManifest({ entryPoint: '' }))).rejects.toThrow();
+    });
+
+    it('should register plugin during install', async () => {
+      const mp = createMarketplace();
+      await mp.installPlugin(makeManifest());
+      const plugin = mp.registry.get('test-plugin');
+      expect(plugin).not.toBeNull();
+      expect(plugin!.name).toBe('test-plugin');
+    });
+
+    it('should resolve dependencies during install', async () => {
+      const mp = createMarketplace();
+      // Register dependency first
+      mp.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));
+      mp.registry.register(makeManifest({ name: 'dep-a', version: '1.2.0' }));
+
+      const result = await mp.installPlugin(
+        makeManifest({ dependencies: { 'dep-a': '^1.0.0' } })
+      );
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.resolvedDependencies[0].version).toBe('1.2.0');
+    });
+
+    it('should reject circular dependencies', async () => {
+      const mp = createMarketplace();
+      mp.registry.register(
+        makeManifest({ name: 'dep-a', dependencies: { 'test-plugin': '^1.0.0' } })
+      );
+
+      await expect(
+        mp.installPlugin(makeManifest({ dependencies: { 'dep-a': '^1.0.0' } }))
+      ).rejects.toThrow('Circular dependency');
+    });
+
+    it('should handle plugin code that throws', async () => {
+      const mp = createMarketplace();
+      const result = await mp.installPlugin(
+        makeManifest({ entryPoint: 'throw new Error("boom")' })
+      );
+      expect(result.sandboxResult.success).toBe(false);
+      expect(result.sandboxResult.error).toBe('boom');
+    });
