+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0185Mq6xYugpmnaMVX7fTnpy","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import request from 'supertest';\n     3→import { createApp } from '../src/index.js';\n     4→import { resetDefaultConnection } from '@monorepo/core';\n     5→\n     6→describe('Auth Routes', () => {\n     7→  let app: ReturnType<typeof createApp>;\n     8→\n     9→  beforeEach(() => {\n    10→    resetDefaultConnection();\n    11→    app = createApp();\n    12→  });\n    13→\n    14→  it('registers a new user', async () => {\n    15→    const res = await request(app)\n    16→      .post('/auth/register')\n    17→      .send({ name: 'New User', email: 'new@test.com' });\n    18→    expect(res.status).toBe(201);\n    19→    expect(res.body.token).toBeDefined();\n    20→    expect(res.body.user.role).toBe('user');\n    21→  });\n    22→\n    23→  it('rejects registration with invalid data', async () => {\n    24→    const res = await request(app)\n    25→      .post('/auth/register')\n    26→      .send({ name: '', email: 'bad' });\n    27→    expect(res.status).toBe(400);\n    28→  });\n    29→\n    30→  it('handles login', async () => {\n    31→    const res = await request(app)\n    32→      .post('/auth/login')\n    33→      .send({ email: 'user@test.com' });\n    34→    expect(res.status).toBe(200);\n    35→    expect(res.body.token).toBeDefined();\n    36→  });\n    37→\n    38→  it('rejects login without email', async () => {\n    39→    const res = await request(app)\n    40→      .post('/auth/login')\n    41→      .send({});\n    42→    expect(res.status).toBe(400);\n    43→  });\n    44→\n    45→  it('verifies valid token', async () => {\n    46→    const res = await request(app)\n    47→      .get('/auth/verify')\n    48→      .set('Authorization', 'Bearer mock-token-1');\n    49→    expect(res.status).toBe(200);\n    50→    expect(res.body.valid).toBe(tr