@@ -0,0 +1,92 @@
+import { randomUUID } from 'node:crypto';
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'blocked';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface TaskProgress {
+  percentage: number;
+  message?: string;
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+  progress: TaskProgress;
+  metadata: Record<string, unknown>;
+}
+
+export function createTask<T>(payload: T, options: TaskOptions = {}): Task<T> {
+  const now = new Date();
+  const priority = options.priority ?? 5;
+
+  if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+    throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+  }
+
+  let availableAt = now;
+  if (options.availableAt) {
+    availableAt = options.availableAt;
+  } else if (options.delay != null && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  }
+
+  return {
+    id: randomUUID(),
+    payload,
+    status: 'pending',
+    queue: options.queue ?? 'default',
+    priority,
+    createdAt: now,
+    availableAt,
+    attempt: 0,
+    maxRetries: options.maxRetries ?? 3,
+    backoffDelay: options.backoffDelay ?? 1000,
+    failureCount: 0,
+    dependencies: options.dependencies ?? [],
+    resolvedDependencies: new Set(),
+    progress: { percentage: 0 },
+    metadata: {},
+  };
+}
+
+export type ProgressListener = (progress: TaskProgress) => void;
+
+export type Middleware<T = unknown> = (task: Task<T>, next: () => void | Promise<void>) => void | Promise<void>;
+
+export type TaskHandler<T = unknown> = (task: Task<T>) => void | Promise<void>;
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue'>;
+  lastRun?: Date;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
