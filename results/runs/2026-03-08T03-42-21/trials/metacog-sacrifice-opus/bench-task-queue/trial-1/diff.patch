+++ b/src/cron.ts
@@ -0,0 +1,88 @@
+/**
+ * Simple cron expression parser supporting:
+ * - * /N * * * * -- every N minutes (written without space)
+ * - 0 * * * * -- every hour on the hour
+ * - 0 0 * * * -- every day at midnight
+ */
+export interface CronSchedule {
+  minute: { type: 'every'; interval: number } | { type: 'exact'; value: number };
+  hour: { type: 'any' } | { type: 'exact'; value: number };
+}
+
+export function parseCron(expression: string): CronSchedule {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}". Expected 5 fields.`);
+  }
+
+  const [minuteStr, hourStr, dayOfMonth, month, dayOfWeek] = parts;
+
+  // We only support * for the last 3 fields
+  if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {
+    throw new Error(`Unsupported cron expression: "${expression}". Only * is supported for day-of-month, month, and day-of-week.`);
+  }
+
+  let minute: CronSchedule['minute'];
+  if (minuteStr.startsWith('*/')) {
+    const interval = parseInt(minuteStr.slice(2), 10);
+    if (isNaN(interval) || interval <= 0 || interval > 59) {
+      throw new Error(`Invalid cron interval: "${minuteStr}".`);
+    }
+    minute = { type: 'every', interval };
+  } else {
+    const value = parseInt(minuteStr, 10);
+    if (isNaN(value) || value < 0 || value > 59) {
+      throw new Error(`Invalid cron minute value: "${minuteStr}".`);
+    }
+    minute = { type: 'exact', value };
+  }
+
+  let hour: CronSchedule['hour'];
+  if (hourStr === '*') {
+    hour = { type: 'any' };
+  } else {
+    const value = parseInt(hourStr, 10);
+    if (isNaN(value) || value < 0 || value > 23) {
+      throw new Error(`Invalid cron hour value: "${hourStr}".`);
+    }
+    hour = { type: 'exact', value };
+  }
+
+  return { minute, hour };
+}
+
+export function shouldRun(schedule: CronSchedule, now: Date, lastRun: Date | undefined): boolean {
+  const currentMinute = now.getMinutes();
+  const currentHour = now.getHours();
+
+  // Check hour constraint
+  if (schedule.hour.type === 'exact' && currentHour !== schedule.hour.value) {
+    return false;
+  }
+
+  // Check minute constraint
+  if (schedule.minute.type === 'exact') {
+    if (currentMinute !== schedule.minute.value) {
+      return false;
+    }
+  } else {
+    // every N minutes - check if current minute is divisible by interval
+    if (currentMinute % schedule.minute.interval !== 0) {
+      return false;
+    }
+  }
+
+  // Don't run if we already ran in this same minute
+  if (lastRun) {
+    const lastRunMinute = lastRun.getMinutes();
+    const lastRunHour = lastRun.getHours();
+    const lastRunDate = lastRun.toDateString();
+    const nowDate = now.toDateString();
+
+    if (lastRunDate === nowDate && lastRunHour === currentHour && lastRunMinute === currentMinute) {
+      return false;
+    }
+  }
+
+  return true;
+}
