+import { randomUUID } from 'node:crypto';
+import {
+  Task,
+  TaskOptions,
+  TaskProgress,
+  ProgressListener,
+  Middleware,
+  TaskHandler,
+  Schedule,
+  ShutdownResult,
+  createTask,
+} from './types.js';
+import { parseCron, shouldRun, CronSchedule } from './cron.js';
+
+interface QueueState {
+  tasks: Task[];
+  deadLetterQueue: Task[];
+  concurrencyLimit: number | null;
+  middlewares: Middleware[];
+  handler: TaskHandler | null;
+}
+
+export class TaskQueue {
+  private queues: Map<string, QueueState> = new Map();
+  private allTasks: Map<string, Task> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private schedules: Map<string, Schedule & { parsed: CronSchedule }> = new Map();
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+
+  // -- Queue management --
+
+  private getOrCreateQueue(name: string): QueueState {
+    let q = this.queues.get(name);
+    if (!q) {
+      q = {
+        tasks: [],
+        deadLetterQueue: [],
+        concurrencyLimit: null,
+        middlewares: [],
+        handler: null,
+      };
+      this.queues.set(name, q);
+    }
+    return q;
+  }
+
+  private getQueue(name: string): QueueState | undefined {
+    return this.queues.get(name);
+  }
+
+  // -- Phase 1 & 2: Add and retrieve tasks --
+
+  addTask<T = unknown>(payload: T, options?: TaskOptions): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Cannot add tasks: the queue system is shutting down.');
+    }
+
+    const task = createTask(payload, options);
+
+    // Phase 7: Validate dependencies
+    if (task.dependencies.length > 0) {
+      for (const depId of task.dependencies) {
+        const depTask = this.allTasks.get(depId);
+        if (!depTask) {
+          throw new Error(`Dependency task "${depId}" does not exist.`);
+        }
+      }
+
+      // Circular dependency detection
+      this.detectCircularDependencies(task.id, task.dependencies);
+
+      // Resolve already completed dependencies
+      for (const depId of task.dependencies) {
+        const depTask = this.allTasks.get(depId);
+        if (depTask && depTask.status === 'completed') {
+          task.resolvedDependencies.add(depId);
+        }
+      }
+
+      // If not all dependencies resolved, mark as blocked
+      if (task.resolvedDependencies.size < task.dependencies.length) {
+        task.status = 'blocked';
+      }
+    }
+
+    const queue = this.getOrCreateQueue(task.queue);
+    queue.tasks.push(task);
+    this.allTasks.set(task.id, task as Task);
+    return task;
+  }
+
+  private detectCircularDependencies(newTaskId: string, deps: string[]): void {
+    const visited = new Set<string>();
+
+    const dfs = (taskId: string): void => {
+      if (visited.has(taskId)) return;
+      visited.add(taskId);
+
+      const task = this.allTasks.get(taskId);
+      if (task) {
+        for (const depId of task.dependencies) {
+          if (depId === newTaskId) {
+            throw new Error('Circular dependency detected.');
+          }
+          dfs(depId);
+        }
+      }
+    };
+
+    for (const depId of deps) {
+      dfs(depId);
+    }
+  }
+
+  getNextTask(queueName = 'default'): Task | null {
+    const queue = this.getQueue(queueName);
+    if (!queue) return null;
+
+    // Phase 8: Concurrency check
+    if (queue.concurrencyLimit !== null) {
+      const activeCount = this.getActiveCount(queueName);
+      if (activeCount >= queue.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+
+    // Find the best available task:
+    // 1. Must be pending (not blocked, not processing, etc.)
+    // 2. Must be available (availableAt <= now)
+    // 3. Sort by: availableAt, priority, createdAt (FIFO)
+    const availableTasks = queue.tasks.filter(t =>
+      t.status === 'pending' && t.availableAt <= now
+    );
+
+    if (availableTasks.length === 0) return null;
+
+    // Sort: priority first (lower = higher priority), then availableAt, then createdAt
+    availableTasks.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const aTime = a.availableAt.getTime();
+      const bTime = b.availableAt.getTime();
+      if (aTime !== bTime) return aTime - bTime;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = availableTasks[0];
+    task.status = 'processing';
+    task.attempt += 1;
+    return task;
+  }
+
+  // -- Phase 1: Queue size --
+
+  getWaitingCount(queueName = 'default'): number {
+    const queue = this.getQueue(queueName);
+    if (!queue) return 0;
+    return queue.tasks.filter(t => t.status === 'pending' && t.availableAt <= new Date()).length;
+  }
+
+  // -- Phase 2: List queues --
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // -- Phase 5: Complete and fail tasks --
+
+  completeTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state (current: ${task.status}).`);
+    }
+
+    task.status = 'completed';
+    task.progress = { percentage: 100 };
+
+    // Phase 7: Unblock dependent tasks
+    this.resolveDependentsOf(taskId);
+  }
+
+  failTask(taskId: string, error?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state (current: ${task.status}).`);
+    }
+
+    task.error = error;
+    task.failureCount += 1;
+
+    // Check if we have retries remaining
+    if (task.attempt < task.maxRetries) {
+      // Re-add with exponential backoff delay
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      // Task stays in the same queue, same position in the array
+    } else {
+      // No retries left
+      task.status = 'failed';
+
+      // Phase 6: Move to dead letter queue
+      const queue = this.getQueue(task.queue);
+      if (queue) {
+        // Remove from active tasks list
+        const idx = queue.tasks.indexOf(task);
+        if (idx !== -1) {
+          queue.tasks.splice(idx, 1);
+        }
+        queue.deadLetterQueue.push(task);
+      }
+    }
+  }
+
+  // -- Phase 6: Dead letter queue --
+
+  getDeadLetterTasks(queueName = 'default'): Task[] {
+    const queue = this.getQueue(queueName);
+    if (!queue) return [];
+    return [...queue.deadLetterQueue];
+  }
+
+  retryDeadLetterTask(taskId: string): Task {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+
+    const queue = this.getQueue(task.queue);
+    if (!queue) {
+      throw new Error(`Queue "${task.queue}" not found.`);
+    }
+
+    const dlqIdx = queue.deadLetterQueue.indexOf(task);
+    if (dlqIdx === -1) {
+      throw new Error(`Task "${taskId}" is not in the dead letter queue.`);
+    }
+
+    // Remove from DLQ
+    queue.deadLetterQueue.splice(dlqIdx, 1);
+
+    // Reset task for fresh retries
+    task.status = 'pending';
+    task.attempt = 0;
+    task.failureCount = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.progress = { percentage: 0 };
+
+    // Add back to queue
+    queue.tasks.push(task);
+    return task;
+  }
+
+  clearDeadLetterQueue(queueName = 'default'): void {
+    const queue = this.getQueue(queueName);
+    if (!queue) return;
+
+    for (const task of queue.deadLetterQueue) {
+      this.allTasks.delete(task.id);
+    }
+    queue.deadLetterQueue = [];
+  }
+
+  // -- Phase 7: Dependencies --
+
+  private resolveDependentsOf(completedTaskId: string): void {
+    for (const [, task] of this.allTasks) {
+      if (task.status === 'blocked' && task.dependencies.includes(completedTaskId)) {
+        task.resolvedDependencies.add(completedTaskId);
+
+        // Check if all dependencies are now resolved
+        if (task.resolvedDependencies.size >= task.dependencies.length) {
+          task.status = 'pending';
+        }
+      }
+    }
+  }
+
+  getTaskDependencyStatus(taskId: string): {
+    dependencies: string[];
+    resolved: string[];
+    unresolved: string[];
+  } {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+
+    const resolved = Array.from(task.resolvedDependencies);
+    const unresolved = task.dependencies.filter(d => !task.resolvedDependencies.has(d));
+
+    return { dependencies: task.dependencies, resolved, unresolved };
+  }
+
+  // -- Phase 8: Concurrency --
+
+  setConcurrency(queueName: string, limit: number | null): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string): number | null {
+    const queue = this.getQueue(queueName);
+    if (!queue) return null;
+    return queue.concurrencyLimit;
+  }
+
+  getActiveCount(queueName: string): number {
+    const queue = this.getQueue(queueName);
+    if (!queue) return 0;
+    return queue.tasks.filter(t => t.status === 'processing').length;
+  }
+
+  // -- Phase 9: Progress --
+
+  updateProgress(taskId: string, percentage: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state.`);
+    }
+
+    task.progress = { percentage, message };
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(task.progress);
+      }
+    }
+  }
+
+  getProgress(taskId: string): TaskProgress {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+    return { ...task.progress };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    let listeners = this.progressListeners.get(taskId);
+    if (!listeners) {
+      listeners = new Set();
+      this.progressListeners.set(taskId, listeners);
+    }
+    listeners.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      listeners!.delete(listener);
+      if (listeners!.size === 0) {
+        this.progressListeners.delete(taskId);
+      }
+    };
+  }
+
+  // -- Phase 9: Cancellation --
+
+  cancelTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task "${taskId}" not found.`);
+    }
+
+    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {
+      throw new Error(`Task "${taskId}" cannot be cancelled (current status: ${task.status}).`);
+    }
+
+    const previousStatus = task.status;
+    task.status = 'cancelled';
+
+    // If it was pending/blocked, remove from queue
+    if (previousStatus === 'pending' || previousStatus === 'blocked') {
+      const queue = this.getQueue(task.queue);
+      if (queue) {
+        const idx = queue.tasks.indexOf(task);
+        if (idx !== -1) {
+          queue.tasks.splice(idx, 1);
+        }
+      }
+    }
+  }
+
+  // -- Phase 10: Recurring tasks --
+
+  addSchedule(
+    cronExpression: string,
+    queueName: string,
+    payload: unknown,
+    taskOptions?: Omit<TaskOptions, 'queue'>
+  ): string {
+    if (this.isShutdown) {
+      throw new Error('Cannot add schedules: the queue system is shutting down.');
+    }
+
+    const parsed = parseCron(cronExpression);
+    const id = randomUUID();
+    this.schedules.set(id, {
+      id,
+      cronExpression,
+      queue: queueName,
+      payload,
+      taskOptions,
+      parsed,
+    });
+    return id;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule "${scheduleId}" not found.`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values()).map(s => ({
+      id: s.id,
+      cronExpression: s.cronExpression,
+      queue: s.queue,
+      payload: s.payload,
+      taskOptions: s.taskOptions,
+      lastRun: s.lastRun,
+    }));
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const enqueued: Task[] = [];
+
+    for (const [, schedule] of this.schedules) {
+      if (shouldRun(schedule.parsed, currentTime, schedule.lastRun)) {
+        const task = this.addTask(schedule.payload, {
+          ...schedule.taskOptions,
+          queue: schedule.queue,
+        });
+        schedule.lastRun = currentTime;
+        enqueued.push(task as Task);
+      }
+    }
+
+    return enqueued;
+  }
+
+  // -- Phase 11: Middleware --
+
+  use(queueName: string, middleware: Middleware): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.middlewares.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: TaskHandler): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.handler = handler;
+  }
+
+  async processTask(queueName = 'default'): Promise<Task | null> {
+    const task = this.getNextTask(queueName);
+    if (!task) return null;
+
+    const queue = this.getQueue(queueName)!;
+    const middlewares = [...queue.middlewares];
+    const handler = queue.handler;
+
+    try {
+      let index = 0;
+      const runNext = async (): Promise<void> => {
+        if (index < middlewares.length) {
+          const mw = middlewares[index++];
+          await mw(task, runNext);
+        } else if (handler) {
+          await handler(task);
+        }
+      };
+
+      await runNext();
+
+      // If still processing (middleware/handler didn't complete/fail it), mark complete
+      if (task.status === 'processing') {
+        this.completeTask(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.failTask(task.id, err instanceof Error ? err.message : String(err));
+      }
+    }
+
+    return task;
+  }
+
+  // -- Phase 12: Graceful shutdown --
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.performShutdown(timeout);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(timeout: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Find all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const [, queue] of this.queues) {
+      for (const task of queue.tasks) {
+        if (task.status === 'processing') {
+          processingTasks.push(task);
+        }
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const waitStart = Date.now();
+    while (Date.now() - waitStart < timeout) {
+      const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+      if (stillProcessing.length === 0) break;
+      await new Promise(resolve => setTimeout(resolve, 50));
+    }
+
+    // Count completed and force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'completed' || task.status === 'failed') {
+        completed++;
+      } else if (task.status === 'processing') {
+        task.status = 'cancelled';
+        forceCancelled++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+
+  // -- Utility --
+
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  get isShuttingDown(): boolean {
+    return this.isShutdown;
+  }
+}
