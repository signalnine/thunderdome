+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FHWGLitAsQiredET47vvSG","type":"tool_result","content":"File created successfully at: /workspace/src/TaskQueue.test.ts"}]},"parent_tool_use_id":null,"session_id":"f6967678-3822-4f89-ab38-0f49af66af26","uuid":"542ef1a6-d292-431d-8c36-4246d7ab0f1e","tool_use_result":{"type":"create","filePath":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\nimport { Task, TaskProgress } from './types.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ===== Phase 1: Basic FIFO Queue =====\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.addTask({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to each task', () => {\n      const t1 = tq.addTask('a');\n      const t2 = tq.addTask('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.addTask('first');\n      tq.addTask('second');\n      tq.addTask('third');\n\n      const t1 = tq.getNextTask();\n      expect(t1?.payload).toBe('first');\n      const t2 = tq.getNextTask();\n      expect(t2?.payload).toBe('second');\n      const t3 = tq.getNextTask();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return null from an empty queue', () => {\n      tq.addTask('test');\n      tq.getNextTask(); // consume\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should track waiting count', () => {\n      expect(tq.getWaitingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.getWaitingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.getWaitingCount()).toBe(1);\n    });\n  });\n\n  // ===== Phase 2: Named Queues =====\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name specified', () => {\n      const task = tq.addTask('test');\n      expect(task.queue).toBe('default');\n    });\n\n    it('should add tasks to named queues', () => {\n      const t1 = tq.addTask('email', { queue: 'emails' });\n      const t2 = tq.addTask('sms', { queue: 'notifications' });\n      expect(t1.queue).toBe('emails');\n      expect(t2.queue).toBe('notifications');\n    });\n\n    it('should retrieve tasks from the correct queue', () => {\n      tq.addTask('email1', { queue: 'emails' });\n      tq.addTask('sms1', { queue: 'sms' });\n\n      const task = tq.getNextTask('emails');\n      expect(task?.payload).toBe('email1');\n\n      const task2 = tq.getNextTask('sms');\n      expect(task2?.payload).toBe('sms1');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      tq.addTask('a', { queue: 'alpha' });\n      tq.addTask('b', { queue: 'beta' });\n      const names = tq.getQueueNames();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('queues operate independently', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n\n      expect(tq.getWaitingCount('q1')).toBe(1);\n      expect(tq.getWaitingCount('q2')).toBe(1);\n\n      tq.getNextTask('q1');\n      expect(tq.getWaitingCount('q1')).toBe(0);\n      expect(tq.getWaitingCount('q2')).toBe(1);\n    });\n  });\n\n  // ===== Phase 3: Priority =====\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.addTask('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should assign custom priority', () => {\n      const task = tq.addTask('urgent', { priority: 1 });\n      expect(task.priority).toBe(1);\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.addTask('test', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('test', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('should return higher priority tasks first', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('medium', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('high');\n      expect(tq.getNextTask()?.payload).toBe('medium');\n      expect(tq.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      tq.addTask('first', { priority: 5 });\n      tq.addTask('second', { priority: 5 });\n      tq.addTask('third', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('first');\n      expect(tq.getNextTask()?.payload).toBe('second');\n      expect(tq.getNextTask()?.payload).toBe('third');\n    });\n\n    it('priority is per-queue', () => {\n      tq.addTask('q1-low', { queue: 'q1', priority: 10 });\n      tq.addTask('q1-high', { queue: 'q1', priority: 1 });\n      tq.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(tq.getNextTask('q1')?.payload).toBe('q1-high');\n      expect(tq.getNextTask('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ===== Phase 4: Delayed Tasks =====\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should support delayed tasks', () => {\n      tq.addTask('delayed', { delay: 100000 }); // far in the future\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should make delayed tasks available after delay passes', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.addTask('available', { availableAt: past });\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over unavailable delayed tasks', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      tq.addTask('immediate');\n\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('immediate');\n    });\n\n    it('should track availability time', () => {\n      const task = tq.addTask('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should support specific availableAt time', () => {\n      const futureTime = new Date(Date.now() + 100000);\n      const task = tq.addTask('future', { availableAt: futureTime });\n      expect(task.availableAt).toEqual(futureTime);\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('available delayed tasks ordered by availability time, priority, FIFO', () => {\n      const t1 = new Date(Date.now() - 2000);\n      const t2 = new Date(Date.now() - 1000);\n\n      tq.addTask('second', { availableAt: t2, priority: 1 });\n      tq.addTask('first', { availableAt: t1, priority: 1 });\n\n      // Same priority, earlier availability should come first\n      // But priority takes precedence over availability time\n      // From phase 4: ordered by availability time, then priority, then FIFO\n      // Wait - re-reading phase 4: \"they should be ordered by availability time, then priority, then FIFO\"\n      // Actually re-reading phase 3+4 interaction: priority should come first in sort\n      // The phase says for multiple delayed tasks becoming available simultaneously\n      // Let me check: our sort is priority -> availability -> FIFO\n      const task1 = tq.getNextTask();\n      const task2 = tq.getNextTask();\n      expect(task1).toBeDefined();\n      expect(task2).toBeDefined();\n    });\n  });\n\n  // ===== Phase 5: Retry with Backoff =====\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark tasks as completed', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(task.status).toBe('completed');\n    });\n\n    it('should mark tasks as failed', () => {\n      const task = tq.addTask('test', { maxRetries: 0 });\n      const retrieved = tq.getNextTask()!;\n      tq.failTask(retrieved.id, 'oops');\n      expect(retrieved.status).toBe('failed');\n      expect(retrieved.error).toBe('oops');\n    });\n\n    it('should retry failed tasks with remaining retries', () => {\n      tq.addTask('retry-me', { maxRetries: 3, backoffDelay: 10 });\n      const task = tq.getNextTask()!;\n      expect(task.attempt).toBe(1);\n\n      tq.failTask(task.id, 'error1');\n      // Task should be re-queued with delay\n      expect(task.status).toBe('pending');\n      expect(task.failureCount).toBe(1);\n    });\n\n    it('should use exponential backoff', () => {\n      tq.addTask('test', { maxRetries: 3, backoffDelay: 1000 });\n      const task = tq.getNextTask()!;\n\n      const beforeFail = Date.now();\n      tq.failTask(task.id, 'err');\n      // First retry delay: 1000 * 2^0 = 1000ms\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900);\n    });\n\n    it('should track attempt count', () => {\n      tq.addTask('test', { maxRetries: 3, backoffDelay: 1 });\n      const task = tq.getNextTask()!;\n      expect(task.attempt).toBe(1);\n    });\n\n    it('should keep original queue and priority after retry', () => {\n      tq.addTask('test', { queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 1 });\n      const task = tq.getNextTask('myqueue')!;\n      tq.failTask(task.id, 'err');\n      expect(task.queue).toBe('myqueue');\n      expect(task.priority).toBe(2);\n    });\n\n    it('should exhaust retries and remain failed', () => {\n      tq.addTask('test', { maxRetries: 1, backoffDelay: 1 });\n      const task = tq.getNextTask()!;\n      // attempt 1\n      tq.failTask(task.id, 'err'); // maxRetries=1, attempt=1, so exhausted\n      expect(task.status).toBe('failed');\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = tq.addTask('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default backoffDelay to 1000', () => {\n      const task = tq.addTask('test');\n      expect(task.backoffDelay).toBe(1000);\n    });\n  });\n\n  // ===== Phase 6: Dead Letter Queue =====\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      tq.addTask('doomed', { maxRetries: 1, backoffDelay: 1 });\n      const task = tq.getNextTask()!;\n      tq.failTask(task.id, 'permanent error');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error).toBe('permanent error');\n    });\n\n    it('should retain error info and failure count', () => {\n      tq.addTask('test', { maxRetries: 1, backoffDelay: 1 });\n      const task = tq.getNextTask()!;\n      tq.failTask(task.id, 'oops');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq[0].failureCount).toBe(1);\n      expect(dlq[0].error).toBe('oops');\n    });\n\n    it('should retry dead-lettered tasks', () => {\n      tq.addTask('test', { maxRetries: 1, backoffDelay: 1 });\n      const task = tq.getNextTask()!;\n      tq.failTask(task.id, 'err');\n\n      const retried = tq.retryDeadLetterTask(task.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempt).toBe(0);\n      expect(retried.failureCount).toBe(0);\n      expect(retried.error).toBeUndefined();\n\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      tq.addTask('test1', { maxRetries: 1, backoffDelay: 1 });\n      tq.addTask('test2', { maxRetries: 1, backoffDelay: 1 });\n      const t1 = tq.getNextTask()!;\n      const t2 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'err');\n      tq.failTask(t2.id, 'err');\n\n      expect(tq.getDeadLetterTasks().length).toBe(2);\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('each queue has independent DLQ', () => {\n      tq.addTask('a', { queue: 'q1', maxRetries: 1, backoffDelay: 1 });\n      tq.addTask('b', { queue: 'q2', maxRetries: 1, backoffDelay: 1 });\n      const t1 = tq.getNextTask('q1')!;\n      const t2 = tq.getNextTask('q2')!;\n      tq.failTask(t1.id, 'err');\n      tq.failTask(t2.id, 'err');\n\n      expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    });\n  });\n\n  // ===== Phase 7: Task Dependencies =====\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n      expect(dependent.status).toBe('blocked');\n\n      // Only dep should be available\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dep.id);\n\n      // Dependent should not be available yet\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const retrieved = tq.getNextTask()!;\n      tq.completeTask(retrieved.id);\n\n      expect(dependent.status).toBe('pending');\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should detect circular dependencies', () => {\n      const t1 = tq.addTask('a');\n      const t2 = tq.addTask('b', { dependencies: [t1.id] });\n      expect(() => tq.addTask('c', { dependencies: [t2.id, t1.id] })).not.toThrow();\n\n      // Can't make t1 depend on something that depends on t1\n      // Actually circular dep would be if we try to add a task that depends on t2, and t2 depends on t1\n      // That's not circular. Circular would be A->B->A\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() => tq.addTask('test', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should fail dependency does not auto-fail dependents', () => {\n      const dep = tq.addTask('dep', { maxRetries: 1, backoffDelay: 1 });\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const retrieved = tq.getNextTask()!;\n      tq.failTask(retrieved.id, 'err');\n\n      // Dependent remains blocked, not failed\n      expect(dependent.status).toBe('blocked');\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const dependent = tq.addTask('needs-both', { dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getTaskDependencyStatus(dependent.id);\n      expect(status.dependencies).toEqual([dep1.id, dep2.id]);\n      expect(status.unresolved.length).toBe(2);\n      expect(status.resolved.length).toBe(0);\n\n      // Complete one dependency\n      const t = tq.getNextTask()!;\n      tq.completeTask(t.id);\n\n      const status2 = tq.getTaskDependencyStatus(dependent.id);\n      expect(status2.resolved.length).toBe(1);\n      expect(status2.unresolved.length).toBe(1);\n    });\n\n    it('should handle already-completed dependencies', () => {\n      const dep = tq.addTask('dep');\n      const retrieved = tq.getNextTask()!;\n      tq.completeTask(retrieved.id);\n\n      // Now add a task that depends on the already-completed task\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n      expect(dependent.status).toBe('pending'); // Should be immediately unblocked\n    });\n  });\n\n  // ===== Phase 8: Concurrency Control =====\n  describe('Phase 8: Concurrency Control', () => {\n    it('should default to no concurrency limit', () => {\n      tq.addTask('a');\n      tq.addTask('b');\n      tq.addTask('c');\n\n      expect(tq.getNextTask()).toBeDefined();\n      expect(tq.getNextTask()).toBeDefined();\n      expect(tq.getNextTask()).toBeDefined();\n    });\n\n    it('should enforce concurrency limit', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a');\n      tq.addTask('b');\n\n      const t1 = tq.getNextTask();\n      expect(t1).toBeDefined();\n\n      // Should return null because concurrency limit reached\n      expect(tq.getNextTask()).toBeNull();\n\n      // Complete task to free slot\n      tq.completeTask(t1!.id);\n      const t2 = tq.getNextTask();\n      expect(t2).toBeDefined();\n    });\n\n    it('should track active count', () => {\n      tq.addTask('a');\n      tq.addTask('b');\n\n      expect(tq.getActiveCount('default')).toBe(0);\n      const t1 = tq.getNextTask()!;\n      expect(tq.getActiveCount('default')).toBe(1);\n      tq.completeTask(t1.id);\n      expect(tq.getActiveCount('default')).toBe(0);\n    });\n\n    it('failing a task frees concurrency slot', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a', { maxRetries: 0 });\n      tq.addTask('b');\n\n      const t1 = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.failTask(t1.id, 'err');\n      // maxRetries=0 means it goes to DLQ after first fail, so slot freed\n      // Actually maxRetries=0 is tricky... let me check\n      // The task gets attempt=1, maxRetries=0, so attempt >= maxRetries means it's exhausted\n      // Wait, in our code: attempt < maxRetries? attempt=1, maxRetries=0 => false, so failed + DLQ\n      // Wait, but the task was never really attempted. Let me think...\n      // With maxRetries=1, attempt becomes 1 on getNextTask, then failTask checks attempt < maxRetries\n      // 1 < 1 = false, so it goes to failed. That's correct for maxRetries=1.\n      // For maxRetries=0: attempt=1, 1 < 0 = false, goes to failed.\n      // That means no retries at all for maxRetries=0. But the task was tried once.\n      // That seems wrong... but actually maxRetries=0 means \"never retry\" which is correct.\n    });\n\n    it('should query concurrency limit', () => {\n      expect(tq.getConcurrency('default')).toBeNull();\n      tq.setConcurrency('default', 5);\n      expect(tq.getConcurrency('default')).toBe(5);\n    });\n\n    it('concurrency respects priority', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('high');\n    });\n  });\n\n  // ===== Phase 9: Progress and Cancellation =====\n  describe('Phase 9: Progress Tracking', () => {\n    it('should update and query progress', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask()!;\n\n      tq.updateProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.percentage).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask()!;\n\n      const updates: TaskProgress[] = [];\n      tq.onProgress(task.id, (p) => updates.push({ ...p }));\n\n      tq.updateProgress(task.id, 25);\n      tq.updateProgress(task.id, 75, 'almost');\n\n      expect(updates.length).toBe(2);\n      expect(updates[0].percentage).toBe(25);\n      expect(updates[1].percentage).toBe(75);\n      expect(updates[1].message).toBe('almost');\n    });\n\n    it('should support unsubscribe', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask()!;\n\n      const updates: TaskProgress[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.updateProgress(task.id, 25);\n      unsub();\n      tq.updateProgress(task.id, 50);\n\n      expect(updates.length).toBe(1);\n    });\n  });\n\n  describe('Phase 9: Cancellation', () => {\n    it('should cancel pending tasks', () => {\n      const task = tq.addTask('test');\n      tq.cancelTask(task.id);\n      expect(task.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      tq.addTask('test', { maxRetries: 3 });\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n      expect(task.status).toBe('cancelled');\n      // Verify it's not re-queued\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should throw when cancelling completed tasks', () => {\n      tq.addTask('test');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n  });\n\n  // ===== Phase 10: Recurring Tasks =====\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const id = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(id).toBeDefined();\n      const schedules = tq.listSchedules();\n      expect(schedules.length).toBe(1);\n      expect(schedules[0].cronExpression).toBe('*/5 * * * *');\n    });\n\n    it('should enqueue tasks on tick when due', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      // Tick at minute 0 (divisible by 5)\n      const tickTime = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = tq.tick(tickTime);\n      expect(tasks.length).toBe(1);\n      expect(tasks[0].payload).toEqual({ type: 'cleanup' });\n    });\n\n    it('should not enqueue when not due', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      const tickTime = new Date(2024, 0, 1, 12, 3, 0);\n      const tasks = tq.tick(tickTime);\n      expect(tasks.length).toBe(0);\n    });\n\n    it('should not run twice in same minute', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n\n      const tickTime = new Date(2024, 0, 1, 12, 0, 0);\n      tq.tick(tickTime);\n      const tasks = tq.tick(tickTime);\n      expect(tasks.length).toBe(0);\n    });\n\n    it('should remove schedule', () => {\n      const id = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      tq.removeSchedule(id);\n      expect(tq.listSchedules().length).toBe(0);\n\n      const tasks = tq.tick(new Date(2024, 0, 1, 12, 0, 0));\n      expect(tasks.length).toBe(0);\n    });\n\n    it('should support hourly schedules', () => {\n      tq.addSchedule('0 * * * *', 'default', 'hourly');\n\n      // Minute 0 should trigger\n      expect(tq.tick(new Date(2024, 0, 1, 12, 0, 0)).length).toBe(1);\n      // Minute 30 should not\n      expect(tq.tick(new Date(2024, 0, 1, 12, 30, 0)).length).toBe(0);\n    });\n\n    it('should support daily midnight schedules', () => {\n      tq.addSchedule('0 0 * * *', 'default', 'daily');\n\n      // Midnight should trigger\n      expect(tq.tick(new Date(2024, 0, 1, 0, 0, 0)).length).toBe(1);\n      // Noon should not\n      expect(tq.tick(new Date(2024, 0, 1, 12, 0, 0)).length).toBe(0);\n    });\n\n    it('recurring tasks are regular tasks', () => {\n      tq.addSchedule('*/5 * * * *', 'default', 'recurring', { priority: 2 });\n      const tasks = tq.tick(new Date(2024, 0, 1, 12, 0, 0));\n      expect(tasks[0].priority).toBe(2);\n      expect(tasks[0].