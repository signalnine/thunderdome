mpSync(join(tmpdir(), 'collab-test-'));\n    const dbFile = join(tmpDir, 'test.db');\n\n    try {\n      // Create doc and make edit via WebSocket\n      const app1 = createApp(dbFile);\n      const port1 = await app1.start(0);\n      const res = await fetch(`http://localhost:${port1}/api/documents`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ title: 'Versioned', content: 'v0' }),\n      });\n      const doc = await res.json();\n\n      const ws = new WebSocket(`ws://localhost:${port1}/ws/${doc.id}`);\n      await new Promise<void>((resolve) => ws.on('open', resolve));\n      await waitForMessage(ws); // sync\n\n      ws.send(JSON.stringify({\n        type: 'operation',\n        docId: doc.id,\n        version: 0,\n        operation: [2, ' updated'],\n        clientId: 'test',\n      }));\n      await waitForMessage(ws); // ack\n      ws.close();\n      await new Promise(r => setTimeout(r, 100));\n      await app1.stop();\n\n      // Verify on second server instance\n      const app2 = createApp(dbFile);\n      const port2 = await app2.start(0);\n      const versionsRes = await fetch(`http://localhost:${port2}/api/documents/${doc.id}/versions`);\n      const versions = await versionsRes.json();\n      expect(versions.length).toBe(2); // version 0 and 1\n      expect(versions[1].content).toBe('v0 updated');\n      await app2.stop();\n    } finally {\n      rmSync(tmpDir, { recursive: true, force: true });\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null}}
