new file mode 100644
index 0000000..24c246c
--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,278 @@
+import { WebSocket, WebSocketServer } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server } from 'http';
+import { Socket } from 'net';
+import { DocumentStore } from './db.js';
+import {
+  Operation,
+  OperationMessage,
+  ServerMessage,
+  apply,
+  transform,
+  validate,
+} from './ot.js';
+import { randomUUID } from 'crypto';
+
+interface ConnectedClient {
+  ws: WebSocket;
+  clientId: string;
+  docId: string;
+}
+
+interface DocumentSession {
+  docId: string;
+  content: string;
+  version: number;
+  clients: Map<string, ConnectedClient>;
+  /** Operation history indexed by version (version N is the op that produced version N from N-1). */
+  history: Operation[];
+}
+
+export class CollaborationManager {
+  private sessions: Map<string, DocumentSession> = new Map();
+  private store: DocumentStore;
+  private wss: WebSocketServer | null = null;
+  private closed = false;
+
+  constructor(store: DocumentStore) {
+    this.store = store;
+  }
+
+  createWebSocketServer(server: Server): WebSocketServer {
+    this.wss = new WebSocketServer({ noServer: true });
+
+    server.on('upgrade', (request: IncomingMessage, socket: Socket, head: Buffer) => {
+      const url = request.url || '';
+      const match = url.match(/\/ws\/([^/?]+)/);
+      if (!match) {
+        socket.write('HTTP/1.1 400 Bad Request\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      this.wss!.handleUpgrade(request, socket, head, (ws) => {
+        this.wss!.emit('connection', ws, request);
+      });
+    });
+
+    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      this.handleConnection(ws, req);
+    });
+
+    return this.wss;
+  }
+
+  private handleConnection(ws: WebSocket, req: IncomingMessage): void {
+    const url = req.url || '';
+    const match = url.match(/\/ws\/([^/?]+)/);
+    if (!match) {
+      this.sendMessage(ws, { type: 'error', message: 'Invalid WebSocket URL. Use /ws/:docId' });
+      ws.close();
+      return;
+    }
+
+    const docId = match[1];
+    const doc = this.store.getDocument(docId);
+    if (!doc) {
+      this.sendMessage(ws, { type: 'error', message: 'Document not found' });
+      ws.close();
+      return;
+    }
+
+    const clientId = randomUUID();
+    const session = this.getOrCreateSession(docId);
+    const client: ConnectedClient = { ws, clientId, docId };
+    session.clients.set(clientId, client);
+
+    // Send sync message with current state
+    this.sendMessage(ws, {
+      type: 'sync',
+      docId,
+      content: session.content,
+      version: session.version,
+    });
+
+    ws.on('message', (data: Buffer | string) => {
+      try {
+        const raw = typeof data === 'string' ? data : data.toString('utf-8');
+        const msg = JSON.parse(raw);
+        this.handleClientMessage(client, msg);
+      } catch (err) {
+        this.sendMessage(ws, {
+          type: 'error',
+          message: `Invalid message: ${err instanceof Error ? err.message : String(err)}`,
+        });
+      }
+    });
+
+    ws.on('close', () => {
+      session.clients.delete(clientId);
+      if (session.clients.size === 0 && !this.closed) {
+        // Persist content and remove session
+        try {
+          this.store.updateContent(docId, session.content);
+        } catch (_e) {
+          // DB may be closed during shutdown
+        }
+        this.sessions.delete(docId);
+      }
+    });
+
+    ws.on('error', () => {
+      session.clients.delete(clientId);
+    });
+  }
+
+  private handleClientMessage(client: ConnectedClient, msg: unknown): void {
+    if (!msg || typeof msg !== 'object') {
+      this.sendMessage(client.ws, { type: 'error', message: 'Invalid message format' });
+      return;
+    }
+
+    const message = msg as Record<string, unknown>;
+
+    if (message.type !== 'operation') {
+      this.sendMessage(client.ws, { type: 'error', message: `Unknown message type: ${String(message.type)}` });
+      return;
+    }
+
+    const opMsg = message as unknown as OperationMessage;
+    if (!opMsg.operation || !Array.isArray(opMsg.operation)) {
+      this.sendMessage(client.ws, { type: 'error', message: 'Operation must be an array' });
+      return;
+    }
+
+    if (typeof opMsg.version !== 'number') {
+      this.sendMessage(client.ws, { type: 'error', message: 'Version must be a number' });
+      return;
+    }
+
+    const session = this.sessions.get(client.docId);
+    if (!session) {
+      this.sendMessage(client.ws, { type: 'error', message: 'Session not found' });
+      return;
+    }
+
+    this.applyOperation(session, client, opMsg);
+  }
+
+  private applyOperation(session: DocumentSession, client: ConnectedClient, msg: OperationMessage): void {
+    let op = msg.operation;
+    const clientVersion = msg.version;
+
+    if (clientVersion < 0 || clientVersion > session.version) {
+      this.sendMessage(client.ws, {
+        type: 'error',
+        message: `Invalid version: ${clientVersion}. Current version is ${session.version}`,
+      });
+      return;
+    }
+
+    // Transform the operation against all operations that happened since the client's version
+    for (let i = clientVersion; i < session.version; i++) {
+      const serverOp = session.history[i];
+      const [, oPrime] = transform(serverOp, op);
+      op = oPrime;
+    }
+
+    // Validate the transformed operation against current document
+    const validationError = validate(op, session.content.length);
+    if (validationError) {
+      this.sendMessage(client.ws, { type: 'error', message: validationError });
+      return;
+    }
+
+    // Apply operation to the document
+    try {
+      session.content = apply(session.content, op);
+    } catch (err) {
+      this.sendMessage(client.ws, {
+        type: 'error',
+        message: `Failed to apply operation: ${err instanceof Error ? err.message : String(err)}`,
+      });
+      return;
+    }
+
+    session.history.push(op);
+    session.version++;
+
+    // Persist the version
+    this.store.addVersion(
+      session.docId,
+      session.version,
+      session.content,
+      JSON.stringify(op)
+    );
+    this.store.updateContent(session.docId, session.content);
+
+    // Acknowledge the sender
+    this.sendMessage(client.ws, { type: 'ack', version: session.version });
+
+    // Broadcast to other clients
+    for (const [id, c] of session.clients) {
+      if (id !== client.clientId) {
+        this.sendMessage(c.ws, {
+          type: 'operation',
+          docId: session.docId,
+          version: session.version,
+          operation: op,
+          clientId: client.clientId,
+        });
+      }
+    }
+  }
+
+  private getOrCreateSession(docId: string): DocumentSession {
+    let session = this.sessions.get(docId);
+    if (!session) {
+      const doc = this.store.getDocument(docId)!;
+      const latestVersion = this.store.getLatestVersion(docId);
+      const version = latestVersion ? latestVersion.version : 0;
+
+      // Load history from DB
+      const allVersions = this.store.getVersions(docId);
+      const history: Operation[] = [];
+      for (const v of allVersions) {
+        if (v.operation) {
+          history.push(JSON.parse(v.operation) as Operation);
+        }
+      }
+
+      session = {
+        docId,
+        content: doc.content,
+        version,
+        clients: new Map(),
+        history,
+      };
+      this.sessions.set(docId, session);
+    }
+    return session;
+  }
+
+  private sendMessage(ws: WebSocket, msg: ServerMessage): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(msg));
+    }
+  }
+
+  closeAll(): void {
+    this.closed = true;
+    // Persist all session content before closing
+    for (const session of this.sessions.values()) {
+      try {
+        this.store.updateContent(session.docId, session.content);
+      } catch (_e) {
+        // DB may already be closed
+      }
+      for (const client of session.clients.values()) {
+        client.ws.close();
+      }
+    }
+    this.sessions.clear();
+    if (this.wss) {
+      this.wss.close();
+      this.wss = null;
+    }
+  }
+}
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..3935fd6
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,128 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join, dirname } from 'path';
+import { fileURLToPath } from 'url';
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  const schemaPath = join(__dirname, '..', 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  private stmts: {
+    insertDoc: Database.Statement;
+    getDoc: Database.Statement;
+    listDocs: Database.Statement;
+    updateDoc: Database.Statement;
+    deleteDoc: Database.Statement;
+    insertVersion: Database.Statement;
+    getVersions: Database.Statement;
+    getLatestVersion: Database.Statement;
+    getVersion: Database.Statement;
+  };
+
+  constructor(db: Database.Database) {
+    this.db = db;
+    this.stmts = {
+      insertDoc: db.prepare(
+        `INSERT INTO documents (id, title, content, created_at, updated_at)
+         VALUES (?, ?, ?, datetime('now'), datetime('now'))`
+      ),
+      getDoc: db.prepare('SELECT * FROM documents WHERE id = ?'),
+      listDocs: db.prepare('SELECT * FROM documents ORDER BY updated_at DESC'),
+      updateDoc: db.prepare(
+        `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+      ),
+      deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),
+      insertVersion: db.prepare(
+        `INSERT INTO versions (document_id, version, content, operation, created_at)
+         VALUES (?, ?, ?, ?, datetime('now'))`
+      ),
+      getVersions: db.prepare(
+        'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+      ),
+      getLatestVersion: db.prepare(
+        'SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'
+      ),
+      getVersion: db.prepare(
+        'SELECT * FROM versions WHERE document_id = ? AND version = ?'
+      ),
+    };
+  }
+
+  createDocument(id: string, title: string, content: string = ''): DocumentRow {
+    this.stmts.insertDoc.run(id, title, content);
+    // Also create initial version
+    this.stmts.insertVersion.run(id, 0, content, null);
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): DocumentRow | undefined {
+    return this.stmts.getDoc.get(id) as DocumentRow | undefined;
+  }
+
+  listDocuments(): DocumentRow[] {
+    return this.stmts.listDocs.all() as DocumentRow[];
+  }
+
+  updateDocument(id: string, title: string, content: string): DocumentRow | undefined {
+    const result = this.stmts.updateDoc.run(title, content, id);
+    if (result.changes === 0) return undefined;
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.stmts.deleteDoc.run(id);
+    return result.changes > 0;
+  }
+
+  addVersion(docId: string, version: number, content: string, operation: string | null): void {
+    this.stmts.insertVersion.run(docId, version, content, operation);
+  }
+
+  getVersions(docId: string): VersionRow[] {
+    return this.stmts.getVersions.all(docId) as VersionRow[];
+  }
+
+  getLatestVersion(docId: string): VersionRow | undefined {
+    return this.stmts.getLatestVersion.get(docId) as VersionRow | undefined;
+  }
+
+  getVersion(docId: string, version: number): VersionRow | undefined {
+    return this.stmts.getVersion.get(docId, version) as VersionRow | undefined;
+  }
+
+  updateContent(docId: string, content: string): void {
+    this.db.prepare(
+      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`
+    ).run(content, docId);
+  }
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..f063247
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,171 @@
+import { describe, it, expect } from 'vitest';
+import { apply, transform, validate, inputLength, outputLength, normalize, compose } from './ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply an insert at the beginning', () => {
+      expect(apply('hello', ['world ', 5])).toBe('world hello');
+    });
+
+    it('should apply an insert at the end', () => {
+      expect(apply('hello', [5, ' world'])).toBe('hello world');
+    });
+
+    it('should apply a delete', () => {
+      expect(apply('hello world', [5, -6])).toBe('hello');
+    });
+
+    it('should apply retain only (identity)', () => {
+      expect(apply('hello', [5])).toBe('hello');
+    });
+
+    it('should apply insert in the middle', () => {
+      expect(apply('hllo', [1, 'e', 3])).toBe('hello');
+    });
+
+    it('should apply delete in the middle', () => {
+      expect(apply('heello', [1, -1, 4])).toBe('hello');
+    });
+
+    it('should throw on length mismatch', () => {
+      expect(() => apply('hello', [3])).toThrow();
+    });
+
+    it('should handle empty document insert', () => {
+      expect(apply('', ['hello'])).toBe('hello');
+    });
+  });
+
+  describe('transform', () => {
+    it('should handle two inserts at different positions', () => {
+      // Doc: "abc"
+      // A inserts "X" at position 1: [1, "X", 2]  -> "aXbc"
+      // B inserts "Y" at position 2: [2, "Y", 1]  -> "abYc"
+      const [aPrime, bPrime] = transform([1, 'X', 2], [2, 'Y', 1]);
+      const doc = 'abc';
+      const afterA = apply(doc, [1, 'X', 2]); // "aXbc"
+      const afterB = apply(doc, [2, 'Y', 1]); // "abYc"
+      const finalAB = apply(afterA, bPrime);   // apply B' after A
+      const finalBA = apply(afterB, aPrime);   // apply A' after B
+      expect(finalAB).toBe(finalBA);
+      // Both inserts should be preserved
+      expect(finalAB).toContain('X');
+      expect(finalAB).toContain('Y');
+    });
+
+    it('should handle two inserts at the same position', () => {
+      // Doc: "abc"
+      // Both insert at position 1
+      const [aPrime, bPrime] = transform([1, 'X', 2], [1, 'Y', 2]);
+      const doc = 'abc';
+      const afterA = apply(doc, [1, 'X', 2]);
+      const afterB = apply(doc, [1, 'Y', 2]);
+      const finalAB = apply(afterA, bPrime);
+      const finalBA = apply(afterB, aPrime);
+      expect(finalAB).toBe(finalBA);
+      expect(finalAB).toContain('X');
+      expect(finalAB).toContain('Y');
+    });
+
+    it('should handle insert vs delete', () => {
+      // Doc: "abcd"
+      // A inserts "X" at position 1: [1, "X", 3]
+      // B deletes char at position 1: [1, -1, 2]
+      const [aPrime, bPrime] = transform([1, 'X', 3], [1, -1, 2]);
+      const doc = 'abcd';
+      const afterA = apply(doc, [1, 'X', 3]); // "aXbcd"
+      const afterB = apply(doc, [1, -1, 2]);  // "acd"
+      const finalAB = apply(afterA, bPrime);
+      const finalBA = apply(afterB, aPrime);
+      expect(finalAB).toBe(finalBA);
+      expect(finalAB).toContain('X');
+    });
+
+    it('should handle both deleting the same character', () => {
+      // Doc: "abc"
+      // Both delete char at position 1
+      const [aPrime, bPrime] = transform([1, -1, 1], [1, -1, 1]);
+      const doc = 'abc';
+      const afterA = apply(doc, [1, -1, 1]); // "ac"
+      const afterB = apply(doc, [1, -1, 1]); // "ac"
+      const finalAB = apply(afterA, bPrime);
+      const finalBA = apply(afterB, aPrime);
+      expect(finalAB).toBe(finalBA);
+      expect(finalAB).toBe('ac');
+    });
+
+    it('should handle identity operations', () => {
+      const [aPrime, bPrime] = transform([3], [3]);
+      expect(apply('abc', aPrime)).toBe('abc');
+      expect(apply('abc', bPrime)).toBe('abc');
+    });
+  });
+
+  describe('validate', () => {
+    it('should accept valid operations', () => {
+      expect(validate([5, 'hello', -3], 8)).toBeNull();
+    });
+
+    it('should reject length mismatch', () => {
+      expect(validate([5], 3)).not.toBeNull();
+    });
+
+    it('should reject non-array', () => {
+      expect(validate('hello' as unknown as number[], 5)).not.toBeNull();
+    });
+
+    it('should reject zero numeric component', () => {
+      expect(validate([0, 3], 3)).not.toBeNull();
+    });
+
+    it('should reject empty string component', () => {
+      expect(validate(['', 3], 3)).not.toBeNull();
+    });
+  });
+
+  describe('normalize', () => {
+    it('should merge adjacent retains', () => {
+      expect(normalize([2, 3])).toEqual([5]);
+    });
+
+    it('should merge adjacent deletes', () => {
+      expect(normalize([-2, -3])).toEqual([-5]);
+    });
+
+    it('should merge adjacent inserts', () => {
+      expect(normalize(['ab', 'cd'])).toEqual(['abcd']);
+    });
+
+    it('should remove zero-length components', () => {
+      expect(normalize([0, 3, '', 'x', 2])).toEqual([3, 'x', 2]);
+    });
+  });
+
+  describe('inputLength and outputLength', () => {
+    it('should compute input length', () => {
+      expect(inputLength([3, 'hello', -2])).toBe(5);
+    });
+
+    it('should compute output length', () => {
+      expect(outputLength([3, 'hello', -2])).toBe(8);
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two insert operations', () => {
+      const doc = 'abc';
+      const op1 = [1, 'X', 2] as (string | number)[]; // "aXbc"
+      const op2 = [3, 'Y', 1] as (string | number)[]; // "aXbYc"
+      const composed = compose(op1, op2);
+      expect(apply(doc, composed)).toBe(apply(apply(doc, op1), op2));
+    });
+
+    it('should compose insert then delete', () => {
+      const doc = 'abc';
+      const op1 = [1, 'X', 2] as (string | number)[]; // "aXbc"
+      const op2 = [1, -1, 2] as (string | number)[]; // "abc" (deletes X)
+      const composed = compose(op1, op2);
+      expect(apply(doc, composed)).toBe(apply(apply(doc, op1), op2));
+    });
+  });
+});
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..e744bcd
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,351 @@
+/**
+ * Operational Transform engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert text
+ * - number < 0: delete |N| characters
+ *
+ * An operation's "input length" is the sum of retains + |deletes|.
+ * An operation's "output length" is the sum of retains + insert lengths.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  version: number; // the version the client was at when it generated this op
+  operation: Operation;
+  clientId: string;
+}
+
+export interface SyncMessage {
+  type: 'sync';
+  docId: string;
+  content: string;
+  version: number;
+}
+
+export interface AckMessage {
+  type: 'ack';
+  version: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export type ServerMessage = SyncMessage | OperationMessage | AckMessage | ErrorMessage;
+export type ClientMessage = OperationMessage;
+
+/** Compute input length of an operation (the length of the string it expects). */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      else len += -c;
+    }
+    // inserts don't consume input
+  }
+  return len;
+}
+
+/** Compute output length of an operation (the length of the string it produces). */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      // deletes produce nothing
+    } else {
+      len += c.length;
+    }
+  }
+  return len;
+}
+
+/** Normalize an operation by merging adjacent same-type components and removing no-ops. */
+export function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+    if (typeof c === 'number' && typeof last === 'number') {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+        continue;
+      }
+    }
+    if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+      continue;
+    }
+    result.push(c);
+  }
+  return result;
+}
+
+/** Apply an operation to a string, producing a new string. */
+export function apply(doc: string, op: Operation): string {
+  const inLen = inputLength(op);
+  if (inLen !== doc.length) {
+    throw new Error(`Operation input length (${inLen}) doesn't match document length (${doc.length})`);
+  }
+
+  let pos = 0;
+  let result = '';
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        pos += -c; // skip deleted chars
+      }
+    } else {
+      result += c;
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ * Given ops A and B that were both generated against the same document state,
+ * returns [A', B'] such that apply(apply(doc, A), B') === apply(apply(doc, B), A').
+ *
+ * A has priority (its inserts go first at the same position).
+ */
+export function transform(opA: Operation, opB: Operation): [Operation, Operation] {
+  const a = new OpIterator(opA);
+  const b = new OpIterator(opB);
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  while (a.hasNext() || b.hasNext()) {
+    const aComp = a.peek();
+    const bComp = b.peek();
+
+    // If A inserts, include in A' and retain in B'
+    if (aComp !== null && typeof aComp === 'string') {
+      const s = a.next() as string;
+      aPrime.push(s);
+      bPrime.push(s.length); // retain over A's insert
+      continue;
+    }
+
+    // If B inserts, include in B' and retain in A'
+    if (bComp !== null && typeof bComp === 'string') {
+      const s = b.next() as string;
+      bPrime.push(s);
+      aPrime.push(s.length); // retain over B's insert
+      continue;
+    }
+
+    // Both are null - done
+    if (aComp === null && bComp === null) break;
+
+    if (aComp === null || bComp === null) {
+      throw new Error('Transform: operations have different input lengths');
+    }
+
+    // Both are numbers (retain or delete)
+    const aLen = Math.abs(aComp as number);
+    const bLen = Math.abs(bComp as number);
+    const minLen = Math.min(aLen, bLen);
+
+    const aIsDel = (aComp as number) < 0;
+    const bIsDel = (bComp as number) < 0;
+
+    if (!aIsDel && !bIsDel) {
+      // Both retain
+      aPrime.push(minLen);
+      bPrime.push(minLen);
+    } else if (aIsDel && bIsDel) {
+      // Both delete the same region - neither needs to in the prime
+      // (nothing added to either prime)
+    } else if (aIsDel) {
+      // A deletes, B retains -> A' still deletes, B' skips (already deleted)
+      aPrime.push(-minLen);
+    } else {
+      // B deletes, A retains -> B' still deletes, A' skips
+      bPrime.push(-minLen);
+    }
+
+    a.consume(minLen);
+    b.consume(minLen);
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/** Compose two sequential operations into one. apply(doc, compose(a, b)) === apply(apply(doc, a), b). */
+export function compose(opA: Operation, opB: Operation): Operation {
+  const a = new OpIterator(opA);
+  const b = new OpIterator(opB);
+  const result: Operation = [];
+
+  while (a.hasNext() || b.hasNext()) {
+    const bComp = b.peek();
+
+    // If B inserts, output it directly
+    if (bComp !== null && typeof bComp === 'string') {
+      result.push(b.next() as string);
+      continue;
+    }
+
+    const aComp = a.peek();
+
+    // If A inserts
+    if (aComp !== null && typeof aComp === 'string') {
+      const s = a.next() as string;
+      if (bComp === null) {
+        result.push(s);
+        continue;
+      }
+      // B must consume A's insert output
+      const bLen = Math.abs(bComp as number);
+      const minLen = Math.min(s.length, bLen);
+      const bIsDel = (bComp as number) < 0;
+
+      if (bIsDel) {
+        // B deletes part of A's insert — those characters vanish
+        if (s.length > minLen) {
+          a.putBack(s.slice(minLen));
+        }
+        b.consume(minLen);
+        if (s.length <= minLen) {
+          // entire insert consumed by delete
+        }
+      } else {
+        // B retains over A's insert
+        result.push(s.slice(0, minLen));
+        if (s.length > minLen) {
+          a.putBack(s.slice(minLen));
+        }
+        b.consume(minLen);
+      }
+      continue;
+    }
+
+    if (aComp === null && bComp === null) break;
+
+    if (aComp === null || bComp === null) {
+      throw new Error('Compose: operations are incompatible');
+    }
+
+    // Both numeric
+    const aLen = Math.abs(aComp as number);
+    const bLen = Math.abs(bComp as number);
+    const minLen = Math.min(aLen, bLen);
+
+    const aIsDel = (aComp as number) < 0;
+    const bIsDel = (bComp as number) < 0;
+
+    if (!aIsDel && !bIsDel) {
+      result.push(minLen);
+    } else if (aIsDel && !bIsDel) {
+      result.push(-minLen);
+    } else if (!aIsDel && bIsDel) {
+      result.push(-minLen);
+    } else {
+      // Both delete — A's delete produces nothing, so B can't delete it
+      throw new Error('Compose: double delete should not happen');
+    }
+
+    a.consume(minLen);
+    b.consume(minLen);
+  }
+
+  return normalize(result);
+}
+
+/** Validate that an operation is well-formed and matches a document of the given length. */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) return 'Operation must be an array';
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c) || c === 0) return `Invalid numeric component: ${c}`;
+    } else if (typeof c === 'string') {
+      if (c.length === 0) return 'Empty string component';
+    } else {
+      return `Invalid component type: ${typeof c}`;
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) doesn't match document length (${docLength})`;
+  }
+
+  return null;
+}
+
+/**
+ * Iterator over operation components that allows partial consumption.
+ */
+class OpIterator {
+  private components: OpComponent[];
+  private index: number;
+  private offset: number;
+
+  constructor(op: Operation) {
+    this.components = op;
+    this.index = 0;
+    this.offset = 0;
+  }
+
+  hasNext(): boolean {
+    return this.index < this.components.length;
+  }
+
+  peek(): OpComponent | null {
+    if (!this.hasNext()) return null;
+    const c = this.components[this.index];
+    if (this.offset === 0) return c;
+    if (typeof c === 'number') {
+      return c > 0 ? c - this.offset : c + this.offset;
+    }
+    return c.slice(this.offset);
+  }
+
+  next(): OpComponent | null {
+    if (!this.hasNext()) return null;
+    const c = this.peek();
+    this.index++;
+    this.offset = 0;
+    return c;
+  }
+
+  /** Consume `n` characters from the current component. */
+  consume(n: number): void {
+    if (!this.hasNext()) return;
+    const c = this.components[this.index];
+    const len = typeof c === 'number' ? Math.abs(c) : c.length;
+    const remaining = len - this.offset;
+
+    if (n >= remaining) {
+      this.index++;
+      this.offset = 0;
+    } else {
+      this.offset += n;
+    }
+  }
+
+  putBack(s: string): void {
+    // Insert a new component right after current position
+    this.components.splice(this.index, 0, s);
+  }
+}
