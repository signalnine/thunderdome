     res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get version history for a document\n  router.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const doc = store.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = store.getVersions(req.params.id);\n    res.json(versions);\n  });\n\n  // Get specific version\n  router.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n    const doc = store.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const version = store.getVersion(req.params.id, parseInt(req.params.version, 10));\n    if (!version) {\n      res.status(404).json({ error: 'Version not found' });\n      return;\n    }\n    res.json(version);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":303,"cache_read_input_tokens":26439,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":303},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"de573273-6ec8-4a83-a70f-8cb2ca12768d","uuid":"01e99e08-a303-405a-834c-7e3fcd8b21b9"}
