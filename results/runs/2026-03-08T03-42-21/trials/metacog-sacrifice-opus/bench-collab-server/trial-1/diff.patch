ate handleConnection(ws: WebSocket, req: IncomingMessage): void {\n    const url = req.url || '';\n    const match = url.match(/\\/ws\\/([^/?]+)/);\n    if (!match) {\n      this.sendMessage(ws, { type: 'error', message: 'Invalid WebSocket URL. Use /ws/:docId' });\n      ws.close();\n      return;\n    }\n\n    const docId = match[1];\n    const doc = this.store.getDocument(docId);\n    if (!doc) {\n      this.sendMessage(ws, { type: 'error', message: 'Document not found' });\n      ws.close();\n      return;\n    }\n\n    const clientId = randomUUID();\n    const session = this.getOrCreateSession(docId);\n    const client: ConnectedClient = { ws, clientId, docId };\n    session.clients.set(clientId, client);\n\n    // Send sync message with current state\n    this.sendMessage(ws, {\n      type: 'sync',\n      docId,\n      content: session.content,\n      version: session.version,\n    });\n\n    ws.on('message', (data: Buffer | string) => {\n      try {\n        const raw = typeof data === 'string' ? data : data.toString('utf-8');\n        const msg = JSON.parse(raw);\n        this.handleClientMessage(client, msg);\n      } catch (err) {\n        this.sendMessage(ws, {\n          type: 'error',\n          message: `Invalid message: ${err instanceof Error ? err.message : String(err)}`,\n        });\n      }\n    });\n\n    ws.on('close', () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0 && !this.closed) {\n        // Persist content and remove session\n        try {\n          this.store.updateContent(docId, session.content);\n        } catch (_e) {\n          // DB may be closed during shutdown\n        }\n        this.sessions.delete(docId);\n      }\n    });\n\n    ws.on('error', () => {\n      session.clients.delete(clientId);\n    });\n  }\n\n  private handleClientMessage(client: ConnectedClient, msg: unknown): void {\n    if (!msg || typeof msg !== 'object') {\n      this.sendMessage(client.ws, { type: 'error', message: 'Invalid message format' });\n      return;\n    }\n\n    const message = msg as Record<string, unknown>;\n\n    if (message.type !== 'operation') {\n      this.sendMessage(client.ws, { type: 'error', message: `Unknown message type: ${String(message.type)}` });\n      return;\n    }\n\n    const opMsg = message as unknown as OperationMessage;\n    if (!opMsg.operation || !Array.isArray(opMsg.operation)) {\n      this.sendMessage(client.ws, { type: 'error', message: 'Operation must be an array' });\n      return;\n    }\n\n    if (typeof opMsg.version !== 'number') {\n      this.sendMessage(client.ws, { type: 'error', message: 'Version must be a number' });\n      return;\n    }\n\n    const session = this.sessions.get(client.docId);\n    if (!session) {\n      this.sendMessage(client.ws, { type: 'error', message: 'Session not found' });\n      return;\n    }\n\n    this.applyOperation(session, client, opMsg);\n  }\n\n  private applyOperation(session: DocumentSession, client: ConnectedClient, msg: OperationMessage): void {\n    let op = msg.operation;\n    const clientVersion = msg.version;\n\n    if (clientVersion < 0 || clientVersion > session.version) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Invalid version: ${clientVersion}. Current version is ${session.version}`,\n      });\n      return;\n    }\n\n    // Transform the operation against all operations that happened since the client's version\n    for (let i = clientVersion; i < session.version; i++) {\n      const serverOp = session.history[i];\n      const [, oPrime] = transform(serverOp, op);\n      op = oPrime;\n    }\n\n    // Validate the transformed operation against current document\n    const validationError = validate(op, session.content.length);\n    if (validationError) {\n      this.sendMessage(client.ws, { type: 'error', message: validationError });\n      return;\n    }\n\n    // Apply operation to the document\n    try {\n      session.content = apply(session.content, op);\n    } catch (err) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Failed to apply operation: ${err instanceof Error ? err.message : String(err)}`,\n      });\n      return;\n    }\n\n    session.history.push(op);\n    session.version++;\n\n    // Persist the version\n    this.store.addVersion(\n      session.docId,\n      session.version,\n      session.content,\n      JSON.stringify(op)\n    );\n    this.store.updateContent(session.docId, session.content);\n\n    // Acknowledge the sender\n    this.sendMessage(client.ws, { type: 'ack', version: session.version });\n\n    // Broadcast to other clients\n    for (const [id, c] of session.clients) {\n      if (id !== client.clientId) {\n        this.sendMessage(c.ws, {\n          type: 'operation',\n          docId: session.docId,\n          version: session.version,\n          operation: op,\n          clientId: client.clientId,\n        });\n      }\n    }\n  }\n\n  private getOrCreateSession(docId: string): DocumentSession {\n    let session = this.sessions.get(docId);\n    if (!session) {\n      const doc = this.store.getDocument(docId)!;\n      const latestVersion = this.store.getLatestVersion(docId);\n      const version = latestVersion ? latestVersion.version : 0;\n\n      // Load history from DB\n      const allVersions = this.store.getVersions(docId);\n      const history: Operation[] = [];\n      for (const v of allVersions) {\n        if (v.operation) {\n          history.push(JSON.parse(v.operation) as Operation);\n        }\n      }\n\n      session = {\n        docId,\n        content: doc.content,\n        version,\n        clients: new Map(),\n        history,\n      };\n      this.sessions.set(docId, session);\n    }\n    return session;\n  }\n\n  private sendMessage(ws: WebSocket, msg: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  closeAll(): void {\n    this.closed = true;\n  