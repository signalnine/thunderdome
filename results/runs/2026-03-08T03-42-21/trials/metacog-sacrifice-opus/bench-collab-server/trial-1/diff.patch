   const [aPrime, bPrime] = transform([1, 'X', 2], [2, 'Y', 1]);\n      const doc = 'abc';\n      const afterA = apply(doc, [1, 'X', 2]); // \"aXbc\"\n      const afterB = apply(doc, [2, 'Y', 1]); // \"abYc\"\n      const finalAB = apply(afterA, bPrime);   // apply B' after A\n      const finalBA = apply(afterB, aPrime);   // apply A' after B\n      expect(finalAB).toBe(finalBA);\n      // Both inserts should be preserved\n      expect(finalAB).toContain('X');\n      expect(finalAB).toContain('Y');\n    });\n\n    it('should handle two inserts at the same position', () => {\n      // Doc: \"abc\"\n      // Both insert at position 1\n      const [aPrime, bPrime] = transform([1, 'X', 2], [1, 'Y', 2]);\n      const doc = 'abc';\n      const afterA = apply(doc, [1, 'X', 2]);\n      const afterB = apply(doc, [1, 'Y', 2]);\n      const finalAB = apply(afterA, bPrime);\n      const finalBA = apply(afterB, aPrime);\n      expect(finalAB).toBe(finalBA);\n      expect(finalAB).toContain('X');\n      expect(finalAB).toContain('Y');\n    });\n\n    it('should handle insert vs delete', () => {\n      // Doc: \"abcd\"\n      // A inserts \"X\" at position 1: [1, \"X\", 3]\n      // B deletes char at position 1: [1, -1, 2]\n      const [aPrime, bPrime] = transform([1, 'X', 3], [1, -1, 2]);\n      const doc = 'abcd';\n      const afterA = apply(doc, [1, 'X', 3]); // \"aXbcd\"\n      const afterB = apply(doc, [1, -1, 2]);  // \"acd\"\n      const finalAB = apply(afterA, bPrime);\n      const finalBA = apply(afterB, aPrime);\n      expect(finalAB).toBe(finalBA);\n      expect(finalAB).toContain('X');\n    });\n\n    it('should handle both deleting the same character', () => {\n      // Doc: \"abc\"\n      // Both delete char at position 1\n      const [aPrime, bPrime] = transform([1, -1, 1], [1, -1, 1]);\n      const doc = 'abc';\n      const afterA = apply(doc, [1, -1, 1]); // \"ac\"\n      const afterB = apply(doc, [1, -1, 1]); // \"ac\"\n      const finalAB = apply(afterA, bPrime)