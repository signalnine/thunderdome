+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { createApp, AppInstance } from './server.js';
+import WebSocket from 'ws';
+
+let app: AppInstance;
+let port: number;
+let baseUrl: string;
+
+beforeEach(async () => {
+  app = createApp(':memory:');
+  port = await app.start(0);
+  baseUrl = `http://localhost:${port}`;
+});
+
+afterEach(async () => {
+  await app.stop();
+});
+
+function wsUrl(docId: string): string {
+  return `ws://localhost:${port}/ws/${docId}`;
+}
+
+function waitForMessage<T = unknown>(ws: WebSocket): Promise<T> {
+  return new Promise((resolve, reject) => {
+    const timeout = setTimeout(() => reject(new Error('WS message timeout')), 5000);
+    ws.once('message', (data) => {
+      clearTimeout(timeout);
+      resolve(JSON.parse(data.toString()));
+    });
+  });
+}
+
+function connectWs(docId: string): Promise<WebSocket> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(wsUrl(docId));
+    const timeout = setTimeout(() => reject(new Error('WS connect timeout')), 5000);
+    ws.on('open', () => {
+      clearTimeout(timeout);
+      resolve(ws);
+    });
+    ws.on('error', (err) => {
+      clearTimeout(timeout);
+      reject(err);
+    });
+  });
+}
+
+async function createDocument(title: string, content = ''): Promise<{ id: string; title: string; content: string }> {
+  const res = await fetch(`${baseUrl}/api/documents`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ title, content }),
+  });
+  return res.json();
+}
+
+describe('REST API', () => {
