Message<{ type: string; version: number }>(ws);\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    ws.close();\n\n    // Verify via REST\n    // Wait a moment for the close handler to persist\n    await new Promise(r => setTimeout(r, 100));\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content).toBe('hello world');\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const doc = await createDocument('Broadcast Test', 'abc');\n    const ws1 = await connectWs(doc.id);\n    const ws2 = await connectWs(doc.id);\n\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    // Client 1 inserts \"X\" at position 1\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      docId: doc.id,\n      version: 0,\n      operation: [1, 'X', 2],\n      clientId: 'client1',\n    }));\n\n    const ack = await waitForMessage<{ type: string }>(ws1);\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await waitForMessage<{ type: string; operation: (string | number)[] }>(ws2);\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.operation).toBeDefined();\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const doc = await createDocument('OT Test', 'abc');\n\n    const ws1 = await connectWs(doc.id);\n    const ws2 = await connectWs(doc.id);\n\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    // Both clients send operations against version 0 concurrently\n    // Client 1: insert \"X\" at position 0\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      docId: doc.id,\n      version: 0,\n      operation: ['X', 3],\n      clientId: 'client1',\n    }));\n\n    // Client 2: insert \"Y\" at position 3\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      docId: doc.id,\n      version: 0,\n      operation: [3, 'Y'],\n      clientId: 'client2',\n    }));\n\n    // Wait for acks and broadcasts to settle\n    const messages1: unknown[] = [];\n    const messages2: unknown[] = [];\n\n    const collect = (ws: WebSocket, arr: unknown[]) => new Promise<void>((resolve) => {\n      const handler = (data: Buffer | string) => {\n        arr.push(JSON.parse(data.toString()));\n        if (arr.length >= 2) {\n          ws.off('message', handler);\n          resolve();\n        }\n      };\n      ws.on('message', handler);\n      setTimeout(() => { ws.off('message', handler); resolve(); }, 3000);\n    });\n\n    await Promise.all([collect(ws1, messages1), collect(ws2, messages2)]);\n\n    ws1.close();\n    ws2.close();\n\n    // Verify final document state via REST\n    await new Promise(r => setTimeout(r, 100));\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const final = await res.json();\n\n    // Both X and Y must be in the final document\n    expect(final.content).toContain('X');\n    expect(final.content).toContain('Y');\n    expect(final.content).toContain('abc');\n    expect(final.content.length).toBe(5);\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const doc = await createDocument('Stress Test', 'abcdefghij');\n    const clients: WebSocket[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(doc.id);\n      await waitForMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client inserts a character at a different position\n    const promises: Promise<void>[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ws = clients[i];\n      const char = String.fromCharCode(65 + i); // A, B, C, ...\n      // All insert at position i (against version 0)\n      const op: (string | number)[] = [];\n      if (i > 0) op.push(i);\n      op.push(char);\n      const remaining = 10 - i;\n      if (remaining > 0) op.push(remaining);\n\n      ws.send(JSON.stringify({\n        type: 'operation',\n        docId: doc.id,\n        version: 0,\n        operation: op,\n        clientId: `client-${i}`,\n      }));\n\n      promises.push(\n        waitForMessage(ws).then(() => {}) // wait for ack or broadcast\n      );\n    }\n\n    await Promise.all(promises);\n\n    // Allow time for all operations to be processed\n    await new Promise(r => setTimeout(r, 500));\n\n    // Close all clients\n    for (const ws of clients) {\n      ws.close();\n    }\n    await new Promise(r => setTimeout(r, 200));\n\n    // Verify via REST\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const final = await res.json();\n\n    // All 10 inserted characters should be present\n    for (let i = 0; i < 10; i++) {\n      expect(final.content).toContain(String.fromCharCode(65 + i));\n    }\n    // Original content should be present\n    expect(final.content).toContain('abcdefghij');\n    // Total length should be 20 (10 original + 10 inserted)\n    expect(final.content.length).toBe(20);\n  });\n\n  it('should reject malformed operations', async () => {\n    const doc = await createDocument('Error Test', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    // Send invalid operation (wrong input length)\n    ws.send(JSON.stringify({\n      type: 'operation',\n      docId: doc.id,\n      version: 0,\n      operation: [10], // wrong length\n      clientId: 'bad-client',\n    }));\n\n    const msg = await waitForMessage<{ type: string; message: string }>(ws);\n    expect(msg.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject invalid message types', async () => {\n    const doc = await createDocument('Invalid Type', 'hello');\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({ type: 'unknown', data: 'test' }));\n    const msg = await waitForMessage<{ type: string }>(ws);\n    expect(msg.type