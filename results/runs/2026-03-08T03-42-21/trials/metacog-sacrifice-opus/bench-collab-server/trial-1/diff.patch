Row[];\n  }\n\n  getLatestVersion(docId: string): VersionRow | undefined {\n    return this.stmts.getLatestVersion.get(docId) as VersionRow | undefined;\n  }\n\n  getVersion(docId: string, version: number): VersionRow | undefined {\n    return this.stmts.getVersion.get(docId, version) as VersionRow | undefined;\n  }\n\n  updateContent(docId: string, content: string): void {\n    this.db.prepare(\n      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`\n    ).run(content, docId);\n  }\n}\n","structuredPatch":[],"originalFile":null}}
