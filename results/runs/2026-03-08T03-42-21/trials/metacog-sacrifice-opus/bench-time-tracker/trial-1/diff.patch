--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,116 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: number;
+  stop: number | null;
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.load();
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    const now = Date.now();
+
+    // Stop currently running timer if any
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = now;
+    }
+
+    this.entries.push({ task, start: now, stop: null });
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = Date.now();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(since?: Date, until?: Date): TimeEntry[] {
+    let result = this.entries;
+
+    if (since) {
+      const sinceMs = since.getTime();
+      result = result.filter((e) => e.start >= sinceMs);
+    }
+
+    if (until) {
+      const untilMs = until.getTime();
+      result = result.filter((e) => e.start <= untilMs);
+    }
+
+    return result.map((e) => ({ ...e }));
+  }
+
+  getSummary(since?: Date, until?: Date): TimeSummary {
+    const entries = this.getEntries(since, until);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const end = entry.stop ?? Date.now();
+      const duration = end - entry.start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== null;
+  }
+
+  currentTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.task : null;
+  }
+
+  private getRunningEntry(): TimeEntry | null {
+    for (let i = this.entries.length - 1; i >= 0; i--) {
+      if (this.entries[i].stop === null) {
+        return this.entries[i];
+      }
+    }
+    return null;
+  }
+
+  private load(): void {
+    try {
+      const data = fs.readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (Array.isArray(parsed)) {
+        this.entries = parsed as TimeEntry[];
+      }
+    } catch {
+      // File doesn't exist or is invalid — start fresh
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+}
