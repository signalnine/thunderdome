ker.start(\"new-task\");\n      tracker.stop();\n\n      const filtered = tracker.getEntries(afterFirst);\n      // The new-task should have a start >= afterFirst\n      // old-task may or may not be included depending on timing\n      // But at minimum the results should be a subset\n      expect(filtered.length).toBeLessThanOrEqual(tracker.getEntries().length);\n    });\n\n    it(\"should filter by until\", () => {\n      const tracker = new TimeTracker(file);\n      tracker.start(\"task\");\n      tracker.stop();\n      const cutoff = new Date(Date.now() + 100000);\n      const filtered = tracker.getEntries(undefined, cutoff);\n      expect(filtered).toHaveLength(1);\n    });\n\n    it(\"should return all entries when no filters given\", () => {\n      const tracker = new TimeTracker(file);\n      tracker.start(\"a\");\n      tracker.stop();\n      tracker.start(\"b\");\n      tracker.stop();\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should sum durations by task name\", () => {\n      const tracker = new TimeTracker(file);\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"review\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(Object.keys(summary)).toHaveLength(2);\n      expect(summary[\"coding\"]).toBeGreaterThan(0);\n      expect(summary[\"review\"]).toBeGreaterThan(0);\n    });\n\n    it(\"should use current time for running tasks\", () => {\n      const tracker = new TimeTracker(file);\n      tracker.start(\"active\");\n\n      const summary = tracker.getSummary();\n      expect(summary[\"active\"]).toBeGreaterThan(0);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle unicode task names\", () => {\n      const tracker = new TimeTracker(file);\n      tracker.start(\"日本語タスク\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"日本語タスク\");\n    });\n\n    it(\"should handle emoji task names\", () => {\n      const tracker = new TimeTracker(file);\n      tracker.start(\"🚀 Deploy\");\n      tracker.stop();\n\n      // Verify persistence too\n      const tracker2 = new TimeTracker(file);\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"🚀 Deploy\");\n    });\n\n    it(\"should handle mixed unicode in summaries\", () => {\n      const tracker = new TimeTracker(file);\n      tracker.start(\"café ☕\");\n      tracker.stop();\n      tracker.start(\"café ☕\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"café ☕\"]).toBeGreaterThan(0);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
