new file mode 100644
index 0000000..c9873d9
--- /dev/null
+++ b/src/tracker.test.ts
@@ -0,0 +1,202 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as os from "node:os";
+import * as path from "node:path";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tracker-test-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let file: string;
+
+  beforeEach(() => {
+    file = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(file);
+  });
+
+  describe("start/stop", () => {
+    it("should start and stop a timer", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("coding");
+      expect(tracker.isRunning()).toBe(true);
+      expect(tracker.currentTask()).toBe("coding");
+
+      const entry = tracker.stop();
+      expect(entry.task).toBe("coding");
+      expect(entry.stop).not.toBeNull();
+      expect(entry.stop!).toBeGreaterThanOrEqual(entry.start);
+      expect(tracker.isRunning()).toBe(false);
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].stop).toBeNull();
+    });
+
+    it("should throw when starting with empty name", () => {
+      const tracker = new TimeTracker(file);
+      expect(() => tracker.start("")).toThrow();
+      expect(() => tracker.start("   ")).toThrow();
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker(file);
+      expect(() => tracker.stop()).toThrow();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to file", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("work");
+      tracker.stop();
+
+      // Load from same file in a new instance
+      const tracker2 = new TimeTracker(file);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("work");
+    });
+
+    it("should create parent directories automatically", () => {
+      const nested = path.join(os.tmpdir(), "tracker-test-nested", "a", "b", "data.json");
+      try {
+        const tracker = new TimeTracker(nested);
+        tracker.start("test");
+        tracker.stop();
+        expect(fs.existsSync(nested)).toBe(true);
+      } finally {
+        fs.rmSync(path.join(os.tmpdir(), "tracker-test-nested"), {
+          recursive: true,
+          force: true,
+        });
+      }
+    });
+
+    it("should handle missing file gracefully on load", () => {
+      const tracker = new TimeTracker(file);
+      expect(tracker.getEntries()).toHaveLength(0);
+    });
+  });
+
+  describe("getEntries with date filtering", () => {
+    it("should filter by since", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("old-task");
+      tracker.stop();
+
+      const afterFirst = new Date();
+
+      tracker.start("new-task");
+      tracker.stop();
+
+      const filtered = tracker.getEntries(afterFirst);
+      // The new-task should have a start >= afterFirst
+      // old-task may or may not be included depending on timing
+      // But at minimum the results should be a subset
+      expect(filtered.length).toBeLessThanOrEqual(tracker.getEntries().length);
+    });
+
+    it("should filter by until", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("task");
+      tracker.stop();
+      const cutoff = new Date(Date.now() + 100000);
+      const filtered = tracker.getEntries(undefined, cutoff);
+      expect(filtered).toHaveLength(1);
+    });
+
+    it("should return all entries when no filters given", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("a");
+      tracker.stop();
+      tracker.start("b");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations by task name", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("review");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(Object.keys(summary)).toHaveLength(2);
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["review"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should use current time for running tasks", async () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("active");
+
+      // Wait a small amount so Date.now() advances
+      await new Promise((resolve) => setTimeout(resolve, 10));
+
+      const summary = tracker.getSummary();
+      expect(summary["active"]).toBeGreaterThan(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("日本語タスク");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("日本語タスク");
+    });
+
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("🚀 Deploy");
+      tracker.stop();
+
+      // Verify persistence too
+      const tracker2 = new TimeTracker(file);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("🚀 Deploy");
+    });
+
+    it("should handle mixed unicode in summaries", () => {
+      const tracker = new TimeTracker(file);
+      tracker.start("café ☕");
+      tracker.stop();
+      tracker.start("café ☕");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["café ☕"]).toBeGreaterThanOrEqual(0);
+      expect("café ☕" in summary).toBe(true);
+    });
+  });
+});
