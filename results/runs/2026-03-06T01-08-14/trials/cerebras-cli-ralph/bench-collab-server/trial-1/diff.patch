seVersion: msg.version, ops: [{ pos: 0, insert: 'Hello' }] };\n          clientA.send(JSON.stringify(opMsg));\n        } else if (msg.type === 'op') {\n          opsA.push(msg);\n        } else if (msg.type === 'ack') {\n          // ignore\n        }\n        checkDone();\n      });\n      clientB.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (msg.type === 'sync') {\n          syncB = true;\n        } else if (msg.type === 'op') {\n          opsB.push(msg);\n        }\n        checkDone();\n      });\n      const checkDone = async () => {\n        if (syncA && syncB && opsB.length > 0) {\n          // Both clients should have received the op from A\n          expect(opsB[0].ops[0].insert).toBe('Hello');\n          // Verify final content via REST\n          const getRes = await request(appInstance.app).get(`/documents/${docId}`);\n          expect(getRes.body.content).toBe('Hello');\n          clientA.close();\n          clientB.close();\n          done();\n        }\n      };\n    })();\n  });\n});\n","after":"import { describe, it, expect, beforeAll, afterAll } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport createApp from '../server.js';\n\nlet appInstance: ReturnType<typeof createApp>;\nlet port: number;\n\nbeforeAll(() => {\n  appInstance = createApp();\n  port = appInstance.start();\n});\n\nafterAll(() => {\n  appInstance.stop();\n});\n\ndescribe('REST API', () => {\n  it('should create, get, list, update, delete document', async () => {\n    const title = 'Test Doc';\n    const content = 'Hello World';\n    // create\n    const createRes = await request(appInstance.app).post('/documents').send({ title, content });\n    expect(createRes.status).toBe(201);\n    const doc = createRes.body as { id: number; title: string; content: string };\n    expect(doc.title).toBe(title);\n    expect(doc.content).toBe(content);\n    const id = doc.id;\n    // get\n    const getRes = await request(