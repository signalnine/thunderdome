= op.insert.length;\n36:     } else if (op.delete !== undefined) {\n37:       result = result.slice(0, pos) + result.slice(pos + op.delete);\n38:       offset -= op.delete;\n39:     }\n40:   }\n41:   return result;\n42: }\n43: \n44: /**\n45:  * Transform a new operation against an existing operation.\n46:  * Returns a new operation that can be applied after the existing one.\n47:  * This is a simplified version suitable for single-character edits.\n48:  */\n49: export function transform(op: TextOperation, against: TextOperation): TextOperation {\n50:   // If against is an insert before op.pos, shift op.pos forward.\n51:   if (against.insert !== undefined) {\n52:     if (against.pos <= op.pos) {\n53:       return { ...op, pos: op.pos + against.insert.length };\n54:     }\n55:     return op;\n56:   }\n57:   // against is a delete\n58:   if (against.delete !== undefined) {\n59:     const delStart = against.pos;\n60:     const delEnd = against.pos + against.delete;\n61:     if (op.pos >= delEnd) {\n62:       // Op after deleted region, shift left\n63:       return { ...op, pos: op.pos - against.delete };\n64:     } else if (op.pos >= delStart && op.pos < delEnd) {\n65:       // Op inside deleted region: move to start of deletion\n66:       return { ...op, pos: delStart };\n67:     } else {\n68:       // Op before deleted region, unchanged\n69:       return op;\n70:     }\n71:   }\n72:   return op; // should not reach here\n73: }\n74: \n75: /**\n76:  * Transform an array of new operations against a sequence of existing operations.\n77:  * Applies transform sequentially.\n78:  */\n79: export function transformOps(newOps: TextOperation[], existingOps: TextOperation[]): TextOperation[] {\n80:   let transformed = newOps.map(op => ({ ...op }));\n81:   for (const exist of existingOps) {\n82:     transformed = transformed.map(op => transform(op, exist));\n83:   }\n84:   return transformed;\n85: }\n86: \n87: export default { applyOps, transformOps, transform };\n88: \n\n(End of 