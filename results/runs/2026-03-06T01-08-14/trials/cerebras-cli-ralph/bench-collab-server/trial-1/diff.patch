 };\n        ws.send(JSON.stringify(err));\n        ws.close();\n        return;\n      }\n      // Retrieve or load document state\n      let state: DocumentState;\n      try {\n        state = getState(docId);\n      } catch (e) {\n        const err: ErrorMessage = { type: 'error', message: 'Document not found' };\n        ws.send(JSON.stringify(err));\n        ws.close();\n        return;\n      }\n      // Add ws to clients set\n      state.clients.add(ws);\n\n      // Send initial sync message\n      const syncMsg: SyncMessage = { type: 'sync', content: state.content, version: state.version };\n      ws.send(JSON.stringify(syncMsg));\n\n      ws.on('message', (data: any) => {\n        let msg: OpMessage;\n        try {\n          msg = JSON.parse(data.toString());\n        } catch {\n          const err: ErrorMessage = { type: 'error', message: 'Invalid JSON' };\n          ws.send(JSON.stringify(err));\n          return;\n        }\n        if (msg.type !== 'op') {\n          const err: ErrorMessage = { type: 'error', message: 'Unsupported message type' };\n          ws.send(JSON.stringify(err));\n          return;\n        }\n        // Validate baseVersion\n        if (msg.baseVersion !== state.version) {\n          // Need to transform ops against missed ops\n          const missed = state.history.filter(h => h.version > msg.baseVersion);\n          const existingOps = missed.flatMap(h => h.ops);\n          const transformedOps = transformOps(msg.ops, existingOps);\n          // Apply transformed ops\n          const newContent = applyOps(state.content, transformedOps);\n          // Update state\n          state.content = newContent;\n          state.version = state.version + 1; // increment version per batch\n          // Record history\n          state.history.push({ version: state.version, ops: transformedOps });\n          // Persist to DB\n          db.updateDocument(docId, (db.getDocument(docId)!.title), newContent);\n          // Broadcast to others (including sender) as new op broadcast (skip transformation for sender?)\n          const broadcast: OpMessage = {\n            type: 'op',\n            clientId,\n            baseVersion: state.version,\n            ops: transformedOps\n          };\n          const payload = JSON.stringify(broadcast);\n          state.clients.forEach(client => {\n            if (client !== ws && client.readyState === WebSocket.OPEN) client.send(payload);\n          });\n          // Ack to sender with new version\n          const ack = { type: 'ack', newVersion: state.version } as const;\n          ws.send(JSON.stringify(ack));\n        } else {\n          // No concurrent version difference, apply directly\n          const newContent = applyOps(state.content, msg.ops);\n          state.content = newContent;\n          state.version = state.version + msg.ops.length;\n          state.history.push({ version: state.version, ops: msg.ops });\n          // Persist\n          db.updateDocument(docId, (db.getDocument(docId)!.title), newContent);\n          // Broadcast to other clients\n          const broadcast: OpMessage = { ...msg, baseVersion: state.version };\n          const payload = JSON.stringify(broadcast);\n          state.clients.forEach(client => {\n            if (client !== ws && client.readyState === WebSocket.OPEN) client.send(payload);\n          });\n          // Ack\n          const ack = { type: 'ack', newVersion: state.version } as const;\n          ws.send(JSON.stringify(ack));\n        }\n      });\n\n      ws.on('close', () => {\n        state.clients.delete(ws);\n        // If no more clients, we could cleanup memory, but keep for now\n      });\n    });\n    return actualPort as number;\n  };\n\n  const stop = () => {\n    if (wss) wss.close();\n    if (httpServer) httpServer.close();\n    db.close();\n  };\n\n  return { app, start, stop };\n}\n\nexport default createApp;\n","additions":1,"deletions":1},"truncated":false},"time":{"start":1772759355977,"end":177