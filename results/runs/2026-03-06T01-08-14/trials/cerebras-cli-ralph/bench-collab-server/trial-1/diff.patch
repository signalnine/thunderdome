@@ -0,0 +1,40 @@
+export type DocumentId = number;
+
+export interface DocumentPayload {
+  title: string;
+  content: string;
+}
+
+export interface VersionInfo {
+  id: number;
+  docId: number;
+  title: string;
+  content: string;
+  timestamp: string;
+}
+
+// WebSocket message types
+export interface SyncMessage {
+  type: 'sync';
+  content: string;
+  version: number;
+}
+
+export interface OpMessage {
+  type: 'op';
+  clientId: string; // identifier for the sender
+  baseVersion: number; // version the ops are based on
+  ops: { pos: number; insert?: string; delete?: number }[];
+}
+
+export interface AckMessage {
+  type: 'ack';
+  newVersion: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export type ServerMessage = SyncMessage | OpMessage | AckMessage | ErrorMessage;
