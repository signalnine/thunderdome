stInsertRowid), title, content };\n50:     this.createVersion(doc.id, title, content);\n51:     return doc;\n52:   }\n53: \n54:   getDocument(id: number): Document | undefined {\n55:     const stmt = this.db.prepare('SELECT id, title, content FROM documents WHERE id = ?');\n56:     const row = stmt.get(id) as { id: number; title: string; content: string } | undefined;\n57:     return row ? { id: row.id, title: row.title, content: row.content } : undefined;\n58:   }\n59: \n60:   updateDocument(id: number, title: string, content: string): Document | undefined {\n61:     const stmt = this.db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?');\n62:     const info = stmt.run(title, content, id);\n63:     if (info.changes === 0) return undefined;\n64:     const doc = this.getDocument(id);\n65:     if (doc) this.createVersion(id, title, content);\n66:     return doc;\n67:   }\n68: \n69:   deleteDocument(id: number): boolean {\n70:     const stmt = this.db.prepare('DELETE FROM documents WHERE id = ?');\n71:     const info = stmt.run(id);\n72:     return info.changes > 0;\n73:   }\n74: \n75:   listDocuments(): Document[] {\n76:     const stmt = this.db.prepare('SELECT id, title, content FROM documents ORDER BY id');\n77:     return stmt.all() as Document[];\n78:   }\n79: \n80:   // Versions\n81:   private createVersion(docId: number, title: string, content: string) {\n82:     const stmt = this.db.prepare('INSERT INTO versions (doc_id, title, content) VALUES (?, ?, ?)');\n83:     stmt.run(docId, title, content);\n84:   }\n85: \n86:   getVersions(docId: number): Version[] {\n87:     const stmt = this.db.prepare('SELECT id, doc_id as docId, title, content, timestamp FROM versions WHERE doc_id = ? ORDER BY id');\n88:     return stmt.all() as Version[];\n89:   }\n90: \n91:   // Close DB (optional)\n92:   close() {\n93:     this.db.close();\n94:   }\n95: }\n96: \n97: export default DB;\n98: \n\n(End of file - total 98 lines)\n</content>","title":"src/db.ts","metad