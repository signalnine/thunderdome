t: string };\n    if (typeof title !== 'string' || typeof content !== 'string') {\n      return res.status(400).json({ error: 'Invalid payload' });\n    }\n    const updated = db.updateDocument(id, title, content);\n    if (!updated) return res.status(404).json({ error: 'Not found' });\n    // Reset in-memory state to match DB content\n    const state = getState(id);\n    state.content = updated.content;\n    state.version = 0;\n    state.history = [];\n    // broadcast reset to clients\n    const msg: SyncMessage = { type: 'sync', content: updated.content, version: state.version };\n    const payload = JSON.stringify(msg);\n    state.clients.forEach(ws => ws.send(payload));\n    res.json(updated);\n  });\n\n  // Delete document\n  app.delete('/documents/:id', (req: Request, res: Response) => {\n    const id = Number(req.params.id);\n    const ok = db.deleteDocument(id);\n    if (!ok) return res.status(404).json({ error: 'Not found' });\n    // Close any WS connections for this doc\n    const state = docsState.get(id);\n    if (state) {\n      state.clients.forEach(ws => ws.close(1000, 'Document deleted'));\n      docsState.delete(id);\n    }\n    res.status(204).send();\n  });\n\n  // Get version history\n  app.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const id = Number(req.params.id);\n    const versions = db.getVersions(id);\n    res.json(versions);\n  });\n\n  // Error handling middleware\n  app.use((err: any, _req: Request, res: Response, _next: NextFunction) => {\n    console.error(err);\n    res.status(500).json({ error: 'Internal server error' });\n  });\n\n  // WebSocket server will be attached after HTTP server is created\n  let httpServer: HttpServer | null = null;\n  let wss: WebSocketServer | null = null;\n\n  const start = (port?: number): number => {\n    httpServer = app.listen(port ?? 0);\n    const actualPort = (httpServer.address() as any).port;\n    // Attach WS server on same HTTP server\n    wss = new WebSocketServer({ server: httpServer, path: '/ws/documents' });\n    wss.on('connection', (ws: WebSocket, request) => {\n      // Expect URL like /ws/documents/:id?clientId=xxx\n      const url = new URL(request.url ?? '', `http://${request.headers.host}`);\n      const pathname = url.pathname; // e.g., /ws/documents/5\n      const parts = pathname.split('/');\n      const docIdStr = parts[parts.length - 1];\n      const docId = Number(docIdStr);\n      const clientId = url.searchParams.get('clientId') ?? randomUUID();\n      if (isNaN(docId)) {\n        const err: ErrorMessage = { type: 'error', message: 'Invalid document ID in WS path' };\n        ws.send(JSON.stringify(err));\n        ws.close();\n        return;\n      }\n      // Retrieve or load document state\n      let state: DocumentState;\n      try {\n        state = getState(docId);\n      } catch (e) {\n        const err: ErrorMessage = { type: 'error', message: 'Document not found' };\n        ws.send(JSON.stringify(err));\n        ws.close();\n        return;\n      }\n      // Add ws to clients set\n      state.clients.add(ws);\n\n      // Send initial sync message\n      const syncMsg: SyncMessage = { type: 'sync', content: state.content, version: state.version };\n      ws.send(JSON.stringify(syncMsg));\n\n      ws.on('message', (data: any) => {\n        let msg: OpMessage;\n        try {\n          msg = JSON.parse(data.toString());\n        } catch {\n          const err: ErrorMessage = { type: 'error', message: 'Invalid JSON' };\n          ws.send(JSON.stringify(err));\n          return;\n        }\n        if (msg.type !== 'op') {\n          const err: ErrorMessage = { type: 'error', message: 'Unsupported message type' };\n          ws.send(JSON.stringify(err));\n          return;\n        }\n        // Validate baseVersion\n        if (msg.baseVersion !== state.version) {\n          // Need to transform ops against missed ops\n          const missed = state.history.filter(h => h.version > msg.baseVersion);\