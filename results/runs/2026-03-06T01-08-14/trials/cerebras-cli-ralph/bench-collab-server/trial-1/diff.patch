+{"type":"tool_use","timestamp":1772759311407,"sessionID":"ses_33f4fd2b5ffeGXtRMMjxvu6ZWZ","part":{"id":"prt_cc0b05fff001Jjn6g8f2bI5Z1q","sessionID":"ses_33f4fd2b5ffeGXtRMMjxvu6ZWZ","messageID":"msg_cc0b05e0600285331dCbC1YetC","type":"tool","callID":"ccde33a36","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/server.ts","content":"import express, { Request, Response, NextFunction } from 'express';\nimport { Server as HttpServer } from 'http';\nimport { WebSocketServer, WebSocket } from 'ws';\nimport DB, { Document, Version } from './db';\nimport { applyOps, transformOps, TextOperation } from './ot';\nimport type { SyncMessage, OpMessage, ServerMessage, ErrorMessage } from './types';\nimport { randomUUID } from 'crypto';\n\ninterface DocumentState {\n  content: string;\n  version: number;\n  // Queue of ops that have been applied, along with version they were at\n  history: { version: number; ops: TextOperation[] }[];\n  // Connected clients\n  clients: Set<WebSocket>;\n}\n\nexport function createApp(dbPath?: string) {\n  const db = new DB(dbPath);\n  const app = express();\n  app.use(express.json());\n\n  // In-memory map: docId -> DocumentState\n  const docsState = new Map<number, DocumentState>();\n\n  const loadDocState = (docId: number): DocumentState => {\n    const doc = db.getDocument(docId);\n    if (!doc) throw new Error('Document not found');\n    const state: DocumentState = {\n      content: doc.content,\n      version: 0,\n      history: [],\n      clients: new Set()\n    };\n    // Initialize version based on existing content (no ops yet)\n    docsState.set(docId, state);\n    return state;\n  };\n\n  // Helper to get state, loading if absent\n  const getState = (docId: number): DocumentState => {\n    const existing = docsState.get(docId);\n    if (existing) return existing;\n    return loadDocState(docId);\n  };\n\n  // REST API routes\n  // Create document\n  app.post('/documents', (req: Request, res: Response) => {\n    const { title, content } = req.body as { title: string; content: string };\n    if (typeof title !== 'string' || typeof content !== 'string') {\n      return res.status(400).json({ error: 'Invalid payload' });\n    }\n    const doc = db.createDocument(title, content);\n    // Initialize in-memory state\n    docsState.set(doc.id, {\n      content: doc.content,\n      version: 0,\n      history: [],\n      clients: new Set()\n    });\n    res.status(201).json(doc);\n  });\n\n  // List documents\n  app.get('/documents', (req: Request, res: Response) => {\n    const docs = db.listDocuments();\n    res.json(docs);\n  });\n\n  // Get document\n  app.get('/documents/:id', (req: Request, res: Response) => {\n    const id = Number(req.params.id);\n    const doc = db.getDocument(id);\n    if (!doc) return res.status(404).json({ error: 'Not found' });\n    res.json(doc);\n  });\n\n  // Update document (full replace)\n  app.put('/documents/:id', (req: Request, res: Response) => {\n    const id = Number(req.params.id);\n    const { title, content } = req.body as { title: string; content: string };\n    if (typeof title !== 'string' || typeof content !== 'string') {\n      return res.status(400).json({ error: 'Invalid payload' });\n    }\n    const updated = db.updateDocument(id, title, content);\n    if (!updated) return res.status(404).json({ error: 'Not found' });\n    // Reset in-memory state to match DB content\n    const state = getState(id);\n    state.content = updated.content;\n    state.version = 0;\n    state.history = [];\n    // broadcast reset to clients\n    const msg: SyncMessage = { type: 'sync', content: updated.content, version: state.version };\n    const payload = JSON.stringify(msg);\n    state.clients.forEach(ws => ws.send(payload));\n    res.json(updated);\n  });\n\n  // Delete document\n  app.delete('/documents/:id', (req: Request, res: Response) => {\n    const id = Number(req.params.id);\n    const ok = db.deleteDocument(id);\n    if (!ok) return res.status(404).json({ error: 'Not found' });\n    // Close any WS connections for this doc\n    const state = docsState.get(id);\n    if (state) {\n      state.clients.forEach(ws => ws.close(1000, 'Document deleted'));\n      docsState.delete(id);\n    }\n    res.status(204).send();\n  });\n\n  // Get version history\n  app.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const id = Number(req.params.id);\n    const versions = db.getVersions(id);\n    res.json(versions);\n  });\n\n  // Error handling middleware\n  app.use((err: any, _req: Request, res: Response, _next: NextFunction) => {\n    console.error(err);\n    res.status(500).json({ error: 'Internal server error' });\n  });\n\n  // WebSocket server will be attached after HTTP server is created\n  let httpServer: HttpServer | null = null;\n  let wss: WebSocketServer | null = null;\n\n  const start = (port?: number): number => {\n    httpServer = app.listen(port ?? 0);\n    const actualPort = (httpServer.address() as any).port;\n    // Attach WS server on same HTTP server\n    wss = new WebSocketServer({ server: httpServer, path: '/ws/documents' });\n    wss.on('connection', (ws: WebSocket, request) => {\n      // Expect URL like /ws/documents/:id?clientId=xxx\n      const url = new URL(request.url ?? '', `http://${request.headers.host}`);\n      const pathname = url.pathname; // e.g., /ws/documents/5\n      const parts = pathname.split('/');\n      const docIdStr = parts[parts.length - 1];\n      const docId = Number(docIdStr);\n      const clientId = url.searchParams.get('clientId') ?? randomUUID();\n      if (isNaN(docId)) {\n        const err: ErrorMessage = { type: 'error', message: 'Invalid document ID in WS path' };\n        ws.send(JSON.stringify(err));\n        ws.close();\n        return;\n      }\n      // Retrieve or load document state\n      let state: DocumentState;\n      try {\n        state = getState(docId);\n      } catch (e) {\n        const err: ErrorMessage = { type: 'error', message: 'Document not found' };\n        ws.send(JSON.stringify(err));\n        ws.close();\n        return;\n      }\n      // Add ws to clients set\n      state.clients.add(ws);\n\n      // Send initial sync message\n      const syncMsg: SyncMessage = { type: 'sync', content: state.content, version: state.version };\n      ws.send(JSON.stringify(syncMsg));\n\n      ws.on('message', (data: any) => {\n        let msg: OpMessage;\n        try {\n          msg = JSON.parse(data.toString());\n        } catch {\n          const err: ErrorMessage = { type: 'error', message: 'Invalid JSON' };\n          ws.send(JSON.stringify(err));\n          return;\n        }\n        if (msg.type !== 'op') {\n          const err: ErrorMessage = { type: 'error', message: 'Unsupported message type' };\n          ws.send(JSON.stringify(err));\n          return;\n        }\n        // Validate baseVersion\n        if (msg.baseVersion !== state.version) {\n          // Need to transform ops against missed ops\n          const missed = state.history.filter(h => h.version > msg.baseVersion);\n          const existingOps = missed.flatMap(h => h.ops);\n          const transformedOps = transformOps(msg.ops, existingOps);\n          // Apply transformed ops\n          const newContent = applyOps(state.content, transformedOps);\n          // Update state\n          state.content = newContent;\n          state.version = state.version + transformedOps.length; // simplistic increment per op batch\n          // Record history\n          state.history.push({ version: state.version, ops: transformedOps });\n          // Persist to DB\n          db.updateDocument(docId, (db.getDocument(docId)!.title), newContent);\n          // Broadcast to others (including sender) as new op broadcast (skip transformation for sender?)\n          const broadcast: OpMessage = {\n            type: 'op',\n            clientId,\n            baseVersion: state.version,\n            ops: transformedOps\n          };\n          const payload = JSON.stringify(broadcast);\n          state.clients.forEach(client => {\n            if (client !== ws && client.readyState === WebSocket.OPEN) client.send(payload);\n          });\n          // Ack to sender with new version\n          const ack = { type: 'ack', newVersion: state.version } as const;\n          ws.send(JSON.stringify(ack));\n        } else {\n          // No concurrent version difference, apply directly\n          const newContent = applyOps(state.content, msg.ops);\n          state.content = newContent;\n          state.version = state.version + msg.ops.length;\n          state.history.push({ version: state.version, ops: msg.ops });\n          // Persist\n          db.updateDocument(docId, (db.getDocument(docId)!.title), newContent);\n          // Broadcast to other clients\n          const broadcast: OpMessage = { ...msg, baseVersion: state.version };\n          const payload = JSON.stringify(broadcast);\n          state.clients.forEach(client => {\n            if (client !== ws && client.readyState === WebSocket.OPEN) client.send(payload);\n          });\n          // Ack\n          const ack = { type: 'ack', newVersion: state.version } as const;\n          ws.send(JSON.stringify(ack));\n        }\n      });\n\n      ws.on('close', () => {\n        state.clients.delete(ws);\n        // If no more clients, we could cleanup memory, but keep for now\n      });\n    });\n    return actualPort as number;\n  };\n\n  const stop = () => {\n    if (wss) wss.close();\n    if (httpServer) httpServer.close();\n    db.close();\n  };\n\n  return { app, start, stop };\n}\n\nexport default createApp;\n","encoding":"utf8"},"output":"Wrote file successfully.","title":"src/server.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/server.ts","exists":false,"truncated":false},"time":{"start":1772759311400,"end":1772759311406}}}}
