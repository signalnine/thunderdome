umber): DocumentState => {\n42:     const existing = docsState.get(docId);\n43:     if (existing) return existing;\n44:     return loadDocState(docId);\n45:   };\n46: \n47:   // REST API routes\n48:   // Create document\n49:   app.post('/documents', (req: Request, res: Response) => {\n50:     const { title, content } = req.body as { title: string; content: string };\n51:     if (typeof title !== 'string' || typeof content !== 'string') {\n52:       return res.status(400).json({ error: 'Invalid payload' });\n53:     }\n54:     const doc = db.createDocument(title, content);\n55:     // Initialize in-memory state\n56:     docsState.set(doc.id, {\n57:       content: doc.content,\n58:       version: 0,\n59:       history: [],\n60:       clients: new Set()\n61:     });\n62:     res.status(201).json(doc);\n63:   });\n64: \n65:   // List documents\n66:   app.get('/documents', (req: Request, res: Response) => {\n67:     const docs = db.listDocuments();\n68:     res.json(docs);\n69:   });\n70: \n71:   // Get document\n72:   app.get('/documents/:id', (req: Request, res: Response) => {\n73:     const id = Number(req.params.id);\n74:     const doc = db.getDocument(id);\n75:     if (!doc) return res.status(404).json({ error: 'Not found' });\n76:     res.json(doc);\n77:   });\n78: \n79:   // Update document (full replace)\n80:   app.put('/documents/:id', (req: Request, res: Response) => {\n81:     const id = Number(req.params.id);\n82:     const { title, content } = req.body as { title: string; content: string };\n83:     if (typeof title !== 'string' || typeof content !== 'string') {\n84:       return res.status(400).json({ error: 'Invalid payload' });\n85:     }\n86:     const updated = db.updateDocument(id, title, content);\n87:     if (!updated) return res.status(404).json({ error: 'Not found' });\n88:     // Reset in-memory state to match DB content\n89:     const state = getState(id);\n90:     state.content = updated.content;\n91:     state.version = 0;\n92:     state.histor