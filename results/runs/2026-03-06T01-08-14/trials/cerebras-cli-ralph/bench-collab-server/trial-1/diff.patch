+{"type":"tool_use","timestamp":1772759309138,"sessionID":"ses_33f4fd2b5ffeGXtRMMjxvu6ZWZ","part":{"id":"prt_cc0b0587b0015QRzZz5p4hs0qJ","sessionID":"ses_33f4fd2b5ffeGXtRMMjxvu6ZWZ","messageID":"msg_cc0b04e3e0023UWJTthEE6PqpF","type":"tool","callID":"fe279e29a","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/ot.ts","content":"// Simple Operational Transform implementation for plain text.\n// Supports insert and delete operations.\n\nexport interface TextOperation {\n  /** Position in the string (0-indexed) where the operation applies */\n  pos: number;\n  /** Text to insert. If undefined, this is a delete operation */\n  insert?: string;\n  /** Number of characters to delete. If undefined, this is an insert operation */\n  delete?: number;\n}\n\n/**\n * Apply an array of operations sequentially to a string.\n * @param content Original content\n * @param ops Operations to apply (assumed already transformed)\n * @returns New content after applying all ops\n */\nexport function applyOps(content: string, ops: TextOperation[]): string {\n  // Apply in order of positions ascending. For overlapping ops, assume they are already transformed.\n  let result = content;\n  // Sort ops by position to apply correctly; for same position, inserts before deletes.\n  const sorted = ops.slice().sort((a, b) => {\n    if (a.pos !== b.pos) return a.pos - b.pos;\n    // Insert before delete if same position\n    if (a.insert && !b.insert) return -1;\n    if (!a.insert && b.insert) return 1;\n    return 0;\n  });\n  let offset = 0; // track shift due to prior ops\n  for (const op of sorted) {\n    const pos = op.pos + offset;\n    if (op.insert !== undefined) {\n      result = result.slice(0, pos) + op.insert + result.slice(pos);\n      offset += op.insert.length;\n    } else if (op.delete !== undefined) {\n      result = result.slice(0, pos) + result.slice(pos + op.delete);\n      offset -= op.delete;\n    }\n  }\n  return result;\n}\n\n/**\n * Transform a new operation against an existing operation.\n * Returns a new operation that can be applied after the existing one.\n * This is a simplified version suitable for single-character edits.\n */\nexport function transform(op: TextOperation, against: TextOperation): TextOperation {\n  // If against is an insert before op.pos, shift op.pos forward.\n  if (against.insert !== undefined) {\n    if (against.pos <= op.pos) {\n      return { ...op, pos: op.pos + against.insert.length };\n    }\n    return op;\n  }\n  // against is a delete\n  if (against.delete !== undefined) {\n    const delStart = against.pos;\n    const delEnd = against.pos + against.delete;\n    if (op.pos >= delEnd) {\n      // Op after deleted region, shift left\n      return { ...op, pos: op.pos - against.delete };\n    } else if (op.pos >= delStart && op.pos < delEnd) {\n      // Op inside deleted region: move to start of deletion\n      return { ...op, pos: delStart };\n    } else {\n      // Op before deleted region, unchanged\n      return op;\n    }\n  }\n  return op; // should not reach here\n}\n\n/**\n * Transform an array of new operations against a sequence of existing operations.\n * Applies transform sequentially.\n */\nexport function transformOps(newOps: TextOperation[], existingOps: TextOperation[]): TextOperation[] {\n  let transformed = newOps.map(op => ({ ...op }));\n  for (const exist of existingOps) {\n    transformed = transformed.map(op => transform(op, exist));\n  }\n  return transformed;\n}\n\nexport default { applyOps, transformOps, transform };\n","encoding":"utf8"},"output":"Wrote file successfully.","title":"src/ot.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/ot.ts","exists":false,"truncated":false},"time":{"start":1772759309131,"end":1772759309137}}}}
