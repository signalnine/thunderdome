  });\n87:       const checkDone = async () => {\n88:         if (syncA && syncB && opsB.length > 0) {\n89:           // Both clients should have received the op from A\n90:           expect(opsB[0].ops[0].insert).toBe('Hello');\n91:           // Verify final content via REST\n92:           const getRes = await request(appInstance.app).get(`/documents/${docId}`);\n93:           expect(getRes.body.content).toBe('Hello');\n94:           clientA.close();\n95:           clientB.close();\n96:           done();\n97:         }\n98:       };\n99:     })();\n100:   });\n101: });\n102: \n\n(End of file - total 102 lines)\n</content>","title":"src/__tests__/server.test.ts","metadata":{"preview":"import { describe, it, expect, beforeAll, afterAll } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport createApp from '../server';\n\nlet appInstance: ReturnType<typeof createApp>;\nlet port: number;\n\nbeforeAll(() => {\n  appInstance = createApp();\n  port = appInstance.start();\n});\n\nafterAll(() => {\n  appInstance.stop();\n});\n\ndescribe('REST API', () => {\n  it('should create, get, list, update, delete document', async () => {\n    const title = 'Test Doc';","truncated":false,"loaded":[]},"time":{"start":1772759330344,"end":1772759330353}}}}
