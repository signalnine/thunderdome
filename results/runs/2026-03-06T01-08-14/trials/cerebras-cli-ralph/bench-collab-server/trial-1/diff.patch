+import Database from 'better-sqlite3';
+import path from 'path';
+
+export interface Document {
+  id: number;
+  title: string;
+  content: string;
+}
+
+export interface Version {
+  id: number;
+  docId: number;
+  title: string;
+  content: string;
+  timestamp: string; // ISO string
+}
+
+export class DB {
+  private db: Database.Database;
+
+    constructor(dbPath?: string) {
+      const resolvedPath = dbPath ? path.resolve(dbPath) : path.resolve('data.db');
+      this.db = new Database(resolvedPath);
+      this.initialize();
+    }
+
+  private initialize() {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL
+      );
+      CREATE TABLE IF NOT EXISTS versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        doc_id INTEGER NOT NULL,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL,
+        timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
+        FOREIGN KEY (doc_id) REFERENCES documents(id) ON DELETE CASCADE
+      );
+    `);
+  }
+
+  // Document CRUD
+  createDocument(title: string, content: string): Document {
+    const stmt = this.db.prepare('INSERT INTO documents (title, content) VALUES (?, ?)');
+    const info = stmt.run(title, content);
+    const doc: Document = { id: Number(info.lastInsertRowid), title, content };
+    this.createVersion(doc.id, title, content);
+    return doc;
+  }
+
+  getDocument(id: number): Document | undefined {
+    const stmt = this.db.prepare('SELECT id, title, content FROM documents WHERE id = ?');
+    const row = stmt.get(id) as { id: number; title: string; content: string } | undefined;
+    return row ? { id: row.id, title: row.title, content: row.content } : undefined;
+  }
+
+  updateDocument(id: number, title: string, content: string): Document | undefined {
+    const stmt = this.db.prepare('UPDATE documents SET title = ?, content = ? WHERE id = ?');
+    const info = stmt.run(title, content, id);
+    if (info.changes === 0) return undefined;
+    const doc = this.getDocument(id);
+    if (doc) this.createVersion(id, title, content);
+    return doc;
+  }
+
+  deleteDocument(id: number): boolean {
+    const stmt = this.db.prepare('DELETE FROM documents WHERE id = ?');
+    const info = stmt.run(id);
+    return info.changes > 0;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare('SELECT id, title, content FROM documents ORDER BY id');
+    return stmt.all() as Document[];
+  }
+
+  // Versions
+  private createVersion(docId: number, title: string, content: string) {
+    const stmt = this.db.prepare('INSERT INTO versions (doc_id, title, content) VALUES (?, ?, ?)');
+    stmt.run(docId, title, content);
+  }
+
+  getVersions(docId: number): Version[] {
+    const stmt = this.db.prepare('SELECT id, doc_id as docId, title, content, timestamp FROM versions WHERE doc_id = ? ORDER BY id');
+    return stmt.all() as Version[];
+  }
+
+  // Close DB (optional)
+  close() {
+    this.db.close();
+  }
+}
+
+export default DB;
