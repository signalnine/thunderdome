y = [];\n93:     // broadcast reset to clients\n94:     const msg: SyncMessage = { type: 'sync', content: updated.content, version: state.version };\n95:     const payload = JSON.stringify(msg);\n96:     state.clients.forEach(ws => ws.send(payload));\n97:     res.json(updated);\n98:   });\n99: \n100:   // Delete document\n101:   app.delete('/documents/:id', (req: Request, res: Response) => {\n102:     const id = Number(req.params.id);\n103:     const ok = db.deleteDocument(id);\n104:     if (!ok) return res.status(404).json({ error: 'Not found' });\n105:     // Close any WS connections for this doc\n106:     const state = docsState.get(id);\n107:     if (state) {\n108:       state.clients.forEach(ws => ws.close(1000, 'Document deleted'));\n109:       docsState.delete(id);\n110:     }\n111:     res.status(204).send();\n112:   });\n113: \n114:   // Get version history\n115:   app.get('/documents/:id/versions', (req: Request, res: Response) => {\n116:     const id = Number(req.params.id);\n117:     const versions = db.getVersions(id);\n118:     res.json(versions);\n119:   });\n120: \n121:   // Error handling middleware\n122:   app.use((err: any, _req: Request, res: Response, _next: NextFunction) => {\n123:     console.error(err);\n124:     res.status(500).json({ error: 'Internal server error' });\n125:   });\n126: \n127:   // WebSocket server will be attached after HTTP server is created\n128:   let httpServer: HttpServer | null = null;\n129:   let wss: WebSocketServer | null = null;\n130: \n131:   const start = (port?: number): number => {\n132:     httpServer = app.listen(port ?? 0);\n133:     const actualPort = (httpServer.address() as any).port;\n134:     // Attach WS server on same HTTP server\n135:     wss = new WebSocketServer({ server: httpServer, path: '/ws' });\n136:     wss.on('connection', (ws: WebSocket, request) => {\n137:       // Expect URL like /ws/documents/:id?clientId=xxx\n138:       const url = new URL(request.url ?? '', `http://${request.headers.host}`);\n139:       const docIdStr = url.searchParams.get('docId');\n140:       const docId = docIdStr ? Number(docIdStr) : NaN;\n141:       const clientId = url.searchParams.get('clientId') ?? randomUUID();\n142:       if (isNaN(docId)) {\n143:         const err: ErrorMessage = { type: 'error', message: 'Invalid document ID in WS path' };\n144:         ws.send(JSON.stringify(err));\n145:         ws.close();\n146:         return;\n147:       }\n148:       // Retrieve or load document state\n149:       let state: DocumentState;\n150:       try {\n151:         state = getState(docId);\n152:       } catch (e) {\n153:         const err: ErrorMessage = { type: 'error', message: 'Document not found' };\n154:         ws.send(JSON.stringify(err));\n155:         ws.close();\n156:         return;\n157:       }\n158:       // Add ws to clients set\n159:       state.clients.add(ws);\n160: \n161:       // Send initial sync message\n162:       const syncMsg: SyncMessage = { type: 'sync', content: state.content, version: state.version };\n163:       ws.send(JSON.stringify(syncMsg));\n164: \n165:       ws.on('message', (data: any) => {\n166:         let msg: OpMessage;\n167:         try {\n168:           msg = JSON.parse(data.toString());\n169:         } catch {\n170:           const err: ErrorMessage = { type: 'error', message: 'Invalid JSON' };\n171:           ws.send(JSON.stringify(err));\n172:           return;\n173:         }\n174:         if (msg.type !== 'op') {\n175:           const err: ErrorMessage = { type: 'error', message: 'Unsupported message type' };\n176:           ws.send(JSON.stringify(err));\n177:           return;\n178:         }\n179:         // Validate baseVersion\n180:         if (msg.baseVersion !== state.version) {\n181:           // Need to transform ops against missed ops\n182:           const missed = state.history.filter(h => h.version > msg.baseVersion);\n183:           const existingOps = missed.flatMap(h => h.ops);\n184:           const transformedO