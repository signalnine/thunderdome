@@ -0,0 +1,107 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Position {
+  row: number;
+  col: number;
+}
+
+function findSource(grid: string[][]): Position | null {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') {
+      return { row: 0, col };
+    }
+  }
+  return null;
+}
+
+function isInBounds(grid: string[][], row: number, col: number): boolean {
+  return row >= 0 && row < grid.length && col >= 0 && col < grid[0].length;
+}
+
+function getNextPosition(row: number, col: number, direction: Direction): Position {
+  switch (direction) {
+    case 'down':
+      return { row: row + 1, col };
+    case 'down-left':
+      return { row: row + 1, col: col - 1 };
+    case 'down-right':
+      return { row: row + 1, col: col + 1 };
+  }
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  const key = (r: number, c: number) => `${r},${c}`;
+
+  const queue: Array<{ row: number; col: number; direction: Direction }> = [
+    { row: source.row, col: source.col, direction: 'down' },
+  ];
+
+  while (queue.length > 0) {
+    const { row, col, direction } = queue.shift()!;
+
+    if (!isInBounds(grid, row, col)) continue;
+
+    const cellKey = key(row, col);
+    if (visited.has(cellKey)) continue;
+    visited.add(cellKey);
+
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      const leftNext = getNextPosition(row, col, 'down-left');
+      const rightNext = getNextPosition(row, col, 'down-right');
+      queue.push({ ...leftNext, direction: 'down-left' });
+      queue.push({ ...rightNext, direction: 'down-right' });
+    } else {
+      const next = getNextPosition(row, col, direction);
+      queue.push({ ...next, direction });
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  const memo = new Map<string, bigint>();
+  const key = (r: number, c: number, d: Direction) => `${r},${c},${d}`;
+
+  function countPaths(row: number, col: number, direction: Direction): bigint {
+    if (!isInBounds(grid, row, col)) {
+      return 1n;
+    }
+
+    const memoKey = key(row, col, direction);
+    if (memo.has(memoKey)) {
+      return memo.get(memoKey)!;
+    }
+
+    const cell = grid[row][col];
+    let result: bigint;
+
+    if (cell === '^') {
+      const leftNext = getNextPosition(row, col, 'down-left');
+      const rightNext = getNextPosition(row, col, 'down-right');
+      result = countPaths(leftNext.row, leftNext.col, 'down-left') +
+               countPaths(rightNext.row, rightNext.col, 'down-right');
+    } else {
+      const next = getNextPosition(row, col, direction);
+      result = countPaths(next.row, next.col, direction);
+    }
+
+    memo.set(memoKey, result);
+    return result;
+  }
+
+  return countPaths(source.row, source.col, 'down');
+}
