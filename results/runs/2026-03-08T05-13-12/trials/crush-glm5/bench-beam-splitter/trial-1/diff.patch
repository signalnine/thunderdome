+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('Beam Splitter', () => {
+  describe('countBeamCells', () => {
+    it('handles simple grid with one splitter', () => {
+      const grid = [
+        ['.', 'S', '.', '.', '.'],
+        ['.', '.', '.', '.', '.'],
+        ['.', '^', '.', '.', '.'],
+        ['.', '.', '.', '.', '.'],
+      ];
+      expect(countBeamCells(grid)).toBe(5);
+    });
+
+    it('handles grid with two splitters', () => {
+      const grid = [
+        ['.', 'S', '.', '.', '.'],
+        ['.', '^', '.', '.', '.'],
+        ['^', '.', '^', '.', '.'],
+        ['.', '.', '.', '.', '.'],
+      ];
+      expect(countBeamCells(grid)).toBe(6);
+    });
+
+    it('handles grid with no splitters', () => {
+      const grid = [
+        ['.', 'S', '.'],
+        ['.', '.', '.'],
+        ['.', '.', '.'],
+      ];
+      expect(countBeamCells(grid)).toBe(3);
+    });
+
+    it('handles empty grid', () => {
+      expect(countBeamCells([])).toBe(0);
+    });
+
+    it('handles grid with no source', () => {
+      const grid = [
+        ['.', '.', '.'],
+        ['.', '.', '.'],
+      ];
+      expect(countBeamCells(grid)).toBe(0);
+    });
+  });
+
+  describe('countBeamPaths', () => {
+    it('handles simple grid with one splitter', () => {
+      const grid = [
+        ['.', 'S', '.', '.', '.'],
+        ['.', '.', '.', '.', '.'],
+        ['.', '^', '.', '.', '.'],
+        ['.', '.', '.', '.', '.'],
+      ];
+      expect(countBeamPaths(grid)).toBe(2n);
+    });
+
+    it('handles grid with two splitters', () => {
+      const grid = [
+        ['.', 'S', '.', '.', '.'],
+        ['.', '^', '.', '.', '.'],
+        ['^', '.', '^', '.', '.'],
+        ['.', '.', '.', '.', '.'],
+      ];
+      expect(countBeamPaths(grid)).toBe(4n);
+    });
+
+    it('handles grid with no splitters', () => {
+      const grid = [
+        ['.', 'S', '.'],
+        ['.', '.', '.'],
+        ['.', '.', '.'],
+      ];
+      expect(countBeamPaths(grid)).toBe(1n);
+    });
+
+    it('handles empty grid', () => {
+      expect(countBeamPaths([])).toBe(0n);
+    });
+
+    it('handles large number of paths efficiently', () => {
+      // Create a grid with cascading splitters in a binary tree pattern
+      // Each level has one more splitter than the previous
+      // All beams from splitters hit splitters at the next level
+      const depth = 50;
+      const rows = depth + 2;
+      const cols = depth * 2 + 5;
+      const grid: string[][] = [];
+      for (let r = 0; r < rows; r++) {
+        const row: string[] = [];
+        for (let c = 0; c < cols; c++) {
+          row.push('.');
+        }
+        grid.push(row);
+      }
+
+      const center = Math.floor(cols / 2);
+      grid[0][center] = 'S';
+
+      // Place splitters in a binary tree pattern
+      // Level n (1-indexed) has n splitters at positions:
+      // center - (n-1), center - (n-3), ..., center + (n-3), center + (n-1)
+      for (let level = 1; level <= depth; level++) {
+        const row = level;
+        for (let i = 0; i < level; i++) {
+          const col = center - (level - 1) + 2 * i;
+          grid[row][col] = '^';
+        }
+      }
+
+      const start = Date.now();
+      const result = countBeamPaths(grid);
+      const elapsed = Date.now() - start;
+
+      expect(result).toBe(2n ** BigInt(depth));
+      expect(elapsed).toBeLessThan(5000);
+    });
+  });
+});
