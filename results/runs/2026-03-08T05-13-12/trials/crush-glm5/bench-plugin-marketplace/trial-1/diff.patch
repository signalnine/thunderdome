+import type { DepsService, DependencyNode, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      const plugin = registry.get(name);
+      if (!plugin) {
+        throw new Error(`Plugin ${name} not found`);
+      }
+
+      const dependencies: DependencyNode[] = [];
+      for (const depName of Object.keys(plugin.dependencies)) {
+        dependencies.push(this.buildTree(depName, registry));
+      }
+
+      return {
+        name: plugin.name,
+        version: plugin.version,
+        dependencies,
+      };
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles: string[][] = [];
+      const visited = new Set<string>();
+      const recursionStack = new Set<string>();
+      const path: string[] = [];
+
+      function dfs(nodeName: string): boolean {
+        visited.add(nodeName);
+        recursionStack.add(nodeName);
+        path.push(nodeName);
+
+        const plugin = registry.get(nodeName);
+        if (plugin) {
+          for (const depName of Object.keys(plugin.dependencies)) {
+            if (!visited.has(depName)) {
+              if (dfs(depName)) {
+                return true;
+              }
+            } else if (recursionStack.has(depName)) {
+              const cycleStart = path.indexOf(depName);
+              const cycle = path.slice(cycleStart);
+              cycles.push(cycle);
+            }
+          }
+        }
+
+        path.pop();
+        recursionStack.delete(nodeName);
+        return false;
+      }
+
+      dfs(name);
+
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const result: string[] = [];
+      const visited = new Set<string>();
+
+      function visit(nodeName: string): void {
+        if (visited.has(nodeName)) {
+          return;
+        }
+        visited.add(nodeName);
+
+        const plugin = registry.get(nodeName);
+        if (plugin) {
+          for (const depName of Object.keys(plugin.dependencies)) {
+            visit(depName);
+          }
+        }
+
+        result.push(nodeName);
+      }
+
+      visit(name);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const result: string[] = [];
+      const visited = new Set<string>();
+
+      function collect(nodeName: string): void {
+        const plugin = registry.get(nodeName);
+        if (!plugin) {
+          return;
+        }
+
+        for (const depName of Object.keys(plugin.dependencies)) {
+          if (!visited.has(depName)) {
+            visited.add(depName);
+            result.push(depName);
+            collect(depName);
+          }
+        }
+      }
+
+      collect(name);
+      return result;
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      return this.detectCycles(name, registry) !== null;
+    },
+  };
+}
