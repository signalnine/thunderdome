+import { Script } from 'vm';
+import type { RunnerService, SandboxResult } from '../types.js';
+
+export function createRunner(): RunnerService {
+  async function executeCode(
+    code: string,
+    context: Record<string, unknown> = {},
+    timeoutMs?: number
+  ): Promise<SandboxResult> {
+    const startTime = Date.now();
+    const startMemory = process.memoryUsage().heapUsed;
+
+    try {
+      const wrappedCode = `(function() { ${code} })()`;
+      const script = new Script(wrappedCode, {
+        filename: 'plugin.js',
+        lineOffset: 0,
+      });
+
+      const sandbox: Record<string, unknown> = {
+        ...context,
+        console: { log: () => {}, error: () => {}, warn: () => {} },
+      };
+
+      const options: { timeout?: number } = {};
+      if (timeoutMs !== undefined) {
+        options.timeout = timeoutMs;
+      }
+
+      const output = script.runInNewContext(sandbox, options);
+      const endMemory = process.memoryUsage().heapUsed;
+
+      return {
+        success: true,
+        output,
+        duration: Date.now() - startTime,
+        memoryUsed: endMemory - startMemory,
+      };
+    } catch (error) {
+      const endMemory = process.memoryUsage().heapUsed;
+      const errorMessage = error instanceof Error ? error.message : String(error);
+
+      return {
+        success: false,
+        output: null,
+        duration: Date.now() - startTime,
+        memoryUsed: endMemory - startMemory,
+        error: errorMessage,
+      };
+    }
+  }
+
+  return {
+    async execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+      return executeCode(code, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return executeCode(code, context, timeoutMs);
+    },
+  };
+}
