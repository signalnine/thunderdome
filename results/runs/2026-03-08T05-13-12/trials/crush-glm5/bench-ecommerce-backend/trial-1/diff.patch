@@ -0,0 +1,102 @@
+import { EventBus } from '../bus.js';
+import { AnalyticsService, Events, OrderCreatedEvent, PaymentProcessedEvent, CartUpdatedEvent, PaymentStatus, AnalyticsEvent } from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  const uniqueCarts = new Set<string>();
+  const orders = new Set<string>();
+  let totalRevenue = 0;
+  const orderToCart = new Map<string, string>();
+  const orderTotals = new Map<string, number>();
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+
+  const trackEvent = (event: string, data: Record<string, unknown>) => {
+    const count = eventCounts.get(event) || 0;
+    eventCounts.set(event, count + 1);
+
+    const payload: AnalyticsEvent = { event, data, timestamp: Date.now() };
+    bus.emit(Events.ANALYTICS_EVENT, payload);
+  };
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as CartUpdatedEvent;
+    uniqueCarts.add(event.cartId);
+    cartItems.set(event.cartId, event.items);
+    trackEvent(Events.CART_UPDATED, event as unknown as Record<string, unknown>);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orders.add(event.orderId);
+    orderToCart.set(event.orderId, event.cartId);
+    orderTotals.set(event.orderId, event.total);
+    trackEvent(Events.ORDER_CREATED, event as unknown as Record<string, unknown>);
+  });
+
+  bus.on(Events.PRODUCT_CREATED, (payload: unknown) => {
+    trackEvent(Events.PRODUCT_CREATED, payload as Record<string, unknown>);
+  });
+
+  bus.on(Events.INVENTORY_UPDATED, (payload: unknown) => {
+    trackEvent(Events.INVENTORY_UPDATED, payload as Record<string, unknown>);
+  });
+
+  bus.on(Events.LOW_STOCK_ALERT, (payload: unknown) => {
+    trackEvent(Events.LOW_STOCK_ALERT, payload as Record<string, unknown>);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {
+    trackEvent(Events.ORDER_STATUS_CHANGED, payload as Record<string, unknown>);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    trackEvent(Events.PAYMENT_PROCESSED, event as unknown as Record<string, unknown>);
+
+    if (event.status === PaymentStatus.SUCCESS) {
+      const orderTotal = orderTotals.get(event.orderId) || 0;
+      totalRevenue += orderTotal;
+    }
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, (payload: unknown) => {
+    trackEvent(Events.NOTIFICATION_SENT, payload as Record<string, unknown>);
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) || 0;
+    },
+
+    getRevenue(): number {
+      return totalRevenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCarts.size === 0) return 0;
+      return orders.size / uniqueCarts.size;
+    },
+
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> {
+      const productCounts = new Map<string, number>();
+      
+      for (const orderId of orders) {
+        const cartId = orderToCart.get(orderId);
+        if (cartId) {
+          const items = cartItems.get(cartId);
+          if (items) {
+            for (const item of items) {
+              const current = productCounts.get(item.productId) || 0;
+              productCounts.set(item.productId, current + item.quantity);
+            }
+          }
+        }
+      }
+
+      return Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    }
+  };
+}
