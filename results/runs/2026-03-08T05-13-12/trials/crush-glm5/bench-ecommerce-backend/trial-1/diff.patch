+import { EventBus } from '../bus.js';
+import { OrderService, OrderStatus, Events, OrderCreatedEvent, OrderStatusChangedEvent } from '../types.js';
+
+export function createOrderService(bus: EventBus): OrderService {
+  const orders = new Map<string, { id: string; userId: string; cartId: string; status: OrderStatus; total: number }>();
+  const userOrders = new Map<string, Set<string>>();
+
+  return {
+    createOrder(userId: string, cartId: string, total: number): string {
+      const id = `order_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
+      orders.set(id, { id, userId, cartId, status: OrderStatus.PENDING, total });
+      
+      if (!userOrders.has(userId)) {
+        userOrders.set(userId, new Set());
+      }
+      userOrders.get(userId)!.add(id);
+
+      const payload: OrderCreatedEvent = { orderId: id, userId, cartId, total };
+      bus.emit(Events.ORDER_CREATED, payload);
+
+      return id;
+    },
+
+    getOrder(orderId: string) {
+      const order = orders.get(orderId);
+      if (!order) return null;
+      return {
+        id: order.id,
+        userId: order.userId,
+        status: order.status,
+        total: order.total
+      };
+    },
+
+    updateStatus(orderId: string, status: OrderStatus): void {
+      const order = orders.get(orderId);
+      if (order) {
+        const previousStatus = order.status;
+        order.status = status;
+        
+        const payload: OrderStatusChangedEvent = {
+          orderId,
+          status,
+          previousStatus
+        };
+        bus.emit(Events.ORDER_STATUS_CHANGED, payload);
+      }
+    },
+
+    listOrders(userId: string) {
+      const orderIds = userOrders.get(userId);
+      if (!orderIds) return [];
+      
+      return Array.from(orderIds)
+        .map(id => orders.get(id))
+        .filter((o): o is NonNullable<typeof o> => o !== undefined)
+        .map(o => ({ id: o.id, status: o.status, total: o.total }));
+    }
+  };
+}
