+interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set(gates);
+  
+  while (remaining.size > 0) {
+    let progress = false;
+    for (const gate of remaining) {
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const v1 = wires[gate.in1];
+        const v2 = wires[gate.in2];
+        let result: number;
+        if (gate.op === 'AND') result = v1 & v2;
+        else if (gate.op === 'OR') result = v1 | v2;
+        else result = v1 ^ v2;
+        wires[gate.out] = result;
+        remaining.delete(gate);
+        progress = true;
+        break;
+      }
+    }
+    if (!progress) break;
+  }
+  
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const outputToGate = new Map<string, Gate>();
+  for (const gate of gates) {
+    outputToGate.set(gate.out, gate);
+  }
+  
+  // Identify XOR(xNN, yNN) and AND(xNN, yNN) gates
+  const partialSum = new Map<number, Gate>();
+  const generate = new Map<number, Gate>();
+  
+  for (const gate of gates) {
+    const bit = getXYBit(gate);
+    if (bit !== null) {
+      if (gate.op === 'XOR') partialSum.set(bit, gate);
+      else if (gate.op === 'AND') generate.set(bit, gate);
+    }
+  }
+  
+  const maxBit = Math.max(...partialSum.keys());
+  const swapped = new Set<string>();
+  
+  // Check 1: z00 should be XOR(x00, y00)
+  const ps0 = partialSum.get(0)!;
+  if (ps0.out !== 'z00') {
+    swapped.add(ps0.out);
+    swapped.add('z00');
+  }
+  
+  // Check 2: For each bit N > 0, find XOR gate using partialSum[N].out
+  // This XOR gate should output zNN
+  for (let n = 1; n <= maxBit; n++) {
+    const ps = partialSum.get(n)!;
+    const zWire = `z${n.toString().padStart(2, '0')}`;
+    
+    const xorUsingPs = gates.filter(g => 
+      g !== ps && g.op === 'XOR' && (g.in1 === ps.out || g.in2 === ps.out)
+    );
+    
+    if (xorUsingPs.length >= 1) {
+      const correctZGate = xorUsingPs[0];
+      if (correctZGate.out !== zWire) {
+        swapped.add(correctZGate.out);
+        swapped.add(zWire);
+      }
+    } else {
+      // No XOR gate using ps.out - the partial sum wire might be swapped
+      swapped.add(ps.out);
+      swapped.add(zWire);
+    }
+  }
+  
+  // Check 3: XOR(xNN, yNN) for N > 0 should NOT output any z wire
+  for (const [bit, ps] of partialSum) {
+    if (bit > 0 && ps.out.startsWith('z')) {
+      swapped.add(ps.out);
+    }
+  }
+  
+  // Check 3b: XOR(xNN, yNN) for N > 0 should have its output used by another XOR gate
+  for (const [bit, ps] of partialSum) {
+    if (bit === 0) continue;
+    
+    const xorUsingPs = gates.filter(g => 
+      g !== ps && g.op === 'XOR' && (g.in1 === ps.out || g.in2 === ps.out)
+    );
+    
+    if (xorUsingPs.length === 0 && !ps.out.startsWith('z')) {
+      // No XOR gate using ps.out and it's not outputting z - likely swapped
+      swapped.add(ps.out);
+    }
+  }
+  
+  // Check 4: AND(xNN, yNN) should NOT output any z wire
+  for (const gen of generate.values()) {
+    if (gen.out.startsWith('z')) {
+      swapped.add(gen.out);
+    }
+  }
+  
+  // Check 4b: AND(xNN, yNN) for N > 0 should have its output used by an OR gate
+  // (AND(x00, y00) outputs carry for bit 0, which is used by XOR for z01)
+  for (const [bit, gen] of generate) {
+    if (bit === 0) continue;
+    
+    const orUsingGen = gates.filter(g => 
+      g.op === 'OR' && (g.in1 === gen.out || g.in2 === gen.out)
+    );
+    
+    if (orUsingGen.length === 0 && !gen.out.startsWith('z')) {
+      // No OR gate using gen.out - likely swapped
+      swapped.add(gen.out);
+    }
+  }
+  
+  // Check 5: z(maxBit+1) should be OR gate
+  const finalZ = `z${(maxBit + 1).toString().padStart(2, '0')}`;
+  const finalZGate = outputToGate.get(finalZ);
+  
+  if (finalZGate && finalZGate.op !== 'OR') {
+    swapped.add(finalZ);
+    // Find the correct OR gate
+    const correctOR = findFinalORGate(gates, partialSum, generate, maxBit);
+    if (correctOR && correctOR.out !== finalZ) {
+      swapped.add(correctOR.out);
+    }
+  } else if (!finalZGate) {
+    swapped.add(finalZ);
+    const correctOR = findFinalORGate(gates, partialSum, generate, maxBit);
+    if (correctOR) {
+      swapped.add(correctOR.out);
+    }
+  }
+  
+  // Check 6: The final OR gate should output z(maxBit+1)
+  const correctOR = findFinalORGate(gates, partialSum, generate, maxBit);
+  if (correctOR && correctOR.out !== finalZ && correctOR.out.startsWith('z')) {
+    swapped.add(correctOR.out);
+  }
+  
+  return [...swapped].sort();
+}
+
+function findFinalORGate(
+  gates: Gate[], 
+  partialSum: Map<number, Gate>, 
+  generate: Map<number, Gate>,
+  maxBit: number
+): Gate | undefined {
+  const psMax = partialSum.get(maxBit)!;
+  const genMax = generate.get(maxBit)!;
+  
+  // Find XOR gate using psMax.out (the zMax gate)
+  const xorUsingPsMax = gates.filter(g => 
+    g !== psMax && g.op === 'XOR' && (g.in1 === psMax.out || g.in2 === psMax.out)
+  );
+  
+  if (xorUsingPsMax.length === 0) return undefined;
+  
+  const zMaxGate = xorUsingPsMax[0];
+  const carryIn = zMaxGate.in1 === psMax.out ? zMaxGate.in2 : zMaxGate.in1;
+  
+  // Find AND gate using psMax.out and carryIn (propagate)
+  const propGate = gates.find(g => 
+    g.op === 'AND' && ((g.in1 === psMax.out && g.in2 === carryIn) || (g.in1 === carryIn && g.in2 === psMax.out))
+  );
+  
+  if (!propGate) return undefined;
+  
+  // Find OR gate using genMax.out and propGate.out (final carry)
+  return gates.find(g => 
+    g.op === 'OR' && ((g.in1 === genMax.out && g.in2 === propGate.out) || (g.in1 === propGate.out && g.in2 === genMax.out))
+  );
+}
+
+function getXYBit(gate: Gate): number | null {
+  const m1 = gate.in1.match(/^[xy](\d+)$/);
+  const m2 = gate.in2.match(/^[xy](\d+)$/);
+  if (m1 && m2 && m1[1] === m2[1] && gate.in1[0] !== gate.in2[0]) {
+    return parseInt(m1[1]);
+  }
+  return null;
+}
