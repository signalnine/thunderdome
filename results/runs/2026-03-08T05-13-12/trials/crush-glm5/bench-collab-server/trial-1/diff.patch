+export interface InsertOperation {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOperation {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOperation | DeleteOperation;
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: Operation | null;
+  created_at: string;
+}
+
+export interface ActiveConnection {
+  id: string;
+  document_id: string;
+  connected_at: string;
+}
+
+export interface WsMessage {
+  type: 'operation' | 'ack' | 'sync' | 'error';
+  operation?: Operation;
+  version?: number;
+  content?: string;
+  message?: string;
+}
+
+export interface ClientMessage {
+  type: 'operation';
+  operation: Operation;
+  version?: number;
+}
