+import { Router, type Request, type Response } from 'express';
+import type Database from 'better-sqlite3';
+import { generateId } from './db.js';
+import type { Document, Version, VersionRow, Operation } from './models.js';
+
+export function createRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  router.post('/docs', (req: Request, res: Response) => {
+    const { title, content = '' } = req.body;
+    const id = generateId();
+    const now = new Date().toISOString();
+
+    const stmt = db.prepare(`
+      INSERT INTO documents (id, title, content, created_at, updated_at)
+      VALUES (?, ?, ?, ?, ?)
+    `);
+    stmt.run(id, title, content, now, now);
+
+    const versionStmt = db.prepare(`
+      INSERT INTO versions (document_id, version, content, operation, created_at)
+      VALUES (?, 0, ?, NULL, ?)
+    `);
+    versionStmt.run(id, content, now);
+
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document;
+    res.status(201).json(doc);
+  });
+
+  router.get('/docs', (_req: Request, res: Response) => {
+    const docs = db.prepare('SELECT * FROM documents ORDER BY created_at DESC').all() as Document[];
+    res.json(docs);
+  });
+
+  router.get('/docs/:id', (req: Request, res: Response) => {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id) as Document | undefined;
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  router.put('/docs/:id', (req: Request, res: Response) => {
+    const { title } = req.body;
+    const now = new Date().toISOString();
+
+    const existing = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id) as Document | undefined;
+    if (!existing) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    db.prepare('UPDATE documents SET title = ?, updated_at = ? WHERE id = ?').run(title, now, req.params.id);
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id) as Document;
+    res.json(doc);
+  });
+
+  router.delete('/docs/:id', (req: Request, res: Response) => {
+    const existing = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    if (!existing) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    db.prepare('DELETE FROM documents WHERE id = ?').run(req.params.id);
+    res.status(204).send();
+  });
+
+  router.get('/docs/:id/versions', (req: Request, res: Response) => {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const versions = db
+      .prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC')
+      .all(req.params.id) as VersionRow[];
+    
+    const parsedVersions: Version[] = versions.map((v) => ({
+      ...v,
+      operation: v.operation ? JSON.parse(v.operation) as Operation : null,
+    }));
+    
+    res.json(parsedVersions);
+  });
+
+  router.get('/docs/:id/versions/:version', (req: Request, res: Response) => {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const versionRow = db
+      .prepare('SELECT * FROM versions WHERE document_id = ? AND version = ?')
+      .get(req.params.id, parseInt(req.params.version, 10)) as VersionRow | undefined;
+
+    if (!versionRow) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+
+    const version: Version = {
+      ...versionRow,
+      operation: versionRow.operation ? JSON.parse(versionRow.operation) as Operation : null,
+    };
+
+    res.json(version);
+  });
+
+  return router;
+}
