@@ -0,0 +1,171 @@
+import { WebSocket } from 'ws';
+import type Database from 'better-sqlite3';
+import type { Operation, Document, WsMessage, ClientMessage } from './models.js';
+import { applyOperation, validateOperation, transformOperation } from './ot.js';
+import { generateId } from './db.js';
+
+interface Room {
+  docId: string;
+  clients: Set<WebSocket>;
+  pendingOperations: Array<{ op: Operation; clientVersion: number; clientId: WebSocket }>;
+}
+
+export class WebSocketHandler {
+  private rooms: Map<string, Room> = new Map();
+  private clientRooms: Map<WebSocket, string> = new Map();
+  private db: Database.Database;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+  }
+
+  handleConnection(ws: WebSocket, docId: string): void {
+    const doc = this.db.prepare('SELECT * FROM documents WHERE id = ?').get(docId) as Document | undefined;
+
+    if (!doc) {
+      this.send(ws, { type: 'error', message: 'Document not found' });
+      ws.close();
+      return;
+    }
+
+    const version = this.getLatestVersion(docId);
+
+    const connId = generateId();
+    this.db.prepare('INSERT INTO active_connections (id, document_id, connected_at) VALUES (?, ?, ?)').run(
+      connId,
+      docId,
+      new Date().toISOString()
+    );
+
+    if (!this.rooms.has(docId)) {
+      this.rooms.set(docId, { docId, clients: new Set(), pendingOperations: [] });
+    }
+    const room = this.rooms.get(docId)!;
+    room.clients.add(ws);
+    this.clientRooms.set(ws, docId);
+
+    this.send(ws, { type: 'sync', content: doc.content, version });
+
+    ws.on('message', (data: Buffer) => {
+      this.handleMessage(ws, docId, data);
+    });
+
+    ws.on('close', () => {
+      this.handleDisconnect(ws, docId, connId);
+    });
+  }
+
+  private handleMessage(ws: WebSocket, docId: string, data: Buffer): void {
+    let msg: ClientMessage;
+    try {
+      msg = JSON.parse(data.toString()) as ClientMessage;
+    } catch {
+      this.send(ws, { type: 'error', message: 'Invalid JSON' });
+      return;
+    }
+
+    if (msg.type !== 'operation') {
+      this.send(ws, { type: 'error', message: 'Unknown message type' });
+      return;
+    }
+
+    const op = msg.operation;
+    if (op.type !== 'insert' && op.type !== 'delete') {
+      this.send(ws, { type: 'error', message: 'Invalid operation type' });
+      return;
+    }
+
+    const doc = this.db.prepare('SELECT * FROM documents WHERE id = ?').get(docId) as Document;
+    if (!doc) {
+      this.send(ws, { type: 'error', message: 'Document not found' });
+      return;
+    }
+
+    const currentVersion = this.getLatestVersion(docId);
+    const clientVersion = msg.version ?? currentVersion;
+
+    let transformedOp = op;
+    const room = this.rooms.get(docId);
+    
+    if (room) {
+      for (const pending of room.pendingOperations) {
+        if (pending.clientVersion >= clientVersion) {
+          transformedOp = transformOperation(transformedOp, pending.op);
+        }
+      }
+    }
+
+    if (!validateOperation(transformedOp, doc.content.length)) {
+      this.send(ws, { type: 'error', message: 'Invalid operation: out of bounds' });
+      return;
+    }
+
+    const newContent = applyOperation(doc.content, transformedOp);
+    const newVersion = currentVersion + 1;
+    const now = new Date().toISOString();
+
+    this.db.prepare('UPDATE documents SET content = ?, updated_at = ? WHERE id = ?').run(newContent, now, docId);
+
+    this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation, created_at) VALUES (?, ?, ?, ?, ?)'
+    ).run(docId, newVersion, newContent, JSON.stringify(transformedOp), now);
+
+    if (room) {
+      room.pendingOperations.push({ op: transformedOp, clientVersion, clientId: ws });
+      if (room.pendingOperations.length > 100) {
+        room.pendingOperations.shift();
+      }
+    }
+
+    this.send(ws, { type: 'ack', version: newVersion });
+
+    this.broadcast(docId, { type: 'operation', operation: transformedOp, version: newVersion }, ws);
+  }
+
+  private handleDisconnect(ws: WebSocket, docId: string, connId: string): void {
+    const room = this.rooms.get(docId);
+    if (room) {
+      room.clients.delete(ws);
+      if (room.clients.size === 0) {
+        this.rooms.delete(docId);
+      }
+    }
+    this.clientRooms.delete(ws);
+    this.db.prepare('DELETE FROM active_connections WHERE id = ?').run(connId);
+  }
+
+  private getLatestVersion(docId: string): number {
+    const result = this.db
+      .prepare('SELECT MAX(version) as version FROM versions WHERE document_id = ?')
+      .get(docId) as { version: number | null };
+    return result.version ?? 0;
+  }
+
+  private send(ws: WebSocket, msg: WsMessage): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(msg));
+    }
+  }
+
+  private broadcast(docId: string, msg: WsMessage, exclude?: WebSocket): void {
+    const room = this.rooms.get(docId);
+    if (!room) return;
+
+    const data = JSON.stringify(msg);
+    for (const client of room.clients) {
+      if (client !== exclude && client.readyState === WebSocket.OPEN) {
+        client.send(data);
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const [docId, room] of this.rooms) {
+      for (const client of room.clients) {
+        client.close();
+      }
+      this.rooms.delete(docId);
+    }
+    this.clientRooms.clear();
+  }
+}
