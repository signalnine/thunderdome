@@ -0,0 +1,76 @@
+import type { Operation, InsertOperation, DeleteOperation } from './models.js';
+
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const before = content.slice(0, op.position);
+    const after = content.slice(op.position);
+    return before + op.text + after;
+  } else {
+    const before = content.slice(0, op.position);
+    const after = content.slice(op.position + op.count);
+    return before + after;
+  }
+}
+
+export function transformOperation(op: Operation, against: Operation): Operation {
+  if (op.type === 'insert') {
+    if (against.type === 'insert') {
+      if (against.position <= op.position) {
+        return { ...op, position: op.position + against.text.length };
+      }
+      return op;
+    } else {
+      if (against.position + against.count <= op.position) {
+        return { ...op, position: op.position - against.count };
+      } else if (against.position <= op.position) {
+        return { ...op, position: against.position };
+      }
+      return op;
+    }
+  } else {
+    if (against.type === 'insert') {
+      if (against.position <= op.position) {
+        return { ...op, position: op.position + against.text.length };
+      } else if (against.position < op.position + op.count) {
+        return { ...op, count: op.count + against.text.length };
+      }
+      return op;
+    } else {
+      if (against.position + against.count <= op.position) {
+        return { ...op, position: op.position - against.count };
+      } else if (op.position + op.count <= against.position) {
+        return op;
+      } else if (against.position <= op.position && against.position + against.count >= op.position + op.count) {
+        return { ...op, position: against.position, count: 0 };
+      } else if (against.position <= op.position) {
+        const overlap = against.position + against.count - op.position;
+        return { ...op, position: against.position, count: op.count - overlap };
+      } else if (against.position + against.count >= op.position + op.count) {
+        const overlap = op.position + op.count - against.position;
+        return { ...op, count: op.count - overlap };
+      } else {
+        return { ...op, count: op.count - against.count };
+      }
+    }
+  }
+}
+
+export function validateOperation(op: Operation, contentLength: number): boolean {
+  if (op.type === 'insert') {
+    return op.position >= 0 && op.position <= contentLength && typeof op.text === 'string';
+  } else {
+    return (
+      op.position >= 0 &&
+      op.count > 0 &&
+      op.position + op.count <= contentLength
+    );
+  }
+}
+
+export function isInsertOperation(op: Operation): op is InsertOperation {
+  return op.type === 'insert';
+}
+
+export function isDeleteOperation(op: Operation): op is DeleteOperation {
+  return op.type === 'delete';
+}
