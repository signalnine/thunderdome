+import { Plugin } from '../core/types.js';
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: (ctx) => {
+        const { files } = ctx;
+
+        const index = files.map((file) => {
+          // Strip HTML tags from content
+          const plainText = file.content
+            .replace(/<[^>]*>/g, '')
+            .replace(/\s+/g, ' ')
+            .trim();
+
+          const entry: Record<string, unknown> = {
+            slug: file.slug,
+            title: file.title,
+            content: plainText,
+          };
+
+          if (file.tags) {
+            entry.tags = file.tags;
+          }
+
+          return entry;
+        });
+
+        ctx.output.set('search-index.json', JSON.stringify(index, null, 2));
+      },
+    },
+  };
+}
