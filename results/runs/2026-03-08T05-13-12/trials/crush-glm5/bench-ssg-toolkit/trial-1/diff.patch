@@ -0,0 +1,53 @@
+import { Plugin } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string | null;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: (ctx) => {
+        const { output, data } = ctx;
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes: [],
+          assetPaths: [],
+          searchIndexPath: null,
+        };
+
+        // Get asset paths from asset-pipeline
+        const assetManifest = data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (assetManifest && assetManifest.assets) {
+          config.assetPaths = assetManifest.assets;
+          for (const asset of assetManifest.assets) {
+            config.routes.push({
+              path: `/assets/${asset}`,
+              handler: 'asset',
+            });
+          }
+        }
+
+        // Add content routes
+        for (const [path] of output) {
+          if (path === 'search-index.json') {
+            config.searchIndexPath = '/search-index.json';
+          }
+          config.routes.push({
+            path: `/${path}`,
+            handler: 'static',
+          });
+        }
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
