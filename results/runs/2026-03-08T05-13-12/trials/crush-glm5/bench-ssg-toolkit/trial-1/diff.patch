+import { marked } from 'marked';
+import { Plugin } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file) => {
+        let content = file.content;
+
+        // Process admonition containers before markdown conversion
+        // :::note, :::warning, :::tip -> <div class="admonition admonition-xxx">...</div>
+        content = content.replace(
+          /:::(note|warning|tip)\n([\s\S]*?)\n:::/g,
+          (_, type, innerContent) => {
+            return `<div class="admonition admonition-${type}">${innerContent.trim()}</div>`;
+          }
+        );
+
+        // Process footnotes
+        const footnoteRefs: Map<string, string> = new Map();
+        const footnoteRegex = /\[\^(\w+)\]:\s*(.*)/g;
+        let match;
+        while ((match = footnoteRegex.exec(content)) !== null) {
+          footnoteRefs.set(match[1], match[2]);
+        }
+
+        // Remove footnote definitions from content
+        content = content.replace(/\[\^(\w+)\]:\s*(.*)\n?/g, '');
+
+        // Replace footnote references with superscript links
+        content = content.replace(
+          /\[\^(\w+)\]/g,
+          (_, id) => `<sup><a href="#fn-${id}">${id}</a></sup>`
+        );
+
+        // Convert markdown to HTML
+        content = await marked(content);
+
+        // Add footnotes section if any footnotes exist
+        if (footnoteRefs.size > 0) {
+          let footnotesHtml = '<section class="footnotes">\n<ol>\n';
+          footnoteRefs.forEach((text, id) => {
+            footnotesHtml += `<li id="fn-${id}">${text}</li>\n`;
+          });
+          footnotesHtml += '</ol>\n</section>';
+          content = content + '\n' + footnotesHtml;
+        }
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
