@@ -0,0 +1,47 @@
+import { Plugin } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file, ctx) => {
+        let content = file.content;
+        const assets: string[] = [];
+
+        // Rewrite relative image URLs
+        content = content.replace(
+          /src="\.\/([^"]+)"/g,
+          (_, assetPath) => {
+            assets.push(assetPath);
+            return `src="/assets/${assetPath}"`;
+          }
+        );
+
+        // Rewrite relative link URLs
+        content = content.replace(
+          /href="\.\/([^"]+)"/g,
+          (_, assetPath) => {
+            assets.push(assetPath);
+            return `href="/assets/${assetPath}"`;
+          }
+        );
+
+        // Update asset manifest
+        if (assets.length > 0) {
+          const existingManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+          const existingAssets = existingManifest?.assets || [];
+          ctx.data.set('asset-manifest', {
+            assets: [...existingAssets, ...assets],
+          });
+        }
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
