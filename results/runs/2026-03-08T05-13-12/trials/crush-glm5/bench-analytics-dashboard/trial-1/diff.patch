+import { Router, Request, Response, NextFunction } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import jwt from 'jsonwebtoken';
+import crypto from 'crypto';
+import { getDb } from '../db';
+import { authMiddleware } from '../auth';
+import { ValidationError, UnauthorizedError, ConflictError } from '../errors';
+
+const router = Router();
+const JWT_SECRET = process.env.JWT_SECRET || 'default-secret-key';
+
+function hashPassword(password: string): string {
+  return crypto.createHash('sha256').update(password).digest('hex');
+}
+
+interface RegisterBody {
+  email: string;
+  password: string;
+  tenant_id: string;
+}
+
+interface LoginBody {
+  email: string;
+  password: string;
+}
+
+interface RoleBody {
+  role: string;
+}
+
+router.post('/', (req: Request, res: Response, next: NextFunction) => {
+  try {
+    const { email, password, tenant_id } = req.body as RegisterBody;
+
+    if (!email || !password || !tenant_id) {
+      throw new ValidationError('Email, password, and tenant_id are required');
+    }
+
+    const db = getDb();
+
+    const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);
+    if (existing) {
+      throw new ConflictError('Email already registered');
+    }
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+
+    db.prepare(
+      'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'
+    ).run(id, email, passwordHash, tenant_id, 'viewer');
+
+    res.status(201).json({
+      id,
+      email,
+      tenant_id,
+      role: 'viewer',
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/login', (req: Request, res: Response, next: NextFunction) => {
+  try {
+    const { email, password } = req.body as LoginBody;
+
+    if (!email || !password) {
+      throw new ValidationError('Email and password are required');
+    }
+
+    const db = getDb();
+    const user = db.prepare(
+      'SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?'
+    ).get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;
+
+    if (!user) {
+      throw new UnauthorizedError('Invalid credentials');
+    }
+
+    const passwordHash = hashPassword(password);
+    if (passwordHash !== user.password_hash) {
+      throw new UnauthorizedError('Invalid credentials');
+    }
+
+    const token = jwt.sign(
+      { sub: user.id, tid: user.tenant_id },
+      JWT_SECRET,
+      { expiresIn: '24h' }
+    );
+
+    res.json({
+      token,
+      user: {
+        id: user.id,
+        email: user.email,
+        tenant_id: user.tenant_id,
+        role: user.role,
+      },
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.get('/me', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+    const user = db.prepare(
+      'SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?'
+    ).get(req.user.id) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;
+
+    if (!user) {
+      throw new UnauthorizedError('User not found');
+    }
+
+    res.json(user);
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.patch('/:id/role', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+
+    const adminUser = db.prepare(
+      'SELECT role, tenant_id FROM users WHERE id = ?'
+    ).get(req.user.id) as { role: string; tenant_id: string } | undefined;
+
+    if (!adminUser || adminUser.role !== 'admin') {
+      throw new UnauthorizedError('Admin access required');
+    }
+
+    const targetId = req.params.id;
+    const { role } = req.body as RoleBody;
+
+    if (!role || !['admin', 'viewer', 'editor'].includes(role)) {
+      throw new ValidationError('Valid role is required (admin, viewer, editor)');
+    }
+
+    const targetUser = db.prepare(
+      'SELECT id, tenant_id FROM users WHERE id = ?'
+    ).get(targetId) as { id: string; tenant_id: string } | undefined;
+
+    if (!targetUser) {
+      throw new ValidationError('User not found');
+    }
+
+    if (targetUser.tenant_id !== adminUser.tenant_id) {
+      throw new UnauthorizedError('Cannot modify users from other tenants');
+    }
+
+    db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, targetId);
+
+    const updated = db.prepare(
+      'SELECT id, email, tenant_id, role FROM users WHERE id = ?'
+    ).get(targetId) as { id: string; email: string; tenant_id: string; role: string };
+
+    res.json(updated);
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
