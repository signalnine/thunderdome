+++ b/src/query/router.ts
@@ -0,0 +1,257 @@
+import { Router, Request, Response, NextFunction } from 'express';
+import { getDb } from '../db';
+import { authMiddleware } from '../auth';
+import { ValidationError, UnauthorizedError } from '../errors';
+
+const router = Router();
+
+interface CountQuery {
+  event_name: string;
+  start?: string;
+  end?: string;
+}
+
+interface TimeseriesQuery {
+  event_name: string;
+  bucket: 'hour' | 'day' | 'week' | 'month';
+  start?: string;
+  end?: string;
+}
+
+interface BreakdownQuery {
+  event_name: string;
+  property_key: string;
+  start?: string;
+  end?: string;
+}
+
+interface FunnelQuery {
+  steps: string[];
+  start?: string;
+  end?: string;
+}
+
+router.post('/count', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const { event_name, start, end } = req.body as CountQuery;
+
+    if (!event_name) {
+      throw new ValidationError('event_name is required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+
+    let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?';
+    const params: string[] = [tenantId, event_name];
+
+    if (start) {
+      sql += ' AND timestamp >= ?';
+      params.push(start);
+    }
+
+    if (end) {
+      sql += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/timeseries', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const { event_name, bucket, start, end } = req.body as TimeseriesQuery;
+
+    if (!event_name) {
+      throw new ValidationError('event_name is required');
+    }
+
+    if (!bucket) {
+      throw new ValidationError('bucket is required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+
+    let dateFormat: string;
+    switch (bucket) {
+      case 'hour':
+        dateFormat = '%Y-%m-%d %H:00:00';
+        break;
+      case 'day':
+        dateFormat = '%Y-%m-%d';
+        break;
+      case 'week':
+        dateFormat = '%Y-W%W';
+        break;
+      case 'month':
+        dateFormat = '%Y-%m';
+        break;
+      default:
+        dateFormat = '%Y-%m-%d';
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+    const params: string[] = [tenantId, event_name];
+
+    if (start) {
+      sql += ' AND timestamp >= ?';
+      params.push(start);
+    }
+
+    if (end) {
+      sql += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    sql += ' GROUP BY bucket ORDER BY bucket';
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({ data: results });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/breakdown', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const { event_name, property_key, start, end } = req.body as BreakdownQuery;
+
+    if (!event_name) {
+      throw new ValidationError('event_name is required');
+    }
+
+    if (!property_key) {
+      throw new ValidationError('property_key is required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+
+    let sql = 'SELECT properties, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?';
+    const params: string[] = [tenantId, event_name];
+
+    if (start) {
+      sql += ' AND timestamp >= ?';
+      params.push(start);
+    }
+
+    if (end) {
+      sql += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    sql += ' GROUP BY properties';
+
+    const results = db.prepare(sql).all(...params) as Array<{ properties: string; count: number }>;
+
+    const breakdown: Array<{ property_value: string; count: number }> = [];
+    const valueCounts = new Map<string, number>();
+
+    for (const row of results) {
+      try {
+        const props = JSON.parse(row.properties) as Record<string, unknown>;
+        const value = props[property_key];
+        const valueStr = value !== undefined ? String(value) : '(none)';
+
+        const current = valueCounts.get(valueStr) || 0;
+        valueCounts.set(valueStr, current + row.count);
+      } catch {
+        // Skip invalid JSON
+      }
+    }
+
+    for (const [property_value, count] of valueCounts) {
+      breakdown.push({ property_value, count });
+    }
+
+    breakdown.sort((a, b) => b.count - a.count);
+
+    res.json({ data: breakdown });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/funnel', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const { steps, start, end } = req.body as FunnelQuery;
+
+    if (!steps || !Array.isArray(steps) || steps.length === 0) {
+      throw new ValidationError('steps array is required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+
+    const funnelSteps: Array<{ step: string; count: number }> = [];
+
+    for (let i = 0; i < steps.length; i++) {
+      const stepName = steps[i];
+
+      let sql = `
+        SELECT COUNT(DISTINCT session_id) as count
+        FROM events
+        WHERE tenant_id = ? AND name = ? AND session_id IS NOT NULL
+      `;
+      const params: (string | null)[] = [tenantId, stepName];
+
+      if (i > 0) {
+        const prevSteps = steps.slice(0, i);
+        const placeholders = prevSteps.map(() => '?').join(', ');
+
+        sql = `
+          SELECT COUNT(DISTINCT e1.session_id) as count
+          FROM events e1
+          WHERE e1.tenant_id = ? AND e1.name = ? AND e1.session_id IS NOT NULL
+          AND e1.session_id IN (
+            SELECT DISTINCT session_id FROM events
+            WHERE tenant_id = ? AND name IN (${placeholders}) AND session_id IS NOT NULL
+          )
+        `;
+        params.push(tenantId, ...prevSteps);
+      }
+
+      if (start) {
+        sql += ' AND timestamp >= ?';
+        params.push(start);
+      }
+
+      if (end) {
+        sql += ' AND timestamp <= ?';
+        params.push(end);
+      }
+
+      const result = db.prepare(sql).get(...params) as { count: number };
+      funnelSteps.push({ step: stepName, count: result.count });
+    }
+
+    res.json({ steps: funnelSteps });
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
