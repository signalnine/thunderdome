+import { Router, Request, Response, NextFunction } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db';
+import { authMiddleware } from '../auth';
+import { ValidationError, UnauthorizedError } from '../errors';
+
+const router = Router();
+
+interface EventInput {
+  name: string;
+  properties?: Record<string, unknown>;
+  timestamp?: string;
+  user_id?: string;
+  session_id?: string;
+}
+
+interface BatchBody {
+  events: EventInput[];
+}
+
+router.post('/', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const { name, properties, timestamp, user_id, session_id } = req.body as EventInput;
+
+    if (!name) {
+      throw new ValidationError('Event name is required');
+    }
+
+    const db = getDb();
+    const id = uuidv4();
+    const tenantId = req.user.tenantId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = JSON.stringify(properties || {});
+
+    db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, user_id || null, session_id || null);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+      user_id: user_id || null,
+      session_id: session_id || null,
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/batch', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const { events } = req.body as BatchBody;
+
+    if (!events || !Array.isArray(events) || events.length === 0) {
+      throw new ValidationError('Events array is required and must not be empty');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+    const insertedEvents: Array<Record<string, unknown>> = [];
+
+    const insert = db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    );
+
+    const insertMany = db.transaction((eventList: EventInput[]) => {
+      for (const event of eventList) {
+        if (!event.name) {
+          throw new ValidationError('Event name is required');
+        }
+
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+        const eventProperties = JSON.stringify(event.properties || {});
+
+        insert.run(
+          id,
+          tenantId,
+          event.name,
+          eventProperties,
+          eventTimestamp,
+          event.user_id || null,
+          event.session_id || null
+        );
+
+        insertedEvents.push({
+          id,
+          tenant_id: tenantId,
+          name: event.name,
+          properties: event.properties || {},
+          timestamp: eventTimestamp,
+          user_id: event.user_id || null,
+          session_id: event.session_id || null,
+        });
+      }
+    });
+
+    insertMany(events);
+
+    res.status(201).json({
+      inserted: insertedEvents.length,
+      events: insertedEvents,
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
