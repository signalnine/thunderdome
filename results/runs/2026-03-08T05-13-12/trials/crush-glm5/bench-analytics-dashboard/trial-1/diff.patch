@@ -0,0 +1,314 @@
+import { Router, Request, Response, NextFunction } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db';
+import { authMiddleware } from '../auth';
+import { ValidationError, UnauthorizedError, NotFoundError } from '../errors';
+
+const router = Router();
+
+interface CreateDashboardBody {
+  name: string;
+  config?: Record<string, unknown>;
+}
+
+interface UpdateDashboardBody {
+  name?: string;
+  config?: Record<string, unknown>;
+}
+
+interface CreateWidgetBody {
+  type: 'counter' | 'timeseries' | 'breakdown' | 'funnel';
+  config?: Record<string, unknown>;
+  position_x?: number;
+  position_y?: number;
+  width?: number;
+  height?: number;
+}
+
+router.post('/', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const { name, config } = req.body as CreateDashboardBody;
+
+    if (!name) {
+      throw new ValidationError('Dashboard name is required');
+    }
+
+    const db = getDb();
+    const id = uuidv4();
+    const tenantId = req.user.tenantId;
+    const ownerId = req.user.id;
+    const configJson = JSON.stringify(config || {});
+
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, ownerId, configJson);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      owner_id: ownerId,
+      config: config || {},
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.get('/', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+
+    const dashboards = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?'
+    ).all(tenantId) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    }>;
+
+    res.json(dashboards.map((d) => ({
+      ...d,
+      config: JSON.parse(d.config),
+    })));
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.get('/:id', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+    const dashboardId = req.params.id;
+
+    const dashboard = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId) as {
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    } | undefined;
+
+    if (!dashboard) {
+      throw new NotFoundError('Dashboard not found');
+    }
+
+    const widgets = db.prepare(
+      'SELECT id, dashboard_id, type, config, position_x, position_y, width, height FROM widgets WHERE dashboard_id = ?'
+    ).all(dashboardId) as Array<{
+      id: string;
+      dashboard_id: string;
+      type: string;
+      config: string;
+      position_x: number;
+      position_y: number;
+      width: number;
+      height: number;
+    }>;
+
+    res.json({
+      ...dashboard,
+      config: JSON.parse(dashboard.config),
+      widgets: widgets.map((w) => ({
+        ...w,
+        config: JSON.parse(w.config),
+      })),
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.patch('/:id', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+    const dashboardId = req.params.id;
+    const { name, config } = req.body as UpdateDashboardBody;
+
+    const existing = db.prepare(
+      'SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId);
+
+    if (!existing) {
+      throw new NotFoundError('Dashboard not found');
+    }
+
+    const updates: string[] = [];
+    const params: (string | number)[] = [];
+
+    if (name !== undefined) {
+      updates.push('name = ?');
+      params.push(name);
+    }
+
+    if (config !== undefined) {
+      updates.push('config = ?');
+      params.push(JSON.stringify(config));
+    }
+
+    if (updates.length > 0) {
+      updates.push("updated_at = datetime('now')");
+      params.push(dashboardId);
+      params.push(tenantId);
+
+      db.prepare(
+        `UPDATE dashboards SET ${updates.join(', ')} WHERE id = ? AND tenant_id = ?`
+      ).run(...params);
+    }
+
+    const updated = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId) as {
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    };
+
+    res.json({
+      ...updated,
+      config: JSON.parse(updated.config),
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.delete('/:id', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+    const dashboardId = req.params.id;
+
+    const existing = db.prepare(
+      'SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId);
+
+    if (!existing) {
+      throw new NotFoundError('Dashboard not found');
+    }
+
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(dashboardId);
+
+    res.status(204).send();
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.post('/:id/widgets', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+    const dashboardId = req.params.id;
+    const { type, config, position_x, position_y, width, height } = req.body as CreateWidgetBody;
+
+    if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+      throw new ValidationError('Valid widget type is required (counter, timeseries, breakdown, funnel)');
+    }
+
+    const dashboard = db.prepare(
+      'SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId);
+
+    if (!dashboard) {
+      throw new NotFoundError('Dashboard not found');
+    }
+
+    const id = uuidv4();
+    const widgetConfig = JSON.stringify(config || {});
+
+    db.prepare(
+      'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+    ).run(
+      id,
+      dashboardId,
+      type,
+      widgetConfig,
+      position_x ?? 0,
+      position_y ?? 0,
+      width ?? 1,
+      height ?? 1
+    );
+
+    res.status(201).json({
+      id,
+      dashboard_id: dashboardId,
+      type,
+      config: config || {},
+      position_x: position_x ?? 0,
+      position_y: position_y ?? 0,
+      width: width ?? 1,
+      height: height ?? 1,
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.delete('/:id/widgets/:widgetId', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+    const dashboardId = req.params.id;
+    const widgetId = req.params.widgetId;
+
+    const dashboard = db.prepare(
+      'SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId);
+
+    if (!dashboard) {
+      throw new NotFoundError('Dashboard not found');
+    }
+
+    db.prepare('DELETE FROM widgets WHERE id = ? AND dashboard_id = ?').run(widgetId, dashboardId);
+
+    res.status(204).send();
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
