@@ -0,0 +1,123 @@
+import { Router, Request, Response, NextFunction } from 'express';
+import { getDb } from '../db';
+import { authMiddleware } from '../auth';
+import { ValidationError, UnauthorizedError, NotFoundError } from '../errors';
+
+const router = Router();
+
+router.get('/events', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const format = req.query.format as string;
+
+    if (!format || !['json', 'csv'].includes(format)) {
+      throw new ValidationError('format must be either "json" or "csv"');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+
+    const events = db.prepare(
+      'SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ? ORDER BY timestamp DESC'
+    ).all(tenantId) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string | null;
+      session_id: string | null;
+    }>;
+
+    const parsedEvents = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    if (format === 'json') {
+      res.json(parsedEvents);
+      return;
+    }
+
+    // CSV format
+    const headers = ['id', 'tenant_id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+    const csvRows = [headers.join(',')];
+
+    for (const event of parsedEvents) {
+      const row = [
+        event.id,
+        event.tenant_id,
+        event.name,
+        `"${JSON.stringify(event.properties).replace(/"/g, '""')}"`,
+        event.timestamp,
+        event.user_id || '',
+        event.session_id || '',
+      ];
+      csvRows.push(row.join(','));
+    }
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.send(csvRows.join('\n'));
+  } catch (err) {
+    next(err);
+  }
+});
+
+router.get('/dashboard/:id', authMiddleware, (req: Request, res: Response, next: NextFunction) => {
+  try {
+    if (!req.user) {
+      throw new UnauthorizedError('Authentication required');
+    }
+
+    const db = getDb();
+    const tenantId = req.user.tenantId;
+    const dashboardId = req.params.id;
+
+    const dashboard = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?'
+    ).get(dashboardId, tenantId) as {
+      id: string;
+      tenant_id: string;
+      name: string;
+      owner_id: string;
+      config: string;
+      created_at: string;
+      updated_at: string;
+    } | undefined;
+
+    if (!dashboard) {
+      throw new NotFoundError('Dashboard not found');
+    }
+
+    const widgets = db.prepare(
+      'SELECT id, dashboard_id, type, config, position_x, position_y, width, height FROM widgets WHERE dashboard_id = ?'
+    ).all(dashboardId) as Array<{
+      id: string;
+      dashboard_id: string;
+      type: string;
+      config: string;
+      position_x: number;
+      position_y: number;
+      width: number;
+      height: number;
+    }>;
+
+    res.json({
+      dashboard: {
+        ...dashboard,
+        config: JSON.parse(dashboard.config),
+      },
+      widgets: widgets.map((w) => ({
+        ...w,
+        config: JSON.parse(w.config),
+      })),
+    });
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;
