-function resolveLedger(mod: Record<string, any>): (new () => LedgerLike) | null {
-  // Strategy 1: Named export 'Ledger'
-  const names = ['Ledger', 'FinancialLedger', 'AccountingLedger', 'Journal'];
-  for (const name of names) {
-    if (typeof mod[name] === 'function') {
