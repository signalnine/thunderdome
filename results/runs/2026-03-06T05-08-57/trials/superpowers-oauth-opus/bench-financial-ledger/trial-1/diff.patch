+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ESkc7e6DeN1QWZ86xLQ892","type":"tool_result","content":"The file /workspace/src/ledger.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"1979cdeb-e24b-4330-acd7-a7ba6b93fa75","uuid":"9639f9c9-db5f-4336-b725-7a48aaada204","tool_use_result":{"filePath":"/workspace/src/ledger.ts","oldString":"      throw new Error(`Cannot mix currencies in a single entry: ${[...currencies].join(', ')}`);","newString":"      throw new Error(`Cannot mix currency in a single entry: ${[...currencies].join(', ')}`);","originalFile":"/**\n * Double-entry accounting ledger\n */\n\nexport type AccountType = 'asset' | 'liability' | 'equity' | 'revenue' | 'expense';\n\nexport interface Account {\n  name: string;\n  type: AccountType;\n  currency: string;\n}\n\nexport interface LineItem {\n  account: string;\n  amount: number;\n}\n\nexport interface JournalEntry {\n  id: number;\n  description: string;\n  debits: LineItem[];\n  credits: LineItem[];\n  date: Date;\n}\n\nexport interface BalanceEntry {\n  account: string;\n  type: AccountType;\n  debit: number;\n  credit: number;\n}\n\nexport interface StatementLine {\n  date: Date;\n  description: string;\n  debit: number;\n  credit: number;\n  balance: number;\n}\n\nexport interface ProfitAndLoss {\n  revenue: number;\n  expenses: number;\n  netIncome: number;\n}\n\nexport class Ledger {\n  private accounts: Map<string, Account> = new Map();\n  private entries: JournalEntry[] = [];\n  private nextId = 1;\n\n  createAccount(name: string, type: AccountType, currency: string = 'USD'): Account {\n    if (this.accounts.has(name)) {\n      throw new Error(`Account already exists: ${name}`);\n    }\n    const account: Account = { name, type, currency };\n    this.accounts.set(name, account);\n    return account;\n  }\n\n  postEntry(\n    description: string,\n    debits: LineItem[],\n    credits: LineItem[],\n    date?: Date\n  ): JournalEntry {\n    for (const d of debits) {\n      if (!this.accounts.has(d.account)) {\n        throw new Error(`Account not found: ${d.account}`);\n      }\n    }\n    for (const c of credits) {\n      if (!this.accounts.has(c.account)) {\n        throw new Error(`Account not found: ${c.account}`);\n      }\n    }\n\n    const allAccounts = [...debits, ...credits].map(li => this.accounts.get(li.account)!);\n    const currencies = new Set(allAccounts.map(a => a.currency));\n    if (currencies.size > 1) {\n      throw new Error(`Cannot mix currencies in a single entry: ${[...currencies].join(', ')}`);\n    }\n\n    const totalDebits = debits.reduce((sum, d) => sum + d.amount, 0);\n    const totalCredits = credits.reduce((sum, c) => sum + c.amount, 0);\n    if (totalDebits !== totalCredits) {\n      throw new Error(`Debits (${totalDebits}) must equal credits (${totalCredits})`);\n    }\n\n    for (const d of debits) {\n      if (d.amount <= 0) throw new Error('Amounts must be positive');\n    }\n    for (const c of credits) {\n      if (c.amount <= 0) throw new Error('Amounts must be positive');\n    }\n\n    const entry: JournalEntry = {\n      id: this.nextId++,\n      description,\n      debits: [...debits],\n      credits: [...credits],\n      date: date ?? new Date(),\n    };\n    this.entries.push(entry);\n    return entry;\n  }\n\n  getBalance(accountName: string): number {\n    const account = this.accounts.get(accountName);\n    if (!account) throw new Error(`Account not found: ${accountName}`);\n\n    let balance = 0;\n    for (const entry of this.entries) {\n      for (const d of entry.debits) {\n        if (d.account === accountName) balance += d.amount;\n      }\n      for (const c of entry.credits) {\n        if (c.account === accountName) balance -= c.amount;\n      }\n    }\n\n    // Liability, equity, and revenue accounts have credit-normal balances\n    if (account.type === 'liability' || account.type === 'equity' || account.type === 'revenue') {\n      return -balance;\n    }\n    return balance;\n  }\n\n  getTrialBalance(): BalanceEntry[] {\n    const result: BalanceEntry[] = [];\n\n    for (const [name, account] of this.accounts) {\n      let totalDebits = 0;\n      // eslint-disable-next-line prefer-const\n      let totalCredits = 0;\n\n      for (const entry of this.entries) {\n        for (const d of entry.debits) {\n          if (d.account === name) totalDebits += d.amount;\n        }\n        for (const c of entry.credits) {\n          if (c.account === name) totalCredits += c.amount;\n        }\n      }\n\n      result.push({\n        account: name,\n        type: account.type,\n        debit: totalDebits,\n        credit: totalCredits,\n      });\n    }\n\n    return result;\n  }\n\n  getStatement(\n    accountName: string,\n    startDate?: Date,\n    endDate?: Date\n  ): StatementLine[] {\n    const account = this.accounts.get(accountName);\n    if (!account) throw new Error(`Account not found: ${accountName}`);\n\n    const lines: StatementLine[] = [];\n    let runningBalance = 0;\n\n    const sorted = [...this.entries].sort(\n      (a, b) => a.date.getTime() - b.date.getTime()\n    );\n\n    for (const entry of sorted) {\n      if (startDate && entry.date.getTime() < startDate.getTime()) continue;\n      if (endDate && entry.date.getTime() > endDate.getTime()) continue;\n\n      let debit = 0;\n      let credit = 0;\n\n      for (const d of entry.debits) {\n        if (d.account === accountName) debit += d.amount;\n      }\n      for (const c of entry.credits) {\n        if (c.account === accountName) credit += c.amount;\n      }\n\n      if (debit === 0 && credit === 0) continue;\n\n      runningBalance += debit - credit;\n\n      lines.push({\n        date: entry.date,\n        description: entry.description,\n        debit,\n        credit,\n        balance: runningBalance,\n      });\n    }\n\n    return lines;\n  }\n\n  splitEntry(\n    description: string,\n    fromAccount: string,\n    toAccounts: LineItem[],\n    totalAmount: number,\n    date?: Date\n  ): JournalEntry {\n    if (!this.accounts.has(fromAccount)) {\n      throw new Error(`Account not found: ${fromAccount}`);\n    }\n\n    const debits: LineItem[] = [{ account: fromAccount, amount: totalAmount }];\n    const toTotal = toAccounts.reduce((sum, ta) => sum + ta.amount, 0);\n    if (toTotal !== totalAmount) {\n      throw new Error(`Split amounts (${toTotal}) must equal total (${totalAmount})`);\n    }\n\n    const credits: LineItem[] = toAccounts.map(ta => ({\n      account: ta.account,\n      amount: ta.amount,\n    }));\n\n    return this.postEntry(description, debits, credits, date);\n  }\n\n  getAccountsByType(type: AccountType): Account[] {\n    const result: Account[] = [];\n    for (const account of this.accounts.values()) {\n      if (account.type === type) result.push({ ...account });\n    }\n    return result;\n  }\n\n  getProfitAndLoss(startDate?: Date, endDate?: Date): ProfitAndLoss {\n    let revenue = 0;\n    let expenses = 0;\n\n    for (const entry of this.entries) {\n      if (startDate && entry.date < startDate) continue;\n      if (endDate && entry.date > endDate) continue;\n\n      for (const c of entry.credits) {\n        const acct = this.accounts.get(c.account);\n        if (acct?.type === 'revenue') revenue += c.amount;\n      }\n\n      for (const d of entry.debits) {\n        const acct = this.accounts.get(d.account);\n        if (acct?.type === 'expense') expenses += d.amount;\n      }\n    }\n\n    return {\n      revenue,\n      expenses,\n      netIncome: revenue - expenses,\n    };\n  }\n}\n","structuredPatch":[{"oldStart":78,"oldLines":7,"newStart":78,"newLines":7,"lines":["     const allAccounts = [...debits, ...credits].map(li => this.accounts.get(li.account)!);","     const currencies = new Set(allAccounts.map(a => a.currency));","     if (currencies.size > 1) {","-      throw new Error(`Cannot mix currencies in a single entry: ${[...currencies].join(', ')}`);","+      throw new Error(`Cannot mix currency in a single entry: ${[...currencies].join(', ')}`);","     }"," ","     const totalDebits = debits.reduce((sum, d) => sum + d.amount, 0);"]}],"userModified":false,"replaceAll":false}}
