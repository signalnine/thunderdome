+// Toggle Puzzle: meet-in-the-middle
+function solveToggle(machine: {
+  target: boolean[];
+  buttons: number[][];
+}): number[] | null {
+  const N = machine.target.length;
+  const M = machine.buttons.length;
+  
+  // If there are no buttons, check if target is all false
+  if (M === 0) {
+    for (let i = 0; i < N; i++) {
+      if (machine.target[i]) {
+        return null;
+      }
+    }
+    return [];
+  }
+  
+  // Precompute button effects as BigInt
+  const buttonEffects: bigint[] = [];
+  for (let i = 0; i < M; i++) {
+    let effect = 0n;
+    for (const light of machine.buttons[i]) {
+      effect |= (1n << BigInt(light));
+    }
+    buttonEffects[i] = effect;
+  }
+  
+  // Compute target effect
+  let targetEffect = 0n;
+  for (let light = 0; light < N; light++) {
+    if (machine.target[light]) {
+      targetEffect |= (1n << BigInt(light));
+    }
+  }
+  
+  // Split buttons into two halves
+  const leftSize = Math.floor(M / 2);
+  const rightSize = M - leftSize;
+  
+  // Map for left half: state -> { count, mask }
+  const leftMap = new Map<bigint, { count: number; mask: number }>();
+  
+  // Iterate over all subsets of left half
+  for (let leftMask = 0; leftMask < (1 << leftSize); leftMask++) {
+    let state = 0n;
+    let count = 0;
+    for (let i = 0; i < leftSize; i++) {
+      if (leftMask & (1 << i)) {
+        state ^= buttonEffects[i];
+        count++;
+      }
+    }
+    
+    const existing = leftMap.get(state);
+    if (!existing) {
+      leftMap.set(state, { count, mask: leftMask });
+    } else {
+      if (count < existing.count) {
+        leftMap.set(state, { count, mask: leftMask });
+      } else if (count === existing.count) {
+        // Compare masks lexicographically: which one has smaller indices?
+        let isBetter = false;
+        for (let bit = 0; bit < leftSize; bit++) {
+          const bitA = (leftMask >> bit) & 1;
+          const bitB = (existing.mask >> bit) & 1;
+          if (bitA !== bitB) {
+            if (bitA === 1) {
+              isBetter = true;
+            }
+            break;
+          }
+        }
+        if (isBetter) {
+          leftMap.set(state, { count, mask: leftMask });
+        }
+      }
+    }
+  }
+  
+  // Iterate over right half to find best solution
+  let bestTotalCount = Infinity;
+  let bestLeftMask = 0;
+  let bestRightMask = 0;
+  let found = false;
+  
+  for (let rightMask = 0; rightMask < (1 << rightSize); rightMask++) {
+    let state = 0n;
+    let count = 0;
+    for (let i = 0; i < rightSize; i++) {
+      if (rightMask & (1 << i)) {
+        state ^= buttonEffects[leftSize + i];
+        count++;
+      }
+    }
+    
+    const needed = targetEffect ^ state;
+    const leftInfo = leftMap.get(needed);
+    if (leftInfo) {
+      const totalCount = leftInfo.count + count;
+      let isBetter = false;
+      if (totalCount < bestTotalCount) {
+        isBetter = true;
+      } else if (totalCount === bestTotalCount) {
+        // Compare lexicographically: first left masks, then right masks
+        // Compare left masks
+        let leftCmp = 0;
+        for (let bit = 0; bit < leftSize; bit++) {
+          const bitA = (leftInfo.mask >> bit) & 1;
+          const bitB = (bestLeftMask >> bit) & 1;
+          if (bitA !== bitB) {
+            if (bitA === 1) {
+              leftCmp = -1; // leftInfo.mask is lexicographically smaller
+            } else {
+              leftCmp = 1;
+            }
+            break;
+          }
+        }
+        if (leftCmp === 0) {
+          // Left masks equal, compare right masks
+          for (let bit = 0; bit < rightSize; bit++) {
+            const bitA = (rightMask >> bit) & 1;
+            const bitB = (bestRightMask >> bit) & 1;
+            if (bitA !== bitB) {
+              if (bitA === 1) {
+                isBetter = true;
+              } else {
+                isBetter = false;
+              }
+              break;
+            }
+          }
+        } else {
+          isBetter = (leftCmp === -1);
+        }
+      }
+      
+      if (isBetter) {
+        bestTotalCount = totalCount;
+        bestLeftMask = leftInfo.mask;
+        bestRightMask = rightMask;
+        found = true;
+      }
+    }
+  }
+  
+  if (!found) {
+    return null;
+  }
+  
+  // Build result array
+  const result: number[] = [];
+  for (let i = 0; i < leftSize; i++) {
+    if (bestLeftMask & (1 << i)) {
+      result.push(i);
+    }
+  }
+  for (let i = 0; i < rightSize; i++) {
+    if (bestRightMask & (1 << i)) {
+      result.push(leftSize + i);
+    }
+  }
+  
+  return result;
+}
+
+// Counter Puzzle: Gaussian elimination over GF(modulus) with free variable iteration
+function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const N = lights.length;
+  const M = buttons.length;
+  
+  // Build augmented matrix [A | b] where A is N x M, b is N x 1
+  const aug: number[][] = [];
+  for (let row = 0; row < N; row++) {
+    aug[row] = new Array(M + 1);
+    for (let col = 0; col < M; col++) {
+      aug[row][col] = 0;
+    }
+    aug[row][M] = lights[row] % modulus;
+  }
+  
+  // Fill A: aug[row][col] = number of times button col affects counter row (0 or 1, but could be more if button affects same counter multiple times? 
+  // According to problem, buttons[i] = array of indices of counters affected. Each appearance increments by 1.
+  // So if a button affects a counter multiple times, it would be multiple increments. But the array might have duplicates? 
+  // The problem says: buttons[i] = array of indices of counters affected. It doesn't say distinct, so we must count duplicates.
+  for (let col = 0; col < M; col++) {
+    for (const counter of buttons[col]) {
+      if (counter >= 0 && counter < N) {
+        aug[counter][col] = (aug[counter][col] + 1) % modulus;
+      }
+    }
+  }
+  
+  // Gaussian elimination over GF(modulus)
+  const pivotCols: number[] = []; // pivot column for each row
+  let row = 0;
+  let col = 0;
+  
+  // Make a copy of aug to work on
+  const mat = aug.map(r => [...r]);
+  
+  while (row < N && col < M) {
+    // Find pivot in column col starting at row
+    let pivotRow = -1;
+    for (let r = row; r < N; r++) {
+      if (mat[r][col] !== 0) {
+        pivotRow = r;
+        break;
+      }
+    }
+    
+    if (pivotRow === -1) {
+      // No pivot in this column, move to next
+      col++;
+      continue;
+    }
+    
+    // Swap pivotRow with current row
+    [mat[row], mat[pivotRow]] = [mat[pivotRow], mat[row]];
+    
+    // Normalize pivot row: make the pivot element 1
+    const pivotVal = mat[row][col];
+    const inv = modInverse(pivotVal, modulus);
+    for (let c = col; c <= M; c++) {
+      mat[row][c] = (mat[row][c] * inv) % modulus;
+    }
+    
+    // Eliminate current column in all other rows
+    for (let r = 0; r < N; r++) {
+      if (r !== row && mat[r][col] !== 0) {
+        const factor = mat[r][col];
+        for (let c = col; c <= M; c++) {
+          mat[r][c] = (mat[r][c] - factor * mat[row][c]) % modulus;
+          // Ensure non-negative
+          if (mat[r][c] < 0) {
+            mat[r][c] += modulus;
+          }
+        }
+      }
+    }
+    
+    pivotCols.push(col);
+    row++;
+    col++;
+  }
+  
+  // Check for inconsistency: any row [0 ... 0 | b] with b != 0
+  for (let r = row; r < N; r++) {
+    let allZero = true;
+    for (let c = 0; c < M; c++) {
+      if (mat[r][c] !== 0) {
+        allZero = false;
+        break;
+      }
+    }
+    if (allZero && mat[r][M] % modulus !== 0) {
+      return null; // inconsistent
+    }
+  }
+  
+  // Now, we have reduced row echelon form (since we eliminated above and below)
+  // Extract the solution: basic variables in terms of free variables
+  // We'll express the solution as: x = particular + sum (free_var * basis_vector)
+  const particular: number[] = new Array(M).fill(0);
+  const freeVars: number[] = []; // indices of free variables
+  const basis: number[][] = []; // each basis vector corresponds to a free variable
+  
+  // Mark which columns are pivot columns
+  const isPivotCol = new Array(M).fill(false);
+  for (const pc of pivotCols) {
+    isPivotCol[pc] = true;
+  }
+  
+  // For each column, if it's a pivot column, the basic variable is determined by the row where it's the pivot
+  // Otherwise, it's free.
+  for (let col = 0; col < M; col++) {
+    if (isPivotCol[col]) {
+      // This column is a pivot column, find its row
+      // We know that in reduced row echelon form, the pivot is 1 and is the only non-zero in its column in the pivot row?
+      // Actually, we eliminated above and below, so yes.
+      const rowIdx = pivotCols.indexOf(col); // this gives the row where this column is pivot
+      if (rowIdx === -1) {
+        // Should not happen
+        continue;
+      }
+      // x[col] = mat[rowIdx][M] - sum (mat[rowIdx][free_col] * x[free_col]) for free columns
+      // But we will set free variables to 0 for particular solution
+      particular[col] = mat[rowIdx][M];
+    } else {
+      // Free variable
+      freeVars.push(col);
+      // Build basis vector for this free variable: set this free variable to 1, others to 0, and compute basic variables
+      // For homogeneous solution: x_homogeneous satisfies [A | 0] * x_homogeneous = 0
+      const basisVec: number[] = new Array(M).fill(0);
+      basisVec[col] = 1; // set this free variable to 1
+      // Now, for each pivot row, compute the basic variable in the homogeneous solution
+      for (let r = 0; r < pivotCols.length; r++) {
+        const pc = pivotCols[r];
+        // In reduced row echelon form: x_pc + sum (mat[r][free_col] * x_free_col) = 0 (homogeneous)
+        // So x_pc = - sum (mat[r][free_col] * x_free_col)
+        // With current free variable = 1 and others = 0: x_pc = - mat[r][col]
+        basisVec[pc] = (-mat[r][col]) % modulus;
+        // Ensure non-negative
+        if (basisVec[pc] < 0) {
+          basisVec[pc] += modulus;
+        }
+      }
+      basis.push(basisVec);
+    }
+  }
+  
+  // Now, we have:
+  //   x = particular + sum_{i=0}^{k-1} (c_i * basis[i])  where k = freeVars.length, and c_i in [0, modulus-1]
+  // We want to minimize sum(x) and then lexicographically smallest x.
+  
+  const k = freeVars.length;
+  
+  // If too many free variables, we cannot iterate over all possibilities.
+  // We'll set a threshold: if modulus^k > 10^6, we use local search; otherwise brute force.
+  const maxIterations = Math.pow(modulus, k);
+  if (maxIterations > 1000000) {
+    // Use local search for high nullity
+    return localSearch(particular, basis, freeVars, modulus);
+  }
+  
+  // Iterate over all assignments to free variables
+  let bestSum = Infinity;
+  let bestSolution: number[] | null = null;
+  
+  // We'll generate all combinations using recursion or nested loops? Since k is variable, we use recursion.
+  const freeAssignments: number[] = new Array(k).fill(0);
+  
+  function iterateFree(index: number) {
+    if (index === k) {
+      // Compute solution: particular + sum (freeAssignments[i] * basis[i])
+      const solution: number[] = new Array(M).fill(0);
+      for (let i = 0; i < M; i++) {
+        solution[i] = particular[i];
+      }
+      for (let i = 0; i < k; i++) {
+        const coeff = freeAssignments[i];
+        const basisVec = basis[i];
+        for (let j = 0; j < M; j++) {
+          solution[j] = (solution[j] + coeff * basisVec[j]) % modulus;
+        }
+      }
+      // Ensure non-negative
+      for (let j = 0; j < M; j++) {
+        if (solution[j] < 0) {
+          solution[j] += modulus;
+        }
+      }
+      
+      // Compute total presses
+      let total = 0;
+      for (const v of solution) {
+        total += v;
+      }
+      
+      // Compare with best
+      if (total < bestSum) {
+        bestSum = total;
+        bestSolution = solution.slice();
+      } else if (total === bestSum) {
+        // Lexicographically compare
+        if (bestSolution === null) {
+          bestSolution = solution.slice();
+        } else {
+          let isBetter = false;
+          for (let i = 0; i < M; i++) {
+            if (solution[i] < bestSolution[i]) {
+              isBetter = true;
+              break;
+            } else if (solution[i] > bestSolution[i]) {
+              break;
+            }
+          }
+          if (isBetter) {
+            bestSolution = solution.slice();
+          }
+        }
+      }
+      return;
+    }
+    
+    // Try all values for freeAssignments[index] from 0 to modulus-1
+    for (let v = 0; v < modulus; v++) {
+      freeAssignments[index] = v;
+      iterateFree(index + 1);
+    }
+  }
+  
+  iterateFree(0);
+  
+  return bestSolution;
+}
+
+// Helper function: modular inverse for prime modulus
+function modInverse(a: number, modulus: number): number {
+  // Using Fermat's little theorem: a^(modulus-2) mod modulus
+  // Since modulus is prime and a is not divisible by modulus (we checked pivot != 0)
+  let exp = modulus - 2;
+  let result = 1;
+  let base = a % modulus;
+  while (exp > 0) {
+    if (exp & 1) {
+      result = (result * base) % modulus;
+    }
+    base = (base * base) % modulus;
+    exp >>= 1;
+  }
+  return result;
+}
+
+// Local search for solution when nullity is high
+function localSearch(particular: number[], basis: number[][], freeVars: number[], modulus: number): number[] | null {
+  const M = particular.length;
+  const k = freeVars.length;
+  
+  // Start with all free variables = 0
+  let bestSolution = [...particular];
+  let bestSum = bestSolution.reduce((sum, v) => sum + v, 0);
+  
+  // Use hill climbing with random restarts
+  const maxIterations = 10000;
+  const maxRestarts = 10;
+  
+  for (let restart = 0; restart < maxRestarts; restart++) {
+    // Initialize free variables randomly
+    const freeAssignments: number[] = [];
+    for (let i = 0; i < k; i++) {
+      freeAssignments.push(Math.floor(Math.random() * modulus));
+    }
+    
+    // Compute current solution
+    let currentSolution: number[] = new Array(M).fill(0);
+    for (let i = 0; i < M; i++) {
+      currentSolution[i] = particular[i];
+    }
+    for (let i = 0; i < k; i++) {
+      const coeff = freeAssignments[i];
+      const basisVec = basis[i];
+      for (let j = 0; j < M; j++) {
+        currentSolution[j] = (currentSolution[j] + coeff * basisVec[j]) % modulus;
+      }
+    }
+    // Ensure non-negative
+    for (let j = 0; j < M; j++) {
+      if (currentSolution[j] < 0) {
+        currentSolution[j] += modulus;
+      }
+    }
+    
+    let currentSum = currentSolution.reduce((sum, v) => sum + v, 0);
+    
+    // Hill climbing
+    let improved = true;
+    let iterations = 0;
+    while (improved && iterations < maxIterations) {
+      improved = false;
+      
+      // Try changing each free variable
+      for (let i = 0; i < k; i++) {
+        const oldVal = freeAssignments[i];
+        // Try all possible values for this free variable
+        for (let v = 0; v < modulus; v++) {
+          if (v === oldVal) continue;
+          
+          freeAssignments[i] = v;
+          
+          // Compute new solution
+          const newSolution: number[] = new Array(M).fill(0);
+          for (let j = 0; j < M; j++) {
+            newSolution[j] = particular[j];
+          }
+          for (let j = 0; j < k; j++) {
+            const coeff = freeAssignments[j];
+            const basisVec = basis[j];
+            for (let l = 0; l < M; l++) {
+              newSolution[l] = (newSolution[l] + coeff * basisVec[l]) % modulus;
+            }
+          }
+          // Ensure non-negative
+          for (let j = 0; j < M; j++) {
+            if (newSolution[j] < 0) {
+              newSolution[j] += modulus;
+            }
+          }
+          
+          const newSum = newSolution.reduce((sum, val) => sum + val, 0);
+          
+          // Check if better (lower sum, or same sum but lexicographically smaller)
+          if (newSum < currentSum || 
+              (newSum === currentSum && 
+               lexicographicallySmaller(newSolution, currentSolution))) {
+            currentSolution = newSolution;
+            currentSum = newSum;
+            improved = true;
+          } else {
+            // Revert change
+            freeAssignments[i] = oldVal;
+          }
+        }
+        
+        if (improved) break; // Start over from first variable
+      }
+      
+      iterations++;
+    }
+    
+    // Update best solution
+    if (currentSum < bestSum || 
+        (currentSum === bestSum && lexicographicallySmaller(currentSolution, bestSolution))) {
+      bestSolution = currentSolution;
+      bestSum = currentSum;
+    }
+  }
+  
+  return bestSolution;
+}
+
+// Helper function to compare two arrays lexicographically
+function lexicographicallySmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false; // equal
+}
