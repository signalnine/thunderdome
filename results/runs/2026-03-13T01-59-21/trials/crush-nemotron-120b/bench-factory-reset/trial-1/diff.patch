+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('should return null for the example in the description', () => {
+    const machine = {
+      target: [true, true, false, true],
+      buttons: [
+        [0, 1],
+        [1, 2, 3],
+        [0, 3]
+      ]
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should return [0] for a simple solvable case', () => {
+    const machine = {
+      target: [true, false],
+      buttons: [
+        [0],
+        [1]
+      ]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should return the lexicographically smallest when multiple solutions with same press count', () => {
+    // 3 lights, target [true, true, false]
+    // Button 0 toggles [0,1]
+    // Button 1 toggles [1,2]
+    // Button 2 toggles [0,2]
+    // We want: light0: b0 XOR b2 = 1, light1: b0 XOR b1 = 1, light2: b1 XOR b2 = 0
+    // Solutions: 
+    //   b0=0, b1=1, b2=1 -> [1,2] (presses:2)
+    //   b0=1, b1=0, b2=0 -> [0] (presses:1) -> this is better (fewer presses)
+    // So expected [0]
+    const machine = {
+      target: [true, true, false],
+      buttons: [
+        [0,1],
+        [1,2],
+        [0,2]
+      ]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle case where multiple solutions have same press count and choose lexicographically smallest', () => {
+    // 2 lights, target [true, true]
+    // Button 0 toggles [0]
+    // Button 1 toggles [1]
+    // Button 2 toggles [0,1]
+    // Solutions: 
+    //   [0,1] (presses:2) -> [true, true]
+    //   [2] (presses:1) -> [true, true] -> this is better (fewer presses)
+    // So expected [2]
+    const machine = {
+      target: [true, true],
+      buttons: [
+        [0],
+        [1],
+        [0,1]
+      ]
+    };
+    expect(solveToggle(machine)).toEqual([2]);
+  });
+
+  it('should handle empty buttons', () => {
+    const machine = {
+      target: [false, false],
+      buttons: []
+    };
+    expect(solveToggle(machine)).toEqual([]);
+
+    const machine2 = {
+      target: [true, false],
+      buttons: []
+    };
+    expect(solveToggle(machine2)).toBeNull();
+  });
+
+  it('should handle larger case within constraints', () => {
+    // 40 lights, 40 buttons, each button toggles one unique light (so it's diagonal)
+    // Target: all true
+    // Solution: press all buttons -> [0,1,2,...,39]
+    const N = 40;
+    const target = Array(N).fill(true);
+    const buttons = Array.from({ length: N }, (_, i) => [i]);
+    const machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).toEqual(Array.from({ length: N }, (_, i) => i));
+  });
+
+  it('should return null when no solution for larger case', () => {
+    // 2 lights, target [true, true]
+    // Button 0 toggles [0,1]
+    // Button 1 toggles [0,1] (same as button0)
+    // Then the effect of button0 and button1 are the same. We have:
+    //   light0: b0 XOR b1 = 1
+    //   light1: b0 XOR b1 = 1
+    //   So we need b0 XOR b1 = 1.
+    //   Solutions: (0,1) and (1,0) -> both have 2 presses? Actually, each button press counts as 1.
+    //   Wait: pressing button0 once and button1 once: total presses=2.
+    //   But we can also press just one button? 
+    //   If we press button0: [1,1] -> matches target? Yes, because button0 toggles both -> [true, true].
+    //   So there is a solution with 1 press: [0] or [1]. 
+    //   Let me recalc: 
+    //     Initially: [0,0]
+    //     Press button0: toggles [0,1] -> [1,1] -> matches.
+    //   So the example is solvable. Let's make an unsolvable one.
+    //   Instead, set target [true, false] and buttons as above.
+    //   Then: 
+    //     light0: b0 XOR b1 = 1
+    //     light1: b0 XOR b1 = 0 -> contradiction.
+    const machine = {
+      target: [true, false],
+      buttons: [
+        [0,1],
+        [0,1]
+      ]
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+});
+
+describe('solveCounter', () => {
+  it('should solve a simple case', () => {
+    const lights = [1, 0];
+    const buttons = [[0], [1]];
+    const modulus = 2;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([1, 0]);
+  });
+
+  it('should return null when no solution', () => {
+    const lights = [1];
+    const buttons = [[]];
+    const modulus = 2;
+    expect(solveCounter(lights, buttons, modulus)).toBeNull();
+  });
+
+  it('should handle modulus prime', () => {
+    const lights = [2];
+    const buttons = [[0]];
+    const modulus = 3;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([2]);
+  });
+
+  it('should handle case where button affects same counter multiple times (duplicate in array)', () => {
+    // 1 counter, modulus 3
+    // target: [2]
+    // button0: [0,0] (affects counter0 twice -> increment by 2)
+    // Then we need: 2 * x0 ≡ 2 (mod 3) -> x0 ≡ 1 (mod 3) because 2*1=2 mod3.
+    // So pressing button0 once gives 2 increments -> 2 mod3 -> [2].
+    const lights = [2];
+    const buttons = [[0,0]]; // duplicate
+    const modulus = 3;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([1]);
+  });
+
+  it('should handle multiple counters and buttons with modulus 5', () => {
+    // 2 counters, modulus 5
+    // target: [3, 4]
+    // button0: [0,1] (affects both counters)
+    // button1: [0] (affects counter0)
+    // We have:
+    //   counter0: x0 + x1 = 3 (mod5)
+    //   counter1: x0 = 4 (mod5)
+    //   From second: x0 = 4
+    //   Then first: 4 + x1 = 3 -> x1 = 4 (mod5) because 4+4=8≡3 mod5.
+    //   So solution: [4,4]
+    const lights = [3, 4];
+    const buttons = [
+      [0,1],
+      [0]
+    ];
+    const modulus = 5;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([4, 4]);
+  });
+
+  it('should return null when inconsistent system', () => {
+    // 2 counters, modulus 3
+    // target: [1, 2]
+    // button0: [0] (affects counter0)
+    // button1: [0] (affects counter0) -> same as button0
+    // Then we have:
+    //   counter0: x0 + x1 = 1 (mod3)
+    //   counter1: 0 = 2 (mod3) -> false.
+    const lights = [1, 2];
+    const buttons = [
+      [0],
+      [0]
+    ];
+    const modulus = 3;
+    expect(solveCounter(lights, buttons, modulus)).toBeNull();
+  });
+
+  it('should handle free variables and choose minimum total presses', () => {
+    // 2 counters, modulus 2
+    // target: [0, 0]
+    // button0: [0] (affects counter0)
+    // button1: [1] (affects counter1)
+    // button2: [0,1] (affects both)
+    // We have:
+    //   counter0: x0 + x2 = 0 (mod2)
+    //   counter1: x1 + x2 = 0 (mod2)
+    //   We can set x2=0, then x0=0, x1=0 -> solution [0,0,0] with total presses=0.
+    //   Alternatively, x2=1, then x0=1, x1=1 -> [1,1,1] with total presses=3.
+    //   So the minimum is [0,0,0].
+    const lights = [0, 0];
+    const buttons = [
+      [0],
+      [1],
+      [0,1]
+    ];
+    const modulus = 2;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([0, 0, 0]);
+  });
+
+  it('should handle free variables and choose lexicographically smallest when tied on total presses', () => {
+    // 2 counters, modulus 3
+    // target: [0, 0]
+    // button0: [0] (affects counter0)
+    // button1: [0] (affects counter0) -> duplicate
+    // button2: [1] (affects counter1)
+    // We have:
+    //   counter0: x0 + x1 = 0 (mod3)
+    //   counter1: x2 = 0 (mod3)
+    //   So x2=0, and x0 = -x1 mod3 -> x0 = (3 - x1) mod3? Actually, x0 + x1 ≡ 0 -> x0 ≡ -x1 mod3.
+    //   Let x1 = t, then x0 = -t mod3.
+    //   We want to minimize total presses: x0 + x1 + x2 = (-t mod3) + t + 0.
+    //   Let's compute for t in {0,1,2}:
+    //     t=0: x0=0, total=0
+    //     t=1: x0=2 (because -1 mod3=2), total=2+1=3
+    //     t=2: x0=1 (because -2 mod3=1), total=1+2=3
+    //   So minimum total is 0 at t=0 -> solution [0,0,0].
+    //   Now, what if we change target to [1,0]?
+    //   counter0: x0 + x1 = 1 (mod3)
+    //   counter1: x2 = 0 (mod3)
+    //   Let x1 = t, then x0 = 1 - t mod3.
+    //   total = (1-t mod3) + t + 0.
+    //   t=0: x0=1, total=1
+    //   t=1: x0=0, total=1
+    //   t=2: x0=2 (because 1-2=-1≡2), total=2+2=4
+    //   So we have two solutions with total=1: [1,0,0] and [0,1,0].
+    //   Lexicographically: [0,1,0] vs [1,0,0] -> [0,1,0] is smaller because at index0: 0<1.
+    //   So expected [0,1,0].
+    const lights = [1, 0];
+    const buttons = [
+      [0],
+      [0],
+      [1]
+    ];
+    const modulus = 3;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([0, 1, 0]);
+  });
+
+  it('should handle larger case within constraints (modulus small, free variables limited)', () => {
+    // 5 counters, modulus 2
+    // target: [1,1,1,1,1]
+    // Each button i toggles counter i (so diagonal)
+    // Solution: press each button once -> [1,1,1,1,1]
+    const N = 5;
+    const lights = Array(N).fill(1);
+    const buttons = Array.from({ length: N }, (_, i) => [i]);
+    const modulus = 2;
+    const result = solveCounter(lights, buttons, modulus);
+    expect(result).toEqual(Array(N).fill(1));
+  });
+
+  it('should handle case where no solution due to inconsistency in larger system', () => {
+    // 3 counters, modulus 2
+    // target: [1,0,0]
+    // button0: [0,1] (affects counter0 and counter1)
+    // button1: [1,2] (affects counter1 and counter2)
+    // Then we have:
+    //   counter0: x0 = 1
+    //   counter1: x0 + x1 = 0
+    //   counter2: x1 = 0
+    //   From counter0: x0=1
+    //   From counter2: x1=0
+    //   Then counter1: 1+0=1 ≠0 -> inconsistent.
+    const lights = [1, 0, 0];
+    const buttons = [
+      [0,1],
+      [1,2]
+    ];
+    const modulus = 2;
+    expect(solveCounter(lights, buttons, modulus)).toBeNull();
+  });
+});
