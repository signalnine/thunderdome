+import express from 'express';
+import { createDb } from './db.js';
+import createUserRoutes from './userRoutes.js';
+import createEventRoutes from './eventRoutes.js';
+import createQueryRoutes from './queryRoutes.js';
+import createDashboardRoutes from './dashboardRoutes.js';
+import createExportRoutes from './exportRoutes.js';
+
+export function createApp() {
+  const db = createDb();
+  const app = express();
+  app.use(express.json());
+
+  app.use('/api/auth', createUserRoutes(db));
+  app.use('/api', createUserRoutes(db)); // For the users/:id/role route
+  app.use('/api', createEventRoutes(db));
+  app.use('/api', createQueryRoutes(db));
+  app.use('/api', createDashboardRoutes(db));
+  app.use('/api', createExportRoutes(db));
+
+  return app;
+}
