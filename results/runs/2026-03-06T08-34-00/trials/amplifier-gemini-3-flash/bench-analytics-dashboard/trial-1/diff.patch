+++ b/src/app.test.ts
@@ -0,0 +1,213 @@
+import { describe, it, expect } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+
+describe('Analytics Dashboard API', () => {
+  async function setup(tenantId = 'tenant-1', emailPrefix = 'test') {
+    const app = createApp();
+    const email = `${emailPrefix}_${Math.random()}@test.com`;
+    
+    // Register admin
+    await request(app)
+      .post('/api/auth/register')
+      .send({
+        email,
+        password: 'password',
+        tenant_id: tenantId,
+        role: 'admin'
+      });
+
+    // Login admin
+    const loginRes = await request(app)
+      .post('/api/auth/login')
+      .send({
+        email,
+        password: 'password'
+      });
+    const adminToken = loginRes.body.token;
+
+    return { app, adminToken, tenantId };
+  }
+
+  it('should allow users to view their profile', async () => {
+    const { app, adminToken } = await setup();
+    const res = await request(app)
+      .get('/api/auth/me')
+      .set('Authorization', `Bearer ${adminToken}`);
+    
+    expect(res.status).toBe(200);
+  });
+
+  it('should allow admins to change roles', async () => {
+    const { app, adminToken, tenantId } = await setup();
+    
+    // Register viewer
+    const viewerEmail = `viewer_${Math.random()}@test.com`;
+    await request(app)
+      .post('/api/auth/register')
+      .send({
+        email: viewerEmail,
+        password: 'password',
+        tenant_id: tenantId,
+        role: 'viewer'
+      });
+
+    const viewerLoginRes = await request(app)
+      .post('/api/auth/login')
+      .send({
+        email: viewerEmail,
+        password: 'password'
+      });
+    const viewerToken = viewerLoginRes.body.token;
+
+    // Get viewer ID
+    const meRes = await request(app)
+      .get('/api/auth/me')
+      .set('Authorization', `Bearer ${viewerToken}`);
+    const viewerId = meRes.body.id;
+
+    const res = await request(app)
+      .patch(`/api/users/${viewerId}/role`)
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send({ role: 'editor' });
+
+    expect(res.status).toBe(200);
+    
+    const updatedMeRes = await request(app)
+      .get('/api/auth/me')
+      .set('Authorization', `Bearer ${viewerToken}`);
+    expect(updatedMeRes.body.role).toBe('editor');
+  });
+
+  it('should ingest events and query them', async () => {
+    const { app, adminToken } = await setup();
+    
+    // Ingest single event
+    await request(app)
+      .post('/api/events')
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send({
+        name: 'page_view',
+        properties: { url: '/home' }
+      });
+
+    // Ingest batch
+    await request(app)
+      .post('/api/events/batch')
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send([
+        { name: 'page_view', properties: { url: '/about' } },
+        { name: 'click', properties: { button: 'signup' } }
+      ]);
+
+    // Query count
+    const countRes = await request(app)
+      .get('/api/query/count?name=page_view')
+      .set('Authorization', `Bearer ${adminToken}`);
+    expect(countRes.body.count).toBe(2);
+
+    // Query breakdown
+    const breakdownRes = await request(app)
+      .get('/api/query/breakdown?property=url')
+      .set('Authorization', `Bearer ${adminToken}`);
+    expect(breakdownRes.body).toContainEqual({ value: '/home', count: 1 });
+    expect(breakdownRes.body).toContainEqual({ value: '/about', count: 1 });
+  });
+
+  it('should respect tenant isolation', async () => {
+    const { app, adminToken } = await setup('tenant-1', 'admin1');
+    
+    // Register another tenant
+    const otherEmail = `other_${Math.random()}@test.com`;
+    await request(app)
+      .post('/api/auth/register')
+      .send({
+        email: otherEmail,
+        password: 'password',
+        tenant_id: 'tenant-2'
+      });
+
+    const otherLoginRes = await request(app)
+      .post('/api/auth/login')
+      .send({
+        email: otherEmail,
+        password: 'password'
+      });
+    const otherToken = otherLoginRes.body.token;
+
+    // Ingest event for tenant-1
+    await request(app)
+      .post('/api/events')
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send({ name: 'test_event' });
+
+    // Query from tenant-2
+    const res = await request(app)
+      .get('/api/query/count?name=test_event')
+      .set('Authorization', `Bearer ${otherToken}`);
+    
+    expect(res.body.count).toBe(0);
+  });
+
+  it('should manage dashboards', async () => {
+    const { app, adminToken } = await setup();
+    
+    const createRes = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send({ name: 'Main Dashboard', config: { theme: 'dark' } });
+    
+    const dashId = createRes.body.id;
+
+    const getRes = await request(app)
+      .get(`/api/dashboards/${dashId}`)
+      .set('Authorization', `Bearer ${adminToken}`);
+    expect(getRes.body.name).toBe('Main Dashboard');
+
+    const updateRes = await request(app)
+      .put(`/api/dashboards/${dashId}`)
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send({ name: 'Updated Dashboard' });
+    expect(updateRes.status).toBe(200);
+
+    const getRes2 = await request(app)
+      .get(`/api/dashboards/${dashId}`)
+      .set('Authorization', `Bearer ${adminToken}`);
+    expect(getRes2.body.name).toBe('Updated Dashboard');
+
+    await request(app)
+      .delete(`/api/dashboards/${dashId}`)
+      .set('Authorization', `Bearer ${adminToken}`);
+
+    const getRes3 = await request(app)
+      .get(`/api/dashboards/${dashId}`)
+      .set('Authorization', `Bearer ${adminToken}`);
+    expect(getRes3.status).toBe(404);
+  });
+
+  it('should export data', async () => {
+    const { app, adminToken } = await setup();
+    
+    await request(app)
+      .post('/api/events')
+      .set('Authorization', `Bearer ${adminToken}`)
+      .send({ name: 'export_test' });
+
+    const jsonRes = await request(app)
+      .get('/api/export/events')
+      .set('Authorization', `Bearer ${adminToken}`);
+    expect(jsonRes.body.length).toBe(1);
+
+    const csvRes = await request(app)
+      .get('/api/export/events?format=csv')
+      .set('Authorization', `Bearer ${adminToken}`);
+    expect(csvRes.text).toContain('export_test');
+    expect(csvRes.header['content-type']).toContain('text/csv');
+  });
+
+  it('should return 401 for unauthenticated requests', async () => {
+    const app = createApp();
+    const res = await request(app).get('/api/dashboards');
+    expect(res.status).toBe(401);
+  });
+});
