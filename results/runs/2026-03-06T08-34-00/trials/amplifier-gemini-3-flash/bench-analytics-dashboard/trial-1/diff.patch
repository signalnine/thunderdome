+import jwt from 'jsonwebtoken';
+import crypto from 'crypto';
+
+const JWT_SECRET = process.env.JWT_SECRET || 'your-secret-key';
+
+export interface AuthPayload {
+  userId: string;
+  tenantId: string;
+  role: string;
+}
+
+export function generateToken(payload: AuthPayload): string {
+  return jwt.sign(payload, JWT_SECRET, { expiresIn: '24h' });
+}
+
+export function verifyToken(token: string): AuthPayload | null {
+  try {
+    return jwt.verify(token, JWT_SECRET) as AuthPayload;
+  } catch {
+    return null;
+  }
+}
+
+export function hashPassword(password: string): string {
+  return crypto.createHash('sha256').update(password).digest('hex');
+}
diff --git a/src/dashboardRoutes.ts b/src/dashboardRoutes.ts
new file mode 100644
index 0000000..4b62d24
--- /dev/null
+++ b/src/dashboardRoutes.ts
@@ -0,0 +1,120 @@
+import express, { Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { Database } from 'better-sqlite3';
+import { AuthRequest, authenticate } from './middleware.js';
+import { Dashboard, Widget } from './types.js';
+
+export default function(db: Database) {
+  const router = express.Router();
+
+  router.get('/dashboards', authenticate, (req: AuthRequest, res: Response) => {
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(req.user!.tenantId);
+    res.json(dashboards);
+  });
+
+  router.post('/dashboards', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, config } = req.body;
+    if (!name) {
+      return res.status(400).json({ error: 'Dashboard name is required' });
+    }
+
+    const id = uuidv4();
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)'
+    ).run(id, req.user!.tenantId, name, req.user!.userId, JSON.stringify(config || {}));
+
+    res.status(201).json({ id });
+  });
+
+  router.get('/dashboards/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, req.user!.tenantId) as Dashboard | undefined;
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+    
+    const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(req.params.id) as Widget[];
+    res.json({ ...dashboard, widgets });
+  });
+
+  router.put('/dashboards/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, config } = req.body;
+    
+    let result;
+    if (name !== undefined && config !== undefined) {
+      result = db.prepare("UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ? AND tenant_id = ?")
+        .run(name, JSON.stringify(config), req.params.id, req.user!.tenantId);
+    } else if (name !== undefined) {
+      result = db.prepare("UPDATE dashboards SET name = ?, updated_at = datetime('now') WHERE id = ? AND tenant_id = ?")
+        .run(name, req.params.id, req.user!.tenantId);
+    } else if (config !== undefined) {
+      result = db.prepare("UPDATE dashboards SET config = ?, updated_at = datetime('now') WHERE id = ? AND tenant_id = ?")
+        .run(JSON.stringify(config), req.params.id, req.user!.tenantId);
+    } else {
+      return res.json({ message: 'No changes' });
+    }
+
+    if (result.changes === 0) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+    res.json({ message: 'Dashboard updated' });
+  });
+
+  router.delete('/dashboards/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const result = db.prepare('DELETE FROM dashboards WHERE id = ? AND tenant_id = ?').run(req.params.id, req.user!.tenantId);
+    if (result.changes === 0) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+    res.status(204).send();
+  });
+
+  router.post('/dashboards/:id/widgets', authenticate, (req: AuthRequest, res: Response) => {
+    const { type, config, position_x, position_y, width, height } = req.body;
+    const dashboardId = req.params.id;
+
+    // Verify dashboard ownership
+    const dashboard = db.prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?').get(dashboardId, req.user!.tenantId);
+    if (!dashboard) {
+      return res.status(404).json({ error: 'Dashboard not found' });
+    }
+
+    if (!['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+      return res.status(400).json({ error: 'Invalid widget type' });
+    }
+
+    const id = uuidv4();
+    db.prepare(
+      'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+    ).run(
+      id,
+      dashboardId,
+      type,
+      JSON.stringify(config || {}),
+      position_x || 0,
+      position_y || 0,
+      width || 1,
+      height || 1
+    );
+
+    res.status(201).json({ id });
+  });
+
+  router.delete('/widgets/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const id = req.params.id;
+    
+    // Verify widget belongs to a dashboard owned by the tenant
+    const widget = db.prepare(`
+      SELECT w.id FROM widgets w
+      JOIN dashboards d ON w.dashboard_id = d.id
+      WHERE w.id = ? AND d.tenant_id = ?
+    `).get(id, req.user!.tenantId);
+
+    if (!widget) {
+      return res.status(404).json({ error: 'Widget not found' });
+    }
+
+    db.prepare('DELETE FROM widgets WHERE id = ?').run(id);
+    res.status(204).send();
+  });
+
+  return router;
+}
