@@ -0,0 +1,79 @@
+import express, { Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { Database } from 'better-sqlite3';
+import { hashPassword, generateToken } from './auth.js';
+import { AuthRequest, authenticate, authorize } from './middleware.js';
+import { User } from './types.js';
+
+export default function(db: Database) {
+  const router = express.Router();
+
+  router.post('/register', (req: express.Request, res: Response) => {
+    const { email, password, tenant_id, role } = req.body;
+    if (!email || !password || !tenant_id) {
+      return res.status(400).json({ error: 'Missing fields' });
+    }
+
+    const id = uuidv4();
+    const password_hash = hashPassword(password);
+    const userRole = role || 'viewer';
+
+    try {
+      db.prepare(
+        'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'
+      ).run(id, email, password_hash, tenant_id, userRole);
+
+      res.status(201).json({ id, email, tenant_id, role: userRole });
+    } catch (err: unknown) {
+      if (err instanceof Error && err.message.includes('UNIQUE')) {
+        return res.status(400).json({ error: 'Email already exists' });
+      }
+      res.status(500).json({ error: 'Internal server error' });
+    }
+  });
+
+  router.post('/login', (req: express.Request, res: Response) => {
+    const { email, password } = req.body;
+    if (!email || !password) {
+      return res.status(400).json({ error: 'Missing fields' });
+    }
+
+    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email) as User | undefined;
+    if (!user || user.password_hash !== hashPassword(password)) {
+      return res.status(401).json({ error: 'Invalid credentials' });
+    }
+
+    const token = generateToken({
+      userId: user.id,
+      tenantId: user.tenant_id,
+      role: user.role,
+    });
+
+    res.json({ token });
+  });
+
+  router.get('/me', authenticate, (req: AuthRequest, res: Response) => {
+    const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(req.user!.userId) as User | undefined;
+    res.json(user);
+  });
+
+  router.patch('/users/:id/role', authenticate, authorize(['admin']), (req: AuthRequest, res: Response) => {
+    const { role } = req.body;
+    const { id } = req.params;
+
+    if (!['admin', 'editor', 'viewer'].includes(role)) {
+      return res.status(400).json({ error: 'Invalid role' });
+    }
+
+    // Ensure user belongs to the same tenant
+    const targetUser = db.prepare('SELECT tenant_id FROM users WHERE id = ?').get(id) as Pick<User, 'tenant_id'> | undefined;
+    if (!targetUser || targetUser.tenant_id !== req.user!.tenantId) {
+      return res.status(404).json({ error: 'User not found in your tenant' });
+    }
+
+    db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, id);
+    res.json({ message: 'Role updated' });
+  });
+
+  return router;
+}
