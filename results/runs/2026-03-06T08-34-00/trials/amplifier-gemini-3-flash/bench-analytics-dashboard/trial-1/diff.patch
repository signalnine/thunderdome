@@ -0,0 +1,54 @@
+import express, { Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { Database } from 'better-sqlite3';
+import { AuthRequest, authenticate } from './middleware.js';
+
+export default function(db: Database) {
+  const router = express.Router();
+
+  router.post('/events', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, properties, timestamp } = req.body;
+    if (!name) {
+      return res.status(400).json({ error: 'Event name is required' });
+    }
+
+    const id = uuidv4();
+    const eventTime = timestamp || new Date().toISOString();
+    const props = JSON.stringify(properties || {});
+
+    db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+    ).run(id, req.user!.tenantId, name, props, eventTime, req.user!.userId);
+
+    res.status(201).json({ id });
+  });
+
+  router.post('/events/batch', authenticate, (req: AuthRequest, res: Response) => {
+    const events = req.body;
+    if (!Array.isArray(events)) {
+      return res.status(400).json({ error: 'Expected an array of events' });
+    }
+
+    const insert = db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+    );
+
+    const transaction = db.transaction((batchEvents: { name: string; properties?: object; timestamp?: string }[]) => {
+      for (const event of batchEvents) {
+        const id = uuidv4();
+        const eventTime = event.timestamp || new Date().toISOString();
+        const props = JSON.stringify(event.properties || {});
+        insert.run(id, req.user!.tenantId, event.name, props, eventTime, req.user!.userId);
+      }
+    });
+
+    try {
+      transaction(events);
+      res.status(201).json({ count: events.length });
+    } catch (err) {
+      res.status(400).json({ error: 'Failed to ingest batch' });
+    }
+  });
+
+  return router;
+}
