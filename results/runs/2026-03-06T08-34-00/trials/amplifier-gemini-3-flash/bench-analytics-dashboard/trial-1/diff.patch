@@ -0,0 +1,92 @@
+import express, { Response } from 'express';
+import { Database } from 'better-sqlite3';
+import { AuthRequest, authenticate } from './middleware.js';
+
+export default function(db: Database) {
+  const router = express.Router();
+
+  router.get('/query/count', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, start, end } = req.query as { name?: string; start?: string; end?: string };
+    let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: (string | number)[] = [req.user!.tenantId];
+
+    if (name) {
+      query += ' AND name = ?';
+      params.push(name);
+    }
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    const result = db.prepare(query).get(...params) as { count: number } | undefined;
+    res.json({ count: result ? result.count : 0 });
+  });
+
+  router.get('/query/timeseries', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, interval, start, end } = req.query as { name?: string; interval?: string; start?: string; end?: string };
+    
+    let timeFormat = '%Y-%m-%d';
+    if (interval === 'hour') timeFormat = '%Y-%m-%d %H:00:00';
+    if (interval === 'month') timeFormat = '%Y-%m';
+
+    let query = `SELECT strftime(?, timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [timeFormat, req.user!.tenantId];
+
+    if (name) {
+      query += ' AND name = ?';
+      params.push(name);
+    }
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    query += ' GROUP BY bucket ORDER BY bucket ASC';
+
+    const results = db.prepare(query).all(...params);
+    res.json(results);
+  });
+
+  router.get('/query/breakdown', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, property, start, end } = req.query as { name?: string; property?: string; start?: string; end?: string };
+    if (!property) {
+      return res.status(400).json({ error: 'Property name is required for breakdown' });
+    }
+
+    let query = `
+      SELECT json_extract(properties, ?) as value, COUNT(*) as count 
+      FROM events 
+      WHERE tenant_id = ?
+    `;
+    const params: (string | number)[] = [`$.${property}`, req.user!.tenantId];
+
+    if (name) {
+      query += ' AND name = ?';
+      params.push(name);
+    }
+    if (start) {
+      query += ' AND timestamp >= ?';
+      params.push(start);
+    }
+    if (end) {
+      query += ' AND timestamp <= ?';
+      params.push(end);
+    }
+
+    query += ' GROUP BY value ORDER BY count DESC';
+
+    const results = db.prepare(query).all(...params);
+    res.json(results);
+  });
+
+  return router;
+}
