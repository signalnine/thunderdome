@@ -0,0 +1,44 @@
+import express, { Response } from 'express';
+import { Database } from 'better-sqlite3';
+import { AuthRequest, authenticate } from './middleware.js';
+import { AnalyticsEvent, Dashboard, Widget } from './types.js';
+
+export default function(db: Database) {
+  const router = express.Router();
+
+  router.get('/export/events', authenticate, (req: AuthRequest, res: Response) => {
+    const { format } = req.query as { format?: string };
+    const events = db.prepare('SELECT * FROM events WHERE tenant_id = ?').all(req.user!.tenantId) as AnalyticsEvent[];
+
+    if (format === 'csv') {
+      if (events.length === 0) {
+        res.setHeader('Content-Type', 'text/csv');
+        return res.status(200).send('id,tenant_id,name,properties,timestamp,user_id,session_id\n');
+      }
+      const headers = Object.keys(events[0]).join(',');
+      const rows = events.map(event => {
+        return Object.values(event).map(val => {
+          if (typeof val === 'string' && val.includes(',')) return `"${val}"`;
+          return val === null ? '' : val;
+        }).join(',');
+      }).join('\n');
+      res.setHeader('Content-Type', 'text/csv');
+      return res.send(`${headers}\n${rows}`);
+    }
+
+    res.json(events);
+  });
+
+  router.get('/export/dashboards', authenticate, (req: AuthRequest, res: Response) => {
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(req.user!.tenantId) as Dashboard[];
+    
+    const results = dashboards.map(dash => {
+      const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dash.id) as Widget[];
+      return { ...dash, widgets };
+    });
+    
+    res.json(results);
+  });
+
+  return router;
+}
