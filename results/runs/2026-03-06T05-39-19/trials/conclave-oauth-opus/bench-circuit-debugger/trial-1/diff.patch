+```typescript
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+
+  // Build dependency tracking
+  // For each gate, track how many inputs are unresolved
+  const unresolved = new Map<number, number>();
+  // Map from wire name to list of gate indices that need it
+  const dependents = new Map<string, number[]>();
+
+  for (let i = 0; i < gates.length; i++) {
+    const gate = gates[i];
+    let count = 0;
+    if (!(gate.in1 in wires)) {
+      count++;
+      if (!dependents.has(gate.in1)) dependents.set(gate.in1, []);
+      dependents.get(gate.in1)!.push(i);
+    }
+    if (!(gate.in2 in wires)) {
+      count++;
+      if (!dependents.has(gate.in2)) dependents.set(gate.in2, []);
+      dependents.get(gate.in2)!.push(i);
+    }
+    unresolved.set(i, count);
+  }
+
+  // Initialize queue with gates that are ready
+  const queue: number[] = [];
+  for (let i = 0; i < gates.length; i++) {
+    if (unresolved.get(i) === 0) queue.push(i);
+  }
+
+  // Process
+  while (queue.length > 0) {
+    const idx = queue.shift()!;
+    const gate = gates[idx];
+    const a = wires[gate.in1];
+    const b = wires[gate.in2];
+
+    let result: number;
+    switch (gate.op) {
+      case 'AND': result = a & b; break;
+      case 'OR':  result = a | b; break;
+      case 'XOR': result = a ^ b; break;
+    }
+
+    wires[gate.out] = result;
+
+    // Notify dependents
+    const deps = dependents.get(gate.out);
+    if (deps) {
+      for (const depIdx of deps) {
+        const remaining = unresolved.get(depIdx)! - 1;
+        unresolved.set(depIdx, remaining);
+        if (remaining === 0) queue.push(depIdx);
+      }
+    }
+  }
+
+  return wires;
+}
+```
