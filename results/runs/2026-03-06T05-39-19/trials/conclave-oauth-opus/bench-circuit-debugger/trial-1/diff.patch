+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+
+  const unresolved = new Array<number>(gates.length);
+  const dependents = new Map<string, number[]>();
+
+  for (let i = 0; i < gates.length; i++) {
+    const gate = gates[i];
+    let count = 0;
+    if (!(gate.in1 in wires)) {
+      count++;
+      let deps = dependents.get(gate.in1);
+      if (!deps) { deps = []; dependents.set(gate.in1, deps); }
+      deps.push(i);
+    }
+    if (!(gate.in2 in wires)) {
+      count++;
+      let deps = dependents.get(gate.in2);
+      if (!deps) { deps = []; dependents.set(gate.in2, deps); }
+      deps.push(i);
+    }
+    unresolved[i] = count;
+  }
+
+  const queue: number[] = [];
+  for (let i = 0; i < gates.length; i++) {
+    if (unresolved[i] === 0) queue.push(i);
+  }
+
+  let head = 0;
+  while (head < queue.length) {
+    const idx = queue[head++];
+    const gate = gates[idx];
+    const a = wires[gate.in1];
+    const b = wires[gate.in2];
+
+    let result: number;
+    switch (gate.op) {
+      case 'AND': result = a & b; break;
+      case 'OR':  result = a | b; break;
+      case 'XOR': result = a ^ b; break;
+    }
+
+    wires[gate.out] = result;
+
+    const deps = dependents.get(gate.out);
+    if (deps) {
+      for (const depIdx of deps) {
+        unresolved[depIdx]--;
+        if (unresolved[depIdx] === 0) queue.push(depIdx);
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const pad = (i: number) => i.toString().padStart(2, '0');
+
+  // Lookup gate by (op, sorted inputs)
+  const gateByInputs = new Map<string, Gate>();
+  for (const gate of gates) {
+    const inputs = gate.in1 < gate.in2 ? `${gate.in1},${gate.in2}` : `${gate.in2},${gate.in1}`;
+    gateByInputs.set(`${gate.op}:${inputs}`, gate);
+  }
+
+  function lookup(op: string, w1: string, w2: string): Gate | undefined {
+    const inputs = w1 < w2 ? `${w1},${w2}` : `${w2},${w1}`;
+    return gateByInputs.get(`${op}:${inputs}`);
+  }
+
+  const swapped: Set<string> = new Set();
+
+  // Determine number of input bits
+  let numBits = 0;
+  for (const gate of gates) {
+    for (const w of [gate.in1, gate.in2]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);
+    }
+  }
+
+  // Bit 0: half adder
+  const xor0 = lookup('XOR', 'x00', 'y00');
+  if (xor0 && xor0.out !== 'z00') {
+    swapped.add(xor0.out);
+    swapped.add('z00');
+  }
+
+  const and0 = lookup('AND', 'x00', 'y00');
+  let carry = and0 ? and0.out : '';
+
+  // Bits 1..N-1: full adder
+  for (let i = 1; i < numBits; i++) {
+    const xi = `x${pad(i)}`, yi = `y${pad(i)}`, zi = `z${pad(i)}`;
+
+    // XOR(xi, yi) -> partial_sum
+    const xorGate = lookup('XOR', xi, yi);
+    if (!xorGate) continue;
+    let partialSum = xorGate.out;
+
+    // XOR(partialSum, carry) -> should be zi
+    let sumGate = lookup('XOR', partialSum, carry);
+
+    if (!sumGate) {
+      // partialSum or carry was swapped. Search for the correct XOR gate.
+      // Try: find XOR gate with carry as input — the other input is the true partialSum
+      for (const g of gates) {
+        if (g.op !== 'XOR') continue;
+        if (g.in1 === carry || g.in2 === carry) {
+          const other = g.in1 === carry ? g.in2 : g.in1;
+          if (other !== partialSum) {
+            swapped.add(partialSum);
+            swapped.add(other);
+            partialSum = other;
+            sumGate = g;
+            break;
+          }
+        }
+      }
+
+      // Try: find XOR gate with partialSum as input — the other input is the true carry
+      if (!sumGate) {
+        for (const g of gates) {
+          if (g.op !== 'XOR') continue;
+          if (g.in1 === partialSum || g.in2 === partialSum) {
+            const other = g.in1 === partialSum ? g.in2 : g.in1;
+            if (other !== carry) {
+              swapped.add(carry);
+              swapped.add(other);
+              carry = other;
+              sumGate = g;
+              break;
+            }
+          }
+        }
+      }
+    }
+
+    if (sumGate && sumGate.out !== zi) {
+      swapped.add(sumGate.out);
+      swapped.add(zi);
+    }
+
+    // AND(xi, yi) -> generate
+    const genGate = lookup('AND', xi, yi);
+    const generate = genGate ? genGate.out : '';
+
+    // AND(partialSum, carry) -> propagate
+    const propGate = lookup('AND', partialSum, carry);
+    const propagate = propGate ? propGate.out : '';
+
+    // OR(generate, propagate) -> carry_out
+    let carryGate = lookup('OR', generate, propagate);
+
+    if (!carryGate && generate && propagate) {
+      // generate or propagate was swapped. Find the OR gate that uses one of them.
+      for (const g of gates) {
+        if (g.op !== 'OR') continue;
+        const ins = new Set([g.in1, g.in2]);
+        if (ins.has(generate) || ins.has(propagate)) {
+          for (const actual of ins) {
+            if (actual !== generate && actual !== propagate) {
+              if (!ins.has(generate)) {
+                swapped.add(generate);
+                swapped.add(actual);
+              } else {
+                swapped.add(propagate);
+                swapped.add(actual);
+              }
+              carryGate = g;
+              break;
+            }
+          }
+          if (carryGate) break;
+        }
+      }
+    }
+
+    if (carryGate) {
+      if (i === numBits - 1) {
+        const expectedCarry = `z${pad(numBits)}`;
+        if (carryGate.out !== expectedCarry) {
+          swapped.add(carryGate.out);
+          swapped.add(expectedCarry);
+        }
+      }
+      carry = carryGate.out;
+    }
+  }
+
+  return [...swapped].sort();
+}
