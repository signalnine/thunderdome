1', out: 'c01' },\n      // Bit 2: full adder\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      // Bit 3: full adder\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    // 2 = 0b0010 (x: 0,1,0,0), 3 = 0b0011 (y: 1,1,0,0), result 5 = 0b00101 (z: 1,0,1,0,0)\n    const inputs: Record<string, number> = {\n      x00: 0, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 1, y02: 0, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result['z00']).toBe(1);\n    expect(result['z01']).toBe(0);\n    expect(result['z02']).toBe(1);\n    expect(result['z03']).toBe(0);\n    expect(result['z04']).toBe(0);\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npm test`\nExpected: All simulate tests FAIL with \"Not implemented\"\n\n---\n\n### Task 3: Implement `simulate()`\n\n**Files:**\n- Modify: `src/index.ts` (replace the simulate stub)\n\n**Dependencies:** Task 2\n\n**Step 1: Implement simulate with Kahn's algorithm**\n\nReplace the `simulate` function body in `src/index.ts`:\n\n```typescript\nexport function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n\n  // Build dependency tracking\n  // For each gate, track how many inputs are unresolved\n  const unresolved = new Map<number, number>();\n  // Map from wire name to list of gate indices that need it\n  const dependents = new Map<string, number[]>();\n\n  for (let i = 0; i < gates.length; i++) {\n    const gate = gates[i];\n    let count = 0;\n    if (!(gate.in1 in wires)) {\n      count++;\n      if (!dependents.has(gate.in1)) dependents.set(gate.in1, []);\n      dependents.get(gate.in1)!.push(i);\n    }\n    if (!(gate.in2 in wires)) {\n      count++;\n      if (!dependents.has(gate.in2)) dependents.set(gate.in2, []);\n      dependents.get(gate.in2)!.push(i);\n    }\n    unresolved.set(i, count);\n  }\n\n  // Initialize queue with gates that are ready\n  const queue: number[] = [];\n  for (let i = 0; i < gates.length; i++) {\n    if (unresolved.get(i) === 0) queue.push(i);\n  }\n\n  // Process\n  while (queue.length > 0) {\n    const idx = queue.shift()!;\n    const gate = gates[idx];\n    const a = wires[gate.in1];\n    const b = wires[gate.in2];\n\n    let result: number;\n    switch (gate.op) {\n      case 'AND': result = a & b; break;\n      case 'OR':  result = a | b; break;\n      case 'XOR': result = a ^ b; break;\n    }\n\n    wires[gate.out] = result;\n\n    // Notify dependents\n    const deps = dependents.get(gate.out);\n    if (deps) {\n      for (const depIdx of deps) {\n        const remaining = unresolved.get(depIdx)! - 1;\n        unresolved.set(depIdx, remaining);\n        if (remaining === 0) queue.push(depIdx);\n      }\n    }\n  }\n\n  return wires;\n}\n```\n\n**Step 2: Run tests to verify they pass**\n\nRun: `npm test`\nExpected: All simulate tests PASS.\n\n**Step 3: Verify build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: Both pass.\n\n**Step 4: Commit**\n\n```bash\ngit add src/index.ts src/index.test.ts\ngit commit -m \"feat: implement simulate() with Kahn's topological sort\"\n```\n\n---\n\n### Task 4: Implement `findSwappedWires()` — Tests\n\n**Files:**\n- Modify: `src/index.test.ts` (add findSwappedWires tests)\n\n**Dependencies:** Task 3\n\n**Step 1: Write a helper to build a correct N-bit adder and tests**\n\nAdd to `src/index.test.ts`:\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\n// ... existing simulate tests ...\n\n/** Build a correct N-bit ripple-carry adder circuit */\nfunction buildAdder(n: number): Gate[] {\n  const gates: Gate[] = [];\n  const pad = (i: number) => i.toString().padStart(2, '0');\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `z${pad(0)}` });\n  gates.push({ op: 'AND', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `c${pad(0)}` });\n\n  for (let i = 1; i < n; i++) {\n    const xi = `x${pad(i)}`, yi = `y${pad(i)}`, zi = `z${pad(i)}`;\n    const ti = `t${pad(i)}`, ai = `a${pad(i)}`, bi = `b${pad(i)}`, ci = `c${pad(i)}`;\n    const prevCarry = `c${pad(i - 1)}`;\n    gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n    gates.push({ op: 'XOR', in1: ti, in2: prevCarry, out: zi });\n    gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n    gates.push({ op: 'AND', in1: ti, in2: prevCarry, out: bi });\n    gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n  }\n\n  // Final carry becomes the MSB output\n  // The last carry gate (OR for bit n-1) should output z(n) instead of c(n-1)\n  gates[gates.length - 1].out = `z${pad(n)}`;\n\n  return gates;\n}\n\n/** Swap the outputs of two gates (by output wire name) */\nfunction swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n  return gates.map(g => {\n    if (g.out === wire1) return { ...g, out: wire2 };\n    if (g.out === wire2) return { ...g, out: wire1 };\n    return { ...g };\n  });\n}\n\ndescribe('findSwappedWires', () => {\n  it('detects 4 swapped pairs in an 8-bit adder', () => {\n    let gates = buildAdder(8);\n    // Swap 4 pairs\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 'c03');\n    gates = swapOutputs(gates, 't05', 'b05');\n    gates = swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a07', 'b05', 'c03', 't05', 'z01', 'z03', 'z07']);\n  });\n\n  it('detects swaps in a 16-bit adder', () => {\n    let gates = buildAdder(16);\n    gates = swapOutputs(gates, 'z02', 't02');\n    gates = swapOutputs(gates, 'a05', 'c05');\n    gates = swapOutputs(gates, 'z10', 'b10');\n    gates = swapOutputs(gates, 'z15', 'a15');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a05', 'a15', 'b10', 'c05', 't02', 'z02', 'z10', 'z15']);\n  });\n\n  it('handles a 45-bit adder within time limit', () => {\n    let gates = buildAdder(45);\n    gates = swapOutputs(gates, 'z01', 'c01');\n    gates = swapOutputs(gates, 'z22', 'a22');\n    gates = swapOutputs(gates, 't33', 'b33');\n    gates = swapOutputs(gates, 'z44', 'a44');\n\n    const start = performance.now();\n    const result = findSwappedWires(gates);\n    const elapsed = performance.now() - start;\n\n    expect(result).toEqual(['a22', 'a44', 'b33', 'c01', 't33', 'z01', 'z22', 'z44']);\n    expect(elapsed).toBeLessThan(5000);\n  });\n});\n```\n\n**Step 2: Run tests to verify findSwappedWires tests fail**\n\nRun: `npm test`\nExpected: simulate tests pass, findSwappedWires tests FAIL with \"Not implemented\".\n\n---\n\n### Task 5: Implement `findSwappedWires()`\n\n**Files:**\n- Modify: `src/index.ts` (replace the findSwappedWires stub)\n\n**Dependencies:** Task 4\n\n**Step 1: Implement findSwappedWires with structural pattern matching**\n\nReplace the `findSwappedWires` function body in `src/index.ts`:\n\n```typescript\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup: given (op, sorted inputs) -> gate\n  const gateByInputs = new Map<string, Gate>();\n  for (const gate of gates) {\n    const inputs = [gate.in1, gate.in2].sort();\n    const key = `${gate.op}:${inputs[0]}:${inputs[1]}`;\n    gateByInputs.set(key, gate);\n  }\n\n  function lookup(op: string, w1: string, w2: string): Gate | undefined {\n    const inputs = [w1, w2].sort();\n    return gateByInputs.get(`${op}:${inputs[0]}:${inputs[1]}`);\n  }\n\n  const swapped: string[] = [];\n\n  // Track corrections: when we detect a swap, the wire name used in\n  // downstream input references is the *original* (wrong) name since\n  // swaps only affect `out` fields. But we need to know the *role* each\n  // wire plays. We use a resolve map: logicalName -> actualOutputWire\n  const resolve = new Map<string, string>();\n\n  function actual(logicalName: string): string {\n    return resolve.get(logicalName) ?? logicalName;\n  }\n\n  function checkAndRecord(gate: Gate | undefined, expectedOut: string): string {\n    if (!gate) return expectedOut;\n    if (gate.out !== expectedOut) {\n      swapped.push(gate.out, expectedOut);\n      // The gate's actual output is gate.out, but logically it should be expectedOut\n      // Other gates reference gate.out in their inputs (because swaps only affect out)\n      // So when we look for the logical wire expectedOut in downstream inputs,\n      // we actually need to look for gate.out\n      resolve.set(expectedOut, gate.out);\n      return gate.out;\n    }\n    return gate.out;\n  }\n\n  // Determine number of input bits\n  const pad = (i: number) => i.toString().padStart(2, '0');\n  let numBits = 0;\n  for (const gate of gates) {\n    const match = gate.in1.match(/^[xy](\\d+)$/) ?? gate.in2.match(/^[xy](\\d+)$/);\n    if (match) {\n      numBits = Math.max(numBits, parseInt(match[1]) + 1);\n    }\n  }\n\n  // Bit 0: half adder\n  const xor0 = lookup('XOR', 'x00', 'y00');\n  checkAndRecord(xor0, `z00`);\n\n  const and0 = lookup('AND', 'x00', 'y00');\n  const carry0Actual = and0 ? checkAndRecord(and0, and0.out) : 'c00';\n  // carry0 is whatever the AND gate outputs (we don't know the expected name,\n  // it's an internal wire). But if it got swapped with something, we'll catch\n  // that when the downstream gate that uses it has issues.\n  // Actually — we DO need to track what wire the carry is on.\n  // The AND gate's output is the carry wire. It could be anything (random name).\n  // We just use gate.out directly.\n  let prevCarry = and0 ? and0.out : '';\n\n  // Bits 1..N-1: full adders\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${pad(i)}`, yi = `y${pad(i)}`, zi = `z${pad(i)}`;\n\n    // Step 1: xNN XOR yNN -> partial sum\n    const xorGate = lookup('XOR', xi, yi);\n    const partialSum = xorGate ? xorGate.out : '';\n\n    // Step 2: partialSum XOR prevCarry -> zNN\n    const sumGate = lookup('XOR', actual(partialSum), actual(prevCarry));\n    checkAndRecord(sumGate, zi);\n\n    // Step 3: xNN AND yNN -> generate\n    const genGate = lookup('AND', xi, yi);\n    const generate = genGate ? genGate.out : '';\n\n    // Step 4: partialSum AND prevCarry -> propagate\n    const propGate = lookup('AND', actual(partialSum), actual(prevCarry));\n    const propagate = propGate ? propGate.out : '';\n\n    // Step 5: generate OR propagate -> carry\n    const carryGate = lookup('OR', actual(generate), actual(propagate));\n\n    // The last bit's carry should be z(numBits)\n    if (i === numBits - 1) {\n      const expectedCarry = `z${pad(numBits)}`;\n      if (carryGate) checkAndRecord(carryGate, expectedCarry);\n      prevCarry = carryGate ? carryGate.out : '';\n    } else {\n      prevCarry = carryGate ? carryGate.out : '';\n    }\n  }\n\n  return [...new Set(swapped)].sort();\n}\n```\n\n**Important note:** The above is a starting point. The tricky part is that internal wires (partial sums, carries, generates, propagates) have random names, so we can't predict what they \"should\" be. We only check expectations for:\n1. `z00..zNN` — output bits must match\n2. The final carry must be `z(numBits)`\n3. Gate roles must match structurally (XOR with x/y inputs is a partial sum, etc.)\n\nSwaps between internal wires are detected when a gate we look up by inputs can't be found (because the wire name we're using was swapped). In that case, we need to check if the expected wire was swapped and resolve it.\n\n**The refined algorithm needs to handle these cases:**\n- A swap between a z-wire and an internal wire: detected when the sum gate's output isn't zNN.\n- A swap between two internal wires: detected when a downstream lookup fails because the input wire name has been replaced. We resolve by checking the swap map.\n\nAfter the initial implementation, we'll iterate on failing tests.\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: Tests should pass. If any fail, debug and fix.\n\n**Step 3: Verify build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: Both pass.\n\n**Step 4: Commit**\n\n```bash\ngit add src/index.ts src/index.test.ts\ngit commit -m \"feat: implement findSwappedWires() with structural pattern matching\"\n```\n\n---\n\n### Task 6: Robustness — Handle Edge Cases in `findSwappedWires()`\n\n**Files:**\n- Modify: `src/index.ts`\n- Modify: `src/index.test.ts`\n\n**Dependencies:** Task 5\n\n**Step 1: Add edge case tests**\n\nAdd tests for:\n- Swap between a partial-sum wire and a z-wire (the XOR gate that produces the partial sum has its output swapped with a z-wire from a different bit)\n- Swap between carry wires from different bits\n- Swap between a generate and a z-wire\n- Cross-bit swaps (e.g., wire from bit 3 swapped with wire from bit 10)\n\n```typescript\nit('detects cross-bit swaps', () => {\n  let gates = buildAdder(10);\n  // Swap a carry from bit 2 with a z-wire from bit 7\n  gates = swapOutputs(gates, 'c02', 'z07');\n  // Swap partial sum from bit 4 with generate from bit 8\n  gates = swapOutputs(gates, 't04', 'a08');\n  // Swap z03 with b06\n  gates = swapOutputs(gates, 'z03', 'b06');\n  // Swap z09 with a09\n  gates = swapOutputs(gates, 'z09', 'a09');\n\n  const result = findSwappedWires(gates);\n  expect(result).toEqual(['a08', 'a09', 'b06', 'c02', 't04', 'z03', 'z07', 'z09']);\n});\n```\n\n**Step 2: Run tests, fix any failures by refining the algorithm**\n\nThe main challenge is handling cases where a lookup fails because a wire was swapped in an earlier bit. The algorithm must:\n1. When a loo