+**Step 1: Implement findSwappedWires with structural pattern matching**
+
+Replace the `findSwappedWires` function body in `src/index.ts`:
+
+```typescript
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Build lookup: given (op, sorted inputs) -> gate
+  const gateByInputs = new Map<string, Gate>();
+  for (const gate of gates) {
+    const inputs = [gate.in1, gate.in2].sort();
+    const key = `${gate.op}:${inputs[0]}:${inputs[1]}`;
+    gateByInputs.set(key, gate);
+  }
+
+  function lookup(op: string, w1: string, w2: string): Gate | undefined {
+    const inputs = [w1, w2].sort();
+    return gateByInputs.get(`${op}:${inputs[0]}:${inputs[1]}`);
+  }
+
+  const swapped: string[] = [];
+
+  // Track corrections: when we detect a swap, the wire name used in
+  // downstream input references is the *original* (wrong) name since
+  // swaps only affect `out` fields. But we need to know the *role* each
+  // wire plays. We use a resolve map: logicalName -> actualOutputWire
+  const resolve = new Map<string, string>();
+
+  function actual(logicalName: string): string {
+    return resolve.get(logicalName) ?? logicalName;
+  }
+
+  function checkAndRecord(gate: Gate | undefined, expectedOut: string): string {
+    if (!gate) return expectedOut;
+    if (gate.out !== expectedOut) {
+      swapped.push(gate.out, expectedOut);
+      // The gate's actual output is gate.out, but logically it should be expectedOut
+      // Other gates reference gate.out in their inputs (because swaps only affect out)
+      // So when we look for the logical wire expectedOut in downstream inputs,
+      // we actually need to look for gate.out
+      resolve.set(expectedOut, gate.out);
+      return gate.out;
+    }
+    return gate.out;
+  }
+
+  // Determine number of input bits
+  const pad = (i: number) => i.toString().padStart(2, '0');
+  let numBits = 0;
+  for (const gate of gates) {
+    const match = gate.in1.match(/^[xy](\d+)$/) ?? gate.in2.match(/^[xy](\d+)$/);
+    if (match) {
+      numBits = Math.max(numBits, parseInt(match[1]) + 1);
+    }
+  }
+
+  // Bit 0: half adder
+  const xor0 = lookup('XOR', 'x00', 'y00');
+  checkAndRecord(xor0, `z00`);
+
+  const and0 = lookup('AND', 'x00', 'y00');
+  const carry0Actual = and0 ? checkAndRecord(and0, and0.out) : 'c00';
+  // carry0 is whatever the AND gate outputs (we don't know the expected name,
+  // it's an internal wire). But if it got swapped with something, we'll catch
+  // that when the downstream gate that uses it has issues.
+  // Actually — we DO need to track what wire the carry is on.
+  // The AND gate's output is the carry wire. It could be anything (random name).
+  // We just use gate.out directly.
+  let prevCarry = and0 ? and0.out : '';
+
+  // Bits 1..N-1: full adders
+  for (let i = 1; i < numBits; i++) {
+    const xi = `x${pad(i)}`, yi = `y${pad(i)}`, zi = `z${pad(i)}`;
+
+    // Step 1: xNN XOR yNN -> partial sum
+    const xorGate = lookup('XOR', xi, yi);
+    const partialSum = xorGate ? xorGate.out : '';
+
+    // Step 2: partialSum XOR prevCarry -> zNN
+    const sumGate = lookup('XOR', actual(partialSum), actual(prevCarry));
+    checkAndRecord(sumGate, zi);
+
+    // Step 3: xNN AND yNN -> generate
+    const genGate = lookup('AND', xi, yi);
+    const generate = genGate ? genGate.out : '';
+
+    // Step 4: partialSum AND prevCarry -> propagate
+    const propGate = lookup('AND', actual(partialSum), actual(prevCarry));
+    const propagate = propGate ? propGate.out : '';
+
+    // Step 5: generate OR propagate -> carry
+    const carryGate = lookup('OR', actual(generate), actual(propagate));
+
+    // The last bit's carry should be z(numBits)
+    if (i === numBits - 1) {
+      const expectedCarry = `z${pad(numBits)}`;
+      if (carryGate) checkAndRecord(carryGate, expectedCarry);
+      prevCarry = carryGate ? carryGate.out : '';
+    } else {
+      prevCarry = carryGate ? carryGate.out : '';
+    }
+  }
+
+  return [...new Set(swapped)].sort();
+}
+```
+
+**Important note:** The above is a starting point. The tricky part is that internal wires (partial sums, carries, generates, propagates) have random names, so we can't predict what they "should" be. We only check expectations for:
+1. `z00..zNN` — output bits must match
+2. The final carry must be `z(numBits)`
+3. Gate roles must match structurally (XOR with x/y inputs is a partial sum, etc.)
+
+Swaps between internal wires are detected when a gate we look up by inputs can't be found (because the wire name we're using was swapped). In that case, we need to check if the expected wire was swapped and resolve it.
+
+**The refined algorithm needs to handle these cases:**
+- A swap between a z-wire and an internal wire: detected when the sum gate's output isn't zNN.
+- A swap between two internal wires: detected when a downstream lookup fails because the input wire name has been replaced. We resolve by checking the swap map.
