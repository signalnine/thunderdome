+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TimerManager } from '../src/timer.js';
+import { TimeEntry } from '../src/entry.js';
+import { getAllEntries, getEntriesByDateRange, summarizeTimePerTask } from '../src/query.js';
+import * as fs from 'fs';
+import * as path from 'path';
+
+// Mock fs module to control file operations for testing
+vi.mock('fs');
+vi.mock('path', () => ({
+  ...vi.importActual('path'),
+  resolve: vi.fn((...args: string[]) => args.join('/')), // Simple mock for path.resolve
+}));
+
+// Explicitly type the mocked fs and path objects more precisely
+const mockFs: jest.Mocked<typeof fs> = fs as jest.Mocked<typeof fs>;
+const mockPathResolve: jest.MockedFunction<typeof path.resolve> = path.resolve as jest.MockedFunction<typeof path.resolve>;
+
+
+const mockFilePath = '/tmp/test-time-tracker-data.json';
+
+describe('Time Tracker Library', () => {
+  let manager: TimerManager;
+  let mockEntries: TimeEntry[];
+
+  beforeEach(() => {
+    // Reset mocks and create a new manager instance before each test
+    vi.resetAllMocks();
+    mockFs.readFileSync.mockClear();
+    mockFs.writeFileSync.mockClear();
+    mockFs.existsSync.mockClear();
+    mockFs.mkdirSync.mockClear();
+    mockPathResolve.mockClear(); // Clear mockPathResolve too
+    mockPathResolve.mockReturnValue(mockFilePath); // Mock path.resolve
+
+    // Mock initial state for loading
+    mockEntries = [];
+    mockFs.readFileSync.mockReturnValue(JSON.stringify({ entries: mockEntries }));
+    mockFs.existsSync.mockReturnValue(true); // Assume file exists initially
+
+    manager = new TimerManager(mockFilePath);
+
+    // Ensure the manager's internal state is clean for each test if needed
+    // The constructor already loads state, so we rely on mocks above.
+  });
+
+  // --- TimerManager Tests ---
+  describe('TimerManager', () => {
+    it('should initialize with an empty state if file does not exist', () => {
+      mockFs.existsSync.mockReturnValue(false);
+      const newManager = new TimerManager('/non/existent/path.json');
+      expect(newManager.getAllEntries()).toEqual([]);
+      expect(newManager.getCurrentActiveEntry()).toBeNull();
+    });
+
+    it('should load existing entries on initialization', () => {
+      const initialEntries: TimeEntry[] = [
+        { taskName: 'Existing Task 1', startTime: Date.now() - 3600000, endTime: Date.now() - 1800000 },
+        { taskName: 'Existing Task 2', startTime: Date.now() - 7200000, endTime: Date.now() - 5400000 },
+      ];
+      mockFs.readFileSync.mockReturnValue(JSON.stringify({ entries: initialEntries }));
+      const loadedManager = new TimerManager(mockFilePath);
+      expect(loadedManager.getAllEntries()).toEqual(initialEntries);
+    });
+
+    it('should handle running entries on load by finalizing them', () => {
+      const runningEntry: TimeEntry = { taskName: 'Running Task', startTime: Date.now() - 3600000 };
+      mockFs.readFileSync.mockReturnValue(JSON.stringify({ entries: [runningEntry] }));
+      const loadedManager = new TimerManager(mockFilePath);
+      // Expect the running entry to be finalized with endTime
+      expect(loadedManager.getAllEntries().length).toBe(1);
+      expect(loadedManager.getAllEntries()[0].endTime).toBeDefined();
+      expect(loadedManager.getCurrentActiveEntry()).toBeNull(); // Active entry is managed in memory
+    });
+
+    it('should throw an error when starting a timer with an empty name', () => {
+      expect(() => manager.startTimer('')).toThrow('Task name cannot be empty.');
+      expect(() => manager.startTimer('   ')).toThrow('Task name cannot be empty.');
+    });
+
+    it('should start a new timer', () => {
+      const startTime = Date.now();
+      vi.setSystemTime(startTime); // Mock Date.now()
+      manager.startTimer('New Task');
+      expect(manager.getCurrentActiveEntry()).toEqual({ taskName: 'New Task', startTime: startTime });
+      expect(manager.getAllEntries()).toEqual([]); // No saved entries yet
+    });
+
+    it('should automatically stop the previous timer when starting a new one', () => {
+      const startTime1 = Date.now();
+      vi.setSystemTime(startTime1);
+      manager.startTimer('Task A');
+
+      const startTime2 = startTime1 + 1000;
+      vi.setSystemTime(startTime2);
+      manager.startTimer('Task B');
+
+      const activeEntry = manager.getCurrentActiveEntry();
+      expect(activeEntry).toEqual({ taskName: 'Task B', startTime: startTime2 });
+      expect(manager.getAllEntries().length).toBe(1);
+      expect(manager.getAllEntries()[0]).toEqual({ taskName: 'Task A', startTime: startTime1, endTime: startTime2 });
+    });
+
+    it('should throw an error when stopping a timer when none is running', () => {
+      expect(() => manager.stopTimer()).toThrow('No timer is currently running.');
+    });
+
+    it('should stop the current timer and record an entry', () => {
+      const startTime = Date.now();
+      vi.setSystemTime(startTime);
+      manager.startTimer('Task to Stop');
+
+      const stopTime = startTime + 5000;
+      vi.setSystemTime(stopTime);
+      const stoppedEntry = manager.stopTimer();
+
+      expect(stoppedEntry).toEqual({ taskName: 'Task to Stop', startTime: startTime, endTime: stopTime });
+      expect(manager.getCurrentActiveEntry()).toBeNull();
+      expect(manager.getAllEntries()).toEqual([{ taskName: 'Task to Stop', startTime: startTime, endTime: stopTime }]);
+    });
+
+    it('should save state to file when stopTimer is called', () => {
+      manager.startTimer('Task to Save');
+      manager.stopTimer();
+      expect(mockFs.writeFileSync).toHaveBeenCalledTimes(1);
+      expect(mockFs.writeFileSync).toHaveBeenCalledWith(
+        mockFilePath,
+        expect.stringContaining('"taskName": "Task to Save"'),
+        'utf-8'
+      );
+    });
+
+    it('should handle unicode and emoji in task names', () => {
+      const startTime = Date.now();
+      vi.setSystemTime(startTime);
+      manager.startTimer('🚀 Task with Emoji 😄');
+      const stopTime = startTime + 2000;
+      vi.setSystemTime(stopTime);
+      manager.stopTimer();
+
+      expect(manager.getAllEntries()[0].taskName).toBe('🚀 Task with Emoji 😄');
+      expect(mockFs.writeFileSync).toHaveBeenCalledTimes(1);
+      expect(mockFs.writeFileSync).toHaveBeenCalledWith(
+        mockFilePath,
+        expect.stringContaining('"taskName": "🚀 Task with Emoji 😄"'),
+        'utf-8'
+      );
+    });
+
+    it('should return currently active entry when not stopped', () => {
+      const startTime = Date.now();
+      vi.setSystemTime(startTime);
+      manager.startTimer('Running Task');
+      expect(manager.getCurrentActiveEntry()).toEqual({ taskName: 'Running Task', startTime: startTime });
+      expect(manager.getAllEntries()).toEqual([]);
+    });
+
+    it('should include the active entry when calling getAllEntries', () => {
+      const startTime = Date.now();
+      vi.setSystemTime(startTime);
+      manager.startTimer('Active Task');
+      expect(manager.getAllEntries()).toEqual([{ taskName: 'Active Task', startTime: startTime }]);
+    });
+  });
+
+  // --- Querying Tests ---
+  describe('Querying', () => {
+    const testEntries: TimeEntry[] = [
+      { taskName: 'Task 1', startTime: new Date('2023-01-01T10:00:00Z').getTime(), endTime: new Date('2023-01-01T11:00:00Z').getTime() }, // 1 hour
+      { taskName: 'Task 2', startTime: new Date('2023-01-01T11:00:00Z').getTime(), endTime: new Date('2023-01-01T11:30:00Z').getTime() }, // 30 mins
+      { taskName: 'Task 1', startTime: new Date('2023-01-02T09:00:00Z').getTime(), endTime: new Date('2023-01-02T10:00:00Z').getTime() }, // 1 hour
+      { taskName: 'Running Task', startTime: new Date('2023-01-02T10:00:00Z').getTime() }, // Running, will use current time for duration
+    ];
+
+    beforeEach(() => {
+      // Load test entries into the manager for querying tests
+      mockFs.readFileSync.mockReturnValue(JSON.stringify({ entries: testEntries }));
+      manager = new TimerManager(mockFilePath); // Re-create manager with test data
+      // Mock Date.now() for summarizeTimePerTask to make it predictable
+      vi.spyOn(Date, 'now');
+    });
+
+    it('getAllEntries should return all recorded entries', () => {
+      const entries = getAllEntries(manager);
+      expect(entries.length).toBe(4);
+      expect(entries).toEqual(testEntries); // Note: The 'Running Task' here is still running as per testEntries definition
+    });
+
+    it('getEntriesByDateRange should filter entries correctly by start and end dates', () => {
+      const startDate = new Date('2023-01-01T00:00:00Z');
+      const endDate = new Date('2023-01-01T23:59:59Z');
+      const filteredEntries = getEntriesByDateRange(manager, startDate, endDate);
+      expect(filteredEntries.length).toBe(2);
+      expect(filteredEntries.map((e: TimeEntry) => e.taskName)).toEqual(['Task 1', 'Task 2']);
+    });
+
+    it('getEntriesByDateRange should include entries that overlap with the range', () => {
+      const startDate = new Date('2023-01-01T10:30:00Z'); // Middle of Task 1
+      const endDate = new Date('2023-01-01T11:30:00Z');   // End of Task 2
+      const filteredEntries = getEntriesByDateRange(manager, startDate, endDate);
+      expect(filteredEntries.length).toBe(2); // Task 1 (partially) and Task 2 (fully)
+      expect(filteredEntries.map((e: TimeEntry) => e.taskName)).toEqual(['Task 1', 'Task 2']);
+    });
+
+    it('getEntriesByDateRange should handle running tasks correctly', () => {
+      const startDate = new Date('2023-01-02T09:00:00Z'); // Start of 'Task 1' on Jan 2
+      const endDate = new Date('2023-01-02T10:30:00Z');   // After 'Running Task' started
+      vi.setSystemTime(new Date('2023-01-02T11:00:00Z').getTime()); // Set current time
+
+      const filteredEntries = getEntriesByDateRange(manager, startDate, endDate);
+
+      expect(filteredEntries.length).toBe(2);
+      // The running task's endTime is considered 'now' for range checking
+      expect(filteredEntries.map((e: TimeEntry) => e.taskName)).toEqual(['Task 1', 'Running Task']);
+    });
+
+    it('summarizeTimePerTask should calculate total time for each task', () => {
+      const currentMockTime = new Date('2023-01-02T11:00:00Z').getTime();
+      vi.setSystemTime(currentMockTime); // Set current time for the running task
+      Date.now = vi.fn().mockReturnValue(currentMockTime); // Mock Date.now specifically
+
+      const summary = summarizeTimePerTask(manager);
+
+      // Task 1: (11:00 - 10:00) + (10:00 - 09:00) = 1 hour + 1 hour = 2 hours
+      const task1Duration = (11 * 60 * 60 * 1000) - (10 * 60 * 60 * 1000) + (10 * 60 * 60 * 1000) - (9 * 60 * 60 * 1000);
+      // Task 2: 30 mins
+      const task2Duration = 30 * 60 * 1000;
+      // Running Task: current time - startTime = 11:00 - 10:00 = 1 hour
+      const runningTaskDuration = currentMockTime - new Date('2023-01-02T10:00:00Z').getTime();
+
+      expect(summary).toEqual({
+        'Task 1': task1Duration,
+        'Task 2': task2Duration,
+        'Running Task': runningTaskDuration,
+      });
+    });
+
+    it('summarizeTimePerTask should handle empty entries', () => {
+      const emptyManagerInstance = new TimerManager(mockFilePath); // Re-init with empty state
+      mockFs.readFileSync.mockReturnValue(JSON.stringify({ entries: [] })); // Ensure it reads empty data
+
+      const summary = summarizeTimePerTask(emptyManagerInstance);
+      expect(summary).toEqual({});
+    });
+
+    it('summarizeTimePerTask should handle tasks with zero duration correctly', () => {
+      const zeroDurationEntries: TimeEntry[] = [
+        { taskName: 'Zero Task', startTime: 1000, endTime: 1000 }
+      ];
+      mockFs.readFileSync.mockReturnValue(JSON.stringify({ entries: zeroDurationEntries }));
+      const zeroManager = new TimerManager(mockFilePath);
+
+      const summary = summarizeTimePerTask(zeroManager);
+      expect(summary).toEqual({}); // Zero duration should not be counted
+    });
