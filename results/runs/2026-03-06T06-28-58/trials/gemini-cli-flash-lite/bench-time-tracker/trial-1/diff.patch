@@ -0,0 +1,44 @@
+import { TimeEntry } from './entry.js';
+
+export function getAllEntries(manager: { getAllEntries: () => TimeEntry[] }): TimeEntry[] {
+  return manager.getAllEntries();
+}
+
+export function getEntriesByDateRange(
+  manager: { getAllEntries: () => TimeEntry[] },
+  startDate: Date,
+  endDate: Date
+): TimeEntry[] {
+  const allEntries = manager.getAllEntries();
+  const startTime = startDate.getTime();
+  const endTime = endDate.getTime();
+
+  return allEntries.filter(entry => {
+    // For running tasks, use current time for comparison
+    const entryEndTime = entry.endTime === undefined ? Date.now() : entry.endTime;
+
+    // Check if the entry's time range overlaps with the query date range
+    // An entry overlaps if its start time is before the query end time AND its end time is after the query start time.
+    return entry.startTime < endTime && entryEndTime > startTime;
+  });
+}
+
+export function summarizeTimePerTask(manager: { getAllEntries: () => TimeEntry[] }): Record<string, number> {
+  const allEntries = manager.getAllEntries();
+  const summary: Record<string, number> = {};
+  const currentTime = Date.now();
+
+  allEntries.forEach(entry => {
+    const taskName = entry.taskName;
+    const startTime = entry.startTime;
+    // If endTime is undefined, it's a running task, use current time.
+    const endTime = entry.endTime === undefined ? currentTime : entry.endTime;
+    const duration = endTime - startTime;
+
+    if (duration > 0) { // Only add positive durations
+      summary[taskName] = (summary[taskName] || 0) + duration;
+    }
+  });
+
+  return summary;
+}
