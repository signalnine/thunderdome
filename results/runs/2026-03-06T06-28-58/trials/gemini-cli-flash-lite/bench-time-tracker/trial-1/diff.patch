+import { TimeEntry } from './entry.js';
+import * as fs from 'fs';
+import * as path from 'path';
+
+// Helper function to ensure the directory for the file exists
+function ensureDirectoryExists(filePath: string): void {
+  const dir = path.dirname(filePath);
+  if (!fs.existsSync(dir)) {
+    fs.mkdirSync(dir, { recursive: true });
+  }
+}
+
+export function loadEntries(filePath: string): TimeEntry[] {
+  const absoluteFilePath = path.resolve(filePath);
+  try {
+    if (!fs.existsSync(absoluteFilePath)) {
+      return [];
+    }
+    const data = fs.readFileSync(absoluteFilePath, 'utf-8');
+    const parsedData = JSON.parse(data);
+    // Basic validation
+    if (parsedData && Array.isArray(parsedData.entries)) {
+      return parsedData.entries;
+    }
+    return [];
+  } catch (error) {
+    console.error(`Error loading entries from ${absoluteFilePath}:`, error);
+    return []; // Return empty array on error to prevent data corruption
+  }
+}
+
+export function saveEntries(filePath: string, entries: TimeEntry[], activeEntry: TimeEntry | null): void {
+  const absoluteFilePath = path.resolve(filePath);
+  ensureDirectoryExists(absoluteFilePath);
+
+  // When saving, ensure any currently active entry is finalized
+  const allEntries = [...entries];
+  if (activeEntry) {
+    const currentTime = Date.now();
+    allEntries.push({ ...activeEntry, endTime: currentTime });
+  }
+
+  try {
+    fs.writeFileSync(absoluteFilePath, JSON.stringify({ entries: allEntries }, null, 2), 'utf-8');
+  } catch (error) {
+    console.error(`Error saving entries to ${absoluteFilePath}:`, error);
+  }
+}
