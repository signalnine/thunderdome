+++ b/src/timer.ts
@@ -0,0 +1,93 @@
+import { TimeEntry } from './entry.js';
+import { loadEntries, saveEntries } from './persistence.js';
+import * as path from 'path';
+
+interface TimerState {
+  activeEntry: TimeEntry | null;
+  entries: TimeEntry[];
+}
+
+export class TimerManager {
+  private filePath: string;
+  private state: TimerState;
+
+  constructor(filePath: string = 'time-tracker-data.json') {
+    this.filePath = path.resolve(filePath);
+    // Load entries from file, but active entry is managed in memory
+    this.state = {
+      activeEntry: null,
+      entries: loadEntries(this.filePath),
+    };
+    // Ensure any entries loaded from file that are still running are finalized
+    this.finalizeRunningEntries();
+  }
+
+  private finalizeRunningEntries(): void {
+    const currentTime = Date.now();
+    this.state.entries = this.state.entries.map(entry => {
+      if (entry.endTime === undefined) {
+        return { ...entry, endTime: currentTime };
+      }
+      return entry;
+    });
+  }
+
+  private save(): void {
+    saveEntries(this.filePath, this.state.entries, this.state.activeEntry);
+  }
+
+  startTimer(taskName: string): void {
+    if (!taskName || taskName.trim().length === 0) {
+      throw new Error('Task name cannot be empty.');
+    }
+
+    // If a timer is already running, stop it and record the entry
+    if (this.state.activeEntry) {
+      this.stopTimer(); // This will also save the state
+    }
+
+    const currentTime = Date.now();
+    this.state.activeEntry = {
+      taskName: taskName,
+      startTime: currentTime,
+    };
+    // Do not save immediately; a stopTimer call or explicit save should trigger it.
+    // Or, we could save here if starting implies a new state that must be persisted immediately.
+    // Let's opt for saving on stop or explicit save to avoid too many file writes.
+  }
+
+  stopTimer(): TimeEntry | null {
+    if (!this.state.activeEntry) {
+      throw new Error('No timer is currently running.');
+    }
+
+    const currentTime = Date.now();
+    const completedEntry: TimeEntry = {
+      ...this.state.activeEntry,
+      endTime: currentTime,
+    };
+
+    this.state.entries.push(completedEntry);
+    this.state.activeEntry = null;
+    this.save(); // Save after stopping and adding to entries
+    return completedEntry;
+  }
+
+  getCurrentActiveEntry(): TimeEntry | null {
+    return this.state.activeEntry;
+  }
+
+  getAllEntries(): TimeEntry[] {
+    // Return a copy of all entries, including the current active one if it exists
+    const allEntries = [...this.state.entries];
+    if (this.state.activeEntry) {
+      allEntries.push(this.state.activeEntry);
+    }
+    return allEntries;
+  }
+
+  // Explicit save method to persist the current state
+  saveStateExplicitly(): void {
+    this.save();
+  }
+}
