@@ -0,0 +1,135 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  // Track (row, col, dir) to avoid infinite reprocessing
+  const seen = new Set<string>();
+
+  const queue: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+  visited.add(`${source[0]},${source[1]}`);
+  seen.add(`${source[0]},${source[1]},down`);
+
+  while (queue.length > 0) {
+    const beam = queue.shift()!;
+    const { row, col, dir } = beam;
+
+    // If current cell is a splitter (and not the source), split
+    if (grid[row][col] === '^') {
+      // Split into down-left and down-right
+      const dirs: Direction[] = ['down-left', 'down-right'];
+      for (const newDir of dirs) {
+        const [nr, nc] = nextPos(row, col, newDir);
+        if (inBounds(nr, nc, rows, cols)) {
+          const key = `${nr},${nc},${newDir}`;
+          if (!seen.has(key)) {
+            seen.add(key);
+            visited.add(`${nr},${nc}`);
+            queue.push({ row: nr, col: nc, dir: newDir });
+          }
+        }
+      }
+    } else {
+      // Continue in current direction
+      const [nr, nc] = nextPos(row, col, dir);
+      if (inBounds(nr, nc, rows, cols)) {
+        const key = `${nr},${nc},${dir}`;
+        if (!seen.has(key)) {
+          seen.add(key);
+          visited.add(`${nr},${nc}`);
+          queue.push({ row: nr, col: nc, dir });
+        }
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // Use a map from (row, col, dir) -> number of paths reaching that state
+  // Process beams level by level (BFS-style) to count paths
+  let current = new Map<string, bigint>();
+  const startKey = `${source[0]},${source[1]},down`;
+  current.set(startKey, 1n);
+
+  let totalPaths = 0n;
+
+  while (current.size > 0) {
+    const next = new Map<string, bigint>();
+
+    for (const [key, count] of current) {
+      const parts = key.split(',');
+      const row = parseInt(parts[0]);
+      const col = parseInt(parts[1]);
+      const dir = parts[2] as Direction;
+
+      if (grid[row][col] === '^') {
+        // Split into two directions
+        const dirs: Direction[] = ['down-left', 'down-right'];
+        for (const newDir of dirs) {
+          const [nr, nc] = nextPos(row, col, newDir);
+          if (inBounds(nr, nc, rows, cols)) {
+            const nk = `${nr},${nc},${newDir}`;
+            next.set(nk, (next.get(nk) ?? 0n) + count);
+          } else {
+            // Beam exits grid - counts as a path
+            totalPaths += count;
+          }
+        }
+      } else {
+        // Continue in current direction
+        const [nr, nc] = nextPos(row, col, dir);
+        if (inBounds(nr, nc, rows, cols)) {
+          const nk = `${nr},${nc},${dir}`;
+          next.set(nk, (next.get(nk) ?? 0n) + count);
+        } else {
+          // Beam exits grid
+          totalPaths += count;
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  return totalPaths;
+}
