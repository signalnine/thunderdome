+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "../src/index.js";
+import { rmSync, existsSync, readFileSync, mkdirSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+function tmpFile(): string {
+  return join(
+    tmpdir(),
+    `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}.json`
+  );
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    try {
+      rmSync(filePath, { force: true });
+    } catch {
+      // ignore
+    }
+  });
+
+  describe("start/stop", () => {
+    it("should start a timer and return the entry", () => {
+      const tracker = new TimeTracker({ filePath });
+      const entry = tracker.start("coding");
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeNull();
+    });
+
+    it("should stop the running timer", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      const stopped = tracker.stop();
+      expect(stopped.task).toBe("coding");
+      expect(stopped.stop).toBeTruthy();
+    });
+
+    it("should auto-stop the previous timer when starting a new one", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      tracker.start("meeting");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].stop).toBeTruthy(); // auto-stopped
+      expect(entries[1].task).toBe("meeting");
+      expect(entries[1].stop).toBeNull(); // still running
+    });
+
+    it("should throw when starting with an empty name", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.start("")).toThrow("Task name must not be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name must not be empty");
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should save data to the JSON file", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      tracker.stop();
+
+      expect(existsSync(filePath)).toBe(true);
+      const raw = readFileSync(filePath, "utf-8");
+      const data = JSON.parse(raw);
+      expect(data.entries).toHaveLength(1);
+      expect(data.entries[0].task).toBe("coding");
+    });
+
+    it("should load data from an existing file", () => {
+      const tracker1 = new TimeTracker({ filePath });
+      tracker1.start("coding");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker({ filePath });
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const nested = join(
+        tmpdir(),
+        `tracker-test-${Date.now()}`,
+        "deep",
+        "nested",
+        "data.json"
+      );
+      const tracker = new TimeTracker({ filePath: nested });
+      tracker.start("coding");
+      tracker.stop();
+      expect(existsSync(nested)).toBe(true);
+
+      // Cleanup
+      rmSync(join(tmpdir(), `tracker-test-${nested.split("tracker-test-")[1].split("/")[0]}`), {
+        recursive: true,
+        force: true,
+      });
+    });
+
+    it("should handle a missing file gracefully", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(tracker.getEntries()).toHaveLength(0);
+    });
+  });
+
+  describe("querying", () => {
+    it("should return all entries", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("task1");
+      tracker.start("task2");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should return entries filtered by date range", () => {
+      const tracker = new TimeTracker({ filePath });
+
+      // Create entries at known times
+      tracker.start("old-task");
+      tracker.stop();
+
+      const now = new Date();
+      const past = new Date(now.getTime() - 1000);
+      const future = new Date(now.getTime() + 60000);
+
+      tracker.start("recent-task");
+      tracker.stop();
+
+      const filtered = tracker.getEntriesByDateRange(past, future);
+      expect(filtered.length).toBeGreaterThanOrEqual(1);
+      expect(filtered.some((e) => e.task === "recent-task")).toBe(true);
+    });
+
+    it("should return empty array when no entries match date range", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("task");
+      tracker.stop();
+
+      const farFuture = new Date("2099-01-01");
+      const farFuture2 = new Date("2099-12-31");
+      expect(tracker.getEntriesByDateRange(farFuture, farFuture2)).toHaveLength(0);
+    });
+  });
+
+  describe("summary", () => {
+    it("should summarize time per task", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("meeting");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["meeting"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should sum multiple entries with the same task name", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      // There should only be one key for coding
+      expect(Object.keys(summary)).toHaveLength(1);
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("日本語タスク");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("日本語タスク");
+    });
+
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("🚀 deployment");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 deployment");
+
+      // Verify persistence
+      const tracker2 = new TimeTracker({ filePath });
+      expect(tracker2.getEntries()[0].task).toBe("🚀 deployment");
+    });
+
+    it("should handle mixed unicode in summaries", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("编码");
+      tracker.stop();
+      tracker.start("编码");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["编码"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("getRunningEntry", () => {
+    it("should return null when no timer is running", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(tracker.getRunningEntry()).toBeNull();
+    });
+
+    it("should return the running entry", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      const running = tracker.getRunningEntry();
+      expect(running).not.toBeNull();
+      expect(running!.task).toBe("coding");
+    });
   });
 });
