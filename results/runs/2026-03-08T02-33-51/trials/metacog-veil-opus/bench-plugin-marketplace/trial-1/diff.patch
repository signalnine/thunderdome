   await expect(\n        mp.installPlugin(makeManifest({ entryPoint: '' }))\n      ).rejects.toThrow(/entryPoint/);\n    });\n\n    it('should resolve dependencies during install', async () => {\n      const mp = createMarketplace();\n      // Register the dependency first\n      mp.registry.register(\n        makeManifest({\n          name: 'dep-a',\n          version: '1.2.0',\n          entryPoint: '\"dep\"',\n        })\n      );\n\n      const result = await mp.installPlugin(\n        makeManifest({\n          name: 'main',\n          dependencies: { 'dep-a': '^1.0.0' },\n        })\n      );\n\n      expect(result.resolvedDependencies).toHaveLength(1);\n      expect(result.resolvedDependencies[0].name).toBe('dep-a');\n      expect(result.resolvedDependencies[0].version).toBe('1.2.0');\n    });\n\n    it('should reject circular dependencies', async () => {\n      const mp = createMarketplace();\n      // Register a plugin that depends on 'cycler'\n      mp.registry.register(\n        makeManifest({\n          name: 'dep-b',\n          version: '1.0.0',\n          dependencies: { cycler: '^1.0.0' },\n        })\n      );\n\n      // Now try to install 'cycler' which depends on 'dep-b' -> circular\n      await expect(\n        mp.installPlugin(\n          makeManifest({\n            name: 'cycler',\n            version: '1.0.0',\n            dependencies: { 'dep-b': '^1.0.0' },\n          })\n        )\n      ).rejects.toThrow(/Circular/);\n\n      // The cycler plugin should have been removed from registry\n      expect(mp.registry.get('cycler')).toBeNull();\n    });\n\n    it('should handle plugin execution errors gracefully', async () => {\n      const mp = createMarketplace();\n      const result = await mp.installPlugin(\n        makeManifest({\n          entryPoint: 'throw new Error(\"init failed\")',\n        })\n      );\n      expect(result.executionResult.success).toBe(false);\n      expect(result.executionResult.error).toBe('init failed');\n    });\n\