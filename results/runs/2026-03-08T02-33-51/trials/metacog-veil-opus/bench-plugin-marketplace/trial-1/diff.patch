+import { describe, it, expect } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '2 + 2',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  it('should create a marketplace with all services', () => {
+    const mp = createMarketplace();
+    expect(mp.registry).toBeDefined();
+    expect(mp.resolver).toBeDefined();
+    expect(mp.runner).toBeDefined();
+    expect(mp.reviews).toBeDefined();
+    expect(mp.deps).toBeDefined();
+    expect(mp.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin', async () => {
+      const mp = createMarketplace();
+      const result = await mp.installPlugin(makeManifest());
+      expect(result.resolvedDependencies).toEqual([]);
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe(4);
+    });
+
+    it('should validate name', async () => {
+      const mp = createMarketplace();
+      await expect(
+        mp.installPlugin(makeManifest({ name: '' }))
+      ).rejects.toThrow(/name/);
+    });
+
+    it('should validate version', async () => {
+      const mp = createMarketplace();
+      await expect(
+        mp.installPlugin(makeManifest({ version: '' }))
+      ).rejects.toThrow(/version/);
+    });
+
+    it('should validate entryPoint', async () => {
+      const mp = createMarketplace();
+      await expect(
+        mp.installPlugin(makeManifest({ entryPoint: '' }))
+      ).rejects.toThrow(/entryPoint/);
+    });
+
+    it('should resolve dependencies during install', async () => {
+      const mp = createMarketplace();
+      // Register the dependency first
+      mp.registry.register(
+        makeManifest({
+          name: 'dep-a',
+          version: '1.2.0',
+          entryPoint: '"dep"',
+        })
+      );
+
+      const result = await mp.installPlugin(
+        makeManifest({
+          name: 'main',
+          dependencies: { 'dep-a': '^1.0.0' },
+        })
+      );
+
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.resolvedDependencies[0].version).toBe('1.2.0');
+    });
+
+    it('should reject circular dependencies', async () => {
+      const mp = createMarketplace();
+      // Register a plugin that depends on 'cycler'
+      mp.registry.register(
+        makeManifest({
+          name: 'dep-b',
+          version: '1.0.0',
+          dependencies: { cycler: '^1.0.0' },
+        })
+      );
+
+      // Now try to install 'cycler' which depends on 'dep-b' -> circular
+      await expect(
+        mp.installPlugin(
+          makeManifest({
+            name: 'cycler',
+            version: '1.0.0',
+            dependencies: { 'dep-b': '^1.0.0' },
+          })
+        )
+      ).rejects.toThrow(/Circular/);
+
+      // The cycler plugin should have been removed from registry
+      expect(mp.registry.get('cycler')).toBeNull();
+    });
+
+    it('should handle plugin execution errors gracefully', async () => {
+      const mp = createMarketplace();
+      const result = await mp.installPlugin(
+        makeManifest({
+          entryPoint: 'throw new Error("init failed")',
+        })
+      );
+      expect(result.executionResult.success).toBe(false);
+      expect(result.executionResult.error).toBe('init failed');
+    });
+
+    it('should register plugin in catalog', async () => {
+      const mp = createMarketplace();
+      await mp.installPlugin(makeManifest({ name: 'my-plugin' }));
+      const registered = mp.registry.get('my-plugin');
+      expect(registered).not.toBeNull();
+      expect(registered!.name).toBe('my-plugin');
+    });
+  });
+});
