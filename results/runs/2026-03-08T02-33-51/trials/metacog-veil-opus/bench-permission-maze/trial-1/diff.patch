ring }) => e.action === 'resource_shared');\n    expect(shareEntries.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('activity log entries have required fields', async () => {\n    const user = await registerAndLogin('alice', 'pass');\n    const folder = await createFolder(user.token, 'Folder');\n    await createDocument(user.token, 'Doc', 'content', folder.body.id);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${user.token}`);\n\n    for (const entry of res.body) {\n      expect(entry).toHaveProperty('id');\n      expect(entry).toHaveProperty('action');\n      expect(entry).toHaveProperty('userId');\n      expect(entry).toHaveProperty('resourceType');\n      expect(entry).toHaveProperty('resourceId');\n      expect(entry).toHaveProperty('timestamp');\n    }\n  });\n});\n\ndescribe('Edge Cases', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('unauthenticated user cannot access any resource endpoints', async () => {\n    const res1 = await request(app).get('/folders/any');\n    expect(res1.status).toBe(401);\n\n    const res2 = await request(app).get('/documents/any');\n    expect(res2.status).toBe(401);\n\n    const res3 = await request(app).get('/activity');\n    expect(res3.status).toBe(401);\n  });\n\n  it('user without permissions cannot access folder', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Private');\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('creator can create doc in subfolder they created under someone else\\'s folder', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token