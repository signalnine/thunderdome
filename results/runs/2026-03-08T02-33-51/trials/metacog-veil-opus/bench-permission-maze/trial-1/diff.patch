+
+export function createDocumentRouter(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canEdit(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'No permission to create documents in this folder' });
+      return;
+    }
+
+    const id = generateId();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    store.documents.set(id, doc);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    // Activity log
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!canRead(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'No permission to view this document' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!canEdit(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'No permission to edit this document' });
+      return;
+    }
+
+    const { title, content } = req.body;
+
+    if (title !== undefined) {
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = content;
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    store.documents.set(doc.id, doc);
+
+    // Activity log
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: doc.updatedAt,
+    });
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!isOwner(store, userId, 'document', doc.id)) {
+      res.status(403).json({ error: 'Only the owner can delete this document' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+
+    // Activity log
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: now,
+    });
+
+    store.documents.delete(doc.id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)
+    );
+
+    res.status(204).send();
+  });
+
+  return router;
+}
