+import { Router } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+import { canRead, canEdit, isOwner } from '../permissions.js';
+
+export function createFolderRouter(store: Store): Router {
+  const router = Router();
+
+  // Create folder
+  router.post('/', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // Validate parent folder exists and user has access
+    if (parentId) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      if (!canEdit(store, userId, 'folder', parentId)) {
+        res.status(403).json({ error: 'No permission to create subfolder here' });
+        return;
+      }
+    }
+
+    const id = generateId();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+
+    store.folders.set(id, folder);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canRead(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'No permission to view this folder' });
+      return;
+    }
+
+    // Get subfolders
+    const subfolders = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        subfolders.push(f);
+      }
+    }
+
+    // Get documents in folder
+    const documents = [];
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folder.id) {
+        documents.push(doc);
+      }
+    }
+
+    res.json({ ...folder, subfolders, documents });
+  });
+
+  // Update folder
+  router.put('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canEdit(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'No permission to edit this folder' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+
+    if (name !== undefined) {
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular references
+        if (parentId === folder.id) {
+          res.status(400).json({ error: 'Folder cannot be its own parent' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    store.folders.set(folder.id, folder);
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!isOwner(store, userId, 'folder', folder.id)) {
+      res.status(403).json({ error: 'Only the owner can delete this folder' });
+      return;
+    }
+
+    // Delete all documents in folder
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folder.id) {
+        store.documents.delete(doc.id);
+        store.permissions = store.permissions.filter(
+          (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)
+        );
+      }
+    }
+
+    // Delete subfolders recursively
+    const deleteSubfolders = (folderId: string) => {
+      for (const f of store.folders.values()) {
+        if (f.parentId === folderId) {
+          // Delete documents in subfolder
+          for (const doc of store.documents.values()) {
+            if (doc.folderId === f.id) {
+              store.documents.delete(doc.id);
+              store.permissions = store.permissions.filter(
+                (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)
+              );
+            }
+          }
+          deleteSubfolders(f.id);
+          store.folders.delete(f.id);
+          store.permissions = store.permissions.filter(
+            (p) => !(p.resourceType === 'folder' && p.resourceId === f.id)
+          );
+        }
+      }
+    };
+
+    deleteSubfolders(folder.id);
+    store.folders.delete(folder.id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'folder' && p.resourceId === folder.id)
+    );
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..ac25308
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,132 @@
+import { Router } from 'express';
+import { Role } from '../models.js';
+import { Store, generateId } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+import { canShare, isOwner } from '../permissions.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function createSharingRouter(store: Store): Router {
+  const router = Router();
+
+  // Share a resource
+  router.post('/:resourceType/:resourceId/share', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.params;
+    const { targetUserId, role } = req.body;
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'Resource type must be "folder" or "document"' });
+      return;
+    }
+
+    if (!targetUserId || !role) {
+      res.status(400).json({ error: 'targetUserId and role are required' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Role must be viewer, editor, or owner' });
+      return;
+    }
+
+    // Verify resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Verify target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Only owner can assign owner role; editors can share viewer/editor
+    if (role === 'owner' && !isOwner(store, userId, resourceType, resourceId)) {
+      res.status(403).json({ error: 'Only owners can assign the owner role' });
+      return;
+    }
+
+    if (!canShare(store, userId, resourceType, resourceId)) {
+      res.status(403).json({ error: 'No permission to share this resource' });
+      return;
+    }
+
+    // Check for existing permission and update, or create new
+    const existingPerm = store.permissions.find(
+      (p) => p.resourceType === resourceType && p.resourceId === resourceId && p.userId === targetUserId
+    );
+
+    if (existingPerm) {
+      existingPerm.role = role;
+    } else {
+      store.permissions.push({
+        id: generateId(),
+        resourceType,
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    const now = new Date().toISOString();
+
+    // Activity log
+    store.activityLog.push({
+      id: generateId(),
+      action: 'resource_shared',
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: now,
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(200).json({ message: 'Resource shared successfully', resourceType, resourceId, targetUserId, role });
+  });
+
+  // Get permissions for a resource
+  router.get('/:resourceType/:resourceId/permissions', requireAuth, (req: AuthenticatedRequest, res) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.params;
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'Resource type must be "folder" or "document"' });
+      return;
+    }
+
+    // Verify resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    if (!isOwner(store, userId, resourceType, resourceId)) {
+      res.status(403).json({ error: 'Only owners can view permissions' });
+      return;
+    }
+
+    const perms = store.permissions.filter(
+      (p) => p.resourceType === resourceType && p.resourceId === resourceId
+    );
+
+    res.json(perms);
+  });
+
+  return router;
+}
