+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BHSGLSd1p2CtpQRAPHA7Ry","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WzkWtgtrwpAgdrWirosTWD","name":"Write","input":{"file_path":"/workspace/src/routes/sharing.ts","content":"import { Router } from 'express';\nimport { Role } from '../models.js';\nimport { Store, generateId } from '../store.js';\nimport { AuthenticatedRequest, requireAuth } from '../middleware.js';\nimport { canShare, isOwner } from '../permissions.js';\n\nconst VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];\n\nexport function createSharingRouter(store: Store): Router {\n  const router = Router();\n\n  // Share a resource\n  router.post('/:resourceType/:resourceId/share', requireAuth, (req: AuthenticatedRequest, res) => {\n    const userId = req.userId!;\n    const { resourceType, resourceId } = req.params;\n    const { targetUserId, role } = req.body;\n\n    if (resourceType !== 'folder' && resourceType !== 'document') {\n      res.status(400).json({ error: 'Resource type must be \"folder\" or \"document\"' });\n      return;\n    }\n\n    if (!targetUserId || !role) {\n      res.status(400).json({ error: 'targetUserId and role are required' });\n      return;\n    }\n\n    if (!VALID_ROLES.includes(role)) {\n      res.status(400).json({ error: 'Role must be viewer, editor, or owner' });\n      return;\n    }\n\n    // Verify resource exists\n    if (resourceType === 'folder') {\n      if (!store.folders.has(resourceId)) {\n        res.status(404).json({ error: 'Folder not found' });\n        return;\n      }\n    } else {\n      if (!store.documents.has(resourceId)) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n    }\n\n    // Verify target user exists\n    if (!store.users.has(targetUserId)) {\n      res.status(404).json({ error: 'Target user not found' });\n      return;\n    }\n\n    // Only owner can assign owner role; editors can share viewer/editor\n    if (role === 'owner' && !isOwner(store, userId, resourceType, resourceId)) {\n      res.status(403).json({ error: 'Only owners can assign the owner role' });\n      return;\n    }\n\n    if (!canShare(store, userId, resourceType, resourceId)) {\n      res.status(403).json({ error: 'No permission to share this resource' });\n      return;\n    }\n\n    // Check for existing permission and update, or create new\n    const existingPerm = store.permissions.find(\n      (p) => p.resourceType === resourceType && p.resourceId === resourceId && p.userId === targetUserId\n    );\n\n    if (existingPerm) {\n      existingPerm.role = role;\n    } else {\n      store.permissions.push({\n        id: generateId(),\n        resourceType,\n        resourceId,\n        userId: targetUserId,\n        role,\n      });\n    }\n\n    const now = new Date().toISOString();\n\n    // Activity log\n    store.activityLog.push({\n      id: generateId(),\n      action: 'resource_shared',\n      userId,\n      resourceType,\n      resourceId,\n      timestamp: now,\n      details: `Shared with user ${targetUserId} as ${role}`,\n    });\n\n    res.status(200).json({ message: 'Resource shared successfully', resourceType, resourceId, targetUserId, role });\n  });\n\n  // Get permissions for a resource\n  router.get('/:resourceType/:resourceId/permissions', requireAuth, (req: AuthenticatedRequest, res) => {\n    const userId = req.userId!;\n    const { resourceType, resourceId } = req.params;\n\n    if (resourceType !== 'folder' && resourceType !== 'document') {\n      res.status(400).json({ error: 'Resource type must be \"folder\" or \"document\"' });\n      return;\n    }\n\n    // Verify resource exists\n    if (resourceType === 'folder') {\n      if (!store.folders.has(resourceId)) {\n        res.status(404).json({ error: 'Folder not found' });\n        return;\n      }\n    } else {\n      if (!store.documents.has(resourceId)) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n    }\n\n    if (!isOwner(store, userId, resourceType, resourceId)) {\n      res.status(403).json({ error: 'Only owners can view permissions' });\n      return;\n    }\n\n    const perms = store.permissions.filter(\n      (p) => p.resourceType === resourceType && p.resourceId === resourceId\n    );\n\n    res.json(perms);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":381,"cache_read_input_tokens":26866,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":381},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4e9ee941-72b9-4e0a-8296-bb3225487eb8","uuid":"7eb6de06-52ab-4248-bc01-81e4f2f222b3"}
