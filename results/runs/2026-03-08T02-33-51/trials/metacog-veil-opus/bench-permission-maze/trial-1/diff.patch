+      .get('/folders/nonexistent')
+      .set('Authorization', `Bearer ${user.token}`);
+    expect(res.status).toBe(404);
+  });
+
+  it('should update a folder', async () => {
+    const user = await registerAndLogin('alice', 'pass');
+    const folder = await createFolder(user.token, 'Old Name');
+
+    const res = await request(app)
+      .put(`/folders/${folder.body.id}`)
+      .set('Authorization', `Bearer ${user.token}`)
+      .send({ name: 'New Name' });
