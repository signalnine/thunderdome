ole: 'editor' });\n\n    // Bob can read and edit the document inside\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(getRes.status).toBe(200);\n\n    const editRes = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ content: 'updated by bob' });\n    expect(editRes.status).toBe(200);\n  });\n\n  it('nested folder permissions propagate', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const parent = await createFolder(alice.token, 'Parent');\n    const child = await createFolder(alice.token, 'Child', parent.body.id);\n    const doc = await createDocument(alice.token, 'Nested Doc', 'content', child.body.id);\n\n    // Share parent with bob as viewer\n    await request(app)\n      .post(`/folder/${parent.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'viewer' });\n\n    // Bob can view the child folder\n    const childRes = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(childRes.status).toBe(200);\n\n    // Bob can view the document in the child folder\n    const docRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(docRes.status).toBe(200);\n  });\n\n  it('most permissive role wins when access through multiple paths', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n\n    // Share document directly as viewer\n    await request(app)\n      .post(`/document/${doc.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'viewer' });\n\n    // Share folder as editor (more permissive)\n    await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'editor' });\n\n    // Bob should be able to edit the document (editor from folder overrides viewer from doc)\n    const editRes = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ content: 'modified' });\n    expect(editRes.status).toBe(200);\n  });\n\n  it('should reject sharing with invalid role', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n    const res = await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'admin' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject sharing with nonexistent user', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n    const res = await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: 'nonexistent', role: 'viewer' });\n    expect(res.status).toBe(404);\n  });\n\n  it('non-owner cannot assign owner role', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n    const charlie = await registerAndLogin('charlie', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n\n    // Share with bob as editor\n    await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'editor' });\n\n    // Bob tries to share as owner (should fail)\n    const res = await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ targetUserId: charlie.id, role: 'owner' });\n    expect(res.status).toBe(403);\n  });\n\n  it('viewer cannot share', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n    const charlie = await registerAndLogin('charlie', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n\n    // Share with bob as viewer\n    await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'viewer' });\n\n    // Bob tries to share (should fail)\n    const res = await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ targetUserId: charlie.id, role: 'viewer' });\n    expect(res.status).toBe(403);\n  });\n\n  it('non-owner cannot delete folder', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n\n    // Share with bob as editor\n    await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'editor' });\n\n    // Bob tries to delete\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should update existing permission when re-sharing', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const 