+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LjxX5oZScWHkTvpp6KVpWY","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015iUriyjC3TynW8vxXgJtWR","name":"Write","input":{"file_path":"/workspace/src/permissions.ts","content":"import { Role } from './models.js';\nimport { Store } from './store.js';\n\nconst ROLE_LEVELS: Record<Role, number> = {\n  viewer: 1,\n  editor: 2,\n  owner: 3,\n};\n\nexport function getEffectiveRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): Role | null {\n  let bestRole: Role | null = null;\n  let bestLevel = 0;\n\n  // Check direct permissions on this resource\n  for (const perm of store.permissions) {\n    if (perm.userId === userId && perm.resourceType === resourceType && perm.resourceId === resourceId) {\n      const level = ROLE_LEVELS[perm.role];\n      if (level > bestLevel) {\n        bestLevel = level;\n        bestRole = perm.role;\n      }\n    }\n  }\n\n  // If the resource is a document, check permissions on its folder (and ancestors)\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc) {\n      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);\n      if (folderRole) {\n        const level = ROLE_LEVELS[folderRole];\n        if (level > bestLevel) {\n          bestLevel = level;\n          bestRole = folderRole;\n        }\n      }\n    }\n  }\n\n  // If the resource is a folder, check permissions on parent folders\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.parentId) {\n      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n      if (parentRole) {\n        const level = ROLE_LEVELS[parentRole];\n        if (level > bestLevel) {\n          bestLevel = level;\n          bestRole = parentRole;\n        }\n      }\n    }\n  }\n\n  return bestRole;\n}\n\nexport function canRead(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role !== null;\n}\n\nexport function canEdit(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role === 'editor' || role === 'owner';\n}\n\nexport function canShare(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role === 'editor' || role === 'owner';\n}\n\nexport function isOwner(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n  return role === 'owner';\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":334,"cache_read_input_tokens":21292,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":334},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4e9ee941-72b9-4e0a-8296-bb3225487eb8","uuid":"3b739548-a631-4fa0-b185-7220bab764b7"}
