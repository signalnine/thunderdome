).toBe('new content');\n  });\n\n  it('should delete a document', async () => {\n    const user = await registerAndLogin('alice', 'pass');\n    const folder = await createFolder(user.token, 'Folder');\n    const doc = await createDocument(user.token, 'Doc', 'content', folder.body.id);\n\n    const res = await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${user.token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${user.token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for nonexistent document', async () => {\n    const user = await registerAndLogin('alice', 'pass');\n    const res = await request(app)\n      .get('/documents/nonexistent')\n      .set('Authorization', `Bearer ${user.token}`);\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Sharing & Permissions', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should share a folder with another user', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Shared');\n\n    const res = await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'viewer' });\n    expect(res.status).toBe(200);\n\n    // Bob can now view the folder\n    const getRes = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(getRes.status).toBe(200);\n  });\n\n  it('should share a document with another user', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'secret', folder.body.id);\n\n    // Bob cannot see the document initially\n    const noAccessRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(noAccessRes.status).toBe(403);\n\n    // Share with bob as viewer\n    await request(app)\n      .post(`/document/${doc.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'viewer' });\n\n    // Bob can now view\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.content).toBe('secret');\n  });\n\n  it('viewer cannot edit', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'original', folder.body.id);\n\n    await request(app)\n      .post(`/document/${doc.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'viewer' });\n\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ content: 'modified' });\n    expect(res.status).toBe(403);\n  });\n\n  it('editor can edit but not delete', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'original', folder.body.id);\n\n    await request(app)\n      .post(`/document/${doc.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'editor' });\n\n    // Can edit\n  