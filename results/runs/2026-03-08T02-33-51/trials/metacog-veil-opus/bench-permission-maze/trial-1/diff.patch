lder(alice.token, 'Folder');\n\n    // Share with bob as editor\n    await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'editor' });\n\n    // Bob tries to share as owner (should fail)\n    const res = await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ targetUserId: charlie.id, role: 'owner' });\n    expect(res.status).toBe(403);\n  });\n\n  it('viewer cannot share', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n    const charlie = await registerAndLogin('charlie', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n\n    // Share with bob as viewer\n    await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'viewer' });\n\n    // Bob tries to share (should fail)\n    const res = await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ targetUserId: charlie.id, role: 'viewer' });\n    expect(res.status).toBe(403);\n  });\n\n  it('non-owner cannot delete folder', async () => {\n    const alice = await registerAndLogin('alice', 'pass');\n    const bob = await registerAndLogin('bob', 'pass');\n\n    const folder = await createFolder(alice.token, 'Folder');\n\n    // Share with bob as editor\n    await request(app)\n      .post(`/folder/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ targetUserId: bob.id, role: 'editor' });\n\n    // Bob tries to delete\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should u