xt}</li>`)\n            .join('\\n');\n          content += `\\n<section class=\"footnotes\">\\n<ol>\\n${items}\\n</ol>\\n</section>`;\n        }\n\n        return { ...file, content };\n      },\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null}}
