+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0151j8kDkxWvvnMayWnDBtmo","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createSitemapPlugin } from '../../src/plugins/sitemap.js';\n     3→import { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n     4→\n     5→const testConfig: SiteConfig = {\n     6→  title: 'Test Site',\n     7→  baseUrl: 'https://example.com',\n     8→  outputDir: './dist',\n     9→  contentDir: './content',\n    10→  templateDir: './templates',\n    11→};\n    12→\n    13→function makeCtx(\n    14→  output?: Map<string, string>,\n    15→  data?: Map<string, unknown>\n    16→): BuildContext {\n    17→  return {\n    18→    config: testConfig,\n    19→    files: [],\n    20→    output: output || new Map(),\n    21→    assets: new Map(),\n    22→    data: data || new Map(),\n    23→  };\n    24→}\n    25→\n    26→describe('sitemap plugin', () => {\n    27→  const plugin = createSitemapPlugin();\n    28→\n    29→  it('generates sitemap.xml in ctx.output', async () => {\n    30→    const output = new Map<string, string>();\n    31→    output.set('post-1.html', '<html></html>');\n    32→    const ctx = makeCtx(output);\n    33→    await plugin.hooks.afterBuild!(ctx);\n    34→    expect(ctx.output.has('sitemap.xml')).toBe(true);\n    35→  });\n    36→\n    37→  it('includes all content page URLs', async () => {\n    38→    const output = new Map<string, string>();\n    39→    output.set('post-1.html', '<html></html>');\n    40→    output.set('post-2.html', '<html></html>');\n    41→    const ctx = makeCtx(output);\n    42→    await plugin.hooks.afterBuild!(ctx);\n    43→    const sitemap = ctx.output.get('sitemap.xml')!;\n    44→    expect(sitemap).toContain('https://example.com/post-1.html');\n    45→    expect(sitemap).toContain('https://example.com/post-2.html');\n    46→  });\n    47→\n    48→  it('includes taxonomy tag page URLs', async () =>