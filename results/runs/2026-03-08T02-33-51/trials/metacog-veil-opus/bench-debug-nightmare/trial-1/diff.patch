ow(),\n    98→    });\n    99→    const stock = service.getStock('SKU-1');\n   100→    expect(stock?.available).toBe(12);\n   101→    expect(stock?.reserved).toBe(8);\n   102→  });\n   103→});\n   104→"}]},"parent_tool_use_id":"toolu_01G5Aa9t6QUvdkFDfERpw5YB","session_id":"6f09d74f-2515-4d9a-93f0-a0bca78620dc","uuid":"93b15eea-29fb-493f-9a09-ebce6f703c14"}
