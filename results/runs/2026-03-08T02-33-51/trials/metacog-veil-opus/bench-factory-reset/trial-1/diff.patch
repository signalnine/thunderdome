+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve the toggle puzzle using Gaussian elimination over GF(2).
+ *
+ * Builds matrix A where column j is button j's effect vector.
+ * Target vector b is the desired light state.
+ * Solves Ax = b over GF(2), minimizing Hamming weight of x.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  // Build augmented matrix [A | b] over GF(2)
+  // Each row is a light, each column is a button, last column is target
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = [];
+  let row = 0;
+  for (let col = 0; col < m && row < n; col++) {
+    // Find pivot
+    let pivotRow = -1;
+    for (let r = row; r < n; r++) {
+      if (matrix[r][col] === 1) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    // Swap rows
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+    pivotCol.push(col);
+
+    // Eliminate
+    for (let r = 0; r < n; r++) {
+      if (r !== row && matrix[r][col] === 1) {
+        for (let c = 0; c <= m; c++) {
+          matrix[r][c] ^= matrix[row][c];
+        }
+      }
+    }
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < n; r++) {
+    if (matrix[r][m] === 1) return null;
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+
+  const numFree = freeVars.length;
+
+  // Enumerate all 2^numFree assignments of free variables
+  let bestSolution: number[] | null = null;
+  let bestWeight = m + 1;
+
+  for (let mask = 0; mask < (1 << numFree); mask++) {
+    const solution = new Array(m).fill(0);
+
+    // Set free variables
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = (mask >> i) & 1;
+    }
+
+    // Back-substitute pivot variables
+    for (let r = rank - 1; r >= 0; r--) {
+      const pc = pivotCol[r];
+      let val = matrix[r][m];
+      for (let c = 0; c < m; c++) {
+        if (c !== pc && matrix[r][c] === 1) {
+          val ^= solution[c];
+        }
+      }
+      solution[pc] = val;
+    }
+
+    // Calculate weight
+    const weight = solution.reduce((s: number, v: number) => s + v, 0);
+
+    if (weight < bestWeight) {
+      bestWeight = weight;
+      bestSolution = solution;
+    } else if (weight === bestWeight && bestSolution) {
+      // Lexicographic comparison on the index set
+      const indices = solution
+        .map((v: number, i: number) => (v ? i : -1))
+        .filter((i: number) => i >= 0);
+      const bestIndices = bestSolution
+        .map((v: number, i: number) => (v ? i : -1))
+        .filter((i: number) => i >= 0);
+      if (lexSmaller(indices, bestIndices)) {
+        bestSolution = solution;
+      }
+    }
+  }
+
+  if (!bestSolution) return null;
+
+  return bestSolution
+    .map((v: number, i: number) => (v ? i : -1))
+    .filter((i: number) => i >= 0);
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+/**
+ * Solve the counter puzzle using Gaussian elimination over Z/pZ.
+ *
+ * Each button press increments affected counters by 1 (mod p).
+ * We need to find press counts x[j] such that sum(A[i][j] * x[j]) ≡ target[i] (mod p).
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+  const p = modulus;
+
+  // Build augmented matrix [A | b] over Z/pZ
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = ((lights[i] % p) + p) % p;
+    matrix.push(row);
+  }
+
+  // Modular inverse using Fermat's little theorem (p is prime)
+  function modpow(base: number, exp: number, mod: number): number {
+    let result = 1;
+    base = ((base % mod) + mod) % mod;
+    while (exp > 0) {
+      if (exp & 1) result = (result * base) % mod;
+      exp >>= 1;
+      base = (base * base) % mod;
+    }
+    return result;
+  }
+
+  function modinv(a: number, mod: number): number {
+    return modpow(a, mod - 2, mod);
+  }
+
+  // Gaussian elimination over Z/pZ
+  const pivotCol: number[] = [];
+  let row = 0;
+  for (let col = 0; col < m && row < n; col++) {
+    // Find pivot
+    let pivotRow = -1;
+    for (let r = row; r < n; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    // Swap rows
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+    pivotCol.push(col);
+
+    // Scale pivot row so pivot element is 1
+    const inv = modinv(matrix[row][col], p);
+    for (let c = 0; c <= m; c++) {
+      matrix[row][c] = (matrix[row][c] * inv) % p;
+    }
+
+    // Eliminate column in other rows
+    for (let r = 0; r < n; r++) {
+      if (r !== row && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= m; c++) {
+          matrix[r][c] = (((matrix[r][c] - factor * matrix[row][c]) % p) + p) % p;
+        }
+      }
+    }
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < n; r++) {
+    if (matrix[r][m] !== 0) return null;
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+
+  const numFree = freeVars.length;
+
+  // Enumerate all p^numFree assignments of free variables
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const totalCombinations = Math.pow(p, numFree);
+
+  // Guard against combinatorial explosion
+  if (totalCombinations > 10_000_000) {
+    // Too many free variables — use greedy: set free vars to 0
+    const solution = new Array(m).fill(0);
+    for (let r = rank - 1; r >= 0; r--) {
+      const pc = pivotCol[r];
+      let val = matrix[r][m];
+      for (let c = 0; c < m; c++) {
+        if (c !== pc) {
+          val = (((val - matrix[r][c] * solution[c]) % p) + p) % p;
+        }
+      }
+      solution[pc] = val;
+    }
+    return solution;
+  }
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    const solution = new Array(m).fill(0);
+
+    // Set free variables based on combo (base-p representation)
+    let tmp = combo;
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = tmp % p;
+      tmp = Math.floor(tmp / p);
+    }
+
+    // Back-substitute pivot variables
+    for (let r = rank - 1; r >= 0; r--) {
+      const pc = pivotCol[r];
+      let val = matrix[r][m];
+      for (let c = 0; c < m; c++) {
+        if (c !== pc) {
+          val = (((val - matrix[r][c] * solution[c]) % p) + p) % p;
+        }
+      }
+      solution[pc] = val;
+    }
+
+    // Calculate total presses
+    const total = solution.reduce((s: number, v: number) => s + v, 0);
+
+    if (total < bestTotal) {
+      bestTotal = total;
+      bestSolution = [...solution];
+    } else if (total === bestTotal && bestSolution) {
+      // Lexicographic comparison
+      for (let i = 0; i < m; i++) {
+        if (solution[i] < bestSolution[i]) {
+          bestSolution = [...solution];
+          break;
+        } else if (solution[i] > bestSolution[i]) {
+          break;
+        }
+      }
+    }
+  }
+
+  return bestSolution;
+}
