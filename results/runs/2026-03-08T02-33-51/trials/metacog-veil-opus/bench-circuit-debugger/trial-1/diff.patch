 }\n    57→    }\n    58→  }\n    59→  const lastZ = `z${maxZBit.toString().padStart(2, '0')}`;\n    60→\n    61→  // Helper: check if a gate takes x,y register inputs\n    62→  function isXYGate(gate: Gate): boolean {\n    63→    return (\n    64→      ((gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||\n    65→       (gate.in1.startsWith('y') && gate.in2.startsWith('x')))\n    66→    );\n    67→  }\n    68→\n    69→  // Build a map: wire -> list of gates that consume it\n    70→  const consumers = new Map<string, Gate[]>();\n    71→  for (const gate of gates) {\n    72→    if (!consumers.has(gate.in1)) consumers.set(gate.in1, []);\n    73→    if (!consumers.has(gate.in2)) consumers.set(gate.in2, []);\n    74→    consumers.get(gate.in1)!.push(gate);\n    75→    consumers.get(gate.in2)!.push(gate);\n    76→  }\n    77→\n    78→  for (const gate of gates) {\n    79→    const out = gate.out;\n    80→    const outConsumers = consumers.get(out) || [];\n    81→\n    82→    if (gate.op === 'XOR') {\n    83→      if (isXYGate(gate)) {\n    84→        // XOR(xNN, yNN) -> partial sum (or z00 for bit 0)\n    85→        // Rule 1: Should not output to z (except z00)\n    86→        if (out.startsWith('z') && out !== 'z00') {\n    87→          swapped.add(out);\n    88→        }\n    89→        // Rule 6: Partial sum (not z00) should be consumed by XOR and AND.\n    90→        // If consumed by OR, that's wrong.\n    91→        if (out !== 'z00') {\n    92→          for (const c of outConsumers) {\n    93→            if (c.op === 'OR') {\n    94→              swapped.add(out);\n    95→            }\n    96→          }\n    97→        }\n    98→      } else {\n    99→        // XOR(partial_sum, carry) -> zNN\n   100→        // Rule 3: Should output to a z wire\n   101→        if (!out.startsWith('z')) {\n   102→          swapped.add(out);\n   103→        }\n   104→      }\n   105→    } else if (gate.op === 'AND') {\n   106→      const isFirstBitAnd =\n   107→        (gate