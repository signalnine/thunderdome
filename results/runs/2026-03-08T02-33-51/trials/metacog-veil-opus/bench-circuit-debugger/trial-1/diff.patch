rtial sum)","     gates = swapOutputs(gates, 'c05', 't06');","     // Swap z03 with a03","     gates = swapOutputs(gates, 'z03', 'a03');","     // Swap z07 with b07","     gates = swapOutputs(gates, 'z07', 'b07');","-    // Swap a09 with b09","-    gates = swapOutputs(gates, 'a09', 'b09');","+    // Swap c01 with z02","+    gates = swapOutputs(gates, 'c01', 'z02');"," ","     const result = findSwappedWires(gates);","-    expect(result).toEqual(['a03', 'a09', 'b07', 'b09', 'c05', 't06', 'z03', 'z07']);","+    expect(result).toEqual(['a03', 'b07', 'c01', 'c05', 't06', 'z02', 'z03', 'z07']);","   });","+","+  it('should detect generate/propagate cross-bit swaps', () => {","+    let gates = buildCorrectAdder(10);","+    // Swap a02 (generate bit 2) with b05 (propagate bit 5) - cross-bit AND swap","+    gates = swapOutputs(gates, 'a02', 'b05');","+    // Swap z03 with c03","+    gates = swapOutputs(gates, 'z03', 'c03');","+    // Swap z08 with t08","+    gates = swapOutputs(gates, 'z08', 't08');","+    // Swap z01 with a01","+    gates = swapOutputs(gates, 'z01', 'a01');","+","+    const result = findSwappedWires(gates);","+    expect(result).toEqual(['a01', 'a02', 'b05', 'c03', 't08', 'z01', 'z03', 'z08']);","+  });"," });"]}],"originalFile":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from '../src/index.js';\n\ndescribe('simulate', () => {\n  it('should simulate basic AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate basic OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate basic XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle dependency ordering', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'b', in2: 'c', out: 'd' }, // depends on c\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' }, // produces c\n    ];\n    const result = simulate(gates, { a: 1, b: 1 });\n    // c = 1 XOR 1 = 0, d = 1 AND 0 = 0\n    expect(result).toEqual({ a: 1, b: 1, c: 0, d: 0 });\n  });\n\n  it('should simulate a correct 4-bit adder', () => {\n    // 4-bit adder: x + y = z\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n\n    // Test: 5 + 3 = 8 (0101 + 0011 = 1000)\n    const inputs = {\n      x00: 1, x01: 0, x02: 1, x03: 0, // 5 = 0101\n      y00: 1, y01: 1, y02: 0, y03: 0, // 3 = 0011\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n    // 8 = 01000\n\n    // Test: 15 + 1 = 16 (1111 + 0001 = 10000)\n    const inputs2 = {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 0, y02: 0, y03: 0,\n    };\n    const result2 = simulate(gates, inputs2);\n    expect(result2.z00).toBe(0);\n    expect(result2.z01).toBe(0);\n    expect(result2.z02).toBe(0);\n    expect(result2.z03).toBe(0);\n    expect(result2.z04).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Build a correct N-bit adder\n  function buildCorrectAdder(bits: number): Gate[] {\n    const gates: Gate[] = [];\n    const pad = (n: number) => n.toString().padStart(2, '0');\n\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: `x00`, in2: `y00`, out: `z00` });\n    gates.push({ op: 'AND', in1: `x00`, in2: `y00`, out: `c00` });\n\n    // Bits 1..bits-1: full adders\n    for (let i = 1; i < bits; i++) {\n      const x = `x${pad(i)}`;\n      const y = `y${pad(i)}`;\n      const z = `z${pad(i)}`;\n      const t = `t${pad(i)}`;\n      const a = `a${pad(i)}`;\n      const b = `b${pad(i)}`;\n      const cIn = `c${pad(i - 1)}`;\n      const cOut = i === bits - 1 ? `z${pad(bits)}` : `c${pad(i)}`;\n\n      gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n      gates.push({ op: 'XOR', in1: t, in2: cIn, out: z });\n      gates.push({ op: 'AND', in1: x, in2: y, out: a });\n      gates.push({ op: 'AND', in1: t, in2: cIn, out: b });\n      gates.push({ op: 'OR', in1: a, in2: b, out: cOut });\n    }\n\n    return gates;\n  }\n\n  // Swap outputs of two gates\n  function swapOutputs(gates: Gate[], out1: string, out2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === out1) return { ...g, out: out2 };\n      if (g.out === out2) return { ...g, out: out1 };\n      return { ...g };\n    });\n  }\n\n  it('should detect swapped z wire and AND output', () => {\n    let gates = buildCorrectAdder(8);\n    // Swap z03 with a03\n    gates = swapOutputs(gates, 'z03', 'a03');\n    // Swap z05 with b05\n    gates = swapOutputs(gates, 'z05', 'b05');\n    // Swap t02 with c02\n    gates = swapOutputs(gates, 't02', 'c02');\n    // Swap a07 with b07\n    gates = swapOutputs(gates, 'a07', 'b07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a03', 'a07', 'b05', 'b07', 'c02', 't02', 'z03', 'z05']);\n  });\n\n  it('should detect swaps with z and XOR(x,y) output', () => {\n    let gates = buildCorrectAdder(10);\n    // Swap z02 with t02 (XOR(x,y) output swapped with the intermediate XOR output)\n    gates = swapOutputs(gates, 'z02', 't02');\n    // Swap z05 with a05\n    gates = swapOutputs(gates, 'z05', 'a05');\n    // Swap c03 with t04\n    gates = swapOutputs(gates, 'c03', 't04');\n    // Swap b08 with a08\n    gates = swapOutputs(gates, 'b08', 'a08');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a05', 'a08', 'b08', 'c03', 't02', 't04', 'z02', 'z05']);\n  });\n\n  it('should handle large circuits (45 bits) quickly', () => {\n    let gates = buildCorrectAdder(45);\n    gates = swapOutputs(gates, 'z10', 'a10');\n    gates = swapOutputs(gates, 'z20', 'b20');\n    gates = swapOutputs(gates, 'z30', 'c30');\n    gates = swapOutputs(gates, 'z40', 't40');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(result).toEqual(['a10', 'b20', 'c30', 't40', 'z10', 'z20', 'z30', 'z40']);\n    expect(elapsed).toBeLessThan(5000);\n  });\n\n  it('should detect swaps between two AND outputs', () => {\n    let gates = buildCorrectAdder(8);\n    // Swap a03 with b03 (both AND outputs)\n    gates = swapOutputs(gates, 'a03', 'b03');\n    // Swap z05 with a05\n    gates = swapOutputs(gates, 'z05', 'a05');\n    // Swap z02 with c02\n    gates = swapOutputs(gates, 'z02', 'c02');\n    // Swap t07 with z07\n    gates = swapOutputs(gates, 't07', 'z07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a03', 'a05', 'b03', 'c02', 't07', 'z02', 'z05', 'z07']);\n  });\n\n  it('should detect swap between OR output and non-z wire', () => {\n    let gates = buildCorrectAdder(10);\n    // Swap c05 (OR output) with t06 (XOR(x,y) output)\n    gates = swapOutputs(gates, 'c05', 't06');\n    // Swap z03 with a03\n    gates = swapOutputs(gates, 'z03', 'a03');\n    // Swap z07 with b07\n    gates = swapOutputs(gates, 'z07', 'b07');\n    // Swap a09 with b09\n    gates = swapOutputs(gates, 'a09', 'b09');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a03', 'a09', 'b07', 'b09', 'c05', 't06', 'z03', 'z07']);\n  });\n});\n"}}
