+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from '../src/index.js';
+
+describe('simulate', () => {
+  it('should simulate basic AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should simulate basic OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should simulate basic XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should handle dependency ordering', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'b', in2: 'c', out: 'd' },
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result).toEqual({ a: 1, b: 1, c: 0, d: 0 });
+  });
+
+  it('should simulate a correct 4-bit adder', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },
+    ];
+
+    // 5 + 3 = 8
+    const result = simulate(gates, {
+      x00: 1, x01: 0, x02: 1, x03: 0,
+      y00: 1, y01: 1, y02: 0, y03: 0,
+    });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(0);
+    expect(result.z02).toBe(0);
+    expect(result.z03).toBe(1);
+    expect(result.z04).toBe(0);
+
+    // 15 + 1 = 16
+    const result2 = simulate(gates, {
+      x00: 1, x01: 1, x02: 1, x03: 1,
+      y00: 1, y01: 0, y02: 0, y03: 0,
+    });
+    expect(result2.z00).toBe(0);
+    expect(result2.z01).toBe(0);
+    expect(result2.z02).toBe(0);
+    expect(result2.z03).toBe(0);
+    expect(result2.z04).toBe(1);
+  });
+});
+
+describe('findSwappedWires', () => {
+  function buildCorrectAdder(bits: number): Gate[] {
+    const gates: Gate[] = [];
+    const pad = (n: number) => n.toString().padStart(2, '0');
+
+    gates.push({ op: 'XOR', in1: `x00`, in2: `y00`, out: `z00` });
+    gates.push({ op: 'AND', in1: `x00`, in2: `y00`, out: `c00` });
+
+    for (let i = 1; i < bits; i++) {
+      const x = `x${pad(i)}`;
+      const y = `y${pad(i)}`;
+      const z = `z${pad(i)}`;
+      const t = `t${pad(i)}`;
+      const a = `a${pad(i)}`;
+      const b = `b${pad(i)}`;
+      const cIn = `c${pad(i - 1)}`;
+      const cOut = i === bits - 1 ? `z${pad(bits)}` : `c${pad(i)}`;
+
+      gates.push({ op: 'XOR', in1: x, in2: y, out: t });
+      gates.push({ op: 'XOR', in1: t, in2: cIn, out: z });
+      gates.push({ op: 'AND', in1: x, in2: y, out: a });
+      gates.push({ op: 'AND', in1: t, in2: cIn, out: b });
+      gates.push({ op: 'OR', in1: a, in2: b, out: cOut });
+    }
+
+    return gates;
+  }
+
+  function swapOutputs(gates: Gate[], out1: string, out2: string): Gate[] {
+    return gates.map(g => {
+      if (g.out === out1) return { ...g, out: out2 };
+      if (g.out === out2) return { ...g, out: out1 };
+      return { ...g };
+    });
+  }
+
+  it('should detect z/AND and z/OR and z/partial-sum swaps', () => {
+    let gates = buildCorrectAdder(8);
+    gates = swapOutputs(gates, 'z03', 'a03');  // z <-> AND(x,y) generate
+    gates = swapOutputs(gates, 'z05', 'b05');  // z <-> AND(t,c) propagate
+    gates = swapOutputs(gates, 'z02', 'c01');  // z <-> OR carry
+    gates = swapOutputs(gates, 'z07', 't07');  // z <-> XOR(x,y) partial sum
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a03', 'b05', 'c01', 't07', 'z02', 'z03', 'z05', 'z07']);
+  });
+
+  it('should detect carry/non-adjacent-partial-sum swap via walk', () => {
+    let gates = buildCorrectAdder(10);
+    // Swap carry c02 with partial sum t05 (non-adjacent, detectable)
+    gates = swapOutputs(gates, 'c02', 't05');
+    // Swap z01 with a01
+    gates = swapOutputs(gates, 'z01', 'a01');
+    // Swap z07 with b07
+    gates = swapOutputs(gates, 'z07', 'b07');
+    // Swap z09 with t09
+    gates = swapOutputs(gates, 'z09', 't09');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'b07', 'c02', 't05', 't09', 'z01', 'z07', 'z09']);
+  });
+
+  it('should handle large circuits (45 bits) quickly', () => {
+    let gates = buildCorrectAdder(45);
+    gates = swapOutputs(gates, 'z10', 'a10');
+    gates = swapOutputs(gates, 'z20', 'b20');
+    gates = swapOutputs(gates, 'z30', 'c30');
+    gates = swapOutputs(gates, 'z40', 't40');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(result).toEqual(['a10', 'b20', 'c30', 't40', 'z10', 'z20', 'z30', 'z40']);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('should detect generate/propagate cross-bit swaps', () => {
+    let gates = buildCorrectAdder(10);
+    // Swap a02 (generate bit 2) with b05 (propagate bit 5)
+    gates = swapOutputs(gates, 'a02', 'b05');
+    // Swap z03 with c03
+    gates = swapOutputs(gates, 'z03', 'c03');
+    // Swap z08 with t08
+    gates = swapOutputs(gates, 'z08', 't08');
+    // Swap z01 with a01
+    gates = swapOutputs(gates, 'z01', 'a01');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'a02', 'b05', 'c03', 't08', 'z01', 'z03', 'z08']);
+  });
+
+  it('should detect swaps involving carry and z wire', () => {
+    let gates = buildCorrectAdder(10);
+    // c05 swapped with z06 (carry becomes z, z becomes carry)
+    gates = swapOutputs(gates, 'c05', 'z06');
+    // z01 with a01
+    gates = swapOutputs(gates, 'z01', 'a01');
+    // z03 with b03
+    gates = swapOutputs(gates, 'z03', 'b03');
