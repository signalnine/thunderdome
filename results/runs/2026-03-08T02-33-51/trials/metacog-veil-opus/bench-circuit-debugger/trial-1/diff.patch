res[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = a & b;\n            break;\n          case 'OR':\n            result = a | b;\n            break;\n          case 'XOR':\n            result = a ^ b;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  // Build lookup structures\n  function findGate(op: Gate['op'], in1: string, in2: string): Gate | undefined {\n    return gates.find(\n      g => g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))\n    );\n  }\n\n  // Determine the number of input bits\n  let maxInputBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const match = wire.match(/^x(\\d+)$/);\n      if (match) {\n        const bit = parseInt(match[1], 10);\n        if (bit > maxInputBit) maxInputBit = bit;\n      }\n    }\n  }\n\n  // Determine the highest z bit\n  let maxZBit = 0;\n  for (const gate of gates) {\n    const match = gate.out.match(/^z(\\d+)$/);\n    if (match) {\n      const bit = parseInt(match[1], 10);\n      if (bit > maxZBit) maxZBit = bit;\n    }\n  }\n\n  const pad = (n: number) => n.toString().padStart(2, '0');\n  const lastZ = `z${pad(maxZBit)}`;\n\n  // Helper: check if a gate takes x,y register inputs\n  function isXYGate(gate: Gate): boolean {\n    return (\n      (gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||\n      (gate.in1.startsWith('y') && gate.in2.startsWith('x'))\n    );\n  }\n\n  // Build maps\n  const consumers = new Map<string, Gate[]>();\n  for (const gate of gates) {\n    if (!consumers.has(gate.in1)) consumers.set(gate.in1, []);\n    if (!consumers.has(gate.in2)) consumers.set(gate.in2, []);\n    consumers.get(gate.in1)!.push(gate);\n    consumers.get(gate.in2)!.push(gate);\n  }\n\n  const gateByOutput = new Map<string, Gate>();\n  for (const gate of gates) {\n    gateByOutput.set(gate.out, gate);\n  }\n\n  // Rule-based checks to catch obvious violations\n  for (const gate of gates) {\n    const out = gate.out;\n    const outConsumers = consumers.get(out) || [];\n\n    if (gate.op === 'XOR') {\n      if (isXYGate(gate)) {\n        // XOR(xNN, yNN) -> partial sum. Should NOT output to z (except z00).\n        if (out.startsWith('z') && out !== 'z00') {\n          swapped.add(out);\n        }\n        // Partial sum should be consumed by XOR and AND, not OR.\n        if (out !== 'z00') {\n          for (const c of outConsumers) {\n            if (c.op === 'OR') {\n              swapped.add(out);\n            }\n          }\n        }\n      } else {\n        // Intermediate XOR should output to z.\n        if (!out.startsWith('z')) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'AND') {\n      const isFirstBitAnd =\n        (gate.in1 === 'x00' && gate.in2 === 'y00') ||\n        (gate.in1 === 'y00' && gate.in2 === 'x00');\n      if (!isFirstBitAnd) {\n        // AND output should be consumed by OR.\n        for (const c of outConsumers) {\n          if (c.op !== 'OR') {\n            swapped.add(out);\n          }\n        }\n      }\n    } else if (gate.op === 'OR') {\n      // OR output (carry) should not be z (except lastZ).\n      if (out.startsWith('z') && out !== lastZ) {\n        swapped.add(out);\n      }\n    }\n\n    // z outputs (except lastZ) must come from XOR gates.\n    if (out.startsWith('z') && out !== lastZ && gate.op !== 'XOR') {\n      swapped.add(out);\n    }\n  }\n\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // Structural walk to find remaining swaps.\n  // The walk traces the carry chain bit by bit.\n  // When a swap is detected, we identify both swapped wires and\n  // continue with the corrected carry.\n\n  let carry: string | undefined;\n\n  // Bit 0: half adder\n  const xorBit0 = findGate('XOR', 'x00', 'y00');\n  const andBit0 = findGate('AND', 'x00', 'y00');\n  if (!xorBit0 || !andBit0) return [...swapped].sort();\n\n  if (xorBit0.out !== 'z00') {\n    swapped.add(xorBit0.out);\n    swapped.add('z00');\n  }\n  carry = andBit0.out;\n\n  // Check if carry got swapped (the AND output might have been swapped)\n  // If carry is already in swapped set, we need to figure out the correct carry.\n  // But for bit 0, the AND(x00,y00) output just feeds into bit 1.\n  // If it was swapped, we'll detect it at bit 1.\n\n  for (let i = 1; i <= maxInputBit; i++) {\n    if (carry === undefined || swapped.size >= 8) break;\n\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n\n    // Find XOR(xN, yN) and AND(xN, yN)\n    const xorXY = findGate('XOR', x, y);\n    const andXY = findGate('AND', x, y);\n    if (!xorXY || !andXY) break;\n\n    let partialSum = xorXY.out;\n    const generate = andXY.out;\n\n    // Find intermediate XOR: XOR(partialSum, carry) -> z\n    let xorIntermediate = findGate('XOR', partialSum, carry);\n\n    if (!xorIntermediate) {\n      // partialSum or carry might be swapped.\n      // Since we're tracing carry through the circuit, carry should be correct\n      // (we corrected it at each step). So partialSum is likely swapped.\n      //\n      // Find a non-XY XOR gate that uses carry as one of its inputs.\n      // That gate's other input tells us what partialSum SHOULD be.\n      const xorCandidates = (consumers.get(carry) || []).filter(\n        g => g.op === 'XOR' && !isXYGate(g)\n      );\n      if (xorCandidates.length === 1) {\n        xorIntermediate = xorCandidates[0];\n        const actualPartial = xorIntermediate.in1 === carry\n          ? xorIntermediate.in2\n          : xorIntermediate.in1;\n        if