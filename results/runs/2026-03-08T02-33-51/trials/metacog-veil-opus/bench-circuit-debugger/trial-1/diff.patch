'c' }, // produces c\n    33→    ];\n    34→    const result = simulate(gates, { a: 1, b: 1 });\n    35→    // c = 1 XOR 1 = 0, d = 1 AND 0 = 0\n    36→    expect(result).toEqual({ a: 1, b: 1, c: 0, d: 0 });\n    37→  });\n    38→\n    39→  it('should simulate a correct 4-bit adder', () => {\n    40→    // 4-bit adder: x + y = z\n    41→    const gates: Gate[] = [\n    42→      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    43→      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    44→\n    45→      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n    46→      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n    47→      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n    48→      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    49→      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n    50→\n    51→      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n    52→      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n    53→      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n    54→      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n    55→      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n    56→\n    57→      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n    58→      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n    59→      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n    60→      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n    61→      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    62→    ];\n    63→\n    64→    // Test: 5 + 3 = 8 (0101 + 0011 = 1000)\n    65→    const inputs = {\n    66→      x00: 1, x01: 0, x02: 1, x03: 0, // 5 = 0101\n    67→      y00: 1, y01: 1, y02: 0, y03: 0, // 3 = 0011\n    68→    };\n    69→    const result = simulate(gates, inputs);\n    70→    expect(result.z00).toBe(0);\n    71→    expect(result.z01).toBe(0);\n    72→    expect(result.z02).toBe(0);\n    73→    expect(result.z03).toBe(1);\n    74→    expect(result.z04).toBe(0);\n    75→    // 8