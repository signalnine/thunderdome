| g.in2 === wire));\n  }\n\n  // Get the other input of a gate given one input\n  function otherInput(gate: Gate, wire: string): string {\n    return gate.in1 === wire ? gate.in2 : gate.in1;\n  }\n\n  // Map from output wire name to gate\n  const gateByOutput = new Map<string, Gate>();\n  for (const gate of gates) {\n    gateByOutput.set(gate.out, gate);\n  }\n\n  // Determine the number of input bits\n  let maxInputBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const match = wire.match(/^x(\\d+)$/);\n      if (match) {\n        const bit = parseInt(match[1], 10);\n        if (bit > maxInputBit) maxInputBit = bit;\n      }\n    }\n  }\n\n  // Determine the highest z bit\n  let maxZBit = 0;\n  for (const gate of gates) {\n    const match = gate.out.match(/^z(\\d+)$/);\n    if (match) {\n      const bit = parseInt(match[1], 10);\n      if (bit > maxZBit) maxZBit = bit;\n    }\n  }\n\n  const pad = (n: number) => n.toString().padStart(2, '0');\n  const lastZ = `z${pad(maxZBit)}`;\n\n  // Use two complementary approaches and combine results:\n  // 1. Rule-based: catches most single-wire violations\n  // 2. Structural walk: catches cross-wire swaps that rules miss\n\n  // ===== APPROACH 1: Rule-based checks =====\n  // Build a map: wire -> list of gates that consume it\n  const consumers = new Map<string, Gate[]>();\n  for (const gate of gates) {\n    if (!consumers.has(gate.in1)) consumers.set(gate.in1, []);\n    if (!consumers.has(gate.in2)) consumers.set(gate.in2, []);\n    consumers.get(gate.in1)!.push(gate);\n    consumers.get(gate.in2)!.push(gate);\n  }\n\n  function isXYGate(gate: Gate): boolean {\n    return (\n      (gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||\n      (gate.in1.startsWith('y') && gate.in2.startsWith('x'))\n    );\n  }\n\n  for (const gate of gates) {\n    const out = gate.out;\n    const outConsumers = consumers.get(out) || [];\n\n    if (gate.op === 'XOR') {\n      if (isXYGate(gate)) {\n        // XOR(xNN, yNN) -> partial sum. Should NOT output to z (except z00).\n        if (out.startsWith('z') && out !== 'z00') {\n          swapped.add(out);\n        }\n        // Partial sum should be consumed by XOR and AND, not OR.\n        if (out !== 'z00') {\n          for (const c of outConsumers) {\n            if (c.op === 'OR') {\n              swapped.add(out);\n            }\n          }\n        }\n      } else {\n        // Intermediate XOR should output to z.\n        if (!out.startsWith('z')) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'AND') {\n      const isFirstBitAnd =\n        (gate.in1 === 'x00' && gate.in2 === 'y00') ||\n        (gate.in1 === 'y00' && gate.in2 === 'x00');\n      if (!isFirstBitAnd) {\n        // AND output should be consumed by OR.\n        for (const c of outConsumers) {\n          if (c.op !== 'OR') {\n            swapped.add(out);\n          }\n        }\n      }\n    } else if (gate.op === 'OR') {\n      // OR output (carry) should not be z (except lastZ).\n      if (out.startsWith('z') && out !== lastZ) {\n        swapped.add(out);\n      }\n    }\n\n    // z outputs (except lastZ) must come from XOR gates.\n    if (out.startsWith('z') && out !== lastZ && gate.op !== 'XOR') {\n      swapped.add(out);\n    }\n  }\n\n  // If we already found 8, done.\n  if (swapped.size === 8) {\n    return [...swapped].sort();\n  }\n\n  // ===== APPROACH 2: Structural walk =====\n  // Walk through the adder bit by bit, tracking the expected carry wire.\n  // When structure doesn't match expectations, identify swaps.\n\n  // For each bit, we expect:\n  // Bit 0: XOR(x00,y00) -> z00; AND(x00,y00) -> carry\n  // Bit N: XOR(xN,yN) -> partialSum; XOR(partialSum, carry) -> zN;\n  //        AND(xN,yN) -> gen; AND(partialSum, carry) -> prop; OR(gen, prop) -> nextCarry\n\n  let carry: string | undefined;\n\n  // Bit 0\n  const xorBit0 = findGate('XOR', 'x00', 'y00');\n  const andBit0 = findGate('AND', 'x00', 'y00');\n\n  if (xorBit0 && andBit0) {\n    // XOR should output z00\n    if (xorBit0.out !== 'z00') {\n      swapped.add(xorBit0.out);\n      swapped.add('z00');\n    }\n    carry = andBit0.out;\n  }\n\n  // Bits 1..maxInputBit\n  for (let i = 1; i <= maxInputBit && carry !== undefined; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n\n    // Find XOR(xN, yN) -> partialSum\n    const xorXY = findGate('XOR', x, y);\n    if (!xorXY) break;\n    let partialSum = xorXY.out;\n\n    // Find AND(xN, yN) -> generate\n    const andXY = findGate('AND', x, y);\n    if (!andXY) break;\n    const generate = andXY.out;\n\n    // Find the intermediate XOR that uses partialSum and carry\n    let xorIntermediate = findGate('XOR', partialSum, carry);\n    if (!xorIntermediate) {\n      // The partialSum or carry might be swapped.\n      // Try to find XOR gate that uses carry as one input\n      const xorWithCarry = findGateWithInput('XOR', carry);\n      if (xorWithCarry && !isXYGate(xorWithCarry)) {\n        // The other input to this XOR should be partialSum but it's something else\n        // This means partialSum was swapped with something\n        const actualPartialInput = otherInput(xorWithCarry, carry);\n        // partialSum was swapped with actualPartialInput? No - partialSum is an output wire.\n        // The gate that should output partialSum has its output swapped.\n        // So partialSum (as a wire name) doesn't exist or exists somewhere else.\n        // Let's swap: the XOR(xN,yN) output is wrong, and the correct wire is actualPartialInput\n        // but we need to figure out which wires are actually swapped.\n\n        // Actually, the XOR(xN,yN) gate output might have been swapped with something.\n        // If the output wire doesn't appear as an input to any intermediate XOR with carry,\n        // then partialSum is swapped.\n        swapped.add(partialSum);\n        // Find what should be there: the other input of the XOR that uses carry\n        const correctPartialSum = actualPartialInput;\n        swapped.add(correctPartialSum);\n        // Swap the wire for the rest of the walk\n        partialSum = correctPartialSum;\n        xorIntermediate = xorWithCarry;\n      } else {\n        // Try: maybe carry was swapped. Find XOR that uses partialSum.\n        const xorWithPartial = findGateWithInput('XOR', partialSum);\n        if (xorWithPartial && !isXYGate(xorWithPartial)) {\n          const actualCarry = otherInput(xorWithPartial, partialSum);\n          swapped.add(carry);\n          swapped.add(actualCarry);\n          carry = actualCarry;\n          xorIntermediate = xorWithPartial;\n        } else {\n          break;\n        }\n      }\n    }\n\n    // Check intermediate XOR outputs z\n    if (xorIntermediate.out !== z) {\n      swapped.add(xorIntermediate.out);\n      swapped.add(z);\n    }\n\n    // Find AND(partialSum, carry) -> propagate\n    const andProp = findGate('AND', partialSum, carry);\n    if (!andProp) break;\n    const propagate = andProp.out;\n\n    // Find OR(generate, propagate) -> nextCarry\n    let orGate = findGate('OR', generate, propagate);\n    if (!orGate) {\n      // generate or propagate might be swapped\n      // Try finding OR gate with generate\n      const orWithGen = findGateWithInput('OR', generate);\n      if (orWithGen) {\n        const actualProp = otherInput(orWithGen, generate);\n        if (actualProp !== propagate) {\n          swapped.add(propagate);\n          swapped.add(actualProp);\n        }\n        orGate = orWithGen;\n      } else {\n        // Try finding OR gate with propagate\n        const orWithProp = findGateWithInput('OR', propagate);\n        if (orWithProp) {\n          const actualGen = otherInput(orWithProp, propagate);\n          if (actualGen !== generate) {\n            swapped.add(generate);\n            swapped.add(actualGen);\n          }\n          orGate = orWithProp;\n        } else {\n          break;\n        }\n      }\n    }\n\n    carry = orGate.out;\n\n    if (swapped.size >= 8) break;\n  }\n\n  return [...swapped].sort();\n}\n"}}
