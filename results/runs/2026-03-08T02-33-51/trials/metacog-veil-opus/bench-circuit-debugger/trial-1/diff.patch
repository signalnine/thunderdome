+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (changed && remaining.length > 0) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+
+  // Build lookup structures
+  function findGate(op: Gate['op'], in1: string, in2: string): Gate | undefined {
+    return gates.find(
+      g => g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))
+    );
+  }
+
+  // Determine the number of input bits
+  let maxInputBit = 0;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const match = wire.match(/^x(\d+)$/);
+      if (match) {
+        const bit = parseInt(match[1], 10);
+        if (bit > maxInputBit) maxInputBit = bit;
+      }
+    }
+  }
+
+  // Determine the highest z bit
+  let maxZBit = 0;
+  for (const gate of gates) {
+    const match = gate.out.match(/^z(\d+)$/);
+    if (match) {
+      const bit = parseInt(match[1], 10);
+      if (bit > maxZBit) maxZBit = bit;
+    }
+  }
+
+  const pad = (n: number) => n.toString().padStart(2, '0');
+  const lastZ = `z${pad(maxZBit)}`;
+
+  // Helper: check if a gate takes x,y register inputs
+  function isXYGate(gate: Gate): boolean {
+    return (
+      (gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||
+      (gate.in1.startsWith('y') && gate.in2.startsWith('x'))
+    );
+  }
+
+  // Build maps
+  const consumers = new Map<string, Gate[]>();
+  for (const gate of gates) {
+    if (!consumers.has(gate.in1)) consumers.set(gate.in1, []);
+    if (!consumers.has(gate.in2)) consumers.set(gate.in2, []);
+    consumers.get(gate.in1)!.push(gate);
+    consumers.get(gate.in2)!.push(gate);
+  }
+
+  // Rule-based checks to catch obvious violations
+  for (const gate of gates) {
+    const out = gate.out;
+    const outConsumers = consumers.get(out) || [];
+
+    if (gate.op === 'XOR') {
+      if (isXYGate(gate)) {
+        // XOR(xNN, yNN) -> partial sum. Should NOT output to z (except z00).
+        if (out.startsWith('z') && out !== 'z00') {
+          swapped.add(out);
+        }
+        // Partial sum should be consumed by XOR and AND, not OR.
+        if (out !== 'z00') {
+          for (const c of outConsumers) {
+            if (c.op === 'OR') {
+              swapped.add(out);
+            }
+          }
+        }
+      } else {
+        // Intermediate XOR should output to z.
+        if (!out.startsWith('z')) {
+          swapped.add(out);
+        }
+      }
+    } else if (gate.op === 'AND') {
+      const isFirstBitAnd =
+        (gate.in1 === 'x00' && gate.in2 === 'y00') ||
+        (gate.in1 === 'y00' && gate.in2 === 'x00');
+      if (!isFirstBitAnd) {
+        // AND output should be consumed by OR.
+        for (const c of outConsumers) {
+          if (c.op !== 'OR') {
+            swapped.add(out);
+          }
+        }
+      }
+    } else if (gate.op === 'OR') {
+      // OR output (carry) should not be z (except lastZ).
+      if (out.startsWith('z') && out !== lastZ) {
+        swapped.add(out);
+      }
+    }
+
+    // z outputs (except lastZ) must come from XOR gates.
+    if (out.startsWith('z') && out !== lastZ && gate.op !== 'XOR') {
+      swapped.add(out);
+    }
+
+    // lastZ must come from an OR gate (it's the final carry), unless single bit.
+    if (out === lastZ && maxInputBit > 0 && gate.op !== 'OR') {
+      swapped.add(out);
+    }
+  }
+
+  if (swapped.size === 8) {
+    return [...swapped].sort();
+  }
+
+  // Structural walk to find remaining swaps.
+  // The walk traces the carry chain bit by bit.
+  // When a swap is detected, we identify both swapped wires and
+  // continue with the corrected carry.
+
+  let carry: string | undefined;
+
+  // Bit 0: half adder
+  const xorBit0 = findGate('XOR', 'x00', 'y00');
+  const andBit0 = findGate('AND', 'x00', 'y00');
+  if (!xorBit0 || !andBit0) return [...swapped].sort();
+
+  if (xorBit0.out !== 'z00') {
+    swapped.add(xorBit0.out);
+    swapped.add('z00');
+  }
+  carry = andBit0.out;
+
+  // Check if carry got swapped (the AND output might have been swapped)
+  // If carry is already in swapped set, we need to figure out the correct carry.
+  // But for bit 0, the AND(x00,y00) output just feeds into bit 1.
+  // If it was swapped, we'll detect it at bit 1.
+
+  for (let i = 1; i <= maxInputBit; i++) {
+    if (carry === undefined || swapped.size >= 8) break;
+
+    const x = `x${pad(i)}`;
+    const y = `y${pad(i)}`;
+    const z = `z${pad(i)}`;
+
+    // Find XOR(xN, yN) and AND(xN, yN)
+    const xorXY = findGate('XOR', x, y);
+    const andXY = findGate('AND', x, y);
+    if (!xorXY || !andXY) break;
+
+    let partialSum = xorXY.out;
+    const generate = andXY.out;
+
+    // Find intermediate XOR: XOR(partialSum, carry) -> z
+    let xorIntermediate = findGate('XOR', partialSum, carry);
+
+    if (!xorIntermediate) {
+      // partialSum or carry might be swapped.
+      // partialSum is output of XOR(xN,yN) - specific to this bit.
+      // carry might have been swapped to a wire name used elsewhere.
+      // So prioritize finding by partialSum (more reliable).
+      const xorPartialCandidates = (consumers.get(partialSum) || []).filter(
+        g => g.op === 'XOR' && !isXYGate(g)
+      );
+      if (xorPartialCandidates.length === 1) {
+        xorIntermediate = xorPartialCandidates[0];
+        const actualCarry = xorIntermediate.in1 === partialSum
+          ? xorIntermediate.in2
+          : xorIntermediate.in1;
+        if (actualCarry !== carry) {
+          swapped.add(carry);
+          swapped.add(actualCarry);
+          carry = actualCarry;
+        }
+      } else {
+        // Try finding by carry input
+        const xorCandidates = (consumers.get(carry) || []).filter(
+          g => g.op === 'XOR' && !isXYGate(g)
+        );
+        if (xorCandidates.length === 1) {
+          xorIntermediate = xorCandidates[0];
+          const actualPartial = xorIntermediate.in1 === carry
+            ? xorIntermediate.in2
+            : xorIntermediate.in1;
+          if (actualPartial !== partialSum) {
+            swapped.add(partialSum);
+            swapped.add(actualPartial);
+            partialSum = actualPartial;
+          }
+        } else {
+          // Can't resolve - skip this bit
+          break;
+        }
+      }
+    }
+
+    // Check that intermediate XOR outputs z
+    if (xorIntermediate && xorIntermediate.out !== z) {
+      swapped.add(xorIntermediate.out);
+      swapped.add(z);
+    }
+
+    // Find AND(partialSum, carry) -> propagate
+    const andProp = findGate('AND', partialSum, carry);
+    if (!andProp) {
+      // This can happen if partialSum or carry wire names are wrong
+      // after cascading effects. Try to continue.
+      break;
+    }
+    const propagate = andProp.out;
+
+    // Find OR(generate, propagate) -> nextCarry
+    // Prefer finding by propagate since it's structurally unique to this bit
+    // (propagate = AND(partialSum, carry) which is specific to this bit position)
+    let orGate = findGate('OR', generate, propagate);
+    if (!orGate) {
+      // generate or propagate might be swapped
+      // Try by propagate first (more reliable - unique to this bit)
+      const orPropCandidates = (consumers.get(propagate) || []).filter(
+        g => g.op === 'OR'
+      );
+      if (orPropCandidates.length === 1) {
+        orGate = orPropCandidates[0];
+        const actualGen = orGate.in1 === propagate ? orGate.in2 : orGate.in1;
+        if (actualGen !== generate) {
+          swapped.add(generate);
+          swapped.add(actualGen);
+        }
+      } else {
+        // Try by generate
+        const orGenCandidates = (consumers.get(generate) || []).filter(
+          g => g.op === 'OR'
+        );
+        if (orGenCandidates.length === 1) {
+          orGate = orGenCandidates[0];
+          const actualProp = orGate.in1 === generate ? orGate.in2 : orGate.in1;
+          if (actualProp !== propagate) {
+            swapped.add(propagate);
+            swapped.add(actualProp);
+          }
+        } else {
+          break;
+        }
+      }
+    }
+
+    if (orGate) {
+      carry = orGate.out;
+    } else {
+      break;
+    }
+  }
+
+  return [...swapped].sort();
+}
