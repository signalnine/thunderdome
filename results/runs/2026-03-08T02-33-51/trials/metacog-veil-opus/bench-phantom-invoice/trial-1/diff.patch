+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WA1oSbD7ZVR6BgEMvtj4Mr","type":"tool_result","content":"     1→/**\n     2→ * Format a Date object to an ISO date string (YYYY-MM-DD).\n     3→ * Uses UTC methods to avoid timezone-related shifts.\n     4→ */\n     5→// TODO: fix timezone\n     6→export function formatDate(date: Date): string {\n     7→  const year = date.getUTCFullYear();\n     8→  const month = String(date.getUTCMonth() + 1).padStart(2, '0');\n     9→  const day = String(date.getUTCDate()).padStart(2, '0');\n    10→  return `${year}-${month}-${day}`;\n    11→}\n    12→\n    13→/**\n    14→ * Parse an ISO date string (YYYY-MM-DD) into a Date object.\n    15→ * Creates the date in UTC to avoid timezone issues.\n    16→ */\n    17→export function parseDate(str: string): Date {\n    18→  const [year, month, day] = str.split('-').map(Number);\n    19→  return new Date(Date.UTC(year, month - 1, day));\n    20→}\n    21→\n    22→/**\n    23→ * Get the start and end dates for a given month.\n    24→ * Returns ISO date strings for the first and last day of the month.\n    25→ */\n    26→export function getMonthRange(year: number, month: number): { start: string; end: string } {\n    27→  const start = new Date(Date.UTC(year, month - 1, 1));\n    28→  const end = new Date(Date.UTC(year, month, 0)); // last day of the month\n    29→  return {\n    30→    start: formatDate(start),\n    31→    end: formatDate(end),\n    32→  };\n    33→}\n    34→\n    35→/**\n    36→ * Check if a date string falls within a range (inclusive).\n    37→ */\n    38→export function isDateInRange(date: string, start: string, end: string): boolean {\n    39→  return date >= start && date <= end;\n    40→}\n    41→"}]},"parent_tool_use_id":null,"session_id":"cb37e3a9-ecc1-423e-ad63-8ba181e5ba8e","uuid":"7ecf72d4-3370-4299-8f36-1c847999f989","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/utils/dates.ts","content":"/**\n * Format a Date object to an ISO date string (YYYY-MM-DD).\n * Uses UTC methods to avoid timezone-related shifts.\n */\n// TODO: fix timezone\nexport function formatDate(date: Date): string {\n  const year = date.getUTCFullYear();\n  const month = String(date.getUTCMonth() + 1).padStart(2, '0');\n  const day = String(date.getUTCDate()).padStart(2, '0');\n  return `${year}-${month}-${day}`;\n}\n\n/**\n * Parse an ISO date string (YYYY-MM-DD) into a Date object.\n * Creates the date in UTC to avoid timezone issues.\n */\nexport function parseDate(str: string): Date {\n  const [year, month, day] = str.split('-').map(Number);\n  return new Date(Date.UTC(year, month - 1, day));\n}\n\n/**\n * Get the start and end dates for a given month.\n * Returns ISO date strings for the first and last day of the month.\n */\nexport function getMonthRange(year: number, month: number): { start: string; end: string } {\n  const start = new Date(Date.UTC(year, month - 1, 1));\n  const end = new Date(Date.UTC(year, month, 0)); // last day of the month\n  return {\n    start: formatDate(start),\n    end: formatDate(end),\n  };\n}\n\n/**\n * Check if a date string falls within a range (inclusive).\n */\nexport function isDateInRange(date: string, start: string, end: string): boolean {\n  return date >= start && date <= end;\n}\n","numLines":41,"startLine":1,"totalLines":41}}}
