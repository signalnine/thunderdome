+describe('Phase 11: Middleware Pipeline', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should run middleware before handler', async () => {
+    const order: string[] = [];
+
+    queue.use('default', async (_task, next) => {
+      order.push('middleware');
+      await next();
+    });
+
+    queue.process('default', async () => {
+      order.push('handler');
+    });
+
+    queue.addTask('test');
+    const task = queue.getNextTask()!;
+    await queue.processTask(task.id);
+
+    expect(order).toEqual(['middleware', 'handler']);
+  });
+
+  it('should run middleware in order', async () => {
+    const order: string[] = [];
+
+    queue.use('default', async (_task, next) => {
+      order.push('first');
+      await next();
+    });
+
+    queue.use('default', async (_task, next) => {
+      order.push('second');
+      await next();
+    });
+
+    queue.process('default', async () => {
+      order.push('handler');
+    });
+
+    queue.addTask('test');
+    const task = queue.getNextTask()!;
+    await queue.processTask(task.id);
+
+    expect(order).toEqual(['first', 'second', 'handler']);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const handlerCalled = vi.fn();
+
+    queue.use('default', async () => {
+      // intentionally not calling next
+    });
+
+    queue.process('default', handlerCalled);
+
+    queue.addTask('test');
+    const task = queue.getNextTask()!;
+    await queue.processTask(task.id);
+
+    expect(handlerCalled).not.toHaveBeenCalled();
+  });
+
+  it('should allow middleware to modify task', async () => {
+    queue.use('default', async (task, next) => {
+      (task as any).payload = { ...task.payload as any, modified: true };
+      await next();
+    });
+
+    let receivedPayload: any;
+    queue.process('default', async (task) => {
+      receivedPayload = task.payload;
+    });
+
+    queue.addTask({ original: true });
+    const task = queue.getNextTask()!;
+    await queue.processTask(task.id);
+
+    expect(receivedPayload).toEqual({ original: true, modified: true });
+  });
+
+  it('should fail task when middleware throws', async () => {
+    queue.use('default', async () => {
+      throw new Error('middleware error');
+    });
+
+    queue.addTask('test', { maxRetries: 0, backoffDelay: 0 });
+    const task = queue.getNextTask()!;
+
+    await expect(queue.processTask(task.id)).rejects.toThrow('middleware error');
+    expect(task.error).toBe('middleware error');
+  });
+
+  it('should have independent middleware per queue', async () => {
+    const q1Order: string[] = [];
+    const q2Order: string[] = [];
+
+    queue.use('q1', async (_task, next) => {
+      q1Order.push('q1-mw');
+      await next();
+    });
+
+    queue.use('q2', async (_task, next) => {
+      q2Order.push('q2-mw');
+      await next();
+    });
+
+    queue.process('q1', async () => { q1Order.push('q1-handler'); });
+    queue.process('q2', async () => { q2Order.push('q2-handler'); });
+
+    queue.addTask('a', 'q1');
+    queue.addTask('b', 'q2');
+
+    const t1 = queue.getNextTask('q1')!;
+    const t2 = queue.getNextTask('q2')!;
+
+    await queue.processTask(t1.id);
+    await queue.processTask(t2.id);
+
+    expect(q1Order).toEqual(['q1-mw', 'q1-handler']);
+    expect(q2Order).toEqual(['q2-mw', 'q2-handler']);
+  });
+
+  it('should register handler per queue', async () => {
+    const result: string[] = [];
+
+    queue.process('default', async (task) => {
+      result.push(task.payload as string);
+    });
+
+    queue.addTask('hello');
+    const task = queue.getNextTask()!;
+    await queue.processTask(task.id);
+
+    expect(result).toEqual(['hello']);
+  });
+});
