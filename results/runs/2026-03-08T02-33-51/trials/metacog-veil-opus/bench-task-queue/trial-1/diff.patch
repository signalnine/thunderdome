diff --git a/src/cron.ts b/src/cron.ts
new file mode 100644
index 0000000..04eece9
--- /dev/null
+++ b/src/cron.ts
@@ -0,0 +1,79 @@
+export interface ParsedCron {
+  minute: number | { every: number };
+  hour: number | null;
+}
+
+export function parseCron(expression: string): ParsedCron {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: ${expression}`);
+  }
+
+  const [minutePart, hourPart, dayOfMonth, month, dayOfWeek] = parts;
+
+  // We only support expressions where day-of-month, month, and day-of-week are all wildcards
+  if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {
+    throw new Error(`Unsupported cron expression: ${expression}. Only */N * * * *, 0 * * * *, and 0 0 * * * are supported.`);
+  }
+
+  const result: ParsedCron = { minute: 0, hour: null };
+
+  // Parse minute
+  if (minutePart.startsWith('*/')) {
+    const n = parseInt(minutePart.slice(2), 10);
+    if (isNaN(n) || n <= 0 || n > 59) {
+      throw new Error(`Invalid cron minute interval: ${minutePart}`);
+    }
+    result.minute = { every: n };
+  } else {
+    const m = parseInt(minutePart, 10);
+    if (isNaN(m) || m < 0 || m > 59) {
+      throw new Error(`Invalid cron minute: ${minutePart}`);
+    }
+    result.minute = m;
+  }
+
+  // Parse hour
+  if (hourPart === '*') {
+    result.hour = null;
+  } else {
+    const h = parseInt(hourPart, 10);
+    if (isNaN(h) || h < 0 || h > 23) {
+      throw new Error(`Invalid cron hour: ${hourPart}`);
+    }
+    result.hour = h;
+  }
+
+  return result;
+}
+
+export function shouldRunAt(parsed: ParsedCron, date: Date, lastRun: Date | undefined): boolean {
+  const minute = date.getMinutes();
+  const hour = date.getHours();
+
+  // Check if this time matches the cron pattern
+  let minuteMatch = false;
+  if (typeof parsed.minute === 'object') {
+    // */N pattern - matches when minute is divisible by N
+    minuteMatch = minute % parsed.minute.every === 0;
+  } else {
+    minuteMatch = minute === parsed.minute;
+  }
+
+  if (!minuteMatch) return false;
+
+  // Check hour
+  if (parsed.hour !== null && hour !== parsed.hour) return false;
+
+  // Check if we already ran at this matching time
+  if (lastRun) {
+    // Truncate both to minute precision for comparison
+    const lastRunMinute = new Date(lastRun.getFullYear(), lastRun.getMonth(), lastRun.getDate(), lastRun.getHours(), lastRun.getMinutes());
+    const currentMinute = new Date(date.getFullYear(), date.getMonth(), date.getDate(), date.getHours(), date.getMinutes());
+    if (currentMinute.getTime() <= lastRunMinute.getTime()) {
+      return false;
+    }
+  }
+
+  return true;
+}
