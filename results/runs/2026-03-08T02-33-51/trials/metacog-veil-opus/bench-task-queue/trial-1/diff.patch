nceCounter++);\n    queue.tasks.set(task.id, task);\n    this.allTasks.set(task.id, task);\n\n    // If dependencies are specified, resolve any that are already completed\n    if (task.dependencies.length > 0) {\n      for (const depId of task.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (depTask && depTask.status === 'completed') {\n          task.resolvedDependencies.add(depId);\n        }\n      }\n    }\n\n    return task;\n  }\n\n  // Phase 7: Check circular dependencies\n  private checkCircularDependencies(dependencyIds: string[]): void {\n    // Check for cycles in the dependency graph\n    // Since the new task doesn't exist yet, we check if there are cycles\n    // among the existing dependency chains of the specified dependencies\n    const visited = new Set<string>();\n\n    const detectCycle = (taskId: string, path: Set<string>): void => {\n      if (path.has(taskId)) {\n        throw new Error(`Circular dependency detected involving task: ${taskId}`);\n      }\n      if (visited.has(taskId)) return;\n\n      visited.add(taskId);\n      path.add(taskId);\n\n      const task = this.allTasks.get(taskId);\n      if (task) {\n        for (const depId of task.dependencies) {\n          detectCycle(depId, new Set(path));\n        }\n      }\n\n      path.delete(taskId);\n    };\n\n    for (const depId of dependencyIds) {\n      detectCycle(depId, new Set<string>());\n    }\n  }\n\n  // Phase 1: Get next task from queue\n  getNextTask(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return null;\n\n    // Phase 8: Check concurrency limit\n    if (queue.concurrencyLimit !== null) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= queue.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of queue.tasks.values()) {\n      if (task.status !== 'pending') continue;\n\n      // Phase 7: Skip blocked tasks\n      if (task.dependencies.length > 0) {\n        const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n        if (!allResolved) continue;\n      }\n\n      // Phase 4: Check availability time\n      if (task.availableAt > now) continue;\n\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort: priority (lower number = higher priority), then availability time, then FIFO (sequenceNumber)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const aTime = a.availableAt.getTime();\n      const bTime = b.availableAt.getTime();\n      if (aTime !== bTime) return aTime - bTime;\n      return a.sequenceNumber - b.sequenceNumber;\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt++;\n    task.progress = { percentage: 0 };\n    return task;\n  }\n\n  // Phase 1: Count pending tasks\n  pendingCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const task of queue.tasks.values()) {\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // Phase 2: List all queue names\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // Phase 5: Complete a task\n  completeTask(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in '${task.status}' state`);\n    }\n    task.status = 'completed';\n    task.progress = { percentage: 100 };\n\n    // Phase 7: Resolve dependencies\n    this.resolveDependencies(taskId);\n  }\n\n  // Phase 5: Fail a task\n  failTask(taskId: string, error?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in '${task.status}' state`);\n    }\n\n    task.error = error;\n    task.failureCount++;\n\n    // Check retries\n    if (task.attempt < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = { percentage: 0 };\n    } else {\n      task.status = 'failed';\n      // Phase 6: Move to dead letter queue\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // Phase 6: Move to dead letter queue\n  private moveToDeadLetterQueue(task: Task): void {\n    const queue = this.getQueue(task.queueName);\n    queue.deadLetterQueue.push(task);\n    // Remove from active queue\n    queue.tasks.delete(task.id);\n  }\n\n  // Phase 6: Get dead letter queue tasks\n  getDeadLetterQueue(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return [];\n    return [...queue.deadLetterQueue];\n  }\n\n  // Phase 6: Retry a dead-lettered task\n  retryDeadLetter(taskId: string): Task {\n    // Find the task in any DLQ\n    for (const queue of this.queues.values()) {\n      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const task = queue.deadLetterQueue[index];\n        queue.deadLetterQueue.splice(index, 1);\n        // Reset for fresh retries\n        task.status = 'pending';\n        task.attempt = 0;\n        task.failureCount = 0;\n        task.error = undefined;\n        task.availableAt = new Date();\n        task.progress = { percentage: 0 };\n        task.sequenceNumber = queue.sequenceCounter++;\n        queue.tasks.set(task.id, task);\n        return task;\n      }\n    }\n    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n  }\n\n  // Phase 6: Clear dead letter queue\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (queue) {\n      // Remove from allTasks as well\n      for (const task of queue.deadLetterQueue) {\n        this.allTasks.delete(task.id);\n      }\n      queue.deadLetterQueue = [];\n    }\n  }\n\n  // Phase 7: Resolve dependencies when a task completes\n  private resolveDependencies(completedTaskId: string): void {\n    for (const task of this.allTasks.values()) {\n      if (task.status === 'pending' && task.dependencies.includes(completedTaskId)) {\n        task.resolvedDependencies.add(completedTaskId);\n      }\n    }\n  }\n\n  // Phase 7: Get dependency status\n  getDependencyStatus(taskId: string): DependencyStatus {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved = Array.from(task.resolvedDependencies);\n    const pending = task.dependencies.filter(depId => !task.resolvedDependencies.has(depId));\n\n    return {\n      dependencies: [...task.dependencies],\n      resolved,\n      pending,\n      isBlocked: pending.length > 0,\n    };\n  }\n\n  // Phase 8: Set concurrency limit\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queue = this.getQueue(queueName);\n    queue.concurrencyLimit = limit;\n  }\n\n  // Phase 8: Get concurrency limit\n  getConcurrencyLimit(queueName?: string): number | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    return queue?.concurrencyLimit ?? null;\n  }\n\n  // Phase 8: Get active (processing) count\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const task of queue.tasks.values()) {\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // Phase 9: Report progress\n  reportProgress(taskId: string, percentage: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in '${task.status}' state`);\n    }\n\n    if (percentage < 0 || percentage > 100) {\n      throw new Error(`Progress percentage must be between 0 and 100, got ${percentage}`);\n    }\n\n    task.progress = { percentage, message };\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener({ percentage, message });\n      }\n    }\n  }\n\n  // Phase 9: Get progress\n  getProgress(taskId: string): ProgressInfo {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { ...task.progress };\n  }\n\n  // Phase 9: Subscribe to progress\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  // Phase 9: Cancel a task\n  cancelTask(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Cannot cancel task in '${task.status}' s