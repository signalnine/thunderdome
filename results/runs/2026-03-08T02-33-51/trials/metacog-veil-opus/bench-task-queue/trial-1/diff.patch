\n\n  // Phase 11: Register middleware\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const queue = this.getQueue(queueName);\n    queue.middlewares.push(middleware);\n  }\n\n  // Phase 11: Register handler\n  process(queueName: string, handler: HandlerFn): void {\n    const queue = this.getQueue(queueName);\n    queue.handler = handler;\n  }\n\n  // Phase 11: Process a task through middleware pipeline and handler\n  async processTask(taskId: string): Promise<void> {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const queue = this.queues.get(task.queueName);\n    if (!queue) throw new Error(`Queue not found: ${task.queueName}`);\n\n    const middlewares = [...queue.middlewares];\n    const handler = queue.handler;\n\n    let index = 0;\n\n    const runNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        await mw(task, runNext);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    try {\n      await runNext();\n    } catch (err) {\n      const errorMessage = err instanceof Error ? err.message : String(err);\n      // Only fail the task if it's still in processing state\n      if (task.status === 'processing') {\n        this.failTask(taskId, errorMessage);\n      }\n      throw err;\n    }\n  }\n\n  // Phase 12: Register shutdown callback\n  onShutdown(callback: () => Promise<void> | void): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  // Phase 12: Shutdown\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(options);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    const