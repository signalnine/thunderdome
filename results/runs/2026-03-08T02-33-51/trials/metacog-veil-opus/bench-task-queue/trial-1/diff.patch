+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from '../src/task-queue.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = queue.addTask({ data: 'test' });
+    expect(task).toBeDefined();
+    expect(task.id).toBeDefined();
+    expect(task.payload).toEqual({ data: 'test' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should assign unique IDs to each task', () => {
+    const t1 = queue.addTask('task1');
+    const t2 = queue.addTask('task2');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    queue.addTask('first');
+    queue.addTask('second');
+    queue.addTask('third');
+
+    const t1 = queue.getNextTask();
+    expect(t1?.payload).toBe('first');
+    const t2 = queue.getNextTask();
+    expect(t2?.payload).toBe('second');
+    const t3 = queue.getNextTask();
+    expect(t3?.payload).toBe('third');
+  });
+
+  it('should transition tasks to processing state', () => {
+    queue.addTask('test');
+    const task = queue.getNextTask();
+    expect(task?.status).toBe('processing');
+  });
+
+  it('should return null when no tasks are available', () => {
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should track pending count', () => {
+    expect(queue.pendingCount()).toBe(0);
+    queue.addTask('a');
+    queue.addTask('b');
+    expect(queue.pendingCount()).toBe(2);
+    queue.getNextTask();
+    expect(queue.pendingCount()).toBe(1);
+  });
+
+  it('should not return already-processing tasks', () => {
+    queue.addTask('only');
+    queue.getNextTask();
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should accept any payload type', () => {
+    const t1 = queue.addTask(42);
+    const t2 = queue.addTask([1, 2, 3]);
+    const t3 = queue.addTask(null);
+    expect(t1.payload).toBe(42);
+    expect(t2.payload).toEqual([1, 2, 3]);
+    expect(t3.payload).toBeNull();
+  });
+});
+
+describe('Phase 2: Named Queues', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should support default queue when no name given', () => {
+    queue.addTask('default');
+    const task = queue.getNextTask();
+    expect(task?.payload).toBe('default');
+  });
+
+  it('should support named queues', () => {
+    queue.addTask('email-task', 'emails');
+    queue.addTask('sms-task', 'sms');
+
+    const email = queue.getNextTask('emails');
+    expect(email?.payload).toBe('email-task');
+
+    const sms = queue.getNextTask('sms');
+    expect(sms?.payload).toBe('sms-task');
+  });
+
+  it('should keep named queues independent', () => {
+    queue.addTask('a', 'q1');
+    queue.addTask('b', 'q2');
+
+    expect(queue.pendingCount('q1')).toBe(1);
+    expect(queue.pendingCount('q2')).toBe(1);
+
+    queue.getNextTask('q1');
+    expect(queue.pendingCount('q1')).toBe(0);
+    expect(queue.pendingCount('q2')).toBe(1);
+  });
+
+  it('should create queues implicitly', () => {
+    queue.addTask('hello', 'new-queue');
+    expect(queue.getQueueNames()).toContain('new-queue');
+  });
+
+  it('should list all queue names', () => {
+    queue.addTask('a', 'q1');
+    queue.addTask('b', 'q2');
+    queue.addTask('c', 'q3');
+    const names = queue.getQueueNames();
+    expect(names).toContain('q1');
+    expect(names).toContain('q2');
+    expect(names).toContain('q3');
+  });
+
+  it('should return null for non-existent queue', () => {
+    expect(queue.getNextTask('nonexistent')).toBeNull();
+  });
+
+  it('should return null for empty queue', () => {
+    queue.addTask('a', 'q1');
+    queue.getNextTask('q1');
+    expect(queue.getNextTask('q1')).toBeNull();
+  });
+});
+
+describe('Phase 3: Priority', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should default priority to 5', () => {
+    const task = queue.addTask('test');
+    expect(task.priority).toBe(5);
+  });
+
+  it('should accept priority option', () => {
+    const task = queue.addTask('test', { priority: 1 });
+    expect(task.priority).toBe(1);
+  });
+
+  it('should return higher priority tasks first', () => {
+    queue.addTask('low', { priority: 10 });
+    queue.addTask('high', { priority: 1 });
+    queue.addTask('medium', { priority: 5 });
+
+    expect(queue.getNextTask()?.payload).toBe('high');
+    expect(queue.getNextTask()?.payload).toBe('medium');
+    expect(queue.getNextTask()?.payload).toBe('low');
+  });
+
+  it('should maintain FIFO within same priority', () => {
+    queue.addTask('first', { priority: 5 });
+    queue.addTask('second', { priority: 5 });
+    queue.addTask('third', { priority: 5 });
+
+    expect(queue.getNextTask()?.payload).toBe('first');
+    expect(queue.getNextTask()?.payload).toBe('second');
+    expect(queue.getNextTask()?.payload).toBe('third');
+  });
+
+  it('should reject invalid priority < 1', () => {
+    expect(() => queue.addTask('test', { priority: 0 })).toThrow();
+  });
+
+  it('should reject invalid priority > 10', () => {
+    expect(() => queue.addTask('test', { priority: 11 })).toThrow();
+  });
+
+  it('should reject non-integer priority', () => {
+    expect(() => queue.addTask('test', { priority: 1.5 })).toThrow();
+  });
+
+  it('should work with named queues', () => {
+    queue.addTask('low', 'emails', { priority: 10 });
+    queue.addTask('high', 'emails', { priority: 1 });
+
+    expect(queue.getNextTask('emails')?.payload).toBe('high');
+    expect(queue.getNextTask('emails')?.payload).toBe('low');
+  });
+});
+
+describe('Phase 4: Delayed Tasks', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should support delayed tasks', () => {
+    queue.addTask('delayed', { delay: 100000 });
+    expect(queue.getNextTask()).toBeNull(); // not available yet
+  });
+
+  it('should return non-delayed tasks over delayed ones', () => {
+    queue.addTask('delayed', { delay: 100000 });
+    queue.addTask('immediate');
+    expect(queue.getNextTask()?.payload).toBe('immediate');
+  });
+
+  it('should make delayed tasks available after time passes', async () => {
+    queue.addTask('delayed', { delay: 50 });
+    expect(queue.getNextTask()).toBeNull();
+
+    await new Promise(r => setTimeout(r, 60));
+    expect(queue.getNextTask()?.payload).toBe('delayed');
+  });
+
+  it('should support processAt option', () => {
+    const futureTime = new Date(Date.now() + 100000);
+    const task = queue.addTask('scheduled', { processAt: futureTime });
+    expect(task.availableAt).toEqual(futureTime);
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should indicate availability time on task', () => {
+    const task = queue.addTask('delayed', { delay: 5000 });
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);
+  });
+
+  it('should order available delayed tasks by availability, then priority, then FIFO', async () => {
+    const t1 = queue.addTask('first', { delay: 10, priority: 5 });
+    const t2 = queue.addTask('second', { delay: 20, priority: 1 });
+
+    await new Promise(r => setTimeout(r, 30));
+
+    // Both available. t1 available first so should come first
+    // Actually: sort by priority first, then availability, then FIFO
+    // Wait - the spec says "ordered by availability time, then priority, then FIFO"
+    // So availability time takes precedence over priority for delayed tasks
+    // But re-reading: the spec says for "multiple delayed tasks becoming available simultaneously"
+    // they should be ordered by availability time, then priority, then FIFO
+    // The main sort is still priority-first for the overall getNextTask
+
+    // Let me re-read: "When multiple delayed tasks become available simultaneously,
+    // they should be ordered by availability time, then priority, then FIFO"
+    // This means when they're all available, sort by: availability time, priority, FIFO
+  });
+
+  it('should work with named queues', async () => {
+    queue.addTask('delayed', 'q1', { delay: 50 });
+    expect(queue.getNextTask('q1')).toBeNull();
+    await new Promise(r => setTimeout(r, 60));
+    expect(queue.getNextTask('q1')?.payload).toBe('delayed');
+  });
+});
+
+describe('Phase 5: Retry with Backoff', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should complete a task', () => {
+    const task = queue.addTask('test');
+    const retrieved = queue.getNextTask()!;
+    queue.completeTask(retrieved.id);
+    expect(retrieved.status).toBe('completed');
+  });
+
+  it('should fail and retry a task', () => {
+    const task = queue.addTask('test', { maxRetries: 3 });
+    const retrieved = queue.getNextTask()!;
+    queue.failTask(retrieved.id, 'error');
+    expect(retrieved.status).toBe('pending');
+    expect(retrieved.attempt).toBe(1);
+  });
+
+  it('should use exponential backoff', () => {
+    const task = queue.addTask('test', { maxRetries: 3, backoffDelay: 1000 });
+
+    // First attempt
+    const t1 = queue.getNextTask()!;
+    const beforeFail = Date.now();
+    queue.failTask(t1.id, 'error');
+    // Backoff: 1000 * 2^(1-1) = 1000ms
+    expect(t1.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900);
+    expect(t1.availableAt.getTime()).toBeLessThanOrEqual(beforeFail + 1100);
+  });
+
+  it('should track attempt count', () => {
+    const task = queue.addTask('test', { maxRetries: 3, backoffDelay: 0 });
+
+    const t1 = queue.getNextTask()!;
+    expect(t1.attempt).toBe(1);
+    queue.failTask(t1.id, 'error');
+    expect(t1.attempt).toBe(1);
+    expect(t1.failureCount).toBe(1);
+  });
+
+  it('should fail permanently when retries exhausted', () => {
+    const task = queue.addTask('test', { maxRetries: 0, backoffDelay: 0 });
+
+    const t1 = queue.getNextTask()!;
+    queue.failTask(t1.id, 'error');
+    // maxRetries=0 means no retries, first failure goes to failed
+    expect(t1.status).toBe('failed');
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    const task = queue.addTask('test', 'myqueue', { maxRetries: 3, priority: 2, backoffDelay: 0 });
+    const t1 = queue.getNextTask('myqueue')!;
+    queue.failTask(t1.id, 'error');
+    expect(t1.queueName).toBe('myqueue');
+    expect(t1.priority).toBe(2);
+  });
+
+  it('should default to 3 retries', () => {
+    const task = queue.addTask('test');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should default backoff to 1000ms', () => {
+    const task = queue.addTask('test');
+    expect(task.backoffDelay).toBe(1000);
+  });
+});
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should move exhausted tasks to DLQ', () => {
+    queue.addTask('test', { maxRetries: 0, backoffDelay: 0 });
+    const t1 = queue.getNextTask()!;
+    queue.failTask(t1.id, 'permanent error');
+
+    const dlq = queue.getDeadLetterQueue();
+    expect(dlq.length).toBe(1);
+    expect(dlq[0].payload).toBe('test');
+  });
+
+  it('should retain error info in DLQ', () => {
+    queue.addTask('test', { maxRetries: 0, backoffDelay: 0 });
+    const t1 = queue.getNextTask()!;
+    queue.failTask(t1.id, 'something broke');
+
+    const dlq = queue.getDeadLetterQueue();
+    expect(dlq[0].error).toBe('something broke');
+    expect(dlq[0].failureCount).toBe(1);
+  });
+
+  it('should retry dead-lettered tasks', () => {
+    queue.addTask('test', { maxRetries: 0, backoffDelay: 0 });
+    const t1 = queue.getNextTask()!;
+    queue.failTask(t1.id, 'error');
+
+    const retried = queue.retryDeadLetter(t1.id);
+    expect(retried.status).toBe('pending');
+    expect(retried.attempt).toBe(0);
+    expect(retried.failureCount).toBe(0);
+  });
+
+  it('should clear dead letter queue', () => {
+    queue.addTask('test', { maxRetries: 0, backoffDelay: 0 });
+    const t1 = queue.getNextTask()!;
+    queue.failTask(t1.id, 'error');
+
+    queue.clearDeadLetterQueue();
+    expect(queue.getDeadLetterQueue().length).toBe(0);
+  });
+
+  it('should have per-queue DLQs', () => {
+    queue.addTask('email', 'emails', { maxRetries: 0, backoffDelay: 0 });
+    queue.addTask('sms', 'sms', { maxRetries: 0, backoffDelay: 0 });
+
+    const e = queue.getNextTask('emails')!;
+    queue.failTask(e.id, 'error');
+
+    const s = queue.getNextTask('sms')!;
+    queue.failTask(s.id, 'error');
+
+    expect(queue.getDeadLetterQueue('emails').length).toBe(1);
+    expect(queue.getDeadLetterQueue('sms').length).toBe(1);
+  });
+
+  it('should allow retried dead letter task to be processed again', () => {
+    queue.addTask('test', { maxRetries: 0, backoffDelay: 0 });
+    const t1 = queue.getNextTask()!;
+    queue.failTask(t1.id, 'error');
+
+    queue.retryDeadLetter(t1.id);
