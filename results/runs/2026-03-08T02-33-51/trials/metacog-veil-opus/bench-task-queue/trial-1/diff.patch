+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01TsYpNLxiyKgQuZi1YqG2SJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01M5NUvx6ikpbBqApcLriNr7","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should add a task and return a task object', () => {\n    const task = queue.addTask({ data: 'test' });\n    expect(task).toBeDefined();\n    expect(task.id).toBeDefined();\n    expect(task.payload).toEqual({ data: 'test' });\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n  });\n\n  it('should assign unique IDs to each task', () => {\n    const t1 = queue.addTask('task1');\n    const t2 = queue.addTask('task2');\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  it('should retrieve tasks in FIFO order', () => {\n    queue.addTask('first');\n    queue.addTask('second');\n    queue.addTask('third');\n\n    const t1 = queue.getNextTask();\n    expect(t1?.payload).toBe('first');\n    const t2 = queue.getNextTask();\n    expect(t2?.payload).toBe('second');\n    const t3 = queue.getNextTask();\n    expect(t3?.payload).toBe('third');\n  });\n\n  it('should transition tasks to processing state', () => {\n    queue.addTask('test');\n    const task = queue.getNextTask();\n    expect(task?.status).toBe('processing');\n  });\n\n  it('should return null when no tasks are available', () => {\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should track pending count', () => {\n    expect(queue.pendingCount()).toBe(0);\n    queue.addTask('a');\n    queue.addTask('b');\n    expect(queue.pendingCount()).toBe(2);\n    queue.getNextTask();\n    expect(queue.pendingCount()).toBe(1);\n  });\n\n  it('should not return already-processing tasks', () => {\n    queue.addTask('only');\n    queue.getNextTask();\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should accept any payload type', () => {\n    const t1 = queue.addTask(42);\n    const t2 = queue.addTask([1, 2, 3]);\n    const t3 = queue.addTask(null);\n    expect(t1.payload).toBe(42);\n    expect(t2.payload).toEqual([1, 2, 3]);\n    expect(t3.payload).toBeNull();\n  });\n});\n\ndescribe('Phase 2: Named Queues', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should support default queue when no name given', () => {\n    queue.addTask('default');\n    const task = queue.getNextTask();\n    expect(task?.payload).toBe('default');\n  });\n\n  it('should support named queues', () => {\n    queue.addTask('email-task', 'emails');\n    queue.addTask('sms-task', 'sms');\n\n    const email = queue.getNextTask('emails');\n    expect(email?.payload).toBe('email-task');\n\n    const sms = queue.getNextTask('sms');\n    expect(sms?.payload).toBe('sms-task');\n  });\n\n  it('should keep named queues independent', () => {\n    queue.addTask('a', 'q1');\n    queue.addTask('b', 'q2');\n\n    expect(queue.pendingCount('q1')).toBe(1);\n    expect(queue.pendingCount('q2')).toBe(1);\n\n    queue.getNextTask('q1');\n    expect(queue.pendingCount('q1')).toBe(0);\n    expect(queue.pendingCount('q2')).toBe(1);\n  });\n\n  it('should create queues implicitly', () => {\n    queue.addTask('hello', 'new-queue');\n    expect(queue.getQueueNames()).toContain('new-queue');\n  });\n\n  it('should list all queue names', () => {\n    queue.addTask('a', 'q1');\n    queue.addTask('b', 'q2');\n    queue.addTask('c', 'q3');\n    const names = queue.getQueueNames();\n    expect(names).toContain('q1');\n    expect(names).toContain('q2');\n    expect(names).toContain('q3');\n  });\n\n  it('should return null for non-existent queue', () => {\n    expect(queue.getNextTask('nonexistent')).toBeNull();\n  });\n\n  it('should return null for empty queue', () => {\n    queue.addTask('a', 'q1');\n    queue.getNextTask('q1');\n    expect(queue.getNextTask('q1')).toBeNull();\n  });\n});\n\ndescribe('Phase 3: Priority', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should default priority to 5', () => {\n    const task = queue.addTask('test');\n    expect(task.priority).toBe(5);\n  });\n\n  it('should accept priority option', () => {\n    const task = queue.addTask('test', { priority: 1 });\n    expect(task.priority).toBe(1);\n  });\n\n  it('should return higher priority tasks first', () => {\n    queue.addTask('low', { priority: 10 });\n    queue.addTask('high', { priority: 1 });\n    queue.addTask('medium', { priority: 5 });\n\n    expect(queue.getNextTask()?.payload).toBe('high');\n    expect(queue.getNextTask()?.payload).toBe('medium');\n    expect(queue.getNextTask()?.payload).toBe('low');\n  });\n\n  it('should maintain FIFO within same priority', () => {\n    queue.addTask('first', { priority: 5 });\n    queue.addTask('second', { priority: 5 });\n    queue.addTask('third', { priority: 5 });\n\n    expect(queue.getNextTask()?.payload).toBe('first');\n    expect(queue.getNextTask()?.payload).toBe('second');\n    expect(queue.getNextTask()?.payload).toBe('third');\n  });\n\n  it('should reject invalid priority < 1', () => {\n    expect(() => queue.addTask('test', { priority: 0 })).toThrow();\n  });\n\n  it('should reject invalid priority > 10', () => {\n    expect(() => queue.addTask('test', { priority: 11 })).toThrow();\n  });\n\n  it('should reject non-integer priority', () => {\n    expect(() => queue.addTask('test', { priority: 1.5 })).toThrow();\n  });\n\n  it('should work with named queues', () => {\n    queue.addTask('low', 'emails', { priority: 10 });\n    queue.addTask('high', 'emails', { priority: 1 });\n\n    expect(queue.getNextTask('emails')?.payload).toBe('high');\n    expect(queue.getNextTask('emails')?.payload).toBe('low');\n  });\n});\n\ndescribe('Phase 4: Delayed Tasks', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should support delayed tasks', () => {\n    queue.addTask('delayed', { delay: 100000 });\n    expect(queue.getNextTask()).toBeNull(); // not available yet\n  });\n\n  it('should return non-delayed tasks over delayed ones', () => {\n    queue.addTask('delayed', { delay: 100000 });\n    queue.addTask('immediate');\n    expect(queue.getNextTask()?.payload).toBe('immediate');\n  });\n\n  it('should make delayed tasks available after time passes', async () => {\n    queue.addTask('delayed', { delay: 50 });\n    expect(queue.getNextTask()).toBeNull();\n\n    await new Promise(r => setTimeout(r, 60));\n    expect(queue.getNextTask()?.payload).toBe('delayed');\n  });\n\n  it('should support processAt option', () => {\n    const futureTime = new Date(Date.now() + 100000);\n    const task = queue.addTask('scheduled', { processAt: futureTime });\n    expect(task.availableAt).toEqual(futureTime);\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should indicate availability time on task', () => {\n    const task = queue.addTask('delayed', { delay: 5000 });\n    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n  });\n\n  it('should order available delayed tasks by availability, then priority, then FIFO', async () => {\n    const t1 = queue.addTask('first', { delay: 10, priority: 5 });\n    const t2 = queue.addTask('second', { delay: 20, priority: 1 });\n\n    await new Promise(r => setTimeout(r, 30));\n\n    // Both available. t1 available first so should come first\n    // Actually: sort by priority first, then availability, then FIFO\n    // Wait - the spec says \"ordered by availability time, then priority, then FIFO\"\n    // So availability time takes precedence over priority for delayed tasks\n    // But re-reading: the spec says for \"multiple delayed tasks becoming available simultaneously\"\n    // they should be ordered by availability time, then priority, then FIFO\n    // The main sort is still priority-first for the overall getNextTask\n\n    // Let me re-read: \"When multiple delayed tasks become available simultaneously,\n    // they should be ordered by availability time, then priority, then FIFO\"\n    // This means when they're all available, sort by: availability time, priority, FIFO\n  });\n\n  it('should work with named queues', async () => {\n    queue.addTask('delayed', 'q1', { delay: 50 });\n    expect(queue.getNextTask('q1')).toBeNull();\n    await new Promise(r => setTimeout(r, 60));\n    expect(queue.getNextTask('q1')?.payload).toBe('delayed');\n  });\n});\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should complete a task', () => {\n    const task = queue.addTask('test');\n    const retrieved = queue.getNextTask()!;\n    queue.completeTask(retrieved.id);\n    expect(retrieved.status).toBe('completed');\n  });\n\n  it('should fail and retry a task', () => {\n    const task = queue.addTask('test', { maxRetries: 3 });\n    const retrieved = queue.getNextTask()!;\n    queue.failTask(retrieved.id, 'error');\n    expect(retrieved.status).toBe('pending');\n    expect(retrieved.attempt).toBe(1);\n  });\n\n  it('should use exponential backoff', () => {\n    const task = queue.addTask('test', { maxRetries: 3, backoffDelay: 1000 });\n\n    // First attempt\n    const t1 = queue.getNextTask()!;\n    const beforeFail = Date.now();\n    queue.failTask(t1.id, 'error');\n    // Backoff: 1000 * 2^(1-1) = 1000ms\n    expect(t1.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900);\n    expect(t1.availableAt.getTime()).toBeLessThanOrEqual(beforeFail + 1100);\n  });\n\n  it('should track attempt count', () => {\n    const task = queue.addTask('test', { maxRetries: 3, backoffDelay: 0 });\n\n    const t1 = queue.getNextTask()!;\n    expect(t1.attempt).toBe(1);\n    queue.failTask(t1.id, 'error');\n    expect(t1.attempt).toBe(1);\n    expect(t1.failureCount).toBe(1);\n  });\n\n  it('should fail permanently when retries exhausted', () => {\n    const task = queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error'); // first failure, but retry is available\n    // maxRetries=1 means only 1 attempt total? Or 1 retry?\n    // \"default maximum number of retries is 3\" - this implies attempts are maxRetries\n    // attempt starts at 0, first getNextTask sets it to 1\n    // fail checks attempt < maxRetries (1 < 1 is false), so goes to failed\n    expect(t1.status).toBe('failed');\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    const task = queue.addTask('test', 'myqueue', { maxRetries: 3, priority: 2, backoffDelay: 0 });\n    const t1 = queue.getNextTask('myqueue')!;\n    queue.failTask(t1.id, 'error');\n    expect(t1.queueName).toBe('myqueue');\n    expect(t1.priority).toBe(2);\n  });\n\n  it('should default to 3 retries', () => {\n    const task = queue.addTask('test');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default backoff to 1000ms', () => {\n    const task = queue.addTask('test');\n    expect(task.backoffDelay).toBe(1000);\n  });\n});\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should move exhausted tasks to DLQ', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'permanent error');\n\n    const dlq = queue.getDeadLetterQueue();\n    expect(dlq.length).toBe(1);\n    expect(dlq[0].payload).toBe('test');\n  });\n\n  it('should retain error info in DLQ', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'something broke');\n\n    const dlq = queue.getDeadLetterQueue();\n    expect(dlq[0].error).toBe('something broke');\n    expect(dlq[0].failureCount).toBe(1);\n  });\n\n  it('should retry dead-lettered tasks', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error');\n\n    const retried = queue.retryDeadLetter(t1.id);\n    expect(retried.status).toBe('pending');\n    expect(retried.attempt).toBe(0);\n    expect(retried.failureCount).toBe(0);\n  });\n\n  it('should clear dead letter queue', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error');\n\n    queue.clearDeadLetterQueue();\n    expect(queue.getDeadLetterQueue().length).toBe(0);\n  });\n\n  it('should have per-queue DLQs', () => {\n    queue.addTask('email', 'emails', { maxRetries: 1, backoffDelay: 0 });\n    queue.addTask('sms', 'sms', { maxRetries: 1, backoffDelay: 0 });\n\n    const e = queue.getNextTask('emails')!;\n    queue.failTask(e.id, 'error');\n\n    const s = queue.getNextTask('sms')!;\n    queue.failTask(s.id, 'error');\n\n    expect(queue.getDeadLetterQueue('emails').length).toBe(1);\n    expect(queue.getDeadLetterQueue('sms').length).toBe(1);\n  });\n\n  it('should allow retried dead letter task to be processed again', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error');\n\n    queue.retryDeadLetter(t1.id);\n    const t2 = queue.getNextTask()!;\n    expect(t2.id).toBe(t1.id);\n    expect(t2.payload).toBe('test');\n  });\n\n  it('should throw when retrying non-existent DLQ task', () => {\n    expect(() => queue.retryDeadLetter('nonexistent')).toThrow();\n  });\n});\n\ndescribe('Phase 7: Task Dependencies', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should block tasks with unresolved dependencies', () => {\n    const t1 = queue.addTask('first');\n    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n    // t2 should be blocked\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t1.id);\n    // Only t1 should be available\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should unblock tasks when dependencies complete', () => {\n    const t1 = queue.addTask('first');\n    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n    const retrieved = queue.getNextTask()!;\n    queue.completeTask(retrieved.id);\n\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t2.id);\n  });\n\n  it('should support multiple dependencies', () => {\n    const t1 = queue.addTask('first');\n    const t2 = queue.addTask('second');\n    const t3 = queue.addTask('third', { dependencies: [t1.id, t2.id] });\n\n    const r1 = queue.getNextTask()!;\n    queue.completeTask(r1.id);\n\n    // t3 still blocked (t2 not done)\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t2.id);\n    expect(queue.getNextTask()).toBeNull(); // t3 still blocked\n\n    queue.completeTask(next!.id);\n    const last = queue.getNextTask();\n    expect(last?.id).toBe(t3.id);\n  });\n\n  it('should reject non-existent dependencies', () => {\n    expect(() => queue.addTask('test', { dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  it('should inspect dependency status', () => {\n    const t1 = queue.addTask('first');\n    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n    const status = queue.getDependencyStatus(t2.id);\n    expect(status.dependencies).toContain(t1.id);\n    expect(status.pending).toContain(t1.id);\n    expect(status.resolved).toHaveLength(0);\n    expect(status.isBlocked).toBe(true);\n\n    const r1 = queue.getNextTask()!;\n    queue.completeTask(r1.id);\n\n    const statusAfter = queue.getDependencyStatus(t2.id);\n    expect(statusAfter.resolved).toContain(t1.id);\n    expect(statusAfter.pending).toHaveLength(0);\n    expect(statusAfter.isBlocked).toBe(false);\n  });\n\n  it('should keep dependents blocked when dependency fails', () => {\n    const t1 = queue.addTask('first', { maxRetries: 1, backoffDelay: 0 });\n    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n    const r1 = queue.getNextTask()!;\n    queue.failTask(r1.id, 'error');\n\n    // t2 should still be blocked\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should work with named queues', () => {\n    const t1 = queue.addTask('first', 'q1');\n    const t2 = queue.addTask('second', 'q1', { dependencies: [t1.id] });\n\n    const r1 = queue.getNextTask('q1')!;\n    expect(r1.id).toBe(t1.id);\n    expect(queue.getNextTask('q1')).toBeNull();\n\n    queue.completeTask(r1.id);\n    const r2 = queue.getNextTask('q1')!;\n    expect(r2.id).toBe(t2.id);\n  });\n});\n\ndescribe('Phase 8: Concurrency Control', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should default to unlimited concurrency', () => {\n    expect(queue.getConcurrencyLimit()).toBeNull();\n  });\n\n  it('should set concurrency limit', () => {\n    queue.setConcurrency('default', 2);\n    expect(queue.getConcurrencyLimit('default')).toBe(2);\n  });\n\n  it('should respect concurrency limit', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('a');\n    queue.addTask('b');\n\n    const t1 = queue.getNextTask();\n    expect(t1).not.toBeNull();\n    const t2 = queue.getNextTask();\n    expect(t2).toBeNull(); // limit reached\n  });\n\n  it('should free slot when task completes', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('a');\n    queue.addTask('b');\n\n    const t1 = queue.getNextTask()!;\n    queue.completeTask(t1.id);\n\n    const t2 = queue.getNextTask();\n    expect(t2).not.toBeNull();\n  });\n\n  it('should free slot when task fails', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('a', { maxRetries: 1, backoffDelay: 0 });\n    queue.addTask('b');\n\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error');\n\n    const t2 = queue.getNextTask();\n    expect(t2).not.toBeNull();\n  });\n\n  it('should track active count', () => {\n    queue.addTask('a');\n    queue.addTask('b');\n\n    expect(queue.getActiveCount()).toBe(0);\n    queue.getNextTask();\n    expect(queue.getActiveCount()).toBe(1);\n    queue.getNextTask();\n    expect(queue.getActiveCount()).toBe(2);\n  });\n\n  it('should interact correctly with priority', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('low', { priority: 10 });\n    queue.addTask('high', { priority: 1 });\n\n    const t = queue.getNextTask();\n    expect(t?.payload).toBe('high');\n  });\n});\n\ndescribe('Phase 9: Progress and Cancellation', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should report progress', () => {\n    const task = queue.addTask('test');\n    queue.getNextTask();\n    queue.reportProgress(task.id, 50, 'halfway');\n\n    const progress = queue.getProgress(task.id);\n    expect(progress.percentage).toBe(50);\n    expect(progress.message).toBe('halfway');\n  });\n\n  it('should notify progress listeners', () => {\n    const task = queue.addTask('test');\n    queue.getNextTask();\n\n    const updates: Array<{ percentage: number; message?: string }> = [];\n    queue.onProgress(task.id, (p) => updates.push(p));\n\n    queue.reportProgress(task.id, 25, 'quarter');\n    queue.reportProgress(task.id, 75, 'three quarters');\n\n    expect(updates).toHaveLength(2);\n    expect(updates[0].percentage).toBe(25);\n    expect(updates[1].percentage).toBe(75);\n  });\n\n  it('should support unsubscribing from progress', () => {\n    const task = queue.addTask('test');\n    queue.getNextTask();\n\n    const updates: number[] = [];\n    const unsubscribe = queue.onProgress(task.id, (p) => updates.push(p.percentage));\n\n    queue.reportProgress(task.id, 25);\n    unsubscribe();\n    queue.reportProgress(task.id, 50);\n\n    expect(updates).toHaveLength(1);\n  });\n\n  it('should cancel pending tasks', () => {\n    const task = queue.addTask('test');\n    queue.cancelTask(task.id);\n    expect(task.status).toBe('cancelled');\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should cancel processing tasks', () => {\n    const task = queue.addTask('test');\n    queue.getNextTask();\n    queue.cancelTask(task.id);\n    expect(task.status).toBe('cancelled');\n  });\n\n  it('should not retry cancelled tasks', () => {\n    const task = queue.addTask('test', { maxRetries: 3 });\n    queue.getNextTask();\n    queue.cancelTask(task.id);\n    // Task is cancelled, should not be re-queued\n    expect(task.status).toBe('cancelled');\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should reject progress for non-processing tasks', () => {\n    const task = queue.addTask('test');\n    expect(() => queue.reportProgress(task.id, 50)).toThrow();\n  });\n\n  it('should reject invalid progress percentage', () => {\n    const task = queue.addTask('test');\n    queue.getNextTask();\n    expect(() => queue.reportProgress(task.id, 150)).toThrow();\n  });\n});\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should create a schedule', () => {\n    const schedule = queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n    expect(schedule.id).toBeDefined();\n    expect(schedule.cronExpression).toBe('*/5 * * * *');\n  });\n\n  it('should list schedules', () => {\n    queue.addSchedule('*/5 * * * *', 'default', 'payload1');\n    queue.addSchedule('0 * * * *', 'default', 'payload2');\n    expect(queue.getSchedules()).toHaveLength(2);\n  });\n\n  it('should remove schedule', () => {\n    const schedule = queue.addSchedule('*/5 * * * *', 'default', 'payload');\n    queue.removeSchedule(schedule.id);\n    expect(queue.getSchedules()).toHaveLength(0);\n  });\n\n  it('should enqueue tasks on tick when due', () => {\n    queue.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });\n\n    // Tick at a time that's divisible by 5\n    const time = new Date();\n    time.setMinutes(10, 0, 0);\n    const tasks = queue.tick(time);\n    expect(tasks.length).toBe(1);\n    expect(tasks[0].payload).toEqual({ type: 'recurring' });\n  });\n\n  it('should not enqueue on non-matching tick', () => {\n    queue.addSchedule('0 0 * * *', 'default', 'midnight');\n\n    const time = new Date();\n    time.setHours(12, 30, 0, 0);\n    const tasks = queue.tick(time);\n    expect(tasks.length).toBe(0);\n  });\n\n  it('should not double-enqueue on same minute', () => {\n    queue.addSchedule('*/5 * * * *', 'default', 'payload');\n\n    const time = new Date();\n    time.setMinutes(10, 0, 0);\n    queue.tick(time);\n    const tasks = queue.tick(time);\n    expect(tasks.length).toBe(0);\n  });\n\n  it('should stop creating tasks after schedule removal', () => {\n    const schedule = queue.addSchedule('*/5 * * * *', 'default', 'payload');\n\n    const time = new Date();\n    time.setMinutes(10, 0, 0);\n    queue.tick(time);\n\n    queue.removeSchedule(schedule.id);\n\n    time.setMinutes(15, 0, 0);\n    const tasks = queue.tick(time);\n    expect(tasks.length).toBe(0);\n  });\n});\n\ndescribe('Phase 11: Middleware Pipeline', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should run middleware before handler', async () => {\n    const order: string[] = [];\n\n    queue.use('default', async (_task, next) => {\n      order.push('middleware');\n      await next();\n    });\n\n    queue.process('default', async () => {\n      order.push('handler');\n    });\n\n    queue.addTask('test');\n    const task = queue.getNextTask()!;\n    await queue.processTask(task.id);\n\n    expect(order).toEqual(['middleware', 'handler']);\n  });\n\n  it('should run middleware in order', async () => {\n    const order: string[] = [];\n\n    queue.use('default', async (_task, next) => {\n      order.push('first');\n      await next();\n    });\n\n    queue.use('default', async (_task, next) => {\n      order.push('second');\n      await next();\n    });\n\n    queue.process('default', async () => {\n      order.push('handler');\n    });\n\n    queue.addTask('test');\n    const task = queue.getNextTask()!;\n    await queue.processTask(task.id);\n\n    expect(order).toEqual(['first', 'second', 'handler']);\n  });\n\n  it('should skip processing if middleware does not call next', async () => {\n    const handlerCalled = vi.fn();\n\n    queue.use('default', async () => {\n      // intentionally not calling next\n    });\n\n    queue.process('default', handlerCalled);\n\n    queue.addTask('test');\n    const task = queue.getNextTask()!;\n    await queue.processTask(task.id);\n\n    expect(handlerCalled).not.toHaveBeenCalled();\n  });\n\n  it('should allow middleware to modify task', async () => {\n    queue.use('default', async (task, next) => {\n      (task as any).payload = { ...task.payload as any, modified: true };\n      await next();\n    });\n\n    let receivedPayload: any;\n    queue.process('default', async (task) => {\n      receivedPayload = task.payload;\n    });\n\n    queue.addTask({ original: true });\n    const task = queue.getNextTask()!;\n    await queue.processTask(task.id);\n\n    expect(receivedPayload).toEqual({ original: true, modified: true });\n  });\n\n  it('should fail task when middleware throws', async () => {\n    queue.use('default', async () => {\n      throw new Error('middleware error');\n    });\n\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const task = queue.getNextTask()!;\n\n    await expect(queue.processTask(task.id)).rejects.toThrow('middleware error');\n    expect(task.error).toBe('middleware error');\n  });\n\n  it('should have independent middleware per queue', async () => {\n    const q1Order: string[] = [];\n    const q2Order: string[] = [];\n\n    queue.use('q1', async (_task, next) => {\n      q1Order.push('q1-mw');\n      await next();\n    });\n\n    queue.use('q2', async (_task, next) => {\n      q2Order.push('q2-mw');\n      await next();\n    });\n\n    queue.process('q1', async () => { q1Order.push('q1-handler'); });\n    queue.process('q2', async () => { q2Order.push('q2-handler'); });\n\n    queue.addTask('a', 'q1');\n    queue.addTask('b', 'q2');\n\n    const t1 = queue.getNextTask('q1')!;\n    const t2 = queue.getNextTask('q2')!;\n\n    await queue.processTask(t1.id);\n    await queue.processTask(t2.id);\n\n    expect(q1Order).toEqual(['q1-mw', 'q1-handler']);\n    expect(q2Order).toEqual(['q2-mw', 'q2-handler']);\n  });\n\n  it('should register handler per queue', async () => {\n    const result: string[] = [];\n\n    queue.process('default', async (task) => {\n      result.push(task.payload as string);\n    });\n\n    queue.addTask('hello');\n    const task = queue.getNextTask()!;\n    await queue.processTask(task.id);\n\n    expect(result).toEqual(['hello']);\n  });\n});\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should stop accepting new tasks after shutdown', async () => {\n    await queue.shutdown();\n    expect(() => queue.addTask('test')).toThrow();\n  });\n\n  it('should complete immediately if no tasks processing', async () => {\n    const result = await queue.shutdown();\n    expect(result.forceCancelled).toBe(0);\n    expect(result.completed).toBe(0);\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n\n  it('should wait for processing tasks', async () => {\n    queue.addTask('test');\n    const task = queue.getNextTask()!;\n\n    // Complete the task shortly after shutdown starts\n    setTimeout(() => queue.completeTask(task.id), 50);\n\n    const result = await queue.shutdown({ timeout: 5000 });\n    expect(result.completed).toBe(1);\n    expect(result.forceCancelled).toBe(0);\n  });\n\n  it('should force cancel on timeout', async () => {\n    queue.addTask('test');\n    queue.getNextTask()!; // don't complete it\n\n    const result = await queue.shutdown({ timeout: 50 });\n    expect(result.forceCancelled).toBe(1);\n  });\n\n  it('should return same result on multiple shutdown calls', async () => {\n    const r1 = queue.shutdown();\n    const r2 = queue.shutdown();\n\n    expect(await r1).toBe(await r2);\n  });\n\n  it('should run shutdown callbacks', async () => {\n    let callbackRan = false;\n    queue.onShutdown(() => { callbackRan = true; });\n\n    await queue.shutdown();\n    expect(callbackRan).toBe(true);\n  });\n\n  it('should provide shutdown summary', async () => {\n    const result = await queue.shutdown();\n    expect(result).toHaveProperty('completed');\n    expect(result).toHaveProperty('forceCancelled');\n    expect(result).toHaveProperty('duration');\n  });\n\n  it('should report shuttingDown state', async () => {\n    expect(queue.shuttingDown).toBe(false);\n    const promise = queue.shutdown();\n    expect(queue.shuttingDown).toBe(true);\n    await promise;\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":218,"cache_read_input_tokens":37390,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":218},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5e89c2d1-8af7-43e3-aba0-7a2329afe11b","uuid":"88a11672-078a-4ae8-b9bd-ebd0bfab1c9d"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M5NUvx6ikpbBqApcLriNr7","type":"tool_result","content":"File created successfully at: /workspace/src/task-queue.test.ts"}]},"parent_tool_use_id":null,"session_id":"5e89c2d1-8af7-43e3-aba0-7a2329afe11b","uuid":"38ae61dc-b3a0-4834-93f9-91a9f3f9045d","tool_use_result":{"type":"create","filePath":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should add a task and return a task object', () => {\n    const task = queue.addTask({ data: 'test' });\n    expect(task).toBeDefined();\n    expect(task.id).toBeDefined();\n    expect(task.payload).toEqual({ data: 'test' });\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n  });\n\n  it('should assign unique IDs to each task', () => {\n    const t1 = queue.addTask('task1');\n    const t2 = queue.addTask('task2');\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  it('should retrieve tasks in FIFO order', () => {\n    queue.addTask('first');\n    queue.addTask('second');\n    queue.addTask('third');\n\n    const t1 = queue.getNextTask();\n    expect(t1?.payload).toBe('first');\n    const t2 = queue.getNextTask();\n    expect(t2?.payload).toBe('second');\n    const t3 = queue.getNextTask();\n    expect(t3?.payload).toBe('third');\n  });\n\n  it('should transition tasks to processing state', () => {\n    queue.addTask('test');\n    const task = queue.getNextTask();\n    expect(task?.status).toBe('processing');\n  });\n\n  it('should return null when no tasks are available', () => {\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should track pending count', () => {\n    expect(queue.pendingCount()).toBe(0);\n    queue.addTask('a');\n    queue.addTask('b');\n    expect(queue.pendingCount()).toBe(2);\n    queue.getNextTask();\n    expect(queue.pendingCount()).toBe(1);\n  });\n\n  it('should not return already-processing tasks', () => {\n    queue.addTask('only');\n    queue.getNextTask();\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should accept any payload type', () => {\n    const t1 = queue.addTask(42);\n    const t2 = queue.addTask([1, 2, 3]);\n    const t3 = queue.addTask(null);\n    expect(t1.payload).toBe(42);\n    expect(t2.payload).toEqual([1, 2, 3]);\n    expect(t3.payload).toBeNull();\n  });\n});\n\ndescribe('Phase 2: Named Queues', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should support default queue when no name given', () => {\n    queue.addTask('default');\n    const task = queue.getNextTask();\n    expect(task?.payload).toBe('default');\n  });\n\n  it('should support named queues', () => {\n    queue.addTask('email-task', 'emails');\n    queue.addTask('sms-task', 'sms');\n\n    const email = queue.getNextTask('emails');\n    expect(email?.payload).toBe('email-task');\n\n    const sms = queue.getNextTask('sms');\n    expect(sms?.payload).toBe('sms-task');\n  });\n\n  it('should keep named queues independent', () => {\n    queue.addTask('a', 'q1');\n    queue.addTask('b', 'q2');\n\n    expect(queue.pendingCount('q1')).toBe(1);\n    expect(queue.pendingCount('q2')).toBe(1);\n\n    queue.getNextTask('q1');\n    expect(queue.pendingCount('q1')).toBe(0);\n    expect(queue.pendingCount('q2')).toBe(1);\n  });\n\n  it('should create queues implicitly', () => {\n    queue.addTask('hello', 'new-queue');\n    expect(queue.getQueueNames()).toContain('new-queue');\n  });\n\n  it('should list all queue names', () => {\n    queue.addTask('a', 'q1');\n    queue.addTask('b', 'q2');\n    queue.addTask('c', 'q3');\n    const names = queue.getQueueNames();\n    expect(names).toContain('q1');\n    expect(names).toContain('q2');\n    expect(names).toContain('q3');\n  });\n\n  it('should return null for non-existent queue', () => {\n    expect(queue.getNextTask('nonexistent')).toBeNull();\n  });\n\n  it('should return null for empty queue', () => {\n    queue.addTask('a', 'q1');\n    queue.getNextTask('q1');\n    expect(queue.getNextTask('q1')).toBeNull();\n  });\n});\n\ndescribe('Phase 3: Priority', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should default priority to 5', () => {\n    const task = queue.addTask('test');\n    expect(task.priority).toBe(5);\n  });\n\n  it('should accept priority option', () => {\n    const task = queue.addTask('test', { priority: 1 });\n    expect(task.priority).toBe(1);\n  });\n\n  it('should return higher priority tasks first', () => {\n    queue.addTask('low', { priority: 10 });\n    queue.addTask('high', { priority: 1 });\n    queue.addTask('medium', { priority: 5 });\n\n    expect(queue.getNextTask()?.payload).toBe('high');\n    expect(queue.getNextTask()?.payload).toBe('medium');\n    expect(queue.getNextTask()?.payload).toBe('low');\n  });\n\n  it('should maintain FIFO within same priority', () => {\n    queue.addTask('first', { priority: 5 });\n    queue.addTask('second', { priority: 5 });\n    queue.addTask('third', { priority: 5 });\n\n    expect(queue.getNextTask()?.payload).toBe('first');\n    expect(queue.getNextTask()?.payload).toBe('second');\n    expect(queue.getNextTask()?.payload).toBe('third');\n  });\n\n  it('should reject invalid priority < 1', () => {\n    expect(() => queue.addTask('test', { priority: 0 })).toThrow();\n  });\n\n  it('should reject invalid priority > 10', () => {\n    expect(() => queue.addTask('test', { priority: 11 })).toThrow();\n  });\n\n  it('should reject non-integer priority', () => {\n    expect(() => queue.addTask('test', { priority: 1.5 })).toThrow();\n  });\n\n  it('should work with named queues', () => {\n    queue.addTask('low', 'emails', { priority: 10 });\n    queue.addTask('high', 'emails', { priority: 1 });\n\n    expect(queue.getNextTask('emails')?.payload).toBe('high');\n    expect(queue.getNextTask('emails')?.payload).toBe('low');\n  });\n});\n\ndescribe('Phase 4: Delayed Tasks', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should support delayed tasks', () => {\n    queue.addTask('delayed', { delay: 100000 });\n    expect(queue.getNextTask()).toBeNull(); // not available yet\n  });\n\n  it('should return non-delayed tasks over delayed ones', () => {\n    queue.addTask('delayed', { delay: 100000 });\n    queue.addTask('immediate');\n    expect(queue.getNextTask()?.payload).toBe('immediate');\n  });\n\n  it('should make delayed tasks available after time passes', async () => {\n    queue.addTask('delayed', { delay: 50 });\n    expect(queue.getNextTask()).toBeNull();\n\n    await new Promise(r => setTimeout(r, 60));\n    expect(queue.getNextTask()?.payload).toBe('delayed');\n  });\n\n  it('should support processAt option', () => {\n    const futureTime = new Date(Date.now() + 100000);\n    const task = queue.addTask('scheduled', { processAt: futureTime });\n    expect(task.availableAt).toEqual(futureTime);\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should indicate availability time on task', () => {\n    const task = queue.addTask('delayed', { delay: 5000 });\n    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n  });\n\n  it('should order available delayed tasks by availability, then priority, then FIFO', async () => {\n    const t1 = queue.addTask('first', { delay: 10, priority: 5 });\n    const t2 = queue.addTask('second', { delay: 20, priority: 1 });\n\n    await new Promise(r => setTimeout(r, 30));\n\n    // Both available. t1 available first so should come first\n    // Actually: sort by priority first, then availability, then FIFO\n    // Wait - the spec says \"ordered by availability time, then priority, then FIFO\"\n    // So availability time takes precedence over priority for delayed tasks\n    // But re-reading: the spec says for \"multiple delayed tasks becoming available simultaneously\"\n    // they should be ordered by availability time, then priority, then FIFO\n    // The main sort is still priority-first for the overall getNextTask\n\n    // Let me re-read: \"When multiple delayed tasks become available simultaneously,\n    // they should be ordered by availability time, then priority, then FIFO\"\n    // This means when they're all available, sort by: availability time, priority, FIFO\n  });\n\n  it('should work with named queues', async () => {\n    queue.addTask('delayed', 'q1', { delay: 50 });\n    expect(queue.getNextTask('q1')).toBeNull();\n    await new Promise(r => setTimeout(r, 60));\n    expect(queue.getNextTask('q1')?.payload).toBe('delayed');\n  });\n});\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should complete a task', () => {\n    const task = queue.addTask('test');\n    const retrieved = queue.getNextTask()!;\n    queue.completeTask(retrieved.id);\n    expect(retrieved.status).toBe('completed');\n  });\n\n  it('should fail and retry a task', () => {\n    const task = queue.addTask('test', { maxRetries: 3 });\n    const retrieved = queue.getNextTask()!;\n    queue.failTask(retrieved.id, 'error');\n    expect(retrieved.status).toBe('pending');\n    expect(retrieved.attempt).toBe(1);\n  });\n\n  it('should use exponential backoff', () => {\n    const task = queue.addTask('test', { maxRetries: 3, backoffDelay: 1000 });\n\n    // First attempt\n    const t1 = queue.getNextTask()!;\n    const beforeFail = Date.now();\n    queue.failTask(t1.id, 'error');\n    // Backoff: 1000 * 2^(1-1) = 1000ms\n    expect(t1.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900);\n    expect(t1.availableAt.getTime()).toBeLessThanOrEqual(beforeFail + 1100);\n  });\n\n  it('should track attempt count', () => {\n    const task = queue.addTask('test', { maxRetries: 3, backoffDelay: 0 });\n\n    const t1 = queue.getNextTask()!;\n    expect(t1.attempt).toBe(1);\n    queue.failTask(t1.id, 'error');\n    expect(t1.attempt).toBe(1);\n    expect(t1.failureCount).toBe(1);\n  });\n\n  it('should fail permanently when retries exhausted', () => {\n    const task = queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error'); // first failure, but retry is available\n    // maxRetries=1 means only 1 attempt total? Or 1 retry?\n    // \"default maximum number of retries is 3\" - this implies attempts are maxRetries\n    // attempt starts at 0, first getNextTask sets it to 1\n    // fail checks attempt < maxRetries (1 < 1 is false), so goes to failed\n    expect(t1.status).toBe('failed');\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    const task = queue.addTask('test', 'myqueue', { maxRetries: 3, priority: 2, backoffDelay: 0 });\n    const t1 = queue.getNextTask('myqueue')!;\n    queue.failTask(t1.id, 'error');\n    expect(t1.queueName).toBe('myqueue');\n    expect(t1.priority).toBe(2);\n  });\n\n  it('should default to 3 retries', () => {\n    const task = queue.addTask('test');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default backoff to 1000ms', () => {\n    const task = queue.addTask('test');\n    expect(task.backoffDelay).toBe(1000);\n  });\n});\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should move exhausted tasks to DLQ', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'permanent error');\n\n    const dlq = queue.getDeadLetterQueue();\n    expect(dlq.length).toBe(1);\n    expect(dlq[0].payload).toBe('test');\n  });\n\n  it('should retain error info in DLQ', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'something broke');\n\n    const dlq = queue.getDeadLetterQueue();\n    expect(dlq[0].error).toBe('something broke');\n    expect(dlq[0].failureCount).toBe(1);\n  });\n\n  it('should retry dead-lettered tasks', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error');\n\n    const retried = queue.retryDeadLetter(t1.id);\n    expect(retried.status).toBe('pending');\n    expect(retried.attempt).toBe(0);\n    expect(retried.failureCount).toBe(0);\n  });\n\n  it('should clear dead letter queue', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error');\n\n    queue.clearDeadLetterQueue();\n    expect(queue.getDeadLetterQueue().length).toBe(0);\n  });\n\n  it('should have per-queue DLQs', () => {\n    queue.addTask('email', 'emails', { maxRetries: 1, backoffDelay: 0 });\n    queue.addTask('sms', 'sms', { maxRetries: 1, backoffDelay: 0 });\n\n    const e = queue.getNextTask('emails')!;\n    queue.failTask(e.id, 'error');\n\n    const s = queue.getNextTask('sms')!;\n    queue.failTask(s.id, 'error');\n\n    expect(queue.getDeadLetterQueue('emails').length).toBe(1);\n    expect(queue.getDeadLetterQueue('sms').length).toBe(1);\n  });\n\n  it('should allow retried dead letter task to be processed again', () => {\n    queue.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error');\n\n    queue.retryDeadLetter(t1.id);\n    const t2 = queue.getNextTask()!;\n    expect(t2.id).toBe(t1.id);\n    expect(t2.payload).toBe('test');\n  });\n\n  it('should throw when retrying non-existent DLQ task', () => {\n    expect(() => queue.retryDeadLetter('nonexistent')).toThrow();\n  });\n});\n\ndescribe('Phase 7: Task Dependencies', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should block tasks with unresolved dependencies', () => {\n    const t1 = queue.addTask('first');\n    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n    // t2 should be blocked\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t1.id);\n    // Only t1 should be available\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should unblock tasks when dependencies complete', () => {\n    const t1 = queue.addTask('first');\n    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n    const retrieved = queue.getNextTask()!;\n    queue.completeTask(retrieved.id);\n\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t2.id);\n  });\n\n  it('should support multiple dependencies', () => {\n    const t1 = queue.addTask('first');\n    const t2 = queue.addTask('second');\n    const t3 = queue.addTask('third', { dependencies: [t1.id, t2.id] });\n\n    const r1 = queue.getNextTask()!;\n    queue.completeTask(r1.id);\n\n    // t3 still blocked (t2 not done)\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t2.id);\n    expect(queue.getNextTask()).toBeNull(); // t3 still blocked\n\n    queue.completeTask(next!.id);\n    const last = queue.getNextTask();\n    expect(last?.id).toBe(t3.id);\n  });\n\n  it('should reject non-existent dependencies', () => {\n    expect(() => queue.addTask('test', { dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  it('should inspect dependency status', () => {\n    const t1 = queue.addTask('first');\n    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n    const status = queue.getDependencyStatus(t2.id);\n    expect(status.dependencies).toContain(t1.id);\n    expect(status.pending).toContain(t1.id);\n    expect(status.resolved).toHaveLength(0);\n    expect(status.isBlocked).toBe(true);\n\n    const r1 = queue.getNextTask()!;\n    queue.completeTask(r1.id);\n\n    const statusAfter = queue.getDependencyStatus(t2.id);\n    expect(statusAfter.resolved).toContain(t1.id);\n    expect(statusAfter.pending).toHaveLength(0);\n    expect(statusAfter.isBlocked).toBe(false);\n  });\n\n  it('should keep dependents blocked when dependency fails', () => {\n    const t1 = queue.addTask('first', { maxRetries: 1, backoffDelay: 0 });\n    const t2 = queue.addTask('second', { dependencies: [t1.id] });\n\n    const r1 = queue.getNextTask()!;\n    queue.failTask(r1.id, 'error');\n\n    // t2 should still be blocked\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should work with named queues', () => {\n    const t1 = queue.addTask('first', 'q1');\n    const t2 = queue.addTask('second', 'q1', { dependencies: [t1.id] });\n\n    const r1 = queue.getNextTask('q1')!;\n    expect(r1.id).toBe(t1.id);\n    expect(queue.getNextTask('q1')).toBeNull();\n\n    queue.completeTask(r1.id);\n    const r2 = queue.getNextTask('q1')!;\n    expect(r2.id).toBe(t2.id);\n  });\n});\n\ndescribe('Phase 8: Concurrency Control', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should default to unlimited concurrency', () => {\n    expect(queue.getConcurrencyLimit()).toBeNull();\n  });\n\n  it('should set concurrency limit', () => {\n    queue.setConcurrency('default', 2);\n    expect(queue.getConcurrencyLimit('default')).toBe(2);\n  });\n\n  it('should respect concurrency limit', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('a');\n    queue.addTask('b');\n\n    const t1 = queue.getNextTask();\n    expect(t1).not.toBeNull();\n    const t2 = queue.getNextTask();\n    expect(t2).toBeNull(); // limit reached\n  });\n\n  it('should free slot when task completes', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('a');\n    queue.addTask('b');\n\n    const t1 = queue.getNextTask()!;\n    queue.completeTask(t1.id);\n\n    const t2 = queue.getNextTask();\n    expect(t2).not.toBeNull();\n  });\n\n  it('should free slot when task fails', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('a', { maxRetries: 1, backoffDelay: 0 });\n    queue.addTask('b');\n\n    const t1 = queue.getNextTask()!;\n    queue.failTask(t1.id, 'error');\n\n    const t2 = queue.getNextTask();\n    expect(t2).not.toBeNull();\n  });\n\n  it('should track active count', () => {\n    queue.addTask('a');\n    queue.addTask('b');\n\n    expect(queue.getActiveCount()).toBe(0);\n    queue.getNextTask();\n    expect(queue.getActiveCount()).toBe(1);\n    queue.getNextTask();\n    expect(queue.getActiveCount()).toBe(2);\n  });\n\n  it('should interact correctly with priority', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('low', { priority: 10 });\n    queue.addTask('high', { priority: 1 });\n\n    const t = queue.getNextTask();\n    expect(t?.payload).toBe('high');\n  });\n});\n\ndescribe('Phase 9: Progress and Cancellation', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should report progress', () => {\n    const task = queue.addTask('test');\n    queue.getNextTask();\n    queue.reportProgress(task.id, 50, 'halfway');\n\n    const progress = queue.getProgress(task.id);\n    expect(progress.percentage).toBe(50);\n    expect(progress.message).toBe('halfway');\n  });\n\n  it('should notify progress listeners', () => {\n    const task = queue.addTask('test');\n    queue.getNextTask();\n\n    const updates: Array<{ percentage: number; message?: string }> = [];\n    queue.onProgress(task.id, (p) => updates.push(p));\n\n    queue.reportProgress(task.id, 25, 'quarter');\n    queue.reportProgress(task.id, 75, 'three quarters');\n\n    expect(updates).toHaveLength(2);\n    expect(updates[0].percentage).toBe(25);\n    expect(updates[1].percentage).toBe(75);\n  });\n\n  it('should support unsubscribing from progress', () =>