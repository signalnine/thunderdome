+import { randomUUID } from 'node:crypto';
+
+// Task statuses
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+// Progress info
+export interface ProgressInfo {
+  percentage: number;
+  message?: string;
+}
+
+// Task object
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: Date;
+  priority: number;
+  queueName: string;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+  progress: ProgressInfo;
+  sequenceNumber: number;
+  cancelledAt?: Date;
+}
+
+// Options when adding a task
+export interface AddTaskOptions {
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  runAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  retries?: number;
+  dependencies?: string[];
+  dependsOn?: string[];
+}
+
+// Middleware function
+export type MiddlewareNext = () => Promise<void> | void;
+export type MiddlewareFn = (task: Task, next: MiddlewareNext) => Promise<void> | void;
+
+// Handler function
+export type HandlerFn = (task: Task) => Promise<void> | void;
+
+// Progress listener
+export type ProgressListener = (progress: ProgressInfo) => void;
+
+// Schedule for recurring tasks
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queueName: string;
+  payload: unknown;
+  options?: Omit<AddTaskOptions, 'delay' | 'processAt' | 'runAt' | 'dependencies' | 'dependsOn'>;
+  lastRun?: Date;
+}
+
+// Shutdown options
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+// Shutdown result
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+// Dependency status
+export interface DependencyStatus {
+  dependencies: string[];
+  resolved: string[];
+  pending: string[];
+  isBlocked: boolean;
+}
+
+export function createTask<T>(payload: T, queueName: string, options: AddTaskOptions = {}, sequenceNumber: number): Task<T> {
+  const now = new Date();
+  let availableAt = now;
+
+  const scheduledTime = options.processAt ?? options.runAt;
+  if (scheduledTime) {
+    availableAt = scheduledTime;
+  } else if (options.delay && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  }
+
+  const priority = options.priority ?? 5;
+  if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+    throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+  }
+
+  const maxRetries = options.maxRetries ?? options.retries ?? 3;
+  const deps = options.dependencies ?? options.dependsOn ?? [];
+
+  return {
+    id: randomUUID(),
+    payload,
+    status: 'pending',
+    createdAt: now,
+    priority,
+    queueName,
+    availableAt,
+    attempt: 0,
+    maxRetries,
+    backoffDelay: options.backoffDelay ?? 1000,
+    failureCount: 0,
+    dependencies: [...deps],
+    resolvedDependencies: new Set<string>(),
+    progress: { percentage: 0 },
+    sequenceNumber,
+  };
+}
