6→      throw new Error('Queue system is shutting down. Cannot add new tasks.');\n    57→    }\n    58→  }\n    59→\n    60→  // Phase 1 & 2: Add a task\n    61→  addTask<T = unknown>(payload: T, queueName?: string, options?: AddTaskOptions): Task<T>;\n    62→  addTask<T = unknown>(payload: T, options?: AddTaskOptions): Task<T>;\n    63→  addTask<T = unknown>(\n    64→    payload: T,\n    65→    queueNameOrOptions?: string | AddTaskOptions,\n    66→    maybeOptions?: AddTaskOptions\n    67→  ): Task<T> {\n    68→    this.ensureNotShutdown();\n    69→\n    70→    let queueName = DEFAULT_QUEUE;\n    71→    let options: AddTaskOptions = {};\n    72→\n    73→    if (typeof queueNameOrOptions === 'string') {\n    74→      queueName = queueNameOrOptions;\n    75→      options = maybeOptions ?? {};\n    76→    } else if (queueNameOrOptions && typeof queueNameOrOptions === 'object') {\n    77→      options = queueNameOrOptions;\n    78→    }\n    79→\n    80→    // Phase 7: Validate dependencies\n    81→    if (options.dependencies && options.dependencies.length > 0) {\n    82→      for (const depId of options.dependencies) {\n    83→        const depTask = this.allTasks.get(depId);\n    84→        if (!depTask) {\n    85→          throw new Error(`Dependency task not found: ${depId}`);\n    86→        }\n    87→      }\n    88→      // Circular dependency detection\n    89→      this.checkCircularDependencies(options.dependencies);\n    90→    }\n    91→\n    92→    const queue = this.getQueue(queueName);\n    93→    const task = createTask(payload, queueName, options, queue.sequenceCounter++);\n    94→    queue.tasks.set(task.id, task);\n    95→    this.allTasks.set(task.id, task);\n    96→\n    97→    // If dependencies are specified, resolve any that are already completed\n    98→    if (task.dependencies.length > 0) {\n    99→      for (const depId of task.dependencies) {\n   100→        const depTask = this.allTasks.get(depId);\n   101→        if (depTask && depTask.status === 'completed') {\n   102→          task.resolvedDependencies.add(depId);\n   103→        }\n   104→      }\n   105→    }\n   106→\n   107→    return task;\n   108→  }\n   109→\n   110→  // Phase 7: Check circular dependencies\n   111→  private checkCircularDependencies(dependencyIds: string[]): void {\n   112→    // Check for cycles in the dependency graph\n   113→    // Since the new task doesn't exist yet, we check if there are cycles\n   114→    // among the existing dependency chains of the specified dependencies\n   115→    const visited = new Set<string>();\n   116→\n   117→    const detectCycle = (taskId: string, path: Set<string>): void => {\n   118→      if (path.has(taskId)) {\n   119→        throw new Error(`Circular dependency detected involving task: ${taskId}`);\n   120→      }\n   121→      if (visited.has(taskId)) return;\n   122→\n   123→      visited.add(taskId);\n   124→      path.add(taskId);\n   125→\n   126→      const task = this.allTasks.get(taskId);\n   127→      if (task) {\n   128→        for (const depId of task.dependencies) {\n   129→          detectCycle(depId, new Set(path));\n   130→        }\n   131→      }\n   132→\n   133→      path.delete(taskId);\n   134→    };\n   135→\n   136→    for (const depId of dependencyIds) {\n   137→      detectCycle(depId, new Set<string>());\n   138→    }\n   139→  }\n   140→\n   141→  // Phase 1: Get next task from queue\n   142→  getNextTask(queueName?: string): Task | null {\n   143→    const name = queueName ?? DEFAULT_QUEUE;\n   144→    const queue = this.queues.get(name);\n   145→    if (!queue) return null;\n   146→\n   147→    // Phase 8: Check concurrency limit\n   148→    if (queue.concurrencyLimit !== null) {\n   149→      const activeCount = this.getActiveCount(name);\n   150→      if (activeCount >= queue.concurrencyLimit) {\n   151→        return null;\n   152→      }\n   153→    }\n   154→\n   155→    const now = new Date();\n   156→    const candidates: Task[] = [];\n   157→\n   158→    for (const task of queue.tasks.values()) {\n   159→      if (task.status !== 'pending') continue;\n   160→\n   161→      // Phase 7: Skip blocked tasks\n   162→      if (task.dependencies.length > 0) {\n   163→        const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n   164→        if (!allResolved) continue;\n   165→      }\n   166→\n   167→      // Phase 4: Check availability time\n   168→      if (task.availableAt > now) continue;\n   169→\n   170→      candidates.push(task);\n   171→    }\n   172→\n   173→    if (candidates.length === 0) return null;\n   174→\n   175→    // Sort: priority (lower number = higher priority), then availability time, then FIFO (sequenceNumber)\n   176→    candidates.sort((a, b) => {\n   177→      if (a.priority !== b.priority) return a.priority - b.priority;\n   178→      const aTime = a.availableAt.getTime();\n   179→      const bTime = b.availableAt.getTime();\n   180→      if (aTime !== bTime) return aTime - bTime;\n   181→      return a.sequenceNumber - b.sequenceNumber;\n   182→    });\n   183→\n   184→    const task = candidates[0];\n   185→    task.status = 'processing';\n   186→    task.attempt++;\n   187→    task.progress = { percentage: 0 };\n   188→    return task;\n   189→  }\n   190→\n   191→  // Phase 1: Count pending tasks\n   192→  pendingCount(queueName?: string): number {\n   193→    const name = queueName ?? DEFAULT_QUEUE;\n   194→    const queue = this.queues.get(name);\n   195→    if (!queue) return 0;\n   196→\n   197→    let count = 0;\n   198→    for (const task of queue.tasks.values()) {\n   199→      if (task.status === 'pending') count++;\n   200→    }\n   201→    return count;\n   202→  }\n   203→\n   204→  // Phase 2: List all queue names\n   205→  getQueueNames(): string[] {\n   206→    return Array.from(this.queues.keys());\n   207→  }\n   208→\n   209→  // Phase 5: Complete a task\n   210→  completeTask(taskId: string): void {\n   211→    const task = this.allTasks.get(taskId);\n   212→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   213→    if (task.status !== 'processing') {\n   214→      throw new Error(`Cannot complete task in '${task.status}' state`);\n   215→    }\n   216→    task.status = 'completed';\n   217→    task.progress = { percentage: 100 };\n   218→\n   219→    // Phase 7: Resolve dependencies\n   220→    this.resolveDependencies(taskId);\n   221→  }\n   222→\n   223→  // Phase 5: Fail a task\n   224→  failTask(taskId: string, error?: string): void {\n   225→    const task = this.allTasks.get(taskId);\n   226→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   227→    if (task.status !== 'processing') {\n   228→      throw new Error(`Cannot fail task in '${task.status}' state`);\n   229→    }\n   230→\n   231→    task.error = error;\n   232→    task.failureCount++;\n   233→\n   234→    // Check retries: failureCount has already been incremented above\n   235→    if (task.failureCount <= task.maxRetries) {\n   236→      // Re-queue with backoff delay: baseDelay * 2^(attempt-1) where attempt starts at 1\n   237→      const delay = task.backoffDelay * Math.pow(2, task.failureCount - 1);\n   238→      task.status = 'pending';\n   239→      task.availableAt = new Date(Date.now() + delay);\n   240→      task.progress = { percentage: 0 };\n   241→    } else {\n   242→      task.status = 'failed';\n   243→      // Phase 6: Move to dead letter queue\n   244→      this.moveToDeadLetterQueue(task);\n   245→    }\n   246→  }\n   247→\n   248→  // Phase 6: Move to dead letter queue\n   249→  private moveToDeadLetterQueue(task: Task): void {\n   250→    const queue = this.getQueue(task.queueName);\n   251→    queue.deadLetterQueue.push(task);\n   252→    // Remove from active queue\n   253→    queue.tasks.delete(task.id);\n   254→  }\n   255→\n   256→  // Phase 6: Get dead letter queue tasks\n   257→  getDeadLetterQueue(queueName?: string): Task[] {\n   258→    const name = queueName ?? DEFAULT_QUEUE;\n   259→    const queue = this.queues.get(name);\n   260→    if (!queue) return [];\n   261→    return [...queue.deadLetterQueue];\n   262→  }\n   263→\n   264→  // Phase 6: Retry a dead-lettered task\n   265→  retryDeadLetter(taskId: string): Task {\n   266→    // Find the task in any DLQ\n   267→    for (const queue of this.queues.values()) {\n   268→      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);\n   269→      if (index !== -1) {\n   270→        const task = queue.deadLetterQueue[index];\n   271→        queue.deadLetterQueue.splice(index, 1);\n   272→        // Reset for fresh retries\n   273→        task.status = 'pending';\n   274→        task.attempt = 0;\n   275→        task.failureCount = 0;\n   276→        task.error = undefined;\n   277→        task.availableAt = new Date();\n   278→        task.progress = { percentage: 0 };\n   279→        task.sequenceNumber = queue.sequenceCounter++;\n   280→        queue.tasks.set(task.id, task);\n   281→        return task;\n   282→      }\n   283→    }\n   284→    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n   285→  }\n   286→\n   287→  // Phase 6: Clear dead letter queue\n   288→  clearDeadLetterQueue(queueName?: string): void {\n   289→    const name = queueName ?? DEFAULT_QUEUE;\n   290→    const queue = this.queues.get(name);\n   291→    if (queue) {\n   292→      // Remove from allTasks as well\n   293→      for (const task of queue.deadLetterQueue) {\n   294→        this.allTasks.delete(task.id);\n   295→      }\n   296→      queue.deadLetterQueue = [];\n   297→    }\n   298→  }\n   299→\n   300→  // Phase 7: Resolve dependencies when a task completes\n   301→  private resolveDependencies(completedTaskId: string): void {\n   302→    for (const task of this.allTasks.values()) {\n   303→      if (task.status === 'pending' && task.dependencies.includes(completedTaskId)) {\n   304→        task.resolvedDependencies.add(completedTaskId);\n   305→      }\n   306→    }\n   307→  }\n   308→\n   309→  // Phase 7: Get dependency status\n   310→  getDependencyStatus(taskId: string): DependencyStatus {\n   311→    const task = this.allTasks.get(taskId);\n   312→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   313→\n   314→    const resolved = Array.from(task.resolvedDependencies);\n   315→    const pending = task.dependencies.filter(depId => !task.resolvedDependencies.has(depId));\n   316→\n   317→    return {\n   318→      dependencies: [...task.dependencies],\n   319→      resolved,\n   320→      pending,\n   321→      isBlocked: pending.length > 0,\n   322→    };\n   323→  }\n   324→\n   325→  // Phase 8: Set concurrency limit\n   326→  setConcurrency(queueName: string, limit: number | null): void {\n   327→    const queue = this.getQueue(queueName);\n   328→    queue.concurrencyLimit = limit;\n   329→  }\n   330→\n   331→  // Phase 8: Get concurrency limit\n   332→  getConcurrencyLimit(queueName?: string): number | null {\n   333→    const name = queueName ?? DEFAULT_QUEUE;\n   334→    const queue = this.queues.get(name);\n   335→    return queue?.concurrencyLimit ?? null;\n   336→  }\n   337→\n   338→  // Phase 8: Get active (processing) count\n   339→  getActiveCount(queueName?: string): number {\n   340→    const name = queueName ?? DEFAULT_QUEUE;\n   341→    const queue = this.queues.get(name);\n   342→    if (!queue) return 0;\n   343→\n   344→    let count = 0;\n   345→    for (const task of queue.tasks.values()) {\n   346→      if (task.status === 'processing') count++;\n   347→    }\n   348→    return count;\n   349→  }\n   350→\n   351→  // Phase 9: Report progress\n   352→  reportProgress(taskId: string, percentage: number, message?: string): void {\n   353→    const task = this.allTasks.get(taskId);\n   354→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   355→    if (task.status !== 'processing') {\n   356→      throw new Error(`Cannot report progress for task in '${task.status}' state`);\n   357→    }\n   358→\n   359→    if (percentage < 0 || percentage > 100) {\n   360→      throw new Error(`Progress percentage must be between 0 and 100, got ${percentage}`);\n   361→    }\n   362→\n   363→    task.progress = { percentage, message };\n   364→\n   365→    // Notify listeners\n   366→    const listeners = this.progressListeners.get(taskId);\n   367→    if (listeners) {\n   368→      for (const listener of listeners) {\n   369→        listener({ percentage, message });\n   370→      }\n   371→    }\n   372→  }\n   373→\n   374→  // Phase 9: Get progress\n   375→  getProgress(taskId: string): ProgressInfo {\n   376→    const task = this.allTasks.get(taskId);\n   377→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   378→    return { ...task.progress };\n   379→  }\n   380→\n   381→  // Phase 9: Subscribe to progress\n   382→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   383→    if (!this.progressListeners.has(taskId)) {\n   384→      this.progressListeners.set(taskId, new Set());\n   385→    }\n   386→    this.progressListeners.get(taskId)!.add(listener);\n   387→\n   388→    // Return unsubscribe function\n   389→    return () => {\n   390→      const listeners = this.progressListeners.get(taskId);\n   391→      if (listeners) {\n   392→        listeners.delete(listener);\n   393→        if (listeners.size === 0) {\n   394→          this.progressListeners.delete(taskId);\n   395→        }\n   396→      }\n   397→    };\n   398→  }\n   399→\n   400→  // Phase 9: Cancel a task\n   401→  cancelTask(taskId: string): void {\n   402→    const task = this.allTasks.get(taskId);\n   403→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   404→\n   405→    if (task.status !== 'pending' && task.status !== 'processing') {\n   406→      throw new Error(`Cannot cancel task in '${task.status}' state`);\n   407→    }\n   408→\n   409→    const wasProcessing = task.status === 'processing';\n   410→    task.status = 'cancelled';\n   411→    task.cancelledAt = new Date();\n   412→\n   413→    // If pending, remove from queue\n   414→    if (!wasProcessing) {\n   415→      const queue = this.queues.get(task.queueName);\n   416→      if (queue) {\n   417→        queue.tasks.delete(task.id);\n   418→      }\n   419→    }\n   420→  }\n   421→\n   422→  // Phase 10: Add schedule\n   423→  addSchedule(\n   424→    cronExpression: string,\n   425→    queueName: string,\n   426→    payload: unknown,\n   427→    options?: Omit<AddTaskOptions, 'delay' | 'processAt' | 'dependencies'>\n   428→  ): Schedule {\n   429→    this.ensureNotShutdown();\n   430→    // Validate cron expression\n   431→    parseCron(cronExpression);\n   432→\n   433→    const schedule: Schedule = {\n   434→      id: randomUUID(),\n   435→      cronExpression,\n   436→      queueName,\n   437→      payload,\n   438→      options,\n   439→    };\n   440→\n   441→    this.schedules.set(schedule.id, schedule);\n   442→    return schedule;\n   443→  }\n   444→\n   445→  // Phase 10: Remove schedule\n   446→  removeSchedule(scheduleId: string): void {\n   447→    if (!this.schedules.has(scheduleId)) {\n   448→      throw new Error(`Schedule not found: ${scheduleId}`);\n   449→    }\n   450→    this.schedules.delete(scheduleId);\n   451→  }\n   452→\n   453→  // Phase 10: List schedules\n   454→  getSchedules(): Schedule[] {\n   455→    return Array.from(this.schedules.values());\n   456→  }\n   457→\n   458→  // Phase 10: Tick - check and enqueue recurring tasks\n   459→  tick(now?: Date): Task[] {\n   460→    const currentTime = now ?? new Date();\n   461→    const enqueued: Task[] = [];\n   462→\n   463→    for (const schedule of this.schedules.values()) {\n   464→      const parsed = parseCron(schedule.cronExpression);\n   465→      if (shouldRunAt(parsed, currentTime, schedule.lastRun)) {\n   466→        const task = this.addTask(schedule.payload, schedule.queueName, schedule.options);\n   467→        enqueued.push(task);\n   468→        schedule.lastRun = currentTime;\n   469→      }\n   470→    }\n   471→\n   472→    return enqueued;\n   473→  }\n   474→\n   475→  // Phase 11: Register middleware\n   476→  use(queueName: string, middleware: MiddlewareFn): void {\n   477→    const queue = this.getQueue(queueName);\n   478→    queue.middlewares.push(middleware);\n   479→  }\n   480→\n   481→  // Phase 11: Register handler\n   482→  process(queueName: string, handler: HandlerFn): void {\n   483→    const queue = this.getQueue(queueName);\n   484→    queue.handler = handler;\n   485→  }\n   486→\n   487→  // Phase 11: Process a task through middleware pipeline and handler\n   488→  async processTask(taskId: string): Promise<void> {\n   489→    const task = this.allTasks.get(taskId);\n   490→    if (!task) throw new Error(`Task not found: ${taskId}`);\n   491→\n   492→    const queue = this.queues.get(task.queueName);\n   493→    if (!queue) throw new Error(`Queue not found: ${task.queueName}`);\n   494→\n   495→    const middlewares = [...queue.middlewares];\n   496→    const handler = queue.handler;\n   497→\n   498→    let index = 0;\n   499→\n   500→    const runNext = async (): Promise<void> => {\n   501→      if (index < middlewares.length) {\n   502→        const mw = middlewares[index++];\n   503→        await mw(task, runNext);\n   504→      } else if (handler) {\n   505→        await handler(task);\n   506→      }\n   507→    };\n   508→\n   509→    try {\n   510→      await runNext();\n   511→    } catch (err) {\n   512→      const errorMessage = err instanceof Error ? err.message : String(err);\n   513→      // Only fail the task if it's still in processing state\n   514→      if (task.status === 'processing') {\n   515→        this.failTask(taskId, errorMessage);\n   516→      }\n   517→      throw err;\n   518→    }\n   519→  }\n   520→\n   521→  // Phase 12: Register shutdown callback\n   522→  onShutdown(callback: () => Promise<void> | void): void {\n   523→    this.shutdownCallbacks.push(callback);\n   524→  }\n   525→\n   526→  // Phase 12: Shutdown\n   527→  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   528→    if (this.shutdownPromise) {\n   529→      return this.shutdownPromise;\n   530→    }\n   531→\n   532→    this.isShuttingDown = true;\n   533→    this.shutdownPromise = this.performShutdown(options);\n   534→    return this.shutdownPromise;\n   535→  }\n   536→\n   537→  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   538→    const startTime = Date.now();\n   539→    const timeout = options?.timeout ?? 30000;\n   540→    let completed = 0;\n   541→    let forceCancelled = 0;\n   542→\n   543→    // Run shutdown callbacks\n   544→    for (const cb of this.shutdownCallbacks) {\n   545→      await cb();\n   546→    }\n   547→\n   548→    // Collect all currently processing tasks\n   549→    const processingTasks: Task[] = [];\n   550→    for (const queue of this.queues.values()) {\n   551→      for (const task of queue.tasks.values()) {\n   552→        if (task.status === 'processing') {\n   553→          processingTasks.push(task);\n   554→        }\n   555→      }\n   556→    }\n   557→\n   558→    if (processingTasks.length === 0) {\n   559→      return {\n   560→        completed: 0,\n   561→        forceCancelled: 0,\n   562→        duration: Date.now() - startTime,\n   563→      };\n   564→    }\n   565→\n   566→    // Wait for processing tasks to complete, up to timeout\n   567→    const waitStart = Date.now();\n   568→\n   569→    await new Promise<void>((resolve) => {\n   570→      const checkInterval = setInterval(() => {\n   571→        let allDone = true;\n   572→        for (const task of processingTasks) {\n   573→          if (task.status === 'processing') {\n   574→            allDone = false;\n   575→            break;\n   576→          }\n   577→        }\n   578→\n   579→        if (allDone || Date.now() - waitS