+    const statusAfter = queue.getDependencyStatus(t2.id);
+    expect(statusAfter.resolved).toContain(t1.id);
+    expect(statusAfter.pending).toHaveLength(0);
+    expect(statusAfter.isBlocked).toBe(false);
+  });
+
+  it('should keep dependents blocked when dependency fails', () => {
+    const t1 = queue.addTask('first', { maxRetries: 0, backoffDelay: 0 });
+    const t2 = queue.addTask('second', { dependencies: [t1.id] });
+
+    const r1 = queue.getNextTask()!;
+    queue.failTask(r1.id, 'error');
+
+    // t2 should still be blocked
+    expect(queue.getNextTask()).toBeNull();
+  });
+
+  it('should work with named queues', () => {
+    const t1 = queue.addTask('first', 'q1');
+    const t2 = queue.addTask('second', 'q1', { dependencies: [t1.id] });
+
+    const r1 = queue.getNextTask('q1')!;
+    expect(r1.id).toBe(t1.id);
+    expect(queue.getNextTask('q1')).toBeNull();
+
+    queue.completeTask(r1.id);
+    const r2 = queue.getNextTask('q1')!;
+    expect(r2.id).toBe(t2.id);
+  });
+});
+
+describe('Phase 8: Concurrency Control', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  it('should default to unlimited concurrency', () => {
+    expect(queue.getConcurrencyLimit()).toBeNull();
+  });
+
+  it('should set concurrency limit', () => {
+    queue.setConcurrency('default', 2);
+    expect(queue.getConcurrencyLimit('default')).toBe(2);
+  });
+
+  it('should respect concurrency limit', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('a');
+    queue.addTask('b');
+
+    const t1 = queue.getNextTask();
+    expect(t1).not.toBeNull();
+    const t2 = queue.getNextTask();
+    expect(t2).toBeNull(); // limit reached
+  });
+
+  it('should free slot when task completes', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('a');
+    queue.addTask('b');
+
+    const t1 = queue.getNextTask()!;
+    queue.completeTask(t1.id);
+
+    const t2 = queue.getNextTask();
+    expect(t2).not.toBeNull();
+  });
+
+  it('should free slot when task fails', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('a', { maxRetries: 0, backoffDelay: 0 });
+    queue.addTask('b');
+
+    const t1 = queue.getNextTask()!;
+    queue.failTask(t1.id, 'error');
+
+    const t2 = queue.getNextTask();
+    expect(t2).not.toBeNull();
+  });
+
+  it('should track active count', () => {
+    queue.addTask('a');
+    queue.addTask('b');
+
+    expect(queue.getActiveCount()).toBe(0);
+    queue.getNextTask();
+    expect(queue.getActiveCount()).toBe(1);
+    queue.getNextTask();
+    expect(queue.getActiveCount()).toBe(2);
+  });
+
+  it('should interact correctly with priority', () => {
+    queue.setConcurrency('default', 1);
+    queue.addTask('low', { priority: 10 });
+    queue.addTask('high', { priority: 1 });
+
+    const t = queue.getNextTask();
+    expect(t?.payload).toBe('high');
+  });
+});
