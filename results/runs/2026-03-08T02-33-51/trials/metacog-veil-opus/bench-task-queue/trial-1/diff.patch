e: string,\n    payload: unknown,\n    options?: Omit<AddTaskOptions, 'delay' | 'processAt' | 'dependencies'>\n  ): Schedule {\n    this.ensureNotShutdown();\n    // Validate cron expression\n    parseCron(cronExpression);\n\n    const schedule: Schedule = {\n      id: randomUUID(),\n      cronExpression,\n      queueName,\n      payload,\n      options,\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  // Phase 10: Remove schedule\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule not found: ${scheduleId}`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  // Phase 10: List schedules\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  // Phase 10: Tick - check and enqueue recurring tasks\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const enqueued: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      const parsed = parseCron(schedule.cronExpression);\n      if (shouldRunAt(parsed, currentTime, schedule.lastRun)) {\n        const task = this.addTask(schedule.payload, schedule.queueName, schedule.options);\n        enqueued.push(task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return enqueued;\n  }\n\n  // Phase 11: Register middleware\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const queue = this.getQueue(queueName);\n    queue.middlewares.push(middleware);\n  }\n\n  // Phase 11: Register handler\n  process(queueName: string, handler: HandlerFn): void {\n    const queue = this.getQueue(queueName);\n    queue.handler = handler;\n  }\n\n  // Phase 11: Process a task through middleware pipeline and handler\n  async processTask(taskId: string): Promise<void> {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const queue = this.queues.get(task.queueName