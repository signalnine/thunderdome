   46→    });\n    47→  });\n    48→\n    49→  // ===== Journal Entries (8 tests, 7 pass) =====\n    50→\n    51→  describe('postEntry', () => {\n    52→    beforeEach(() => {\n    53→      ledger.createAccount('Cash', 'asset');\n    54→      ledger.createAccount('Revenue', 'revenue');\n    55→      ledger.createAccount('Expenses', 'expense');\n    56→      ledger.createAccount('AP', 'liability');\n    57→    });\n    58→\n    59→    it('posts a simple entry', () => {\n    60→      const entry = ledger.postEntry(\n    61→        'Sale',\n    62→        [{ account: 'Cash', amount: 100 }],\n    63→        [{ account: 'Revenue', amount: 100 }]\n    64→      );\n    65→      expect(entry.id).toBe(1);\n    66→      expect(entry.description).toBe('Sale');\n    67→    });\n    68→\n    69→    it('posts a compound entry', () => {\n    70→      const entry = ledger.postEntry(\n    71→        'Split payment',\n    72→        [{ account: 'Cash', amount: 50 }, { account: 'Expenses', amount: 50 }],\n    73→        [{ account: 'AP', amount: 100 }]\n    74→      );\n    75→      expect(entry.debits).toHaveLength(2);\n    76→      expect(entry.credits).toHaveLength(1);\n    77→    });\n    78→\n    79→    it('rejects unbalanced entries', () => {\n    80→      expect(() =>\n    81→        ledger.postEntry(\n    82→          'Bad',\n    83→          [{ account: 'Cash', amount: 100 }],\n    84→          [{ account: 'Revenue', amount: 50 }]\n    85→        )\n    86→      ).toThrow(/must equal/i);\n    87→    });\n    88→\n    89→    it('rejects unknown accounts', () => {\n    90→      expect(() =>\n    91→        ledger.postEntry(\n    92→          'Bad',\n    93→          [{ account: 'NonExistent', amount: 100 }],\n    94→          [{ account: 'Revenue', amount: 100 }]\n    95→        )\n    96→      ).toThrow(/not found/i);\n    97→    });\n    98→\n    99→    it('rejects zero or negative amounts', () => {\n   100→      expect(() =>\n   101→        ledger.postEntry(\n   102→        