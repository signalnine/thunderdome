→      ledger.createAccount('Revenue', 'revenue');\n   261→      ledger.createAccount('Expenses', 'expense');\n   262→    });\n   263→\n   264→    it('returns empty statement for no entries', () => {\n   265→      const stmt = ledger.getStatement('Cash');\n   266→      expect(stmt).toHaveLength(0);\n   267→    });\n   268→\n   269→    it('returns entries in date order', () => {\n   270→      ledger.postEntry('Late', [{ account: 'Cash', amount: 50 }], [{ account: 'Revenue', amount: 50 }], jan31);\n   271→      ledger.postEntry('Early', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n   272→      const stmt = ledger.getStatement('Cash');\n   273→      expect(stmt).toHaveLength(2);\n   274→      expect(stmt[0].description).toBe('Early');\n   275→      expect(stmt[1].description).toBe('Late');\n   276→    });\n   277→\n   278→    it('only includes entries for the requested account', () => {\n   279→      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n   280→      ledger.postEntry('Cost', [{ account: 'Expenses', amount: 30 }], [{ account: 'Cash', amount: 30 }], jan15);\n   281→      const stmt = ledger.getStatement('Cash');\n   282→      expect(stmt).toHaveLength(2); // Cash appears in both\n   283→      const revenueStmt = ledger.getStatement('Revenue');\n   284→      expect(revenueStmt).toHaveLength(1);\n   285→    });\n   286→\n   287→    it('throws for unknown account', () => {\n   288→      expect(() => ledger.getStatement('Nonexistent')).toThrow(/not found/i);\n   289→    });\n   290→\n   291→    it('shows correct running balance', () => {\n   292→      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n   293→      ledger.postEntry('Cost', [{ account: 'Expenses', amount: 30 }], [{ account: 'Cash', amount: 30 }], jan15);\n   294→      const stmt = ledger.getStatement('Cash');\n   295→      expect(stmt[0].balance).t