-/**
- * Duck-typing discovery layer for the financial ledger.
- * Finds the Ledger class regardless of export naming convention.
- */
-
-export interface LedgerLike {
-  createAccount: (name: string, type: string, currency?: string) => any;
-  postEntry: (description: string, debits: any[], credits: any[], date?: Date) => any;
-  getBalance: (accountName: string) => number;
-  getTrialBalance: () => any[];
-  getStatement: (accountName: string, startDate?: Date, endDate?: Date) => any[];
-  splitEntry: (description: string, fromAccount: string, toAccounts: any[], totalAmount: number, date?: Date) => any;
-  getAccountsByType: (type: string) => any[];
-  getProfitAndLoss: (startDate?: Date, endDate?: Date) => any;
-}
-
-let LedgerClass: (new () => LedgerLike) | null = null;
-
-function resolveLedger(mod: Record<string, any>): (new () => LedgerLike) | null {
-  // Strategy 1: Named export 'Ledger'
-  const names = ['Ledger', 'FinancialLedger', 'AccountingLedger', 'Journal'];
-  for (const name of names) {
-    if (typeof mod[name] === 'function') {
-      try {
-        const instance = new mod[name]();
-        if (typeof instance.createAccount === 'function' &&
-            typeof instance.postEntry === 'function' &&
-            typeof instance.getBalance === 'function') {
-          return mod[name];
-        }
-      } catch { /* not a constructor */ }
-    }
-  }
-
-  // Strategy 2: Default export
-  if (mod.default) {
-    if (typeof mod.default === 'function') {
-      try {
-        const instance = new mod.default();
-        if (typeof instance.createAccount === 'function') {
-          return mod.default;
-        }
-      } catch { /* not a constructor */ }
-    }
-  }
-
-  // Strategy 3: Any export that's a constructor with createAccount
-  for (const [, value] of Object.entries(mod)) {
-    if (typeof value === 'function') {
-      try {
-        const instance = new (value as any)();
-        if (typeof instance.createAccount === 'function' &&
-            typeof instance.postEntry === 'function') {
-          return value as any;
-        }
-      } catch { /* not a constructor */ }
-    }
-  }
-
-  // Strategy 4: Factory function
-  const factoryNames = ['createLedger', 'newLedger', 'makeLedger', 'create'];
-  for (const name of factoryNames) {
-    if (typeof mod[name] === 'function') {
-      try {
-        const instance = mod[name]();
-        if (typeof instance.createAccount === 'function') {
-          // Wrap factory as a constructor
-          return class {
-            constructor() {
-              return mod[name]();
-            }
-          } as any;
-        }
-      } catch { /* not a factory */ }
-    }
-  }
-
-  return null;
-}
-
-export async function getLedger(): Promise<new () => LedgerLike> {
-  if (LedgerClass) return LedgerClass;
-
-  const paths = ['../src/ledger.js', '../src/index.js', '../src/main.js', '../src/lib.js'];
-  const errors: string[] = [];
-
-  for (const path of paths) {
-    try {
-      const mod = await import(path);
-      const cls = resolveLedger(mod);
-      if (cls) {
-        LedgerClass = cls;
-        return cls;
-      }
-      errors.push(`${path}: no Ledger class found in exports`);
-    } catch (e: any) {
-      errors.push(`${path}: ${e.message}`);
-    }
-  }
-
-  throw new Error(
-    `Could not find a Ledger class. Tried:\n${errors.map(e => `  - ${e}`).join('\n')}`
-  );
-}
