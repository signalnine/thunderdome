@@ -0,0 +1,60 @@
+import express from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import { createDb, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDb(dbPath || ':memory:');
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(createRouter(store));
+
+  let server: HttpServer | null = null;
+  let collabServer: CollaborationServer | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      server = createServer(app);
+      collabServer = new CollaborationServer(server, store);
+
+      return new Promise<number>((resolve, reject) => {
+        server!.on('error', reject);
+        server!.listen(port ?? 0, () => {
+          const addr = server!.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            resolve(0);
+          }
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      if (collabServer) {
+        collabServer.closeAll();
+        collabServer = null;
+      }
+      if (server) {
+        return new Promise<void>((resolve, reject) => {
+          server!.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+          server = null;
+        });
+      }
+      db.close();
+    },
+  };
+}
