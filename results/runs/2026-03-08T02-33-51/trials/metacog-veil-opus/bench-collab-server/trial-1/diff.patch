ack');\n      await waitForMessage(ws1, 'operation');\n      v = ack2.version;\n    }","originalFile":"import { describe, it, expect, beforeEach, afterEach, beforeAll, afterAll } from 'vitest';\nimport { createApp, AppInstance } from '../src/server.js';\nimport WebSocket from 'ws';\nimport { tmpdir } from 'os';\nimport { join } from 'path';\nimport { randomUUID } from 'crypto';\nimport { unlinkSync, existsSync } from 'fs';\n\n// Helper to make HTTP requests\nasync function request(baseUrl: string, path: string, options: RequestInit = {}): Promise<Response> {\n  return fetch(`${baseUrl}${path}`, {\n    headers: { 'Content-Type': 'application/json', ...options.headers as Record<string, string> },\n    ...options,\n  });\n}\n\n// Message buffer that attaches to a WebSocket from creation\n// so no messages are lost between open and waitForMessage calls\ninterface BufferedWebSocket extends WebSocket {\n  __msgBuffer: unknown[];\n  __msgWaiters: Array<{ type?: string; resolve: (msg: unknown) => void; reject: (err: Error) => void; timer: ReturnType<typeof setTimeout> }>;\n}\n\nfunction setupBuffering(ws: WebSocket): BufferedWebSocket {\n  const bws = ws as BufferedWebSocket;\n  bws.__msgBuffer = [];\n  bws.__msgWaiters = [];\n\n  bws.on('message', (data: WebSocket.Data) => {\n    const msg = JSON.parse(data.toString());\n\n    // Check if any waiter matches\n    for (let i = 0; i < bws.__msgWaiters.length; i++) {\n      const waiter = bws.__msgWaiters[i];\n      if (!waiter.type || (msg as { type?: string }).type === waiter.type) {\n        bws.__msgWaiters.splice(i, 1);\n        clearTimeout(waiter.timer);\n        waiter.resolve(msg);\n        return;\n      }\n    }\n\n    // No matching waiter, buffer it\n    bws.__msgBuffer.push(msg);\n  });\n\n  return bws;\n}\n\n// Helper to create a WebSocket client connected to a document\nfunction connectWs(port: number, docId: string): Promise<BufferedWebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    const bws = setupBuffering(ws);\n    ws.on('open', () => resolve(bws));\n    ws.on('error', reject);\n  });\n}\n\n// Helper to wait for a specific message type\nfunction waitForMessage<T = unknown>(ws: WebSocket, type?: string, timeoutMs = 5000): Promise<T> {\n  const bws = ws as BufferedWebSocket;\n\n  // Check buffer first\n  for (let i = 0; i < bws.__msgBuffer.length; i++) {\n    const msg = bws.__msgBuffer[i] as { type?: string };\n    if (!type || msg.type === type) {\n      bws.__msgBuffer.splice(i, 1);\n      return Promise.resolve(msg as T);\n    }\n  }\n\n  // No match in buffer, set up waiter\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => {\n      const idx = bws.__msgWaiters.findIndex(w => w.timer === timer);\n      if (idx >= 0) bws.__msgWaiters.splice(idx, 1);\n      reject(new Error(`Timed out waiting for message${type ? ` of type '${type}'` : ''}`));\n    }, timeoutMs);\n    bws.__msgWaiters.push({ type, resolve: resolve as (msg: unknown) => void, reject, timer });\n  });\n}\n\n// Helper to wait for WebSocket close\nfunction waitForClose(ws: WebSocket, timeoutMs = 5000): Promise<void> {\n  return new Promise((resolve, reject) => {\n    if (ws.readyState === WebSocket.CLOSED) {\n      resolve();\n      return;\n    }\n    const timer = setTimeout(() => reject(new Error('Timed out waiting for close')), timeoutMs);\n    ws.on('close', () => { clearTimeout(timer); resolve(); });\n  });\n}\n\n// ================================\n// REST CRUD (10 tests)\n// ================================\ndescribe('REST CRUD', () => {\n  let app: AppInstance;\n  let port: number;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should create a document with title and content', async () => {\n    const res = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.id).toBeDefined();\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello');\n    expect(doc.created_at).toBeDefined();\n    expect(doc.updated_at).toBeDefined();\n  });\n\n  it('should create a document with empty content by default', async () => {\n    const res = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Empty Doc' }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.content).toBe('');\n  });\n\n  it('should reject document creation without title', async () => {\n    const res = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ content: 'no title' }),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Get Me' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(baseUrl, `/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.id).toBe(created.id);\n    expect(doc.title).toBe('Get Me');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await request(baseUrl, '/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should list all documents', async () => {\n    await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Doc 1' }),\n    });\n    await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Doc 2' }),\n    });\n\n    const res = await request(baseUrl, '/documents');\n    expect(res.status).toBe(200);\n    const docs = await res.json();\n    expect(docs.length).toBe(2);\n  });\n\n  it('should update a document title and content', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Original', content: 'old content' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(baseUrl, `/documents/${created.id}`, {\n      method: 'PUT',\n      body: JSON.stringify({ title: 'Updated', content: 'new content' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Updated');\n    expect(doc.content).toBe('new content');\n  });\n\n  it('should partially update a document with PATCH', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Patch Me', content: 'keep this' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(baseUrl, `/documents/${created.id}`, {\n      method: 'PATCH',\n      body: JSON.stringify({ title: 'Patched' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Patched');\n    expect(doc.content).toBe('keep this');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Delete Me' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(baseUrl, `/documents/${created.id}`, {\n      method: 'DELETE',\n    });\n    expect(res.status).toBe(204);\n\n    const getRes = await request(baseUrl, `/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should get version history for a document', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Versioned', content: 'v0' }),\n    });\n    const created = await createRes.json();\n\n    const res = await request(baseUrl, `/documents/${created.id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = await res.json();\n    expect(versions.length).toBeGreaterThanOrEqual(1);\n    expect(versions[0].version).toBe(0);\n    expect(versions[0].content).toBe('v0');\n  });\n});\n\n// ================================\n// WebSocket Lifecycle (8 tests)\n// ================================\ndescribe('WebSocket Lifecycle', () => {\n  let app: AppInstance;\n  let port: number;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should connect to a document via WebSocket', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'WS Doc' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    expect(ws.readyState).toBe(WebSocket.OPEN);\n    ws.close();\n  });\n\n  it('should receive sync message on connect', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Sync Doc', content: 'initial' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const msg = await waitForMessage<{ type: string; content: string; version: number }>(ws, 'sync');\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('initial');\n    expect(msg.version).toBeDefined();\n    ws.close();\n  });\n\n  it('should close connection for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    await waitForClose(ws);\n    expect(ws.readyState).toBe(WebSocket.CLOSED);\n  });\n\n  it('should handle multiple clients connecting to same document', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Multi Doc' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(port, doc.id);\n    const ws2 = await connectWs(port, doc.id);\n\n    await waitForMessage(ws1, 'sync');\n    await waitForMessage(ws2, 'sync');\n\n    expect(ws1.readyState).toBe(WebSocket.OPEN);\n    expect(ws2.readyState).toBe(WebSocket.OPEN);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle client disconnect cleanly', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Disconnect Doc' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    await waitForMessage(ws, 'sync');\n    ws.close();\n    await waitForClose(ws);\n    expect(ws.readyState).toBe(WebSocket.CLOSED);\n  });\n\n  it('should send sync with correct version number', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Version Doc', content: 'hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const msg = await waitForMessage<{ type: string; version: number }>(ws, 'sync');\n    expect(typeof msg.version).toBe('number');\n    expect(msg.version).toBeGreaterThanOrEqual(0);\n    ws.close();\n  });\n\n  it('should include documentId in sync message', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'ID Doc' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const msg = await waitForMessage<{ type: string; documentId: string }>(ws, 'sync');\n    expect(msg.documentId).toBe(doc.id);\n    ws.close();\n  });\n\n  it('should handle rapid connect/disconnect', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Rapid Doc' }),\n    });\n    const doc = await createRes.json();\n\n    const promises: Promise<void>[] = [];\n    for (let i = 0; i < 5; i++) {\n      promises.push(\n        connectWs(port, doc.id).then(async (ws) => {\n          await waitForMessage(ws, 'sync');\n          ws.close();\n          await waitForClose(ws);\n        })\n      );\n    }\n    await Promise.all(promises);\n  });\n});\n\n// ================================\n// Single Client Editing (6 tests)\n// ================================\ndescribe('Single Client Editing', () => {\n  let app: AppInstance;\n  let port: number;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should apply an insert operation', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Insert Doc', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'Hello' }],\n      version: sync.version,\n    }));\n\n    const ack = await waitForMessage<{ type: string; version: number }>(ws, 'ack');\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBeGreaterThan(sync.version);\n\n    // Verify via REST\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe('Hello');\n\n    ws.close();\n  });\n\n  it('should apply a delete operation', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Delete Op Doc', content: 'Hello World' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n\n    // Delete \"World\" (chars 6-10)\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 5 }, { delete: 6 }],\n      version: sync.version,\n    }));\n\n    await waitForMessage(ws, 'ack');\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe('Hello');\n\n    ws.close();\n  });\n\n  it('should apply multiple sequential operations', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Sequential Doc', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n\n    // Insert \"Hello\"\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'Hello' }],\n      version: sync.version,\n    }));\n    const ack1 = await waitForMessage<{ type: string; version: number }>(ws, 'ack');\n\n    // Insert \" World\" at end (doc is now \"Hello\", 5 chars)\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 5 }, { insert: ' World' }],\n      version: ack1.version,\n    }));\n    await waitForMessage(ws, 'ack');\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe('Hello World');\n\n    ws.close();\n  });\n\n  it('should create version history for each operation', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'History Doc', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'v1' }],\n      version: sync.version,\n    }));\n    const ack1 = await waitForMessage<{ type: string; version: number }>(ws, 'ack');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 2 }, { insert: ' v2' }],\n      version: ack1.version,\n    }));\n    await waitForMessage(ws, 'ack');\n\n    // Check versions\n    const versionsRes = await request(baseUrl, `/documents/${doc.id}/versions`);\n    const versions = await versionsRes.json();\n    expect(versions.length).toBeGreaterThanOrEqual(3); // version 0 + 2 edits\n\n    ws.close();\n  });\n\n  it('should handle insert in the middle of text', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Middle Insert', content: 'HelloWorld' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n\n    // Insert \" \" at position 5\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 5 }, { insert: ' ' }, { retain: 5 }],\n      version: sync.version,\n    }));\n    await waitForMessage(ws, 'ack');\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe('Hello World');\n\n    ws.close();\n  });\n\n  it('should handle replace (delete + insert)', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Replace Doc', content: 'Hello World' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n\n    // Replace \"World\" with \"Earth\"\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 6 }, { delete: 5 }, { insert: 'Earth' }],\n      version: sync.version,\n    }));\n    await waitForMessage(ws, 'ack');\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const updated = await getRes.json();\n    expect(updated.content).toBe('Hello Earth');\n\n    ws.close();\n  });\n});\n\n// ================================\n// Two-Client Convergence (8 tests)\n// ================================\ndescribe('Two-Client Convergence', () => {\n  let app: AppInstance;\n  let port: number;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Broadcast Doc', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(port, doc.id);\n    const ws2 = await connectWs(port, doc.id);\n\n    const sync1 = await waitForMessage<{ version: number }>(ws1, 'sync');\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1 sends an insert\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'Hello' }],\n      version: sync1.version,\n    }));\n\n    // Client 1 gets ack\n    await waitForMessage(ws1, 'ack');\n\n    // Client 2 should receive the operation\n    const opMsg = await waitForMessage<{ type: string; operation: unknown; version: number }>(ws2, 'operation');\n    expect(opMsg.type).toBe('operation');\n    expect(opMsg.operation).toBeDefined();\n    expect(opMsg.version).toBeDefined();\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should converge with concurrent inserts at different positions', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Converge Doc', content: 'Hello World' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(port, doc.id);\n    const ws2 = await connectWs(port, doc.id);\n\n    const sync1 = await waitForMessage<{ version: number }>(ws1, 'sync');\n    const sync2 = await waitForMessage<{ version: number }>(ws2, 'sync');\n\n    // Client 1: insert \"Dear \" at position 0 (based on \"Hello World\" = 11 chars)\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'Dear ' }, { retain: 11 }],\n      version: sync1.version,\n    }));\n\n    // Client 2: insert \"!\" at the end (based on same \"Hello World\" = 11 chars)\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 11 }, { insert: '!' }],\n      version: sync2.version,\n    }));\n\n    // Wait for all acks and operations to settle\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    // Give time for broadcasts\n    await new Promise(r => setTimeout(r, 200));\n\n    // Verify convergence via REST\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const final = await getRes.json();\n    expect(final.content).toContain('Dear');\n    expect(final.content).toContain('Hello World');\n    expect(final.content).toContain('!');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should converge with concurrent inserts at same position', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Same Pos Doc', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(port, doc.id);\n    const ws2 = await connectWs(port, doc.id);\n\n    const sync1 = await waitForMessage<{ version: number }>(ws1, 'sync');\n    const sync2 = await waitForMessage<{ version: number }>(ws2, 'sync');\n\n    // Both insert at position 0 on empty doc\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'AAA' }],\n      version: sync1.version,\n    }));\n\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'BBB' }],\n      version: sync2.version,\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const final = await getRes.json();\n\n    // Both inserts should be present\n    expect(final.content).toContain('AAA');\n    expect(final.content).toContain('BBB');\n    expect(final.content.length).toBe(6);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should converge with concurrent insert and delete', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Ins Del Doc', content: 'Hello World' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(port, doc.id);\n    const ws2 = await connectWs(port, doc.id);\n\n    const sync1 = await waitForMessage<{ version: number }>(ws1, 'sync');\n    const sync2 = await waitForMessage<{ version: number }>(ws2, 'sync');\n\n    // Client 1: insert \"!\" at end\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 11 }, { insert: '!' }],\n      version: sync1.version,\n    }));\n\n    // Client 2: delete \"World\" (chars 6-10)\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 5 }, { delete: 6 }],\n      version: sync2.version,\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const final = await getRes.json();\n\n    // Should have \"Hello\" with \"!\" but without \" World\"\n    expect(final.content).toContain('Hello');\n    expect(final.content).toContain('!');\n    expect(final.content).not.toContain('World');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should preserve both insertions when concurrent', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Preserve Doc', content: 'AB' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(port, doc.id);\n    const ws2 = await connectWs(port, doc.id);\n\n    const sync1 = await waitForMessage<{ version: number }>(ws1, 'sync');\n    const sync2 = await waitForMessage<{ version: number }>(ws2, 'sync');\n\n    // Client 1: insert \"X\" between A and B\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 1 }, { insert: 'X' }, { retain: 1 }],\n      version: sync1.version,\n    }));\n\n    // Client 2: insert \"Y\" between A and B\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 1 }, { insert: 'Y' }, { retain: 1 }],\n      version: sync2.version,\n    }));\n\n    await waitForMessage(ws1, 'ack');\n    await waitForMessage(ws2, 'ack');\n\n    await new Promise(r => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const final = await getRes.json();\n\n    expect(final.content).toContain('X');\n    expect(final.content).toContain('Y');\n    expect(final.content).toContain('A');\n    expect(final.content).toContain('B');\n    expect(final.content.length).toBe(4);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle three sequential edits from two clients', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Three Edits', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(port, doc.id);\n    const ws2 = await connectWs(port, doc.id);\n\n    const sync1 = await waitForMessage<{ version: number }>(ws1, 'sync');\n    await waitForMessage(ws2, 'sync');\n\n    // Client 1: insert \"Hello\"\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'Hello' }],\n      version: sync1.version,\n    }));\n    const ack1 = await waitForMessage<{ version: number }>(ws1, 'ack');\n    const op1 = await waitForMessage<{ version: number }>(ws2, 'operation');\n\n    // Client 2: insert \" World\" at end (after receiving op1, doc = \"Hello\")\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 5 }, { insert: ' World' }],\n      version: op1.version,\n    }));\n    const ack2 = await waitForMessage<{ version: number }>(ws2, 'ack');\n    await waitForMessage(ws1, 'operation');\n\n    // Client 1: insert \"!\" at end (after receiving op from client 2, doc = \"Hello World\")\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 11 }, { insert: '!' }],\n      version: ack2.version,\n    }));\n    await waitForMessage(ws1, 'ack');\n\n    await new Promise(r => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const final = await getRes.json();\n    expect(final.content).toBe('Hello World!');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should update version after each operation', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Version Track', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n    const v0 = sync.version;\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'A' }],\n      version: v0,\n    }));\n    const ack1 = await waitForMessage<{ version: number }>(ws, 'ack');\n    expect(ack1.version).toBeGreaterThan(v0);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 1 }, { insert: 'B' }],\n      version: ack1.version,\n    }));\n    const ack2 = await waitForMessage<{ version: number }>(ws, 'ack');\n    expect(ack2.version).toBeGreaterThan(ack1.version);\n\n    ws.close();\n  });\n\n  it('should handle late-joining client getting correct state', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Late Join', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    // Client 1 connects and makes edits\n    const ws1 = await connectWs(port, doc.id);\n    const sync1 = await waitForMessage<{ version: number }>(ws1, 'sync');\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'Hello' }],\n      version: sync1.version,\n    }));\n    await waitForMessage(ws1, 'ack');\n\n    // Now client 2 joins late\n    const ws2 = await connectWs(port, doc.id);\n    const sync2 = await waitForMessage<{ type: string; content: string; version: number }>(ws2, 'sync');\n\n    expect(sync2.content).toBe('Hello');\n    expect(sync2.version).toBeGreaterThan(sync1.version);\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\n// ================================\n// Stress Test (5 tests)\n// ================================\ndescribe('Stress Test', () => {\n  let app: AppInstance;\n  let port: number;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should handle 10 concurrent client connections', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: '10 Clients', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const clients: WebSocket[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(port, doc.id);\n      await waitForMessage(ws, 'sync');\n      clients.push(ws);\n    }\n\n    expect(clients.length).toBe(10);\n    expect(clients.every(ws => ws.readyState === WebSocket.OPEN)).toBe(true);\n\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it('should handle 10 concurrent inserts without corruption', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Concurrent Inserts', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const N = 10;\n    const clients: WebSocket[] = [];\n    const syncs: { version: number }[] = [];\n\n    for (let i = 0; i < N; i++) {\n      const ws = await connectWs(port, doc.id);\n      const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n      clients.push(ws);\n      syncs.push(sync);\n    }\n\n    // All clients send inserts based on their initial version\n    for (let i = 0; i < N; i++) {\n      clients[i].send(JSON.stringify({\n        type: 'operation',\n        operation: [{ insert: String(i) }],\n        version: syncs[i].version,\n      }));\n    }\n\n    // Wait for all acks\n    const ackPromises = clients.map(ws => waitForMessage(ws, 'ack'));\n    await Promise.all(ackPromises);\n\n    // Give time for all transforms to complete\n    await new Promise(r => setTimeout(r, 500));\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const final = await getRes.json();\n\n    // All digits 0-9 should be present\n    for (let i = 0; i < N; i++) {\n      expect(final.content).toContain(String(i));\n    }\n    expect(final.content.length).toBe(N);\n\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it('should maintain document integrity under rapid sequential edits', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Rapid Edits', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n    let currentVersion = sync.version;\n\n    // Send 20 rapid inserts\n    for (let i = 0; i < 20; i++) {\n      const op: unknown[] = [];\n      if (i > 0) op.push({ retain: i });\n      op.push({ insert: String.fromCharCode(65 + (i % 26)) });\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: op,\n        version: currentVersion,\n      }));\n      const ack = await waitForMessage<{ version: number }>(ws, 'ack');\n      currentVersion = ack.version;\n    }\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const final = await getRes.json();\n    expect(final.content.length).toBe(20);\n\n    ws.close();\n  });\n\n  it('should not crash when clients disconnect mid-operation', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Disconnect Mid', content: 'Hello' }),\n    });\n    const doc = await createRes.json();\n\n    // Connect and immediately disconnect several clients\n    for (let i = 0; i < 5; i++) {\n      const ws = await connectWs(port, doc.id);\n      ws.send(JSON.stringify({\n        type: 'operation',\n        operation: [{ retain: 5 }, { insert: '!' }],\n        version: 0,\n      }));\n      ws.close();\n    }\n\n    // Wait a bit then verify server still works\n    await new Promise(r => setTimeout(r, 300));\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ type: string; content: string }>(ws, 'sync');\n    expect(sync.type).toBe('sync');\n    expect(typeof sync.content).toBe('string');\n\n    ws.close();\n  });\n\n  it('should handle interleaved edits from multiple clients', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Interleaved', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(port, doc.id);\n    const ws2 = await connectWs(port, doc.id);\n\n    const sync1 = await waitForMessage<{ version: number }>(ws1, 'sync');\n    await waitForMessage(ws2, 'sync');\n\n    let v = sync1.version;\n\n    // Alternating edits from two clients, each waiting for ack\n    for (let i = 0; i < 5; i++) {\n      // Client 1 inserts\n      ws1.send(JSON.stringify({\n        type: 'operation',\n        operation: [{ retain: i * 2 }, { insert: 'A' }],\n        version: v,\n      }));\n      const ack1 = await waitForMessage<{ version: number }>(ws1, 'ack');\n      await waitForMessage(ws2, 'operation');\n      v = ack1.version;\n\n      // Client 2 inserts\n      ws2.send(JSON.stringify({\n        type: 'operation',\n        operation: [{ retain: i * 2 + 1 }, { insert: 'B' }],\n        version: v,\n      }));\n      const ack2 = await waitForMessage<{ version: number }>(ws2, 'ack');\n      await waitForMessage(ws1, 'operation');\n      v = ack2.version;\n    }\n\n    const getRes = await request(baseUrl, `/documents/${doc.id}`);\n    const final = await getRes.json();\n    expect(final.content.length).toBe(10);\n    expect((final.content.match(/A/g) || []).length).toBe(5);\n    expect((final.content.match(/B/g) || []).length).toBe(5);\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\n// ================================\n// Error Handling (5 tests)\n// ================================\ndescribe('Error Handling', () => {\n  let app: AppInstance;\n  let port: number;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should reject invalid JSON over WebSocket', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Error Doc' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send('not json{{{');\n    const errMsg = await waitForMessage<{ type: string; message: string }>(ws, 'error');\n    expect(errMsg.type).toBe('error');\n    expect(errMsg.message).toBeDefined();\n\n    // Connection should still be open\n    expect(ws.readyState).toBe(WebSocket.OPEN);\n    ws.close();\n  });\n\n  it('should reject operation with wrong document length', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Wrong Length', content: 'Hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n\n    // Send operation that doesn't match doc length (doc is 5 chars but we retain 10)\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 10 }],\n      version: sync.version,\n    }));\n\n    const errMsg = await waitForMessage<{ type: string; message: string }>(ws, 'error');\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject operation with future version', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Future Version' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'X' }],\n      version: 9999,\n    }));\n\n    const errMsg = await waitForMessage<{ type: string; message: string }>(ws, 'error');\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject malformed operation components', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Malformed Op' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    await waitForMessage(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ unknown: 'field' }],\n      version: 0,\n    }));\n\n    const errMsg = await waitForMessage<{ type: string; message: string }>(ws, 'error');\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should not crash the server on repeated errors', async () => {\n    const createRes = await request(baseUrl, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Repeated Errors', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port, doc.id);\n    await waitForMessage(ws, 'sync');\n\n    // Send multiple bad messages\n    for (let i = 0; i < 5; i++) {\n      ws.send('bad message');\n      await waitForMessage(ws, 'error');\n    }\n\n    // Should still be able to send a valid operation\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'Works' }],\n      version: 0,\n    }));\n    const ack = await waitForMessage<{ type: string }>(ws, 'ack');\n    expect(ack.type).toBe('ack');\n\n    ws.close();\n  });\n});\n\n// ================================\n// Persistence (3 tests)\n// ================================\ndescribe('Persistence', () => {\n  let dbPath: string;\n\n  beforeAll(() => {\n    dbPath = join(tmpdir(), `collab-test-${randomUUID()}.db`);\n  });\n\n  afterAll(() => {\n    if (existsSync(dbPath)) {\n      try { unlinkSync(dbPath); } catch { /* ignore */ }\n    }\n  });\n\n  it('should persist documents across server restarts', async () => {\n    // Start server, create document\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n    const baseUrl1 = `http://localhost:${port1}`;\n\n    const createRes = await request(baseUrl1, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Persist Doc', content: 'original content' }),\n    });\n    const doc = await createRes.json();\n    const docId = doc.id;\n\n    await app1.stop();\n\n    // Restart server with same DB\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n    const baseUrl2 = `http://localhost:${port2}`;\n\n    const getRes = await request(baseUrl2, `/documents/${docId}`);\n    expect(getRes.status).toBe(200);\n    const retrieved = await getRes.json();\n    expect(retrieved.title).toBe('Persist Doc');\n    expect(retrieved.content).toBe('original content');\n\n    await app2.stop();\n  });\n\n  it('should persist WebSocket edits across server restarts', async () => {\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n    const baseUrl1 = `http://localhost:${port1}`;\n\n    // Create document and edit via WS\n    const createRes = await request(baseUrl1, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'WS Persist', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(port1, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ insert: 'Persisted Content' }],\n      version: sync.version,\n    }));\n    await waitForMessage(ws, 'ack');\n    ws.close();\n    await waitForClose(ws);\n\n    await app1.stop();\n\n    // Restart and verify\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n    const baseUrl2 = `http://localhost:${port2}`;\n\n    const getRes = await request(baseUrl2, `/documents/${doc.id}`);\n    const retrieved = await getRes.json();\n    expect(retrieved.content).toBe('Persisted Content');\n\n    await app2.stop();\n  });\n\n  it('should persist version history across restarts', async () => {\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n    const baseUrl1 = `http://localhost:${port1}`;\n\n    const createRes = await request(baseUrl1, '/documents', {\n      method: 'POST',\n      body: JSON.stringify({ title: 'Version Persist', content: 'v0' }),\n    });\n    const doc = await createRes.json();\n\n    // Make an edit to create version history\n    const ws = await connectWs(port1, doc.id);\n    const sync = await waitForMessage<{ version: number }>(ws, 'sync');\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: [{ retain: 2 }, { insert: ' v1' }],\n      version: sync.version,\n    }));\n    await waitForMessage(ws, 'ack');\n    ws.close();\n    await waitForClose(ws);\n\n    await app1.stop();\n\n    // Restart and check versions\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n    const baseUrl2 = `http://localhost:${port2}`;\n\n    const versionsRes = await request(baseUrl2, `/documents/${doc.id}/versions`);\n    const versions = await versionsRes.json();\n    expect(versions.length).toBeGreaterThanOrEqual(2);\n\n    await app2.stop();\n  });\n});\n","structuredPatch":[{"oldStart":1068,"oldLines":20,"newStart":1068,"newLines":24,"lines":[" ","     // Alternating edits from two clients, each waiting for ack","     for (let i = 0; i < 5; i++) {","-      // Client 1 inserts","+      // Client 1 inserts at end","+      const op1: unknown[] = [];","+      if (i * 2 > 0) op1.push({ retain: i * 2 });","+      op1.push({ insert: 'A' });","       ws1.send(JSON.stringify({","         type: 'operation',","-        operation: [{ 