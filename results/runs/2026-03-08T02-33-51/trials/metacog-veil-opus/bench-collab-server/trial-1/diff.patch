;\n\n  // Delete a document\n  router.delete('/documents/:id', (req, res) => {\n    const deleted = store.deleteDocument(req.params.id);\n    if (!deleted) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get version history\n  router.get('/documents/:id/versions', (req, res) => {\n    const doc = store.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = store.getVersions(req.params.id);\n    res.json(versions);\n  });\n\n  // Get specific version\n  router.get('/documents/:id/versions/:version', (req, res) => {\n    const doc = store.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versionNum = parseInt(req.params.version, 10);\n    if (isNaN(versionNum)) {\n      res.status(400).json({ error: 'Version must be a number' });\n      return;\n    }\n    const version = store.getVersion(req.params.id, versionNum);\n    if (!version) {\n      res.status(404).json({ error: 'Version not found' });\n      return;\n    }\n    res.json(version);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":355,"cache_read_input_tokens":29047,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":355},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0aa54153-d7a1-473d-af54-ef2915f3765c","uuid":"8a486f4e-ccca-4886-8d12-83538981af04"}
