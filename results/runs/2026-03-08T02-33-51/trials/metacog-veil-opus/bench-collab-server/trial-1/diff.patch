@@ -0,0 +1,101 @@
+import { Router, json } from 'express';
+import { DocumentStore } from './db.js';
+
+export function createRouter(store: DocumentStore): Router {
+  const router = Router();
+  router.use(json());
+
+  // List all documents
+  router.get('/documents', (_req, res) => {
+    const docs = store.listDocuments();
+    res.json(docs);
+  });
+
+  // Create a new document
+  router.post('/documents', (req, res) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'title is required and must be a string' });
+      return;
+    }
+    const doc = store.createDocument(title, content ?? '');
+    res.status(201).json(doc);
+  });
+
+  // Get a single document
+  router.get('/documents/:id', (req, res) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document
+  router.put('/documents/:id', (req, res) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const { title, content } = req.body;
+    const updated = store.updateDocument(req.params.id, { title, content });
+    res.json(updated);
+  });
+
+  // Partially update a document
+  router.patch('/documents/:id', (req, res) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const { title, content } = req.body;
+    const updated = store.updateDocument(req.params.id, { title, content });
+    res.json(updated);
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req, res) => {
+    const deleted = store.deleteDocument(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get version history
+  router.get('/documents/:id/versions', (req, res) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = store.getVersions(req.params.id);
+    res.json(versions);
+  });
+
+  // Get specific version
+  router.get('/documents/:id/versions/:version', (req, res) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versionNum = parseInt(req.params.version, 10);
+    if (isNaN(versionNum)) {
+      res.status(400).json({ error: 'Version must be a number' });
+      return;
+    }
+    const version = store.getVersion(req.params.id, versionNum);
+    if (!version) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+    res.json(version);
+  });
+
+  return router;
+}
