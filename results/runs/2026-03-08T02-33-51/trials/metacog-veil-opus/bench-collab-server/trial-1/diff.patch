rver: true });\n\n    this.upgradeHandler = (request: IncomingMessage, socket: Duplex, head: Buffer) => {\n      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);\n      const pathMatch = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/) ||\n                        url.pathname.match(/^\\/documents\\/([^/]+)\\/ws$/);\n\n      if (!pathMatch) {\n        socket.destroy();\n        return;\n      }\n\n      const documentId = pathMatch[1];\n      (request as IncomingMessage & { documentId: string }).documentId = documentId;\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request);\n      });\n    };\n\n    server.on('upgrade', this.upgradeHandler);\n\n    this.wss.on('connection', (ws: WebSocket, request: IncomingMessage) => {\n      const documentId = (request as IncomingMessage & { documentId?: string }).documentId;\n      if (!documentId) {\n        this.sendMessage(ws, { type: 'error', message: 'No document ID' });\n        ws.close();\n        return;\n      }\n\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private sendMessage(ws: WebSocket, msg: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  private getOrCreateRoom(documentId: string): DocumentRoom | null {\n    let room = this.rooms.get(documentId);\n    if (room) return room;\n\n    const doc = this.store.getDocument(documentId);\n    if (!doc) return null;\n\n    const version = this.store.getCurrentVersion(documentId);\n\n    room = {\n      documentId,\n      clients: new Map(),\n      operationLog: [],\n      version,\n    };\n    this.rooms.set(documentId, room);\n    return room;\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const room = this.getOrCreateRoom(documentId);\n    if (!room) {\n      this.sendMessage(ws, { type: 'error', message: 'Document not found' });\n      ws.close();\n      return;\n    }\n\n    const clientId = randomUUID();\n    const client: ClientConnection = {\n      id: clientId,\n      ws,\n      documentId,\n      acknowledgedVersion: room.version,\n    };\n\n    room.clients.set(clientId, client);\n\n    const doc = this.store.getDocument(documentId);\n    if (doc) {\n      this.sendMessage(ws, {\n        type: 'sync',\n        content: doc.content,\n        version: room.version,\n        documentId,\n      });\n    }\n\n    ws.on('message', (data) => {\n      try {\n        const msg = JSON.parse(data.toString()) as ClientMessage;\n        this.handleClientMessage(client, room, msg);\n      } catch (err) {\n        this.sendMessage(ws, {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        });\n      }\n    });\n\n    ws.on('close', () => {\n      room.clients.delete(clientId);\n      if (room.clients.size === 0) {\n        this.rooms.delete(documentId);\n      }\n    });\n\n    ws.on('error', () => {\n      room.clients.delete(clientId);\n      if (room.clients.size === 0) {\n        this.rooms.delete(documentId);\n      }\n    });\n  }\n\n  private handleClientMessage(\n    client: ClientConnection,\n    room: DocumentRoom,\n    msg: ClientMessage\n  ): void {\n    if (msg.type === 'operation') {\n      this.handleOperation(client, room, msg as ClientOperationMessage);\n    }\n  }\n\n  private handleOperation(\n    client: ClientConnection,\n    room: DocumentRoom,\n    msg: ClientOperationMessage\n  ): void {\n    const { operation, version: clientVersion } = msg;\n\n    if (typeof clientVersion !== 'number' || clientVersion < 0) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: 'Invalid version number',\n      });\n      return;\n    }\n\n    if (clientVersion > room.version) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Client version ${clientVersion} is ahead of server version ${room.version}`,\n      });\n      return;\n    }\n\n    const doc = this.store.getDocument(room.documentId);\n    if (!doc) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: 'Document no longer exists',\n      });\n      return;\n    }\n\n    // Transform the operation against all operations that happened since clientVersion\n    let transformedOp = operation;\n\n    const startIdx = clientVersion - (room.version - room.operationLog.length);\n\n    for (let i = Math.max(0, startIdx); i < room.operationLog.length; i++) {\n      const serverOp = room.operationLog[i];\n      if (serverOp.version > clientVersion) {\n        try {\n          const [, bPrime] = transform(serverOp.operation, transformedOp, true);\n          transformedOp = bPrime;\n        } catch (err) {\n          this.sendMessage(client.ws, {\n            type: 'error',\n            message: `Transform error: ${err instanceof Error ? err.message : 'unknown'}`,\n          });\n          return;\n        }\n      }\n    }\n\n    // Validate the transformed operation against current document\n    const validationError = validate(transformedOp, doc.content.length);\n    if (validationError) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: validationError,\n      });\n      return;\n    }\n\n    // Apply the transformed operation\n    let newContent: string;\n    try {\n      newContent = apply(doc.content, transformedOp);\n    } catch (err) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Apply error: ${err instanceof Error ? err.message : 'unknown'}`,\n      });\n      return;\n    }\n\n    // Persist\n    const newVersion = this.store.updateContent(room.documentId, newContent, transformedOp);\n    room.version = newVersion;\n    room.operationLog.push({ operation: transformedOp, version: newVersion });\n\n    // Ack the sender\n    client.acknowledgedVersion = newVersion;\n    this.sendMessage(client.ws, {\n      type: 'ack',\n      version: newVersion,\n    });\n\n    // Broadcast to other clients\n    for (const [id, otherClient] of room.clients) {\n      if (id !== client.id) {\n        this.sendMessage(otherClient.ws, {\n          type: 'operation',\n          operation: transformedOp,\n          version: newVersion,\n          clientId: client.id,\n        });\n      }\n    }\n  }\n\n  closeAll(): void {\n    for (const room of this.rooms.values()) {\n      for (const client of room.clients.values()) {\n        client.ws.close();\n      }\n    }\n    this.rooms.clear();\n    this.wss.close();\n    this.server.removeListener('upgrade', this.upgradeHandler);\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3683,"cache_read_input_tokens":62364,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3683},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0aa54153-d7a1-473d-af54-ef2915f3765c","uuid":"34a1ea23-af36-42c0-97a0-1abb0cee5f19"}
