diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..18eab54
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,154 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDb(dbPath: string = ':memory:'): Database.Database {
+  const db = Database(dbPath);
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      operation TEXT,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      UNIQUE(document_id, version)
+    );
+
+    CREATE TABLE IF NOT EXISTS active_connections (
+      id TEXT PRIMARY KEY,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+  `);
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version (version 0)
+    const versionStmt = this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, 0, ?, NULL)`
+    );
+    versionStmt.run(id, content);
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    const stmt = this.db.prepare(`SELECT * FROM documents WHERE id = ?`);
+    return stmt.get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare(`SELECT * FROM documents ORDER BY updated_at DESC`);
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    const stmt = this.db.prepare(
+      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+    );
+    stmt.run(title, content, id);
+
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const stmt = this.db.prepare(`DELETE FROM documents WHERE id = ?`);
+    const result = stmt.run(id);
+    return result.changes > 0;
+  }
+
+  updateContent(id: string, content: string, operation?: object): number {
+    const doc = this.getDocument(id);
+    if (!doc) throw new Error('Document not found');
+
+    // Get current version number
+    const versionStmt = this.db.prepare(
+      `SELECT COALESCE(MAX(version), -1) as max_version FROM versions WHERE document_id = ?`
+    );
+    const row = versionStmt.get(id) as { max_version: number };
+    const newVersion = row.max_version + 1;
+
+    // Update document content
+    const updateStmt = this.db.prepare(
+      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`
+    );
+    updateStmt.run(content, id);
+
+    // Insert version record
+    const insertVersionStmt = this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`
+    );
+    insertVersionStmt.run(id, newVersion, content, operation ? JSON.stringify(operation) : null);
+
+    return newVersion;
+  }
+
+  getVersions(documentId: string): Version[] {
+    const stmt = this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+    );
+    return stmt.all(documentId) as Version[];
+  }
+
+  getVersion(documentId: string, version: number): Version | undefined {
+    const stmt = this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? AND version = ?`
+    );
+    return stmt.get(documentId, version) as Version | undefined;
+  }
+
+  getCurrentVersion(documentId: string): number {
+    const stmt = this.db.prepare(
+      `SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?`
+    );
+    const row = stmt.get(documentId) as { max_version: number };
+    return row.max_version;
+  }
+}
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..817ade2
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,373 @@
+/**
+ * Operational Transform engine for collaborative text editing.
+ *
+ * Operations are sequences of components:
+ * - { retain: n }  -- skip n characters
+ * - { insert: s }  -- insert string s at the current position
+ * - { delete: n }  -- delete n characters from the current position
+ *
+ * An operation's "input length" must match the length of the document it's applied to.
+ * Its "output length" is the resulting document length after application.
+ */
+
+export type OpComponent =
+  | { retain: number }
+  | { insert: string }
+  | { delete: number };
+
+export type Operation = OpComponent[];
+
+function isRetain(op: OpComponent): op is { retain: number } {
+  return 'retain' in op;
+}
+
+function isInsert(op: OpComponent): op is { insert: string } {
+  return 'insert' in op;
+}
+
+function isDelete(op: OpComponent): op is { delete: number } {
+  return 'delete' in op;
+}
+
+/** Calculate the input length of an operation (length of document it applies to) */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (isRetain(c)) len += c.retain;
+    else if (isDelete(c)) len += c.delete;
+    // inserts don't consume input
+  }
+  return len;
+}
+
+/** Calculate the output length of an operation */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (isRetain(c)) len += c.retain;
+    else if (isInsert(c)) len += c.insert.length;
+    // deletes don't produce output
+  }
+  return len;
+}
+
+/** Apply an operation to a document string */
+export function apply(doc: string, op: Operation): string {
+  const inLen = inputLength(op);
+  if (inLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${inLen}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (isRetain(c)) {
+      result += doc.slice(pos, pos + c.retain);
+      pos += c.retain;
+    } else if (isInsert(c)) {
+      result += c.insert;
+    } else if (isDelete(c)) {
+      pos += c.delete;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Normalize an operation by merging consecutive same-type components
+ * and removing no-ops.
+ */
+function normalize(op: Operation): Operation {
+  const result: Operation = [];
+
+  for (const c of op) {
+    if (isRetain(c) && c.retain === 0) continue;
+    if (isDelete(c) && c.delete === 0) continue;
+    if (isInsert(c) && c.insert === '') continue;
+
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (isRetain(c) && isRetain(last)) {
+        result[result.length - 1] = { retain: last.retain + c.retain };
+        continue;
+      }
+      if (isInsert(c) && isInsert(last)) {
+        result[result.length - 1] = { insert: last.insert + c.insert };
+        continue;
+      }
+      if (isDelete(c) && isDelete(last)) {
+        result[result.length - 1] = { delete: last.delete + c.delete };
+        continue;
+      }
+    }
+
+    result.push(c);
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations (a and b) that were both based on the same
+ * document state, producing a' and b' such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Returns [aPrime, bPrime].
+ *
+ * The `aIsFirst` parameter determines priority: when both insert at the same position,
+ * if aIsFirst is true, a's insert goes first (comes before b's insert in the result).
+ */
+export function transform(a: Operation, b: Operation, aIsFirst: boolean = true): [Operation, Operation] {
+  const aLen = inputLength(a);
+  const bLen = inputLength(b);
+  if (aLen !== bLen) {
+    throw new Error(
+      `Operations have different input lengths: a=${aLen}, b=${bLen}`
+    );
+  }
+
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  // Iterator state for each operation
+  let ai = 0;
+  let bi = 0;
+  let aRem: OpComponent | null = null;
+  let bRem: OpComponent | null = null;
+
+  function nextA(): OpComponent | null {
+    if (aRem) {
+      const r = aRem;
+      aRem = null;
+      return r;
+    }
+    if (ai < a.length) return a[ai++];
+    return null;
+  }
+
+  function nextB(): OpComponent | null {
+    if (bRem) {
+      const r = bRem;
+      bRem = null;
+      return r;
+    }
+    if (bi < b.length) return b[bi++];
+    return null;
+  }
+
+  for (;;) {
+    const ca = nextA();
+    const cb = nextB();
+
+    if (ca === null && cb === null) break;
+
+    // If a inserts, include in a' and make b' retain over it
+    if (ca !== null && isInsert(ca)) {
+      if (cb !== null && isInsert(cb)) {
+        // Both insert: priority determines who goes first
+        if (aIsFirst) {
+          aPrime.push(ca);
+          bPrime.push({ retain: ca.insert.length });
+          // Put cb back
+          bRem = cb;
+        } else {
+          bPrime.push(cb);
+          aPrime.push({ retain: cb.insert.length });
+          // Put ca back
+          aRem = ca;
+        }
+      } else {
+        aPrime.push(ca);
+        bPrime.push({ retain: ca.insert.length });
+        // Put cb back since we didn't consume it
+        if (cb !== null) bRem = cb;
+      }
+      continue;
+    }
+
+    // If b inserts (and a doesn't), include in b' and make a' retain over it
+    if (cb !== null && isInsert(cb)) {
+      bPrime.push(cb);
+      aPrime.push({ retain: cb.insert.length });
+      // Put ca back since we didn't consume it
+      if (ca !== null) aRem = ca;
+      continue;
+    }
+
+    if (ca === null || cb === null) {
+      throw new Error('Operation length mismatch during transform');
+    }
+
+    // Both retain
+    if (isRetain(ca) && isRetain(cb)) {
+      const minLen = Math.min(ca.retain, cb.retain);
+      aPrime.push({ retain: minLen });
+      bPrime.push({ retain: minLen });
+      if (ca.retain > minLen) aRem = { retain: ca.retain - minLen };
+      if (cb.retain > minLen) bRem = { retain: cb.retain - minLen };
+    }
+    // a deletes, b retains
+    else if (isDelete(ca) && isRetain(cb)) {
+      const minLen = Math.min(ca.delete, cb.retain);
+      aPrime.push({ delete: minLen });
+      // b's retain is "consumed" by a's delete, so b' gets nothing for this portion
+      if (ca.delete > minLen) aRem = { delete: ca.delete - minLen };
+      if (cb.retain > minLen) bRem = { retain: cb.retain - minLen };
+    }
+    // a retains, b deletes
+    else if (isRetain(ca) && isDelete(cb)) {
+      const minLen = Math.min(ca.retain, cb.delete);
+      bPrime.push({ delete: minLen });
+      if (ca.retain > minLen) aRem = { retain: ca.retain - minLen };
+      if (cb.delete > minLen) bRem = { delete: cb.delete - minLen };
+    }
+    // Both delete
+    else if (isDelete(ca) && isDelete(cb)) {
+      const minLen = Math.min(ca.delete, cb.delete);
+      // Both delete the same text — nothing to do in either prime
+      if (ca.delete > minLen) aRem = { delete: ca.delete - minLen };
+      if (cb.delete > minLen) bRem = { delete: cb.delete - minLen };
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/**
+ * Compose two sequential operations into a single operation.
+ * op1 applied first, then op2 on the result of op1.
+ * The result is a single operation that has the same effect.
+ */
+export function compose(op1: Operation, op2: Operation): Operation {
+  const op1Out = outputLength(op1);
+  const op2In = inputLength(op2);
+  if (op1Out !== op2In) {
+    throw new Error(
+      `Cannot compose: op1 output length (${op1Out}) !== op2 input length (${op2In})`
+    );
+  }
+
+  const result: Operation = [];
+  let i1 = 0;
+  let i2 = 0;
+  let rem1: OpComponent | null = null;
+  let rem2: OpComponent | null = null;
+
+  function next1(): OpComponent | null {
+    if (rem1) { const r = rem1; rem1 = null; return r; }
+    if (i1 < op1.length) return op1[i1++];
+    return null;
+  }
+
+  function next2(): OpComponent | null {
+    if (rem2) { const r = rem2; rem2 = null; return r; }
+    if (i2 < op2.length) return op2[i2++];
+    return null;
+  }
+
+  for (;;) {
+    const c1 = next1();
+    const c2 = next2();
+
+    if (c1 === null && c2 === null) break;
+
+    // op1 deletes: pass through to result (doesn't consume op2)
+    if (c1 !== null && isDelete(c1)) {
+      result.push(c1);
+      if (c2 !== null) rem2 = c2;
+      continue;
+    }
+
+    // op2 inserts: pass through to result (doesn't consume op1)
+    if (c2 !== null && isInsert(c2)) {
+      result.push(c2);
+      if (c1 !== null) rem1 = c1;
+      continue;
+    }
+
+    if (c1 === null || c2 === null) {
+      throw new Error('Operation length mismatch during compose');
+    }
+
+    // op1 retains, op2 retains
+    if (isRetain(c1) && isRetain(c2)) {
+      const minLen = Math.min(c1.retain, c2.retain);
+      result.push({ retain: minLen });
+      if (c1.retain > minLen) rem1 = { retain: c1.retain - minLen };
+      if (c2.retain > minLen) rem2 = { retain: c2.retain - minLen };
+    }
+    // op1 retains, op2 deletes
+    else if (isRetain(c1) && isDelete(c2)) {
+      const minLen = Math.min(c1.retain, c2.delete);
+      result.push({ delete: minLen });
+      if (c1.retain > minLen) rem1 = { retain: c1.retain - minLen };
+      if (c2.delete > minLen) rem2 = { delete: c2.delete - minLen };
+    }
+    // op1 inserts, op2 retains
+    else if (isInsert(c1) && isRetain(c2)) {
+      const minLen = Math.min(c1.insert.length, c2.retain);
+      result.push({ insert: c1.insert.slice(0, minLen) });
+      if (c1.insert.length > minLen) rem1 = { insert: c1.insert.slice(minLen) };
+      if (c2.retain > minLen) rem2 = { retain: c2.retain - minLen };
+    }
+    // op1 inserts, op2 deletes
+    else if (isInsert(c1) && isDelete(c2)) {
+      const minLen = Math.min(c1.insert.length, c2.delete);
+      // insertion followed by deletion cancels out
+      if (c1.insert.length > minLen) rem1 = { insert: c1.insert.slice(minLen) };
+      if (c2.delete > minLen) rem2 = { delete: c2.delete - minLen };
+    }
+  }
+
+  return normalize(result);
+}
+
+/**
+ * Validate an operation against a document length.
+ * Returns null if valid, or an error message string.
+ */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) {
+    return 'Operation must be an array';
+  }
+
+  for (let i = 0; i < op.length; i++) {
+    const c = op[i];
+    if (typeof c !== 'object' || c === null) {
+      return `Component ${i} is not an object`;
+    }
+
+    const keys = Object.keys(c);
+    if (keys.length !== 1) {
+      return `Component ${i} must have exactly one key (retain, insert, or delete)`;
+    }
+
+    const key = keys[0];
+    if (key === 'retain') {
+      if (typeof (c as { retain: unknown }).retain !== 'number' || (c as { retain: number }).retain <= 0) {
+        return `Component ${i}: retain must be a positive number`;
+      }
+    } else if (key === 'insert') {
+      if (typeof (c as { insert: unknown }).insert !== 'string' || (c as { insert: string }).insert.length === 0) {
+        return `Component ${i}: insert must be a non-empty string`;
+      }
+    } else if (key === 'delete') {
+      if (typeof (c as { delete: unknown }).delete !== 'number' || (c as { delete: number }).delete <= 0) {
+        return `Component ${i}: delete must be a positive number`;
+      }
+    } else {
+      return `Component ${i}: unknown operation type '${key}'`;
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
