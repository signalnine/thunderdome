dd tasks: queue is shutting down');\n    }\n\n    const queue = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Resolve dependencies\n    const dependencies = options?.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.allTasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Check circular dependencies\n    if (dependencies.length > 0) {\n      // We'll verify after creating the task ID, but before inserting\n    }\n\n    const now = new Date();\n    let availableAt = now;\n    if (options?.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options?.delay) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: now,\n      priority,\n      queue,\n      availableAt,\n      attempt: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failCount: 0,\n      dependencies: [...dependencies],\n      progress: 0,\n    };\n\n    // Check circular dependencies\n    if (dependencies.length > 0) {\n      this.checkCircularDeps(task.id, dependencies);\n    }\n\n    const q = this.getOrCreateQueue(queue);\n    q.tasks.set(task.id, task as Task);\n    this.allTasks.set(task.id, task as Task);\n\n    return task;\n  }\n\n  private checkCircularDeps(taskId: string, dependencies: string[]): void {\n    // BFS: starting from each dependency, walk through its dependents\n    // If we reach taskId, it's circular\n    const visited = new Set<string>();\n    const stack = [...dependencies];\n\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === taskId) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n\n      const currentTask = this.allTasks.get(current);\n      if (currentTask) {\n        for (const depId of currentTask.dependencies) {\n          stack.push(depId);\n        }\n      }\n    }\n  }\n\n  getTask(id: string): Task | null {\n    return this.allTasks.get(id) ?? null;\n  }\n\n  getNextTask(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const q = this.queues.get(name);\n    if (!q) return null;\n\n    // Check concurrency limit\n    if (q.concurrencyLimit > 0) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= q.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of q.tasks.values()) {\n      if (task.status !== 'pending') continue;\n      if (task.availableAt > now) continue;\n      if (this.hasUnresolvedDependencies(task)) continue;\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort by: availability time, then priority (lower = higher priority), then creation time (FIFO)\n    candidates.sort((a, b) => {\n      // Priority first (lower number = higher priority)\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      // Then availability time\n      const aTime = a.availableAt.getTime();\n      const bTime = b.availableAt.getTime();\n      if (aTime !== bTime) return aTime - bTime;\n      // Then FIFO (creation time)\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt += 1;\n    return task;\n  }\n\n  pendingCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const q = this.queues.get(name);\n    if (!q) return 0;\n\n    let count = 0;\n    for (const task of q.tasks.values()) {\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // --- Phase 5: Complete and fail ---\n\n  completeTask(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Unblock dependents\n    this.checkDependentsUnblocked(taskId);\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n    task.failCount += 1;\n\n    if (task.attempt < task.maxRetries) {\n      // Re-add with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // No retries left\n      task.status = 'failed';\n\n      // Move to DLQ\n      const q = this.queues.get(task.queue);\n      if (q) {\n        q.tasks.delete(task.id);\n        q.deadLetterTasks.set(task.id, task);\n      }\n    }\n  }\n\n  // --- Phase 6: Dead Letter Queue ---\n\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const q = this.queues.get(name);\n    if (!q) return [];\n    return Array.from(q.deadLetterTasks.values());\n  }\n\n  reprocessDeadLetterTask(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'failed') {\n      throw new Error(`Task is not in dead letter queue: ${taskId}`);\n    }\n\n    const q = this.queues.get(task.queue);\n    if (!q) throw new Error(`Queue not found: ${task.queue}`);\n\n    q.deadLetterTasks.delete(taskId);\n\n    // Reset for fresh retries\n    task.status = 'pending';\n    task.attempt = 0;\n    task.failCount = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n    task.progress = 0;\n    task.progressMessage = undefined;\n\n    q.tasks.set(task.id, task);\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const q = this.queues.get(name);\n    if (!q) return;\n\n    for (const taskId of q.deadLetterTasks.keys()) {\n      this.allTasks.delete(taskId);\n    }\n    q.deadLetterTasks.clear();\n  }\n\n  // --- Phase 7: Dependencies ---\n\n  private hasUnresolvedDependencies(task: Task): boolean {\n    if (task.dependencies.length === 0) return false;\n\n    for (const depId of task.dependencies) {\n      const dep = this.allTasks.get(depId);\n      if (!dep || dep.status !== 'completed') {\n        return true;\n      }\n    }\n    return false;\n  }\n\n  private checkDependentsUnblocked(_completedTaskId: string): void {\n    // No explicit action needed - getNextTask checks dependencies dynamically\n  }\n\n  getDependencyStatus(taskId: string): { resolved: string[]; unresolved: string[] } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved: string[] = [];\n    const unresolved: string[] = [];\n\n    for (const depId of task.dependencies) {\n      const dep = this.allTasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        resolved.push(depId);\n      } else {\n        unresolved.push(depId);\n      }\n    }\n\n    return { resolved, unresolved };\n  }\n\n  // --- Phase 8: Concurrency ---\n\n  setConcurrency(queueName: string, limit: number): void {\n    const q = this.getOrCreateQueue(queueName);\n    q.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const q = this.queues.get(name);\n    if (!q) return 0;\n    return q.concurrencyLimit;\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const q = this.queues.get(name);\n    if (!q) return 0;\n\n    let count = 0;\n    for (const task of q.tasks.values()) {\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  // --- Phase 9: Progress and Cancellation ---\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in status: ${task.status}`);\n    }\n\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancelTask(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Cannot cancel task in status: ${task.status}`);\n    }\n\n    const prevStatus = task.status;\n    task.status = 'cancelled';\n    task.progress = 0;\n\n    if (prevStatus === 'pending') {\n      // Remove from queue\n      const q = this.queues.get(task.queue);\n      if (q) {\n        q.tasks.delete(task.id);\n      }\n    }\n  }\n\n  // --- Phase 10: Recurring Tasks ---\n\n  addSchedule(\n    id: string,\n    cron: string,\n    queue: string,\n    payload: unknown,\n    taskOptions?: TaskOptions\n  ): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add schedules: queue is shutting down');\n    }\n\n    this.validateCron(cron);\n\n    const schedule: Schedule = {\n      id,\n      cron,\n      queue,\n      payload,\n      taskOptions,\n    };\n\n    this.schedules.set(id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(id: string): void {\n    this.schedules.delete(id);\n  }\n\n  listSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.addTask(schedule.payload, {\n          ...schedule.taskOptions,\n          queue: schedule.queue,\n        });\n        created.push(task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return created;\n  }\n\n  private validateCron(cron: string): void {\n    const parts = cron.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${cron}`);\n    }\n    // Accept our supported subset:\n    // */N * * * * (every N minutes)\n    // 0 * * * * (every hour)\n    // 0 0 * * * (every day at midnight)\n    // Also accept basic numeric values\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cron.trim().split(/\\s+/);\n    const [minutePart, hourPart] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Check minute field\n    let minuteMatch = false;\n    if (minutePart === '*') {\n      minuteMatch = true;\n    } else if (minutePart.startsWith('*/')) {\n      const interval = parseInt(minutePart.slice(2), 10);\n      minuteMatch = currentMinute % interval === 0;\n    } else {\n      minuteMatch = parseInt(minutePart, 10) === currentMinute;\n    }\n\n    // Check hour field\n    let hourMatch = false;\n    if (hourPart === '*') {\n      hourMatch = true;\n    } else if (hourPart.startsWith('*/')) {\n      const interval = parseInt(hourPart.slice(2), 10);\n      hourMatch = currentHour % interval === 0;\n    } else {\n      hourMatch = parseInt(hourPart, 10) === currentHour;\n    }\n\n    if (!minuteMatch || !hourMatch) return false;\n\n    // Check if we've already run in this time slot\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  // --- Phase 11: Middleware ---\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const q = this.getOrCreateQueue(queueName);\n    q.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: HandlerFn): void {\n    const q = this.getOrCreateQueue(queueName);\n    q.handler = handler;\n  }\n\n  processTask(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const task = this.getNextTask(name);\n    if (!task) return null;\n\n    const q = this.queues.get(name);\n    if (!q) return null;\n\n    const middlewares = q.middlewares;\n    const handler = q.handler;\n\n    try {\n      let index = 0;\n      let proceeded = true;\n\n      const executeNext = (): void => {\n        if (index < middlewares.length) {\n          const mw = middlewares[index++];\n          proceeded = false;\n          mw(task, () => {\n            proceeded = true;\n            executeNext();\n          });\n          // If middleware didn't call next, we stop\n          if (!proceeded) return;\n        } else {\n          // All middlewares passed, call handler\n          if (handler) {\n            handler(task);\n          }\n        }\n      };\n\n      executeNext();\n\n      if (!proceeded && task.status === 'processing') {\n        // Middleware skipped processing - don't change status, let caller decide\n        // Actually, task stays in processing state\n      }\n    } catch (err) {\n      const errorMessage = err instanceof Error ? err.message : String(err);\n      this.failTask(task.id, errorMessage);\n    }\n\n    return task;\n  }\n\n  // --- Phase 12: Graceful Shutdown ---\n\n  onShutdown(callback: ShutdownCallback): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout: number = 30000): Promise<ShutdownSummary> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(timeout);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(timeout: number): Promise<ShutdownSummary> {\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Find all currently processing tasks\n    const processingTasks: Task[] = [];\n    for (const q of this.queues.values()) {\n      for (const task of q.tasks.values()) {\n        if (task.status === 'processing') {\n          processingTasks.push(task);\n        }\n      }\n    }\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks with timeout\n    const result = await new Promise<{ completed: number; forceCancelled: number }>((resolve) => {\n      let localCompleted = 0;\n      let localForceCancelled = 0;\n\n      const checkDone = () => {\n        const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n        if (stillProcessing.length === 0) {\n          localCompleted = processingTasks.filter(t =>\n            t.status === 'completed' || t.status === 'failed'\n          ).length;\n          resolve({ completed: localCompleted, forceCancelled: localForceCancelled });\n          return true;\n        }\n        return false;\n      };\n\n      if (checkDone()) return;\n\n      const timer = setTimeout(() => {\n        // Force cancel remaining\n        for (const task of processingTasks) {\n          if (task.status === 'processing') {\n            task.status = 'cancelled';\n            localForceCancelled++;\n          }\n        }\n        localCompleted = processingTasks.filter(t =>\n          t.status === 'completed' || t.status === 'failed'\n        ).length;\n        resolve({ completed: localCompleted, forceCancelled: localForceCancelled });\n      }, timeout);\n\n      // Poll for completion\n      const interval = setInterval(() => {\n        if (checkDone()) {\n          clearTimeout(timer);\n         