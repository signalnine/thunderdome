+export { TaskQueue } from './TaskQueue.js';
+export type {
+  Task,
+  TaskStatus,
+  TaskOptions,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressListener,
+  ShutdownCallback,
+  ShutdownSummary,
+} from './types.js';
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..cb95008
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,48 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: Date;
+  priority: number;
+  queue: string;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  failCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: TaskOptions;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => void) => void;
+export type HandlerFn = (task: Task) => void;
+export type ProgressListener = (progress: number, message?: string) => void;
+export type ShutdownCallback = () => void | Promise<void>;
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
