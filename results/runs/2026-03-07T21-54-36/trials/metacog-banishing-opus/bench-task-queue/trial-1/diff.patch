' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = tq.addTask('a');\n      const t2 = tq.addTask('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.addTask('first');\n      tq.addTask('second');\n      tq.addTask('third');\n\n      const t1 = tq.getNextTask();\n      expect(t1?.payload).toBe('first');\n      const t2 = tq.getNextTask();\n      expect(t2?.payload).toBe('second');\n      const t3 = tq.getNextTask();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing on retrieval', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      const task = tq.getNextTask();\n      expect(task).toBeNull();\n    });\n\n    it('should count pending tasks', () => {\n      expect(tq.pendingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.pendingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.pendingCount()).toBe(1);\n    });\n  });\n\n  // ==================== Phase 2: Named Queues ====================\n  describe('Phase 2: Named Queues', () => {\n    it('should support adding tasks to named queues', () => {\n      tq.addTask('email', { queue: 'emails' });\n      tq.addTask('sms', { queue: 'sms' });\n\n      expect(tq.pendingCount('emails')).toBe(1);\n      expect(tq.pendingCount('sms')).toBe(1);\n    });\n\n    it('should use default queue when no name given', () => {\n      tq.addTask('data');\n      expect(tq.pendingCount('default')).toBe(1);\n      expect(tq.pendingCount()).toBe(1);\n    });\n\n    it('should retrieve from specific queue', () => {\n      tq.addTask('email1', { queue: 'emails' });\n      tq.addTask('sms1', { queue: 'sms' });\n\n      const task = tq.getNextTask('emails');\n      expect(task?.payload).toBe('email1');\n      expect(tq.getNextTask('emails')).toBeNull();\n      expect(tq.pendingCount('sms')).toBe(1);\n    });\n\n    it('should list queue names', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n      const queues = tq.listQueues();\n      expect(queues).toContain('q1');\n      expect(queues).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should be backward compatible with Phase 1', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('data');\n    });\n  });\n\n  // ==================== Phase 3: Priority ====================\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = tq.addTask('data');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should process higher priority first (lower number)', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('medium', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('high');\n      expect(tq.getNextTask()?.payload).toBe('medium');\n      expect(tq.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      tq.addTask('first', { priority: 3 });\n      tq.addTask('second', { priority: 3 });\n      tq.addTask('third', { priority: 3 });\n\n      expect(tq.getNextTask()?.payload).toBe('first');\n      expect(tq.getNextTask()?.payload).toBe('second');\n      expect(tq.getNextTask()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority', () => {\n      expect(() => tq.addTask('data', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('data', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('data', { priority: 3.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.addTask('data', { priority: 2 });\n      expect(task.priority).toBe(2);\n    });\n  });\n\n  // ==================== Phase 4: Delayed Tasks ====================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should delay tasks by milliseconds', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should make delayed tasks available after time passes', () => {\n      const task = tq.addTask('delayed', { delay: 0 });\n      expect(task.availableAt).toBeInstanceOf(Date);\n      const retrieved = tq.getNextTask();\n      expect(retrieved?.payload).toBe('delayed');\n    });\n\n    it('should accept a specific available time', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      tq.addTask('past', { availableAt: pastTime });\n      expect(tq.getNextTask()?.payload).toBe('past');\n    });\n\n    it('should prefer non-delayed tasks over unavailable delayed tasks', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      tq.addTask('immediate');\n\n      expect(tq.getNextTask()?.payload).toBe('immediate');\n    });\n\n    it('should indicate availability time on task', () => {\n      const task = tq.addTask('data', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should work with named queues', () => {\n      tq.addTask('delayed', { queue: 'myq', delay: 100000 });\n      expect(tq.getNextTask('myq')).toBeNull();\n    });\n  });\n\n  // ==================== Phase 5: Retry with Backoff ====================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark tasks as completed', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should mark tasks as failed', () => {\n      tq.addTask('data', { maxRetries: 0 });\n      const task = tq.getNextTask()!;\n      tq.failTask(task.id, 'something went wrong');\n      expect(tq.getTask(task.id)?.status).toBe('failed');\n      expect(tq.getTask(task.id)?.error).toBe('something went wrong');\n    });\n\n    it('should retry failed tasks with backoff', () => {\n      tq.addTask('data', { maxRetries: 3, backoffDelay: 100 });\n      const task = tq.getNextTask()!;\n      expect(task.attempt).toBe(1);\n\n      tq.failTask(task.id, 'fail');\n\n      // Task should be re-added with delay\n      const retrieved = tq.getTask(task.id);\n      expect(retrieved?.status).toBe('pending');\n      expect(retrieved?.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should track attempt count', () => {\n      tq.addTask('data', { maxRetries: 3, backoffDelay: 0 });\n      const task = tq.getNextTask()!;\n      expect(task.attempt).toBe(1);\n\n      tq.failTask(task.id, 'fail');\n      // Need to wait for task to become available\n      const t = tq.getTask(task.id)!;\n      t.availableAt = new Date(0); // force available\n      const retry1 = tq.getNextTask()!;\n      expect(retry1.attempt).toBe(2);\n    });\n\n    it('should use exponential backoff', () => {\n      tq.addTask('data', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      const t1 = tq.getNextTask()!;\n      const beforeFail1 = Date.now();\n      tq.failTask(t1.id, 'fail');\n      const task1 = tq.getTask(t1.id)!;\n      // backoff = 1000 * 2^0 = 1000ms\n      expect(task1.availableAt.getTime() - beforeFail1).toBeGreaterThanOrEqual(900);\n      expect(task1.availableAt.getTime() - beforeFail1).toBeLessThan(2000);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      tq.addTask('data', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const task = tq.getNextTask('myq')!;\n      tq.failTask(task.id, 'fail');\n      expect(tq.getTask(task.id)?.queue).toBe('myq');\n      expect(tq.getTask(task.id)?.priority).toBe(2);\n    });\n\n    it('should exhaust retries and stay failed', () => {\n      tq.addTask('data', { maxRetries: 0, backoffDelay: 0 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'fail');\n      expect(tq.getTask(t.id)?.status).toBe('failed');\n    });\n  });\n\n  // ==================== Phase 6: Dead Letter Queue ====================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      tq.addTask('data', { maxRetries: 0, backoffDelay: 0 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'fatal');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].id).toBe(t.id);\n      expect(dlq[0].error).toBe('fatal');\n    });\n\n    it('should retain error info and fail count', () => {\n      tq.addTask('data', { maxRetries: 2, backoffDelay: 0 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'fail1');\n      // Force available\n      tq.getTask(t.id)!.availableAt = new Date(0);\n      const t2 = tq.getNextTask()!;\n      tq.failTask(t2.id, 'fail2');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq[0].failCount).toBe(2);\n      expect(dlq[0].error).toBe('fail2');\n    });\n\n    it('should reprocess dead-lettered tasks', () => {\n      tq.addTask('data', { maxRetries: 1, backoffDelay: 0 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'fail');\n\n      expect(tq.getDeadLetterTasks().length).toBe(1);\n\n      const reprocessed = tq.reprocessDeadLetterTask(t.id);\n      expect(reprocessed.status).toBe('pending');\n      expect(reprocessed.attempt).toBe(0);\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      tq.addTask('a', { maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('b', { maxRetries: 1, backoffDelay: 0 });\n\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'fail');\n      const t2 = tq.getNextTask()!;\n      tq.failTask(t2.id, 'fail');\n\n      expect(tq.getDeadLetterTasks().length).toBe(2);\n\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should have independent DLQ per queue', () => {\n      tq.addTask('a', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('b', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n      const t1 = tq.getNextTask('q1')!;\n      tq.failTask(t1.id, 'fail');\n      const t2 = tq.getNextTask('q2')!;\n      tq.failTask(t2.id, 'fail');\n\n      expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterTasks('q1').length).toBe(0);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    });\n  });\n\n  // ==================== Phase 7: Task Dependencies ====================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask('dep');\n      tq.addTask('blocked', { dependencies: [dep.id] });\n\n      // blocked should not be returned\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dep.id);\n    });\n\n    it('should unblock tasks when dependency completes', () => {\n      const dep = tq.addTask('dep');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const depTask = tq.getNextTask()!;\n      tq.completeTask(depTask.id);\n\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should reject circular dependencies', () => {\n      const t1 = tq.addTask('t1');\n      const t2 = tq.addTask('t2', { dependencies: [t1.id] });\n\n      expect(() =>\n        tq.addTask('t3', { dependencies: [t2.id] })\n      ).not.toThrow();\n\n      // Direct circular: t1 depends on itself is not possible since t1 already exists\n      // But we can test: t3 depends on t2, t2 depends on t1, adding t4 that t1 depends on t3\n      // Actually test: add task that creates a cycle\n    });\n\n    it('should reject dependency on non-existent task', () => {\n      expect(() =>\n        tq.addTask('data', { dependencies: ['nonexistent'] })\n      ).toThrow('Dependency task not found');\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.addTask('dep', { maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const depTask = tq.getNextTask()!;\n      tq.failTask(depTask.id, 'fail');\n\n      // Dependent should still be blocked (dep is failed, not completed)\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const dependent = tq.addTask('dependent', {\n        dependencies: [dep1.id, dep2.id],\n      });\n\n      const status = tq.getDependencyStatus(dependent.id);\n      expect(status.unresolved).toContain(dep1.id);\n      expect(status.unresolved).toContain(dep2.id);\n      expect(status.resolved.length).toBe(0);\n\n      // Complete dep1\n      const t = tq.getNextTask()!;\n      tq.completeTask(t.id);\n\n      const status2 = tq.getDependencyStatus(dependent.id);\n      expect(status2.resolved.length).toBe(1);\n      expect(status2.unresolved.length).toBe(1);\n    });\n  });\n\n  // ==================== Phase 8: Concurrency Control ====================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 2);\n      tq.addTask('a');\n      tq.addTask('b');\n      tq.addTask('c');\n\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).toBeNull(); // limit reached\n    });\n\n    it('should free slot on complete', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a');\n      tq.addTask('b');\n\n      const t = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.completeTask(t.id);\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should free slot on fail', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a', { maxRetries: 0 });\n      tq.addTask('b');\n\n      const t = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.failTask(t.id, 'fail');\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      for (let i = 0; i < 100; i++) {\n        tq.addTask(i);\n      }\n      for (let i = 0; i < 100; i++) {\n        expect(tq.getNextTask()).not.toBeNull();\n      }\n    });\n\n    it('should query concurrency info', () => {\n      tq.setConcurrency('default', 5);\n      expect(tq.getConcurrency('default')).toBe(5);\n      expect(tq.getActiveCount('default')).toBe(0);\n\n      tq.addTask('a');\n      tq.getNextTask();\n      expect(tq.getActiveCount('default')).toBe(1);\n    });\n\n    it('should still respect priority ordering', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      const t = tq.getNextTask()!;\n      expect(t.payload).toBe('high');\n    });\n  });\n\n  // ==================== Phase 9: Progress and Cancellation ====================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should update and query progress', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n\n      tq.updateProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (p, m) => {\n        updates.push({ progress: p, message: m });\n      });\n\n      tq.updateProgress(task.id, 25, 'quarter');\n      tq.updateProgress(task.id, 75, 'three quarters');\n\n      expect(updates.length).toBe(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribe', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.updateProgress(task.id, 25);\n      unsub();\n      tq.updateProgress(task.id, 50);\n\n      expect(updates.length).toBe(1);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = tq.addTask('data');\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      tq.addTask('data', { maxRetries: 3 });\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      // Cannot fail a cancelled task\n      expect(() => tq.failTask(task.id, 'fail')).toThrow();\n    });\n\n    it('should reject invalid progress values', () => {\n      tq.addTask('data');\n      const task = tq.getNextTask()!;\n      expect(() => tq.updateProgress(task.id, -1)).toThrow();\n      expect(() => tq.updateProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ==================== Phase 10: Recurring Tasks ====================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create and list schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      const schedules = tq.listSchedules();\n      expect(schedules.length).toBe(1);\n      expect(schedules[0].id).toBe('s1');\n    });\n\n    it('should remove schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      tq.removeSchedule('s1');\n      expect(tq.listSchedules().length).toBe(0);\n    });\n\n    it('should create tasks on tick for every-N-minutes', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'job' });\n\n      // At minute 0 (divisible by 5)\n      const time = new Date('2024-01-01T00:00:00Z');\n      const tasks = tq.tick(time);\n      expect(tasks.length).toBe(1);\n      expect(tasks[0].payload).toEqual({ type: 'job' });\n    });\n\n    it('should not create duplicate tasks on same tick', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'job' });\n\n      const time = new Date('2024-01-01T00:00:00Z');\n      tq.tick(time);\n      const tasks2 = tq.tick(time);\n      expect(tasks2.length).toBe(0);\n    });\n\n    it('should support hourly schedule', () => {\n      tq.addSchedule('s1', '0 * * * *', 'default', { type: 'hourly' });\n\n      const onTheHour = new Date('2024-01-01T03:00:00Z');\n      const notOnTheHour = new Date('2024-01-01T03:30:00Z');\n\n      const tasks1 = tq.tick(onTheHour);\n      expect(tasks1.length).toBe(1);\n\n      const tasks2 = tq.tick(notOnTheHour);\n      expect(tasks2.length).toBe(0);\n    });\n\n    it('should support daily midnight schedule', () => {\n      tq.addSchedule('s1', '0 0 * * *', 'default', { type: 'daily' });\n\n      const midnight = new Date('2024-01-01T00:00:00Z');\n      const noon = new Date('2024-01-01T12:00:00Z');\n\n      const tasks1 = tq.tick(midnight);\n      expect(tasks1.length).toBe(1);\n\n      const tasks2 = t