+++ b/src/index.ts
@@ -0,0 +1,198 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+/**
+ * Trace a beam from (row, col) in direction dir until it hits a splitter or exits.
+ * Returns the cells visited along the way and the outcome.
+ */
+function traceBeam(
+  grid: string[][],
+  startRow: number,
+  startCol: number,
+  dir: Direction,
+): { cells: [number, number][]; hitSplitter: [number, number] | null } {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const cells: [number, number][] = [];
+
+  let r = startRow;
+  let c = startCol;
+
+  while (inBounds(r, c, rows, cols)) {
+    cells.push([r, c]);
+    if (grid[r][c] === '^') {
+      // Hit a splitter
+      return { cells, hitSplitter: [r, c] };
+    }
+    [r, c] = nextPos(r, c, dir);
+  }
+
+  return { cells, hitSplitter: null };
+}
+
+/**
+ * Build a DAG of beam segments. Each segment starts from a source or splitter output
+ * and ends at a splitter or grid exit.
+ *
+ * A "segment key" is `${row},${col},${dir}` representing the starting point and direction.
+ * Each segment maps to: cells visited, and either a splitter (which generates two new segments)
+ * or null (beam exits).
+ */
+
+interface Segment {
+  cells: [number, number][];
+  hitSplitter: [number, number] | null;
+}
+
+function segmentKey(row: number, col: number, dir: Direction): string {
+  return `${row},${col},${dir}`;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // Find source
+  let sourceCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sourceCol = c;
+      break;
+    }
+  }
+  if (sourceCol === -1) return 0;
+
+  // Use BFS/DFS over the segment DAG, collecting all visited cells.
+  // Memoize segments to avoid recomputing.
+  const segmentCache = new Map<string, Segment>();
+  const visited = new Set<string>();
+
+  function getSegment(row: number, col: number, dir: Direction): Segment {
+    const key = segmentKey(row, col, dir);
+    let seg = segmentCache.get(key);
+    if (seg === undefined) {
+      seg = traceBeam(grid, row, col, dir);
+      segmentCache.set(key, seg);
+    }
+    return seg;
+  }
+
+  // BFS through the segment DAG
+  // Each item in the queue is a starting beam (row, col, dir)
+  const processedSegments = new Set<string>();
+  const queue: Beam[] = [{ row: 0, col: sourceCol, dir: 'down' }];
+
+  while (queue.length > 0) {
+    const beam = queue.pop()!;
+    const key = segmentKey(beam.row, beam.col, beam.dir);
+    if (processedSegments.has(key)) continue;
+    processedSegments.add(key);
+
+    const seg = getSegment(beam.row, beam.col, beam.dir);
+
+    // Mark all cells as visited
+    for (const [r, c] of seg.cells) {
+      visited.add(`${r},${c}`);
+    }
+
+    // If hit a splitter, queue the two outgoing beams
+    if (seg.hitSplitter) {
+      const [sr, sc] = seg.hitSplitter;
+      const [lr, lc] = nextPos(sr, sc, 'down-left');
+      const [rr, rc] = nextPos(sr, sc, 'down-right');
+
+      if (inBounds(lr, lc, rows, cols)) {
+        queue.push({ row: lr, col: lc, dir: 'down-left' });
+      }
+      if (inBounds(rr, rc, rows, cols)) {
+        queue.push({ row: rr, col: rc, dir: 'down-right' });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // Find source
+  let sourceCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sourceCol = c;
+      break;
+    }
+  }
+  if (sourceCol === -1) return 0n;
+
+  // DP over the segment DAG.
+  // For a beam starting at (row, col, dir):
+  //   - If it exits the grid without hitting a splitter: 1 path
+  //   - If it hits a splitter: paths(left-beam) + paths(right-beam)
+  //   - If both children immediately exit bounds, each still counts as a path
+  //     that exits the grid.
+
+  const memo = new Map<string, bigint>();
+
+  function countPaths(row: number, col: number, dir: Direction): bigint {
+    const key = segmentKey(row, col, dir);
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    const seg = traceBeam(grid, row, col, dir);
+
+    let result: bigint;
+    if (!seg.hitSplitter) {
+      // Beam exits the grid - one path
+      result = 1n;
+    } else {
+      const [sr, sc] = seg.hitSplitter;
+      const [lr, lc] = nextPos(sr, sc, 'down-left');
+      const [rr, rc] = nextPos(sr, sc, 'down-right');
+
+      let leftPaths: bigint;
+      if (inBounds(lr, lc, rows, cols)) {
+        leftPaths = countPaths(lr, lc, 'down-left');
+      } else {
+        leftPaths = 1n; // exits grid immediately
+      }
+
+      let rightPaths: bigint;
+      if (inBounds(rr, rc, rows, cols)) {
+        rightPaths = countPaths(rr, rc, 'down-right');
+      } else {
+        rightPaths = 1n; // exits grid immediately
+      }
+
+      result = leftPaths + rightPaths;
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  return countPaths(0, sourceCol, 'down');
+}
