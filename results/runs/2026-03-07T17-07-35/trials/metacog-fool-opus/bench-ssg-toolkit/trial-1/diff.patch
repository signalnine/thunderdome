@@ -0,0 +1,58 @@
+import { marked } from 'marked';
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonition containers before markdown parsing
+        // :::type\ncontent\n:::
+        content = content.replace(
+          /^:::(note|warning|tip)\n([\s\S]*?)^:::/gm,
+          (_match, type: string, body: string) => {
+            return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+          }
+        );
+
+        // Extract footnote definitions before markdown parsing
+        const footnoteDefs: Map<string, string> = new Map();
+        content = content.replace(
+          /^\[\^(\d+)\]:\s*(.+)$/gm,
+          (_match, id: string, text: string) => {
+            footnoteDefs.set(id, text);
+            return '';
+          }
+        );
+
+        // Replace footnote references [^1] with sup links
+        content = content.replace(
+          /\[\^(\d+)\]/g,
+          (_match, id: string) => {
+            return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+          }
+        );
+
+        // Parse markdown to HTML using marked
+        const parsed = marked.parse(content, { async: false }) as string;
+        content = parsed;
+
+        // Append footnotes section if any definitions exist
+        if (footnoteDefs.size > 0) {
+          let footnotesHtml = '<section class="footnotes">\n<ol>\n';
+          for (const [id, text] of footnoteDefs) {
+            footnotesHtml += `<li id="fn-${id}">${text}</li>\n`;
+          }
+          footnotesHtml += '</ol>\n</section>';
+          content += footnotesHtml;
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
