 expect(result.content).toContain('Already HTML');\n  });\n\n  it('handles empty content', async () => {\n    const file = makeFile({ content: '' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toBeDefined();\n  });\n});\n","numLines":91,"startLine":1,"totalLines":91}}}
