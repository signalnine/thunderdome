diff --git a/tests/marketplace.test.ts b/tests/marketplace.test.ts
new file mode 100644
index 0000000..e69c904
--- /dev/null
+++ b/tests/marketplace.test.ts
@@ -0,0 +1,133 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from '../src/index.js';
+import type { PluginManifest } from '../src/types.js';
+import type { Marketplace } from '../src/index.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '1 + 1',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should expose all service interfaces', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin without dependencies', async () => {
+      const result = await marketplace.installPlugin(makeManifest());
+      expect(result.resolvedDependencies).toEqual([]);
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe(2); // 1 + 1
+    });
+
+    it('should register plugin in the registry', async () => {
+      await marketplace.installPlugin(makeManifest());
+      const found = marketplace.registry.get('test-plugin');
+      expect(found).not.toBeNull();
+      expect(found!.name).toBe('test-plugin');
+    });
+
+    it('should resolve dependencies during install', async () => {
+      // First register the dependency
+      marketplace.registry.register(
+        makeManifest({ name: 'dep-plugin', version: '1.2.0' })
+      );
+      marketplace.registry.register(
+        makeManifest({ name: 'dep-plugin', version: '1.5.0' })
+      );
+
+      const result = await marketplace.installPlugin(
+        makeManifest({
+          name: 'main-plugin',
+          dependencies: { 'dep-plugin': '^1.0.0' },
+        })
+      );
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-plugin');
+      expect(result.resolvedDependencies[0].version).toBe('1.5.0');
+    });
+
+    it('should reject plugins with missing name', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ name: '' }))
+      ).rejects.toThrow('name');
+    });
+
+    it('should reject plugins with missing version', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ version: '' }))
+      ).rejects.toThrow('version');
+    });
+
+    it('should reject plugins with missing entryPoint', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ entryPoint: '' }))
+      ).rejects.toThrow('entryPoint');
+    });
+
+    it('should reject plugins with circular dependencies', async () => {
+      // Register a plugin that depends on our plugin
+      marketplace.registry.register(
+        makeManifest({
+          name: 'dep-a',
+          dependencies: { 'circular-plugin': '^1.0.0' },
+        })
+      );
+
+      await expect(
+        marketplace.installPlugin(
+          makeManifest({
+            name: 'circular-plugin',
+            dependencies: { 'dep-a': '^1.0.0' },
+          })
+        )
+      ).rejects.toThrow('Circular dependency');
+    });
+
+    it('should throw when dependency is not in registry', async () => {
+      await expect(
+        marketplace.installPlugin(
+          makeManifest({
+            dependencies: { 'missing-dep': '^1.0.0' },
+          })
+        )
+      ).rejects.toThrow('not found in registry');
+    });
+
+    it('should execute plugin entryPoint in sandbox', async () => {
+      const result = await marketplace.installPlugin(
+        makeManifest({ entryPoint: '"hello world"' })
+      );
+      expect(result.sandboxResult.success).toBe(true);
+      expect(result.sandboxResult.output).toBe('hello world');
+    });
+
+    it('should handle plugin code that throws', async () => {
+      const result = await marketplace.installPlugin(
+        makeManifest({ entryPoint: 'throw new Error("init failed")' })
+      );
+      expect(result.sandboxResult.success).toBe(false);
+      expect(result.sandboxResult.error).toBe('init failed');
+    });
+  });
+});
