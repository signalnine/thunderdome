sCircularDependency('a', registry)).toBe(true);\n    });\n  });\n\n  describe('topologicalSort', () => {\n    it('should return correct topological order', () => {\n      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));\n      registry.register(makeManifest('b', { c: '^1.0.0' }));\n      registry.register(makeManifest('c'));\n      const sorted = depsService.topologicalSort('a', registry);\n      expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('b'));\n      expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));\n    });\n\n    it('should throw on circular dependencies', () => {\n      registry.register(makeManifest('a', { b: '^1.0.0' }));\n      registry.register(makeManifest('b', { a: '^1.0.0' }));\n      expect(() => depsService.topologicalSort('a', registry)).toThrow();\n    });\n\n    it('should handle single node', () => {\n      registry.register(makeManifest('a'));\n      expect(depsService.topologicalSort('a', registry)).toEqual(['a']);\n    });\n  });\n\n  describe('flattenDependencies', () => {\n    it('should flatten all transitive dependencies', () => {\n      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));\n      registry.register(makeManifest('b', { d: '^1.0.0' }));\n      registry.register(makeManifest('c'));\n      registry.register(makeManifest('d'));\n      const deps = depsService.flattenDependencies('a', registry);\n      expect(deps).toContain('b');\n      expect(deps).toContain('c');\n      expect(deps).toContain('d');\n      expect(deps).not.toContain('a');\n    });\n\n    it('should return empty array for plugin with no dependencies', () => {\n      registry.register(makeManifest('a'));\n      expect(depsService.flattenDependencies('a', registry)).toEqual([]);\n    });\n\n    it('should not duplicate dependencies', () => {\n      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));\n      registry.register(makeManifest('b', { c: '^1.0.0' }));\n      registry.register(makeManifest('c'));\n      const deps = depsService.flattenDependencies('a', registry);\n      const uniqueDeps = new Set(deps);\n      expect(deps.length).toBe(uniqueDeps.size);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
