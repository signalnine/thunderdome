 install', async () => {\n      // First register the dependency\n      marketplace.registry.register(\n        makeManifest({ name: 'dep-plugin', version: '1.2.0' })\n      );\n      marketplace.registry.register(\n        makeManifest({ name: 'dep-plugin', version: '1.5.0' })\n      );\n\n      const result = await marketplace.installPlugin(\n        makeManifest({\n          name: 'main-plugin',\n          dependencies: { 'dep-plugin': '^1.0.0' },\n        })\n      );\n      expect(result.resolvedDependencies).toHaveLength(1);\n      expect(result.resolvedDependencies[0].name).toBe('dep-plugin');\n      expect(result.resolvedDependencies[0].version).toBe('1.5.0');\n    });\n\n    it('should reject plugins with missing name', async () => {\n      await expect(\n        marketplace.installPlugin(makeManifest({ name: '' }))\n      ).rejects.toThrow('name');\n    });\n\n    it('should reject plugins with missing version', async () => {\n      await expect(\n        marketplace.installPlugin(makeManifest({ version: '' }))\n      ).rejects.toThrow('version');\n    });\n\n    it('should reject plugins with missing entryPoint', async () => {\n      await expect(\n        marketplace.installPlugin(makeManifest({ entryPoint: '' }))\n      ).rejects.toThrow('entryPoint');\n    });\n\n    it('should reject plugins with circular dependencies', async () => {\n      // Register a plugin that depends on our plugin\n      marketplace.registry.register(\n        makeManifest({\n          name: 'dep-a',\n          dependencies: { 'circular-plugin': '^1.0.0' },\n        })\n      );\n\n      await expect(\n        marketplace.installPlugin(\n          makeManifest({\n            name: 'circular-plugin',\n            dependencies: { 'dep-a': '^1.0.0' },\n          })\n        )\n      ).rejects.toThrow('Circular dependency');\n    });\n\n    it('should throw when dependency is not in registry', async () => {\n      await expect(\n        marketplace.installPlugin(\n          makeManifest({\n            dependencies: { 'missing-dep': '^1.0.0' },\n          })\n        )\n      ).rejects.toThrow('not found in registry');\n    });\n\n    it('should execute plugin entryPoint in sandbox', async () => {\n      const result = await marketplace.installPlugin(\n        makeManifest({ entryPoint: '\"hello world\"' })\n      );\n      expect(result.sandboxResult.success).toBe(true);\n      expect(result.sandboxResult.output).toBe('hello world');\n    });\n\n    it('should handle plugin code that throws', async () => {\n      const result = await marketplace.installPlugin(\n        makeManifest({ entryPoint: 'throw new Error(\"init failed\")' })\n      );\n      expect(result.sandboxResult.success).toBe(false);\n      expect(result.sandboxResult.error).toBe('init failed');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1958,"cache_read_input_tokens":35742,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1958},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f22d0194-8062-4fef-b8cb-84ddff0d9e90","uuid":"7cdedae0-deb0-413c-9be3-5399e67236f2"}
