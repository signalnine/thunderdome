+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values,
+ * compute the final value of every wire.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+  let progress = true;
+
+  while (remaining.length > 0 && progress) {
+    progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder.
+ *
+ * Strategy: Check each gate's output against structural rules for a
+ * ripple-carry adder. Any violation indicates a swapped wire.
+ *
+ * Rules for a correct ripple-carry adder:
+ * 1. XOR gates with x/y inputs at bit 0: output is z00
+ * 2. XOR gates with x/y inputs at bit > 0: output is a partial sum (NOT z-wire)
+ * 3. XOR gates with non-x/y inputs: output IS a z-wire (final sum)
+ * 4. AND gates: output feeds into an OR gate (never directly to z, except bit0 carry)
+ * 5. OR gates: output is carry — feeds into XOR and AND, never a z-wire
+ *    (except final carry = z[N])
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Build lookup structures
+  const outputToGate = new Map<string, Gate>();
+  for (const g of gates) {
+    outputToGate.set(g.out, g);
+  }
+
+  // Build map: wire -> set of gates that consume it as input
+  const consumers = new Map<string, Gate[]>();
+  for (const g of gates) {
+    if (!consumers.has(g.in1)) consumers.set(g.in1, []);
+    consumers.get(g.in1)!.push(g);
+    if (!consumers.has(g.in2)) consumers.set(g.in2, []);
+    consumers.get(g.in2)!.push(g);
+  }
+
+  // Determine N: the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2, g.out]) {
+      if (w.startsWith('x') || w.startsWith('y')) {
+        const num = parseInt(w.substring(1), 10);
+        if (num > maxBit) maxBit = num;
+      }
+    }
+  }
+  const n = maxBit + 1;
+  const finalZ = `z${String(n).padStart(2, '0')}`;
+
+  const swapped = new Set<string>();
+
+  function isXYInput(wire: string): boolean {
+    return wire.startsWith('x') || wire.startsWith('y');
+  }
+
+  function isZWire(wire: string): boolean {
+    return wire.startsWith('z');
+  }
+
+  function hasXYInputs(gate: Gate): boolean {
+    return (isXYInput(gate.in1) || isXYInput(gate.in2));
+  }
+
+  function isBit0Gate(gate: Gate): boolean {
+    return (
+      (gate.in1 === 'x00' || gate.in1 === 'y00') &&
+      (gate.in2 === 'x00' || gate.in2 === 'y00')
+    );
+  }
+
+  // Check what ops consume a given wire
+  function consumedByOps(wire: string): Set<string> {
+    const ops = new Set<string>();
+    const cs = consumers.get(wire) || [];
+    for (const c of cs) {
+      ops.add(c.op);
+    }
+    return ops;
+  }
+
+  for (const gate of gates) {
+    const out = gate.out;
+
+    if (isBit0Gate(gate)) {
+      // Bit 0 half adder:
+      // XOR x00, y00 -> z00
+      if (gate.op === 'XOR' && out !== 'z00') {
+        swapped.add(out);
+      }
+      // AND x00, y00 -> carry (should feed into XOR and AND, not be z)
+      if (gate.op === 'AND' && isZWire(out)) {
+        swapped.add(out);
+      }
+      continue;
+    }
+
+    if (gate.op === 'XOR') {
+      if (hasXYInputs(gate)) {
+        // This is a partial sum XOR (xNN XOR yNN -> tNN)
+        // Its output should NOT be a z-wire
+        if (isZWire(out)) {
+          swapped.add(out);
+        }
+        // Its output should be consumed by XOR and AND (not OR)
+        // If it's consumed only by OR, that's wrong
+        const ops = consumedByOps(out);
+        if (ops.size > 0 && !ops.has('XOR') && !ops.has('AND')) {
+          swapped.add(out);
+        }
+      } else {
+        // This is a final sum XOR (tNN XOR carry -> zNN)
+        // Its output SHOULD be a z-wire, but NOT finalZ
+        // (finalZ must come from an OR gate — it's the final carry)
+        if (!isZWire(out) || out === finalZ) {
+          swapped.add(out);
+        }
+      }
+    } else if (gate.op === 'AND') {
+      // AND output should feed into an OR gate
+      // It should NOT be a z-wire
+      if (isZWire(out)) {
+        swapped.add(out);
+      }
+      // AND output should be consumed by an OR gate
+      const ops = consumedByOps(out);
+      if (ops.size > 0 && !ops.has('OR')) {
+        swapped.add(out);
+      }
+    } else if (gate.op === 'OR') {
+      // OR output is a carry. It should NOT be a z-wire
+      // EXCEPT for the final carry which is z[N]
+      if (isZWire(out) && out !== finalZ) {
+        swapped.add(out);
+      }
+      // If it IS the final z, that's fine
+      // If it's not a z-wire, it should be consumed by XOR and AND
+      if (!isZWire(out)) {
+        const ops = consumedByOps(out);
+        if (ops.size > 0 && !ops.has('XOR') && !ops.has('AND')) {
+          swapped.add(out);
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
