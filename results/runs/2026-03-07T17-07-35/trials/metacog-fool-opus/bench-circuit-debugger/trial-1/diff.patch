p: 'AND', in1: x0, in2: y0, out: c0 });\n\n  let carry = c0;\n\n  // Bits 1..n-1: full adders\n  for (let i = 1; i < n; i++) {\n    const pad = String(i).padStart(2, '0');\n    const xi = `x${pad}`, yi = `y${pad}`, zi = `z${pad}`;\n    const t = randomWireName(rng, usedNames);\n    const a = randomWireName(rng, usedNames);\n    const b = randomWireName(rng, usedNames);\n    const c = randomWireName(rng, usedNames);\n\n    gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });\n    gates.push({ op: 'XOR', in1: t, in2: carry, out: zi });\n    gates.push({ op: 'AND', in1: xi, in2: yi, out: a });\n    gates.push({ op: 'AND', in1: t, in2: carry, out: b });\n    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n\n    carry = c;\n  }\n\n  // Final carry → z[n]\n  const finalZ = `z${String(n).padStart(2, '0')}`;\n  for (const gate of gates) {\n    if (gate.out === carry) gate.out = finalZ;\n    if (gate.in1 === carry) gate.in1 = finalZ;\n    if (gate.in2 === carry) gate.in2 = finalZ;\n  }\n\n  return gates;\n}\n\nfunction applySwaps(gates: Gate[], pairs: [string, string][]): Gate[] {\n  const swapMap = new Map<string, string>();\n  for (const [a, b] of pairs) {\n    swapMap.set(a, b);\n    swapMap.set(b, a);\n  }\n  return gates.map((g) => ({\n    ...g,\n    out: swapMap.get(g.out) ?? g.out,\n  }));\n}\n\nfunction shuffleGates(gates: Gate[], seed: number): Gate[] {\n  const rng = seededRandom(seed);\n  const arr = [...gates];\n  for (let i = arr.length - 1; i > 0; i--) {\n    const j = Math.floor(rng() * (i + 1));\n    [arr[i], arr[j]] = [arr[j], arr[i]];\n  }\n  return arr;\n}\n\nfunction shuffleArray(arr: string[], rng: () => number): void {\n  for (let i = arr.length - 1; i > 0; i--) {\n    const j = Math.floor(rng() * (i + 1));\n    [arr[i], arr[j]] = [arr[j], arr[i]];\n  }\n}\n\n/**\n * Categorize gate output wires by their structural role in the adder.\n * Only swaps between certain categories are detectable by structural rules.\n *\n * Detectable cross-category pairs:\n *   z ↔ {t, a, b, c}\n *   t ↔ {a, b}\n *   finalZ ↔ z\n *\n * NOT detectable: t↔c, a↔b, a↔c, b↔c, same↔same\n */\nfunction categorizeWires(gates: Gate[], n: number) {\n  const finalZ = `z${String(n).padStart(2, '0')}`;\n  const z: string[] = [];  // output XOR → z (not z00, not finalZ)\n  const t: string[] = [];  // input XOR → partial sum (not bit0)\n  const a: string[] = [];  // input AND → generate (not bit0)\n  const b: string[] = [];  // non-input AND → propagate\n  const c: string[] = [];  // OR → carry\n\n  for (const gate of gates) {\n    const isBit0 =\n      (gate.in1 === 'x00' || gate.in1 === 'y00') &&\n      (gate.in2 === 'x00' || gate.in2 === 'y00');\n    if (isBit0) continue;\n    if (gate.out === finalZ) continue;\n\n    const hasXY =\n      gate.in1.startsWith('x') || gate.in1.startsWith('y') ||\n      gate.in2.startsWith('x') || gate.in2.startsWith('y');\n\n    if (gate.out.startsWith('z')) z.push(gate.out);\n    else if (gate.op === 'XOR' && hasXY) t.push(gate.out);\n    else if (gate.op === 'AND' && hasXY) a.push(gate.out);\n    else if (gate.op === 'AND') b.push(gate.out);\n    else if (gate.op === 'OR') c.push(gate.out);\n  }\n\n  return { z, t, a, b, c, finalZ };\n}\n\n/**\n * Pick 4 swap pairs guaranteed to be detectable by structural analysis.\n * Cycles through: z↔a, z↔b, t↔a, t↔b (all proven detectable).\n */\nfunction pickDetectableSwapPairs(\n  gates: Gate[],\n  n: number,\n  seed: number,\n): [string, string][] {\n  const rng = seededRandom(seed);\n  const cats = categorizeWires(gates, n);\n\n  // Shuffle each category\n  shuffleArray(cats.z, rng);\n  shuffleArray(cats.t, rng);\n  shuffleArray(cats.a, rng);\n  shuffleArray(cats.b, rng);\n  shuffleArray(cats.c, rng);\n\n  // Cross-category templates (all verified detectable)\n  const pairs: [string, string][] = [\n    [cats.z[0], cats.a[0]],   // z ↔ generate\n    [cats.z[1], cats.b[0]],   // z ↔ propagate\n    [cats.t[0], cats.a[1]],   // partial-sum ↔ generate\n    [cats.t[1], cats.