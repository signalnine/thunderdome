  });\n\n  it(\"should persist data across instances\", () => {\n    const tracker1 = new TimeTracker(filePath);\n    tracker1.start(\"work\");\n    tracker1.stop();\n\n    const tracker2 = new TimeTracker(filePath);\n    const entries = tracker2.getEntries();\n    expect(entries).toHaveLength(1);\n    expect(entries[0].task).toBe(\"work\");\n  });\n\n  it(\"should create parent directories automatically\", () => {\n    const deepPath = join(tmpDir, \"a\", \"b\", \"c\", \"data.json\");\n    const tracker = new TimeTracker(deepPath);\n    tracker.start(\"test\");\n    tracker.stop();\n\n    const tracker2 = new TimeTracker(deepPath);\n    expect(tracker2.getEntries()).toHaveLength(1);\n  });\n\n  it(\"should filter entries by date range\", () => {\n    const tracker = new TimeTracker(filePath);\n\n    // Create entries at different times\n    tracker.start(\"old-task\");\n    tracker.stop();\n\n    const afterFirst = new Date();\n\n    tracker.start(\"new-task\");\n    tracker.stop();\n\n    const entries = tracker.getEntries(afterFirst);\n    expect(entries).toHaveLength(1);\n    expect(entries[0].task).toBe(\"new-task\");\n  });\n\n  it(\"should summarize time per task\", () => {\n    const tracker = new TimeTracker(filePath);\n\n    tracker.start(\"coding\");\n    tracker.stop();\n    tracker.start(\"coding\");\n    tracker.stop();\n\n    const summary = tracker.getSummary();\n    expect(summary[\"coding\"]).toBeGreaterThan(0);\n  });\n\n  it(\"should include running tasks in summary using current time\", () => {\n    const tracker = new TimeTracker(filePath);\n    tracker.start(\"active\");\n    const summary = tracker.getSummary();\n    expect(summary[\"active\"]).toBeGreaterThanOrEqual(0);\n  });\n\n  it(\"should support unicode and emoji task names\", () => {\n    const tracker = new TimeTracker(filePath);\n\n    tracker.start(\"🚀 déploiement\");\n    tracker.stop();\n    tracker.start(\"日本語タスク\");\n    tracker.stop();\n    tracker.start(\"café ☕ break\");\n    tracker.stop();\n\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(3);\n    expect(entries[0].task).toBe(\"🚀 déploiement\");\n    expect(entries[1].task).toBe(\"日本語タスク\");\n    expect(entries[2].task).toBe(\"café ☕ break\");\n\n    const summary = tracker.getSummary();\n    expect(summary[\"🚀 déploiement\"]).toBeGreaterThanOrEqual(0);\n    expect(summary[\"日本語タスク\"]).toBeGreaterThanOrEqual(0);\n    expect(summary[\"café ☕ break\"]).toBeGreaterThanOrEqual(0);\n  });\n\n  it(\"should return a copy of the running entry\", () => {\n    const tracker = new TimeTracker(filePath);\n    tracker.start(\"test\");\n    const running = tracker.getRunning();\n    expect(running).toBeDefined();\n    expect(running!.task).toBe(\"test\");\n  });\n\n  it(\"should persist unicode task names across instances\", () => {\n    const tracker1 = new TimeTracker(filePath);\n    tracker1.start(\"🎉 party\");\n    tracker1.stop();\n\n    const tracker2 = new TimeTracker(filePath);\n    const entries = tracker2.getEntries();\n    expect(entries[0].task).toBe(\"🎉 party\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":232,"cache_read_input_tokens":23353,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":232},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"61b0244b-ae90-48be-8423-099c679896d3","uuid":"2fb8a25a-c9ab-4bf5-a066-546d24b6d496"}
