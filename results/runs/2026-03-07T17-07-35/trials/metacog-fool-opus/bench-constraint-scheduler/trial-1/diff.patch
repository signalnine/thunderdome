+import { describe, it, expect } from "vitest";
+import { schedule, Event, Room, ScheduleOptions } from "./index.js";
+
+describe("schedule", () => {
+  const defaultOptions: ScheduleOptions = {
+    startTime: 540, // 9:00 AM
+    endTime: 1020, // 5:00 PM
+  };
+
+  describe("basic scheduling", () => {
+    it("should schedule a single event into a single room", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Meeting", duration: 60 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room A", capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0]).toEqual({
+        eventId: "e1",
+        roomId: "r1",
+        startTime: 540,
+        endTime: 600,
+      });
+    });
+
+    it("should return empty results for empty events", () => {
+      const result = schedule([], [{ id: "r1", name: "Room", capacity: 10 }], defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it("should schedule multiple events into different rooms", () => {
+      const events: Event[] = [
+        { id: "e1", name: "A", duration: 60, attendees: 5 },
+        { id: "e2", name: "B", duration: 60, attendees: 5 },
+      ];
+      const rooms: Room[] = [
+        { id: "r1", name: "Room A", capacity: 10 },
+        { id: "r2", name: "Room B", capacity: 10 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it("should schedule events sequentially in the same room with gaps", () => {
+      const events: Event[] = [
+        { id: "e1", name: "A", duration: 60 },
+        { id: "e2", name: "B", duration: 60 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room A", capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+
+      // Both should be in room r1
+      const a1 = result.assignments.find((a) => a.eventId === "e1")!;
+      const a2 = result.assignments.find((a) => a.eventId === "e2")!;
+
+      // Gap of at least 15 minutes between events in same room
+      expect(Math.abs(a2.startTime - a1.endTime) >= 15 || Math.abs(a1.startTime - a2.endTime) >= 15).toBe(true);
+    });
+  });
+
+  describe("capacity constraints", () => {
+    it("should not schedule an event in a room with insufficient capacity", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Big Meeting", duration: 60, attendees: 20 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Small Room", capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(["e1"]);
+    });
+
+    it("should place events in rooms with sufficient capacity", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Big Meeting", duration: 60, attendees: 20 },
+        { id: "e2", name: "Small Meeting", duration: 60, attendees: 5 },
+      ];
+      const rooms: Room[] = [
+        { id: "r1", name: "Small Room", capacity: 10 },
+        { id: "r2", name: "Large Room", capacity: 30 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
+
+      const bigAssignment = result.assignments.find((a) => a.eventId === "e1")!;
+      expect(bigAssignment.roomId).toBe("r2");
+    });
+  });
+
+  describe("time window constraints", () => {
+    it("should not schedule an event that exceeds the time window", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Long Meeting", duration: 600 }, // 10 hours
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room A", capacity: 10 }];
+      const options: ScheduleOptions = {
+        startTime: 540,
+        endTime: 1020, // 8 hour window = 480 minutes
+      };
+
+      const result = schedule(events, rooms, options);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(["e1"]);
+    });
+
+    it("should respect custom gap setting", () => {
+      const events: Event[] = [
+        { id: "e1", name: "A", duration: 60 },
+        { id: "e2", name: "B", duration: 60 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room A", capacity: 10 }];
+      const options: ScheduleOptions = {
+        startTime: 540,
+        endTime: 1020,
+        gap: 30,
+      };
+
+      const result = schedule(events, rooms, options);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find((a) => a.eventId === "e1")!;
+      const a2 = result.assignments.find((a) => a.eventId === "e2")!;
+
+      const laterStart = Math.max(a1.startTime, a2.startTime);
+      const earlierEnd = Math.min(a1.endTime, a2.endTime);
+      // Difference between later start and earlier end should be >= 30
+      expect(laterStart - earlierEnd).toBeGreaterThanOrEqual(30);
+    });
+  });
+
+  describe("prerequisites", () => {
+    it("should schedule prerequisite events before dependent events", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Intro", duration: 60 },
+        { id: "e2", name: "Advanced", duration: 60, prerequisites: ["e1"] },
+      ];
+      const rooms: Room[] = [
+        { id: "r1", name: "Room A", capacity: 10 },
+        { id: "r2", name: "Room B", capacity: 10 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find((a) => a.eventId === "e1")!;
+      const a2 = result.assignments.find((a) => a.eventId === "e2")!;
+
+      expect(a1.endTime).toBeLessThanOrEqual(a2.startTime);
+    });
+
+    it("should respect prerequisite gap", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Intro", duration: 60 },
+        { id: "e2", name: "Advanced", duration: 60, prerequisites: ["e1"] },
+      ];
+      const rooms: Room[] = [
+        { id: "r1", name: "Room A", capacity: 10 },
+        { id: "r2", name: "Room B", capacity: 10 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      const a1 = result.assignments.find((a) => a.eventId === "e1")!;
+      const a2 = result.assignments.find((a) => a.eventId === "e2")!;
+
+      // Gap should be at least 15 (default) between prerequisite end and dependent start
+      expect(a2.startTime - a1.endTime).toBeGreaterThanOrEqual(15);
+    });
+
+    it("should handle chains of prerequisites", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Step 1", duration: 30 },
+        { id: "e2", name: "Step 2", duration: 30, prerequisites: ["e1"] },
+        { id: "e3", name: "Step 3", duration: 30, prerequisites: ["e2"] },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room A", capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+
+      const a1 = result.assignments.find((a) => a.eventId === "e1")!;
+      const a2 = result.assignments.find((a) => a.eventId === "e2")!;
+      const a3 = result.assignments.find((a) => a.eventId === "e3")!;
+
+      expect(a1.endTime + 15).toBeLessThanOrEqual(a2.startTime);
+      expect(a2.endTime + 15).toBeLessThanOrEqual(a3.startTime);
+    });
+
+    it("should throw on self-referencing prerequisite", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Self Ref", duration: 60, prerequisites: ["e1"] },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room", capacity: 10 }];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+    });
+
+    it("should throw on prerequisite cycle", () => {
+      const events: Event[] = [
+        { id: "e1", name: "A", duration: 60, prerequisites: ["e2"] },
+        { id: "e2", name: "B", duration: 60, prerequisites: ["e1"] },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room", capacity: 10 }];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+    });
+
+    it("should throw on longer prerequisite cycle", () => {
+      const events: Event[] = [
+        { id: "e1", name: "A", duration: 30, prerequisites: ["e3"] },
+        { id: "e2", name: "B", duration: 30, prerequisites: ["e1"] },
+        { id: "e3", name: "C", duration: 30, prerequisites: ["e2"] },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room", capacity: 10 }];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrow();
+    });
+  });
+
+  describe("preferred room", () => {
+    it("should honor preferred room when possible", () => {
+      const events: Event[] = [
+        { id: "e1", name: "A", duration: 60, preferredRoom: "r2" },
+      ];
+      const rooms: Room[] = [
+        { id: "r1", name: "Room A", capacity: 10 },
+        { id: "r2", name: "Room B", capacity: 10 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments[0].roomId).toBe("r2");
+    });
+
+    it("should ignore preferred room if it violates capacity", () => {
+      const events: Event[] = [
+        {
+          id: "e1",
+          name: "A",
+          duration: 60,
+          attendees: 20,
+          preferredRoom: "r1",
+        },
+      ];
+      const rooms: Room[] = [
+        { id: "r1", name: "Small Room", capacity: 10 },
+        { id: "r2", name: "Large Room", capacity: 30 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments[0].roomId).toBe("r2");
+    });
+  });
+
+  describe("unscheduled events", () => {
+    it("should put events in unscheduled when no room fits", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Huge Meeting", duration: 60, attendees: 100 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room", capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(["e1"]);
+    });
+
+    it("should put events in unscheduled when time window is full", () => {
+      const events: Event[] = [
+        { id: "e1", name: "A", duration: 60 },
+        { id: "e2", name: "B", duration: 60 },
+        { id: "e3", name: "C", duration: 60 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room", capacity: 10 }];
+      const options: ScheduleOptions = {
+        startTime: 540,
+        endTime: 700, // Only 160 minutes, two 60-min events + 15-min gap = 135, third won't fit
+      };
+
+      const result = schedule(events, rooms, options);
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(1);
+    });
+  });
+
+  describe("optimization", () => {
+    it("should maximize the number of events scheduled", () => {
+      // Setup: One room, tight window. A single long event or two short events.
+      // The scheduler should prefer scheduling 2 short events over 1 long one.
+      const events: Event[] = [
+        { id: "long", name: "Long Event", duration: 200 },
+        { id: "short1", name: "Short 1", duration: 90 },
+        { id: "short2", name: "Short 2", duration: 90 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room", capacity: 10 }];
+      const options: ScheduleOptions = {
+        startTime: 540,
+        endTime: 745, // 205 minutes: fits long (200) OR short1+gap+short2 (90+15+90=195)
+      };
+
+      const result = schedule(events, rooms, options);
+      // Should schedule 2 events (the two short ones), not just 1 (the long one)
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(1);
+    });
+  });
+
+  describe("default values", () => {
+    it("should default attendees to 1", () => {
+      const events: Event[] = [
+        { id: "e1", name: "Solo", duration: 30 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room", capacity: 1 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+    });
+
+    it("should default gap to 15 minutes", () => {
+      const events: Event[] = [
+        { id: "e1", name: "A", duration: 30 },
+        { id: "e2", name: "B", duration: 30 },
+      ];
+      const rooms: Room[] = [{ id: "r1", name: "Room", capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      const a1 = result.assignments.find((a) => a.eventId === "e1")!;
+      const a2 = result.assignments.find((a) => a.eventId === "e2")!;
+
+      const laterStart = Math.max(a1.startTime, a2.startTime);
+      const earlierEnd = Math.min(a1.endTime, a2.endTime);
+      expect(laterStart - earlierEnd).toBeGreaterThanOrEqual(15);
+    });
+  });
+});
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..f288d03
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,501 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph and return a topological order.
+ * Throws on cycles (including self-references).
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map((e) => e.id));
+  const adjList = new Map<string, string[]>();
+  const inDegree = new Map<string, number>();
+
+  for (const e of events) {
+    adjList.set(e.id, []);
+    inDegree.set(e.id, 0);
+  }
+
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        // Self-reference is a cycle
+        if (prereq === e.id) {
+          throw new Error(
+            `Cycle detected: event "${e.id}" has itself as a prerequisite`
+          );
+        }
+        // Only consider prerequisites that are in the event list
+        if (eventIds.has(prereq)) {
+          adjList.get(prereq)!.push(e.id);
+          inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+        }
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    sorted.push(node);
+    for (const neighbor of adjList.get(node) ?? []) {
+      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) queue.push(neighbor);
+    }
+  }
+
+  if (sorted.length !== events.length) {
+    throw new Error("Cycle detected in prerequisite graph");
+  }
+
+  return sorted;
+}
+
+/**
+ * Find the earliest start time for an event in a given room,
+ * respecting room bookings, prerequisite finish times, and the time window.
+ */
+function findEarliestStart(
+  eventDuration: number,
+  roomId: string,
+  roomBookings: Assignment[],
+  prerequisiteEndTime: number,
+  gap: number,
+  windowStart: number,
+  windowEnd: number
+): number | null {
+  const earliest = Math.max(windowStart, prerequisiteEndTime);
+
+  // Get bookings for this room, sorted by start time
+  const bookings = roomBookings
+    .filter((a) => a.roomId === roomId)
+    .sort((a, b) => a.startTime - b.startTime);
+
+  let candidateStart = earliest;
+
+  for (const booking of bookings) {
+    // Check if the candidate fits before this booking with required gap
+    if (candidateStart + eventDuration + gap <= booking.startTime) {
+      // It fits in this slot - but also check it ends within window
+      if (candidateStart + eventDuration <= windowEnd) {
+        return candidateStart;
+      }
+    }
+
+    // Move candidate past this booking + gap
+    const afterBooking = booking.endTime + gap;
+    if (afterBooking > candidateStart) {
+      candidateStart = afterBooking;
+    }
+  }
+
+  // Try after all bookings (no gap needed after the last event in the room
+  // towards the end of window, but we still need the event to fit)
+  if (candidateStart + eventDuration <= windowEnd) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+/**
+ * Schedule events into rooms, maximizing the number of events scheduled.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? 15;
+
+  // Validate and get topological order (throws on cycles)
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Build prerequisite graph: for each event, which events must finish first
+  const prereqsOf = new Map<string, string[]>();
+  const eventIds = new Set(events.map((e) => e.id));
+  for (const e of events) {
+    const validPrereqs = (e.prerequisites ?? []).filter((p) => eventIds.has(p));
+    prereqsOf.set(e.id, validPrereqs);
+  }
+
+  // Compute "topological depth" for ordering: events deeper in the prereq chain
+  // should be considered more constrained
+  const topoDepth = new Map<string, number>();
+  for (const id of topoOrder) {
+    const prereqs = prereqsOf.get(id) ?? [];
+    const maxPrereqDepth = prereqs.reduce(
+      (max, p) => Math.max(max, (topoDepth.get(p) ?? 0) + 1),
+      0
+    );
+    topoDepth.set(id, maxPrereqDepth);
+  }
+
+  // Sort events by "most constrained first":
+  // 1. Topological depth (higher depth = more prerequisite chains, place prereqs first)
+  //    Actually we want to place events with fewer valid rooms first (more constrained).
+  // 2. Number of rooms that can hold them (fewer = more constrained)
+  // 3. Longer duration (harder to fit)
+  // 4. Respect topological order
+  const topoPosition = new Map<string, number>();
+  topoOrder.forEach((id, idx) => topoPosition.set(id, idx));
+
+  const validRoomsCount = new Map<string, number>();
+  for (const e of events) {
+    const attendees = e.attendees ?? 1;
+    const count = rooms.filter((r) => r.capacity >= attendees).length;
+    validRoomsCount.set(e.id, count);
+  }
+
+  // Build a scheduling order that respects topological constraints
+  // but prioritizes most-constrained events
+  const schedulingOrder = [...topoOrder];
+
+  // We'll use a greedy approach with retry: try scheduling in topological order,
+  // but within each "level" (same topo depth), sort by most constrained first.
+  schedulingOrder.sort((a, b) => {
+    const depthA = topoDepth.get(a) ?? 0;
+    const depthB = topoDepth.get(b) ?? 0;
+    if (depthA !== depthB) return depthA - depthB;
+
+    // Same depth: more constrained first (fewer valid rooms)
+    const roomsA = validRoomsCount.get(a) ?? 0;
+    const roomsB = validRoomsCount.get(b) ?? 0;
+    if (roomsA !== roomsB) return roomsA - roomsB;
+
+    // Longer events first (harder to fit)
+    const evA = eventMap.get(a)!;
+    const evB = eventMap.get(b)!;
+    if (evB.duration !== evA.duration) return evB.duration - evA.duration;
+
+    // Tiebreak by topological position
+    return (topoPosition.get(a) ?? 0) - (topoPosition.get(b) ?? 0);
+  });
+
+  // Try multiple greedy orderings and pick the best
+  // Strategy 1: longer events first (harder to fit, give them priority)
+  const bestResult = greedySchedule(
+    schedulingOrder,
+    eventMap,
+    rooms,
+    prereqsOf,
+    gap,
+    options.startTime,
+    options.endTime
+  );
+
+  // Strategy 2: shorter events first (maximizes count by fitting more events)
+  const shortFirstOrder = [...schedulingOrder].sort((a, b) => {
+    const depthA = topoDepth.get(a) ?? 0;
+    const depthB = topoDepth.get(b) ?? 0;
+    if (depthA !== depthB) return depthA - depthB;
+
+    const evA = eventMap.get(a)!;
+    const evB = eventMap.get(b)!;
+    return evA.duration - evB.duration;
+  });
+
+  const shortFirstResult = greedySchedule(
+    shortFirstOrder,
+    eventMap,
+    rooms,
+    prereqsOf,
+    gap,
+    options.startTime,
+    options.endTime
+  );
+
+  let best =
+    shortFirstResult.assignments.length > bestResult.assignments.length
+      ? shortFirstResult
+      : bestResult;
+
+  // If some events are unscheduled, try backtracking for small inputs
+  if (best.unscheduled.length > 0 && events.length <= 30) {
+    const btResult = backtrackSchedule(
+      schedulingOrder,
+      eventMap,
+      rooms,
+      prereqsOf,
+      gap,
+      options.startTime,
+      options.endTime
+    );
+    if (btResult.assignments.length > best.assignments.length) {
+      best = btResult;
+    }
+  }
+
+  return best;
+}
+
+function greedySchedule(
+  order: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  prereqsOf: Map<string, string[]>,
+  gap: number,
+  windowStart: number,
+  windowEnd: number
+): ScheduleResult {
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+  const assignmentMap = new Map<string, Assignment>();
+
+  for (const eventId of order) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+    const prereqs = prereqsOf.get(eventId) ?? [];
+
+    // Calculate earliest start based on prerequisites
+    let prereqEnd = windowStart;
+    let allPrereqsScheduled = true;
+    for (const prereqId of prereqs) {
+      const prereqAssignment = assignmentMap.get(prereqId);
+      if (prereqAssignment) {
+        prereqEnd = Math.max(prereqEnd, prereqAssignment.endTime + gap);
+      } else {
+        // Prerequisite wasn't scheduled - this event can't be scheduled either
+        allPrereqsScheduled = false;
+        break;
+      }
+    }
+
+    if (!allPrereqsScheduled) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    // Find valid rooms (capacity check)
+    const validRooms = rooms.filter((r) => r.capacity >= attendees);
+    if (validRooms.length === 0) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    // Sort rooms: preferred room first, then by capacity (smallest sufficient room first)
+    const sortedRooms = [...validRooms].sort((a, b) => {
+      if (event.preferredRoom) {
+        if (a.id === event.preferredRoom && b.id !== event.preferredRoom)
+          return -1;
+        if (b.id === event.preferredRoom && a.id !== event.preferredRoom)
+          return 1;
+      }
+      return a.capacity - b.capacity;
+    });
+
+    let placed = false;
+    for (const room of sortedRooms) {
+      const start = findEarliestStart(
+        event.duration,
+        room.id,
+        assignments,
+        prereqEnd,
+        gap,
+        windowStart,
+        windowEnd
+      );
+
+      if (start !== null) {
+        const assignment: Assignment = {
+          eventId,
+          roomId: room.id,
+          startTime: start,
+          endTime: start + event.duration,
+        };
+        assignments.push(assignment);
+        assignmentMap.set(eventId, assignment);
+        placed = true;
+        break;
+      }
+    }
+
+    if (!placed) {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
+
+/**
+ * Backtracking scheduler that tries to maximize scheduled events.
+ * For each event, tries multiple room/time combinations and backtracks
+ * if a choice leads to fewer total events scheduled.
+ */
+function backtrackSchedule(
+  order: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  prereqsOf: Map<string, string[]>,
+  gap: number,
+  windowStart: number,
+  windowEnd: number
+): ScheduleResult {
+  let bestAssignments: Assignment[] = [];
+  let bestCount = 0;
+  const totalEvents = order.length;
+  let iterations = 0;
+  const maxIterations = 50000;
+
+  function solve(
+    idx: number,
+    currentAssignments: Assignment[],
+    assignmentMap: Map<string, Assignment>,
+    skippedCount: number
+  ): void {
+    iterations++;
+    if (iterations > maxIterations) return;
+
+    // Pruning: if we can't possibly beat the best even by scheduling all remaining
+    const remaining = totalEvents - idx;
+    const currentCount = currentAssignments.length;
+    if (currentCount + remaining <= bestCount) return;
+
+    if (idx === totalEvents) {
+      if (currentCount > bestCount) {
+        bestCount = currentCount;
+        bestAssignments = [...currentAssignments];
+      }
+      return;
+    }
+
+    const eventId = order[idx];
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+    const prereqs = prereqsOf.get(eventId) ?? [];
+
+    // Check prerequisites
+    let prereqEnd = windowStart;
+    let allPrereqsScheduled = true;
+    for (const prereqId of prereqs) {
+      const prereqAssignment = assignmentMap.get(prereqId);
+      if (prereqAssignment) {
+        prereqEnd = Math.max(prereqEnd, prereqAssignment.endTime + gap);
+      } else {
+        allPrereqsScheduled = false;
+        break;
+      }
+    }
+
+    if (!allPrereqsScheduled) {
+      // Skip this event
+      solve(idx + 1, currentAssignments, assignmentMap, skippedCount + 1);
+      return;
+    }
+
+    // Find valid rooms
+    const validRooms = rooms.filter((r) => r.capacity >= attendees);
+
+    // Try each room
+    const roomOptions: { room: Room; start: number }[] = [];
+    for (const room of validRooms) {
+      const start = findEarliestStart(
+        event.duration,
+        room.id,
+        currentAssignments,
+        prereqEnd,
+        gap,
+        windowStart,
+        windowEnd
+      );
+      if (start !== null) {
+        roomOptions.push({ room, start });
+      }
+    }
+
+    // Sort options: preferred room first, then earliest start, then smallest room
+    roomOptions.sort((a, b) => {
+      if (event.preferredRoom) {
+        if (
+          a.room.id === event.preferredRoom &&
+          b.room.id !== event.preferredRoom
+        )
+          return -1;
+        if (
+          b.room.id === event.preferredRoom &&
+          a.room.id !== event.preferredRoom
+        )
+          return 1;
+      }
+      if (a.start !== b.start) return a.start - b.start;
+      return a.room.capacity - b.room.capacity;
+    });
+
+    // Try placing in each valid option
+    for (const option of roomOptions) {
+      const assignment: Assignment = {
+        eventId,
+        roomId: option.room.id,
+        startTime: option.start,
+        endTime: option.start + event.duration,
+      };
+      currentAssignments.push(assignment);
+      assignmentMap.set(eventId, assignment);
+
+      solve(idx + 1, currentAssignments, assignmentMap, skippedCount);
+
+      // If we found a perfect solution, stop
+      if (bestCount === totalEvents) return;
+
+      currentAssignments.pop();
+      assignmentMap.delete(eventId);
+
+      if (iterations > maxIterations) return;
+    }
+
+    // Also try skipping this event (maybe leaving room for others)
+    solve(idx + 1, currentAssignments, assignmentMap, skippedCount + 1);
+  }
+
+  solve(0, [], new Map(), 0);
+
+  const scheduledIds = new Set(bestAssignments.map((a) => a.eventId));
+  const unscheduled = order.filter((id) => !scheduledIds.has(id));
+
+  return { assignments: bestAssignments, unscheduled };
+}
