rice)\n    52→    VALUES (?, ?, ?, ?)\n    53→  `);\n    54→\n    55→  const result = insertInvoice.run(\n    56→    data.customer_id,\n    57→    data.date,\n    58→    data.subtotal,\n    59→    data.discount_rate,\n    60→    data.tax_rate,\n    61→    data.total,\n    62→    data.status || 'draft',\n    63→  );\n    64→\n    65→  const invoiceId = result.lastInsertRowid as number;\n    66→\n    67→  if (data.line_items) {\n    68→    for (const item of data.line_items) {\n    69→      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    70→    }\n    71→  }\n    72→\n    73→  return invoiceId;\n    74→}\n    75→\n    76→/**\n    77→ * Retrieve all invoices for a specific customer.\n    78→ */\n    79→export function getInvoicesByCustomer(\n    80→  db: Database.Database,\n    81→  customerId: string,\n    82→): Invoice[] {\n    83→  const stmt = db.prepare(`\n    84→    SELECT * FROM invoices\n    85→    WHERE customer_id = ?\n    86→    ORDER BY date ASC\n    87→  `);\n    88→  return stmt.all(customerId) as Invoice[];\n    89→}\n    90→"}]},"parent_tool_use_id":null,"session_id":"98e895b0-9884-4227-b69c-daf3d243c673","uuid":"eb8b58dd-549f-469d-be04-3996954232dd","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/db/queries.ts","content":"import type Database from 'better-sqlite3';\nimport type { Invoice, LineItem } from '../models/invoice.js';\n\n/**\n * Retrieve invoices within a date range (inclusive on both ends).\n */\nexport function getInvoicesByDateRange(\n  db: Database.Database,\n  startDate: string,\n  endDate: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE date >= ? AND date < ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(startDate, endDate) as Invoice[];\n}\n\n/**\n * Retrieve a single invoice by ID, including its line items.\n */\nexport function getInvoiceById(\n  db: Database.Database,\n  id: number,\n): (Invoice & { line_items: LineItem[] }) | undefined {\n  const invoiceStmt = db.prepare('SELECT * FROM invoices WHERE id = ?');\n  const invoice = invoiceStmt.get(id) as Invoice | undefined;\n\n  if (!invoice) return undefined;\n\n  const itemsStmt = db.prepare('SELECT * FROM line_items WHERE invoice_id = ?');\n  const line_items = itemsStmt.all(id) as LineItem[];\n\n  return { ...invoice, line_items };\n}\n\n/**\n * Create a new invoice with line items.\n */\nexport function createInvoice(\n  db: Database.Database,\n  data: Invoice & { line_items?: LineItem[] },\n): number {\n  const insertInvoice = db.prepare(`\n    INSERT INTO invoices (customer_id, date, subtotal, discount_rate, tax_rate, total, status)\n    VALUES (?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const insertLineItem = db.prepare(`\n    INSERT INTO line_items (invoice_id, description, quantity, unit_price)\n    VALUES (?, ?, ?, ?)\n  `);\n\n  const result = insertInvoice.run(\n    data.customer_id,\n    data.date,\n    data.subtotal,\n    data.discount_rate,\n    data.tax_rate,\n    data.total,\n    data.status || 'draft',\n  );\n\n  const invoiceId = result.lastInsertRowid as number;\n\n  if (data.line_items) {\n    for (const item of data.line_items) {\n      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    }\n  }\n\n  return invoiceId;\n}\n\n/**\n * Retrieve all invoices for a specific customer.\n */\nexport function getInvoicesByCustomer(\n  db: Database.Database,\n  customerId: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE customer_id = ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(customerId) as Invoice[];\n}\n","numLines":90,"startLine":1,"totalLines":90}}}
