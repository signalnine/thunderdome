t connectWs(port, docId);\n\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    // Client 1: insert 'X' at start\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: ['X', 3],\n    }));\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe('ack');\n\n    // ws2 receives broadcast of op1\n    const broadcast1 = await waitForMessage(ws2);\n    expect(broadcast1.type).toBe('operation');\n\n    // Client 2: insert 'Y' at end, based on version 0 (concurrent)\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: [3, 'Y'],\n    }));\n\n    // ws1 receives broadcast of transformed op2\n    const broadcast2Promise = waitForMessage(ws1);\n\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe('ack');\n\n    await broadcast2Promise;\n\n    const getRes = await httpGet(port, `/api/documents/${docId}`);\n    const content = getRes.data.content;\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content).toContain('abc');\n\n    await closeWs(ws1);\n    await closeWs(ws2);\n  });\n\n  it('should reject invalid operations', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Invalid Op Test', content: 'hello' });\n    const docId = createRes.data.id;\n\n    const ws = await connectWs(port, docId);\n    await waitForMessage(ws); // sync\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: [10, 'x'],\n    }));\n\n    const errMsg = await waitForMessage(ws);\n    expect(errMsg.type).toBe('error');\n\n    await closeWs(ws);\n  });\n\n  it('should close WebSocket for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    await new Promise<void>((resolve) => {\n      ws.on('open', () => {\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          expect(msg.type).toBe('error');\n          ws.on('close', () => resolve());\n        });\n      });\n    });\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: '10 Clients Test', content: '' });\n    const docId = createRes.data.id;\n\n    const clients: WebSocket[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(port, docId);\n      await waitForMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client sends sequentially, each based on the latest version\n    for (let i = 0; i < 10; i++) {\n      clients[i].send(JSON.stringify({\n        type: 'operation',\n        docId,\n        version: i,\n        operation: i === 0 ? [`${i}`] : [i, `${i}`],\n      }));\n\n      const ack = await waitForMessage(clients[i]);\n      expect(ack.type).toBe('ack');\n\n      // Drain broadcasts for all other connected clients\n      const drainPromises: Promise<Record<string, unknown>>[] = [];\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          drainPromises.push(waitForMessage(clients[j]));\n        }\n      }\n      await Promise.all(drainPromises);\n    }\n\n    const getRes = await httpGet(port, `/api/documents/${docId}`);\n    const content = getRes.data.content;\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(`${i}`);\n    }\n\n    for (const ws of clients) {\n      await closeWs(ws);\n    }\n  });\n\n  it('should persist data across server restarts', async () => {\n    const tmpDb = `/tmp/collab-test-${Date.now()}.db`;\n\n    const instance1 = createApp(tmpDb);\n    const port1 = await instance1.start(0);\n\n    const createRes = await httpPost(port1, '/api/documents', { title: 'Persist Test', content: 'initial' });\n    const docId = createRes.data.id;\n\n    const ws = await connectWs(port1, docId);\n    await waitForMessage(ws);