components', () => {\n      expect(validate([0], 0)).not.toBeNull();\n    });\n  });\n\n  describe('transform', () => {\n    it('should handle two inserts at different positions', () => {\n      const doc = 'abc';\n      // User A inserts 'X' at position 1: [1, 'X', 2]\n      // User B inserts 'Y' at position 2: [2, 'Y', 1]\n      const opA: Operation = [1, 'X', 2];\n      const opB: Operation = [2, 'Y', 1];\n\n      const [opAprime, opBprime] = transform(opA, opB);\n\n      // Apply A then B'\n      const resultAB = apply(apply(doc, opA), opBprime);\n      // Apply B then A'\n      const resultBA = apply(apply(doc, opB), opAprime);\n\n      expect(resultAB).toBe(resultBA);\n      // Both inserts should be present\n      expect(resultAB).toContain('X');\n      expect(resultAB).toContain('Y');\n    });\n\n    it('should handle two inserts at the same position', () => {\n      const doc = 'abc';\n      const opA: Operation = [1, 'X', 2];\n      const opB: Operation = [1, 'Y', 2];\n\n      const [opAprime, opBprime] = transform(opA, opB);\n\n      const resultAB = apply(apply(doc, opA), opBprime);\n      const resultBA = apply(apply(doc, opB), opAprime);\n\n      expect(resultAB).toBe(resultBA);\n      expect(resultAB).toContain('X');\n      expect(resultAB).toContain('Y');\n    });\n\n    it('should handle insert vs delete', () => {\n      const doc = 'abcd';\n      // A inserts 'X' at position 1\n      const opA: Operation = [1, 'X', 3];\n      // B deletes character at position 2\n      const opB: Operation = [2, -1, 1];\n\n      const [opAprime, opBprime] = transform(opA, opB);\n\n      const resultAB = apply(apply(doc, opA), opBprime);\n      const resultBA = apply(apply(doc, opB), opAprime);\n\n      expect(resultAB).toBe(resultBA);\n      expect(resultAB).toContain('X');\n      expect(resultAB).not.toContain('c'); // deleted char\n    });\n\n    it('should handle both deleting the same character', () => {\n      const doc = 'abc';\n      // Both delete character