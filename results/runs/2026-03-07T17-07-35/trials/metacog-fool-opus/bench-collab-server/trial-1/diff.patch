        c2 = i2 < op2.length ? op2[i2] : null;\n          }\n        } else {\n          // partial insert consumed\n          c1 = c1.slice(d2);\n          i2++;\n          c2 = i2 < op2.length ? op2[i2] : null;\n        }\n      } else if (typeof c1 === 'number' && c1 > 0) {\n        // op1 retains, op2 deletes\n        const min = Math.min(c1, d2);\n        result.push(-min);\n        if (c1 === d2) {\n          i1++; i2++;\n          c1 = i1 < op1.length ? op1[i1] : null;\n          c2 = i2 < op2.length ? op2[i2] : null;\n        } else if (c1 < d2) {\n          i1++;\n          c1 = i1 < op1.length ? op1[i1] : null;\n          c2 = -(d2 - c1);\n        } else {\n          i2++;\n          c2 = i2 < op2.length ? op2[i2] : null;\n          c1 = c1 - d2;\n        }\n      } else {\n        throw new Error('Compose: mismatch');\n      }\n      continue;\n    }\n\n    // If op1 inserts, handle it\n    if (typeof c1 === 'string') {\n      // op1 inserts. op2 must consume these chars (retain or delete handled above)\n      if (typeof c2 === 'number' && c2 > 0) {\n        // op2 retains through op1's insert\n        const insLen = c1.length;\n        const min = Math.min(insLen, c2);\n        result.push(c1.slice(0, min));\n        if (insLen === c2) {\n          i1++; i2++;\n          c1 = i1 < op1.length ? op1[i1] : null;\n          c2 = i2 < op2.length ? op2[i2] : null;\n        } else if (insLen < c2) {\n          i1++;\n          c1 = i1 < op1.length ? op1[i1] : null;\n          c2 = c2 - insLen;\n        } else {\n          i2++;\n          c2 = i2 < op2.length ? op2[i2] : null;\n          c1 = c1.slice(c2 as number); // remaining insert\n        }\n      } else if (typeof c2 === 'string') {\n        // Both insert - op2's insert first\n        result.push(c2);\n        i2++;\n        c2 = i2 < op2.length ? op2[i2] : null;\n      } else if (c2 === null) {\n        result.push(c1);\n        i1++;\n        c1 = i1 < op1.length ? op1[i1] : null;\n      } else {\n   