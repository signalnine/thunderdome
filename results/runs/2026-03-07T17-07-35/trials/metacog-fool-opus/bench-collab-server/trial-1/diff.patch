own>[] = [];\n  private waiters: ((msg: Record<string, unknown>) => void)[] = [];\n\n  constructor(ws: WebSocket) {\n    this.ws = ws;\n    ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (this.waiters.length > 0) {\n        const waiter = this.waiters.shift()!;\n        waiter(msg);\n      } else {\n        this.messageQueue.push(msg);\n      }\n    });\n  }\n\n  send(data: unknown): void {\n    this.ws.send(JSON.stringify(data));\n  }\n\n  nextMessage(): Promise<Record<string, unknown>> {\n    if (this.messageQueue.length > 0) {\n      return Promise.resolve(this.messageQueue.shift()!);\n    }\n    return new Promise((resolve, reject) => {\n      const timer = setTimeout(() => reject(new Error('Timeout waiting for WS message')), 5000);\n      this.waiters.push((msg) => {\n        clearTimeout(timer);\n        resolve(msg);\n      });\n    });\n  }\n\n  async close(): Promise<void> {\n    return new Promise((resolve) => {\n      if (this.ws.readyState === WebSocket.CLOSED) {\n        resolve();\n        return;\n      }\n      this.ws.on('close', () => resolve());\n      this.ws.close();\n    });\n  }\n}\n\nfunction connectWs(port: number, docId: string): Promise<WsClient> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    // Register message handler BEFORE open fires, so we don't miss early messages\n    const client = new WsClient(ws);\n    ws.on('open', () => resolve(client));\n    ws.on('error', (err) => reject(err));\n  });\n}\n\ndescribe('REST API', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterAll(async () => {\n    await instance.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await httpPost(port, '/api/documents', { title: 'Test Doc', content: 'Hello' });\n    expect(res.status).toBe(201);\n    expect(res.data).toHaveProperty('id');\n    expect(res.data).toHaveProperty('title', 'Test Doc');\n    expect(res.data).toHaveProperty('content', 'Hello');\n  });\n\n  it('should list documents', async () => {\n    const res = await httpGet(port, '/api/documents');\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.data)).toBe(true);\n    expect(res.data.length).toBeGreaterThan(0);\n  });\n\n  it('should get a single document', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Get Test' });\n    const id = createRes.data.id;\n    const res = await httpGet(port, `/api/documents/${id}`);\n    expect(res.status).toBe(200);\n    expect(res.data).toHaveProperty('title', 'Get Test');\n  });\n\n  it('should update a document', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Update Test' });\n    const id = createRes.data.id;\n    const res = await httpPut(port, `/api/documents/${id}`, { title: 'Updated Title', content: 'New Content' });\n    expect(res.status).toBe(200);\n    expect(res.data).toHaveProperty('title', 'Updated Title');\n    expect(res.data).toHaveProperty('content', 'New Content');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Delete Test' });\n    const id = createRes.data.id;\n    const res = await httpDelete(port, `/api/documents/${id}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await httpGet(port, `/api/documents/${id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await httpGet(port, '/api/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should return 400 for missing title', async () => {\n    const res = await httpPost(port, '/api/documents', {});\n    expect(res.status).toBe(400);\n  });\n\n  it('should get version history', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Version Test', content: 'v1' });\n    const id = createRes.data.id;\n    const res = await httpGet(port, `/api/documents/${id}/versions`);\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.data)).toBe(true);\n    expect(res.data.length).toBe(1);\n    expect(res.data[0]).toHaveProperty('version', 0);\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterAll(async () => {\n    await instance.stop();\n  });\n\n  it('should send sync message on connect', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'WS Test', content: 'hello' });\n    const docId = createRes.data.id;\n\n    const client = await connectWs(port, docId);\n    const msg = await client.nextMessage();\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n    expect(msg).toHaveProperty('clientId');\n\n    await client.close();\n  });\n\n  it('should handle a simple insert operation', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Op Test', content: 'hello' });\n    const docId = createRes.data.id;\n\n    const client = await connectWs(port, docId);\n    const syncMsg = await client.nextMessage();\n    expect(syncMsg.type).toBe('sync');\n\n    client.send({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: [5, ' world'],\n    });\n\n    const ackMsg = await client.nextMessage();\n    expect(ackMsg.type).toBe('ack');\n    expect(ackMsg.version).toBe(1);\n\n    const getRes = await httpGet(port, `/api/documents/${docId}`);\n    expect(getRes.data.content).toBe('hello world');\n\n    await client.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Broadcast Test', content: 'abc' });\n    const docId = createRes.data.id;\n\n    const c1 = await connectWs(port, docId);\n    const c2 = await connectWs(port, docId);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    c1.send({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: [3, 'X'],\n    });\n\n    const ack = await c1.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await c2.nextMessage();\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(1);\n    expect(broadcast.operation).toEqual([3, 'X']);\n\n    await c1.close();\n    await c2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'OT Test', content: 'abc' });\n    const docId = createRes.data.id;\n\n    const c1 = await connectWs(port, docId);\n    const c2 = await connectWs(port, docId);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // Client 1: insert 'X' at start\n    c1.send({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: ['X', 3],\n    });\n\n    const ack1 = await c1.nextMessage();\n    expect(ack1.type).toBe('ack');\n\n    // c2 receives broadcast of op1\n    const broadcast1 = await c2.nextMessage();\n    expect(broadcast1.type).toBe('operation');\n\n    // Client 2: insert 'Y' at end based on version 0 (concurrent)\n    c2.send({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: [3, 'Y'],\n    });\n\n    const ack2 = await c2.nextMessage();\n    expect(ack2.type).toBe('ack');\n\n    // c1 receives broadcast of transformed op2\n    const broadcast2 = await c1.nextMessage();\n    expect(broadcast2.type).toBe('operation');\n\n    const getRes = await httpGet(port, `/api/documents/${docId}`);\n    const content = getRes.data.content;\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content).toContain('abc');\n\n    await c1.close();\n    await c2.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Invalid Op Test', content: 'hello' });\n    const docId = createRes.data.id;\n\n    const client = await connectWs(port, docId);\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: [10, 'x'],\n    });\n\n    const errMsg = await client.nextMessage();\n    expect(errMsg.type).toBe('error');\n\n    await client.close();\n  });\n\n  it('should close WebSocket for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    await new Promise<void>((resolve) => {\n      ws.on('open', () => {\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          expect(msg.type).toBe('error');\n          ws.on('close', () => resolve());\n        });\n      });\n    });\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: '10 Clients Test', content: '' });\n    const docId = createRes.data.id;\n\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(port, docId);\n      await client.nextMessage(); // sync\n      clients.push(client);\n    }\n\n    for (let i = 0; i < 10; i++) {\n      clients[i].send({\n        type: 'operation',\n        docId,\n        version: i,\n        operation: i === 0 ? [`${i}`] : [i, `${i}`],\n      });\n\n      const ack = await clients[i].nextMessage();\n      expect(ack.type).toBe('ack');\n\n      // Drain broadcasts for all other clients\n      const drainPromises: Promise<Record<string, unknown>>[] = [];\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          drainPromises.push(clients[j].nextMessage());\n        }\n      }\n      await Promise.all(drainPromises);\n    }\n\n    const getRes = await httpGet(port, `/api/documents/${docId}`);\n    const content = getRes.data.content;\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(`${i}`);\n    }\n\n    for (const client of clients) {\n      await client.close();\n    }\n  });\n\n  it('should persist data across server restarts', async () => {\n    const tmpDb = `/tmp/collab-test-${Date.now()}.db`;\n\n    const instance1 = createApp(tmpDb);\n    const port1 = await instance1.start(0);\n\n    const createRes = await httpPost(port1, '/api/documents', { title: 'Persist Test', content: 'initial' });\n    const docId = createRes.data.id;\n\n    const client = await connectWs(port1, docId);\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      docId,\n      version: 0,\n      operation: [7, ' data'],\n    });\n\n    const ack = await client.nextMessage();\n    expect(ack.type).toBe('ack');\n    await client.close();\n\n    await instance1.stop();\n\n    const instance2 = createApp(tmpDb);\n    const port2 = await instance2.start(0);\n\n    const getRes = await httpGet(port2, `/api/documents/${docId}`);\n    expect(getRes.status).toBe(200);\n    expect(getRes.data.content).toBe('initial data');\n\n    const versionsRes = await httpGet(port2, `/api/documents/${docId}/versions`);\n    expect(versionsRes.data.length).toBe(2);\n\n    await instance2.stop();\n  });\n});\n","structuredPatch":[{"oldStart":35,"oldLines":44,"newStart":35,"newLines":67,"lines":["   return { status: res.status };"," }"," ","-function connectWs(port: number, docId: string): Promise<WebSocket> {","-  return new Promise((resolve, reject) => {","-    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);","-    ws.on('open', () => {","-      resolve(ws);","+/**","+ * A buffered WebSocket wrapper that capt