@@ -0,0 +1,264 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server } from 'http';
+import { DocumentStore } from './database.js';
+import { Operation, apply, validate, transform } from './ot.js';
+import { randomUUID } from 'crypto';
+
+interface ConnectedClient {
+  ws: WebSocket;
+  clientId: string;
+  docId: string;
+}
+
+interface DocumentState {
+  version: number;
+  content: string;
+  /** History of operations applied since version 0, indexed by version number (1-indexed) */
+  ops: Operation[];
+}
+
+interface IncomingMessage_WS {
+  type: string;
+  docId?: string;
+  version?: number;
+  operation?: Operation;
+  clientId?: string;
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private store: DocumentStore;
+  /** docId -> list of connected clients */
+  private rooms: Map<string, ConnectedClient[]> = new Map();
+  /** docId -> in-memory document state for OT */
+  private docStates: Map<string, DocumentState> = new Map();
+
+  constructor(server: Server, store: DocumentStore) {
+    this.store = store;
+    this.wss = new WebSocketServer({ noServer: true });
+
+    // Handle upgrade ourselves to support path-based routing
+    server.on('upgrade', (request: IncomingMessage, socket, head) => {
+      const url = new URL(request.url ?? '/', `http://${request.headers.host ?? 'localhost'}`);
+      const match = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+
+      if (!match) {
+        // Also support just /ws with docId as query param
+        if (url.pathname === '/ws') {
+          const docId = url.searchParams.get('docId');
+          if (docId) {
+            this.wss.handleUpgrade(request, socket, head, (ws) => {
+              this.handleConnection(ws, docId);
+            });
+            return;
+          }
+        }
+        socket.destroy();
+        return;
+      }
+
+      const docId = match[1];
+      this.wss.handleUpgrade(request, socket, head, (ws) => {
+        this.handleConnection(ws, docId);
+      });
+    });
+  }
+
+  private getDocState(docId: string): DocumentState | null {
+    let state = this.docStates.get(docId);
+    if (state) return state;
+
+    // Load from database
+    const doc = this.store.getDocument(docId);
+    if (!doc) return null;
+
+    const latestVersion = this.store.getLatestVersion(docId);
+    state = {
+      version: latestVersion,
+      content: doc.content,
+      ops: [],
+    };
+
+    // Load operation history from DB
+    const versions = this.store.getVersions(docId);
+    for (const v of versions) {
+      if (v.operation) {
+        try {
+          state.ops[v.version] = JSON.parse(v.operation);
+        } catch {
+          // skip malformed ops
+        }
+      }
+    }
+
+    this.docStates.set(docId, state);
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, docId: string): void {
+    const clientId = randomUUID();
+    const state = this.getDocState(docId);
+
+    if (!state) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    const client: ConnectedClient = { ws, clientId, docId };
+
+    if (!this.rooms.has(docId)) {
+      this.rooms.set(docId, []);
+    }
+    this.rooms.get(docId)!.push(client);
+
+    // Send sync message with current state
+    ws.send(JSON.stringify({
+      type: 'sync',
+      docId,
+      content: state.content,
+      version: state.version,
+      clientId,
+    }));
+
+    ws.on('message', (data) => {
+      try {
+        const msg: IncomingMessage_WS = JSON.parse(data.toString());
+        this.handleMessage(client, msg);
+      } catch (err) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          message: err instanceof Error ? err.message : 'Invalid message',
+        }));
+      }
+    });
+
+    ws.on('close', () => {
+      const room = this.rooms.get(docId);
+      if (room) {
+        const idx = room.indexOf(client);
+        if (idx >= 0) room.splice(idx, 1);
+        if (room.length === 0) {
+          this.rooms.delete(docId);
+          // Keep docStates around for efficiency
+        }
+      }
+    });
+  }
+
+  private handleMessage(client: ConnectedClient, msg: IncomingMessage_WS): void {
+    if (msg.type !== 'operation') {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: `Unknown message type: ${msg.type}`,
+      }));
+      return;
+    }
+
+    const { docId } = client;
+    const state = this.getDocState(docId);
+    if (!state) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      return;
+    }
+
+    const clientVersion = msg.version;
+    let operation = msg.operation;
+
+    if (clientVersion === undefined || !operation) {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: 'Missing version or operation',
+      }));
+      return;
+    }
+
+    if (clientVersion < 0 || clientVersion > state.version) {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: `Invalid version ${clientVersion}; server is at version ${state.version}`,
+      }));
+      return;
+    }
+
+    // Transform the operation against all operations that have been applied
+    // since the client's version
+    try {
+      // Transform against concurrent ops
+      for (let v = clientVersion + 1; v <= state.version; v++) {
+        const serverOp = state.ops[v];
+        if (serverOp) {
+          const [transformedClient] = transform(operation, serverOp);
+          operation = transformedClient;
+        }
+      }
+
+      // Now validate the transformed operation against current content
+      const validationError = validate(operation, state.content.length);
+      if (validationError) {
+        client.ws.send(JSON.stringify({
+          type: 'error',
+          message: validationError,
+        }));
+        return;
+      }
+
+      // Apply the operation
+      const newContent = apply(state.content, operation);
+      const newVersion = state.version + 1;
+
+      // Update state
+      state.content = newContent;
+      state.version = newVersion;
+      state.ops[newVersion] = operation;
+
+      // Persist to database
+      this.store.updateContent(docId, newContent);
+      this.store.addVersion(docId, newVersion, newContent, JSON.stringify(operation));
+
+      // Acknowledge to the sender
+      client.ws.send(JSON.stringify({
+        type: 'ack',
+        version: newVersion,
+      }));
+
+      // Broadcast to all other clients in the room
+      const room = this.rooms.get(docId);
+      if (room) {
+        const broadcastMsg = JSON.stringify({
+          type: 'operation',
+          version: newVersion,
+          operation,
+          clientId: client.clientId,
+        });
+        for (const other of room) {
+          if (other !== client && other.ws.readyState === WebSocket.OPEN) {
+            other.ws.send(broadcastMsg);
+          }
+        }
+      }
+    } catch (err) {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: err instanceof Error ? err.message : 'Operation failed',
+      }));
+    }
+  }
+
+  closeAll(): void {
+    for (const [, room] of this.rooms) {
+      for (const client of room) {
+        client.ws.close();
+      }
+    }
+    this.rooms.clear();
+    this.docStates.clear();
+    this.wss.close();
+  }
+
+  /** Reset in-memory state for a document (useful when document is deleted via REST) */
+  invalidateDoc(docId: string): void {
+    this.docStates.delete(docId);
+  }
+}
