from '../server.js';\nimport WebSocket from 'ws';\n\nfunction makeUrl(port: number, path: string): string {\n  return `http://localhost:${port}${path}`;\n}\n\nasync function httpPost(port: number, path: string, body: unknown) {\n  const res = await fetch(makeUrl(port, path), {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(body),\n  });\n  return { status: res.status, data: await res.json() };\n}\n\nasync function httpGet(port: number, path: string) {\n  const res = await fetch(makeUrl(port, path));\n  if (res.status === 204) return { status: res.status, data: null };\n  return { status: res.status, data: await res.json() };\n}\n\nasync function httpPut(port: number, path: string, body: unknown) {\n  const res = await fetch(makeUrl(port, path), {\n    method: 'PUT',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(body),\n  });\n  return { status: res.status, data: await res.json() };\n}\n\nasync function httpDelete(port: number, path: string) {\n  const res = await fetch(makeUrl(port, path), { method: 'DELETE' });\n  return { status: res.status };\n}\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/${docId}`);\n    ws.on('open', () => {\n      resolve(ws);\n    });\n    ws.on('error', (err) => {\n      console.error('connectWs error:', err);\n      reject(err);\n    });\n    ws.on('unexpected-response', (_req, res) => {\n      console.error('unexpected-response:', res.statusCode);\n      reject(new Error(`Unexpected response: ${res.statusCode}`));\n    });\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('Timeout waiting for WS message')), 5000);\n    ws.once('message', (data) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction closeWs(ws: WebSocket): Promise<void> {\n  return new Promise((resolve) => {\n    if (ws.readyState === WebSocket.CLOSED) {\n      resolve();\n      return;\n    }\n    ws.on('close', () => resolve());\n    ws.close();\n  });\n}\n\ndescribe('REST API', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterAll(async () => {\n    await instance.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await httpPost(port, '/api/documents', { title: 'Test Doc', content: 'Hello' });\n    expect(res.status).toBe(201);\n    expect(res.data).toHaveProperty('id');\n    expect(res.data).toHaveProperty('title', 'Test Doc');\n    expect(res.data).toHaveProperty('content', 'Hello');\n  });\n\n  it('should list documents', async () => {\n    const res = await httpGet(port, '/api/documents');\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.data)).toBe(true);\n    expect(res.data.length).toBeGreaterThan(0);\n  });\n\n  it('should get a single document', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Get Test' });\n    const id = createRes.data.id;\n    const res = await httpGet(port, `/api/documents/${id}`);\n    expect(res.status).toBe(200);\n    expect(res.data).toHaveProperty('title', 'Get Test');\n  });\n\n  it('should update a document', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Update Test' });\n    const id = createRes.data.id;\n    const res = await httpPut(port, `/api/documents/${id}`, { title: 'Updated Title', content: 'New Content' });\n    expect(res.status).toBe(200);\n    expect(res.data).toHaveProperty('title', 'Updated Title');\n    expect(res.data).toHaveProperty('content', 'New Content');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Delete Test' });\n    const id = createRes.data.id;\n    const res = await httpDelete(port, `/api/documents/${id}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await httpGet(port, `/api/documents/${id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await httpGet(port, '/api/documents/nonexistent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should return 400 for missing title', async () => {\n    const res = await httpPost(port, '/api/documents', {});\n    expect(res.status).toBe(400);\n  });\n\n  it('should get version history', async () => {\n    const createRes = await httpPost(port, '/api/documents', { title: 'Version Test', content: 'v1' });\n    const id = createRes.data.id;\n    const res = await httpGet(port, `/api/documents/${id}/versions`);\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.data)).toBe(true);\n    expect(res.data.length).toBe(1);\n    expect(res.data[0]).toHaveProperty('version', 0);\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  let instance: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterAll(async () => {\n    await instance.stop();\n  });\n\n  it('should send sync message on connect', async () => {\n    console.log('sync test: port=', port);\n    const createRes = await httpPost(port, '/api/documents', { title: 'WS Test', content: 'hello' });\n    const docId = createRes.data.id;\n    console.log('sync test: docId=', docId);\n\n    const ws = await connectWs(port, docId);\n    console.log('sync test: ws connected, readyState=', ws.readyState);\n    const msg = await waitForMessage(ws);\n    console.log('sync test: got message', msg.type);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe