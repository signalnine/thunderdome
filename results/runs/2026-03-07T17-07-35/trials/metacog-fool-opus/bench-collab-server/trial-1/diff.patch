index 0000000..952f1cd
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,402 @@
+/**
+ * Operational Transformation engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string at current position
+ * - number < 0: delete |N| characters
+ *
+ * The total "input length" of an operation (sum of retains + |deletes|) must
+ * equal the length of the document it applies to.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface ClientOperation {
+  type: 'operation';
+  docId: string;
+  version: number; // the version this op was based on
+  operation: Operation;
+  clientId?: string;
+}
+
+/** Calculate the input length an operation expects */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;      // retain
+      else len += Math.abs(c);   // delete
+    }
+    // inserts don't consume input characters
+  }
+  return len;
+}
+
+/** Calculate the output length an operation produces */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;      // retain produces characters
+      // delete produces nothing
+    } else {
+      len += c.length;           // insert produces characters
+    }
+  }
+  return len;
+}
+
+/** Apply an operation to a document string */
+export function apply(doc: string, op: Operation): string {
+  if (inputLength(op) !== doc.length) {
+    throw new Error(
+      `Operation input length ${inputLength(op)} does not match document length ${doc.length}`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === 'string') {
+      result += c;
+    } else if (c > 0) {
+      result += doc.slice(pos, pos + c);
+      pos += c;
+    } else {
+      // delete: skip characters
+      pos += Math.abs(c);
+    }
+  }
+
+  return result;
+}
+
+/** Compact an operation by merging adjacent same-type components */
+function compact(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+    if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+    } else if (typeof c === 'number' && typeof last === 'number') {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else {
+      result.push(c);
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations (op1 and op2) that were both applied
+ * to the same document state.
+ *
+ * Returns [op1', op2'] such that:
+ *   apply(apply(doc, op1), op2') === apply(apply(doc, op2), op1')
+ */
+export function transform(op1: Operation, op2: Operation): [Operation, Operation] {
+  const op1prime: Operation = [];
+  const op2prime: Operation = [];
+
+  // Use iterators over the components
+  let i1 = 0, i2 = 0;
+  let c1: OpComponent | null = op1[i1] ?? null;
+  let c2: OpComponent | null = op2[i2] ?? null;
+
+  while (c1 !== null || c2 !== null) {
+    // If op1 has an insert, it goes first in op1' and we retain over it in op2'
+    if (typeof c1 === 'string') {
+      op1prime.push(c1);
+      op2prime.push(c1.length);
+      i1++;
+      c1 = i1 < op1.length ? op1[i1] : null;
+      continue;
+    }
+
+    // If op2 has an insert, it goes first in op2' and we retain over it in op1'
+    if (typeof c2 === 'string') {
+      op2prime.push(c2);
+      op1prime.push(c2.length);
+      i2++;
+      c2 = i2 < op2.length ? op2[i2] : null;
+      continue;
+    }
+
+    if (c1 === null || c2 === null) {
+      throw new Error('Transform mismatch: operations have different base lengths');
+    }
+
+    // Both are numbers. Could be retain or delete.
+    const n1 = c1 as number;
+    const n2 = c2 as number;
+
+    if (n1 > 0 && n2 > 0) {
+      // Both retain
+      const min = Math.min(n1, n2);
+      op1prime.push(min);
+      op2prime.push(min);
+      if (n1 === n2) {
+        i1++; i2++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = i2 < op2.length ? op2[i2] : null;
+      } else if (n1 < n2) {
+        i1++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = n2 - n1;
+      } else {
+        i2++;
+        c2 = i2 < op2.length ? op2[i2] : null;
+        c1 = n1 - n2;
+      }
+    } else if (n1 < 0 && n2 < 0) {
+      // Both delete
+      const d1 = Math.abs(n1);
+      const d2 = Math.abs(n2);
+      const min = Math.min(d1, d2);
+      // Both are deleting the same characters, so they cancel out
+      if (d1 === d2) {
+        i1++; i2++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = i2 < op2.length ? op2[i2] : null;
+      } else if (d1 < d2) {
+        i1++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = -(d2 - min);
+      } else {
+        i2++;
+        c2 = i2 < op2.length ? op2[i2] : null;
+        c1 = -(d1 - min);
+      }
+    } else if (n1 < 0 && n2 > 0) {
+      // op1 deletes, op2 retains
+      const d1 = Math.abs(n1);
+      const min = Math.min(d1, n2);
+      op1prime.push(-min);
+      // op2 doesn't get to retain those chars (they were deleted)
+      if (d1 === n2) {
+        i1++; i2++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = i2 < op2.length ? op2[i2] : null;
+      } else if (d1 < n2) {
+        i1++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = n2 - d1;
+      } else {
+        i2++;
+        c2 = i2 < op2.length ? op2[i2] : null;
+        c1 = -(d1 - n2);
+      }
+    } else if (n1 > 0 && n2 < 0) {
+      // op1 retains, op2 deletes
+      const d2 = Math.abs(n2);
+      const min = Math.min(n1, d2);
+      op2prime.push(-min);
+      if (n1 === d2) {
+        i1++; i2++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = i2 < op2.length ? op2[i2] : null;
+      } else if (n1 < d2) {
+        i1++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = -(d2 - n1);
+      } else {
+        i2++;
+        c2 = i2 < op2.length ? op2[i2] : null;
+        c1 = n1 - d2;
+      }
+    }
+  }
+
+  return [compact(op1prime), compact(op2prime)];
+}
+
+/** Compose two sequential operations into one */
+export function compose(op1: Operation, op2: Operation): Operation {
+  if (outputLength(op1) !== inputLength(op2)) {
+    throw new Error('Compose: op1 output length must equal op2 input length');
+  }
+
+  const result: Operation = [];
+  let i1 = 0, i2 = 0;
+  let c1: OpComponent | null = op1[i1] ?? null;
+  let c2: OpComponent | null = op2[i2] ?? null;
+
+  while (c1 !== null || c2 !== null) {
+    // If op2 deletes, it goes into result
+    if (typeof c2 === 'number' && c2 < 0) {
+      // op2 deletes characters. Those chars came from op1's output.
+      // We need to consume from op1's output.
+      const d2 = Math.abs(c2);
+      // What did op1 produce at this point?
+      if (typeof c1 === 'string') {
+        // op1 inserted, op2 deletes that insert
+        const insLen = c1.length;
+        if (insLen <= d2) {
+          // entire insert consumed by delete
+          i1++;
+          c1 = i1 < op1.length ? op1[i1] : null;
+          if (d2 > insLen) {
+            c2 = -(d2 - insLen);
+          } else {
+            i2++;
+            c2 = i2 < op2.length ? op2[i2] : null;
+          }
+        } else {
+          // partial insert consumed
+          c1 = c1.slice(d2);
+          i2++;
+          c2 = i2 < op2.length ? op2[i2] : null;
+        }
+      } else if (typeof c1 === 'number' && c1 > 0) {
+        // op1 retains, op2 deletes
+        const r1: number = c1;
+        const min = Math.min(r1, d2);
+        result.push(-min);
+        if (r1 === d2) {
+          i1++; i2++;
+          c1 = i1 < op1.length ? op1[i1] : null;
+          c2 = i2 < op2.length ? op2[i2] : null;
+        } else if (r1 < d2) {
+          i1++;
+          c1 = i1 < op1.length ? op1[i1] : null;
+          c2 = -(d2 - r1);
+        } else {
+          i2++;
+          c2 = i2 < op2.length ? op2[i2] : null;
+          c1 = r1 - d2;
+        }
+      } else {
+        throw new Error('Compose: mismatch');
+      }
+      continue;
+    }
+
+    // If op1 inserts, handle it
+    if (typeof c1 === 'string') {
+      // op1 inserts. op2 must consume these chars (retain or delete handled above)
+      if (typeof c2 === 'number' && c2 > 0) {
+        // op2 retains through op1's insert
+        const insLen = c1.length;
+        const r2 = c2;
+        const min = Math.min(insLen, r2);
+        result.push(c1.slice(0, min));
+        if (insLen === r2) {
+          i1++; i2++;
+          c1 = i1 < op1.length ? op1[i1] : null;
+          c2 = i2 < op2.length ? op2[i2] : null;
+        } else if (insLen < r2) {
+          i1++;
+          c1 = i1 < op1.length ? op1[i1] : null;
+          c2 = r2 - insLen;
+        } else {
+          c1 = c1.slice(min);
+          i2++;
+          c2 = i2 < op2.length ? op2[i2] : null;
+        }
+      } else if (typeof c2 === 'string') {
+        // Both insert - op2's insert first
+        result.push(c2);
+        i2++;
+        c2 = i2 < op2.length ? op2[i2] : null;
+      } else if (c2 === null) {
+        result.push(c1);
+        i1++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+      } else {
+        throw new Error('Compose: unexpected state');
+      }
+      continue;
+    }
+
+    // If op2 inserts
+    if (typeof c2 === 'string') {
+      result.push(c2);
+      i2++;
+      c2 = i2 < op2.length ? op2[i2] : null;
+      continue;
+    }
+
+    if (c1 === null || c2 === null) {
+      if (c1 !== null) {
+        result.push(c1);
+        i1++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+      }
+      if (c2 !== null) {
+        result.push(c2);
+        i2++;
+        c2 = i2 < op2.length ? op2[i2] : null;
+      }
+      continue;
+    }
+
+    // Both are numbers
+    const n1 = c1 as number;
+    const n2 = c2 as number;
+
+    if (n1 > 0 && n2 > 0) {
+      // Both retain
+      const min = Math.min(n1, n2);
+      result.push(min);
+      if (n1 === n2) {
+        i1++; i2++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = i2 < op2.length ? op2[i2] : null;
+      } else if (n1 < n2) {
+        i1++;
+        c1 = i1 < op1.length ? op1[i1] : null;
+        c2 = n2 - n1;
+      } else {
+        i2++;
+        c2 = i2 < op2.length ? op2[i2] : null;
+        c1 = n1 - n2;
+      }
+    } else if (n1 < 0) {
+      // op1 deletes, pass through
+      result.push(n1);
+      i1++;
+      c1 = i1 < op1.length ? op1[i1] : null;
+    } else {
+      throw new Error('Compose: unexpected case');
+    }
+  }
+
+  return compact(result);
+}
+
+/** Validate that an operation is well-formed for a document of the given length */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) return 'Operation must be an array';
+
+  for (const c of op) {
+    if (typeof c === 'string') continue;
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c)) return 'Numeric components must be integers';
+      if (c === 0) return 'Zero-length components are not allowed';
+      continue;
+    }
+    return `Invalid component type: ${typeof c}`;
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
diff --git a/src/routes.ts b/src/routes.ts
new file mode 100644
index 0000000..b023c3f
--- /dev/null
+++ b/src/routes.ts
@@ -0,0 +1,67 @@
+import { Router, Request, Response } from 'express';
+import { DocumentStore } from './database.js';
+
+export function createRouter(store: DocumentStore): Router {
+  const router = Router();
+
+  // Create a document
+  router.post('/documents', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Title is required and must be a string' });
+      return;
+    }
+    const doc = store.createDocument(title, content ?? '');
+    res.status(201).json(doc);
+  });
+
+  // List documents
+  router.get('/documents', (_req: Request, res: Response) => {
+    const docs = store.listDocuments();
+    res.json(docs);
+  });
+
+  // Get a single document
+  router.get('/documents/:id', (req: Request, res: Response) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document
+  router.put('/documents/:id', (req: Request, res: Response) => {
+    const { title, content } = req.body;
+    const doc = store.updateDocument(req.params.id, { title, content });
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req: Request, res: Response) => {
+    const deleted = store.deleteDocument(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get version history for a document
+  router.get('/documents/:id/versions', (req: Request, res: Response) => {
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = store.getVersions(req.params.id);
+    res.json(versions);
+  });
+
+  return router;
+}
diff --git a/src/server.ts b/src/server.ts
