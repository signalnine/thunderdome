+++ b/src/__tests__/ot.test.ts
@@ -0,0 +1,160 @@
+import { describe, it, expect } from 'vitest';
+import { apply, transform, validate, inputLength, outputLength, Operation } from '../ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply a retain-only operation', () => {
+      expect(apply('hello', [5])).toBe('hello');
+    });
+
+    it('should apply an insert operation', () => {
+      expect(apply('', ['hello'])).toBe('hello');
+    });
+
+    it('should apply a delete operation', () => {
+      expect(apply('hello', [-5])).toBe('');
+    });
+
+    it('should apply a mixed operation (insert at position)', () => {
+      // Insert "world" after "hello "
+      expect(apply('hello ', [6, 'world'])).toBe('hello world');
+    });
+
+    it('should apply an operation that deletes and inserts', () => {
+      // Replace "hello" with "hi"
+      expect(apply('hello', [-5, 'hi'])).toBe('hi');
+    });
+
+    it('should apply retain + insert + retain', () => {
+      expect(apply('helo', [2, 'l', 2])).toBe('hello');
+    });
+
+    it('should throw on length mismatch', () => {
+      expect(() => apply('hello', [3])).toThrow();
+    });
+  });
+
+  describe('validate', () => {
+    it('should accept a valid operation', () => {
+      expect(validate([3, 'abc', 2], 5)).toBeNull();
+    });
+
+    it('should reject wrong input length', () => {
+      expect(validate([3], 5)).not.toBeNull();
+    });
+
+    it('should reject non-array', () => {
+      expect(validate('not an array' as unknown as Operation, 5)).not.toBeNull();
+    });
+
+    it('should reject zero components', () => {
+      expect(validate([0], 0)).not.toBeNull();
+    });
+  });
+
+  describe('transform', () => {
+    it('should handle two inserts at different positions', () => {
+      const doc = 'abc';
+      // User A inserts 'X' at position 1: [1, 'X', 2]
+      // User B inserts 'Y' at position 2: [2, 'Y', 1]
+      const opA: Operation = [1, 'X', 2];
+      const opB: Operation = [2, 'Y', 1];
+
+      const [opAprime, opBprime] = transform(opA, opB);
+
+      // Apply A then B'
+      const resultAB = apply(apply(doc, opA), opBprime);
+      // Apply B then A'
+      const resultBA = apply(apply(doc, opB), opAprime);
+
+      expect(resultAB).toBe(resultBA);
+      // Both inserts should be present
+      expect(resultAB).toContain('X');
+      expect(resultAB).toContain('Y');
+    });
+
+    it('should handle two inserts at the same position', () => {
+      const doc = 'abc';
+      const opA: Operation = [1, 'X', 2];
+      const opB: Operation = [1, 'Y', 2];
+
+      const [opAprime, opBprime] = transform(opA, opB);
+
+      const resultAB = apply(apply(doc, opA), opBprime);
+      const resultBA = apply(apply(doc, opB), opAprime);
+
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toContain('X');
+      expect(resultAB).toContain('Y');
+    });
+
+    it('should handle insert vs delete', () => {
+      const doc = 'abcd';
+      // A inserts 'X' at position 1
+      const opA: Operation = [1, 'X', 3];
+      // B deletes character at position 2
+      const opB: Operation = [2, -1, 1];
+
+      const [opAprime, opBprime] = transform(opA, opB);
+
+      const resultAB = apply(apply(doc, opA), opBprime);
+      const resultBA = apply(apply(doc, opB), opAprime);
+
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toContain('X');
+      expect(resultAB).not.toContain('c'); // deleted char
+    });
+
+    it('should handle both deleting the same character', () => {
+      const doc = 'abc';
+      // Both delete character at position 1 ('b')
+      const opA: Operation = [1, -1, 1];
+      const opB: Operation = [1, -1, 1];
+
+      const [opAprime, opBprime] = transform(opA, opB);
+
+      const resultAB = apply(apply(doc, opA), opBprime);
+      const resultBA = apply(apply(doc, opB), opAprime);
+
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toBe('ac');
+    });
+
+    it('should handle retain-only transforms', () => {
+      const doc = 'hello';
+      const opA: Operation = [5];
+      const opB: Operation = [5];
+
+      const [opAprime, opBprime] = transform(opA, opB);
+
+      const resultAB = apply(apply(doc, opA), opBprime);
+      const resultBA = apply(apply(doc, opB), opAprime);
+
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toBe('hello');
+    });
+
+    it('should handle empty document inserts', () => {
+      const doc = '';
+      const opA: Operation = ['hello'];
+      const opB: Operation = ['world'];
+
+      const [opAprime, opBprime] = transform(opA, opB);
+
+      const resultAB = apply(apply(doc, opA), opBprime);
+      const resultBA = apply(apply(doc, opB), opAprime);
+
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toContain('hello');
+      expect(resultAB).toContain('world');
+    });
+  });
+
+  describe('inputLength / outputLength', () => {
+    it('should compute input and output lengths', () => {
+      const op: Operation = [3, 'abc', -2, 1];
+      expect(inputLength(op)).toBe(6); // 3 retain + 2 delete + 1 retain
+      expect(outputLength(op)).toBe(7); // 3 retain + 3 insert + 1 retain
+    });
+  });
+});
