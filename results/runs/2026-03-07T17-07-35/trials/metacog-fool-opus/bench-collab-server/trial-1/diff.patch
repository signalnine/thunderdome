op1.length ? op1[i1] : null;\n      continue;\n    }\n\n    // If op2 has an insert, it goes first in op2' and we retain over it in op1'\n    if (typeof c2 === 'string') {\n      op2prime.push(c2);\n      op1prime.push(c2.length);\n      i2++;\n      c2 = i2 < op2.length ? op2[i2] : null;\n      continue;\n    }\n\n    if (c1 === null || c2 === null) {\n      throw new Error('Transform mismatch: operations have different base lengths');\n    }\n\n    // Both are numbers. Could be retain or delete.\n    const n1 = c1 as number;\n    const n2 = c2 as number;\n\n    if (n1 > 0 && n2 > 0) {\n      // Both retain\n      const min = Math.min(n1, n2);\n      op1prime.push(min);\n      op2prime.push(min);\n      if (n1 === n2) {\n        i1++; i2++;\n        c1 = i1 < op1.length ? op1[i1] : null;\n        c2 = i2 < op2.length ? op2[i2] : null;\n      } else if (n1 < n2) {\n        i1++;\n        c1 = i1 < op1.length ? op1[i1] : null;\n        c2 = n2 - n1;\n      } else {\n        i2++;\n        c2 = i2 < op2.length ? op2[i2] : null;\n        c1 = n1 - n2;\n      }\n    } else if (n1 < 0 && n2 < 0) {\n      // Both delete\n      const d1 = Math.abs(n1);\n      const d2 = Math.abs(n2);\n      const min = Math.min(d1, d2);\n      // Both are deleting the same characters, so they cancel out\n      if (d1 === d2) {\n        i1++; i2++;\n        c1 = i1 < op1.length ? op1[i1] : null;\n        c2 = i2 < op2.length ? op2[i2] : null;\n      } else if (d1 < d2) {\n        i1++;\n        c1 = i1 < op1.length ? op1[i1] : null;\n        c2 = -(d2 - min);\n      } else {\n        i2++;\n        c2 = i2 < op2.length ? op2[i2] : null;\n        c1 = -(d1 - min);\n      }\n    } else if (n1 < 0 && n2 > 0) {\n      // op1 deletes, op2 retains\n      const d1 = Math.abs(n1);\n      const min = Math.min(d1, n2);\n      op1prime.push(-min);\n      // op2 doesn't get to retain those chars (they were deleted)\n      if (d1 === n2) {\n        i1++; i2++;\n        c1 = i1 < op1.length ? op1[i1] : n