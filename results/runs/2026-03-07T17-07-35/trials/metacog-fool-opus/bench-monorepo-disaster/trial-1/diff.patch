ing;\n    53→    email: string;\n    54→    role: string;\n    55→    created_at: string;\n    56→    updated_at: string;\n    57→  };\n    58→  return {\n    59→    id: row.id,\n    60→    name: row.name,\n    61→    email: row.email,\n    62→    role: row.role as User['role'],\n    63→    createdAt: row.created_at,\n    64→    updatedAt: row.updated_at,\n    65→  };\n    66→}\n    67→\n    68→export function findUserById(\n    69→  conn: DatabaseConnection,\n    70→  id: number\n    71→): User | null {\n    72→  const stmt = conn.db.prepare('SELECT * FROM users WHERE id = ?');\n    73→  const row = stmt.get(id) as {\n    74→    id: number;\n    75→    name: string;\n    76→    email: string;\n    77→    role: string;\n    78→    created_at: string;\n    79→    updated_at: string;\n    80→  } | undefined;\n    81→  if (!row) return null;\n    82→  return {\n    83→    id: row.id,\n    84→    name: row.name,\n    85→    email: row.email,\n    86→    role: row.role as User['role'],\n    87→    createdAt: row.created_at,\n    88→    updatedAt: row.updated_at,\n    89→  };\n    90→}\n    91→\n    92→export function findAllUsers(conn: DatabaseConnection): User[] {\n    93→  const stmt = conn.db.prepare('SELECT * FROM users ORDER BY id');\n    94→  const rows = stmt.all() as Array<{\n    95→    id: number;\n    96→    name: string;\n    97→    email: string;\n    98→    role: string;\n    99→    created_at: string;\n   100→    updated_at: string;\n   101→  }>;\n   102→  return rows.map((row) => ({\n   103→    id: row.id,\n   104→    name: row.name,\n   105→    email: row.email,\n   106→    role: row.role as User['role'],\n   107→    createdAt: row.created_at,\n   108→    updatedAt: row.updated_at,\n   109→  }));\n   110→}\n   111→"}]},"parent_tool_use_id":null,"session_id":"5536ca5c-db16-4125-add3-cc83a2353b3b","uuid":"d36dfa88-e81e-4569-b7ee-18db191b0d19","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/core/src/database.ts","content":"/**\n * Database connection factory and table creation.\n * Uses better-sqlite3 for a simple embedded database.\n */\n\nimport Database from 'better-sqlite3';\nimport type { User } from './types.js';\n\nexport interface DatabaseConnection {\n  db: Database.Database;\n  close: () => void;\n}\n\nexport function createDatabase(path: string = ':memory:'): DatabaseConnection {\n  const db = new Database(path);\n\n  // Enable WAL mode for better concurrent read performance\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  return {\n    db,\n    close: () => db.close(),\n  };\n}\n\nexport function createTables(conn: DatabaseConnection): void {\n  conn.db.exec(`\n    CREATE TABLE IF NOT EXISTS users (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      name TEXT NOT NULL,\n      email TEXT NOT NULL UNIQUE,\n      role TEXT NOT NULL CHECK(role IN ('admin', 'user', 'viewer')),\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n    );\n\n    CREATE INDEX IF NOT EXISTS idx_users_email ON users(email);\n    CREATE INDEX IF NOT EXISTS idx_users_role ON users(role);\n  `);\n}\n\nexport function insertUser(\n  conn: DatabaseConnection,\n  user: { name: string; email: string; role: string }\n): User {\n  const stmt = conn.db.prepare(\n    'INSERT INTO users (name, email, role) VALUES (?, ?, ?) RETURNING *'\n  );\n  const row = stmt.get(user.name, user.email, user.role) as {\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  };\n  return {\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nexport function findUserById(\n  conn: DatabaseConnection,\n  id: number\n): User | null {\n  const stmt = conn.db.prepare('SELECT * FROM users WHERE id = ?');\n  const row = stmt.get(id) as {\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  } | undefined;\n  if (!row) return null;\n  return {\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nexport function findAllUsers(conn: DatabaseConnection): User[] {\n  const stmt = conn.db.prepare('SELECT * FROM users ORDER BY id');\n  const rows = stmt.all() as Array<{\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  }>;\n  return rows.map((row) => ({\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  }));\n}\n","numLines":111,"startLine":1,"totalLines":111}}}
