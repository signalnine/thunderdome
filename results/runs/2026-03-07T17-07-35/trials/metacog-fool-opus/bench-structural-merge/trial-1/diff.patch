+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Document CRUD', () => {
+    it('creates and retrieves a document', () => {
+      store.create('doc1', { name: 'Alice', age: 30 });
+      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 30 });
+    });
+
+    it('throws on duplicate create', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(() => store.create('doc1', { name: 'Bob' })).toThrow();
+    });
+
+    it('throws on get of nonexistent document', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('updates a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.update('doc1', { name: 'Bob' });
+      expect(store.get('doc1')).toEqual({ name: 'Bob' });
+    });
+
+    it('throws on update of nonexistent document', () => {
+      expect(() => store.update('nonexistent', { name: 'Bob' })).toThrow();
+    });
+
+    it('deletes a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('throws on delete of nonexistent document', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('throws on delete of already deleted document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+
+    it('throws on update of deleted document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.update('doc1', { name: 'Bob' })).toThrow();
+    });
+
+    it('deep clones on create - external mutation does not affect store', () => {
+      const content = { name: 'Alice', nested: { x: 1 } };
+      store.create('doc1', content);
+      content.name = 'Bob';
+      content.nested.x = 999;
+      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });
+    });
+
+    it('deep clones on get - mutation of returned value does not affect store', () => {
+      store.create('doc1', { name: 'Alice', nested: { x: 1 } });
+      const retrieved = store.get('doc1') as Record<string, unknown>;
+      retrieved.name = 'Bob';
+      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });
+    });
+  });
+
+  describe('Version History', () => {
+    it('creates a version on create', () => {
+      store.create('doc1', { name: 'Alice' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ name: 'Alice' });
+      expect(history[0].id).toBeDefined();
+      expect(history[0].timestamp).toBeDefined();
+    });
+
+    it('creates versions on updates', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.update('doc1', { name: 'Bob' });
+      store.update('doc1', { name: 'Charlie' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ name: 'Alice' });
+      expect(history[1].content).toEqual({ name: 'Bob' });
+      expect(history[2].content).toEqual({ name: 'Charlie' });
+    });
+
+    it('returns versions in chronological order', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+      const history = store.getHistory('doc1');
+      for (let i = 1; i < history.length; i++) {
+        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);
+      }
+    });
+
+    it('retrieves specific version by id', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.update('doc1', { name: 'Bob' });
+      const history = store.getHistory('doc1');
+      const v1 = store.getVersion('doc1', history[0].id);
+      const v2 = store.getVersion('doc1', history[1].id);
+      expect(v1).toEqual({ name: 'Alice' });
+      expect(v2).toEqual({ name: 'Bob' });
+    });
+
+    it('throws on getVersion with invalid version id', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();
+    });
+
+    it('throws on getHistory for nonexistent document', () => {
+      expect(() => store.getHistory('nonexistent')).toThrow();
+    });
+
+    it('deep clones version content', () => {
+      store.create('doc1', { nested: { x: 1 } });
+      const history = store.getHistory('doc1');
+      (history[0].content as Record<string, unknown>).nested = 'mutated';
+      const historyAgain = store.getHistory('doc1');
+      expect(historyAgain[0].content).toEqual({ nested: { x: 1 } });
+    });
+  });
+
+  describe('Branching', () => {
+    it('starts on main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('lists branches', () => {
+      expect(store.listBranches()).toEqual(['main']);
+    });
+
+    it('creates and switches branches', () => {
+      store.createBranch('feature');
+      expect(store.listBranches()).toContain('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('throws on duplicate branch name', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('throws on switch to nonexistent branch', () => {
+      expect(() => store.switchBranch('nonexistent')).toThrow();
+    });
+
+    it('branches inherit documents from parent', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('changes on one branch do not affect another', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.createBranch('feature');
+
+      // Change on feature
+      store.switchBranch('feature');
+      store.update('doc1', { name: 'Bob' });
+      expect(store.get('doc1')).toEqual({ name: 'Bob' });
+
+      // Main still has original
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('creates branch from specific branch', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { name: 'Bob' });
+
+      // Create a branch from feature while on feature
+      store.createBranch('feature2', 'feature');
+      store.switchBranch('feature2');
+      expect(store.get('doc1')).toEqual({ name: 'Bob' });
+    });
+
+    it('new doc on branch not visible on main', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { name: 'Alice' });
+
+      store.switchBranch('main');
+      expect(() => store.get('doc1')).toThrow();
+    });
+  });
+
+  describe('Merging', () => {
+    it('merges non-conflicting changes from source into current', () => {
