--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,445 @@
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+type JsonValue = any;
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: JsonValue;
+  ours: JsonValue;
+  theirs: JsonValue;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentData {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, DocumentData>;
+  forkSnapshot: Map<string, object | null>;
+  parentBranch: string | null;
+}
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function generateId(): string {
+  return Math.random().toString(36).substring(2) + Date.now().toString(36);
+}
+
+/**
+ * Recursively collect all keys from up to three objects.
+ */
+function allKeys(...objs: (JsonValue | undefined)[]): Set<string> {
+  const keys = new Set<string>();
+  for (const obj of objs) {
+    if (obj !== null && obj !== undefined && typeof obj === 'object' && !Array.isArray(obj)) {
+      for (const k of Object.keys(obj)) {
+        keys.add(k);
+      }
+    }
+  }
+  return keys;
+}
+
+/**
+ * Three-way structural merge of two objects against a common base.
+ * Returns the merged result and any conflicts found.
+ */
+function threeWayMerge(
+  base: JsonValue,
+  ours: JsonValue,
+  theirs: JsonValue,
+  path: string,
+  documentId: string,
+  conflicts: Conflict[]
+): JsonValue {
+  // If both sides are identical, no conflict
+  if (JSON.stringify(ours) === JSON.stringify(theirs)) {
+    return deepClone(ours);
+  }
+
+  // If only one side changed from base
+  const oursChanged = JSON.stringify(base) !== JSON.stringify(ours);
+  const theirsChanged = JSON.stringify(base) !== JSON.stringify(theirs);
+
+  if (!oursChanged && !theirsChanged) {
+    return deepClone(base);
+  }
+  if (!oursChanged && theirsChanged) {
+    return deepClone(theirs);
+  }
+  if (oursChanged && !theirsChanged) {
+    return deepClone(ours);
+  }
+
+  // Both sides changed. If both are objects (not arrays), recurse.
+  if (
+    ours !== null && theirs !== null && base !== null &&
+    typeof ours === 'object' && typeof theirs === 'object' && typeof base === 'object' &&
+    !Array.isArray(ours) && !Array.isArray(theirs) && !Array.isArray(base)
+  ) {
+    const result: Record<string, JsonValue> = {};
+    const keys = allKeys(base, ours, theirs);
+    for (const key of keys) {
+      const childPath = path ? `${path}.${key}` : key;
+      result[key] = threeWayMerge(
+        base[key] !== undefined ? base[key] : undefined,
+        ours[key] !== undefined ? ours[key] : undefined,
+        theirs[key] !== undefined ? theirs[key] : undefined,
+        childPath,
+        documentId,
+        conflicts
+      );
+    }
+    return result;
+  }
+
+  // Both changed to different non-object values (or mixed types) — conflict
+  conflicts.push({
+    documentId,
+    path: path,
+    base: base !== undefined ? deepClone(base) : undefined,
+    ours: ours !== undefined ? deepClone(ours) : undefined,
+    theirs: theirs !== undefined ? deepClone(theirs) : undefined,
+  });
+
+  // Resolve in favor of "ours" for the merged preview
+  return ours !== undefined ? deepClone(ours) : undefined;
+}
+
+function cloneDocumentData(doc: DocumentData): DocumentData {
+  return {
+    content: deepClone(doc.content),
+    versions: doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: doc.deleted,
+  };
+}
+
+function cloneBranchDocuments(docs: Map<string, DocumentData>): Map<string, DocumentData> {
+  const cloned = new Map<string, DocumentData>();
+  for (const [id, doc] of docs) {
+    cloned.set(id, cloneDocumentData(doc));
+  }
+  return cloned;
+}
+
+function snapshotDocuments(docs: Map<string, DocumentData>): Map<string, object | null> {
+  const snapshot = new Map<string, object | null>();
+  for (const [id, doc] of docs) {
+    snapshot.set(id, doc.deleted ? null : deepClone(doc.content));
+  }
+  return snapshot;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      forkSnapshot: new Map(),
+      parentBranch: null,
+    });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branchName = name ?? this.currentBranch;
+    const branch = this.branches.get(branchName);
+    if (!branch) {
+      throw new Error(`Branch "${branchName}" does not exist`);
+    }
+    return branch;
+  }
+
+  // ---- Document CRUD ----
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  // ---- Version History ----
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ---- Branching ----
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.getBranchData(sourceName);
+
+    this.branches.set(name, {
+      documents: cloneBranchDocuments(source.documents),
+      forkSnapshot: snapshotDocuments(source.documents),
+      parentBranch: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ---- Merging ----
+
+  merge(sourceBranch: string): MergeResult {
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    const target = this.getBranchData(); // current branch ("ours")
+    const source = this.getBranchData(sourceBranch); // source branch ("theirs")
+
+    // The common ancestor is the fork snapshot of the source branch
+    // (what the parent branch looked like when the source was created)
+    const baseSnapshot = source.forkSnapshot;
+
+    // Collect all document IDs across base, ours, theirs
+    const allDocIds = new Set<string>();
+    for (const id of baseSnapshot.keys()) allDocIds.add(id);
+    for (const [id, doc] of target.documents) {
+      if (!doc.deleted) allDocIds.add(id);
+    }
+    for (const [id, doc] of source.documents) {
+      if (!doc.deleted) allDocIds.add(id);
+    }
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseContent = baseSnapshot.has(docId) ? (baseSnapshot.get(docId) ?? undefined) : undefined;
+      const oursDoc = target.documents.get(docId);
+      const oursContent = (oursDoc && !oursDoc.deleted) ? oursDoc.content : undefined;
+      const theirsDoc = source.documents.get(docId);
+      const theirsContent = (theirsDoc && !theirsDoc.deleted) ? theirsDoc.content : undefined;
+
+      // Skip if nothing exists anywhere
+      if (baseContent === undefined && oursContent === undefined && theirsContent === undefined) {
+        continue;
+      }
+
+      // If both sides have the same content (or both undefined/deleted), nothing to do
+      if (JSON.stringify(oursContent) === JSON.stringify(theirsContent)) {
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      // Only one side changed from base
+      const oursChanged = JSON.stringify(baseContent) !== JSON.stringify(oursContent);
+      const theirsChanged = JSON.stringify(baseContent) !== JSON.stringify(theirsContent);
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes
+        if (baseContent !== undefined) {
+          merged[docId] = deepClone(baseContent);
+        }
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        // Only theirs changed — take theirs
+        if (theirsContent !== undefined) {
+          merged[docId] = deepClone(theirsContent);
+        }
+        // If theirs is undefined (deleted), don't include in merged
+        continue;
+      }
+
+      if (oursChanged && !theirsChanged) {
+        // Only ours changed — keep ours
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      // Both changed. If one deleted and other modified, or both exist, need to handle.
+      if (oursContent === undefined || theirsContent === undefined) {
+        // One side deleted, other modified — conflict at document level
+        // We treat the whole document as a conflict
+        const base = baseContent !== undefined ? deepClone(baseContent) : undefined;
+        const ours = oursContent !== undefined ? deepClone(oursContent) : undefined;
+        const theirs = theirsContent !== undefined ? deepClone(theirsContent) : undefined;
+        conflicts.push({
+          documentId: docId,
+          path: '',
+          base,
+          ours,
+          theirs,
+        });
+        // For merged preview, use ours
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      // Both sides exist and both changed — three-way merge at field level
+      const baseObj = baseContent !== undefined ? baseContent : {};
+      const mergedContent = threeWayMerge(baseObj, oursContent, theirsContent, '', docId, conflicts);
+      merged[docId] = mergedContent;
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      // First, handle documents that were in source but not target (new docs from source)
+      for (const [docId, content] of Object.entries(merged)) {
+        const existingDoc = target.documents.get(docId);
+        if (existingDoc && !existingDoc.deleted) {
+          // Update if content actually changed
+          if (JSON.stringify(existingDoc.content) !== JSON.stringify(content)) {
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(content),
+            };
+            existingDoc.content = deepClone(content);
+            existingDoc.versions.push(version);
+          }
+        } else {
+          // New document on this branch (came from source)
+          const version: Version = {
+            id: generateId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          target.documents.set(docId, {
+            content: deepClone(content),
+            versions: [version],
+            deleted: false,
+          });
+        }
+      }
+
+      // Handle documents that were deleted on source branch
+      for (const docId of allDocIds) {
+        if (!(docId in merged)) {
+          // Document should be deleted in merged result
+          const targetDoc = target.documents.get(docId);
+          if (targetDoc && !targetDoc.deleted) {
+            targetDoc.deleted = true;
+          }
+        }
+      }
+    }
+
+    return {
+      merged,
+      conflicts,
+      applied,
+    };
+  }
+}
