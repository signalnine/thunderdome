sync () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await payment.processPayment(orderId, 50);\n    await new Promise(resolve => setTimeout(resolve, 20));\n    expect(analytics.getRevenue()).toBe(50);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await payment.processPayment(orderId, 50);\n    await new Promise(resolve => setTimeout(resolve, 20));\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cartId1 = cart.createCart('user1');\n    cart.addItem(cartId1, 'p1', 1);\n    const cartId2 = cart.createCart('user2');\n    cart.addItem(cartId2, 'p2', 1);\n\n    orders.createOrder('user1', cartId1, 100);\n\n    await new Promise(resolve => setTimeout(resolve, 20));\n    // 1 order / 2 unique carts = 0.5\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products by order quantity', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cartId1 = cart.createCart('user1');\n    cart.addItem(cartId1, 'p1', 5);\n    cart.addItem(cartId1, 'p2', 2);\n\n    const cartId2 = cart.createCart('user2');\n    cart.addItem(cartId2, 'p1', 3);\n\n    orders.createOrder('user1', cartId1, 100);\n    orders.createOrder('user2', cartId2, 50);\n\n    await new Promise(resolve => setTimeout(resolve, 20));\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(8);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('should process end-to-end purchase flow', async () => {\n    const bus = new EventBus();\n\n    // Initialize all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // 1. Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // 2. Set inventory\n    inventory.setStock(productId, 50);\n    inventory.setLowStockThreshold(productId, 5);\n\n    // 3. Subscribe user for notifications\n    notifications.subscribe('alice');\n\n    // 4. Create a cart and add items\n    const cartId = cartService.createCart('alice');\n    cartService.addItem(cartId, productId, 2);\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // 5. Calculate pricing\n    const price = pricing.getPrice(productId);\n    expect(price).toBe(999.99);\n\n    const cartData = cartService.getCart(cartId)!;\n    const items = cartData.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1999.98);\n    expect(totals.tax).toB