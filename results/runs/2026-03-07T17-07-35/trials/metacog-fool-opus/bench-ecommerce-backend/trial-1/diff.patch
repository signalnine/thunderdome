oad: unknown) => {\n    41→    trackEvent(Events.PAYMENT_PROCESSED);\n    42→    const event = payload as PaymentProcessedEvent;\n    43→    if (event.status === PaymentStatus.SUCCESS) {\n    44→      // Get the amount from the order — we track it from ORDER_CREATED events\n    45→      const orderData = orderTotals.get(event.orderId);\n    46→      if (orderData !== undefined) {\n    47→        totalRevenue += orderData;\n    48→      }\n    49→    }\n    50→  });\n    51→  bus.on(Events.NOTIFICATION_SENT, () => { trackEvent(Events.NOTIFICATION_SENT); });\n    52→  bus.on(Events.ANALYTICS_EVENT, () => { trackEvent(Events.ANALYTICS_EVENT); });\n    53→\n    54→  // Track order totals for revenue calculation\n    55→  const orderTotals = new Map<string, number>();\n    56→  // Track cart contents for product ranking\n    57→  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();\n    58→  const orderCarts = new Map<string, string>();\n    59→\n    60→  // Override ORDER_CREATED to also track totals and cart association\n    61→  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    62→    const event = payload as OrderCreatedEvent;\n    63→    orderTotals.set(event.orderId, event.total);\n    64→    orderCarts.set(event.orderId, event.cartId);\n    65→\n    66→    // Use the latest cart snapshot for product counts\n    67→    const items = cartItems.get(event.cartId);\n    68→    if (items) {\n    69→      for (const item of items) {\n    70→        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n    71→      }\n    72→    }\n    73→  });\n    74→\n    75→  // Track cart contents\n    76→  bus.on(Events.CART_UPDATED, (payload: unknown) => {\n    77→    const event = payload as { cartId: string; items: Array<{ productId: string; quantity: number }> };\n    78→    cartItems.set(event.cartId, event.items);\n    79→  });\n    80→\n    81→  return {\n    82→    getEventCount(eventType: string