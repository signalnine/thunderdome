tatus === PaymentStatus.SUCCESS) {\n      // Get the amount from the order — we track it from ORDER_CREATED events\n      const orderData = orderTotals.get(event.orderId);\n      if (orderData !== undefined) {\n        totalRevenue += orderData;\n      }\n    }\n  });\n  bus.on(Events.NOTIFICATION_SENT, () => { trackEvent(Events.NOTIFICATION_SENT); });\n  bus.on(Events.ANALYTICS_EVENT, () => { trackEvent(Events.ANALYTICS_EVENT); });\n\n  // Track order totals for revenue calculation\n  const orderTotals = new Map<string, number>();\n  // Track cart contents for product ranking\n  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();\n  const orderCarts = new Map<string, string>();\n\n  // Override ORDER_CREATED to also track totals and cart association\n  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    const event = payload as OrderCreatedEvent;\n    orderTotals.set(event.orderId, event.total);\n    orderCarts.set(event.orderId, event.cartId);\n\n    // Use the latest cart snapshot for product counts\n    const items = cartItems.get(event.cartId);\n    if (items) {\n      for (const item of items) {\n        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n      }\n    }\n  });\n\n  // Track cart contents\n  bus.on(Events.CART_UPDATED, (payload: unknown) => {\n    const event = payload as { cartId: string; items: Array<{ productId: string; quantity: number }> };\n    cartItems.set(event.cartId, event.items);\n  });\n\n  return {\n    getEventCount(eventType: string): number {\n      return eventCounts.get(eventType) ?? 0;\n    },\n\n    getRevenue(): number {\n      return totalRevenue;\n    },\n\n    getConversionRate(): number {\n      if (uniqueCarts.size === 0) return 0;\n      return orderCount / uniqueCarts.size;\n    },\n\n    getTopProducts(limit: number) {\n      return Array.from(productCounts.entries())\n        .map(([productId, count]) => ({ productId, count }))\n     