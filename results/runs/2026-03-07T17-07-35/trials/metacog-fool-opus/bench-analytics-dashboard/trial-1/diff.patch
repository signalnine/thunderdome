@@ -0,0 +1,172 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { authenticate, AuthRequest } from "../middleware.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function escapeCSVField(field: string): string {
+  if (field.includes(",") || field.includes('"') || field.includes("\n")) {
+    return `"${field.replace(/"/g, '""')}"`;
+  }
+  return field;
+}
+
+function eventsToCSV(events: EventRow[]): string {
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) =>
+    [
+      escapeCSVField(e.id),
+      escapeCSVField(e.tenant_id),
+      escapeCSVField(e.name),
+      escapeCSVField(e.properties),
+      escapeCSVField(e.timestamp),
+      escapeCSVField(e.user_id || ""),
+      escapeCSVField(e.session_id || ""),
+    ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCSV(dashboards: DashboardRow[]): string {
+  const header = "id,tenant_id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map((d) =>
+    [
+      escapeCSVField(d.id),
+      escapeCSVField(d.tenant_id),
+      escapeCSVField(d.name),
+      escapeCSVField(d.owner_id),
+      escapeCSVField(d.config),
+      escapeCSVField(d.created_at),
+      escapeCSVField(d.updated_at),
+    ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authenticate, (req: AuthRequest, res: Response): void => {
+    const name = req.query.name as string | undefined;
+    const startDate = req.query.startDate as string | undefined;
+    const endDate = req.query.endDate as string | undefined;
+
+    let query = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+
+    const mapped = events.map((e) => ({
+      id: e.id,
+      tenantId: e.tenant_id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json({ events: mapped });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authenticate, (req: AuthRequest, res: Response): void => {
+    const name = req.query.name as string | undefined;
+    const startDate = req.query.startDate as string | undefined;
+    const endDate = req.query.endDate as string | undefined;
+
+    let query = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [req.user!.tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCSV(events));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authenticate, (req: AuthRequest, res: Response): void => {
+    const dashboards = db.prepare(
+      "SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+    ).all(req.user!.tenantId) as DashboardRow[];
+
+    const mapped = dashboards.map((d) => ({
+      id: d.id,
+      tenantId: d.tenant_id,
+      name: d.name,
+      ownerId: d.owner_id,
+      config: JSON.parse(d.config),
+      createdAt: d.created_at,
+      updatedAt: d.updated_at,
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.json");
+    res.json({ dashboards: mapped });
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authenticate, (req: AuthRequest, res: Response): void => {
+    const dashboards = db.prepare(
+      "SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+    ).all(req.user!.tenantId) as DashboardRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(dashboardsToCSV(dashboards));
+  });
+
+  return router;
+}
