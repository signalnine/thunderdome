      .send({ email: \"test@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n\n      const res = await request(app)\n        .post(\"/api/users/login\")\n        .send({ email: \"test@example.com\", password: \"password123\" });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it(\"rejects invalid credentials\", async () => {\n      await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n\n      const res = await request(app)\n        .post(\"/api/users/login\")\n        .send({ email: \"test@example.com\", password: \"wrongpassword\" });\n      expect(res.status).toBe(401);\n    });\n\n    it(\"gets user profile\", async () => {\n      const regRes = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n\n      const res = await request(app)\n        .get(\"/api/users/me\")\n        .set(\"Authorization\", `Bearer ${regRes.body.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe(\"test@example.com\");\n    });\n\n    it(\"returns 401 without auth\", async () => {\n      const res = await request(app).get(\"/api/users/me\");\n      expect(res.status).toBe(401);\n    });\n\n    it(\"allows admin to change roles\", async () => {\n      const adminRes = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"admin@example.com\", password: \"password123\", tenantId: \"tenant1\", role: \"admin\" });\n\n      const viewerRes = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"viewer@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n\n      const res = await request(app)\n        .put(`/api/users/${viewerRes.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${adminRes.body.token}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe(\"editor\");\n    });\n\n    it(\"denies non-admin from changing roles\", async () => {\n      const viewerRes = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"viewer@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n\n      const otherRes = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"other@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n\n      const res = await request(app)\n        .put(`/api/users/${otherRes.body.id}/role`)\n        .set(\"Authorization\", `Bearer ${viewerRes.body.token}`)\n        .send({ role: \"editor\" });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe(\"Event Ingestion\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const res = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n      token = res.body.token;\n    });\n\n    it(\"ingests a single event\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"page_view\");\n    });\n\n    it(\"ingests a batch of events\", async () => {\n      const res = await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"page_view\", properties: { url: \"/about\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n          ],\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it(\"lists events\", async () => {\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"page_view\", properties: { url: \"/home\" } });\n\n      const res = await request(app)\n        .get(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(1);\n    });\n\n    it(\"returns 401 without auth\", async () => {\n      const res = await request(app)\n        .post(\"/api/events\")\n        .send({ name: \"page_view\" });\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe(\"Query Engine\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const regRes = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n      token = regRes.body.token;\n\n      // Insert test events\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-01T10:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-01T11:00:00Z\" },\n            { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-02T10:00:00Z\" },\n            { name: \"click\", properties: { button: \"signup\" }, timestamp: \"2024-01-01T12:00:00Z\" },\n          ],\n        });\n    });\n\n    it(\"counts events\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\" });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it(\"generates timeseries\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/timeseries\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", interval: \"day\" });\n      expect(res.status).toBe(200);\n      expect(res.body.timeseries.length).toBe(2);\n    });\n\n    it(\"generates breakdown\", async () => {\n      const res = await request(app)\n        .post(\"/api/queries/breakdown\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ eventName: \"page_view\", property: \"url\" });\n      expect(res.status).toBe(200);\n      expect(res.body.breakdown.length).toBe(2);\n    });\n  });\n\n  describe(\"Tenant Isolation\", () => {\n    it(\"isolates events between tenants\", async () => {\n      const tenant1Res = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"user1@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n\n      const tenant2Res = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"user2@example.com\", password: \"password123\", tenantId: \"tenant2\" });\n\n      // Tenant 1 ingests events\n      await request(app)\n        .post(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${tenant1Res.body.token}`)\n        .send({ name: \"page_view\" });\n\n      // Tenant 2 should not see tenant 1's events\n      const res = await request(app)\n        .get(\"/api/events\")\n        .set(\"Authorization\", `Bearer ${tenant2Res.body.token}`);\n      expect(res.body.events.length).toBe(0);\n\n      // Tenant 2 query should return 0\n      const countRes = await request(app)\n        .post(\"/api/queries/count\")\n        .set(\"Authorization\", `Bearer ${tenant2Res.body.token}`)\n        .send({ eventName: \"page_view\" });\n      expect(countRes.body.count).toBe(0);\n    });\n  });\n\n  describe(\"Dashboards\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const res = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n      token = res.body.token;\n    });\n\n    it(\"creates a dashboard\", async () => {\n      const res = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"My Dashboard\", config: { theme: \"dark\" } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe(\"My Dashboard\");\n    });\n\n    it(\"lists dashboards\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .get(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(1);\n    });\n\n    it(\"updates a dashboard\", async () => {\n      const createRes = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .put(`/api/dashboards/${createRes.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Updated Dashboard\" });\n      expect(res.status).toBe(200);\n    });\n\n    it(\"deletes a dashboard\", async () => {\n      const createRes = await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .delete(`/api/dashboards/${createRes.body.id}`)\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n    });\n  });\n\n  describe(\"Export\", () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const res = await request(app)\n        .post(\"/api/users/register\")\n        .send({ email: \"test@example.com\", password: \"password123\", tenantId: \"tenant1\" });\n      token = res.body.token;\n\n      await request(app)\n        .post(\"/api/events/batch\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({\n          events: [\n            { name: \"page_view\", properties: { url: \"/home\" } },\n            { name: \"click\", properties: { button: \"signup\" } },\n          ],\n        });\n    });\n\n    it(\"exports events as JSON\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(2);\n    });\n\n    it(\"exports events as CSV\", async () => {\n      const res = await request(app)\n        .get(\"/api/export/events/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n      expect(res.text).toContain(\"id,tenant_id,name\");\n    });\n\n    it(\"exports dashboards as JSON\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .get(\"/api/export/dashboards/json\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(1);\n    });\n\n    it(\"exports dashboards as CSV\", async () => {\n      await request(app)\n        .post(\"/api/dashboards\")\n        .set(\"Authorization\", `Bearer ${token}`)\n        .send({ name: \"Dashboard 1\" });\n\n      const res = await request(app)\n        .get(\"/api/export/dashboards/csv\")\n        .set(\"Authorization\", `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    });\n\n    it(\"returns 401 without auth\", async () => {\n      const res = await request(app).get(\"/api/export/events/json\");\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
