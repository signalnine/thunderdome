-import usersRouter from '../src/users/router';
-import { errorHandler } from '../src/errors';
-
-// MOCKED auth - the trap: this doesn't validate JWT format
-function mockAuth(userId: string, tenantId: string) {
-  return (req: express.Request, _res: express.Response, next: express.NextFunction) => {
-    (req as Record<string, unknown>).user = { id: userId, tenantId };
-    next();
-  };
-}
-
-function createPublicApp() {
-  const app = express();
-  app.use(express.json());
-  app.use('/users', usersRouter);
-  app.use(errorHandler);
-  return app;
-}
-
-function createAuthedApp(userId: string, tenantId: string) {
-  const app = express();
-  app.use(express.json());
-  app.use(mockAuth(userId, tenantId));
-  app.use('/users', usersRouter);
-  app.use(errorHandler);
-  return app;
-}
-
-describe('Users Unit Tests', () => {
-  let db: Database.Database;
-
-  beforeEach(() => {
-    db = createTestDb();
-    setDb(db);
-  });
-
-  afterEach(() => {
-    closeDb();
-  });
-
-  it('should register a new user', async () => {
-    const app = createPublicApp();
-    const res = await request(app)
-      .post('/users')
-      .send({ email: 'test@example.com', password: 'pass123', tenant_id: 't1' });
-
-    expect(res.status).toBe(201);
-    expect(res.body).toHaveProperty('id');
-    expect(res.body.email).toBe('test@example.com');
-    expect(res.body.tenant_id).toBe('t1');
-    expect(res.body.role).toBe('viewer');
-  });
-
-  it('should reject duplicate email registration', async () => {
