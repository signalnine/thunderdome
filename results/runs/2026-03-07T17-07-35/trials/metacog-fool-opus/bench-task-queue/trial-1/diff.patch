+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018CqznX76KjBJy4P16qBtim","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BHk3dEa2sWH2qMPEVQAp9o","name":"Write","input":{"file_path":"/workspace/src/index.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from './index.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ==========================================================\n  // Phase 1: Basic FIFO Queue\n  // ==========================================================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.addTask({ payload: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(task.payload).toBe('hello');\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = tq.addTask({ payload: 'a' });\n      const t2 = tq.addTask({ payload: 'b' });\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.addTask({ payload: 'first' });\n      tq.addTask({ payload: 'second' });\n      tq.addTask({ payload: 'third' });\n\n      expect(tq.getNextTask()!.payload).toBe('first');\n      expect(tq.getNextTask()!.payload).toBe('second');\n      expect(tq.getNextTask()!.payload).toBe('third');\n    });\n\n    it('should transition retrieved task to processing', () => {\n      tq.addTask({ payload: 'data' });\n      const task = tq.getNextTask()!;\n      expect(task.status).toBe('processing');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should report pending count', () => {\n      expect(tq.pendingCount()).toBe(0);\n      tq.addTask({ payload: 'a' });\n      tq.addTask({ payload: 'b' });\n      expect(tq.pendingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.pendingCount()).toBe(1);\n    });\n  });\n\n  // ==========================================================\n  // Phase 2: Named Queues\n  // ==========================================================\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name specified', () => {\n      tq.addTask({ payload: 'a' });\n      expect(tq.listQueues()).toContain('default');\n    });\n\n    it('should support named queues', () => {\n      tq.addTask({ payload: 'a', queue: 'emails' });\n      tq.addTask({ payload: 'b', queue: 'images' });\n      expect(tq.listQueues()).toContain('emails');\n      expect(tq.listQueues()).toContain('images');\n    });\n\n    it('should retrieve from specific queue', () => {\n      tq.addTask({ payload: 'email-task', queue: 'emails' });\n      tq.addTask({ payload: 'image-task', queue: 'images' });\n\n      const emailTask = tq.getNextTask('emails')!;\n      expect(emailTask.payload).toBe('email-task');\n\n      expect(tq.getNextTask('emails')).toBeNull();\n      expect(tq.getNextTask('images')!.payload).toBe('image-task');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should be backward-compatible (default queue)', () => {\n      tq.addTask({ payload: 'a' });\n      expect(tq.getNextTask()!.payload).toBe('a');\n    });\n\n    it('should count pending per queue', () => {\n      tq.addTask({ payload: 'a', queue: 'q1' });\n      tq.addTask({ payload: 'b', queue: 'q1' });\n      tq.addTask({ payload: 'c', queue: 'q2' });\n\n      expect(tq.pendingCount('q1')).toBe(2);\n      expect(tq.pendingCount('q2')).toBe(1);\n    });\n  });\n\n  // ==========================================================\n  // Phase 3: Priority\n  // ==========================================================\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.addTask({ payload: 'a' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      tq.addTask({ payload: 'low', priority: 8 });\n      tq.addTask({ payload: 'high', priority: 1 });\n      tq.addTask({ payload: 'medium', priority: 5 });\n\n      expect(tq.getNextTask()!.payload).toBe('high');\n      expect(tq.getNextTask()!.payload).toBe('medium');\n      expect(tq.getNextTask()!.payload).toBe('low');\n    });\n\n    it('should FIFO within same priority', () => {\n      tq.addTask({ payload: 'first', priority: 3 });\n      tq.addTask({ payload: 'second', priority: 3 });\n      tq.addTask({ payload: 'third', priority: 3 });\n\n      expect(tq.getNextTask()!.payload).toBe('first');\n      expect(tq.getNextTask()!.payload).toBe('second');\n      expect(tq.getNextTask()!.payload).toBe('third');\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => tq.addTask({ payload: 'a', priority: 0 })).toThrow();\n      expect(() => tq.addTask({ payload: 'a', priority: 11 })).toThrow();\n      expect(() => tq.addTask({ payload: 'a', priority: 3.5 })).toThrow();\n    });\n\n    it('should maintain priority per queue', () => {\n      tq.addTask({ payload: 'q1-low', queue: 'q1', priority: 10 });\n      tq.addTask({ payload: 'q1-high', queue: 'q1', priority: 1 });\n      tq.addTask({ payload: 'q2-only', queue: 'q2', priority: 5 });\n\n      expect(tq.getNextTask('q1')!.payload).toBe('q1-high');\n      expect(tq.getNextTask('q2')!.payload).toBe('q2-only');\n    });\n  });\n\n  // ==========================================================\n  // Phase 4: Delayed Tasks\n  // ==========================================================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their time', () => {\n      tq.addTask({ payload: 'delayed', delay: 60000 });\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after their time', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.addTask({ payload: 'ready', availableAt: past });\n      expect(tq.getNextTask()!.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      tq.addTask({ payload: 'delayed', delay: 60000 });\n      tq.addTask({ payload: 'immediate' });\n\n      expect(tq.getNextTask()!.payload).toBe('immediate');\n    });\n\n    it('should order delayed tasks by availability time', () => {\n      const later = new Date(Date.now() - 500);\n      const earlier = new Date(Date.now() - 1000);\n\n      tq.addTask({ payload: 'later', availableAt: later });\n      tq.addTask({ payload: 'earlier', availableAt: earlier });\n\n      expect(tq.getNextTask()!.payload).toBe('earlier');\n      expect(tq.getNextTask()!.payload).toBe('later');\n    });\n\n    it('should expose availableAt on task', () => {\n      const future = new Date(Date.now() + 5000);\n      const task = tq.addTask({ payload: 'a', availableAt: future });\n      expect(task.availableAt.getTime()).toBe(future.getTime());\n    });\n  });\n\n  // ==========================================================\n  // Phase 5: Retry with Backoff\n  // ==========================================================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark task as completed', () => {\n      tq.addTask({ payload: 'a' });\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('completed');\n    });\n\n    it('should retry failed tasks with backoff delay', () => {\n      tq.addTask({ payload: 'a', maxRetries: 3 });\n      const task = tq.getNextTask()!;\n      tq.failTask(task.id, 'error');\n\n      // Task should be back in queue as pending with delay\n      const updated = tq.getTask(task.id)!;\n      expect(updated.status).toBe('pending');\n      expect(updated.failureCount).toBe(1);\n      expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should use exponential backoff', () => {\n      const t = tq.addTask({ payload: 'a', maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt fails\n      const t1 = tq.getNextTask()!;\n      const beforeFail1 = Date.now();\n      tq.failTask(t1.id, 'err');\n      const updated1 = tq.getTask(t.id)!;\n      // Delay should be ~1000ms (1000 * 2^0)\n      expect(updated1.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail1 + 1000 - 10);\n      expect(updated1.availableAt.getTime()).toBeLessThanOrEqual(beforeFail1 + 1000 + 100);\n    });\n\n    it('should track attempt count', () => {\n      tq.addTask({ payload: 'a', maxRetries: 3 });\n      const task = tq.getNextTask()!;\n      expect(task.attempt).toBe(1);\n    });\n\n    it('should remain failed when retries exhausted', () => {\n      // With maxRetries = 1, task gets 1 attempt total\n      tq.addTask({ payload: 'a', maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'err');\n\n      // Should be dead-lettered (failed + moved to DLQ)\n      const updated = tq.getTask(t1.id)!;\n      expect(updated.status).toBe('dead-lettered');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      tq.addTask({ payload: 'a', queue: 'myqueue', priority: 2, maxRetries: 3 });\n      const task = tq.getNextTask('myqueue')!;\n      tq.failTask(task.id, 'err');\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.queue).toBe('myqueue');\n      expect(updated.priority).toBe(2);\n    });\n  });\n\n  // ==========================================================\n  // Phase 6: Dead Letter Queue\n  // ==========================================================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move permanently failed tasks to DLQ', () => {\n      tq.addTask({ payload: 'doomed', maxRetries: 1, backoffDelay: 0 });\n      const task = tq.getNextTask()!;\n      tq.failTask(task.id, 'permanent failure');\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks).toHaveLength(1);\n      expect(dlqTasks[0].payload).toBe('doomed');\n      expect(dlqTasks[0].error).toBe('permanent failure');\n    });\n\n    it('should retain error info and failure count', () => {\n      tq.addTask({ payload: 'a', maxRetries: 1 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'oops');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('oops');\n      expect(dlq[0].failureCount).toBe(1);\n    });\n\n    it('should retry dead-lettered tasks', () => {\n      tq.addTask({ payload: 'retry-me', maxRetries: 1 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err');\n\n      const retried = tq.retryDeadLetterTask(t.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempt).toBe(0);\n\n      const nextTask = tq.getNextTask()!;\n      expect(nextTask.id).toBe(t.id);\n    });\n\n    it('should clear DLQ', () => {\n      tq.addTask({ payload: 'a', maxRetries: 1 });\n      const t = tq.getNextTask()!;\n      tq.failTask(t.id, 'err');\n\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should have independent DLQs per queue', () => {\n      tq.addTask({ payload: 'a', queue: 'q1', maxRetries: 1 });\n      tq.addTask({ payload: 'b', queue: 'q2', maxRetries: 1 });\n\n      const t1 = tq.getNextTask('q1')!;\n      const t2 = tq.getNextTask('q2')!;\n      tq.failTask(t1.id, 'err1');\n      tq.failTask(t2.id, 'err2');\n\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(0);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n  });\n\n  // ==========================================================\n  // Phase 7: Task Dependencies\n  // ==========================================================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = tq.addTask({ payload: 'first' });\n      tq.addTask({ payload: 'second', dependencies: [t1.id] });\n\n      // Only t1 should be available\n      const next = tq.getNextTask()!;\n      expect(next.payload).toBe('first');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const t1 = tq.addTask({ payload: 'first' });\n      const t2 = tq.addTask({ payload: 'second', dependencies: [t1.id] });\n\n      const processing = tq.getNextTask()!;\n      tq.completeTask(processing.id);\n\n      // t2 should now be available\n      const next = tq.getNextTask()!;\n      expect(next.id).toBe(t2.id);\n    });\n\n    it('should detect circular dependencies', () => {\n      const t1 = tq.addTask({ payload: 'a' });\n      // t1 depends on nothing, but now create t2 that depends on t1\n      const t2 = tq.addTask({ payload: 'b', dependencies: [t1.id] });\n\n      // Now try to create t3 that depends on t2, and t2 depends on t1 — no cycle\n      const t3 = tq.addTask({ payload: 'c', dependencies: [t2.id] });\n      expect(t3).toBeDefined();\n    });\n\n    it('should reject dependency on non-existent task', () => {\n      expect(() =>\n        tq.addTask({ payload: 'a', dependencies: ['nonexistent'] })\n      ).toThrow('Dependency task not found');\n    });\n\n    it('should allow inspecting dependency status', () => {\n      const t1 = tq.addTask({ payload: 'first' });\n      const t2 = tq.addTask({ payload: 'second', dependencies: [t1.id] });\n\n      const status = tq.getDependencyStatus(t2.id);\n      expect(status.dependencies).toContain(t1.id);\n      expect(status.pending).toContain(t1.id);\n      expect(status.resolved).toHaveLength(0);\n\n      // Complete t1\n      tq.getNextTask();\n      tq.completeTask(t1.id);\n\n      const updatedStatus = tq.getDependencyStatus(t2.id);\n      expect(updatedStatus.resolved).toContain(t1.id);\n      expect(updatedStatus.pending).toHaveLength(0);\n    });\n\n    it('should leave dependents blocked when dependency fails', () => {\n      const t1 = tq.addTask({ payload: 'dep', maxRetries: 1 });\n      tq.addTask({ payload: 'dependent', dependencies: [t1.id] });\n\n      const processing = tq.getNextTask()!;\n      tq.failTask(processing.id, 'error');\n\n      // Dependent should still be blocked (not failed)\n      expect(tq.getNextTask()).toBeNull();\n    });\n  });\n\n  // ==========================================================\n  // Phase 8: Concurrency Control\n  // ==========================================================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should default to no concurrency limit', () => {\n      const info = tq.getConcurrency();\n      expect(info.limit).toBeUndefined();\n      expect(info.active).toBe(0);\n    });\n\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 2);\n      tq.addTask({ payload: 'a' });\n      tq.addTask({ payload: 'b' });\n      tq.addTask({ payload: 'c' });\n\n      const t1 = tq.getNextTask()!;\n      const t2 = tq.getNextTask()!;\n      expect(t1).toBeDefined();\n      expect(t2).toBeDefined();\n      expect(tq.getNextTask()).toBeNull(); // limit reached\n\n      // Complete one, should free a slot\n      tq.completeTask(t1.id);\n      const t3 = tq.getNextTask()!;\n      expect(t3).toBeDefined();\n    });\n\n    it('should report active count', () => {\n      tq.setConcurrency('default', 3);\n      tq.addTask({ payload: 'a' });\n      tq.addTask({ payload: 'b' });\n\n      tq.getNextTask();\n      expect(tq.getConcurrency().active).toBe(1);\n\n      tq.getNextTask();\n      expect(tq.getConcurrency().active).toBe(2);\n    });\n\n    it('should respect priority with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask({ payload: 'low', priority: 10 });\n      tq.addTask({ payload: 'high', priority: 1 });\n\n      const first = tq.getNextTask()!;\n      expect(first.payload).toBe('high');\n    });\n  });\n\n  // ==========================================================\n  // Phase 9: Progress Tracking and Cancellation\n  // ==========================================================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should track progress', () => {\n      tq.addTask({ payload: 'a' });\n      const task = tq.getNextTask()!;\n\n      tq.reportProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      tq.addTask({ payload: 'a' });\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      tq.reportProgress(task.id, 75);\n      expect(updates).toEqual([25, 75]);\n    });\n\n    it('should support unsubscribe', () => {\n      tq.addTask({ payload: 'a' });\n      const task = tq.getNextTask()!;\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsub();\n      tq.reportProgress(task.id, 75);\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = tq.addTask({ payload: 'a' });\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      tq.addTask({ payload: 'a' });\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    });\n\n    it('should never retry cancelled tasks', () => {\n      tq.addTask({ payload: 'a', maxRetries: 5 });\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)!.maxRetries).toBe(0);\n    });\n  });\n\n  // ==========================================================\n  // Phase 10: Recurring Tasks\n  // ==========================================================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'report' });\n      expect(schedule.id).toBe('s1');\n      expect(schedule.cron).toBe('*/5 * * * *');\n    });\n\n    it('should list schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n      tq.addSchedule('s2', '0 * * * *', 'emails', {});\n\n      const schedules = tq.listSchedules();\n      expect(schedules).toHaveLength(2);\n    });\n\n    it('should remove schedule', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n      tq.removeSchedule('s1');\n      expect(tq.listSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick for matching schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'report' });\n\n      // Tick at a time that matches */5 (minute = 0, 5, 10, etc.)\n      const matchTime = new Date('2024-01-01T00:00:00');\n      const tasks = tq.tick(matchTime);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'report' });\n    });\n\n    it('should not enqueue when cron does not match', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n\n      // Tick at minute 3 — does not match */5\n      const noMatch = new Date('2024-01-01T00:03:00');\n      const tasks = tq.tick(noMatch);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should prevent double-fire within same minute', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n\n      const time = new Date('2024-01-01T00:00:00');\n      tq.tick(time);\n      const tasks2 = tq.tick(time);\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should support hourly cron', () => {\n      tq.addSchedule('s1', '0 * * * *', 'default', {});\n\n      const onHour = new Date('2024-01-01T03:00:00');\n      const tasks = tq.tick(onHour);\n      expect(tasks).toHaveLength(1);\n\n      const offHour = new Date('2024-01-01T03:15:00');\n      const tasks2 = tq.tick(offHour);\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should support daily midnight cron', () => {\n      tq.addSchedule('s1', '0 0 * * *', 'default', {});\n\n      const midnight = new Date('2024-01-01T00:00:00');\n      const tasks = tq.tick(midnight);\n      expect(tasks).toHaveLength(1);\n\n      const noon = new Date('2024-01-01T12:00:00');\n      const tasks2 = tq.tick(noon);\n      expect(tasks2).toHaveLength(0);\n    });\n  });\n\n  // ==========================================================\n  // Phase 11: Middleware Pipeline\n  // ==========================================================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should process task through middleware and handler', async () => {\n      const log: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        log.push('mw1-before');\n        await next();\n        log.push('mw1-after');\n      });\n\n      tq.registerHandler('default', async () => {\n        log.push('handler');\n      });\n\n      tq.addTask({ payload: 'a' });\n      await tq.processTask();\n\n      expect(log).toEqual(['mw1-before', 'handler', 'mw1-after']);\n    });\n\n    it('should skip processing when middleware does not call next', async () => {\n      const log: string[] = [];\n\n      tq.use('default', async (_task, _next) => {\n        log.push('mw-skip');\n        // Intentionally not calling next\n      });\n\n      tq.registerHandler('default', async () => {\n        log.push('handler');\n      });\n\n      tq.addTask({ payload: 'a' });\n      await tq.processTask();\n\n      expect(log).toEqual(['mw-skip']);\n      expect(log).not.toContain('handler');\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        task.metadata['enriched'] = true;\n        await next();\n      });\n\n      let receivedTask: unknown = null;\n      tq.registerHandler('default', async (task) => {\n        receivedTask = task;\n      });\n\n      tq.addTask({ payload: 'a' });\n      await tq.processTask();\n\n      expect((receivedTask as { metadata: Record<string, unknown> }).metadata['enriched']).toBe(true);\n    });\n\n    it('should fail task when middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.addTask({ payload: 'a', maxRetries: 1 });\n      await tq.processTask();\n\n      const updated = tq.getTask(task.id)!;\n      expect(updated.status).toBe('dead-lettered');\n      expect(updated.error).toBe('middleware error');\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const log: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        log.push('q1-mw');\n        await next();\n      });\n\n      tq.use('q2', async (_task, next) => {\n        log.push('q2-mw');\n        await next();\n      });\n\n      tq.addTask({ payload: 'a', queue: 'q1' });\n      tq.addTask({ payload: 'b', queue: 'q2' });\n\n      await tq.processTask('q1');\n      await tq.processTask('q2');\n\n      expect(log).toEqual(['q1-mw', 'q2-mw']);\n    });\n\n    it('should return null from processTask when no tasks available', async () => {\n      const result = await tq.processTask();\n      expect(result).toBeNull();\n    });\n  });\n\n  // ==========================================================\n  // Phase 12: Graceful Shutdown\n  // ==========================================================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.addTask({ payload: 'a' })).toThrow('shutting down');\n    });\n\n    it('should complete immediately when no tasks are processing', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should force cancel tasks that exceed timeout', async () => {\n      tq.addTask({ payload: 'long-running' });\n      tq.getNextTask(); // now processing\n\n      const result = await tq.shutdown(50);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should return same result on multiple shutdown calls', async () => {\n      const r1 = tq.shutdown(100);\n      const r2 = tq.shutdown(100);\n\n      const result1 = await r1;\n      const result2 = await r2;\n      expect(result1).toBe(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      tq.onShutdown(() => {\n        callbackRan = true;\n      });\n\n      await tq.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should count completed tasks during shutdown', async () => {\n      tq.addTask({ payload: 'a' });\n      const task = tq.getNextTask()!;\n\n      // Start shutdown with generous timeout\n      const shutdownPromise = tq.shutdown(1000);\n\n      // Complete the task while shutdown is waiting\n      tq.completeTask(task.id);\n\n      const result = await shutdownPromise;\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"c