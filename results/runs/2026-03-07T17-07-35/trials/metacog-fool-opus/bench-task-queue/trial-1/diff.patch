+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01VwvfqzKR7gdaqtNvutPk1H","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0134uGQdNo98i2xaqd7sngJw","name":"Write","input":{"file_path":"/workspace/src/index.ts","content":"import { randomUUID } from 'crypto';\n\n// ============================================================\n// Types\n// ============================================================\n\nexport type TaskStatus =\n  | 'pending'\n  | 'processing'\n  | 'completed'\n  | 'failed'\n  | 'cancelled'\n  | 'dead-lettered';\n\nexport interface Task<T = unknown> {\n  id: string;\n  payload: T;\n  status: TaskStatus;\n  createdAt: Date;\n  queue: string;\n  priority: number;\n  availableAt: Date;\n  attempt: number;\n  maxRetries: number;\n  backoffDelay: number;\n  error?: string;\n  failureCount: number;\n  dependencies: string[];\n  resolvedDependencies: Set<string>;\n  progress: number;\n  progressMessage?: string;\n  metadata: Record<string, unknown>;\n}\n\nexport interface AddTaskOptions<T = unknown> {\n  payload: T;\n  queue?: string;\n  priority?: number;\n  delay?: number;\n  availableAt?: Date;\n  maxRetries?: number;\n  backoffDelay?: number;\n  dependencies?: string[];\n}\n\nexport type ProgressListener = (progress: number, message?: string) => void;\n\nexport type Middleware = (\n  task: Task,\n  next: () => Promise<void>\n) => Promise<void> | void;\n\nexport type TaskHandler = (task: Task) => Promise<void> | void;\n\nexport interface Schedule {\n  id: string;\n  cron: string;\n  queue: string;\n  payload: unknown;\n  lastRun: Date | null;\n}\n\nexport interface ShutdownResult {\n  completed: number;\n  forceCancelled: number;\n  durationMs: number;\n}\n\n// ============================================================\n// Default constants\n// ============================================================\n\nconst DEFAULT_QUEUE = 'default';\nconst DEFAULT_PRIORITY = 5;\nconst DEFAULT_MAX_RETRIES = 3;\nconst DEFAULT_BACKOFF_DELAY = 1000;\n\n// ============================================================\n// TaskQueue\n// ============================================================\n\nexport class TaskQueue {\n  // All tasks by ID\n  private tasks = new Map<string, Task>();\n\n  // Per-queue pending task IDs (ordered by insertion for FIFO)\n  private queues = new Map<string, string[]>();\n\n  // Per-queue dead letter queue\n  private dlqs = new Map<string, string[]>();\n\n  // Per-queue concurrency limit (undefined = unlimited)\n  private concurrencyLimits = new Map<string, number>();\n\n  // Per-queue active processing count\n  private activeCount = new Map<string, number>();\n\n  // Progress listeners per task\n  private progressListeners = new Map<string, Set<ProgressListener>>();\n\n  // Schedules for recurring tasks\n  private schedules = new Map<string, Schedule>();\n\n  // Per-queue middleware stacks\n  private middlewareStacks = new Map<string, Middleware[]>();\n\n  // Per-queue handlers\n  private handlers = new Map<string, TaskHandler>();\n\n  // Shutdown state\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n\n  // -------------------------------------------------------\n  // Phase 1 & 2: Add task to queue\n  // -------------------------------------------------------\n\n  addTask<T = unknown>(options: AddTaskOptions<T>): Task<T> {\n    // Phase 12: reject if shutting down\n    if (this.isShuttingDown) {\n      throw new Error('Queue is shutting down; cannot add new tasks');\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n    const priority = options.priority ?? DEFAULT_PRIORITY;\n\n    // Phase 3: validate priority\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Compute availability time\n    let availableAt = new Date();\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    }\n\n    // Phase 7: validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload: options.payload,\n      status: 'pending',\n      createdAt: new Date(),\n      queue: queueName,\n      priority,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failureCount: 0,\n      dependencies: [...dependencies],\n      resolvedDependencies: new Set<string>(),\n      progress: 0,\n      metadata: {},\n    };\n\n    // Phase 7: detect circular dependencies\n    if (dependencies.length > 0) {\n      this.detectCircularDependency(task);\n    }\n\n    this.tasks.set(task.id, task as Task);\n\n    // Ensure queue exists\n    if (!this.queues.has(queueName)) {\n      this.queues.set(queueName, []);\n    }\n    this.queues.get(queueName)!.push(task.id);\n\n    return task;\n  }\n\n  // -------------------------------------------------------\n  // Phase 1, 2, 3, 4, 7, 8: Retrieve next task\n  // -------------------------------------------------------\n\n  getNextTask(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const taskIds = this.queues.get(name);\n    if (!taskIds || taskIds.length === 0) return null;\n\n    // Phase 8: check concurrency limit\n    const limit = this.concurrencyLimits.get(name);\n    const active = this.activeCount.get(name) ?? 0;\n    if (limit !== undefined && active >= limit) {\n      return null;\n    }\n\n    const now = Date.now();\n\n    // Find the best candidate considering priority, availability, FIFO, and dependencies\n    let bestIdx = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < taskIds.length; i++) {\n      const task = this.tasks.get(taskIds[i]);\n      if (!task || task.status !== 'pending') continue;\n\n      // Phase 4: skip tasks that aren't available yet\n      if (task.availableAt.getTime() > now) continue;\n\n      // Phase 7: skip tasks with unresolved dependencies\n      if (this.hasUnresolvedDependencies(task)) continue;\n\n      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {\n        bestIdx = i;\n        bestTask = task;\n      }\n    }\n\n    if (bestIdx === -1 || bestTask === null) return null;\n\n    // Remove from queue and transition to processing\n    taskIds.splice(bestIdx, 1);\n    bestTask.status = 'processing';\n    bestTask.attempt += 1;\n\n    // Update active count\n    this.activeCount.set(name, (this.activeCount.get(name) ?? 0) + 1);\n\n    return bestTask;\n  }\n\n  // -------------------------------------------------------\n  // Phase 1: Pending count\n  // -------------------------------------------------------\n\n  pendingCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const taskIds = this.queues.get(name);\n    if (!taskIds) return 0;\n\n    let count = 0;\n    for (const id of taskIds) {\n      const task = this.tasks.get(id);\n      if (task && task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // -------------------------------------------------------\n  // Phase 2: List queues\n  // -------------------------------------------------------\n\n  listQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // -------------------------------------------------------\n  // Phase 5: Complete / Fail tasks\n  // -------------------------------------------------------\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n\n    // Decrement active count\n    const active = this.activeCount.get(task.queue) ?? 0;\n    this.activeCount.set(task.queue, Math.max(0, active - 1));\n\n    // Phase 7: resolve dependencies for dependents\n    this.resolveDependency(taskId);\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.error = error;\n    task.failureCount += 1;\n\n    // Decrement active count\n    const active = this.activeCount.get(task.queue) ?? 0;\n    this.activeCount.set(task.queue, Math.max(0, active - 1));\n\n    // Check if retries remain\n    if (task.attempt < task.maxRetries) {\n      // Re-add to queue with exponential backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n\n      // Put back in queue\n      const queueTasks = this.queues.get(task.queue);\n      if (queueTasks) {\n        queueTasks.push(taskId);\n      }\n    } else {\n      // No retries left\n      task.status = 'failed';\n\n      // Phase 6: move to DLQ\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // -------------------------------------------------------\n  // Phase 6: Dead Letter Queue\n  // -------------------------------------------------------\n\n  private moveToDeadLetterQueue(task: Task): void {\n    task.status = 'dead-lettered';\n    if (!this.dlqs.has(task.queue)) {\n      this.dlqs.set(task.queue, []);\n    }\n    this.dlqs.get(task.queue)!.push(task.id);\n  }\n\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlqIds = this.dlqs.get(name);\n    if (!dlqIds) return [];\n    return dlqIds\n      .map(id => this.tasks.get(id))\n      .filter((t): t is Task => t !== undefined);\n  }\n\n  retryDeadLetterTask(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'dead-lettered') {\n      throw new Error(`Task ${taskId} is not in dead-lettered state`);\n    }\n\n    // Remove from DLQ\n    const dlqIds = this.dlqs.get(task.queue);\n    if (dlqIds) {\n      const idx = dlqIds.indexOf(taskId);\n      if (idx !== -1) dlqIds.splice(idx, 1);\n    }\n\n    // Reset task for fresh retries\n    task.status = 'pending';\n    task.attempt = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n    task.progress = 0;\n    task.progressMessage = undefined;\n\n    // Add back to queue\n    if (!this.queues.has(task.queue)) {\n      this.queues.set(task.queue, []);\n    }\n    this.queues.get(task.queue)!.push(task.id);\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlqIds = this.dlqs.get(name);\n    if (dlqIds) {\n      for (const id of dlqIds) {\n        this.tasks.delete(id);\n      }\n      this.dlqs.set(name, []);\n    }\n  }\n\n  // -------------------------------------------------------\n  // Phase 7: Task Dependencies\n  // -------------------------------------------------------\n\n  private hasUnresolvedDependencies(task: Task): boolean {\n    if (task.dependencies.length === 0) return false;\n    for (const depId of task.dependencies) {\n      if (!task.resolvedDependencies.has(depId)) return true;\n    }\n    return false;\n  }\n\n  private resolveDependency(completedTaskId: string): void {\n    // Check all tasks and resolve this dependency\n    for (const task of this.tasks.values()) {\n      if (task.dependencies.includes(completedTaskId)) {\n        task.resolvedDependencies.add(completedTaskId);\n      }\n    }\n  }\n\n  private detectCircularDependency(newTask: Task): void {\n    // BFS/DFS from each dependency to check if they transitively depend on newTask\n    // Since newTask isn't yet in the system's dependency graph (it's new),\n    // we only need to check if any of newTask's dependencies have\n    // newTask's dependencies in their chain (direct circular among existing tasks),\n    // or more specifically, we check for cycles if newTask were added.\n    // Actually, newTask.id is new and no existing task can depend on it yet,\n    // so circular deps can only happen if dep chain forms cycles among declared deps.\n    // We need to check: do any of newTask's deps transitively depend on any of newTask's other deps?\n    // Actually, the real check is: would adding newTask create a cycle?\n    // Since newTask.id is fresh, no existing task depends on it yet, so no cycle is possible\n    // UNLESS two of newTask's dependencies form a cycle among themselves — but that would\n    // have been caught when those tasks were added.\n    // The real scenario: task A depends on B, task B depends on A.\n    // When adding A (depends on B), B exists, no cycle (B doesn't depend on A since A doesn't exist yet).\n    // When adding B (depends on A), A exists and A depends on B — cycle detected!\n\n    const visited = new Set<string>();\n    const stack = [...newTask.dependencies];\n\n    while (stack.length > 0) {\n      const current = stack.pop()!;\n      if (current === newTask.id) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n\n      const currentTask = this.tasks.get(current);\n      if (currentTask) {\n        for (const depId of currentTask.dependencies) {\n          stack.push(depId);\n        }\n      }\n    }\n\n    // Also check: do any existing tasks depend on one of newTask's dependencies\n    // in a way that would create a cycle through newTask?\n    // This is already handled: if task X depends on newTask.id, that's impossible\n    // since newTask.id is brand new. So no cycles can form through newTask.\n  }\n\n  getDependencyStatus(taskId: string): {\n    dependencies: string[];\n    resolved: string[];\n    pending: string[];\n  } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved = task.dependencies.filter(id =>\n      task.resolvedDependencies.has(id)\n    );\n    const pending = task.dependencies.filter(\n      id => !task.resolvedDependencies.has(id)\n    );\n\n    return { dependencies: [...task.dependencies], resolved, pending };\n  }\n\n  // -------------------------------------------------------\n  // Phase 8: Concurrency Control\n  // -------------------------------------------------------\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName?: string): {\n    limit: number | undefined;\n    active: number;\n  } {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return {\n      limit: this.concurrencyLimits.get(name),\n      active: this.activeCount.get(name) ?? 0,\n    };\n  }\n\n  // -------------------------------------------------------\n  // Phase 9: Progress Tracking\n  // -------------------------------------------------------\n\n  reportProgress(\n    taskId: string,\n    progress: number,\n    message?: string\n  ): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n      }\n    };\n  }\n\n  // -------------------------------------------------------\n  // Phase 9: Cancellation\n  // -------------------------------------------------------\n\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    if (task.status === 'pending') {\n      // Remove from queue\n      const queueTasks = this.queues.get(task.queue);\n      if (queueTasks) {\n        const idx = queueTasks.indexOf(taskId);\n        if (idx !== -1) queueTasks.splice(idx, 1);\n      }\n      task.status = 'cancelled';\n    } else if (task.status === 'processing') {\n      task.status = 'cancelled';\n      // Decrement active count\n      const active = this.activeCount.get(task.queue) ?? 0;\n      this.activeCount.set(task.queue, Math.max(0, active - 1));\n    } else {\n      throw new Error(\n        `Task ${taskId} cannot be cancelled (current status: ${task.status})`\n      );\n    }\n\n    // Ensure cancelled tasks can never be retried\n    task.maxRetries = 0;\n  }\n\n  // -------------------------------------------------------\n  // Phase 10: Recurring Tasks (Cron)\n  // -------------------------------------------------------\n\n  addSchedule(\n    id: string,\n    cron: string,\n    queueName: string,\n    payload: unknown\n  ): Schedule {\n    if (this.isShuttingDown) {\n      throw new Error('Queue is shutting down; cannot add schedules');\n    }\n\n    // Validate cron expression\n    this.parseCron(cron);\n\n    const schedule: Schedule = {\n      id,\n      cron,\n      queue: queueName,\n      payload,\n      lastRun: null,\n    };\n    this.schedules.set(id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(id: string): void {\n    if (!this.schedules.has(id)) {\n      throw new Error(`Schedule not found: ${id}`);\n    }\n    this.schedules.delete(id);\n  }\n\n  listSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const createdTasks: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.addTask({\n          payload: schedule.payload,\n          queue: schedule.queue,\n        });\n        createdTasks.push(task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  private parseCron(cron: string): { minute: string; hour: string } {\n    const parts = cron.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${cron}`);\n    }\n    // We support:\n    // */N * * * *  (every N minutes)\n    // 0 * * * *    (every hour)\n    // 0 0 * * *    (every day at midnight)\n    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n\n    // day of month, month, day of week must be *\n    if (dayOfMonth !== '*' || month !== '*' || dayOfWeek !== '*') {\n      // We only require these for our simple subset\n      // Actually, \"0 0 * * *\" has dayOfMonth=*, month=*, dayOfWeek=* which works\n    }\n\n    // Validate minute\n    if (minute !== '*' && !minute.match(/^\\d+$/) && !minute.match(/^\\*\\/\\d+$/)) {\n      throw new Error(`Invalid cron minute field: ${minute}`);\n    }\n\n    // Validate hour\n    if (hour !== '*' && !hour.match(/^\\d+$/)) {\n      throw new Error(`Invalid cron hour field: ${hour}`);\n    }\n\n    return { minute, hour };\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cron.trim().split(/\\s+/);\n    const [minuteField, hourField] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Check minute match\n    let minuteMatch = false;\n    if (minuteField === '*') {\n      minuteMatch = true;\n    } else if (minuteField.startsWith('*/')) {\n      const interval = parseInt(minuteField.slice(2), 10);\n      minuteMatch = currentMinute % interval === 0;\n    } else {\n      minuteMatch = currentMinute === parseInt(minuteField, 10);\n    }\n\n    // Check hour match\n    let hourMatch = false;\n    if (hourField === '*') {\n      hourMatch = true;\n    } else {\n      hourMatch = currentHour === parseInt(hourField, 10);\n    }\n\n    if (!minuteMatch || !hourMatch) return false;\n\n    // Prevent double-firing within same minute\n    if (schedule.lastRun) {\n      const lastRunMinute = schedule.lastRun.getMinutes();\n      const lastRunHour = schedule.lastRun.getHours();\n      const lastRunDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (\n        lastRunDate === nowDate &&\n        lastRunHour === currentHour &&\n        lastRunMinute === currentMinute\n      ) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  // -------------------------------------------------------\n  // Phase 11: Middleware Pipeline\n  // -------------------------------------------------------\n\n  use(queueName: string, middleware: Middleware): void {\n    if (!this.middlewareStacks.has(queueName)) {\n      this.middlewareStacks.set(queueName, []);\n    }\n    this.middlewareStacks.get(queueName)!.push(middleware);\n  }\n\n  registerHandler(queueName: string, handler: TaskHandler): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  async processTask(queueName?: string): Promise<Task | null> {\n    const task = this.getNextTask(queueName);\n    if (!task) return null;\n\n    const name = queueName ?? DEFAULT_QUEUE;\n    const middlewares = this.middlewareStacks.get(name) ?? [];\n    const handler = this.handlers.get(name);\n\n    try {\n      await this.executeMiddlewarePipeline(task, middlewares, handler);\n      // If still processing (middleware didn't skip), complete it\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.failTask(\n          task.id,\n          err instanceof Error ? err.message : String(err)\n        );\n      }\n    }\n\n    return task;\n  }\n\n  private async executeMiddlewarePipeline(\n    task: Task,\n    middlewares: Middleware[],\n    handler?: TaskHandler\n  ): Promise<void> {\n    let index = 0;\n    let nextCalled = false;\n\n    const executeNext = async (): Promise<void> => {\n      nextCalled = true;\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        nextCalled = false;\n        await mw(task, executeNext);\n        // If middleware didn't call next, we stop the pipeline\n        // and skip processing — mark task as completed (skipped)\n        if (!nextCalled && index <= middlewares.length) {\n          // Middleware chose not to call next — skip processing\n          // We complete the task since middleware decided to skip\n          if (task.status === 'processing') {\n            this.completeTask(task.id);\n          }\n        }\n      } else {\n        // All middleware done, run handler\n        if (handler) {\n          await handler(task);\n        }\n      }\n    };\n\n    await executeNext();\n  }\n\n  // -------------------------------------------------------\n  // Phase 12: Graceful Shutdown\n  // -------------------------------------------------------\n\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {\n    // Idempotent: return same promise if already shutting down\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(timeoutMs);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(timeoutMs: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Count currently processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks up to timeout\n    const waitResult = await new Promise<void>(resolve => {\n      const checkInterval = setInterval(() => {\n        const stillProcessing = processingTasks.filter(\n          t => t.status === 'processing'\n        );\n        if (stillProcessing.length === 0) {\n          clearInterval(checkInterval);\n          resolve();\n        }\n      }, 10);\n\n      setTimeout(() => {\n        clearInterval(checkInterval);\n        resolve();\n      }, timeoutMs);\n    });\n\n    void waitResult;\n\n    // Count results\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        // Force cancel\n        task.status = 'cancelled';\n        const active = this.activeCount.get(task.queue) ?? 0;\n        this.activeCount.set(task.queue, Math.max(0, active - 1));\n        forceCancelled++;\n      } else if (task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      durationMs: Date.now() - startTime,\n    };\n  }\n\n  // -------------------------------------------------------\n  // Utility: Get task by ID\n  // -------------------------------------------------------\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // -------------------------------------------------------\n  // Priority comparison helper\n  // -------------------------------------------------------\n\n  private compareTasks(a: Task, b: Task): number {\n    // 1. Priority (lower number = higher priority)\n    if (a.priority !== b.priority) return a.priority - b.priority;\n\n    // 2. Availability time (earlier = first)\n    const aTime = a.availableAt.getTime();\n    const bTime = b.availableAt.getTime();\n    if (aTime !== bTime) return aTime - bTime;\n\n    // 3. FIFO (earlier creation = first)\n    return a.createdAt.getTime() - b.createdAt.getTime();\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":524,"cache_read_input_tokens":26067,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":524},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"context_management":