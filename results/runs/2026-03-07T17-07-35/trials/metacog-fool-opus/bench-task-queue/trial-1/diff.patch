+      expect(task.status).toBe('pending');
+      expect(task.createdAt).toBeInstanceOf(Date);
+    });
+
+    it('should assign unique IDs to tasks', () => {
+      const t1 = tq.addTask({ payload: 'a' });
+      const t2 = tq.addTask({ payload: 'b' });
+      expect(t1.id).not.toBe(t2.id);
+    });
+
+    it('should retrieve tasks in FIFO order', () => {
+      tq.addTask({ payload: 'first' });
+      tq.addTask({ payload: 'second' });
+      tq.addTask({ payload: 'third' });
+
+      expect(tq.getNextTask()!.payload).toBe('first');
+      expect(tq.getNextTask()!.payload).toBe('second');
+      expect(tq.getNextTask()!.payload).toBe('third');
+    });
+
+    it('should transition retrieved task to processing', () => {
+      tq.addTask({ payload: 'data' });
+      const task = tq.getNextTask()!;
+      expect(task.status).toBe('processing');
+    });
+
+    it('should return null when no tasks are available', () => {
+      expect(tq.getNextTask()).toBeNull();
+    });
+
+    it('should report pending count', () => {
+      expect(tq.pendingCount()).toBe(0);
