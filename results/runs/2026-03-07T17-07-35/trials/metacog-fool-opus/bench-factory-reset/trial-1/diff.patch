press', () => {\n    const result = solveToggle({\n      target: [true, true, false],\n      buttons: [[0, 1], [1, 2], [0, 2]],\n    });\n    expect(result).toEqual([0]);\n    expect(verifyToggle([true, true, false], [[0, 1], [1, 2], [0, 2]], result!)).toBe(true);\n  });\n\n  it('should solve with two button presses', () => {\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0, 1]);\n    expect(verifyToggle([true, false, true], [[0, 1], [1, 2]], result!)).toBe(true);\n  });\n\n  it('should handle no buttons needed', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should return minimum presses when multiple solutions exist', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle single light single button', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle larger system', () => {\n    // 5 lights, 5 buttons, identity-like\n    const result = solveToggle({\n      target: [true, true, true, true, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    });\n    expect(result).toEqual([0, 1, 2, 3, 4]);\n  });\n\n  it('should handle overlapping buttons', () => {\n    // Button 0: [0,1], Button 1: [1,2], target: [true, false, true]\n    // b0 XOR 0 = 1 (light 0), b0 XOR b1 = 0 (light 1), b1 = 1 (light 2)\n    // b1 = 1, b0 = b1 = 1. Solution: [0, 1]\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0, 1]);\n    expect(verifyToggle([true, false, true], [[0, 1], [1, 2]], result!)).toBe(true);\n  });\n\n  it('should prefer fewer presses over lex order', () => {\n    // Button 0: [0], Button 1: [0, 1], Button 2: [1]\n    // Target: [true, true]\n    // Options: {1} (1 press), {0, 2} (2 presses)\n    // Should pick {1} since it uses fewer presses\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [0, 1], [1]],\n    });\n    expect(result).toEqual([1]);\n  });\n\n  it('should handle performance with 20 lights and 20 buttons', () => {\n    const n = 20;\n    const target = new Array(n).fill(true);\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i]); // Each button toggles one light\n    }\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(Array.from({ length: n }, (_, i) => i));\n  });\n\n  it('should handle 40 buttons and 40 lights within time', () => {\n    const n = 40;\n    const target = new Array(n).fill(true);\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i]);\n    }\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(Array.from({ length: n }, (_, i) => i));\n  });\n\n  it('should handle overlapping 40-button system', () => {\n    const n = 40;\n    const target = new Array(n).fill(false);\n    target[0] = true;\n    // Button i toggles lights i and (i+1) % n\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i, (i + 1) % n]);\n    }\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    if (result !== null) {\n      expect(verifyToggle(target, buttons, result)).toBe(true);\n    }\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zero', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should solve a simple counter puzzle', () => {\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should solve with two buttons and two counters', () => {\n    const result = solveCounter([1, 2], [[0, 1], [1]], 5);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 2], [[0, 1], [1]], [1, 1], 5)).toBe(true);\n  });\n\n  it('should return null when no solution exists', () => {\n    const result = solveCounter([1, 0], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('should handle modular wrapping', () => {\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should return minimum total presses with lex tiebreak', () => {\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should handle modulus 2 (equivalent to toggle)', () => {\n    // Target counter 0 = 1 (mod 2)\n    const result = solveCounter([1], [[0]], 2);\n    expect(result).toEqual([1]);\n  });\n\n  it('should handle larger modulus', () => {\n    // Button 0 increments counter 0. Target: counter 0 = 96 (mod 97)\n    const result = solveCounter([96], [[0]], 97);\n    expect(result).toEqual([96]);\n  });\n\n  it('should prefer minimum sum over lex order for counter', () => {\n    // Two buttons both increment counter 0 (mod 7)\n    // Target: 2\n    // Solutions: (0,2) sum=2, (1,1) sum=2, (2,0) sum=2, (3,6) sum=9, ...\n    // Min sum = 2, lex smallest among those: (0,2)\n    const result = solveCounter([2], [[0], [0]], 7);\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('should handle 40 counters and 40 buttons within time', () => {\n    const n = 40;\n    const lights = new Array(n).fill(1);\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i])