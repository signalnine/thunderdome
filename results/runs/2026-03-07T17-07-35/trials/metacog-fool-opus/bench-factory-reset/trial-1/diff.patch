 of the\n  // system is at most 40, so we could have up to 40 free variables in degenerate\n  // cases. But in practice, the number of free variables is usually small.\n  //\n  // Strategy: enumerate if p^numFree <= threshold, otherwise use\n  // meet-in-the-middle for p=2 or heuristic for larger p.\n\n  const totalCombinations = Math.pow(p, numFree);\n\n  if (totalCombinations <= 1_000_000) {\n    return enumerateFreeSolutions(aug, nCols, p, pivotCol, pivotRow, freeVars, currentRow);\n  }\n\n  // Meet-in-the-middle for p=2 with many free variables\n  if (p === 2) {\n    return meetInTheMiddleBinary(aug, nCols, pivotCol, pivotRow, freeVars, currentRow);\n  }\n\n  // For large p with many free variables (unlikely given constraints), fall back\n  // to trying each free variable = 0 (which gives a valid but possibly non-optimal solution)\n  return enumerateFreeSolutions(aug, nCols, p, pivotCol, pivotRow, freeVars, currentRow);\n}\n\nfunction computeSolution(\n  aug: number[][],\n  nCols: number,\n  p: number,\n  pivotCol: number[],\n  pivotRow: number[],\n  freeVars: number[],\n  freeAssignment: number[],\n  currentRow: number\n): number[] {\n  const solution = new Array(nCols).fill(0);\n\n  // Set free variables\n  for (let i = 0; i < freeVars.length; i++) {\n    solution[freeVars[i]] = freeAssignment[i];\n  }\n\n  // Compute pivot variables\n  for (let row = 0; row < currentRow; row++) {\n    const pc = pivotCol[row];\n    if (pc === -1) continue;\n    let val = aug[row][nCols];\n    for (let i = 0; i < freeVars.length; i++) {\n      val = mod(val - aug[row][freeVars[i]] * freeAssignment[i], p);\n    }\n    solution[pc] = val;\n  }\n\n  return solution;\n}\n\nfunction solutionCost(solution: number[]): number {\n  let sum = 0;\n  for (const v of solution) sum += v;\n  return sum;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nfunction enumerateFreeSolutions(\n  aug: number[][],\n  nCols: number,\n  p: number,\n  pivotCol: number[],\n  pivotRow: number[],\n  freeVars: number[],\n  currentRow: number\n): number[] {\n  const numFree = freeVars.length;\n  let bestSolution: number[] | null = null;\n  let bestCost = Infinity;\n\n  // Enumerate all p^numFree combinations\n  const assignment = new Array(numFree).fill(0);\n\n  const totalCombinations = Math.pow(p, numFree);\n  for (let combo = 0; combo < totalCombinations; combo++) {\n    // Convert combo to base-p assignment\n    let temp = combo;\n    for (let i = numFree - 1; i >= 0; i--) {\n      assignment[i] = temp % p;\n      temp = Math.floor(temp / p);\n    }\n\n    const sol = computeSolution(aug, nCols, p, pivotCol, pivotRow, freeVars, assignment, currentRow);\n    const cost = solutionCost(sol);\n\n    if (cost < bestCost || (cost === bestCost && bestSolution !== null && lexSmaller(sol, bestSolution))) {\n      bestCost = cost;\n      bestSolution = [...sol];\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction meetInTheMiddleBinary(\n  aug: number[][],\n  nCols: number,\n  pivotCol: number[],\n  pivotRow: number[],\n  freeVars: number[],\n  currentRow: number\n): number[] {\n  const p = 2;\n  const numFree = freeVars.length;\n\n  // Precompute how each free variable affects each pivot variable.\n  // For pivot variable at pivotCol[row]:\n  //   solution[pivotCol[row]] = aug[row][nCols] XOR sum(aug[row][freeVars[i]] * freeVars_assignment[i])\n  // In GF(2), this is just XOR of those free vars where aug[row][freeVars[i]] = 1.\n\n  // For each free var combination, the full solution is determined.\n  // Cost = (number of free vars set to 1) + (number of pivot vars that end up 1)\n  //\n  // For pivot var at row r: it equals aug[r][nCols] XOR (XOR of free vars i where aug[r][freeVars[i]]=1)\n  //\n  // Let's represent the effect of free variables on pivot variables as a bitmask.\n  // pivot_base[r] = aug[r][nCols] (base value without free vars)\n  // pivot_mask[r] = bitmask of which free vars affect pivot r (over free var indices)\n  //\n  // For a free var assignment (bitmask f):\n  //   pivot[r] = pivot_base[r] XOR popcount(f & pivot_mask[r]) % 2\n  //            = pivot_base[r] XOR parity(f & pivot_mask[r])\n\n  // Total cost = popcount(f) + sum over pivot rows of (pivot_base[r] XOR parity(f & pivot_mask[r]))\n\n  // Split free vars into two halves\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // Precompute pivot info\n  const pivotInfo: { col: number; base: number; mask: number }[] = [];\n  for (let row = 0; row < currentRow; row++) {\n    const pc = pivotCol[row];\n    if (pc === -1) continue;\n    let mask = 0;\n    for (let i = 0; i < numFree; i++) {\n      if (aug[row][freeVars[i]] === 1) {\n        mask |= (1 << i);\n      }\n    }\n    pivotInfo.push({ col: pc, base: aug[row][nCols], mask });\n  }\n\n  // For each half1 assignment, compute a \"signature\" that captures\n  // its contribution to each pivot variable, and store cost + assignment.\n  // Then for each half2 assignment, compute what signature we need and look up.\n\n  // Actually, for meet-in-the-middle to work efficiently here, we need to\n  // define a key that, combined between the two halves, determines the total cost.\n  //\n  // The pivot value for row r is:\n  //   base[r] XOR parity(f1 & mask_r_low) XOR parity(f2 & mask_r_high)\n  // where mask_r_low = mask_r & ((1<<half1)-1), mask_r_high = mask_r >> half1\n  //\n  // The pivot's contribution to cost is either 0 or 1, depending on the XOR.\n  // To minimize total cost, we want to minimize:\n  //   popcount(f1) + popcount(f2) + sum_r(base[r] XOR par1[r] XOR par2[r])\n  //\n  // = popcount(f1) + sum_r(base[r] XOR par1[r]) + popcount(f2) + sum_r(par2[r] * (-1)^(base[r] XOR par1[r]+1))\n  //\n  // Hmm, this doesn't decompose cleanly because par2 interacts with par1.\n  // Let's define signature for half1 as: for each pivot row,