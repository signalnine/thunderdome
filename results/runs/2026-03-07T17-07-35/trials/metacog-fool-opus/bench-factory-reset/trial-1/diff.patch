   201→  return false;\n   202→}\n   203→\n   204→function enumerateFreeSolutions(\n   205→  aug: number[][],\n   206→  nCols: number,\n   207→  p: number,\n   208→  pivotCol: number[],\n   209→  pivotRow: number[],\n   210→  freeVars: number[],\n   211→  currentRow: number\n   212→): number[] {\n   213→  const numFree = freeVars.length;\n   214→  let bestSolution: number[] | null = null;\n   215→  let bestCost = Infinity;\n   216→\n   217→  // Enumerate all p^numFree combinations\n   218→  const assignment = new Array(numFree).fill(0);\n   219→\n   220→  const totalCombinations = Math.pow(p, numFree);\n   221→  for (let combo = 0; combo < totalCombinations; combo++) {\n   222→    // Convert combo to base-p assignment\n   223→    let temp = combo;\n   224→    for (let i = numFree - 1; i >= 0; i--) {\n   225→      assignment[i] = temp % p;\n   226→      temp = Math.floor(temp / p);\n   227→    }\n   228→\n   229→    const sol = computeSolution(aug, nCols, p, pivotCol, pivotRow, freeVars, assignment, currentRow);\n   230→    const cost = solutionCost(sol);\n   231→\n   232→    if (cost < bestCost || (cost === bestCost && bestSolution !== null && lexSmaller(sol, bestSolution))) {\n   233→      bestCost = cost;\n   234→      bestSolution = [...sol];\n   235→    }\n   236→  }\n   237→\n   238→  return bestSolution!;\n   239→}\n   240→\n   241→function meetInTheMiddleBinary(\n   242→  aug: number[][],\n   243→  nCols: number,\n   244→  pivotCol: number[],\n   245→  pivotRow: number[],\n   246→  freeVars: number[],\n   247→  currentRow: number\n   248→): number[] {\n   249→  const p = 2;\n   250→  const numFree = freeVars.length;\n   251→\n   252→  // Precompute how each free variable affects each pivot variable.\n   253→  // For pivot variable at pivotCol[row]:\n   254→  //   solution[pivotCol[row]] = aug[row][nCols] XOR sum(aug[row][freeVars[i]] * freeVars_assignment[i])\n   255→  // In GF(2), this is just XOR of those free vars where aug[row][freeVars[i]] = 1.\n   256→\n   257→  // For each free var combination, the full solution is determined.\n   258→  // Cost = (number of free vars set to 1) + (number of pivot vars that end up 1)\n   259→  //\n   260→  // For pivot var at row r: it equals aug[r][nCols] XOR (XOR of free vars i where aug[r][freeVars[i]]=1)\n   261→  //\n   262→  // Let's represent the effect of free variables on pivot variables as a bitmask.\n   263→  // pivot_base[r] = aug[r][nCols] (base value without free vars)\n   264→  // pivot_mask[r] = bitmask of which free vars affect pivot r (over free var indices)\n   265→  //\n   266→  // For a free var assignment (bitmask f):\n   267→  //   pivot[r] = pivot_base[r] XOR popcount(f & pivot_mask[r]) % 2\n   268→  //            = pivot_base[r] XOR parity(f & pivot_mask[r])\n   269→\n   270→  // Total cost = popcount(f) + sum over pivot rows of (pivot_base[r] XOR parity(f & pivot_mask[r]))\n   271→\n   272→  // Split free vars into two halves\n   273→  const half1 = Math.floor(numFree / 2);\n   274→  const half2 = numFree - half1;\n   275→\n   276→  // Precompute pivot info\n   277→  const pivotInfo: { col: number; base: number; mask: number }[] = [];\n   278→  for (let row = 0; row < currentRow; row++) {\n   279→    const pc = pivotCol[row];\n   280→    if (pc === -1) continue;\n   281→    let mask = 0;\n   282→    for (let i = 0; i < numFree; i++) {\n   283→      if (aug[row][freeVars[i]] === 1) {\n   284→        mask |= (1 << i);\n   285→      }\n   286→    }\n   287→    pivotInfo.push({ col: pc, base: aug[row][nCols], mask });\n   288→  }\n   289→\n   290→  // For each half1 assignment, compute a \"signature\" that captures\n   291→  // its contribution to each pivot variable, and store cost + assignment.\n   292→  // Then for each half2 assignment, compute what signature we need and look up.\n   293→\n   294→  // Actually, for meet-in-the-middle to work efficiently here, we need to\n   295→  // define a key that, combined between the two halves, determines the total cost.\n   296→  //\n   297→  // The pivot value for row r is:\n   298→  //   base[r] XOR parity(f1 & mask_r_low) XOR parity(f2 & mask_r_high)\n   299→  // where mask_r_low = mask_r & ((1<<half1)-1), mask_r_high = mask_r >> half1\n   300→  //\n   301→  // The pivot's contribution to cost is either 0 or 1, depending on the XOR.\n   302→  // To minimize total cost, we want to minimize:\n   303→  //   popcount(f1) + popcount(f2) + sum_r(base[r] XOR par1[r] XOR par2[r])\n   304→  //\n   305→  // = popcount(f1) + sum_r(base[r] XOR par1[r]) + popcount(f2) + sum_r(par2[r] * (-1)^(base[r] XOR par1[r]+1))\n   306→  //\n   307→  // Hmm, this doesn't decompose cleanly because par2 interacts with par1.\n   308→  // Let's define signature for half1 as: for each pivot row, the parity contribution.\n   309→  // This is a bitvector of length = number of pivot variables.\n   310→  //\n   311→  // sig1 = bitvector where bit r = parity(f1 & mask_r_low)\n   312→  // sig2 = bitvector where bit r = parity(f2 & mask_r_high)\n   313→  //\n   314→  // pivot[r] = base[r] XOR sig1[r] XOR sig2[r]\n   315→  // cost = popcount(f1) + popcount(f2) + sum_r(base[r] XOR sig1[r] XOR sig2[r])\n   316→  //\n   317→  // For a fixed sig1, we want sig2 such that cost is minimized.\n   318→  // cost = popcount(f1) + popcount(f2) + sum_r(base[r] XOR sig1[r] XOR sig2[r])\n   319→  //\n   320→  // Let base_sig = bitvector where bit r = base[r]\n   321→  // effective = base_sig XOR sig1\n   322→  // Then cost = popcount(f1) + popcount(f2) + sum_r(effective[r] XOR sig2[r])\n   323→  // For bits where effective[r] = 1: sig2[r] = 1 reduces cost by 1, sig2[r] = 0 adds 1\n   324→  // For bits where effective[r] = 0: sig2[r] = 0 reduces cost by 0, sig2[r] = 1 adds 1\n   325→  // So for the pivot cost part, we want sig2 = effective (i.e., sig2[r] = effective[r]) to minimize.\n   326→  // Pivot cost with optimal sig2 = 0 (all pivots become 0).\n   327→  // But sig2 is constrained by the f2 assignment — not all sig2 value