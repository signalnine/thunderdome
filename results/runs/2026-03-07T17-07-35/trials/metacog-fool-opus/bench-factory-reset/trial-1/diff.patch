    if (par) sig2 |= (1 << r);\n    }\n    const cost2 = popcount(f2);\n    const existing = sig2Map.get(sig2);\n    if (!existing || cost2 < existing.cost) {\n      sig2Map.set(sig2, { cost: cost2, f2 });\n    }\n  }\n\n  let bestCost = Infinity;\n  let bestF1 = 0;\n  let bestF2 = 0;\n\n  // Compute base_sig\n  let baseSig = 0;\n  for (let r = 0; r < nPivots; r++) {\n    if (pivotInfo[r].base) baseSig |= (1 << r);\n  }\n\n  for (let f1 = 0; f1 < (1 << half1); f1++) {\n    let sig1 = 0;\n    for (let r = 0; r < nPivots; r++) {\n      const maskLow = pivotInfo[r].mask & mask1;\n      const par = popcount(f1 & maskLow) & 1;\n      if (par) sig1 |= (1 << r);\n    }\n\n    const effective = baseSig ^ sig1;\n    const cost1 = popcount(f1);\n\n    // For each possible sig2, the pivot cost = popcount(effective XOR sig2)\n    // Total cost = cost1 + cost2 + popcount(effective XOR sig2)\n    // We want to minimize this.\n    // Iterate over all entries in sig2Map\n    for (const [sig2, { cost: cost2, f2 }] of sig2Map) {\n      const pivotCost = popcount(effective ^ sig2);\n      const totalCost = cost1 + cost2 + pivotCost;\n      if (totalCost < bestCost || (totalCost === bestCost && needsUpdate(f1, f2, bestF1, bestF2, half1, numFree, aug, nCols, pivotCol, pivotRow, freeVars, currentRow))) {\n        bestCost = totalCost;\n        bestF1 = f1;\n        bestF2 = f2;\n      }\n    }\n  }\n\n  // Reconstruct solution from bestF1 and bestF2\n  const assignment = new Array(numFree).fill(0);\n  for (let i = 0; i < half1; i++) {\n    assignment[i] = (bestF1 >> i) & 1;\n  }\n  for (let i = 0; i < half2; i++) {\n    assignment[half1 + i] = (bestF2 >> i) & 1;\n  }\n\n  return computeSolution(aug, nCols, p, pivotCol, pivotRow, freeVars, assignment, currentRow);\n}\n\nfunction needsUpdate(\n  f1: number, f2: number,\n  bestF1: number, bestF2: number,\n  half1: number, numFree: number,\n  aug: number[][], nCols: number,\n  pivotCol: number[], pivotRow: number[],\n  freeVars: number[], currentRow: number\n): boolean {\n  // Compare lexicographically the full solutions\n  const assignment1 = new Array(numFree).fill(0);\n  for (let i = 0; i < half1; i++) assignment1[i] = (f1 >> i) & 1;\n  for (let i = 0; i < numFree - half1; i++) assignment1[half1 + i] = (f2 >> i) & 1;\n\n  const assignment2 = new Array(numFree).fill(0);\n  for (let i = 0; i < half1; i++) assignment2[i] = (bestF1 >> i) & 1;\n  for (let i = 0; i < numFree - half1; i++) assignment2[half1 + i] = (bestF2 >> i) & 1;\n\n  const sol1 = computeSolution(aug, nCols, 2, pivotCol, pivotRow, freeVars, assignment1, currentRow);\n  const sol2 = computeSolution(aug, nCols, 2, pivotCol, pivotRow, freeVars, assignment2, currentRow);\n\n  return lexSmaller(sol1, sol2);\n}\n\nfunction popcount(n: number): number {\n  n = n - ((n >> 1) & 0x55555555);\n  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n  n = (n + (n >> 4)) & 0x0f0f0f0f;\n  n = n + (n >> 8);\n  n = n + (n >> 16);\n  return n & 0x3f;\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  // Build augmented matrix [A | b] where A[light][button] = 1 if button toggles light\n  const augMatrix: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array(nButtons + 1).fill(0);\n    for (let j = 0; j < nButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[nButtons] = target[i] ? 1 : 0;\n    augMatrix.push(row);\n  }\n\n  const solution = solveLinearSystemGF(augMatrix, nLights, nButtons, 2);\n  if (solution === null) return null;\n\n  // Convert to array of button indices that are pressed (value = 1)\n  const pressed: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (solution[i] === 1) {\n      pressed.push(i);\n    }\n  }\n\n  return pressed;\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: num