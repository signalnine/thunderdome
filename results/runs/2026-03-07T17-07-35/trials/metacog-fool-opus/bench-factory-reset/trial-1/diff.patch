@@ -0,0 +1,431 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+type Comparator = (a: number[], b: number[]) => boolean;
+
+function mod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+function modInverse(a: number, p: number): number {
+  a = mod(a, p);
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return mod(old_s, p);
+}
+
+interface GaussResult {
+  aug: number[][];
+  pivotCol: number[];
+  pivotRow: number[];
+  freeVars: number[];
+  rank: number;
+}
+
+function gaussianElimination(
+  matrix: number[][],
+  nRows: number,
+  nCols: number,
+  p: number
+): GaussResult | null {
+  const aug = matrix.map(row => [...row]);
+  const pivotCol: number[] = new Array(nRows).fill(-1);
+  const pivotRow: number[] = new Array(nCols).fill(-1);
+
+  let currentRow = 0;
+  for (let col = 0; col < nCols && currentRow < nRows; col++) {
+    let found = -1;
+    for (let row = currentRow; row < nRows; row++) {
+      if (aug[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    if (found !== currentRow) {
+      [aug[currentRow], aug[found]] = [aug[found], aug[currentRow]];
+    }
+
+    pivotCol[currentRow] = col;
+    pivotRow[col] = currentRow;
+
+    const inv = modInverse(aug[currentRow][col], p);
+    for (let j = col; j <= nCols; j++) {
+      aug[currentRow][j] = mod(aug[currentRow][j] * inv, p);
+    }
+
+    for (let row = 0; row < nRows; row++) {
+      if (row === currentRow || aug[row][col] === 0) continue;
+      const factor = aug[row][col];
+      for (let j = col; j <= nCols; j++) {
+        aug[row][j] = mod(aug[row][j] - factor * aug[currentRow][j], p);
+      }
+    }
+
+    currentRow++;
+  }
+
+  for (let row = currentRow; row < nRows; row++) {
+    if (aug[row][nCols] !== 0) return null;
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < nCols; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  return { aug, pivotCol, pivotRow, freeVars, rank: currentRow };
+}
+
+function computeSolution(
+  gauss: GaussResult,
+  nCols: number,
+  p: number,
+  freeAssignment: number[]
+): number[] {
+  const solution = new Array(nCols).fill(0);
+  const { aug, pivotCol, freeVars, rank } = gauss;
+
+  for (let i = 0; i < freeVars.length; i++) {
+    solution[freeVars[i]] = freeAssignment[i];
+  }
+
+  for (let row = 0; row < rank; row++) {
+    const pc = pivotCol[row];
+    if (pc === -1) continue;
+    let val = aug[row][nCols];
+    for (let i = 0; i < freeVars.length; i++) {
+      val = mod(val - aug[row][freeVars[i]] * freeAssignment[i], p);
+    }
+    solution[pc] = val;
+  }
+
+  return solution;
+}
+
+function solutionCost(solution: number[]): number {
+  let sum = 0;
+  for (const v of solution) sum += v;
+  return sum;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function toggleLexSmaller(a: number[], b: number[]): boolean {
+  // For p=2 toggle: compare pressed-index sets lexicographically.
+  // Pressed-index set = positions where value is 1.
+  // Lex comparison of these sets means: at the first position where they differ,
+  // the one with 1 (pressed) is "earlier" in the set.
+  // E.g., [1,0,0] -> {0} vs [0,0,1] -> {2}: {0} < {2}
+  //
+  // This is equivalent to: for the first position i where a[i] != b[i],
+  // prefer the one with a[i] = 1 (because that button index is in the set
+  // and is smaller than whatever index b has later).
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] > b[i]) return true;  // a has 1, b has 0 at position i -> a's set has i, b's doesn't
+    if (a[i] < b[i]) return false; // b has 1, a has 0
+  }
+  return false;
+}
+
+function solveLinearSystemGF(
+  matrix: number[][],
+  nRows: number,
+  nCols: number,
+  p: number,
+  isBetter: Comparator
+): number[] | null {
+  const gauss = gaussianElimination(matrix, nRows, nCols, p);
+  if (gauss === null) return null;
+
+  const { freeVars } = gauss;
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const solution = new Array(nCols).fill(0);
+    for (let row = 0; row < gauss.rank; row++) {
+      solution[gauss.pivotCol[row]] = gauss.aug[row][nCols];
+    }
+    return solution;
+  }
+
+  const totalCombinations = Math.pow(p, numFree);
+
+  if (totalCombinations <= 2_000_000) {
+    return enumerateFreeSolutions(gauss, nCols, p, numFree, isBetter);
+  }
+
+  if (p === 2) {
+    return meetInTheMiddleBinary(gauss, nCols, numFree, isBetter);
+  }
+
+  // Branch and bound for large search spaces with p > 2
+  return branchAndBound(gauss, nCols, p, numFree, isBetter);
+}
+
+function enumerateFreeSolutions(
+  gauss: GaussResult,
+  nCols: number,
+  p: number,
+  numFree: number,
+  isBetter: Comparator
+): number[] {
+  let bestSolution: number[] | null = null;
+  let bestCost = Infinity;
+
+  const totalCombinations = Math.pow(p, numFree);
+  const assignment = new Array(numFree).fill(0);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    let temp = combo;
+    for (let i = numFree - 1; i >= 0; i--) {
+      assignment[i] = temp % p;
+      temp = Math.floor(temp / p);
+    }
+
+    const sol = computeSolution(gauss, nCols, p, assignment);
+    const cost = solutionCost(sol);
+
+    if (cost < bestCost || (cost === bestCost && bestSolution !== null && isBetter(sol, bestSolution))) {
+      bestCost = cost;
+      bestSolution = [...sol];
+    }
+  }
+
+  return bestSolution!;
+}
+
+function popcount(n: number): number {
+  n = n - ((n >> 1) & 0x55555555);
+  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);
+  n = (n + (n >> 4)) & 0x0f0f0f0f;
+  n = n + (n >> 8);
+  n = n + (n >> 16);
+  return n & 0x3f;
+}
+
+function meetInTheMiddleBinary(
+  gauss: GaussResult,
+  nCols: number,
+  numFree: number,
+  isBetter: Comparator
+): number[] {
+  const { aug, pivotCol, freeVars, rank } = gauss;
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+
+  // Precompute: for each pivot row, which free variables in each half affect it
+  const pivotInfo: { col: number; base: number; maskLow: number; maskHigh: number }[] = [];
+  for (let row = 0; row < rank; row++) {
+    const pc = pivotCol[row];
+    if (pc === -1) continue;
+    let maskLow = 0;
+    let maskHigh = 0;
+    for (let i = 0; i < half1; i++) {
+      if (aug[row][freeVars[i]] === 1) {
+        maskLow |= (1 << i);
+      }
+    }
+    for (let i = 0; i < half2; i++) {
+      if (aug[row][freeVars[half1 + i]] === 1) {
+        maskHigh |= (1 << i);
+      }
+    }
+    pivotInfo.push({ col: pc, base: aug[row][nCols], maskLow, maskHigh });
+  }
+
+  const nPivots = pivotInfo.length;
+
+  // For each sig2 value, store all (cost, f2) pairs grouped by cost
+  // sig2 -> Map<cost, f2[]>
+  const sig2Groups = new Map<number, Map<number, number[]>>();
+  const minCost2BySig2 = new Map<number, number>();
+
+  for (let f2 = 0; f2 < (1 << half2); f2++) {
+    let sig2 = 0;
+    for (let r = 0; r < nPivots; r++) {
+      if (popcount(f2 & pivotInfo[r].maskHigh) & 1) sig2 |= (1 << r);
+    }
+    const cost2 = popcount(f2);
+
+    if (!sig2Groups.has(sig2)) {
+      sig2Groups.set(sig2, new Map());
+      minCost2BySig2.set(sig2, cost2);
+    }
+    const costMap = sig2Groups.get(sig2)!;
+    if (!costMap.has(cost2)) {
+      costMap.set(cost2, []);
+    }
+    costMap.get(cost2)!.push(f2);
+
+    const mc = minCost2BySig2.get(sig2)!;
+    if (cost2 < mc) minCost2BySig2.set(sig2, cost2);
+  }
+
+  let baseSig = 0;
+  for (let r = 0; r < nPivots; r++) {
+    if (pivotInfo[r].base) baseSig |= (1 << r);
+  }
+
+  let bestCost = Infinity;
+  let bestSolution: number[] | null = null;
+
+  for (let f1 = 0; f1 < (1 << half1); f1++) {
+    let sig1 = 0;
+    for (let r = 0; r < nPivots; r++) {
+      if (popcount(f1 & pivotInfo[r].maskLow) & 1) sig1 |= (1 << r);
+    }
+
+    const effective = baseSig ^ sig1;
+    const cost1 = popcount(f1);
+
+    // Early prune: even with best possible f2 (cost2=0, pivotCost=0),
+    // can we beat bestCost?
+    if (cost1 >= bestCost) continue;
+
+    for (const [sig2, costMap] of sig2Groups) {
+      const pivotCost = popcount(effective ^ sig2);
+      const minC2 = minCost2BySig2.get(sig2)!;
+
+      // Lower bound for this sig2
+      if (cost1 + minC2 + pivotCost > bestCost) continue;
+
+      // Try each cost level
+      for (const [cost2, f2List] of costMap) {
+        const totalCost = cost1 + cost2 + pivotCost;
+        if (totalCost > bestCost) continue;
+
+        for (const f2 of f2List) {
+          const assignment = new Array(numFree).fill(0);
+          for (let i = 0; i < half1; i++) assignment[i] = (f1 >> i) & 1;
+          for (let i = 0; i < half2; i++) assignment[half1 + i] = (f2 >> i) & 1;
+          const sol = computeSolution(gauss, nCols, 2, assignment);
+
+          if (totalCost < bestCost || (bestSolution !== null && isBetter(sol, bestSolution))) {
+            bestCost = totalCost;
+            bestSolution = sol;
+          }
+        }
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function branchAndBound(
+  gauss: GaussResult,
+  nCols: number,
+  p: number,
+  numFree: number,
+  isBetter: Comparator
+): number[] {
+  let bestCost = Infinity;
+  let bestSolution: number[] | null = null;
+
+  // Start with the zero assignment to get an initial upper bound
+  const zeroAssignment = new Array(numFree).fill(0);
+  const zeroSol = computeSolution(gauss, nCols, p, zeroAssignment);
+  bestCost = solutionCost(zeroSol);
+  bestSolution = [...zeroSol];
+
+  const assignment = new Array(numFree).fill(0);
+
+  function search(depth: number, partialCost: number): void {
+    if (depth === numFree) {
+      const sol = computeSolution(gauss, nCols, p, assignment);
+      const cost = solutionCost(sol);
+      if (cost < bestCost || (cost === bestCost && bestSolution !== null && isBetter(sol, bestSolution))) {
+        bestCost = cost;
+        bestSolution = [...sol];
+      }
+      return;
+    }
+
+    // Lower bound: partialCost counts free vars assigned so far.
+    // Remaining free vars contribute at least 0 each.
+    // Pivot vars contribute at least 0 each.
+    // So lower bound = partialCost (plus pivot costs already determined).
+    // Actually, we can't easily compute a tight lower bound without
+    // knowing all free var values. Use partialCost as a weak bound.
+    if (partialCost >= bestCost) return;
+
+    for (let v = 0; v < p; v++) {
+      assignment[depth] = v;
+      search(depth + 1, partialCost + v);
+    }
+  }
+
+  search(0, 0);
+  return bestSolution!;
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const nLights = target.length;
+  const nButtons = buttons.length;
+
+  const augMatrix: number[][] = [];
+  for (let i = 0; i < nLights; i++) {
+    const row = new Array(nButtons + 1).fill(0);
+    for (let j = 0; j < nButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[nButtons] = target[i] ? 1 : 0;
+    augMatrix.push(row);
+  }
+
+  const solution = solveLinearSystemGF(augMatrix, nLights, nButtons, 2, toggleLexSmaller);
+  if (solution === null) return null;
+
+  const pressed: number[] = [];
+  for (let i = 0; i < nButtons; i++) {
+    if (solution[i] === 1) {
+      pressed.push(i);
+    }
+  }
+
+  return pressed;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const nCounters = lights.length;
+  const nButtons = buttons.length;
+
+  const augMatrix: number[][] = [];
+  for (let i = 0; i < nCounters; i++) {
+    const row = new Array(nButtons + 1).fill(0);
+    for (let j = 0; j < nButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[nButtons] = lights[i];
+    augMatrix.push(row);
+  }
+
+  const solution = solveLinearSystemGF(augMatrix, nCounters, nButtons, modulus, lexSmaller);
+  return solution;
+}
