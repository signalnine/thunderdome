r[][],\n  nRows: number,\n  nCols: number,\n  p: number\n): number[] | null {\n  // Deep copy the matrix\n  const aug = matrix.map(row => [...row]);\n\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(nRows).fill(-1);\n  const pivotRow: number[] = new Array(nCols).fill(-1);\n\n  let currentRow = 0;\n  for (let col = 0; col < nCols && currentRow < nRows; col++) {\n    // Find a row with non-zero entry in this column\n    let found = -1;\n    for (let row = currentRow; row < nRows; row++) {\n      if (aug[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue; // Free variable\n\n    // Swap rows\n    if (found !== currentRow) {\n      [aug[currentRow], aug[found]] = [aug[found], aug[currentRow]];\n    }\n\n    pivotCol[currentRow] = col;\n    pivotRow[col] = currentRow;\n\n    // Scale pivot row so pivot = 1\n    const inv = modInverse(aug[currentRow][col], p);\n    for (let j = col; j <= nCols; j++) {\n      aug[currentRow][j] = mod(aug[currentRow][j] * inv, p);\n    }\n\n    // Eliminate all other rows\n    for (let row = 0; row < nRows; row++) {\n      if (row === currentRow || aug[row][col] === 0) continue;\n      const factor = aug[row][col];\n      for (let j = col; j <= nCols; j++) {\n        aug[row][j] = mod(aug[row][j] - factor * aug[currentRow][j], p);\n      }\n    }\n\n    currentRow++;\n  }\n\n  // Check for inconsistency: any row with all zeros in A but non-zero in b\n  for (let row = currentRow; row < nRows; row++) {\n    if (aug[row][nCols] !== 0) return null;\n  }\n\n  // Identify free variables (columns without pivots)\n  const freeVars: number[] = [];\n  for (let col = 0; col < nCols; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // If no free variables, the solution is unique\n  if (numFree === 0) {\n    const solution = new Array(nCols).fill(0);\n    for (let row = 0; row < curre