+  // Create FTS5 virtual table for full-text search
+  db.exec(`
+    CREATE VIRTUAL TABLE IF NOT EXISTS fts_notes USING fts5(
+        title,
+        body,
+        id UNINDEXED
+    );
+  `);
+
+  // Triggers to keep fts_notes in sync with notes table
+  db.exec(`
+    CREATE TRIGGER IF NOT EXISTS fts_notes_ai AFTER INSERT ON notes BEGIN
+      INSERT INTO fts_notes (id, title, body) VALUES (new.id, new.title, new.body);
+    END;
+
+    CREATE TRIGGER IF NOT EXISTS fts_notes_ad AFTER DELETE ON notes BEGIN
+      DELETE FROM fts_notes WHERE id = old.id;
+    END;
+
+    CREATE TRIGGER IF NOT EXISTS fts_notes_au AFTER UPDATE ON notes BEGIN
+      UPDATE fts_notes SET title = new.title, body = new.body WHERE id = old.id;
+    END;
+  `);
+
+  // Populate FTS table with existing notes if it's empty (e.g., on first run)
+  db.exec(`
+    INSERT INTO fts_notes (id, title, body)
+    SELECT id, title, body FROM notes
+    WHERE NOT EXISTS (SELECT 1 FROM fts_notes WHERE fts_notes.id = notes.id);
+  `);
+
   return db;
