+  // Escape double quotes by doubling them
+  query = query.replace(/"/g, '""');
+
+  // If the query contains FTS5 operators or needs to be treated as a literal phrase,
+  // enclose it in double quotes.
+  // We need to be careful not to double quote an already double quoted phrase
+  if (query.startsWith('"') && query.endsWith('"')) {
+    return query;
+  }
+
+  const fts5Operators = ['AND', 'OR', 'NOT', 'NEAR', '-'];
+  const hasFTS5Operator = fts5Operators.some(op =>
+    new RegExp(`\\b${op}\\b`, 'i').test(query)
+  );
+
+  // If it contains operators, or other non-alphanumeric/space characters,
+  // enclose it in double quotes.
+  // Note: We deliberately allow ' " ' in the query string which is handled by the initial replace.
+  if (hasFTS5Operator || /[^a-zA-Z0-9\s"]/.test(query)) {
+    return `"${query}"`;
+  }
