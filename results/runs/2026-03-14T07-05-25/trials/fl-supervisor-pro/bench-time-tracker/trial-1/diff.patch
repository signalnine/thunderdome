+import { TimerManager } from './timerManager';
+import { TimeEntry } from './types';
+import { loadEntries } from './persistence';
+
+export class TimeTracker {
+  private timerManager: TimerManager;
+
+  // Private constructor to enforce using the static factory method
+  private constructor(timerManager: TimerManager) {
+    this.timerManager = timerManager;
+  }
+
+  /**
+   * Asynchronously creates and initializes a new TimeTracker instance.
+   * @param logFilePath The path to the JSON file for storing time entries. Defaults to './time-entries.json'.
+   * @returns A promise that resolves to an initialized TimeTracker instance.
+   */
+  public static async create(logFilePath: string = './time-entries.json'): Promise<TimeTracker> {
+    const initialEntries = await loadEntries(logFilePath);
+    const timerManager = new TimerManager(logFilePath); // TimerManager constructor is synchronous
+    await timerManager.initialize(initialEntries); // Initialize with loaded entries
+    return new TimeTracker(timerManager);
+  }
+
+  /**
+   * Starts a new timer for a given task.
+   * If a timer is already running, it will be stopped automatically.
+   * @param taskName The name of the task to time. Must not be empty.
+   * @throws Error if taskName is empty.
+   */
+  public async startTimer(taskName: string): Promise<void> {
+    await this.timerManager.startTimer(taskName);
+  }
+
+  /**
+   * Stops the currently running timer.
+   * @throws Error if no timer is currently running.
+   */
+  public async stopTimer(): Promise<void> {
+    await this.timerManager.stopTimer();
+  }
+
+  /**
+   * Retrieves all recorded time entries.
+   * @returns A promise that resolves to an array of TimeEntry objects.
+   */
+  public async getAllEntries(): Promise<TimeEntry[]> {
+    return this.timerManager.getAllEntries();
+  }
+
+  /**
+   * Retrieves time entries within a specified date range.
+   * @param startDate The start date of the range (inclusive).
+   * @param endDate The end date of the range (inclusive).
+   * @returns A promise that resolves to an array of TimeEntry objects.
+   */
+  public async getEntriesByDateRange(startDate: Date, endDate: Date): Promise<TimeEntry[]> {
+    return this.timerManager.getEntriesByDateRange(startDate, endDate);
+  }
+
+  /**
+   * Summarizes total time spent per task name.
+   * Running tasks are included with their duration up to the current time.
+   * @returns A promise that resolves to a Map where keys are task names and values are total time in milliseconds.
+   */
+  public async summarizeTime(): Promise<Map<string, number>> {
+    return this.timerManager.summarizeTime();
+  }
+}
