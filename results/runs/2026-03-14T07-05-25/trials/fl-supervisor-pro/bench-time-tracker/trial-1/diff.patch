+// tests/persistence.test.ts
+import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';
+import { TimeEntry } from '../src/types';
+import { loadEntries, saveEntries } from '../src/persistence';
+import fsMock from './__mocks__/fs'; // Import our custom fs mock
+
+// Mocking Date.now() to control time for tests
+const mockDate = new Date('2023-10-26T10:00:00.000Z');
+const originalDate = global.Date;
+
+vi.spyOn(global, 'Date').mockImplementation(() => mockDate as any);
+
+// Mocking crypto.randomUUID for potential future tests, though not strictly needed for persistence tests
+vi.mock('crypto', () => ({
+  randomUUID: vi.fn(() => 'mock-uuid-123'),
+}));
+
+describe('Persistence Module', () => {
+  const testFilePath = './test-data/time-entries.json';
+  const testDirPath = './test-data';
+
+  beforeEach(() => {
+    // Reset mocks before each test
+    vi.clearAllMocks();
+    // Reset the fs mock's internal state
+    (fsMock.promises.readFile as any).mockClear();
+    (fsMock.promises.writeFile as any).mockClear();
+    (fsMock.promises.access as any).mockClear();
+    (fsMock.promises.mkdir as any).mockClear();
+    // fsMock.resetMocks(); // If resetMocks is exposed on fsMock itself
+  });
+
+  afterEach(() => {
+    vi.restoreAllMocks();
+  });
+
+  it('saveEntries should write data to a JSON file and create directories', async () => {
+    const entries: TimeEntry[] = [
+      {
+        id: 'entry-1',
+        taskName: 'Task A',
+        startTime: new Date('2023-10-26T09:00:00.000Z'),
+        stopTime: new Date('2023-10-26T09:30:00.000Z'),
+      },
+      {
+        id: 'entry-2',
+        taskName: 'Task B',
+        startTime: new Date('2023-10-26T09:30:00.000Z'),
+        stopTime: null,
+      },
+    ];
+
+    await saveEntries(entries, testFilePath);
+
+    // Check if mkdir was called with recursive option for the directory
+    expect(fsMock.promises.mkdir).toHaveBeenCalledWith(testDirPath, { recursive: true });
+    // Check if writeFile was called with the correct path and JSON content
+    expect(fsMock.promises.writeFile).toHaveBeenCalledTimes(1);
+    const [filePathArg, fileContentArg] = (fsMock.promises.writeFile as any).mock.calls[0];
+    expect(filePathArg).toBe(testFilePath);
+    const expectedContent = JSON.stringify(
+      [
+        {
+          id: 'entry-1',
+          taskName: 'Task A',
+          startTime: '2023-10-26T09:00:00.000Z',
+          stopTime: '2023-10-26T09:30:00.000Z',
+        },
+        {
+          id: 'entry-2',
+          taskName: 'Task B',
+          startTime: '2023-10-26T09:30:00.000Z',
+          stopTime: null,
+        },
+      ],
+      null,
+      2
+    );
+    expect(fileContentArg).toBe(expectedContent);
+  });
+
+  it('loadEntries should return an empty array and create file if it does not exist', async () => {
+    // Ensure file does not exist in mock
+    (fsMock.promises.access as any).mockRejectedValueOnce(Object.assign(new Error('ENOENT'), { code: 'ENOENT' }));
+
+    const entries = await loadEntries(testFilePath);
+
+    expect(fsMock.promises.access).toHaveBeenCalledWith(testFilePath);
+    expect(fsMock.promises.mkdir).toHaveBeenCalledWith(testDirPath, { recursive: true });
+    expect(fsMock.promises.writeFile).toHaveBeenCalledWith(testFilePath, '[]', 'utf-8'); // Checks creation of empty file
+    expect(entries).toEqual([]);
+  });
+
+  it('loadEntries should return empty array if file is empty', async () => {
+    const emptyContent = '';
+    (fsMock.promises.readFile as any).mockResolvedValueOnce(emptyContent);
+    (fsMock.promises.access as any).mockResolvedValueOnce(undefined); // File exists
+
+    const entries = await loadEntries(testFilePath);
+
+    expect(fsMock.promises.readFile).toHaveBeenCalledWith(testFilePath, 'utf-8');
+    expect(entries).toEqual([]);
+  });
+
+  it('loadEntries should deserialize JSON data correctly including dates', async () => {
+    const mockFileContent = `[
+      {
+        "id": "entry-abc",
+        "taskName": "Existing Task",
+        "startTime": "2023-10-25T15:00:00.000Z",
+        "stopTime": "2023-10-25T16:00:00.000Z"
+      },
+      {
+        "id": "entry-def",
+        "taskName": "Running Task",
+        "startTime": "2023-10-26T08:00:00.000Z",
+        "stopTime": null
+      }
+    ]`;
+    (fsMock.promises.readFile as any).mockResolvedValueOnce(mockFileContent);
+    (fsMock.promises.access as any).mockResolvedValueOnce(undefined); // File exists
+
+    const entries = await loadEntries(testFilePath);
+
+    expect(entries.length).toBe(2);
+    expect(entries[0]).toEqual({
+      id: 'entry-abc',
+      taskName: 'Existing Task',
+      startTime: new Date('2023-10-25T15:00:00.000Z'),
+      stopTime: new Date('2023-10-25T16:00:00.000Z'),
+    });
+    expect(entries[1]).toEqual({
+      id: 'entry-def',
+      taskName: 'Running Task',
+      startTime: new Date('2023-10-26T08:00:00.000Z'),
+      stopTime: null,
+    });
+    // Verify Date objects
+    expect(entries[0].startTime).toBeInstanceOf(Date);
+    expect(entries[0].stopTime).toBeInstanceOf(Date);
+    expect(entries[1].startTime).toBeInstanceOf(Date);
+    expect(entries[1].stopTime).toBeNull();
+  });
+
+  it('loadEntries should handle errors other than ENOENT', async () => {
+    const genericError: any = new Error('Some other fs error');
+    genericError.code = 'EACCES';
+    (fsMock.promises.access as any).mockRejectedValueOnce(genericError);
+
+    await expect(loadEntries(testFilePath)).rejects.toThrow('Some other fs error');
+    expect(fsMock.promises.mkdir).not.toHaveBeenCalled();
+    expect(fsMock.promises.writeFile).not.toHaveBeenCalled();
+  });
+});
