+// tests/timeTracker.test.ts
+import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';
+import { TimeTracker } from '../src/index';
+import { TimerManager } from '../src/timerManager';
+import { loadEntries } from '../src/persistence'; // Mock this
+import { TimeEntry } from '../src/types';
+
+// Mock TimerManager and persistence.loadEntries
+vi.mock('../src/timerManager');
+vi.mock('../src/persistence');
+
+// Typed mocks
+const MockTimerManager = vi.mocked(TimerManager);
+const mockLoadEntries = vi.mocked(loadEntries);
+
+describe('TimeTracker (Public API)', () => {
+  const logFilePath = './test-log.json';
+  let timerManagerInstance: TimerManager; // Holds the mocked instance
+
+  beforeEach(() => {
+    vi.clearAllMocks();
+
+    // Create a mock TimerManager instance
+    // We need to mock the constructor call itself if TimeTracker creates it directly.
+    // But TimeTracker.create calls `new TimerManager(...)` and then `timerManager.initialize(...)`.
+    // So, we can mock the return value of the constructor or mock the methods directly if the instance is created elsewhere.
+    // Since TimeTracker uses `new TimerManager(logFilePath)` internally, we can mock the class itself.
+    timerManagerInstance = {
+      initialize: vi.fn().mockResolvedValue(undefined),
+      startTimer: vi.fn().mockResolvedValue(undefined),
+      stopTimer: vi.fn().mockResolvedValue(undefined),
+      getAllEntries: vi.fn().mockResolvedValue([]),
+      getEntriesByDateRange: vi.fn().mockResolvedValue([]),
+      summarizeTime: vi.fn().mockResolvedValue(new Map<string, number>()),
+    } as any as TimerManager; // Cast to TimerManager as it's a mock
+
+    // Configure the mock TimerManager constructor to return our mock instance
+    MockTimerManager.prototype.initialize.mockClear(); // Clear any previous mocks on the instance
+    MockTimerManager.prototype.initialize = timerManagerInstance.initialize; // Assign our mock methods
+    MockTimerManager.prototype.startTimer = timerManagerInstance.startTimer;
