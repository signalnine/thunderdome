+const mockFiles = new Map<string, string>();
+const mockDirs = new Set<string>();
+
+export const fs = {
+  promises: {
+    readFile: jest.fn(async (filePath: string, encoding: BufferEncoding): Promise<string> => {
+      if (!mockFiles.has(filePath)) {
+        const error: any = new Error(`ENOENT: no such file or directory, open '${filePath}'`);
+        error.code = 'ENOENT';
+        throw error;
+      }
+      return mockFiles.get(filePath)!;
+    }),
+    writeFile: jest.fn(async (filePath: string, data: string, encoding: BufferEncoding): Promise<void> => {
+      mockFiles.set(filePath, data);
+    }),
+    access: jest.fn(async (filePath: string): Promise<void> => {
+      if (!mockFiles.has(filePath)) {
+        const error: any = new Error(`ENOENT: no such file or directory, access '${filePath}'`);
+        error.code = 'ENOENT';
+        throw error;
+      }
+    }),
+    mkdir: jest.fn(async (dirPath: string, options?: { recursive?: boolean }): Promise<void> => {
+      if (options?.recursive) {
+        // Simulate recursive directory creation by adding a placeholder
+        // In a real scenario, you'd parse the path and add parent dirs too.
+        // For simplicity in mock, just mark as existing.
+        mockDirs.add(dirPath);
+      } else {
+        mockDirs.add(dirPath);
+      }
+    }),
+    // Add other fs.promises methods if needed for future tests
+  },
+  // Mocking sync methods if needed
+  // ...
+};
+
+// Helper to reset mocks before each test
+export const resetMocks = () => {
+  mockFiles.clear();
+  mockDirs.clear();
+  fs.promises.readFile.mockClear();
+  fs.promises.writeFile.mockClear();
+  fs.promises.access.mockClear();
+  fs.promises.mkdir.mockClear();
+};
+
+export default fs;
