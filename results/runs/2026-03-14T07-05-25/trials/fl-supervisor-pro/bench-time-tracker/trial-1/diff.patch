@@ -0,0 +1,151 @@
+import { TimeEntry } from './types';
+import { loadEntries, saveEntries } from './persistence';
+
+// Helper to check if a date falls within a range
+function isDateInRange(date: Date, startDate: Date, endDate: Date): boolean {
+  const startTime = startDate.getTime();
+  const endTime = endDate.getTime();
+  const targetTime = date.getTime();
+  return targetTime >= startTime && targetTime <= endTime;
+}
+
+export class TimerManager {
+  private logFilePath: string;
+  private allEntries: TimeEntry[] = [];
+  private currentTimer: TimeEntry | null = null;
+
+  // The constructor now only sets up the file path.
+  // Initialization (loading entries) must be done via the initialize method.
+  constructor(logFilePath: string) {
+    this.logFilePath = logFilePath;
+  }
+
+  /**
+   * Initializes the TimerManager with previously loaded entries.
+   * This method must be called after loading entries from persistence.
+   * @param initialEntries The array of TimeEntry objects loaded from storage.
+   */
+  public async initialize(initialEntries: TimeEntry[]): Promise<void> {
+    this.allEntries = initialEntries;
+    // Find the currently running timer from loaded entries
+    this.currentTimer = this.allEntries.find(entry => entry.stopTime === null) || null;
+  }
+
+  /**
+   * Starts a new timer for a given task.
+   * If a timer is already running, it will be stopped automatically.
+   * @param taskName The name of the task to time. Must not be empty.
+   * @throws Error if taskName is empty.
+   */
+  public async startTimer(taskName: string): Promise<void> {
+    if (!taskName || taskName.trim() === '') {
+      throw new Error('Task name cannot be empty.');
+    }
+
+    // If a timer is already running, stop it first
+    if (this.currentTimer) {
+      await this.stopTimer(); // This will also save the entries
+    }
+
+    const now = new Date();
+    const newEntry: TimeEntry = {
+      id: crypto.randomUUID(), // Use Node.js built-in crypto.randomUUID()
+      taskName: taskName.trim(),
+      startTime: now,
+      stopTime: null, // Timer is running
+    };
+
+    this.currentTimer = newEntry;
+    this.allEntries.push(newEntry);
+
+    await this.saveState();
+  }
+
+  /**
+   * Stops the currently running timer.
+   * @throws Error if no timer is currently running.
+   */
+  public async stopTimer(): Promise<void> {
+    if (!this.currentTimer) {
+      throw new Error('No timer is currently running.');
+    }
+
+    this.currentTimer.stopTime = new Date();
+    // Update the entry in the allEntries list
+    const index = this.allEntries.findIndex(entry => entry.id === this.currentTimer!.id);
+    if (index !== -1) {
+      this.allEntries[index] = this.currentTimer;
+    }
+
+    await this.saveState();
+    this.currentTimer = null; // Reset current timer
+  }
+
+  /**
+   * Retrieves all recorded time entries.
+   * @returns A promise that resolves to an array of TimeEntry objects.
+   */
+  public async getAllEntries(): Promise<TimeEntry[]> {
+    return [...this.allEntries]; // Return a copy to prevent external modification
+  }
+
+  /**
+   * Retrieves time entries within a specified date range.
+   * @param startDate The start date of the range (inclusive).
+   * @param endDate The end date of the range (inclusive).
+   * @returns A promise that resolves to an array of TimeEntry objects.
+   */
+  public async getEntriesByDateRange(startDate: Date, endDate: Date): Promise<TimeEntry[]> {
+    // Ensure endDate is inclusive by setting time to end of day
+    const inclusiveEndDate = new Date(endDate);
+    inclusiveEndDate.setHours(23, 59, 59, 999);
+
+    return this.allEntries.filter(entry =>
+      isDateInRange(entry.startTime, startDate, inclusiveEndDate)
+    );
+  }
+
+  /**
+   * Summarizes total time spent per task name.
+   * Running tasks are included with their duration up to the current time.
+   * @returns A promise that resolves to a Map where keys are task names and values are total time in milliseconds.
+   */
+  public async summarizeTime(): Promise<Map<string, number>> {
+    const summary = new Map<string, number>();
+    const now = new Date();
+
+    for (const entry of this.allEntries) {
+      let duration: number;
+      if (entry.stopTime === null && this.currentTimer && entry.id === this.currentTimer.id) {
+        // It's the currently running timer
+        duration = now.getTime() - entry.startTime.getTime();
+      } else if (entry.stopTime) {
+        // It's a completed timer
+        duration = entry.stopTime.getTime() - entry.startTime.getTime();
+      } else {
+        // This case should ideally not happen if currentTimer is managed correctly,
+        // but as a fallback, treat it as if it's running if stopTime is null.
+        // However, if it's not the *actual* currentTimer, something is wrong.
+        // Let's assume for now that only one entry can have stopTime === null.
+        // If an entry has stopTime === null but is NOT this.currentTimer,
+        // it implies data corruption or an issue with state management.
+        // For robustness, we'll treat it as a running timer if its stopTime is null.
+        duration = now.getTime() - entry.startTime.getTime();
+      }
+
+      if (duration > 0) {
+        const currentTotal = summary.get(entry.taskName) || 0;
+        summary.set(entry.taskName, currentTotal + duration);
+      }
+    }
+
+    return summary;
+  }
+
+  /**
+   * Saves the current state (all entries and potentially current timer state) to the log file.
+   */
+  private async saveState(): Promise<void> {
+    await saveEntries(this.allEntries, this.logFilePath);
+  }
+}
