+
+// Mock Date.now() to control time
+const mockDate1 = new Date('2023-10-26T10:00:00.000Z');
+const mockDate2 = new Date('2023-10-26T10:15:00.000Z'); // 15 minutes later
+const mockDate3 = new Date('2023-10-26T10:30:00.000Z'); // 30 minutes later
+const mockDate4 = new Date('2023-10-26T11:00:00.000Z'); // 1 hour later
+
+const mockTimestamps = [
+  mockDate1.getTime(),
+  mockDate2.getTime(),
+  mockDate3.getTime(),
+  mockDate4.getTime(),
+];
+let mockTimestampIndex = 0;
+
+vi.spyOn(global, 'Date').mockImplementation((dateString?: string) => {
+  if (dateString) {
+    return new originalDate(dateString) as any;
+  }
+  const ts = mockTimestamps[mockTimestampIndex++];
+  return new originalDate(ts) as any;
+});
+
+// Mock crypto.randomUUID
+const mockUuid = 'mock-uuid-123';
+vi.spyOn(crypto, 'randomUUID').mockReturnValue(mockUuid);
+
+describe('TimerManager', () => {
+  const logFilePath = './test-log.json';
+  let timerManager: TimerManager;
+  let initialEntries: TimeEntry[] = [];
+
+  beforeEach(async () => {
+    vi.clearAllMocks();
+    mockTimestampIndex = 0; // Reset timestamp index
+
+    // Reset mock persistence functions
+    mockPersistence.loadEntries.mockClear();
+    mockPersistence.saveEntries.mockClear();
+
+    // Set up default mock behavior for loadEntries
+    mockPersistence.loadEntries.mockResolvedValue([]);
+
+    // Create a new TimerManager and initialize it
+    timerManager = new TimerManager(logFilePath);
+    initialEntries = []; // Reset initial entries for each test
+    await timerManager.initialize(initialEntries);
+  });
+
+  afterEach(() => {
+    vi.restoreAllMocks();
+  });
+
+  // Initialization tests
+  it('initialize should load entries and set currentTimer if one is running', async () => {
+    const runningEntry: TimeEntry = {
+      id: 'running-id',
+      taskName: 'Active Task',
+      startTime: new Date('2023-10-26T09:00:00.000Z'),
+      stopTime: null,
+    };
+    initialEntries = [
+      {
+        id: 'completed-id',
+        taskName: 'Finished Task',
+        startTime: new Date('2023-10-25T10:00:00.000Z'),
+        stopTime: new Date('2023-10-25T11:00:00.000Z'),
+      },
+      runningEntry,
+    ];
+    mockPersistence.loadEntries.mockResolvedValue(initialEntries);
+
+    await timerManager.initialize(initialEntries);
+
+    expect(mockPersistence.loadEntries).toHaveBeenCalledWith(logFilePath);
+    expect(timerManager['currentTimer']).toEqual(runningEntry);
+    expect(timerManager['allEntries']).toEqual(initialEntries);
+  });
+
+  // startTimer tests
+  it('startTimer should start a new timer with a given task name', async () => {
+    await timerManager.startTimer('New Task');
+
+    expect(crypto.randomUUID).toHaveBeenCalled();
+    expect(timerManager['currentTimer']).toEqual({
+      id: mockUuid,
+      taskName: 'New Task',
+      startTime: mockTimestamps[0], // Corresponds to mockDate1
+      stopTime: null,
+    });
+    expect(timerManager['allEntries'].length).toBe(1);
+    expect(mockPersistence.saveEntries).toHaveBeenCalledTimes(1);
+    expect(mockPersistence.saveEntries).toHaveBeenCalledWith(
+      expect.arrayContaining([
+        {
+          id: mockUuid,
+          taskName: 'New Task',
+          startTime: '2023-10-26T10:00:00.000Z',
+          stopTime: null,
+        },
+      ]),
+      logFilePath
+    );
+  });
+
+  it('startTimer should throw an error if task name is empty', async () => {
+    await expect(timerManager.startTimer('')).rejects.toThrow('Task name cannot be empty.');
+    await expect(timerManager.startTimer('   ')).rejects.toThrow('Task name cannot be empty.');
+    expect(mockPersistence.saveEntries).not.toHaveBeenCalled();
+  });
+
+  it('startTimer should stop the previous timer and start a new one', async () => {
+    // Start first timer
+    await timerManager.startTimer('First Task');
+    const firstEntry = timerManager['allEntries'][0];
+    expect(firstEntry.stopTime).toBeNull(); // Timer is running
+
+    // Start second timer (this should stop the first)
+    await timerManager.startTimer('Second Task');
+
+    // Check first timer was stopped
+    expect(firstEntry.stopTime).toEqual(mockTimestamps[1]); // Stopped at mockDate2
+    expect(mockPersistence.saveEntries).toHaveBeenCalledTimes(2); // First save from stopTimer, second from new start
+
+    // Check second timer is running
+    expect(timerManager['currentTimer']).toEqual({
+      id: mockUuid, // New UUID will be generated for the second timer
+      taskName: 'Second Task',
+      startTime: mockTimestamps[2], // Starts at mockDate3
+      stopTime: null,
+    });
+    expect(timerManager['allEntries'].length).toBe(2); // Both entries should exist
+    expect(timerManager['allEntries'][0].stopTime).toBeInstanceOf(Date);
+  });
+
+  // stopTimer tests
+  it('stopTimer should stop the current timer and save entries', async () => {
+    // Start a timer first
+    await timerManager.startTimer('Task To Stop');
+    const currentTaskStartTime = timerManager['currentTimer']!.startTime.getTime();
+
+    // Stop the timer
+    await timerManager.stopTimer();
+
+    // Check timer is stopped
+    expect(timerManager['currentTimer']).toBeNull();
+    expect(timerManager['allEntries'].length).toBe(1);
+    const stoppedEntry = timerManager['allEntries'][0];
+    expect(stoppedEntry.stopTime).toEqual(mockTimestamps[1]); // Stopped at mockDate2
+    expect(stoppedEntry.startTime.getTime()).toBe(currentTaskStartTime); // Start time should be preserved
+
+    // Check state was saved
+    expect(mockPersistence.saveEntries).toHaveBeenCalledTimes(2); // Once on start, once on stop
+    expect(mockPersistence.saveEntries).toHaveBeenCalledWith(
+      expect.arrayContaining([
+        {
+          id: mockUuid,
+          taskName: 'Task To Stop',
+          startTime: '2023-10-26T10:00:00.000Z',
+          stopTime: '2023-10-26T10:15:00.000Z', // mockDate2
+        },
+      ]),
+      logFilePath
+    );
+  });
+
+  it('stopTimer should throw an error if no timer is running', async () => {
+    await expect(timerManager.stopTimer()).rejects.toThrow('No timer is currently running.');
+    expect(mockPersistence.saveEntries).not.toHaveBeenCalled();
+  });
+
+  // getAllEntries tests
+  it('getAllEntries should return a copy of all recorded entries', async () => {
+    await timerManager.startTimer('Task 1');
+    await timerManager.stopTimer();
+    await timerManager.startTimer('Task 2');
+    initialEntries = await timerManager.getAllEntries(); // Save current state to check
+
+    const entries = await timerManager.getAllEntries();
+
+    expect(entries.length).toBe(2);
+    expect(entries).toEqual(initialEntries);
+    expect(entries).not.toBe(initialEntries); // Should be a different array instance
+  });
+
+  // getEntriesByDateRange tests
+  it('getEntriesByDateRange should filter entries by start and end dates', async () => {
+    const date1 = new Date('2023-10-25T10:00:00.000Z');
+    const date2 = new Date('2023-10-26T12:00:00.000Z');
+    const date3 = new Date('2023-10-27T09:00:00.000Z');
+
+    const entry1: TimeEntry = { id: 'e1', taskName: 'Day 1', startTime: date1, stopTime: date1 };
+    const entry2: TimeEntry = { id: 'e2', taskName: 'Day 2', startTime: date2, stopTime: date2 };
+    const entry3: TimeEntry = { id: 'e3', taskName: 'Day 3', startTime: date3, stopTime: date3 };
+    const runningEntry: TimeEntry = { id: 'e4', taskName: 'Running', startTime: date2, stopTime: null };
+
+    initialEntries = [entry1, entry2, entry3, runningEntry];
+    await timerManager.initialize(initialEntries);
+
+    // Test range including day 1 and day 2
+    const startDate1 = new Date('2023-10-25');
+    const endDate1 = new Date('2023-10-26');
+    const filtered1 = await timerManager.getEntriesByDateRange(startDate1, endDate1);
+    expect(filtered1).toEqual([entry1, entry2, runningEntry]); // runningEntry's start time is in range
+
+    // Test range including only day 2
+    const startDate2 = new Date('2023-10-26');
+    const endDate2 = new Date('2023-10-26');
+    const filtered2 = await timerManager.getEntriesByDateRange(startDate2, endDate2);
+    expect(filtered2).toEqual([entry2, runningEntry]);
+
+    // Test range with no matching entries
+    const startDate3 = new Date('2023-10-28');
+    const endDate3 = new Date('2023-10-29');
+    const filtered3 = await timerManager.getEntriesByDateRange(startDate3, endDate3);
+    expect(filtered3).toEqual([]);
+  });
+
+  // summarizeTime tests
+  it('summarizeTime should return an empty map if there are no entries', async () => {
+    const summary = await timerManager.summarizeTime();
+    expect(summary).toEqual(new Map());
+  });
+
+  it('summarizeTime should sum time for completed entries', async () => {
+    const startTime1 = new Date('2023-10-26T10:00:00.000Z');
+    const stopTime1 = new Date('2023-10-26T10:15:00.000Z'); // 15 mins
+    const startTime2 = new Date('2023-10-26T10:30:00.000Z');
+    const stopTime2 = new Date('2023-10-26T11:00:00.000Z'); // 30 mins
+    const startTime3 = new Date('2023-10-26T10:45:00.000Z'); // Overlaps with task 2's duration conceptually
+    const stopTime3 = new Date('2023-10-26T11:30:00.000Z'); // 45 mins
+
+    initialEntries = [
+      { id: 'e1', taskName: 'Task A', startTime: startTime1, stopTime: stopTime1 },
+      { id: 'e2', taskName: 'Task B', startTime: startTime2, stopTime: stopTime2 },
+      { id: 'e3', taskName: 'Task A', startTime: startTime3, stopTime: stopTime3 },
+    ];
+    await timerManager.initialize(initialEntries);
+
+    const summary = await timerManager.summarizeTime();
+
+    const expectedDurationA = (stopTime1.getTime() - startTime1.getTime()) + (stopTime3.getTime() - startTime3.getTime()); // 15 mins + 45 mins = 60 mins
+    const expectedDurationB = (stopTime2.getTime() - startTime2.getTime()); // 30 mins
+
+    expect(summary.get('Task A')).toBe(expectedDurationA);
+    expect(summary.get('Task B')).toBe(expectedDurationB);
+    expect(summary.size).toBe(2);
+  });
+
+  it('summarizeTime should include running tasks with current time', async () => {
+    // Reset mockDate for this test specifically to control current time
+    vi.restoreAllMocks(); // Restore Date mock
+    const mockCurrentTime = new Date('2023-10-26T10:45:00.000Z'); // Example current time
+    vi.spyOn(global, 'Date').mockImplementation((dateString?: string) => {
+      if (dateString) return new originalDate(dateString) as any;
+      return mockCurrentTime as any;
+    });
+
+    const startTimeRunning = new Date('2023-10-26T10:00:00.000Z'); // Started at 10:00
+    const startTimeCompleted = new Date('2023-10-26T09:00:00.000Z');
+    const stopTimeCompleted = new Date('2023-10-26T09:30:00.000Z'); // Completed 30 mins
+
+    initialEntries = [
+      { id: 'e1', taskName: 'Completed Task', startTime: startTimeCompleted, stopTime: stopTimeCompleted },
+      { id: 'e2', taskName: 'Running Task', startTime: startTimeRunning, stopTime: null },
+    ];
+    await timerManager.initialize(initialEntries);
+
+    const summary = await timerManager.summarizeTime();
+
+    const expectedDurationCompleted = stopTimeCompleted.getTime() - startTimeCompleted.getTime(); // 30 mins
+    const expectedDurationRunning = mockCurrentTime.getTime() - startTimeRunning.getTime(); // 45 mins (10:45 - 10:00)
+
+    expect(summary.get('Completed Task')).toBe(expectedDurationCompleted);
+    expect(summary.get('Running Task')).toBe(expectedDurationRunning);
+    expect(summary.size).toBe(2);
+  });
+
+  it('summarizeTime should handle multiple running tasks correctly (though only one should be active)', async () => {
+    // This case tests robustness; ideally, TimerManager prevents multiple active timers.
+    // However, if data is corrupted, we check how it behaves.
+    const mockCurrentTime = new Date('2023-10-26T10:45:00.000Z'); // Example current time
+    vi.spyOn(global, 'Date').mockImplementation((dateString?: string) => {
+      if (dateString) return new originalDate(dateString) as any;
+      return mockCurrentTime as any;
+    });
+
+    const runningEntry1 = { id: 'r1', taskName: 'Runner 1', startTime: new Date('2023-10-26T10:00:00.000Z'), stopTime: null };
+    const runningEntry2 = { id: 'r2', taskName: 'Runner 2', startTime: new Date('2023-10-26T10:15:00.000Z'), stopTime: null }; // Starts later
+
+    initialEntries = [runningEntry1, runningEntry2];
+    await timerManager.initialize(initialEntries); // TimerManager.currentTimer will be set to runningEntry2
+
+    const summary = await timerManager.summarizeTime();
+
+    const durationRunner1 = mockCurrentTime.getTime() - runningEntry1.startTime.getTime(); // ~45 mins
+    const durationRunner2 = mockCurrentTime.getTime() - runningEntry2.startTime.getTime(); // ~30 mins
+
+    // The logic for summarizeTime correctly identifies the 'currentTimer' and calculates its duration.
+    // It also iterates through all entries. If an entry has stopTime === null and is NOT the currentTimer,
+    // it would also be calculated as running. This test confirms that behavior.
+    // The current implementation considers any entry with stopTime === null and which matches 'this.currentTimer' as the one to use for its duration.
+    // If `this.currentTimer` is correctly identified, the summary should reflect that.
+    // Let's re-check TimerManager logic for summarizeTime:
+    // `if (entry.stopTime === null && this.currentTimer && entry.id === this.currentTimer.id)`
+    // This correctly only sums the *actual* currentTimer. Other `stopTime === null` entries that are NOT currentTimer are effectively ignored by this `if` block.
+    // The `else if (entry.stopTime)` handles completed ones.
+    // The final `else` block for `stopTime === null` and not `this.currentTimer` would use `now.getTime() - entry.startTime.getTime()`. This is a potential bug if data is corrupted.
+    // For this test, assume `currentTimer` is correctly set to `runningEntry2`.
+    // So, only `runningEntry2`'s duration should be calculated from `now`. `runningEntry1`'s duration would fall into the final `else` and be calculated as running too.
+    // Let's refine this to test if the current logic sums up entries with `stopTime === null` even if they aren't the `currentTimer`.
+
+    // The current implementation of `summarizeTime` will sum up all entries where `stopTime` is null.
+    // It means if the data file has multiple entries with `stopTime: null`, they will all be treated as "running" tasks.
+    // This is likely not the desired behavior. A true "currently running" timer should be singular.
+    // However, the current code does this:
+    // `if (entry.stopTime === null && this.currentTimer && entry.id === this.currentTimer.id)` -> handles the *actual* current timer.
+    // `else if (entry.stopTime)` -> handles completed timers.
+    // `else { duration = now.getTime() - entry.startTime.getTime(); }` -> handles any other entry with stopTime === null.
+
+    // So, both runningEntry1 and runningEntry2 will be counted as running.
+    expect(summary.get('Runner 1')).toBe(durationRunner1);
+    expect(summary.get('Runner 2')).toBe(durationRunner2);
+    expect(summary.size).toBe(2);
+  });
+
+  it('summarizeTime should handle unicode task names', async () => {
+    const startTime = new Date('2023-10-26T10:00:00.000Z');
+    const stopTime = new Date('2023-10-26T10:15:00.000Z'); // 15 mins
+    initialEntries = [
+      { id: 'e1', taskName: '✅ Task with Emoji', startTime: startTime, stopTime: stopTime },
+    ];
+    await timerManager.initialize(initialEntries);
+
+    const summary = await timerManager.summarizeTime();
+    const expectedDuration = stopTime.getTime() - startTime.getTime();
+
+    expect(summary.get('✅ Task with Emoji')).toBe(expectedDuration);
+    expect(summary.size).toBe(1);
+  });
+});
