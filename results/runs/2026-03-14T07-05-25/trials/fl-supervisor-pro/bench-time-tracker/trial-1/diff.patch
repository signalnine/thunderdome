@@ -0,0 +1,62 @@
+import fs from 'fs/promises';
+import path from 'path';
+import { TimeEntry } from './types';
+
+// Helper to convert Date objects to ISO strings for JSON serialization
+function serializeTimeEntry(entry: TimeEntry): any {
+  return {
+    ...entry,
+    startTime: entry.startTime.toISOString(),
+    stopTime: entry.stopTime ? entry.stopTime.toISOString() : null,
+  };
+}
+
+// Helper to convert ISO strings back to Date objects after JSON deserialization
+function deserializeTimeEntry(entry: any): TimeEntry {
+  return {
+    ...entry,
+    startTime: new Date(entry.startTime),
+    stopTime: entry.stopTime ? new Date(entry.stopTime) : null,
+  };
+}
+
+/**
+ * Loads time entries from a JSON file.
+ * Creates the file and its parent directories if they don't exist, returning an empty array.
+ * @param filePath The path to the JSON file.
+ * @returns A promise that resolves to an array of TimeEntry objects.
+ */
+export async function loadEntries(filePath: string): Promise<TimeEntry[]> {
+  const dirPath = path.dirname(filePath);
+  try {
+    await fs.access(filePath); // Check if file exists
+    const fileContent = await fs.readFile(filePath, 'utf-8');
+    if (!fileContent) {
+      return [];
+    }
+    const entriesData = JSON.parse(fileContent);
+    return entriesData.map(deserializeTimeEntry);
+  } catch (error: any) {
+    if (error.code === 'ENOENT') {
+      // File or directory does not exist, create it and return empty
+      await fs.mkdir(dirPath, { recursive: true });
+      await fs.writeFile(filePath, '[]', 'utf-8');
+      return [];
+    }
+    // Rethrow other errors
+    throw error;
+  }
+}
+
+/**
+ * Saves an array of time entries to a JSON file.
+ * Creates parent directories if they don't exist.
+ * @param entries The array of TimeEntry objects to save.
+ * @param filePath The path to the JSON file.
+ */
+export async function saveEntries(entries: TimeEntry[], filePath: string): Promise<void> {
+  const dirPath = path.dirname(filePath);
+  await fs.mkdir(dirPath, { recursive: true }); // Ensure directory exists
+  const serializedEntries = entries.map(serializeTimeEntry);
+  await fs.writeFile(filePath, JSON.stringify(serializedEntries, null, 2), 'utf-8');
+}
