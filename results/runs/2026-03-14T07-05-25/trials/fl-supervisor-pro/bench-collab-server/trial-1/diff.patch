+import express from 'express';
+import http from 'http';
+import WebSocket from 'ws';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid'; // Using uuid for robust ID generation
+
+// --- Interfaces ---
+interface Document {
+    id: string;
+    title: string;
+    content: string;
+    version: number;
+}
+
+interface Operation {
+    type: 'insert' | 'delete';
+    documentId: string;
+    version: number; // The version of the document *before* this operation was applied by the client
+    userId: string;
+    // For insert:
+    text?: string;
+    position?: number; // Position to insert text
+    // For delete:
+    length?: number; // Number of characters to delete
+    positionToDelete?: number; // Position to start deletion
+}
+
+interface DocumentState {
+    title: string;
+    content: string;
+    version: number;
+}
+
+interface ClientWebSocket extends WebSocket {
+    documentId?: string;
+    userId: string; // Simple user ID for now
+}
+
+// --- OT / CRDT Related Types and Functions ---
+
+// Represents a single operation for transformation purposes
+interface TransformationOperation {
+    type: 'insert' | 'delete';
+    documentId: string;
+    // Server-side derived info
+    version: number; // The version *after* this operation was applied
+    userId: string;
+    originalOperation: Operation; // The operation as received from client
+    // Resolved content/position based on server's current state
+    text?: string;
+    position: number; // Position in the document
+    length?: number;
+}
+
+// Helper to fetch historical operations between two versions for a document
+function fetchOperationsBetweenVersions(db: Database, documentId: string, startVersion: number, endVersion: number): TransformationOperation[] {
+    const ops = db.prepare(`
+        SELECT version, operation FROM document_history
+        WHERE document_id = ? AND version > ? AND version <= ?
+        ORDER BY version ASC
+    `).all({ document_id: documentId, startVersion: startVersion, endVersion: endVersion });
+
+    return ops.map(op => {
+        const parsedOp = JSON.parse(op.operation) as Operation;
+        // For OT, we need to resolve positions relative to the state *after* the previous version,
+        // and before the current version. This is simplified here by directly using the parsed op.
+        // A true OT system might need more granular state to resolve positions precisely.
+        return {
+            type: parsedOp.type,
+            documentId: parsedOp.documentId,
+            version: op.version, // This is the version *after* this operation
+            userId: parsedOp.userId,
+            originalOperation: parsedOp,
+            text: parsedOp.text,
+            position: parsedOp.type === 'insert' ? parsedOp.position! : parsedOp.positionToDelete!,
+            length: parsedOp.length,
+        };
+    });
+}
+
+// --- Core OT Transformation Logic ---
+// This is a simplified OT logic. A full-fledged OT system is complex.
+// It needs to correctly transform insert/delete operations against each other.
+
+// Transforms an operation `opToTransform` against another operation `otherOp`.
+// Returns a new operation that is equivalent to `opToTransform` but adjusted
+// to account for `otherOp`.
+// Returns null if `opToTransform` is invalidated by `otherOp`.
+function transformOperation(opToTransform: Operation, otherOp: TransformationOperation): Operation | null {
+    if (opToTransform.documentId !== otherOp.documentId) {
+        return opToTransform; // No transformation needed for different documents
+    }
+
+    // We only transform operations that are sequential relative to the otherOp's version.
+    // If otherOp.version <= opToTransform.version, then otherOp happened before or at the same time
+    // as the state opToTransform was created from, so we need to transform.
+
+    if (opToTransform.type === 'insert') {
+        if (otherOp.type === 'insert') {
+            // If both are inserts:
+            // - If otherOp inserts before opToTransform's position, adjust opToTransform's position
+            // - If otherOp inserts at the same position, opToTransform's position is increased by otherOp's length
+            if (otherOp.position! < opToTransform.position!) {
+                return { ...opToTransform, position: opToTransform.position! + (otherOp.text?.length || 0) };
+            } else if (otherOp.position! === opToTransform.position!) {
+                // Insert at the same position, otherOp's text comes first (or is interleaved based on user ID, if stable)
+                // For simplicity, let's assume server-side insertion order for same position.
+                // If otherOp is applied first, then opToTransform's position increases.
+                 return { ...opToTransform, position: opToTransform.position! + (otherOp.text?.length || 0) };
+            }
+            // Otherwise, otherOp is after opToTransform's position, no adjustment needed.
+            return opToTransform;
+
+        } else if (otherOp.type === 'delete') {
+            // If otherOp is a delete:
+            // - If otherOp deletes opToTransform's insertion position, opToTransform might be invalidated or shifted.
+            // - If otherOp deletes *before* opToTransform's position, shift opToTransform's position back by delete length.
+            // - If otherOp deletes *at* opToTransform's position, opToTransform's insertion is now at a different spot.
+            const deleteStart = otherOp.positionToDelete!;
+            const deleteEnd = deleteStart + (otherOp.length || 0);
+            const insertPos = opToTransform.position!;
+
+            if (insertPos < deleteStart) {
+                // Insert position is before the delete range, shift insert position back.
+                return { ...opToTransform, position: insertPos - (otherOp.length || 0) };
+            } else if (insertPos >= deleteStart && insertPos < deleteEnd) {
+                // Insert position is within the delete range. This insertion is effectively deleted.
+                return null; // Operation invalidated
+            } else if (insertPos === deleteEnd) {
+                // Insert position is exactly at the end of the delete range.
+                // The insertion point is now at the start of where the deleted text was.
+                return { ...opToTransform, position: deleteStart };
+            }
+            // Otherwise, insert position is after the delete range, no adjustment needed.
+            return opToTransform;
+        }
+    } else if (opToTransform.type === 'delete') {
+        if (otherOp.type === 'insert') {
+            // If opToTransform (delete) is affected by otherOp (insert):
+            // - If otherOp inserts *before* opToTransform's delete start position, adjust delete start position.
+            // - If otherOp inserts *within* opToTransform's delete range, the delete range might shrink or shift.
+            const deleteStart = opToTransform.positionToDelete!;
+            const deleteLength = opToTransform.length!;
+            const insertPos = otherOp.position!;
+            const insertLength = otherOp.text?.length || 0;
+
+            if (insertPos < deleteStart) {
+                // Insert is before delete range. Adjust delete start position.
+                return { ...opToTransform, positionToDelete: deleteStart + insertLength };
+            } else if (insertPos >= deleteStart && insertPos < deleteStart + deleteLength) {
+                // Insert is within delete range. The effective delete length decreases.
+                return { ...opToTransform, length: deleteLength - insertLength };
+            } else if (insertPos === deleteStart + deleteLength) {
+                // Insert is exactly at the end of delete range. Delete range doesn't change.
+                return opToTransform;
+            }
+            // Insert is after delete range, no adjustment needed.
+            return opToTransform;
+
+        } else if (otherOp.type === 'delete') {
+            // If both are deletes:
+            // - If ranges don't overlap, no adjustment.
+            // - If they overlap, adjust delete start and length.
+            const delete1Start = opToTransform.positionToDelete!;
+            const delete1Length = opToTransform.length!;
+            const delete1End = delete1Start + delete1Length;
+
+            const delete2Start = otherOp.positionToDelete!;
+            const delete2Length = otherOp.length!;
+            const delete2End = delete2Start + delete2Length;
+
+            // No overlap
+            if (delete1End <= delete2Start || delete2End <= delete1Start) {
+                return opToTransform;
+            }
+
+            // Overlap exists
+            const overlapStart = Math.max(delete1Start, delete2Start);
+            const overlapEnd = Math.min(delete1End, delete2End);
+            const overlapLength = overlapEnd - overlapStart;
+
+            // If delete1 starts before delete2, and they overlap
+            if (delete1Start < delete2Start) {
+                // The portion of delete1 before delete2 remains.
+                // The portion of delete1 within delete2 is effectively removed from delete1's scope.
+                // If delete1 extends beyond delete2, the remaining part after delete2 is unaffected.
+                const newLength = (overlapStart - delete1Start) + Math.max(0, delete1End - delete2End);
+                if (newLength <= 0) return null; // Entire delete1 range was covered by delete2
+                return { ...opToTransform, length: newLength };
+            } else if (delete1Start > delete2Start) {
+                // If delete1 starts after delete2, and they overlap
+                // The portion of delete1 that was *before* delete2 is now also deleted by delete2.
+                // So, delete1's start position shifts.
+                const shiftAmount = Math.min(delete2Length, delete1Start - delete2Start);
+                const newStart = delete1Start - shiftAmount;
+                const newLength = delete1Length - shiftAmount;
+                if (newLength <= 0) return null; // Entire delete1 range was covered by delete2
+                return { ...opToTransform, positionToDelete: newStart, length: newLength };
+            } else { // delete1Start === delete2Start
+                // If starts are the same, the longer delete "wins".
+                const newLength = Math.max(delete1Length, delete2Length) - delete1Length; // This is wrong, should be max of lengths
+                // The new length should be the maximum of the two lengths, starting from the same point.
+                const finalLength = Math.max(delete1Length, delete2Length);
+                if (finalLength === 0) return null;
+                return { ...opToTransform, length: finalLength };
+            }
+        }
+    }
+    return opToTransform; // Default: no transformation if logic doesn't apply or is too complex
+}
+
+
+export function createApp(dbPath: string = ':memory:') {
+    const app = express();
+    const server = http.createServer(app);
+    const wss = new WebSocket.Server({ noServer: true }); // Use noServer to manage manually
+
+    const db = new Database(dbPath);
+
+    // Setup database schema
+    db.exec(`
+        CREATE TABLE IF NOT EXISTS documents (
+            id TEXT PRIMARY KEY,
+            title TEXT NOT NULL,
+            content TEXT NOT NULL DEFAULT '',
+            version INTEGER NOT NULL DEFAULT 0
+        );
+        CREATE TABLE IF NOT EXISTS document_history (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            document_id TEXT NOT NULL,
+            version INTEGER NOT NULL, -- Version of the document *after* this operation was applied
+            operation TEXT NOT NULL, -- JSON string of the operation
+            timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
+            FOREIGN KEY (document_id) REFERENCES documents(id)
+        );
+    `);
+
+    // Middleware for JSON parsing
+    app.use(express.json());
+
+    // --- REST API for Document Management ---
+
+    // List all documents
+    app.get('/documents', (req, res) => {
+        const docs = db.prepare('SELECT id, title FROM documents').all();
+        res.json(docs);
+    });
+
+    // Create a new document
+    app.post('/documents', (req, res) => {
+        const { title, content = '' } = req.body;
+        if (!title) {
+            return res.status(400).json({ error: 'Title is required' });
+        }
+        const id = uuidv4(); // Use uuid for better ID generation
+        const stmt = db.prepare('INSERT INTO documents (id, title, content, version) VALUES (?, ?, ?, 0)');
+        stmt.run(id, title, content);
+        res.status(201).json({ id, title, content, version: 0 });
+    });
+
+    // Get a specific document
+    app.get('/documents/:id', (req, res) => {
+        const { id } = req.params;
+        const doc = db.prepare('SELECT id, title, content, version FROM documents WHERE id = ?').get({ id });
+        if (!doc) {
+            return res.status(404).json({ error: 'Document not found' });
+        }
+        res.json(doc);
+    });
+
+    // Update a document (title and content) - This would typically be handled via operations on WebSocket
+    // For simplicity, this PUT endpoint allows direct replacement, but for real-time collaboration,
+    // edits should come through WebSocket and be applied via OT.
+    // This endpoint might be used for initial creation or bulk updates, not real-time edits.
+    app.put('/documents/:id', (req, res) => {
+        const { id } = req.params;
+        const { title, content } = req.body;
+
+        const updateFields: string[] = [];
+        const params: { [key: string]: any } = { id };
+
+        if (title !== undefined) {
+            updateFields.push('title = ?');
+            params['title'] = title;
+        }
+        if (content !== undefined) {
+            updateFields.push('content = ?');
+            params['content'] = content;
+            // When content is directly updated, we might want to reset version or create a new history entry.
+            // For now, we'll just update content and not manage versioning via this PUT.
+            // A proper OT/CRDT would handle versioning.
+        }
+
+        if (updateFields.length === 0) {
+            return res.status(400).json({ error: 'No fields to update' });
+        }
+
+        // Construct the SQL statement dynamically
+        const query = `UPDATE documents SET ${updateFields.join(', ')} WHERE id = ?`;
+        const stmt = db.prepare(query);
+        const result = stmt.run(params);
+        if (result.changes === 0) {
+            return res.status(404).json({ error: 'Document not found' });
+        }
+        // Fetch the updated document to return
+        const updatedDoc = db.prepare('SELECT id, title, content, version FROM documents WHERE id = ?').get({ id });
+        res.json(updatedDoc);
+    });
+
+    // Delete a document
+    app.delete('/documents/:id', (req, res) => {
+        const { id } = req.params;
+        const stmt = db.prepare('DELETE FROM documents WHERE id = ?');
+        const result = stmt.run({ id });
+        if (result.changes === 0) {
+            return res.status(404).json({ error: 'Document not found' });
+        }
+        res.status(204).send();
+    });
+
+    // Get document version history
+    app.get('/documents/:id/history', (req, res) => {
+        const { id } = req.params;
+        const history = db.prepare('SELECT id, version, operation, timestamp FROM document_history WHERE document_id = ? ORDER BY version ASC').all({ document_id: id });
+        res.json(history.map(h => ({ ...h, operation: JSON.parse(h.operation) })));
+    });
+
+    // --- WebSocket Handling ---
+    wss.on('connection', (ws: ClientWebSocket, req) => {
+        // Extract documentId from URL: e.g., ws://localhost:8080/ws/doc-id
+        const url = new URL(req.url!, `ws://\${req.headers.host}`);
+        const docId = url.pathname.split('/')[2]; // Assuming path is /ws/:docId
+        const userId = `user_\${uuidv4()}`; // Use uuid for better user ID generation
+
+        if (!docId) {
+            console.error('WebSocket connection error: Document ID is required.');
+            ws.close(1008, 'Document ID is required');
+            return;
+        }
+
+        ws.documentId = docId;
+        ws.userId = userId;
+
+        // Check if document exists
+        const docExists = db.prepare('SELECT id FROM documents WHERE id = ?').get({ id: docId });
+        if (!docExists) {
+            console.error(`WebSocket connection error: Document ${docId} not found for client ${userId}.`);
+            ws.close(1011, 'Document not found');
+            return;
+        }
+
+        console.log(`Client ${userId} connected to document ${docId}`);
+
+        // Send initial document state
+        const doc = db.prepare('SELECT id, title, content, version FROM documents WHERE id = ?').get({ id: docId });
+        ws.send(JSON.stringify({ type: 'doc_sync', payload: { ...doc, userId } }));
+
+        // Handle messages from clients
+        ws.on('message', (message: string) => {
+            let operation: Operation;
+            try {
+                operation = JSON.parse(message) as Operation;
+            } catch (jsonError) {
+                console.error(`Failed to parse JSON message from client ${ws.userId} on doc ${ws.documentId}:`, jsonError);
+                if (ws.readyState === WebSocket.OPEN) {
+                    ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON format', details: (jsonError as Error).message }));
+                }
+                return; // Stop processing this message
+            }
+
+            if (operation.documentId !== docId) {
+                console.warn(`Received operation for wrong document ${operation.documentId} from client ${ws.userId} on doc ${docId}.`);
+                ws.send(JSON.stringify({ type: 'error', message: 'Operation for wrong document' }));
+                return;
+            }
+
+            // Fetch current document state to compare versions
+            const currentDoc = db.prepare('SELECT content, version FROM documents WHERE id = ?').get({ id: docId });
+            if (!currentDoc) {
+                console.error(`Document ${docId} not found during operation processing for client ${ws.userId}.`);
+                ws.send(JSON.stringify({ type: 'error', message: 'Document not found during operation processing' }));
+                return;
+            }
+
+            let transformedOperation: Operation | null = null;
+            let finalContent = currentDoc.content;
+            let finalVersion = currentDoc.version;
+
+            // --- Operational Transform Logic ---
+            if (operation.version < currentDoc.version) {
+                // Version mismatch: Client is behind, needs transformation.
+                console.log(`Version mismatch for doc ${docId}: client version ${operation.version}, server version ${currentDoc.version}. Transforming...`);
+
+                // 1. Fetch historical operations between client's version and server's current version.
+                const historicalOps = fetchOperationsBetweenVersions(db, docId, operation.version, currentDoc.version);
+
+                // 2. Transform the incoming operation against all historical operations.
+                let opToTransform = { ...operation }; // Start with the client's operation
+                for (const historicalOp of historicalOps) {
+                    const transformed = transformOperation(opToTransform, historicalOp);
+                    if (transformed === null) {
+                        // Operation was invalidated by a historical operation.
+                        console.warn(`Client operation ${JSON.stringify(opToTransform)} invalidated by historical op ${JSON.stringify(historicalOp)} for doc ${docId}.`);
+                        // Client needs to resync.
+                        ws.send(JSON.stringify({ type: 'resync_required', documentId: docId, serverVersion: currentDoc.version }));
+                        return;
+                    }
+                    opToTransform = transformed; // Continue transforming with the adjusted operation
+                }
+                transformedOperation = opToTransform; // This is the operation we will apply
+
+                // 3. Apply the transformed operation to the current content to get the new state.
+                try {
+                    if (transformedOperation.type === 'insert') {
+                        if (transformedOperation.text === undefined || transformedOperation.position === undefined) {
+                            throw new Error('Malformed transformed insert operation');
+                        }
+                        const insertPos = Math.max(0, Math.min(transformedOperation.position, finalContent.length));
+                        finalContent = finalContent.slice(0, insertPos) + transformedOperation.text + finalContent.slice(insertPos);
+                    } else if (transformedOperation.type === 'delete') {
+                        if (transformedOperation.length === undefined || transformedOperation.positionToDelete === undefined) {
+                            throw new Error('Malformed transformed delete operation');
+                        }
+                        const deletePos = Math.max(0, Math.min(transformedOperation.positionToDelete, finalContent.length));
+                        const deleteLen = Math.max(0, Math.min(transformedOperation.length, finalContent.length - deletePos));
+                        finalContent = finalContent.slice(0, deletePos) + finalContent.slice(deletePos + deleteLen);
+                    } else {
+                        throw new Error('Unknown operation type in transformed operation');
+                    }
+                    finalVersion = currentDoc.version + 1; // Increment version after successful application
+                } catch (applyError: any) {
+                    console.error(`Error applying transformed operation ${transformedOperation.type} to doc ${docId} from client ${ws.userId}:`, applyError);
+                    if (ws.readyState === WebSocket.OPEN) {
+                        ws.send(JSON.stringify({ type: 'error', message: 'Failed to apply transformed operation', details: applyError.message }));
+                    }
+                    return;
+                }
+
+            } else if (operation.version === currentDoc.version) {
+                // Versions match: Apply operation directly (no transformation needed for this path)
+                try {
+                    if (operation.type === 'insert') {
+                        if (operation.text === undefined || operation.position === undefined) {
+                            throw new Error('Malformed insert operation: missing text or position');
+                        }
+                        const insertPos = Math.max(0, Math.min(operation.position, finalContent.length));
+                        finalContent = finalContent.slice(0, insertPos) + operation.text + finalContent.slice(insertPos);
+                    } else if (operation.type === 'delete') {
+                        if (operation.length === undefined || operation.positionToDelete === undefined) {
+                            throw new Error('Malformed delete operation: missing length or positionToDelete');
+                        }
+                        const deletePos = Math.max(0, Math.min(operation.positionToDelete, finalContent.length));
+                        const deleteLen = Math.max(0, Math.min(operation.length, finalContent.length - deletePos));
+                        finalContent = finalContent.slice(0, deletePos) + finalContent.slice(deletePos + deleteLen);
+                    } else {
+                        throw new Error('Unknown operation type');
+                    }
+                    finalVersion = currentDoc.version + 1; // Increment version
+                } catch (applyError: any) {
+                    console.error(`Error applying operation ${operation.type} to doc ${docId} from client ${ws.userId}:`, applyError);
+                    if (ws.readyState === WebSocket.OPEN) {
+                        ws.send(JSON.stringify({ type: 'error', message: 'Failed to apply operation', details: applyError.message }));
+                    }
+                    return;
+                }
+            } else { // operation.version > currentDoc.version
+                // Client is ahead of server: This should not happen if logic is correct, or indicates a desync.
+                console.error(`Client ${ws.userId} for doc ${docId} is ahead of server: client version ${operation.version}, server version ${currentDoc.version}.`);
+                ws.send(JSON.stringify({ type: 'resync_required', documentId: docId, serverVersion: currentDoc.version }));
+                return;
+            }
+            // --- End of OT Logic ---
+
+
+            // Persist the change and history
+            try {
+                db.transaction(() => {
+                    // Use the final content and version determined by OT or direct application
+                    db.prepare('UPDATE documents SET content = ?, version = ? WHERE id = ?')
+                        .run(finalContent, finalVersion, docId);
+                    
+                    // Store the original client operation and its resulting version in history.
+                    // If transformed, we store the *original* operation for history tracing,
+                    // but the broadcast will use the transformed operation's effect.
+                    // A more sophisticated system might store the transformed operation as well.
+                    const operationToStoreInHistory = transformedOperation || operation;
+                    db.prepare('INSERT INTO document_history (document_id, version, operation) VALUES (?, ?, ?)')
+                        .run(docId, finalVersion, JSON.stringify(operationToStoreInHistory));
+                })();
+            } catch (dbError: any) {
+                console.error(`Database error while saving operation for doc ${docId} from client ${ws.userId}:`, dbError);
+                if (ws.readyState === WebSocket.OPEN) {
+                    ws.send(JSON.stringify({ type: 'error', message: 'Failed to save changes to database', details: dbError.message }));
+                }
+                return;
+            }
+
+
+            // Broadcast the operation and the new state to all other clients for this document
+            const broadcastMessage = JSON.stringify({
+                type: 'operation',
+                payload: {
+                    ...transformedOperation || operation, // Use transformed op if available, else original
+                    newContent: finalContent,          // The final content after applying the operation
+                    newVersion: finalVersion           // The new version of the document
+                }
+            });
+            wss.clients.forEach((client: ClientWebSocket) => {
+                if (client !== ws && client.readyState === WebSocket.OPEN && client.documentId === docId) {
+                    client.send(broadcastMessage);
+                }
+            });
+
+            // Send ack to the client that sent the operation, confirming it was processed.
+            // The ack can reference the client's original operation version.
+            ws.send(JSON.stringify({ type: 'ack', clientVersion: operation.version, serverVersion: finalVersion }));
+
+
+        }); // End of ws.on('message')
+
+        ws.on('close', () => {
+            console.log(`Client ${userId} disconnected from document ${docId}`);
+        });
+
+        ws.on('error', (error) => {
+            console.error(`WebSocket error for client ${userId} on doc ${docId}:`, error);
+        });
+    }); // End of wss.on('connection')
+
+    // WebSocket upgrade handler
+    server.on('upgrade', (req, socket, head) => {
+        const pathname = new URL(req.url!, `ws://\${req.headers.host}`).pathname;
+        if (pathname.startsWith('/ws/')) {
+            wss.handleUpgrade(req, socket, head, (ws) => {
+                wss.emit('connection', ws, req);
+            });
+        } else {
+            socket.destroy(); // Close non-WebSocket connections
+        }
+    });
+
+    const start = async (port?: number): Promise<number> => {
+        return new Promise((resolve, reject) => {
+            server.listen(port || 0, () => {
+                const actualPort = (server.address() as any).port;
+                console.log(`Server listening on port \${actualPort}`);
+                resolve(actualPort);
+            });
+        });
+    };
+
+    const stop = async (): Promise<void> => {
+        return new Promise((resolve, reject) => {
+            wss.close(() => {
+                server.close((err) => {
+                    db.close();
+                    if (err) {
+                        reject(err);
+                    } else {
+                        resolve();
+                    }
+                });
+            });
+        });
+    };
+
+    return { app, start, stop };
+}
