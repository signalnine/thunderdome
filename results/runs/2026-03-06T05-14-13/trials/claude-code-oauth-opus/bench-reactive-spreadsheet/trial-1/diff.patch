diff --git a/src/cells.ts b/src/cells.ts
new file mode 100644
index 0000000..a12ab90
--- /dev/null
+++ b/src/cells.ts
@@ -0,0 +1,64 @@
+/**
+ * Cell reference utilities: parsing "A1", "AA23" etc. into column/row indices,
+ * and expanding range references like "A1:C3".
+ */
+
+/** Parse a column string (e.g. "A", "Z", "AA") into a 0-based column index. */
+export function columnToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64); // 'A' = 65
+  }
+  return index - 1; // 0-based
+}
+
+/** Convert a 0-based column index back to a column string. */
+export function indexToColumn(index: number): string {
+  let result = '';
+  let n = index + 1; // 1-based
+  while (n > 0) {
+    n--;
+    result = String.fromCharCode(65 + (n % 26)) + result;
+    n = Math.floor(n / 26);
+  }
+  return result;
+}
+
+/** Parse a cell reference like "A1" or "AA23" into { col, row } (0-based). */
+export function parseCellRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) {
+    throw new Error(`Invalid cell reference: ${ref}`);
+  }
+  return {
+    col: columnToIndex(match[1]),
+    row: parseInt(match[2], 10) - 1, // 0-based
+  };
+}
+
+/** Normalize a cell reference to uppercase canonical form. */
+export function normalizeRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+/**
+ * Expand a range reference "A1:C3" into an array of individual cell references.
+ * Handles column ranges, row ranges, and block ranges.
+ */
+export function expandRange(startRef: string, endRef: string): string[] {
+  const start = parseCellRef(startRef);
+  const end = parseCellRef(endRef);
+
+  const minCol = Math.min(start.col, end.col);
+  const maxCol = Math.max(start.col, end.col);
+  const minRow = Math.min(start.row, end.row);
+  const maxRow = Math.max(start.row, end.row);
+
+  const cells: string[] = [];
+  for (let row = minRow; row <= maxRow; row++) {
+    for (let col = minCol; col <= maxCol; col++) {
+      cells.push(`${indexToColumn(col)}${row + 1}`);
+    }
+  }
+  return cells;
+}
