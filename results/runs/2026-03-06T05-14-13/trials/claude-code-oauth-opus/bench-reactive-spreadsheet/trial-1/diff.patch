readsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 6);\n      sheet.set('A3', '=A1*A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('should evaluate division', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 20);\n      sheet.set('A2', 4);\n      sheet.set('A3', '=A1/A2');\n      expect(sheet.get('A3')).toBe(5);\n    });\n\n    it('should handle operator precedence', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('A3', 4);\n      sheet.set('B1', '=A1+A2*A3');  // 2 + 3*4 = 14\n      expect(sheet.get('B1')).toBe(14);\n    });\n\n    it('should handle parentheses', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('A3', 4);\n      sheet.set('B1', '=(A1+A2)*A3');  // (2+3)*4 = 20\n      expect(sheet.get('B1')).toBe(20);\n    });\n\n    it('should handle unary minus', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=-A1');\n      expect(sheet.get('B1')).toBe(-5);\n    });\n\n    it('should handle numeric literals in formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+5');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should handle string literals in formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=\"hello\"');\n      expect(sheet.get('A1')).toBe('hello');\n    });\n\n    it('should handle division by zero', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 0);\n      sheet.set('A3', '=A1/A2');\n      expect(sheet.get('A3')).toBe(null);\n    });\n  });\n\n  describe('comparison operators', () => {\n    it('should evaluate greater than', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('B1', '=A1>A2');\n