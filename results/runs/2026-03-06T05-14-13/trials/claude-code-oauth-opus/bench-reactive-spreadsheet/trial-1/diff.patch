ndle Z column', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('Z1', 42);\n      expect(sheet.get('Z1')).toBe(42);\n    });\n  });\n\n  describe('edge cases', () => {\n    it('should handle formula referencing empty cell', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      expect(sheet.get('A1')).toBe(null);\n    });\n\n    it('should handle numeric literal formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=42');\n      expect(sheet.get('A1')).toBe(42);\n    });\n\n    it('should handle boolean in formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=true');\n      expect(sheet.get('A1')).toBe(true);\n    });\n\n    it('should handle complex nested formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=IF(SUM(A1:A3)>50, MAX(A1:A3), MIN(A1:A3))');\n      expect(sheet.get('B1')).toBe(30); // SUM=60>50, so MAX=30\n    });\n\n    it('should handle IF with numeric condition', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('B1', '=IF(A1, \"yes\", \"no\")');\n      expect(sheet.get('B1')).toBe('yes');\n\n      sheet.set('A1', 0);\n      expect(sheet.get('B1')).toBe('no');\n    });\n\n    it('should handle multiple arithmetic operations', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('A3', 4);\n      sheet.set('A4', 5);\n      sheet.set('B1', '=A1+A2+A3+A4');\n      expect(sheet.get('B1')).toBe(14);\n    });\n\n    it('should handle decimal numbers', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 3.14);\n      sheet.set('A2', '=A1*2');\n      expect(sheet.get('A2')).toBeCloseTo(6.28);\n    });\n  });\n\n  describe('example usage from spec', () => {\n    it('should match the documented example', () => {\n      const sheet = new Spreadsheet();\n\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n      expect(sheet.getDisplay('A3')).toBe('30');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(70);\n\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
