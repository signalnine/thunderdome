1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n    });\n\n    it('should handle chain of dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=B1+1');\n      sheet.set('D1', '=C1+1');\n      expect(sheet.get('D1')).toBe(4);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(11);\n      expect(sheet.get('C1')).toBe(12);\n      expect(sheet.get('D1')).toBe(13);\n    });\n\n    it('should handle multiple dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1*2');\n      sheet.set('C1', '=A1*3');\n      sheet.set('D1', '=B1+C1');\n      expect(sheet.get('D1')).toBe(50);\n\n      sheet.set('A1', 5);\n      expect(sheet.get('B1')).toBe(10);\n      expect(sheet.get('C1')).toBe(15);\n      expect(sheet.get('D1')).toBe(25);\n    });\n\n    it('should update SUM when range cells change', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(6);\n\n      sheet.set('A2', 20);\n      expect(sheet.get('B1')).toBe(24);\n    });\n\n    it('should update when a formula cell is overwritten with a value', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1*2');\n      expect(sheet.get('B1')).toBe(20);\n\n      sheet.set('B1', 99);\n      expect(sheet.get('B1')).toBe(99);\n\n      // Changing A1 should no longer affect B1\n      sheet.set('A1', 1);\n      expect(sheet.get('B1')).toBe(99);\n    });\n\n    it('should handle overwriting a formula with another formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set(