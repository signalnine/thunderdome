+import { expandRange, normalizeRef } from './cells.js';
+import { ASTNode, parseFormula } from './parser.js';
+
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  computed: CellValue;
+  deps: Set<string>;       // cells this cell depends on
+}
+
+export class Spreadsheet {
+  /** Stores all cell data keyed by normalized reference (e.g. "A1"). */
+  private cells: Map<string, CellData> = new Map();
+
+  /** Reverse dependency map: for a given cell, which cells depend on it. */
+  private dependents: Map<string, Set<string>> = new Map();
+
+  /**
+   * Set a cell's value. Can be a raw value or a formula string starting with '='.
+   */
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+
+    // Remove old reverse dependencies
+    const existing = this.cells.get(ref);
+    if (existing) {
+      for (const dep of existing.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.slice(1));
+      deps = this.collectDeps(formula);
+    }
+
+    // Register reverse dependencies before cycle check
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Check for circular dependencies
+    if (this.hasCycle(ref)) {
+      // Rollback: remove the reverse deps we just added
+      for (const dep of deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+      // Restore old reverse deps if there was an existing cell
+      if (existing) {
+        for (const dep of existing.deps) {
+          if (!this.dependents.has(dep)) {
+            this.dependents.set(dep, new Set());
+          }
+          this.dependents.get(dep)!.add(ref);
+        }
+      }
+      throw new Error(`Circular reference detected involving ${ref}`);
+    }
+
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      computed: null,
+      deps,
+    };
+
+    this.cells.set(ref, cellData);
+
+    // Evaluate and propagate
+    this.evaluate(ref);
+    this.propagate(ref);
+  }
+
+  /**
+   * Get a cell's computed value. Returns null for empty cells.
+   */
+  get(cell: string): CellValue {
+    const ref = normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  /**
+   * Get the display string for a cell's computed value.
+   */
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  /**
+   * Get all non-empty cells as a Map from cell reference to computed value.
+   */
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  /**
+   * Collect all cell references that a formula AST depends on.
+   */
+  private collectDeps(node: ASTNode): Set<string> {
+    const deps = new Set<string>();
+    this.walkDeps(node, deps);
+    return deps;
+  }
+
+  private walkDeps(node: ASTNode, deps: Set<string>): void {
+    switch (node.type) {
+      case 'cellref':
+        deps.add(node.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(node.start, node.end);
+        for (const c of cells) deps.add(c);
+        break;
+      }
+      case 'binop':
+        this.walkDeps(node.left, deps);
+        this.walkDeps(node.right, deps);
+        break;
+      case 'unary':
+        this.walkDeps(node.operand, deps);
+        break;
+      case 'func':
+        for (const arg of node.args) this.walkDeps(arg, deps);
+        break;
+      // number, string, boolean have no deps
+    }
+  }
+
+  /**
+   * Detect cycles using DFS on the dependents graph starting from `start`.
+   * If we can reach `start` again by following dependents, there's a cycle.
+   */
+  private hasCycle(start: string): boolean {
+    const visited = new Set<string>();
+    const stack = [start];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      const children = this.dependents.get(current);
+      if (!children) continue;
+
+      for (const child of children) {
+        if (child === start) return true;
+        if (!visited.has(child)) {
+          visited.add(child);
+          stack.push(child);
+        }
+      }
+    }
+
+    return false;
+  }
+
+  /**
+   * Evaluate a single cell and store its computed value.
+   */
+  private evaluate(ref: string): void {
+    const data = this.cells.get(ref);
+    if (!data) return;
+
+    if (data.formula) {
+      data.computed = this.evalNode(data.formula);
+    } else {
+      data.computed = data.raw as CellValue;
+    }
+  }
+
+  /**
+   * Evaluate an AST node and return its value.
+   */
+  private evalNode(node: ASTNode): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cellref':
+        return this.get(node.ref);
+      case 'range':
+        // Ranges should only appear as function arguments; evaluate to array
+        // This shouldn't be reached in normal expression evaluation
+        throw new Error('Range used outside of function call');
+      case 'unary':
+        if (node.op === '-') {
+          const val = this.evalNode(node.operand);
+          if (typeof val === 'number') return -val;
+          return null;
+        }
+        return null;
+      case 'binop':
+        return this.evalBinop(node.op, node.left, node.right);
+      case 'func':
+        return this.evalFunc(node.name, node.args);
+    }
+  }
+
+  private evalBinop(op: string, left: ASTNode, right: ASTNode): CellValue {
+    const lv = this.evalNode(left);
+    const rv = this.evalNode(right);
+
+    // Arithmetic
+    if (op === '+' || op === '-' || op === '*' || op === '/') {
+      const ln = typeof lv === 'number' ? lv : 0;
+      const rn = typeof rv === 'number' ? rv : 0;
+      switch (op) {
+        case '+': return ln + rn;
+        case '-': return ln - rn;
+        case '*': return ln * rn;
+        case '/': return rn === 0 ? null : ln / rn;
+      }
+    }
+
+    // Comparison
+    switch (op) {
+      case '>':  return (lv as number) > (rv as number);
+      case '<':  return (lv as number) < (rv as number);
+      case '>=': return (lv as number) >= (rv as number);
+      case '<=': return (lv as number) <= (rv as number);
+      case '=':  return lv === rv;
+      case '<>': return lv !== rv;
+    }
+
+    return null;
+  }
+
+  /**
+   * Resolve range arguments into arrays of values.
+   */
+  private resolveRangeValues(node: ASTNode): number[] {
+    if (node.type === 'range') {
+      const cells = expandRange(node.start, node.end);
+      const values: number[] = [];
+      for (const c of cells) {
+        const v = this.get(c);
+        if (typeof v === 'number') values.push(v);
+      }
+      return values;
+    }
+    // Single value
+    const v = this.evalNode(node);
+    if (typeof v === 'number') return [v];
+    return [];
+  }
+
+  private evalFunc(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        let total = 0;
+        for (const arg of args) {
+          for (const v of this.resolveRangeValues(arg)) {
+            total += v;
+          }
+        }
+        return total;
+      }
+      case 'AVERAGE': {
+        const values: number[] = [];
+        for (const arg of args) {
+          values.push(...this.resolveRangeValues(arg));
+        }
+        if (values.length === 0) return null;
+        return values.reduce((a, b) => a + b, 0) / values.length;
+      }
+      case 'MIN': {
+        const values: number[] = [];
+        for (const arg of args) {
+          values.push(...this.resolveRangeValues(arg));
+        }
+        if (values.length === 0) return null;
+        return Math.min(...values);
+      }
+      case 'MAX': {
+        const values: number[] = [];
+        for (const arg of args) {
+          values.push(...this.resolveRangeValues(arg));
+        }
+        if (values.length === 0) return null;
+        return Math.max(...values);
+      }
+      case 'COUNT': {
+        let count = 0;
+        for (const arg of args) {
+          count += this.resolveRangeValues(arg).length;
+        }
+        return count;
+      }
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evalNode(args[0]);
+        if (condition === true || (typeof condition === 'number' && condition !== 0)) {
+          return this.evalNode(args[1]);
+        }
+        return this.evalNode(args[2]);
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+
+  /**
+   * After a cell changes, propagate recalculation to all transitive dependents
+   * using topological ordering.
+   */
+  private propagate(ref: string): void {
+    // Collect all transitive dependents in topological order
+    const order = this.topologicalDependents(ref);
+
+    for (const dep of order) {
+      this.evaluate(dep);
+    }
+  }
+
+  /**
+   * Get all transitive dependents of `ref` in topological order (BFS-like).
+   * Does not include `ref` itself.
+   */
+  private topologicalDependents(ref: string): string[] {
+    const visited = new Set<string>();
+    const order: string[] = [];
+    const queue = [ref];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const children = this.dependents.get(current);
+      if (!children) continue;
+
+      for (const child of children) {
+        if (!visited.has(child)) {
+          visited.add(child);
+          order.push(child);
+          queue.push(child);
+        }
+      }
+    }
+
+    return order;
+  }
+}
