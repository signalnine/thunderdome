+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('should store and retrieve numeric values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve string values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve boolean values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should overwrite existing values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A1', 20);
+      expect(sheet.get('A1')).toBe(20);
+    });
+
+    it('should handle case-insensitive cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 42);
+      expect(sheet.get('A1')).toBe(42);
+      expect(sheet.get('a1')).toBe(42);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers as strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings as-is', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('Z99')).toBe('');
+    });
+
+    it('should display formula results', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+
+    it('should return empty map for empty spreadsheet', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getCells().size).toBe(0);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1');
+      expect(sheet.get('B1')).toBe(10);
+    });
+
+    it('should evaluate addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(20);
+    });
+
+    it('should evaluate multiplication', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 20);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(5);
+    });
+
+    it('should handle operator precedence', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=A1+A2*A3');  // 2 + 3*4 = 14
+      expect(sheet.get('B1')).toBe(14);
+    });
+
+    it('should handle parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=(A1+A2)*A3');  // (2+3)*4 = 20
+      expect(sheet.get('B1')).toBe(20);
+    });
+
+    it('should handle unary minus', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('B1', '=-A1');
+      expect(sheet.get('B1')).toBe(-5);
+    });
+
+    it('should handle numeric literals in formulas', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+5');
+      expect(sheet.get('B1')).toBe(15);
+    });
+
+    it('should handle string literals in formulas', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '="hello"');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should handle division by zero', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 0);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(null);
+    });
+  });
+
+  describe('comparison operators', () => {
+    it('should evaluate greater than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1>A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate less than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1<A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate equality', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1=A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate not equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 3);
+      sheet.set('B1', '=A1<>A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate >= and <=', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1>=A2');
+      sheet.set('B2', '=A1<=A2');
+      expect(sheet.get('B1')).toBe(true);
+      expect(sheet.get('B2')).toBe(true);
+    });
+  });
+
+  describe('built-in functions', () => {
+    it('should evaluate SUM', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
