+/**
+ * Formula parser: tokenizes and parses formula strings into an AST.
+ *
+ * Grammar (simplified):
+ *   Formula     = Expression
+ *   Expression  = Comparison
+ *   Comparison  = Additive (( ">" | "<" | ">=" | "<=" | "=" | "<>" ) Additive)?
+ *   Additive    = Multiplicative (( "+" | "-" ) Multiplicative)*
+ *   Multiplicative = Unary (( "*" | "/" ) Unary)*
+ *   Unary       = ("-" Unary) | Primary
+ *   Primary     = Number | String | Boolean | FunctionCall | CellRef | "(" Expression ")"
+ *   FunctionCall = IDENT "(" ArgList ")"
+ *   ArgList     = Arg ("," Arg)*
+ *   Arg         = Range | Expression
+ *   Range       = CellRef ":" CellRef
+ */
+
+export type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cellref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'unary'; op: string; operand: ASTNode }
+  | { type: 'func'; name: string; args: ASTNode[] };
+
+enum TokenType {
+  Number,
+  String,
+  Ident,    // cell ref or function name or boolean
+  LParen,
+  RParen,
+  Comma,
+  Colon,
+  Plus,
+  Minus,
+  Star,
+  Slash,
+  GT,
+  LT,
+  GTE,
+  LTE,
+  EQ,
+  NEQ,
+  EOF,
+}
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    const ch = input[i];
+
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    if (ch === '"') {
+      // String literal
+      let str = '';
+      i++; // skip opening quote
+      while (i < input.length && input[i] !== '"') {
+        str += input[i];
+        i++;
+      }
+      if (i >= input.length) throw new Error('Unterminated string');
+      i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    // Numbers
+    if ((ch >= '0' && ch <= '9') || (ch === '.' && i + 1 < input.length && input[i + 1] >= '0' && input[i + 1] <= '9')) {
+      let num = '';
+      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {
+        num += input[i];
+        i++;
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
+
+    // Identifiers (cell refs, function names, booleans)
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z') || ch === '_') {
+      let ident = '';
+      while (i < input.length && ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z') || (input[i] >= '0' && input[i] <= '9') || input[i] === '_')) {
+        ident += input[i];
+        i++;
+      }
+      tokens.push({ type: TokenType.Ident, value: ident });
+      continue;
+    }
+
+    // Two-character operators
+    if (ch === '>' && i + 1 < input.length && input[i + 1] === '=') {
+      tokens.push({ type: TokenType.GTE, value: '>=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<' && i + 1 < input.length && input[i + 1] === '=') {
+      tokens.push({ type: TokenType.LTE, value: '<=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<' && i + 1 < input.length && input[i + 1] === '>') {
+      tokens.push({ type: TokenType.NEQ, value: '<>' });
+      i += 2;
+      continue;
+    }
+
+    // Single-character tokens
+    const singleCharMap: Record<string, TokenType> = {
+      '(': TokenType.LParen,
+      ')': TokenType.RParen,
+      ',': TokenType.Comma,
+      ':': TokenType.Colon,
+      '+': TokenType.Plus,
+      '-': TokenType.Minus,
+      '*': TokenType.Star,
+      '/': TokenType.Slash,
+      '>': TokenType.GT,
+      '<': TokenType.LT,
+      '=': TokenType.EQ,
+    };
+
+    if (ch in singleCharMap) {
+      tokens.push({ type: singleCharMap[ch], value: ch });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  tokens.push({ type: TokenType.EOF, value: '' });
+  return tokens;
+}
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    const token = this.tokens[this.pos];
+    this.pos++;
+    return token;
+  }
+
+  private expect(type: TokenType): Token {
+    const token = this.peek();
+    if (token.type !== type) {
+      throw new Error(`Expected token type ${type}, got ${token.type} (${token.value})`);
+    }
+    return this.advance();
+  }
+
+  parse(): ASTNode {
+    const node = this.parseExpression();
+    this.expect(TokenType.EOF);
+    return node;
+  }
+
+  private parseExpression(): ASTNode {
+    return this.parseComparison();
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAdditive();
+
+    const t = this.peek();
+    if (
+      t.type === TokenType.GT ||
+      t.type === TokenType.LT ||
+      t.type === TokenType.GTE ||
+      t.type === TokenType.LTE ||
+      t.type === TokenType.EQ ||
+      t.type === TokenType.NEQ
+    ) {
+      const op = this.advance();
+      const right = this.parseAdditive();
+      left = { type: 'binop', op: op.value, left, right };
+    }
+
+    return left;
+  }
+
+  private parseAdditive(): ASTNode {
+    let left = this.parseMultiplicative();
+
+    while (this.peek().type === TokenType.Plus || this.peek().type === TokenType.Minus) {
+      const op = this.advance();
+      const right = this.parseMultiplicative();
+      left = { type: 'binop', op: op.value, left, right };
+    }
+
+    return left;
+  }
+
+  private parseMultiplicative(): ASTNode {
+    let left = this.parseUnary();
+
+    while (this.peek().type === TokenType.Star || this.peek().type === TokenType.Slash) {
+      const op = this.advance();
+      const right = this.parseUnary();
+      left = { type: 'binop', op: op.value, left, right };
+    }
+
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek().type === TokenType.Minus) {
+      this.advance();
+      const operand = this.parseUnary();
+      return { type: 'unary', op: '-', operand };
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const token = this.peek();
+
+    // Number literal
+    if (token.type === TokenType.Number) {
+      this.advance();
+      return { type: 'number', value: parseFloat(token.value) };
+    }
+
+    // String literal
+    if (token.type === TokenType.String) {
+      this.advance();
+      return { type: 'string', value: token.value };
+    }
+
+    // Identifier: boolean, function call, or cell reference
+    if (token.type === TokenType.Ident) {
+      const upper = token.value.toUpperCase();
+
+      // Boolean literals
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        this.advance();
+        return { type: 'boolean', value: upper === 'TRUE' };
+      }
+
+      // Look ahead: is this a function call?
+      if (this.tokens[this.pos + 1]?.type === TokenType.LParen) {
+        return this.parseFunctionCall();
+      }
+
+      // Cell reference
+      this.advance();
+      return { type: 'cellref', ref: upper };
+    }
+
+    // Parenthesized expression
+    if (token.type === TokenType.LParen) {
+      this.advance();
+      const expr = this.parseExpression();
+      this.expect(TokenType.RParen);
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${token.value}`);
+  }
+
+  private parseFunctionCall(): ASTNode {
+    const nameToken = this.advance(); // function name
+    const name = nameToken.value.toUpperCase();
+    this.expect(TokenType.LParen);
+
+    const args: ASTNode[] = [];
+    if (this.peek().type !== TokenType.RParen) {
+      args.push(this.parseArg());
+      while (this.peek().type === TokenType.Comma) {
+        this.advance(); // consume comma
+        args.push(this.parseArg());
+      }
+    }
+
+    this.expect(TokenType.RParen);
+    return { type: 'func', name, args };
+  }
+
+  private parseArg(): ASTNode {
+    // Check if this argument is a range (CellRef : CellRef)
+    if (this.peek().type === TokenType.Ident) {
+      const ident = this.peek().value.toUpperCase();
+      // Check if it looks like a cell ref and is followed by ':'
+      if (/^[A-Z]+\d+$/.test(ident) && this.tokens[this.pos + 1]?.type === TokenType.Colon) {
+        const startToken = this.advance();
+        this.advance(); // consume ':'
+        const endToken = this.expect(TokenType.Ident);
+        return {
+          type: 'range',
+          start: startToken.value.toUpperCase(),
+          end: endToken.value.toUpperCase(),
+        };
+      }
+    }
+
+    return this.parseExpression();
+  }
+}
+
+export function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
