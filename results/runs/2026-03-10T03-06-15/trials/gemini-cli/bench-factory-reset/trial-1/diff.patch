+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Part 1: Toggle Puzzle (GF2)
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const N = target.length;
+  const M = buttons.length;
+
+  const buttonVals: bigint[] = buttons.map(b => {
+    let val = 0n;
+    for (const bit of b) val |= (1n << BigInt(bit));
+    return val;
+  });
+
+  const rows: bigint[] = new Array(N).fill(0n);
+  for (let i = 0; i < N; i++) {
+    for (let j = 0; j < M; j++) {
+      if ((buttonVals[j] >> BigInt(i)) & 1n) {
+        rows[i] |= (1n << BigInt(j));
+      }
+    }
+    if (target[i]) {
+      rows[i] |= (1n << BigInt(M));
+    }
+  }
+
+  // RREF
+  let pivotRow = 0;
+  const pivotCols: number[] = [];
+  for (let j = 0; j < M && pivotRow < N; j++) {
+    let sel = pivotRow;
+    while (sel < N && !((rows[sel] >> BigInt(j)) & 1n)) sel++;
+    if (sel === N) continue;
+
+    [rows[pivotRow], rows[sel]] = [rows[sel], rows[pivotRow]];
+    for (let i = 0; i < N; i++) {
+      if (i !== pivotRow && ((rows[i] >> BigInt(j)) & 1n)) {
+        rows[i] ^= rows[pivotRow];
+      }
+    }
+    pivotCols.push(j);
+    pivotRow++;
+  }
+
+  // Check consistency
+  for (let i = pivotRow; i < N; i++) {
+    if ((rows[i] >> BigInt(M)) & 1n) return null;
+  }
+
+  const R = pivotCols.length;
+  const K = M - R;
+
+  const isPivot = new Array(M).fill(false);
+  for (const p of pivotCols) isPivot[p] = true;
+  const freeIndices: number[] = [];
+  for (let j = 0; j < M; j++) if (!isPivot[j]) freeIndices.push(j);
+
+  if (K <= 20) {
+    // Brute force free variables with Gray Code
+    let currentX = 0n;
+    const pivotValsArr = new Uint8Array(R);
+    let currentWeight = 0;
+    for (let r = 0; r < R; r++) {
+      pivotValsArr[r] = Number((rows[r] >> BigInt(M)) & 1n);
+      if (pivotValsArr[r]) {
+        currentWeight++;
+        currentX |= (1n << BigInt(pivotCols[r]));
+      }
+    }
+
+    let bestX = currentX;
+    let minWeight = currentWeight;
+
+    const k_limit = 1 << K;
+    for (let i = 1; i < k_limit; i++) {
+      const gray = i ^ (i >> 1);
+      const prevGray = (i - 1) ^ ((i - 1) >> 1);
+      const diff = gray ^ prevGray;
+      const fIdx = trailingZerosSmall(diff);
+      const f = freeIndices[fIdx];
+
+      if ((gray >> fIdx) & 1) {
+        currentX |= (1n << BigInt(f));
+        currentWeight++;
+      } else {
+        currentX &= ~(1n << BigInt(f));
+        currentWeight--;
+      }
+
+      for (let r = 0; r < R; r++) {
+        if ((rows[r] >> BigInt(f)) & 1n) {
+          if (pivotValsArr[r]) {
+            pivotValsArr[r] = 0;
+            currentWeight--;
+            currentX &= ~(1n << BigInt(pivotCols[r]));
+          } else {
+            pivotValsArr[r] = 1;
+            currentWeight++;
+            currentX |= (1n << BigInt(pivotCols[r]));
+          }
+        }
+      }
+
+      if (currentWeight < minWeight) {
+        minWeight = currentWeight;
+        bestX = currentX;
+      } else if (currentWeight === minWeight) {
+        if (isLexSmaller(currentX, bestX)) {
+          bestX = currentX;
+        }
+      }
+    }
+    return xToIndices(bestX, M);
+  } else {
+    // BFS on syndromes
+    const buttonSyndromes = new BigUint64Array(M); // Using BigInt to store up to 40 syndrome bits
+    for (let j = 0; j < M; j++) {
+      let s = 0n;
+      for (let r = 0; r < R; r++) {
+        if ((rows[r] >> BigInt(j)) & 1n) s |= (1n << BigInt(r));
+      }
+      buttonSyndromes[j] = s;
+    }
+    let targetSyndrome = 0n;
+    for (let r = 0; r < R; r++) {
+      if ((rows[r] >> BigInt(M)) & 1n) targetSyndrome |= (1n << BigInt(r));
+    }
+
+    const dist = new Int32Array(1 << R).fill(-1);
+    const bestMask = new BigUint64Array(1 << R);
+    const queue = new BigUint64Array(1 << R);
+    let head = 0, tail = 0;
+
+    dist[0] = 0;
+    bestMask[0] = 0n;
+    queue[tail++] = 0n;
+
+    let minTargetDist = Infinity;
+    const targetSyndromeNum = Number(targetSyndrome); // R <= 20 so it fits in Number
+
+    while (head < tail) {
+      const s = queue[head++];
+      const d = dist[Number(s)];
+
+      if (d >= minTargetDist) continue;
+
+      for (let j = 0; j < M; j++) {
+        const nextS = s ^ buttonSyndromes[j];
+        const nextSIdx = Number(nextS);
+        const nextD = d + 1;
+        const nextMask = bestMask[Number(s)] | (1n << BigInt(j));
+
+        if (dist[nextSIdx] === -1) {
+          dist[nextSIdx] = nextD;
+          bestMask[nextSIdx] = nextMask;
+          queue[tail++] = nextS;
+          if (nextS === targetSyndrome) minTargetDist = nextD;
+        } else if (dist[nextSIdx] === nextD) {
+          if (isLexSmaller(nextMask, bestMask[nextSIdx])) {
+            bestMask[nextSIdx] = nextMask;
+          }
+        }
+      }
+    }
+
+    if (dist[targetSyndromeNum] === -1) return null;
+    return xToIndices(bestMask[targetSyndromeNum], M);
+  }
+}
+
+function trailingZerosSmall(n: number): number {
+  return 31 - Math.clz32(n & -n);
+}
+
+function isLexSmaller(a: bigint, b: bigint) {
+  const diff = a ^ b;
+  if (diff === 0n) return false;
+  // Smallest bit where they differ
+  let i = 0n;
+  // Optimize: use bitwise trick if needed, but for 40 bits this is okay
+  const diffLow = Number(diff & 0xFFFFFFFFn);
+  if (diffLow !== 0) {
+    i = BigInt(trailingZerosSmall(diffLow));
+  } else {
+    i = BigInt(32 + trailingZerosSmall(Number((diff >> 32n) & 0xFFFFFFFFn)));
+  }
+  return (a >> i) & 1n ? true : false;
+}
+
+function xToIndices(x: bigint, M: number): number[] {
+  const res: number[] = [];
+  for (let i = 0; i < M; i++) {
+    if ((x >> BigInt(i)) & 1n) res.push(i);
+  }
+  return res;
+}
+
+/**
+ * Part 2: Counter Puzzle (GFp)
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const N = lights.length;
+  const M = buttons.length;
+  const p = modulus;
+
+  const matrix: number[][] = Array.from({ length: N }, () => new Array(M + 1).fill(0));
+  for (let j = 0; j < M; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx < N) matrix[lightIdx][j] = 1;
+    }
+  }
+  for (let i = 0; i < N; i++) matrix[i][M] = lights[i] % p;
+
+  let pivotRow = 0;
+  const pivotCols: number[] = [];
+  const gfp = new GFp(p);
+
+  for (let j = 0; j < M && pivotRow < N; j++) {
+    let sel = pivotRow;
+    while (sel < N && matrix[sel][j] === 0) sel++;
+    if (sel === N) continue;
+
+    [matrix[pivotRow], matrix[sel]] = [matrix[sel], matrix[pivotRow]];
+    pivotCols.push(j);
+
+    const inv = gfp.inv(matrix[pivotRow][j]);
+    for (let k = j; k <= M; k++) matrix[pivotRow][k] = gfp.mul(matrix[pivotRow][k], inv);
+
+    for (let i = 0; i < N; i++) {
+      if (i !== pivotRow && matrix[i][j] !== 0) {
+        const factor = matrix[i][j];
+        for (let k = j; k <= M; k++) {
+          matrix[i][k] = gfp.sub(matrix[i][k], gfp.mul(factor, matrix[pivotRow][k]));
+        }
+      }
+    }
+    pivotRow++;
+  }
+
+  for (let i = pivotRow; i < N; i++) {
+    if (matrix[i][M] !== 0) return null;
+  }
+
+  const R = pivotCols.length;
+  const K = M - R;
+  const isPivot = new Array(M).fill(false);
+  for (const pc of pivotCols) isPivot[pc] = true;
+  const freeIndices: number[] = [];
+  for (let j = 0; j < M; j++) if (!isPivot[j]) freeIndices.push(j);
+
+  const p_to_K = Math.pow(p, K);
+  const p_to_R = Math.pow(p, R);
+
+  if (p_to_K <= 2000000) {
+    let bestX: Uint8Array | null = null;
+    let minWeight = Infinity;
+
+    const currentX = new Uint8Array(M);
+    const freeVals = new Uint8Array(K);
+    const currentPivotVals = new Uint8Array(R);
+    let currentW = 0;
+
+    for (let r = 0; r < R; r++) {
+      currentPivotVals[r] = matrix[r][M];
+      currentW += currentPivotVals[r];
+      currentX[pivotCols[r]] = currentPivotVals[r];
+    }
+
+    bestX = new Uint8Array(currentX);
+    minWeight = currentW;
+
+    for (let i = 1; i < p_to_K; i++) {
+      // Incremental update of free variables
+      let j = 0;
+      while (j < K) {
+        freeVals[j]++;
+        if (freeVals[j] < p) {
+          // Changed j-th free variable
+          const diff = 1;
+          const fIdx = freeIndices[j];
+          currentX[fIdx] = freeVals[j];
+          currentW += diff;
+          
+          for (let r = 0; r < R; r++) {
+            const coeff = matrix[r][fIdx];
+            if (coeff !== 0) {
+              const oldP = currentPivotVals[r];
+              const newP = gfp.sub(oldP, coeff);
+              currentPivotVals[r] = newP;
+              currentW = currentW - oldP + newP;
+              currentX[pivotCols[r]] = newP;
+            }
+          }
+          break;
+        } else {
+          // Wrapped around
+          const diff = -(p - 1);
+          const fIdx = freeIndices[j];
+          freeVals[j] = 0;
+          currentX[fIdx] = 0;
+          currentW += diff;
+          for (let r = 0; r < R; r++) {
+            const coeff = matrix[r][fIdx];
+            if (coeff !== 0) {
+              const oldP = currentPivotVals[r];
+              const newP = gfp.add(oldP, gfp.mul(coeff, p-1));
+              currentPivotVals[r] = newP;
+              currentW = currentW - oldP + newP;
+              currentX[pivotCols[r]] = newP;
+            }
+          }
+          j++;
+        }
+      }
+
+      if (currentW < minWeight) {
+        minWeight = currentW;
+        bestX = new Uint8Array(currentX);
+      } else if (currentW === minWeight) {
+        if (bestX && compare(currentX, bestX) < 0) {
+          bestX = new Uint8Array(currentX);
+        }
+      }
+    }
+    return bestX ? Array.from(bestX) : null;
+  } else if (p_to_R <= 2000000) {
+    // BFS on syndromes
+    const buttonSyndromes: number[][] = Array.from({ length: M }, () => new Array(R).fill(0));
+    for (let j = 0; j < M; j++) {
+      for (let r = 0; r < R; r++) buttonSyndromes[j][r] = matrix[r][j];
+    }
+    const targetSyndromeArr = new Array(R).fill(0);
+    for (let r = 0; r < R; r++) targetSyndromeArr[r] = matrix[r][M];
+
+    const encode = (s: number[]) => {
+      let res = 0;
+      for (let i = R - 1; i >= 0; i--) res = res * p + s[i];
+      return res;
+    };
+    const decode = (idx: number) => {
+      const res = new Array(R);
+      for (let i = 0; i < R; i++) {
+        res[i] = idx % p;
+        idx = Math.floor(idx / p);
+      }
+      return res;
+    };
+
+    const targetIdx = encode(targetSyndromeArr);
+    const dist = new Int32Array(p_to_R).fill(-1);
+    const bestX = new Uint8Array(p_to_R * M);
+    const queue = new Uint32Array(p_to_R);
+    let head = 0, tail = 0;
+
+    dist[0] = 0;
+    queue[tail++] = 0;
+
+    let minTargetDist = Infinity;
+
+    while (head < tail) {
+      const sIdx = queue[head++];
+      const d = dist[sIdx];
+      if (d >= minTargetDist) continue;
+
+      const s = decode(sIdx);
+      const currentX = bestX.subarray(sIdx * M, (sIdx + 1) * M);
+
+      for (let j = 0; j < M; j++) {
+        if (currentX[j] === p - 1) continue;
+
+        const nextS = s.map((v, r) => (v + buttonSyndromes[j][r]) % p);
+        const nextSIdx = encode(nextS);
+        const nextD = d + 1;
+
+        if (dist[nextSIdx] === -1) {
+          dist[nextSIdx] = nextD;
+          const nextX = bestX.subarray(nextSIdx * M, (nextSIdx + 1) * M);
+          nextX.set(currentX);
+          nextX[j]++;
+          queue[tail++] = nextSIdx;
+          if (nextSIdx === targetIdx) minTargetDist = nextD;
+        } else if (dist[nextSIdx] === nextD) {
+          const nextX = bestX.subarray(nextSIdx * M, (nextSIdx + 1) * M);
+          const candidateX = new Uint8Array(currentX);
+          candidateX[j]++;
+          if (compare(candidateX, nextX) < 0) {
+            nextX.set(candidateX);
+          }
+        }
+      }
+    }
+
+    if (dist[targetIdx] === -1) return null;
+    return Array.from(bestX.subarray(targetIdx * M, (targetIdx + 1) * M));
+  } else {
+    return null;
+  }
+}
+
+class GFp {
+  p: number;
+  constructor(p: number) { this.p = p; }
+  add(a: number, b: number) { return (a + b) % this.p; }
+  sub(a: number, b: number) { return (a - b + this.p) % this.p; }
+  mul(a: number, b: number) { return (a * b) % this.p; }
+  inv(a: number) {
+    let res = 1, b = this.p - 2, x = a % this.p;
+    while (b > 0) {
+      if (b % 2 === 1) res = (res * x) % this.p;
+      x = (x * x) % this.p;
+      b = Math.floor(b / 2);
+    }
+    return res;
+  }
+}
+
+function compare(a: Uint8Array, b: Uint8Array) {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
