+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+describe('Factory Reset Puzzles', () => {
+  describe('Part 1: Toggle Puzzle', () => {
+    it('should solve the example puzzle correctly (null)', () => {
+      const machine: Machine = {
+        target: [true, true, false, true],
+        buttons: [
+          [0, 1],
+          [1, 2, 3],
+          [0, 3]
+        ]
+      };
+      // Example says no solution:
+      // Correct: press buttons 0 and 2:
+      // After 0: [on, on, off, off]
+      // After 2: [off, on, off, on]
+      // Result: [false, true, false, true] - not matching.
+      expect(solveToggle(machine)).toBeNull();
+    });
+
+    it('should solve a solvable puzzle correctly', () => {
+      const machine: Machine = {
+        target: [false, true, false, true],
+        buttons: [
+          [0, 1],
+          [1, 2, 3],
+          [0, 3]
+        ]
+      };
+      // From the example text, pressing 0 and 2 gives [false, true, false, true]
+      const result = solveToggle(machine);
+      expect(result).toEqual([0, 2]);
+    });
+
+    it('should return the lexicographically smallest set of indices on tie', () => {
+      const machine: Machine = {
+        target: [true, true],
+        buttons: [
+          [0, 1],
+          [0],
+          [1]
+        ]
+      };
+      // Solutions: {0, 1} (weight 2), {1, 2} (weight 2)? No.
+      // Target [T, T]. Buttons: 0={0,1}, 1={0}, 2={1}.
+      // Solution 1: press button 0. indices [0]. weight 1.
+      // Solution 2: press buttons 1 and 2. indices [1, 2]. weight 2.
+      // Smallest weight is 1, so [0].
+      expect(solveToggle(machine)).toEqual([0]);
+    });
+
+    it('should handle ties in weight with lexicographical order', () => {
+       const machine: Machine = {
+        target: [true, true, true],
+        buttons: [
+          [0, 1],
+          [1, 2],
+          [0, 2]
+        ]
+      };
+      // Target [T, T, T].
+      // b0 XOR b2 = 1 (light 0)
+      // b0 XOR b1 = 1 (light 1)
+      // b1 XOR b2 = 1 (light 2)
+      // b0=1, b1=0, b2=0 -> 1, 1, 0 (wrong)
+      // b0=1, b1=0, b2=1 -> 0, 1, 1 (wrong)
+      // Actually b0+b1=1, b1+b2=1, b0+b2=1 -> 2(b0+b1+b2) = 3 -> 0 = 1 (mod 2). No solution.
+      expect(solveToggle(machine)).toBeNull();
+    });
+  });
+
+  describe('Part 2: Counter Puzzle', () => {
+    it('should solve a simple counter puzzle', () => {
+      const lights = [1, 2];
+      const buttons = [[0], [1], [0, 1]];
+      const modulus = 3;
+      // Target [1, 2]. 
+      // b0 + b2 = 1 (mod 3)
+      // b1 + b2 = 2 (mod 3)
+      // Sum: b0 + b1 + 2b2 = 3 = 0.
+      // Possible solutions:
+      // 1. b2=0 -> b0=1, b1=2. Total 3. result [1, 2, 0].
+      // 2. b2=1 -> b0=0, b1=1. Total 2. result [0, 1, 1].
+      // 3. b2=2 -> b0=2, b1=0. Total 4. result [2, 0, 2].
+      // Min total presses is 2: [0, 1, 1].
+      expect(solveCounter(lights, buttons, modulus)).toEqual([0, 1, 1]);
+    });
+  });
+});
