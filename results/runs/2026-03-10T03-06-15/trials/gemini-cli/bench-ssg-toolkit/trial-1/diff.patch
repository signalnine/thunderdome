+++ b/src/plugins/dev-server.ts
@@ -0,0 +1,52 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: (ctx: BuildContext) => {
+        const { data, output } = ctx;
+        
+        const assetManifest = data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assetPaths = assetManifest ? assetManifest.assets : [];
+        
+        const routes: Array<{ path: string; handler: string }> = [];
+        
+        // Asset routes
+        for (const asset of assetPaths) {
+          routes.push({
+            path: `/assets/${asset}`,
+            handler: 'asset',
+          });
+        }
+        
+        // Content routes
+        for (const key of output.keys()) {
+          if (key === 'search-index.json') continue;
+          routes.push({
+            path: `/${key}`,
+            handler: 'static',
+          });
+        }
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath: '/search-index.json',
+        };
+
+        data.set('dev-server-config', config);
+      },
+    },
+  };
+}
