@@ -0,0 +1,54 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        if (!file.content) return file;
+
+        let content = file.content;
+
+        // Pre-process admonitions
+        content = content.replace(/:::(note|warning|tip)\n([\s\S]*?)\n:::/g, (_match, type, innerContent) => {
+          return `<div class="admonition admonition-${type}">\n${innerContent}\n</div>`;
+        });
+
+        // Pre-process footnotes
+        const footnotes: { id: string, content: string }[] = [];
+        const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.*)$/gm;
+        
+        let match;
+        while ((match = footnoteDefRegex.exec(content)) !== null) {
+          footnotes.push({ id: match[1], content: match[2] });
+        }
+        content = content.replace(footnoteDefRegex, '');
+
+        content = content.replace(/\[\^(\d+)\]/g, (_match, id) => {
+          return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+        });
+
+        // Convert markdown to HTML
+        let html = await marked.parse(content);
+
+        // Append footnotes section if any
+        if (footnotes.length > 0) {
+          let footnoteHtml = '\n<section class="footnotes">\n<ol>\n';
+          for (const fn of footnotes) {
+            footnoteHtml += `<li id="fn-${fn.id}">${fn.content}</li>\n`;
+          }
+          footnoteHtml += '</ol>\n</section>';
+          html += footnoteHtml;
+        }
+
+        return {
+          ...file,
+          content: html.trim(),
+        };
+      },
+    },
+  };
+}
