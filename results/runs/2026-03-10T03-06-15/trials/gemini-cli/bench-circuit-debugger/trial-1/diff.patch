+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const pendingGates = [...gates];
+  let progress = true;
+
+  while (progress) {
+    progress = false;
+    for (let i = 0; i < pendingGates.length; i++) {
+      const gate = pendingGates[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const v1 = wires[gate.in1];
+        const v2 = wires[gate.in2];
+        let res: number;
+        switch (gate.op) {
+          case 'AND':
+            res = v1 & v2;
+            break;
+          case 'OR':
+            res = v1 | v2;
+            break;
+          case 'XOR':
+            res = v1 ^ v2;
+            break;
+        }
+        wires[gate.out] = res;
+        pendingGates.splice(i, 1);
+        i--;
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+  const maxZ = gates
+    .filter(g => g.out.startsWith('z'))
+    .reduce((max, g) => Math.max(max, parseInt(g.out.slice(1))), 0);
+  const lastZ = `z${maxZ.toString().padStart(2, '0')}`;
+
+  for (const gate of gates) {
+    // Rule 1: Output is zNN, but op is not XOR (except for the last z)
+    if (gate.out.startsWith('z') && gate.out !== lastZ && gate.op !== 'XOR') {
+      swapped.add(gate.out);
+    }
+
+    // Rule 2: Output is not zNN, and inputs are not xNN/yNN, but op is XOR
+    if (
+      !gate.out.startsWith('z') &&
+      !(gate.in1.startsWith('x') || gate.in1.startsWith('y')) &&
+      !(gate.in2.startsWith('x') || gate.in2.startsWith('y')) &&
+      gate.op === 'XOR'
+    ) {
+      swapped.add(gate.out);
+    }
+
+    // Rule 3: XOR with xNN/yNN (except 00) must feed into another XOR
+    if (
+      gate.op === 'XOR' &&
+      (gate.in1.startsWith('x') || gate.in1.startsWith('y')) &&
+      (gate.in2.startsWith('x') || gate.in2.startsWith('y')) &&
+      gate.in1 !== 'x00' && gate.in2 !== 'x00' &&
+      gate.in1 !== 'y00' && gate.in2 !== 'y00'
+    ) {
+      const feedsXor = gates.some(g => g.op === 'XOR' && (g.in1 === gate.out || g.in2 === gate.out));
+      if (!feedsXor) {
+        swapped.add(gate.out);
+      }
+    }
+
+    // Rule 4: AND gates (except x00 AND y00) must feed into an OR
+    if (gate.op === 'AND') {
+      const isBit0 = (gate.in1 === 'x00' && gate.in2 === 'y00') || (gate.in1 === 'y00' && gate.in2 === 'x00');
+      if (!isBit0) {
+        const feedsOr = gates.some(g => g.op === 'OR' && (g.in1 === gate.out || g.in2 === gate.out));
+        if (!feedsOr) {
+          swapped.add(gate.out);
+        }
+      }
+    }
+
+    // Rule 5: OR gates must not feed into another OR
+    if (gate.op === 'OR') {
+      const feedsOr = gates.some(g => g.op === 'OR' && (g.in1 === gate.out || g.in2 === gate.out));
+      if (feedsOr) {
+        swapped.add(gate.out);
+      }
+    }
+  }
+
+  return Array.from(swapped).sort();
+}
