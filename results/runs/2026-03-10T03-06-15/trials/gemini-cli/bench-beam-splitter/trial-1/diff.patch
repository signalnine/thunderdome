+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0 || grid[0].length === 0) return 0;
+  const cols = grid[0].length;
+
+  const visited = new Uint8Array(rows * cols);
+  const processed = new Uint8Array(rows * cols * 3);
+  const queue: [number, number, number][] = [];
+
+  // Find source 'S' on the top row
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      queue.push([0, c, 0]); // dir 0: DOWN
+      visited[0 * cols + c] = 1;
+      processed[(0 * cols + c) * 3 + 0] = 1;
+    }
+  }
+
+  let head = 0;
+  while (head < queue.length) {
+    const [r, c, dir] = queue[head++];
+
+    if (grid[r][c] === '^') {
+      // Splitter: splits into down-left and down-right
+      const nextStates: [number, number, number][] = [
+        [r + 1, c - 1, 1], // dir 1: DOWN_LEFT
+        [r + 1, c + 1, 2]  // dir 2: DOWN_RIGHT
+      ];
+      for (const [nr, nc, ndir] of nextStates) {
+        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+          visited[nr * cols + nc] = 1;
+          const stateIdx = (nr * cols + nc) * 3 + ndir;
+          if (processed[stateIdx] === 0) {
+            processed[stateIdx] = 1;
+            queue.push([nr, nc, ndir]);
+          }
+        }
+      }
+    } else {
+      // Continue in current direction
+      const dr = 1;
+      let dc = 0;
+      if (dir === 1) dc = -1;
+      else if (dir === 2) dc = 1;
+
+      const nr = r + dr;
+      const nc = c + dc;
+
+      if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+        visited[nr * cols + nc] = 1;
+        const stateIdx = (nr * cols + nc) * 3 + dir;
+        if (processed[stateIdx] === 0) {
+          processed[stateIdx] = 1;
+          queue.push([nr, nc, dir]);
+        }
+      }
+    }
+  }
+
+  let count = 0;
+  for (let i = 0; i < visited.length; i++) {
+    if (visited[i] === 1) count++;
+  }
+  return count;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0 || grid[0].length === 0) return 0n;
+  const cols = grid[0].length;
+
+  // dp[c][dir] stores number of paths at current row at column c with direction dir
+  // dir: 0: DOWN, 1: DOWN_LEFT, 2: DOWN_RIGHT
+  let currentDP = new Array<bigint>(cols * 3).fill(0n);
+
+  // Find source 'S'
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      currentDP[c * 3 + 0] = 1n;
+    }
+  }
+
+  let totalPaths = 0n;
+
+  for (let r = 0; r < rows; r++) {
+    const nextDP = new Array<bigint>(cols * 3).fill(0n);
+    for (let c = 0; c < cols; c++) {
+      for (let dir = 0; dir < 3; dir++) {
+        const count = currentDP[c * 3 + dir];
+        if (count === 0n) continue;
+
+        if (grid[r][c] === '^') {
+          // Split into DOWN_LEFT and DOWN_RIGHT
+          // DOWN_LEFT to (r+1, c-1)
+          if (r + 1 < rows && c - 1 >= 0) {
+            nextDP[(c - 1) * 3 + 1] += count;
+          } else {
+            totalPaths += count;
+          }
+          // DOWN_RIGHT to (r+1, c+1)
+          if (r + 1 < rows && c + 1 < cols) {
+            nextDP[(c + 1) * 3 + 2] += count;
+          } else {
+            totalPaths += count;
+          }
+        } else {
+          // Continue in current direction
+          let dc = 0;
+          if (dir === 1) dc = -1;
+          else if (dir === 2) dc = 1;
+
+          const nc = c + dc;
+          if (r + 1 < rows && nc >= 0 && nc < cols) {
+            nextDP[nc * 3 + dir] += count;
+          } else {
+            totalPaths += count;
+          }
+        }
+      }
+    }
+    currentDP = nextDP;
+  }
+
+  return totalPaths;
+}
