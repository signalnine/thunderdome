+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('Beam Splitter', () => {
+  it('should handle the first example (1 splitter)', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('should handle the second example (multiple splitters)', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('should handle empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('should handle source with no obstacles', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('should handle absorption at bottom', () => {
+    const grid = [
+      ['S'],
+    ];
+    expect(countBeamCells(grid)).toBe(1);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('should handle a 200x200 grid with many splitters', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid = Array.from({ length: rows }, () => Array(cols).fill('.'));
+    grid[0][100] = 'S';
+    
+    // Create a pyramid of splitters
+    let splittersPlaced = 0;
+    for (let r = 1; r < rows && splittersPlaced < 50; r++) {
+      for (let c = 100 - (r-1); c <= 100 + (r-1) && splittersPlaced < 50; c += 2) {
+        if (c >= 0 && c < cols) {
+          grid[r][c] = '^';
+          splittersPlaced++;
+        }
+      }
+    }
+    
+    const start = Date.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const end = Date.now();
+    
+    expect(end - start).toBeLessThan(5000);
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+  });
+});
