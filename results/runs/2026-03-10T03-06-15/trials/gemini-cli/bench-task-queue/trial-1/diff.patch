@@ -0,0 +1,580 @@
+import { randomUUID } from 'node:crypto';
+
+export enum TaskStatus {
+  PENDING = 'pending',
+  PROCESSING = 'processing',
+  COMPLETED = 'completed',
+  FAILED = 'failed',
+  DEAD_LETTERED = 'dead-lettered',
+  CANCELLED = 'cancelled',
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: number;
+  priority: number;
+  availableAt: number;
+  attempts: number;
+  maxRetries: number;
+  baseDelay: number;
+  error?: unknown;
+  queueName: string;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+  metadata?: Record<string, unknown>;
+}
+
+export interface AddTaskOptions {
+  priority?: number;
+  delay?: number;
+  availableAt?: number | Date;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependencies?: string[];
+}
+
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export interface Schedule {
+  id: string;
+  expression: string;
+  payload: unknown;
+  queueName: string;
+  options: AddTaskOptions;
+  lastChecked?: number;
+}
+
+export type Middleware = (task: Task<unknown>, next: () => Promise<void> | void) => Promise<void> | void;
+export type Handler = (task: Task<unknown>) => Promise<void> | void;
+
+export interface ShutdownSummary {
+  completedTasks: number;
+  forceCancelledTasks: number;
+  duration: number;
+}
+
+export enum QueueState {
+  ACTIVE = 'active',
+  SHUTTING_DOWN = 'shutting-down',
+  SHUTDOWN = 'shutdown',
+}
+
+export class TaskQueue {
+  private queues: Map<string, Task<unknown>[]> = new Map();
+  private dlqs: Map<string, Task<unknown>[]> = new Map();
+  private allTasks: Map<string, Task<unknown>> = new Map();
+  private concurrencyLimits: Map<string, number> = new Map();
+  private activeCounts: Map<string, number> = new Map();
+  private progressListeners: Map<string, Map<string, ProgressCallback>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private middlewares: Map<string, Middleware[]> = new Map();
+  private handlers: Map<string, Handler> = new Map();
+  private state: QueueState = QueueState.ACTIVE;
+  private shutdownCallbacks: (() => Promise<void> | void)[] = [];
+  private shutdownResult: ShutdownSummary | null = null;
+  private readonly DEFAULT_QUEUE = 'default';
+
+  constructor() {
+    this.ensureQueue(this.DEFAULT_QUEUE);
+  }
+
+  private ensureQueue(queueName: string): void {
+    if (!this.queues.has(queueName)) {
+      this.queues.set(queueName, []);
+      this.dlqs.set(queueName, []);
+      this.concurrencyLimits.set(queueName, Infinity);
+      this.activeCounts.set(queueName, 0);
+      this.middlewares.set(queueName, []);
+    }
+  }
+
+  addTask<T = unknown>(payload: T, queueName: string = this.DEFAULT_QUEUE, options: AddTaskOptions = {}): Task<T> {
+    if (this.state !== QueueState.ACTIVE) {
+      throw new Error('Cannot add task while system is shutting down or shutdown');
+    }
+
+    const priority = options.priority ?? 5;
+
+    if (priority < 1 || priority > 10) {
+      throw new Error('Priority must be between 1 and 10');
+    }
+
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      if (!this.allTasks.has(depId)) {
+        throw new Error(`Dependency task ${depId} not found`);
+      }
+    }
+
+    const now = Date.now();
+    let availableAt = now;
+
+    if (options.availableAt !== undefined) {
+      availableAt = options.availableAt instanceof Date ? options.availableAt.getTime() : options.availableAt;
+    } else if (options.delay !== undefined) {
+      availableAt = now + options.delay;
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: TaskStatus.PENDING,
+      createdAt: now,
+      priority,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      baseDelay: options.baseDelay ?? 1000,
+      queueName,
+      dependencies,
+      progress: 0,
+      metadata: {},
+    };
+
+    this.ensureQueue(queueName);
+
+    this.queues.get(queueName)!.push(task as Task<unknown>);
+    this.allTasks.set(task.id, task as Task<unknown>);
+    return task;
+  }
+
+  getNextTask(queueName: string = this.DEFAULT_QUEUE): Task<unknown> | null {
+    if (this.state !== QueueState.ACTIVE) {
+      return null;
+    }
+
+    this.ensureQueue(queueName);
+    
+    const activeCount = this.activeCounts.get(queueName) || 0;
+    const limit = this.concurrencyLimits.get(queueName) || Infinity;
+    
+    if (activeCount >= limit) {
+      return null;
+    }
+
+    const queue = this.queues.get(queueName);
+    if (!queue || queue.length === 0) {
+      return null;
+    }
+
+    const now = Date.now();
+
+    // Find all pending and available tasks that are not blocked by dependencies
+    const availableTasks = queue
+      .map((task, index) => ({ task, index }))
+      .filter(({ task }) => {
+        if (task.status !== TaskStatus.PENDING || task.availableAt > now) {
+          return false;
+        }
+        
+        // Check dependencies
+        for (const depId of task.dependencies) {
+          const dep = this.allTasks.get(depId);
+          if (!dep || dep.status !== TaskStatus.COMPLETED) {
+            return false;
+          }
+        }
+        
+        return true;
+      });
+
+    if (availableTasks.length === 0) {
+      return null;
+    }
+
+    // Sort by priority (asc), then availableAt (asc), then by index (FIFO)
+    availableTasks.sort((a, b) => {
+      if (a.task.priority !== b.task.priority) {
+        return a.task.priority - b.task.priority;
+      }
+      if (a.task.availableAt !== b.task.availableAt) {
+        return a.task.availableAt - b.task.availableAt;
+      }
+      return a.index - b.index;
+    });
+
+    const { task } = availableTasks[0];
+    task.status = TaskStatus.PROCESSING;
+    task.attempts++;
+    
+    this.activeCounts.set(queueName, activeCount + 1);
+    
+    return task;
+  }
+
+  completeTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error('Task not found');
+    }
+    
+    if (task.status === TaskStatus.CANCELLED) {
+      return;
+    }
+
+    if (task.status === TaskStatus.PROCESSING) {
+      const activeCount = this.activeCounts.get(task.queueName) || 0;
+      this.activeCounts.set(task.queueName, Math.max(0, activeCount - 1));
+    }
+    
+    task.status = TaskStatus.COMPLETED;
+    task.progress = 100;
+  }
+
+  failTask(taskId: string, error?: unknown): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error('Task not found');
+    }
+
+    if (task.status === TaskStatus.CANCELLED) {
+      return;
+    }
+
+    if (task.status === TaskStatus.PROCESSING) {
+      const activeCount = this.activeCounts.get(task.queueName) || 0;
+      this.activeCounts.set(task.queueName, Math.max(0, activeCount - 1));
+    }
+
+    task.error = error;
+    
+    if (task.attempts <= task.maxRetries) {
+      // Retry
+      const delay = task.baseDelay * Math.pow(2, task.attempts - 1);
+      task.availableAt = Date.now() + delay;
+      task.status = TaskStatus.PENDING;
+    } else {
+      task.status = TaskStatus.DEAD_LETTERED;
+      
+      // Move to DLQ
+      const queue = this.queues.get(task.queueName);
+      if (queue) {
+        const index = queue.findIndex(t => t.id === taskId);
+        if (index !== -1) {
+          queue.splice(index, 1);
+        }
+      }
+      this.dlqs.get(task.queueName)!.push(task);
+    }
+  }
+
+  getTask(taskId: string): Task<unknown> | null {
+    return this.allTasks.get(taskId) ?? null;
+  }
+
+  getDeadLetterTasks(queueName: string = this.DEFAULT_QUEUE): Task<unknown>[] {
+    return this.dlqs.get(queueName) || [];
+  }
+
+  retryDeadLetterTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task || task.status !== TaskStatus.DEAD_LETTERED) {
+      throw new Error('Task not in DLQ');
+    }
+    
+    const dlq = this.dlqs.get(task.queueName);
+    if (!dlq) {
+      throw new Error('DLQ not found');
+    }
+
+    const index = dlq.findIndex(t => t.id === taskId);
+    if (index === -1) {
+      throw new Error('Task not in DLQ');
+    }
+
+    // Reset task
+    task.attempts = 0;
+    task.status = TaskStatus.PENDING;
+    task.availableAt = Date.now();
+    task.error = undefined;
+
+    // Move back to original queue
+    dlq.splice(index, 1);
+    this.queues.get(task.queueName)!.push(task);
+  }
+
+  clearDeadLetterTasks(queueName: string = this.DEFAULT_QUEUE): void {
+    const dlq = this.dlqs.get(queueName);
+    if (dlq) {
+      dlq.forEach(task => this.allTasks.delete(task.id));
+      this.dlqs.set(queueName, []);
+    }
+  }
+
+  getWaitingCount(queueName: string = this.DEFAULT_QUEUE): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) {
+      return 0;
+    }
+    const now = Date.now();
+    return queue.filter((t) => {
+      if (t.status !== TaskStatus.PENDING || t.availableAt > now) {
+        return false;
+      }
+      // Check dependencies
+      for (const depId of t.dependencies) {
+        const dep = this.allTasks.get(depId);
+        if (!dep || dep.status !== TaskStatus.COMPLETED) {
+          return false;
+        }
+      }
+      return true;
+    }).length;
+  }
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  getDependencyStatus(taskId: string): { completed: string[], blockedBy: string[] } {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error('Task not found');
+    }
+
+    const completed: string[] = [];
+    const blockedBy: string[] = [];
+
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (dep && dep.status === TaskStatus.COMPLETED) {
+        completed.push(depId);
+      } else {
+        blockedBy.push(depId);
+      }
+    }
+
+    return { completed, blockedBy };
+  }
+
+  setConcurrencyLimit(queueName: string, limit: number): void {
+    this.ensureQueue(queueName);
+    this.concurrencyLimits.set(queueName, limit);
+  }
+
+  getConcurrencyLimit(queueName: string = this.DEFAULT_QUEUE): number {
+    return this.concurrencyLimits.get(queueName) ?? Infinity;
+  }
+
+  getActiveCount(queueName: string = this.DEFAULT_QUEUE): number {
+    return this.activeCounts.get(queueName) ?? 0;
+  }
+
+  updateTaskProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error('Task not found');
+    }
+    if (task.status !== TaskStatus.PROCESSING) {
+      throw new Error('Task is not in processing state');
+    }
+
+    task.progress = Math.min(100, Math.max(0, progress));
+    task.progressMessage = message;
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const callback of listeners.values()) {
+        callback(task.progress, task.progressMessage);
+      }
+    }
+  }
+
+  subscribeToProgress(taskId: string, callback: ProgressCallback): () => void {
+    if (!this.allTasks.has(taskId)) {
+      throw new Error('Task not found');
+    }
+
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Map());
+    }
+
+    const subscriptionId = randomUUID();
+    this.progressListeners.get(taskId)!.set(subscriptionId, callback);
+
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(subscriptionId);
+        if (listeners.size === 0) {
+          this.progressListeners.delete(taskId);
+        }
+      }
+    };
+  }
+
+  cancelTask(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error('Task not found');
+    }
+
+    if (task.status === TaskStatus.COMPLETED || task.status === TaskStatus.FAILED || task.status === TaskStatus.DEAD_LETTERED) {
+      return;
+    }
+
+    if (task.status === TaskStatus.PROCESSING) {
+      const activeCount = this.activeCounts.get(task.queueName) || 0;
+      this.activeCounts.set(task.queueName, Math.max(0, activeCount - 1));
+    }
+
+    task.status = TaskStatus.CANCELLED;
+    
+    const queue = this.queues.get(task.queueName);
+    if (queue) {
+      const index = queue.findIndex(t => t.id === taskId);
+      if (index !== -1) {
+        queue.splice(index, 1);
+      }
+    }
+  }
+
+  addSchedule<T = unknown>(expression: string, payload: T, queueName: string = this.DEFAULT_QUEUE, options: AddTaskOptions = {}): string {
+    if (this.state !== QueueState.ACTIVE) {
+      throw new Error('Cannot add schedule while system is shutting down or shutdown');
+    }
+    const id = randomUUID();
+    this.schedules.set(id, { id, expression, payload, queueName, options });
+    return id;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  checkSchedules(now: number = Date.now()): void {
+    if (this.state !== QueueState.ACTIVE) return;
+
+    const date = new Date(now);
+    const minute = date.getMinutes();
+    const hour = date.getHours();
+
+    for (const schedule of this.schedules.values()) {
+      const lastMinute = schedule.lastChecked ? new Date(schedule.lastChecked).getMinutes() : -1;
+      const lastHour = schedule.lastChecked ? new Date(schedule.lastChecked).getHours() : -1;
+      const lastDay = schedule.lastChecked ? new Date(schedule.lastChecked).getDate() : -1;
+      
+      const isNewMinute = minute !== lastMinute || date.getHours() !== lastHour || date.getDate() !== lastDay;
+      if (!isNewMinute) continue;
+
+      let shouldRun = false;
+      const parts = schedule.expression.split(' ');
+
+      if (parts.length === 5) {
+        const [m, h] = parts;
+        if (m === '0' && h === '0') {
+          shouldRun = minute === 0 && hour === 0;
+        } else if (m === '0' && h === '*') {
+          shouldRun = minute === 0;
+        } else if (m.startsWith('*/')) {
+          const n = parseInt(m.substring(2));
+          shouldRun = minute % n === 0;
+        }
+      }
+
+      if (shouldRun) {
+        this.addTask(schedule.payload, schedule.queueName, schedule.options);
+        schedule.lastChecked = now;
+      }
+    }
+  }
+
+  use(queueName: string, middleware: Middleware): void {
+    this.ensureQueue(queueName);
+    this.middlewares.get(queueName)!.push(middleware);
+  }
+
+  registerHandler(queueName: string, handler: Handler): void {
+    this.ensureQueue(queueName);
+    this.handlers.set(queueName, handler);
+  }
+
+  async processNextTask(queueName: string = this.DEFAULT_QUEUE): Promise<boolean> {
+    const task = this.getNextTask(queueName);
+    if (!task) {
+      return false;
+    }
+
+    const middlewares = this.middlewares.get(queueName) || [];
+    const handler = this.handlers.get(queueName);
+
+    let index = -1;
+    const next = async (): Promise<void> => {
+      index++;
+      if (index < middlewares.length) {
+        await middlewares[index](task, next);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await next();
+      if (task.status === TaskStatus.PROCESSING) {
+        this.completeTask(task.id);
+      }
+    } catch (error) {
+      this.failTask(task.id, error);
+    }
+
+    return true;
+  }
+
+  onShutdown(callback: () => Promise<void> | void): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout: number = 5000): Promise<ShutdownSummary> {
+    if (this.shutdownResult) {
+      return this.shutdownResult;
+    }
+
+    const startTime = Date.now();
+    this.state = QueueState.SHUTTING_DOWN;
+
+    // Run shutdown callbacks
+    for (const callback of this.shutdownCallbacks) {
+      await callback();
+    }
+
+    const initialProcessingTasks = Array.from(this.allTasks.values()).filter(t => t.status === TaskStatus.PROCESSING);
+    
+    if (initialProcessingTasks.length > 0) {
+      const waitStart = Date.now();
+      while (Date.now() - waitStart < timeout) {
+        const stillProcessing = Array.from(this.allTasks.values()).filter(t => initialProcessingTasks.some(pt => pt.id === t.id) && t.status === TaskStatus.PROCESSING);
+        if (stillProcessing.length === 0) {
+          break;
+        }
+        await new Promise(resolve => setTimeout(resolve, 100));
+      }
+    }
+
+    const finalProcessingTasks = Array.from(this.allTasks.values()).filter(t => initialProcessingTasks.some(pt => pt.id === t.id) && t.status === TaskStatus.PROCESSING);
+    
+    let forceCancelledTasks = 0;
+    for (const task of finalProcessingTasks) {
+      this.cancelTask(task.id);
+      forceCancelledTasks++;
+    }
+
+    const finishedProcessingTasks = initialProcessingTasks.filter(t => !finalProcessingTasks.some(f => f.id === t.id));
+    const completedCount = finishedProcessingTasks.filter(t => t.status === TaskStatus.COMPLETED).length;
+
+    this.state = QueueState.SHUTDOWN;
+    this.shutdownResult = {
+      completedTasks: completedCount,
+      forceCancelledTasks,
+      duration: Date.now() - startTime,
+    };
+
+    return this.shutdownResult;
+  }
+}
