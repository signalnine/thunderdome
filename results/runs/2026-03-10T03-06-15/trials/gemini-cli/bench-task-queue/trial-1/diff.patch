+      queue.use('default', async (_task: Task<unknown>, next: () => Promise<void> | void) => {
+        callOrder.push('m1-start');
+        await next();
+        callOrder.push('m1-end');
+      });
+      queue.use('default', async (_task: Task<unknown>, next: () => Promise<void> | void) => {
+        callOrder.push('m2-start');
+        await next();
+        callOrder.push('m2-end');
+      });
+      queue.registerHandler('default', async (_task: Task<unknown>) => {
+        callOrder.push('handler');
+      });
+
+      queue.addTask({ foo: 'bar' } as TestPayload);
+      const processed = await queue.processNextTask();
+
+      expect(processed).toBe(true);
+      expect(callOrder).toEqual(['m1-start', 'm2-start', 'handler', 'm2-end', 'm1-end']);
+    });
+
+    it('should allow middleware to modify task', async () => {
+      queue.use('default', async (task: Task<unknown>, next: () => Promise<void> | void) => {
+        task.metadata = { ...task.metadata, enriched: true };
+        await next();
+      });
+      queue.registerHandler('default', async (task: Task<unknown>) => {
+        expect(task.metadata?.enriched).toBe(true);
+      });
+
+      queue.addTask({ foo: 'bar' } as TestPayload);
+      await queue.processNextTask();
+    });
+
+    it('should skip processing if next is not called', async () => {
+      queue.use('default', async (_task: Task<unknown>, _next: () => Promise<void> | void) => {
+        // next() NOT called
+      });
+      let handlerCalled = false;
+      queue.registerHandler('default', () => {
+        handlerCalled = true;
+      });
+
+      queue.addTask({ foo: 'bar' } as TestPayload);
+      await queue.processNextTask();
+      
+      expect(handlerCalled).toBe(false);
+    });
+
+    it('should fail task if middleware/handler throws', async () => {
+      queue.registerHandler('default', () => {
+        throw new Error('boom');
+      });
+
+      const task = queue.addTask({ foo: 'bar' } as TestPayload);
+      await queue.processNextTask();
+      
+      const updated = queue.getTask(task.id);
+      expect(updated?.status).toBe(TaskStatus.PENDING); // Retrying
+      expect(updated?.error instanceof Error ? (updated?.error as Error).message : updated?.error).toBe('boom');
+    });
+  });
+
+  describe('Phase 12: Graceful Shutdown', () => {
+    it('should stop accepting new tasks after shutdown', async () => {
+      await queue.shutdown();
+      expect(() => queue.addTask({ foo: 'bar' } as TestPayload)).toThrow('Cannot add task');
+      expect(() => queue.addSchedule('* * * * *', {} as TestPayload)).toThrow('Cannot add schedule');
+      expect(queue.getNextTask()).toBeNull();
+    });
+
+    it('should wait for processing tasks', async () => {
+      let finished = false;
+      queue.registerHandler('default', async () => {
+        await new Promise(resolve => setTimeout(resolve, 200));
+        finished = true;
+      });
+      
+      queue.addTask({ foo: 'bar' } as TestPayload);
+      queue.processNextTask(); // Start processing
+
+      await new Promise(resolve => setTimeout(resolve, 50));
+      const summary = await queue.shutdown(1000);
+
+      
+      expect(finished).toBe(true);
+      expect(summary.completedTasks).toBe(1);
+      expect(summary.forceCancelledTasks).toBe(0);
+    });
+
+    it('should force-cancel tasks after timeout', async () => {
+      queue.registerHandler('default', async () => {
+        await new Promise(resolve => setTimeout(resolve, 1000));
+      });
+      
+      const task = queue.addTask({ foo: 'bar' } as TestPayload);
+      queue.processNextTask();
+
+      await new Promise(resolve => setTimeout(resolve, 50));
+      const summary = await queue.shutdown(100);
+
+      
+      expect(summary.completedTasks).toBe(0);
+      expect(summary.forceCancelledTasks).toBe(1);
+      expect(queue.getTask(task.id)?.status).toBe(TaskStatus.CANCELLED);
+    });
+
+    it('should run shutdown callbacks', async () => {
+      let called = false;
+      queue.onShutdown(() => {
+        called = true;
+      });
+      
+      await queue.shutdown();
+      expect(called).toBe(true);
+    });
+
+    it('should return the same summary if called multiple times', async () => {
+      const s1 = await queue.shutdown();
+      const s2 = await queue.shutdown();
+      expect(s1).toBe(s2);
+    });
+  });
+});
