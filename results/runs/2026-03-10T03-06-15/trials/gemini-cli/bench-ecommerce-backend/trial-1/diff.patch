new file mode 100644
index 0000000..41f29b2
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,75 @@
+import { EventBus } from '../bus.js';
+import { 
+  AnalyticsService, Events, OrderCreatedEvent, PaymentProcessedEvent, 
+  CartUpdatedEvent, PaymentStatus 
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const orderAmounts = new Map<string, number>();
+  const orders = new Set<string>();
+  const carts = new Set<string>();
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+  const productOrderQuantities = new Map<string, number>();
+
+  const trackEvent = (event: string) => {
+    eventCounts.set(event, (eventCounts.get(event) || 0) + 1);
+  };
+
+  // Register listeners for all events
+  Object.values(Events).forEach((event: string) => {
+    bus.on(event, () => trackEvent(event));
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const data = payload as OrderCreatedEvent;
+    orders.add(data.orderId);
+    orderAmounts.set(data.orderId, data.total);
+    
+    // Track product quantities from the cart
+    const items = cartItems.get(data.cartId) || [];
+    items.forEach(item => {
+      productOrderQuantities.set(
+        item.productId, 
+        (productOrderQuantities.get(item.productId) || 0) + item.quantity
+      );
+    });
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const data = payload as PaymentProcessedEvent;
+    if (data.status === PaymentStatus.SUCCESS) {
+      const amount = orderAmounts.get(data.orderId) || 0;
+      revenue += amount;
+    }
+  });
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const data = payload as CartUpdatedEvent;
+    carts.add(data.cartId);
+    cartItems.set(data.cartId, data.items);
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) || 0;
+    },
+
+    getRevenue(): number {
+      return revenue;
+    },
+
+    getConversionRate(): number {
+      if (carts.size === 0) return 0;
+      return orders.size / carts.size;
+    },
+
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> {
+      return Array.from(productOrderQuantities.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    }
+  };
+}
