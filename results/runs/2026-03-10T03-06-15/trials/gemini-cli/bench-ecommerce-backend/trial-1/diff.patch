@@ -0,0 +1,53 @@
+import { EventBus } from '../bus.js';
+import { 
+  NotificationService, Events, OrderCreatedEvent, 
+  OrderStatusChangedEvent, PaymentProcessedEvent 
+} from '../types.js';
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const notifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();
+  const orderUserMap = new Map<string, string>();
+  const subscribedUsers = new Set<string>();
+
+  const addNotification = (userId: string, type: string, message: string) => {
+    if (!subscribedUsers.has(userId)) return;
+    
+    if (!notifications.has(userId)) {
+      notifications.set(userId, []);
+    }
+    notifications.get(userId)!.push({ type, message, timestamp: Date.now() });
+    
+    bus.emit(Events.NOTIFICATION_SENT, { userId, type, message });
+  };
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const data = payload as OrderCreatedEvent;
+    orderUserMap.set(data.orderId, data.userId);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {
+    const data = payload as OrderStatusChangedEvent;
+    const userId = orderUserMap.get(data.orderId);
+    if (userId) {
+      addNotification(userId, 'order_status', `Order ${data.orderId} status changed to ${data.status}`);
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const data = payload as PaymentProcessedEvent;
+    const userId = orderUserMap.get(data.orderId);
+    if (userId) {
+      addNotification(userId, 'payment', `Payment for order ${data.orderId} ${data.status}`);
+    }
+  });
+
+  return {
+    subscribe(userId: string): void {
+      subscribedUsers.add(userId);
+    },
+
+    getNotifications(userId: string) {
+      return notifications.get(userId) || [];
+    }
+  };
+}
