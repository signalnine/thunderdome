@@ -0,0 +1,48 @@
+import { EventBus } from '../bus.js';
+import { PaymentService, Events, PaymentStatus, PaymentProcessedEvent } from '../types.js';
+
+export interface PaymentOptions {
+  simulationMode?: PaymentStatus;
+  delay?: number;
+}
+
+export function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {
+  const transactions = new Set<string>();
+
+  return {
+    async processPayment(orderId: string, _amount: number): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> {
+      const { simulationMode = PaymentStatus.SUCCESS, delay = 0 } = options;
+      
+      if (delay > 0) {
+        await new Promise(resolve => setTimeout(resolve, delay));
+      }
+
+      let result: { status: PaymentStatus; transactionId?: string; error?: string };
+
+      if (simulationMode === PaymentStatus.SUCCESS) {
+        const transactionId = `txn_${Math.random().toString(36).substring(2, 9)}`;
+        transactions.add(transactionId);
+        result = { status: PaymentStatus.SUCCESS, transactionId };
+      } else if (simulationMode === PaymentStatus.FAILED) {
+        result = { status: PaymentStatus.FAILED, error: 'Insufficient funds' };
+      } else {
+        result = { status: PaymentStatus.TIMEOUT, error: 'Gateway timeout' };
+      }
+
+      const event: PaymentProcessedEvent = { orderId, ...result };
+      await bus.emit(Events.PAYMENT_PROCESSED, event);
+
+      return result;
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      if (transactions.has(transactionId)) {
+        transactions.delete(transactionId);
+        // In a real system, we might emit a PAYMENT_REFUNDED event, 
+        // but it's not in the types.ts Events object.
+        return true;
+      }
+      return false;
+    }
+  };
+}
