+++ b/src/index.ts
@@ -0,0 +1,142 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set<number>(gates.map((_, i) => i));
+
+  let changed = true;
+  while (changed) {
+    changed = false;
+    for (const idx of remaining) {
+      const g = gates[idx];
+      if (wires[g.in1] !== undefined && wires[g.in2] !== undefined) {
+        const a = wires[g.in1];
+        const b = wires[g.in2];
+        let result: number;
+        switch (g.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[g.out] = result;
+        remaining.delete(idx);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Build lookup: output wire -> gate
+  const outToGate = new Map<string, Gate>();
+  for (const g of gates) {
+    outToGate.set(g.out, g);
+  }
+
+  // Determine how many bits the adder has by looking at x-wires
+  const xWires = new Set<string>();
+  for (const g of gates) {
+    if (g.in1.startsWith('x')) xWires.add(g.in1);
+    if (g.in2.startsWith('x')) xWires.add(g.in2);
+  }
+  const numBits = xWires.size;
+
+  const swapped = new Set<string>();
+
+  // Helper to pad bit index to 2 digits
+  function pad(n: number): string {
+    return n.toString().padStart(2, '0');
+  }
+
+  // Structural analysis approach:
+  // Check rules that must hold for a ripple-carry adder and collect violations.
+  //
+  // Rules:
+  // 1. z-wires (except the last one z{numBits}) must be outputs of XOR gates
+  // 2. XOR gates with x/y inputs must NOT output to z (except z00)
+  // 3. XOR gates with non-x/y inputs must output to z
+  // 4. AND gates (except x00 AND y00) must feed into OR gates
+  // 5. XOR gate outputs that aren't z must feed into both XOR and AND gates
+
+  // Check each gate against structural rules
+  for (const g of gates) {
+    const isXYInput =
+      (g.in1.startsWith('x') || g.in1.startsWith('y')) &&
+      (g.in2.startsWith('x') || g.in2.startsWith('y'));
+    const isZOutput = g.out.startsWith('z');
+    const lastZ = `z${pad(numBits)}`;
+
+    if (isZOutput && g.out !== lastZ) {
+      // Rule 1: z-wires must come from XOR gates
+      if (g.op !== 'XOR') {
+        swapped.add(g.out);
+      }
+    }
+
+    if (g.op === 'XOR') {
+      if (isXYInput) {
+        // Rule 2: XOR of x/y inputs should not output directly to z (except z00)
+        if (isZOutput && g.out !== 'z00') {
+          swapped.add(g.out);
+        }
+        // Rule 5: If not z00, the output should feed into both an XOR and an AND
+        if (!isZOutput && g.out !== 'z00') {
+          // Check that this output is used as input to an XOR gate
+          const feedsXOR = gates.some(
+            (other) =>
+              other.op === 'XOR' &&
+              (other.in1 === g.out || other.in2 === g.out),
+          );
+          if (!feedsXOR) {
+            swapped.add(g.out);
+          }
+        }
+      } else {
+        // Rule 3: XOR of non-x/y inputs must output to z
+        if (!isZOutput) {
+          swapped.add(g.out);
+        }
+      }
+    }
+
+    if (g.op === 'AND') {
+      // Rule 4: AND gate outputs must feed into OR gates (except the half-adder AND for bit 0)
+      const isBit0 =
+        (g.in1 === 'x00' || g.in1 === 'y00') &&
+        (g.in2 === 'x00' || g.in2 === 'y00');
+      if (!isBit0) {
+        const feedsOR = gates.some(
+          (other) =>
+            other.op === 'OR' &&
+            (other.in1 === g.out || other.in2 === g.out),
+        );
+        if (!feedsOR) {
+          swapped.add(g.out);
+        }
+      }
+    }
+  }
+
+  // If we found exactly 8 wires, great. If not, we need more analysis.
+  // But with 4 swaps = 8 wires, the structural rules should catch them all.
+  // However, sometimes a swap might cause two rules to flag the same wire,
+  // or a swap partner might be caught by different rules.
+
+  return Array.from(swapped).sort();
+}
