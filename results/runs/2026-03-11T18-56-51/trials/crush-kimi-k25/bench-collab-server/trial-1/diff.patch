@@ -0,0 +1,180 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join, dirname } from 'path';
+import { fileURLToPath } from 'url';
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+  version: number;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export interface Operation {
+  type: 'insert' | 'delete';
+  position: number;
+  text?: string;
+  length?: number;
+}
+
+export class DatabaseManager {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    this.init();
+  }
+
+  private init(): void {
+    const schemaPath = join(dirname(__dirname), 'schema.sql');
+    const schema = readFileSync(schemaPath, 'utf-8');
+    this.db.exec(schema);
+  }
+
+  close(): void {
+    this.db.close();
+  }
+
+  // Document operations
+  createDocument(id: string, title: string, content: string = ''): Document {
+    const stmt = this.db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version
+    const versionStmt = this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, ?)'
+    );
+    versionStmt.run(id, content, null);
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | null {
+    const stmt = this.db.prepare(
+      `SELECT d.*, COALESCE(MAX(v.version), 0) as version
+       FROM documents d
+       LEFT JOIN versions v ON d.id = v.document_id
+       WHERE d.id = ?
+       GROUP BY d.id`
+    );
+    return stmt.get(id) as Document | null;
+  }
+
+  getAllDocuments(): Document[] {
+    const stmt = this.db.prepare(
+      `SELECT d.*, COALESCE(MAX(v.version), 0) as version
+       FROM documents d
+       LEFT JOIN versions v ON d.id = v.document_id
+       GROUP BY d.id
+       ORDER BY d.updated_at DESC`
+    );
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, title?: string, content?: string): Document | null {
+    const doc = this.getDocument(id);
+    if (!doc) return null;
+
+    const newTitle = title ?? doc.title;
+    const newContent = content ?? doc.content;
+
+    const updateStmt = this.db.prepare(
+      'UPDATE documents SET title = ?, content = ?, updated_at = datetime(\'now\') WHERE id = ?'
+    );
+    updateStmt.run(newTitle, newContent, id);
+
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const stmt = this.db.prepare('DELETE FROM documents WHERE id = ?');
+    const result = stmt.run(id);
+    return result.changes > 0;
+  }
+
+  // Version operations
+  addVersion(documentId: string, content: string, operation: Operation): Version {
+    const doc = this.getDocument(documentId);
+    if (!doc) throw new Error('Document not found');
+
+    const newVersion = doc.version + 1;
+    const stmt = this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    );
+    const result = stmt.run(documentId, newVersion, content, JSON.stringify(operation));
+
+    // Update document content
+    this.db.prepare('UPDATE documents SET content = ?, updated_at = datetime(\'now\') WHERE id = ?').run(content, documentId);
+
+    return {
+      id: result.lastInsertRowid as number,
+      document_id: documentId,
+      version: newVersion,
+      content,
+      operation: JSON.stringify(operation),
+      created_at: new Date().toISOString(),
+    };
+  }
+
+  getVersions(documentId: string): Version[] {
+    const stmt = this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    );
+    return stmt.all(documentId) as Version[];
+  }
+
+  getVersion(documentId: string, version: number): Version | null {
+    const stmt = this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? AND version = ?'
+    );
+    return stmt.get(documentId, version) as Version | null;
+  }
+
+  // Connection tracking
+  addConnection(connectionId: string, documentId: string): void {
+    const stmt = this.db.prepare(
+      'INSERT OR REPLACE INTO active_connections (id, document_id) VALUES (?, ?)'
+    );
+    stmt.run(connectionId, documentId);
+  }
+
+  removeConnection(connectionId: string): void {
+    const stmt = this.db.prepare('DELETE FROM active_connections WHERE id = ?');
+    stmt.run(connectionId);
+  }
+
+  getConnectionsForDocument(documentId: string): string[] {
+    const stmt = this.db.prepare(
+      'SELECT id FROM active_connections WHERE document_id = ?'
+    );
+    const rows = stmt.all(documentId) as { id: string }[];
+    return rows.map(r => r.id);
+  }
+
+  getConnectionDocument(connectionId: string): string | null {
+    const stmt = this.db.prepare(
+      'SELECT document_id FROM active_connections WHERE id = ?'
+    );
+    const row = stmt.get(connectionId) as { document_id: string } | null;
+    return row?.document_id ?? null;
+  }
+
+  getDb(): Database.Database {
+    return this.db;
+  }
+}
