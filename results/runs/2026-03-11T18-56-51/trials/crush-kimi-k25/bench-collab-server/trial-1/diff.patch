+++ b/src/ot.ts
@@ -0,0 +1,187 @@
+// Operational Transform (OT) implementation for collaborative editing
+// This ensures that concurrent operations converge to the same state
+
+export interface Operation {
+  type: 'insert' | 'delete';
+  position: number;
+  text?: string;
+  length?: number;
+  clientId?: string;
+  timestamp?: number;
+}
+
+export interface TransformedOperation extends Operation {
+  transformed: boolean;
+  originalPosition: number;
+}
+
+/**
+ * Apply an operation to a document string
+ */
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert' && op.text) {
+    // Clamp position to valid range
+    const pos = Math.max(0, Math.min(op.position, content.length));
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else if (op.type === 'delete' && op.length) {
+    const pos = Math.max(0, Math.min(op.position, content.length));
+    const endPos = Math.min(pos + op.length, content.length);
+    return content.slice(0, pos) + content.slice(endPos);
+  }
+  return content;
+}
+
+/**
+ * Transform operation A against operation B
+ * Returns the transformed version of A that can be applied after B
+ *
+ * This is the core OT algorithm - it ensures concurrent edits
+ * don't overwrite each other
+ */
+export function transformOperation(a: Operation, b: Operation): Operation {
+  // Make copies to avoid mutating inputs
+  const transformed: Operation = { ...a };
+
+  if (a.type === 'insert' && b.type === 'insert') {
+    // Both are insertions
+    if (b.position < a.position) {
+      // B was inserted before A, so A needs to shift right
+      transformed.position = a.position + (b.text?.length ?? 0);
+    } else if (b.position === a.position) {
+      // Same position - use deterministic tiebreaker (timestamp or clientId)
+      const aOrder = a.timestamp ?? 0;
+      const bOrder = b.timestamp ?? 0;
+      if (aOrder > bOrder || (aOrder === bOrder && (a.clientId ?? '') > (b.clientId ?? ''))) {
+        transformed.position = a.position + (b.text?.length ?? 0);
+      }
+    }
+  } else if (a.type === 'delete' && b.type === 'delete') {
+    // Both are deletions
+    const bEnd = b.position + (b.length ?? 0);
+
+    if (b.position >= a.position + (a.length ?? 0)) {
+      // B is entirely after A, no change needed
+    } else if (bEnd <= a.position) {
+      // B is entirely before A, shift A left
+      transformed.position = a.position - (b.length ?? 0);
+    } else {
+      // Overlapping deletions - need to adjust
+      if (b.position <= a.position) {
+        // B starts before or at A
+        const overlapStart = a.position;
+        const overlapEnd = Math.min(a.position + (a.length ?? 0), bEnd);
+        const overlapLength = overlapEnd - overlapStart;
+
+        transformed.position = b.position;
+        transformed.length = Math.max(0, (a.length ?? 0) - overlapLength);
+      } else {
+        // B starts within A
+        const overlapLength = Math.min(b.length ?? 0, a.position + (a.length ?? 0) - b.position);
+        transformed.length = Math.max(0, (a.length ?? 0) - overlapLength);
+      }
+    }
+  } else if (a.type === 'insert' && b.type === 'delete') {
+    // A is insert, B is delete
+    const bEnd = b.position + (b.length ?? 0);
+
+    if (b.position >= a.position) {
+      // Delete is after insert, no change needed
+    } else if (bEnd <= a.position) {
+      // Delete is entirely before insert, shift insert left
+      transformed.position = a.position - (b.length ?? 0);
+    } else {
+      // Delete overlaps insert position - shift insert to delete position
+      transformed.position = b.position;
+    }
+  } else if (a.type === 'delete' && b.type === 'insert') {
+    // A is delete, B is insert
+    if (b.position <= a.position) {
+      // Insert is before or at delete start, shift delete right
+      transformed.position = a.position + (b.text?.length ?? 0);
+    }
+    // Otherwise insert is after delete, no change
+  }
+
+  return transformed;
+}
+
+/**
+ * Transform an operation against a list of operations
+ * This is used when a client needs to apply an operation that was
+ * created against an older version of the document
+ */
+export function transformAgainstOperations(
+  operation: Operation,
+  operations: Operation[]
+): Operation {
+  let transformed = { ...operation };
+  for (const op of operations) {
+    transformed = transformOperation(transformed, op);
+  }
+  return transformed;
+}
+
+/**
+ * Validate an operation
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (typeof op !== 'object' || op === null) return false;
+
+  const operation = op as Partial<Operation>;
+
+  if (operation.type !== 'insert' && operation.type !== 'delete') return false;
+  if (typeof operation.position !== 'number') return false;
+  if (operation.position < 0) return false;
+
+  if (operation.type === 'insert') {
+    if (typeof operation.text !== 'string') return false;
+    if (operation.text.length === 0) return false;
+  } else {
+    if (typeof operation.length !== 'number') return false;
+    if (operation.length <= 0) return false;
+  }
+
+  return true;
+}
+
+/**
+ * Create a proper operation object with all required fields
+ */
+export function createOperation(
+  type: 'insert' | 'delete',
+  position: number,
+  payload: { text?: string; length?: number },
+  clientId?: string
+): Operation {
+  return {
+    type,
+    position,
+    ...payload,
+    clientId,
+    timestamp: Date.now(),
+  };
+}
+
+/**
+ * Calculate the final position after applying multiple operations
+ * Used for cursor tracking
+ */
+export function transformPosition(
+  position: number,
+  operations: Operation[]
+): number {
+  let newPosition = position;
+  for (const op of operations) {
+    if (op.type === 'insert') {
+      if (op.position <= newPosition) {
+        newPosition += op.text?.length ?? 0;
+      }
+    } else if (op.type === 'delete') {
+      if (op.position < newPosition) {
+        const deleted = Math.min(op.length ?? 0, newPosition - op.position);
+        newPosition -= deleted;
+      }
+    }
+  }
+  return newPosition;
+}
