+import { describe, it, expect, beforeAll, afterAll } from 'vitest';
+import { createApp } from '../src/server.js';
+import WebSocket from 'ws';
+
+describe('Collaborative Document Editor', () => {
+  let app: ReturnType<typeof createApp>;
+  let port: number;
+
+  beforeAll(async () => {
+    app = createApp(':memory:');
+    port = await app.start(0);
+  });
+
+  afterAll(async () => {
+    await app.stop();
+  });
+
+  describe('REST API', () => {
+    it('should create a document', async () => {
+      const response = await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),
+      });
+
+      expect(response.status).toBe(201);
+      const data = await response.json();
+      expect(data.document).toBeDefined();
+      expect(data.document.title).toBe('Test Doc');
+      expect(data.document.content).toBe('Hello');
+    });
+
+    it('should list documents', async () => {
+      await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc' }),
+      });
+
+      const response = await fetch(`http://localhost:${port}/api/documents`);
+      expect(response.status).toBe(200);
+      const data = await response.json();
+      expect(Array.isArray(data.documents)).toBe(true);
+      expect(data.documents.length).toBeGreaterThan(0);
+    });
+
+    it('should get a document', async () => {
+      const createRes = await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc', content: 'Hello World' }),
+      });
+      const createData = await createRes.json();
+      const docId = createData.document.id;
+
+      const response = await fetch(`http://localhost:${port}/api/documents/${docId}`);
+      expect(response.status).toBe(200);
+      const data = await response.json();
+      expect(data.document.id).toBe(docId);
+      expect(data.document.content).toBe('Hello World');
+    });
+
+    it('should update a document', async () => {
+      const createRes = await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),
+      });
+      const createData = await createRes.json();
+      const docId = createData.document.id;
+
+      const response = await fetch(`http://localhost:${port}/api/documents/${docId}`, {
+        method: 'PUT',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Updated Doc', content: 'Updated content' }),
+      });
+
+      expect(response.status).toBe(200);
+      const data = await response.json();
+      expect(data.document.title).toBe('Updated Doc');
+      expect(data.document.content).toBe('Updated content');
+    });
+
+    it('should delete a document', async () => {
+      const createRes = await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc' }),
+      });
+      const createData = await createRes.json();
+      const docId = createData.document.id;
+
+      const response = await fetch(`http://localhost:${port}/api/documents/${docId}`, {
+        method: 'DELETE',
+      });
+
+      expect(response.status).toBe(204);
+
+      const getRes = await fetch(`http://localhost:${port}/api/documents/${docId}`);
+      expect(getRes.status).toBe(404);
+    });
+
+    it('should get version history', async () => {
+      const createRes = await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),
+      });
+      const createData = await createRes.json();
+      const docId = createData.document.id;
+
+      const response = await fetch(`http://localhost:${port}/api/documents/${docId}/versions`);
+      expect(response.status).toBe(200);
+      const data = await response.json();
+      expect(Array.isArray(data.versions)).toBe(true);
+    });
+  });
+
+  describe('WebSocket', () => {
+    it('should connect via WebSocket', async () => {
+      return new Promise<void>((resolve, reject) => {
+        const ws = new WebSocket(`ws://localhost:${port}/ws`);
+        const timeout = setTimeout(() => {
+          ws.close();
+          reject(new Error('Timeout waiting for message'));
+        }, 5000);
+        
+        ws.on('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          expect(msg.type).toBe('ack');
+          expect(msg.clientId).toBeDefined();
+          clearTimeout(timeout);
+          ws.close();
+          resolve();
+        });
+        
+        ws.on('error', (err) => {
+          clearTimeout(timeout);
+          reject(err);
+        });
+      });
+    });
+
+    it('should join a document and receive sync', async () => {
+      const createRes = await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc', content: 'Initial content' }),
+      });
+      const createData = await createRes.json();
+      const docId = createData.document.id;
+
+      return new Promise<void>((resolve, reject) => {
+        const ws = new WebSocket(`ws://localhost:${port}/ws`);
+        let gotAck = false;
+        const timeout = setTimeout(() => {
+          ws.close();
+          reject(new Error('Timeout'));
+        }, 5000);
+        
+        ws.on('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          if (!gotAck) {
+            gotAck = true;
+            ws.send(JSON.stringify({ type: 'join', documentId: docId }));
+          } else {
+            expect(msg.type).toBe('sync');
+            expect(msg.documentId).toBe(docId);
+            expect(msg.content).toBe('Initial content');
+            clearTimeout(timeout);
+            ws.close();
+            resolve();
+          }
+        });
+        
+        ws.on('error', (err) => {
+          clearTimeout(timeout);
+          reject(err);
+        });
+      });
+    });
+
+    it('should apply and broadcast operations', async () => {
+      const createRes = await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc', content: '' }),
+      });
+      const createData = await createRes.json();
+      const docId = createData.document.id;
+
+      return new Promise<void>((resolve, reject) => {
+        const ws = new WebSocket(`ws://localhost:${port}/ws`);
+        let step = 0;
+        const timeout = setTimeout(() => {
+          ws.close();
+          reject(new Error('Timeout'));
+        }, 5000);
+        
+        ws.on('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          if (step === 0) {
+            // ack
+            step = 1;
+            ws.send(JSON.stringify({ type: 'join', documentId: docId }));
+          } else if (step === 1) {
+            // sync
+            step = 2;
+            ws.send(JSON.stringify({
+              type: 'operation',
+              operation: { type: 'insert', position: 0, text: 'Hello' },
+            }));
+          } else if (step === 2) {
+            // ack
+            expect(msg.type).toBe('ack');
+            expect(msg.version).toBeGreaterThan(0);
+            clearTimeout(timeout);
+            ws.close();
+            resolve();
+          }
+        });
+        
+        ws.on('error', (err) => {
+          clearTimeout(timeout);
+          reject(err);
+        });
+      });
+    });
+
+    it('should reject invalid operations', async () => {
+      const createRes = await fetch(`http://localhost:${port}/api/documents`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ title: 'Test Doc', content: '' }),
+      });
+      const createData = await createRes.json();
+      const docId = createData.document.id;
+
+      return new Promise<void>((resolve, reject) => {
+        const ws = new WebSocket(`ws://localhost:${port}/ws`);
+        let step = 0;
+        const timeout = setTimeout(() => {
+          ws.close();
+          reject(new Error('Timeout'));
+        }, 5000);
+        
+        ws.on('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          if (step === 0) {
+            // ack
+            step = 1;
+            ws.send(JSON.stringify({ type: 'join', documentId: docId }));
+          } else if (step === 1) {
+            // sync
+            step = 2;
+            ws.send(JSON.stringify({
+              type: 'operation',
+              operation: { type: 'invalid', position: 0 },
+            }));
+          } else if (step === 2) {
+            // error
+            expect(msg.type).toBe('error');
+            clearTimeout(timeout);
+            ws.close();
+            resolve();
+          }
+        });
+        
+        ws.on('error', (err) => {
+          clearTimeout(timeout);
+          reject(err);
+        });
+      });
+    });
+  });
+});
