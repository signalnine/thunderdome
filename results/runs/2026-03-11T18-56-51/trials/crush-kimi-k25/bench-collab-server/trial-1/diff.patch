@@ -0,0 +1,150 @@
+import { Router, Request, Response } from 'express';
+import { DatabaseManager } from './db.js';
+import { randomUUID } from 'crypto';
+
+export function createRoutes(db: DatabaseManager): Router {
+  const router = Router();
+
+  // List all documents
+  router.get('/documents', (_req: Request, res: Response) => {
+    try {
+      const docs = db.getAllDocuments();
+      res.json({ documents: docs });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch documents' });
+    }
+  });
+
+  // Create a new document
+  router.post('/documents', (req: Request, res: Response) => {
+    try {
+      const { title, content = '', id } = req.body;
+
+      if (!title || typeof title !== 'string') {
+        res.status(400).json({ error: 'Title is required' });
+        return;
+      }
+
+      const documentId = id || randomUUID();
+      const doc = db.createDocument(documentId, title, content);
+      res.status(201).json({ document: doc });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to create document' });
+    }
+  });
+
+  // Get a document by ID
+  router.get('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const doc = db.getDocument(req.params.id);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      res.json({ document: doc });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch document' });
+    }
+  });
+
+  // Update a document (full update - REST API)
+  router.put('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const { title, content } = req.body;
+      const doc = db.updateDocument(req.params.id, title, content);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      res.json({ document: doc });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to update document' });
+    }
+  });
+
+  // Patch a document (partial update)
+  router.patch('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const { title, content } = req.body;
+      const existing = db.getDocument(req.params.id);
+      if (!existing) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      const doc = db.updateDocument(
+        req.params.id,
+        title !== undefined ? title : existing.title,
+        content !== undefined ? content : existing.content
+      );
+      res.json({ document: doc });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to update document' });
+    }
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const success = db.deleteDocument(req.params.id);
+      if (!success) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      res.status(204).send();
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to delete document' });
+    }
+  });
+
+  // Get version history for a document
+  router.get('/documents/:id/versions', (req: Request, res: Response) => {
+    try {
+      const doc = db.getDocument(req.params.id);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      const versions = db.getVersions(req.params.id);
+      res.json({
+        document: doc,
+        versions: versions.map(v => ({
+          ...v,
+          operation: v.operation ? JSON.parse(v.operation) : null,
+        })),
+      });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch versions' });
+    }
+  });
+
+  // Get a specific version
+  router.get('/documents/:id/versions/:version', (req: Request, res: Response) => {
+    try {
+      const doc = db.getDocument(req.params.id);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      const version = parseInt(req.params.version, 10);
+      if (isNaN(version) || version < 1) {
+        res.status(400).json({ error: 'Invalid version number' });
+        return;
+      }
+      const v = db.getVersion(req.params.id, version);
+      if (!v) {
+        res.status(404).json({ error: 'Version not found' });
+        return;
+      }
+      res.json({
+        version: {
+          ...v,
+          operation: v.operation ? JSON.parse(v.operation) : null,
+        },
+      });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch version' });
+    }
+  });
+
+  return router;
+}
