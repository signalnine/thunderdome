+import { describe, it, expect, beforeAll, afterAll } from 'vitest';
+import { createApp } from '../src/server.js';
+import WebSocket from 'ws';
+
+// Helper to create and join a WebSocket to a document
+async function connectAndJoin(port: number, docId: string): Promise<{ ws: WebSocket; clientId: string }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws`);
+    let clientId: string;
+    
+    const timeout = setTimeout(() => {
+      ws.close();
+      reject(new Error('Connection timeout'));
+    }, 5000);
+    
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'ack') {
+        clientId = msg.clientId;
+        ws.send(JSON.stringify({ type: 'join', documentId: docId }));
+      } else if (msg.type === 'sync') {
+        clearTimeout(timeout);
+        resolve({ ws, clientId });
+      }
+    });
+    
+    ws.on('error', (err) => {
+      clearTimeout(timeout);
+      reject(err);
+    });
+  });
+}
+
+// Helper to wait for a specific message type
+function waitForMessage(ws: WebSocket, type: string, timeout = 5000): Promise<any> {
+  return new Promise((resolve, reject) => {
+    const timer = setTimeout(() => reject(new Error(`Timeout waiting for ${type}`)), timeout);
+    const handler = (data: WebSocket.Data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === type) {
+        clearTimeout(timer);
+        ws.off('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+  });
+}
+
+describe('Concurrent Editing', () => {
+  let app: ReturnType<typeof createApp>;
+  let port: number;
+
+  beforeAll(async () => {
+    app = createApp(':memory:');
+    port = await app.start(0);
+  });
+
+  afterAll(async () => {
+    await app.stop();
+  });
+
+  it('should handle concurrent insertions from multiple clients', async () => {
+    // Create a fresh document for this test
+    const res = await fetch(`http://localhost:${port}/api/documents`, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ title: 'Concurrent Test', content: '' }),
+    });
+    const data = await res.json();
+    const testDocId = data.document.id;
+
+    // Connect two clients
+    const client1 = await connectAndJoin(port, testDocId);
+    const client2 = await connectAndJoin(port, testDocId);
+
+    // Client 1 inserts at position 0
+    client1.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 0, text: 'Hello' },
+    }));
+    const ack1 = await waitForMessage(client1.ws, 'ack');
+    expect(ack1.version).toBeGreaterThanOrEqual(1);
+
+    // Client 2 inserts at position 0 (should be transformed)
+    client2.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 0, text: 'World' },
+    }));
+    const ack2 = await waitForMessage(client2.ws, 'ack');
+    expect(ack2.version).toBeGreaterThanOrEqual(2);
+
+    // Wait a bit for broadcasts
+    await new Promise(r => setTimeout(r, 100));
+
+    // Verify via REST API that document has both texts
+    const docRes = await fetch(`http://localhost:${port}/api/documents/${testDocId}`);
+    const docData = await docRes.json();
+    
+    // Content should contain both insertions
+    expect(docData.document.content).toContain('Hello');
+    expect(docData.document.content).toContain('World');
+
+    client1.ws.close();
+    client2.ws.close();
+  });
+
+  it('should handle 10 concurrent clients on same document', async () => {
+    // Create a fresh document
+    const res = await fetch(`http://localhost:${port}/api/documents`, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ title: '10 Client Test', content: '' }),
+    });
+    const data = await res.json();
+    const testDocId = data.document.id;
+
+    const clients: { ws: WebSocket; clientId: string }[] = [];
+    
+    // Connect 10 clients
+    for (let i = 0; i < 10; i++) {
+      const client = await connectAndJoin(port, testDocId);
+      clients.push(client);
+    }
+
+    // Each client inserts a single character
+    const chars = 'ABCDEFGHIJ'.split('');
+    const promises = clients.map((client, i) => {
+      return new Promise<void>((resolve) => {
+        client.ws.send(JSON.stringify({
+          type: 'operation',
+          operation: { type: 'insert', position: 0, text: chars[i] },
+        }));
+        
+        const handler = (data: WebSocket.Data) => {
+          const msg = JSON.parse(data.toString());
+          if (msg.type === 'ack') {
+            client.ws.off('message', handler);
+            resolve();
+          }
+        };
+        client.ws.on('message', handler);
+      });
+    });
+
+    await Promise.all(promises);
+    await new Promise(r => setTimeout(r, 200));
+
+    // Verify all characters are in the document
+    const docRes = await fetch(`http://localhost:${port}/api/documents/${testDocId}`);
+    const docData = await docRes.json();
+    
+    // Content should contain all 10 characters
+    for (const char of chars) {
+      expect(docData.document.content).toContain(char);
+    }
+    expect(docData.document.content.length).toBe(10); // 10 characters inserted
+
+    // Cleanup
+    clients.forEach(c => c.ws.close());
+  });
+
+  it('should persist operations to version history', async () => {
+    // Create a fresh document
+    const res = await fetch(`http://localhost:${port}/api/documents`, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ title: 'Version Test', content: '' }),
+    });
+    const data = await res.json();
+    const testDocId = data.document.id;
+
+    const client = await connectAndJoin(port, testDocId);
+    
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'insert', position: 0, text: 'X' },
+    }));
+    
+    await waitForMessage(client.ws, 'ack');
+    await new Promise(r => setTimeout(r, 100));
+
+    // Check version history
+    const versionsRes = await fetch(`http://localhost:${port}/api/documents/${testDocId}/versions`);
+    const versionsData = await versionsRes.json();
+    
+    // Should have multiple versions including the one with 'X'
+    const hasXVersion = versionsData.versions.some((v: any) => 
+      v.operation?.type === 'insert' && v.operation?.text === 'X'
+    );
+    expect(hasXVersion).toBe(true);
+
+    client.ws.close();
+  });
+
+  it('should handle delete operations correctly', async () => {
+    // Create fresh document with known content
+    const res = await fetch(`http://localhost:${port}/api/documents`, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ title: 'Delete Test', content: 'ABCD' }),
+    });
+    const data = await res.json();
+    const delDocId = data.document.id;
+
+    const client = await connectAndJoin(port, delDocId);
+
+    // Delete 'BC'
+    client.ws.send(JSON.stringify({
+      type: 'operation',
+      operation: { type: 'delete', position: 1, length: 2 },
+    }));
+    
+    await waitForMessage(client.ws, 'ack');
+    await new Promise(r => setTimeout(r, 100));
+
+    // Verify content is now 'AD'
+    const docRes = await fetch(`http://localhost:${port}/api/documents/${delDocId}`);
+    const docData = await docRes.json();
+    expect(docData.document.content).toBe('AD');
+
+    client.ws.close();
+  });
+});
