@@ -0,0 +1,129 @@
+import express from 'express';
+import { createServer, Server } from 'http';
+import { DatabaseManager } from './db.js';
+import { createRoutes } from './routes.js';
+import { CollaborationServer } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Application;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+  getDb(): DatabaseManager;
+  getWsServer(): CollaborationServer | null;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const app = express();
+  const db = new DatabaseManager(dbPath);
+  let collaborationServer: CollaborationServer | null = null;
+  let httpServer: Server | null = null;
+  let isRunning = false;
+
+  // Middleware
+  app.use(express.json());
+
+  // Routes
+  const routes = createRoutes(db);
+  app.use('/api', routes);
+
+  // Health check
+  app.get('/health', (_req, res) => {
+    res.json({ status: 'ok', timestamp: new Date().toISOString() });
+  });
+
+  // Error handler
+  app.use((err: Error, _req: express.Request, res: express.Response, _next: express.NextFunction) => {
+    console.error('Express error:', err);
+    res.status(500).json({ error: 'Internal server error' });
+  });
+
+  const start = async (port?: number): Promise<number> => {
+    if (isRunning) {
+      throw new Error('Server is already running');
+    }
+
+    return new Promise((resolve, reject) => {
+      httpServer = createServer(app);
+
+      // Initialize WebSocket server
+      collaborationServer = new CollaborationServer(httpServer, db);
+
+      const listenPort = port ?? 0;
+
+      httpServer.on('error', (error) => {
+        reject(error);
+      });
+
+      httpServer.listen(listenPort, () => {
+        const address = httpServer?.address();
+        const actualPort = typeof address === 'object' && address !== null
+          ? address.port
+          : listenPort;
+        isRunning = true;
+        resolve(actualPort);
+      });
+    });
+  };
+
+  const stop = async (): Promise<void> => {
+    if (!isRunning) {
+      return;
+    }
+
+    return new Promise((resolve) => {
+      // Close WebSocket server first
+      if (collaborationServer) {
+        collaborationServer.close();
+        collaborationServer = null;
+      }
+
+      // Close HTTP server
+      if (httpServer) {
+        httpServer.close(() => {
+          httpServer = null;
+          isRunning = false;
+          resolve();
+        });
+      } else {
+        isRunning = false;
+        resolve();
+      }
+    });
+  };
+
+  return {
+    app,
+    start,
+    stop,
+    getDb: () => db,
+    getWsServer: () => collaborationServer,
+  };
+}
+
+// Allow running directly
+if (import.meta.url === `file://${process.argv[1]}`) {
+  const app = createApp(process.env.DATABASE_PATH || './data.db');
+  const port = parseInt(process.env.PORT || '3000', 10);
+
+  app.start(port)
+    .then((actualPort) => {
+      console.log(`Server started on port ${actualPort}`);
+    })
+    .catch((error) => {
+      console.error('Failed to start server:', error);
+      process.exit(1);
+    });
+
+  // Graceful shutdown
+  process.on('SIGINT', async () => {
+    console.log('Shutting down...');
+    await app.stop();
+    process.exit(0);
+  });
+
+  process.on('SIGTERM', async () => {
+    console.log('Shutting down...');
+    await app.stop();
+    process.exit(0);
+  });
+}
diff --git a/src/websocket.ts b/src/websocket.ts
new file mode 100644
index 0000000..6784dab
--- /dev/null
+++ b/src/websocket.ts
@@ -0,0 +1,386 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage, Server } from 'http';
+import { DatabaseManager } from './db.js';
+import { Operation, validateOperation, applyOperation, transformAgainstOperations } from './ot.js';
+import { randomUUID } from 'crypto';
+
+interface Client {
+  id: string;
+  ws: WebSocket;
+  documentId: string | null;
+  lastPing: number;
+}
+
+interface CollaborationMessage {
+  type: 'operation' | 'sync' | 'ack' | 'error' | 'ping' | 'pong' | 'join';
+  operation?: Operation;
+  documentId?: string;
+  content?: string;
+  version?: number;
+  clientVersion?: number;
+  message?: string;
+  clientId?: string;
+}
+
+interface DocumentState {
+  content: string;
+  version: number;
+  operations: Operation[];
+  clients: Set<string>;
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private clients: Map<string, Client> = new Map();
+  private documentStates: Map<string, DocumentState> = new Map();
+  private db: DatabaseManager;
+  private pingInterval: ReturnType<typeof setInterval> | null = null;
+
+  constructor(server: Server, db: DatabaseManager) {
+    this.db = db;
+    this.wss = new WebSocketServer({ server, path: '/ws' });
+
+    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      this.handleConnection(ws, req);
+    });
+
+    // Start ping/pong to keep connections alive and detect disconnects
+    this.pingInterval = setInterval(() => this.checkConnections(), 30000);
+  }
+
+  private handleConnection(ws: WebSocket, _req: IncomingMessage): void {
+    const clientId = randomUUID();
+    const client: Client = {
+      id: clientId,
+      ws,
+      documentId: null,
+      lastPing: Date.now(),
+    };
+
+    this.clients.set(clientId, client);
+
+    ws.on('message', (data: Buffer) => {
+      try {
+        const message: CollaborationMessage = JSON.parse(data.toString());
+        this.handleMessage(clientId, message);
+      } catch (error) {
+        this.sendToClient(clientId, {
+          type: 'error',
+          message: 'Invalid JSON message',
+        });
+      }
+    });
+
+    ws.on('close', () => {
+      this.handleDisconnect(clientId);
+    });
+
+    ws.on('error', (error) => {
+      console.error(`WebSocket error for client ${clientId}:`, error);
+      this.handleDisconnect(clientId);
+    });
+
+    ws.on('pong', () => {
+      const c = this.clients.get(clientId);
+      if (c) {
+        c.lastPing = Date.now();
+      }
+    });
+
+    // Send welcome message with client ID
+    this.sendToClient(clientId, {
+      type: 'ack',
+      clientId: clientId,
+      message: 'Connected to collaboration server',
+    });
+  }
+
+  private handleMessage(clientId: string, message: CollaborationMessage): void {
+    const client = this.clients.get(clientId);
+    if (!client) return;
+
+    switch (message.type) {
+      case 'join':
+        this.handleJoin(clientId, message);
+        break;
+      case 'operation':
+        this.handleOperation(clientId, message);
+        break;
+      case 'sync':
+        this.handleSyncRequest(clientId, message);
+        break;
+      case 'ping':
+        this.sendToClient(clientId, { type: 'pong' });
+        break;
+      default:
+        // Ignore unknown message types
+        break;
+    }
+  }
+
+  private handleJoin(clientId: string, message: CollaborationMessage): void {
+    const client = this.clients.get(clientId);
+    if (!client) return;
+
+    const documentId = message.documentId;
+    if (!documentId) {
+      this.sendToClient(clientId, {
+        type: 'error',
+        message: 'Document ID is required',
+      });
+      return;
+    }
+
+    // Get document from database
+    const doc = this.db.getDocument(documentId);
+    if (!doc) {
+      this.sendToClient(clientId, {
+        type: 'error',
+        message: 'Document not found',
+      });
+      return;
+    }
+
+    // Leave previous document if any
+    if (client.documentId && client.documentId !== documentId) {
+      this.leaveDocument(clientId);
+    }
+
+    // Join new document
+    client.documentId = documentId;
+    this.db.addConnection(clientId, documentId);
+
+    // Get or create document state
+    let state = this.documentStates.get(documentId);
+    if (!state) {
+      state = {
+        content: doc.content,
+        version: doc.version,
+        operations: [],
+        clients: new Set(),
+      };
+      this.documentStates.set(documentId, state);
+    }
+
+    state.clients.add(clientId);
+
+    // Send current state to client
+    this.sendToClient(clientId, {
+      type: 'sync',
+      documentId,
+      content: state.content,
+      version: state.version,
+    });
+
+    // Notify other clients
+    this.broadcastToDocument(documentId, {
+      type: 'join',
+      clientId,
+      documentId,
+      message: `Client ${clientId} joined`,
+    }, clientId);
+  }
+
+  private handleOperation(clientId: string, message: CollaborationMessage): void {
+    const client = this.clients.get(clientId);
+    if (!client || !client.documentId) {
+      this.sendToClient(clientId, {
+        type: 'error',
+        message: 'Not joined to a document',
+      });
+      return;
+    }
+
+    const operation = message.operation;
+    if (!operation || !validateOperation(operation)) {
+      this.sendToClient(clientId, {
+        type: 'error',
+        message: 'Invalid operation format',
+      });
+      return;
+    }
+
+    const state = this.documentStates.get(client.documentId);
+    if (!state) {
+      this.sendToClient(clientId, {
+        type: 'error',
+        message: 'Document state not found',
+      });
+      return;
+    }
+
+    // Get client version from message (default to document version)
+    const clientVersion = message.clientVersion ?? state.version;
+
+    // Transform operation against any operations the client hasn't seen
+    let transformedOp: Operation = { ...operation, clientId };
+    if (clientVersion < state.version) {
+      const unseenOps = state.operations.slice(clientVersion);
+      transformedOp = transformAgainstOperations(operation, unseenOps);
+    }
+
+    // Apply the transformed operation
+    const newContent = applyOperation(state.content, transformedOp);
+    state.content = newContent;
+    state.version++;
+    state.operations.push(transformedOp);
+
+    // Save to database
+    try {
+      this.db.addVersion(client.documentId, newContent, transformedOp);
+    } catch (error) {
+      console.error('Failed to save version:', error);
+    }
+
+    // Acknowledge to sender
+    this.sendToClient(clientId, {
+      type: 'ack',
+      version: state.version,
+      operation: transformedOp,
+    });
+
+    // Broadcast to other clients
+    this.broadcastToDocument(clientId, {
+      type: 'operation',
+      version: state.version,
+      operation: transformedOp,
+      clientId,
+    }, clientId);
+  }
+
+  private handleSyncRequest(clientId: string, _message: CollaborationMessage): void {
+    const client = this.clients.get(clientId);
+    if (!client || !client.documentId) {
+      this.sendToClient(clientId, {
+        type: 'error',
+        message: 'Not joined to a document',
+      });
+      return;
+    }
+
+    const state = this.documentStates.get(client.documentId);
+    if (!state) {
+      this.sendToClient(clientId, {
+        type: 'error',
+        message: 'Document state not found',
+      });
+      return;
+    }
+
+    this.sendToClient(clientId, {
+      type: 'sync',
+      documentId: client.documentId,
+      content: state.content,
+      version: state.version,
+    });
+  }
+
+  private leaveDocument(clientId: string): void {
+    const client = this.clients.get(clientId);
+    if (!client || !client.documentId) return;
+
+    const state = this.documentStates.get(clientId);
+    if (state) {
+      state.clients.delete(clientId);
+      if (state.clients.size === 0) {
+        // Clean up document state if no clients
+        this.documentStates.delete(clientId);
+      }
+    }
+
+    this.db.removeConnection(clientId);
+    client.documentId = null;
+  }
+
+  private handleDisconnect(clientId: string): void {
+    this.leaveDocument(clientId);
+    this.clients.delete(clientId);
+  }
+
+  private sendToClient(clientId: string, message: CollaborationMessage): void {
+    const client = this.clients.get(clientId);
+    if (client && client.ws.readyState === WebSocket.OPEN) {
+      try {
+        client.ws.send(JSON.stringify(message));
+      } catch (error) {
+        console.error(`Failed to send to client ${clientId}:`, error);
+      }
+    }
+  }
+
+  private broadcastToDocument(
+    documentId: string,
+    message: CollaborationMessage,
+    excludeClientId?: string
+  ): void {
+    const state = this.documentStates.get(documentId);
+    if (!state) return;
+
+    const messageStr = JSON.stringify(message);
+    for (const clientId of state.clients) {
+      if (clientId === excludeClientId) continue;
+      const client = this.clients.get(clientId);
+      if (client && client.ws.readyState === WebSocket.OPEN) {
+        try {
+          client.ws.send(messageStr);
+        } catch (error) {
+          console.error(`Failed to broadcast to client ${clientId}:`, error);
+        }
+      }
+    }
+  }
+
+  private checkConnections(): void {
+    const now = Date.now();
+    const timeout = 60000; // 60 seconds
+
+    for (const [clientId, client] of this.clients) {
+      if (now - client.lastPing > timeout) {
+        // Client hasn't responded in a while, close connection
+        try {
+          client.ws.close();
+        } catch (error) {
+          // Already closed
+        }
+        this.handleDisconnect(clientId);
+      } else if (client.ws.readyState === WebSocket.OPEN) {
+        // Send ping
+        try {
+          client.ws.ping();
+        } catch (error) {
+          // Connection might be dead
+          this.handleDisconnect(clientId);
+        }
+      }
+    }
+  }
+
+  close(): void {
+    if (this.pingInterval) {
+      clearInterval(this.pingInterval);
+      this.pingInterval = null;
+    }
+
+    // Close all client connections
+    for (const client of this.clients.values()) {
+      try {
+        client.ws.close();
+      } catch (error) {
+        // Ignore
+      }
+    }
+    this.clients.clear();
+    this.documentStates.clear();
+
+    this.wss.close();
+  }
+
+  getClientCount(): number {
+    return this.clients.size;
+  }
+
+  getDocumentClientCount(documentId: string): number {
+    const state = this.documentStates.get(documentId);
+    return state?.clients.size ?? 0;
+  }
+}
