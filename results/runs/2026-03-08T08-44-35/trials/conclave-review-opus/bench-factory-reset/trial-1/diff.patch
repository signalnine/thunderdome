 target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // From the TASK.md example: target [T,T,F,T] with given buttons has no solution\n    const result = solveToggle({\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should solve a simple single-button case', () => {\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should solve with two buttons needed', () => {\n    // Button 0: toggles light 0\n    // Button 1: toggles light 1\n    // Target: [true, true]\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should prefer fewer button presses', () => {\n    // Button 0: toggles [0, 1]\n    // Button 1: toggles [0]\n    // Button 2: toggles [1]\n    // Target: [true, true]\n    // Solution: press button 0 (1 press) rather than buttons 1 and 2 (2 presses)\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should return lexicographically smallest when tied on count', () => {\n    // Button 0: toggles [0]\n    // Button 1: toggles [0]\n    // Target: [true]\n    // Both button 0 and button 1 are single-press solutions; prefer [0]\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle case where no buttons needed', () => {\n    const result = solveToggle({\n      target: [false],\n      buttons: [[0]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should handle larger system', () => {\n    // 5 lights, 5 buttons forming identity-like mapping\n    const result = solveToggle({\n      target: [true, false, true, false, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    });\n    expect(result).toEqual([0, 2, 4]);\n  });\n\n  it('should handle overlapping buttons', () => {\n    // Button 0: [0, 1, 2]\n    // Button 1: [1, 2, 3]\n    // Button 2: [2, 3, 4]\n    // Target: [true, false, false, false, true]\n    // Press 0 and 1: [1,0,0,1,0] - no\n    // Press 0 and 2: [1,1,0,1,1] - no\n    // Press 0,1,2: [1,0,1,0,1] - no\n    // Let's compute: x0 XOR x1 XOR x2 for each light:\n    // light 0: x0 = target[0] = 1\n    // light 1: x0 XOR x1 = target[1] = 0 → x1 = 1\n    // light 2: x0 XOR x1 XOR x2 = target[2] = 0 → x2 = 0\n    // light 3: x1 XOR x2 = target[3] = 0 → check: 1 XOR 0 = 1 ≠ 0 → no solution\n    const result = solveToggle({\n      target: [true, false, false, false, true],\n      buttons: [[0, 1, 2], [1, 2, 3], [2, 3, 4]],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should handle empty buttons list', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should handle empty target (all false) with no buttons', () => {\n    const result = solveToggle({\n      target: [],\n      buttons: [],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should solve with cancellation', () => {\n    // Button 0: [0, 1]\n    // Button 1: [1, 2]\n    // Target: [true, false, true]\n    // Press both: light 0 toggled by 0, light 1 toggled by 0 and 1 (cancel), light 2 toggled by 1\n    // Result: [true, false, true] ✓\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zeros', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should solve simple single-button case', () => {\n    // Button 0 increments counters [0, 1]\n    // Target: [3, 3] mod 5\n    // Press button 0 three times\n    const result = solveCounter([3, 3], [[0, 1]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should solve with two independent buttons', () => {\n    // Button 0: counter [0]\n    // Button 1: counter [1]\n    // Target: [2, 3] mod 5\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // Button 0: counter [0, 1]\n    // Target: [1, 0] mod 2\n    // x0 affects both counters equally, can't make one 1 and other 0\n    const result = solveCounter([1, 0], [[0, 1]], 2);\n    expect(result).toBeNull();\n  });\n\n  it('should minimize total presses', () => {\n    // Button 0: counter [0]\n    // Button 1: counter [0]\n    // Target: [1] mod 5\n    // Press button 0 once (total=1) or button 1 once (total=1)\n    // Lexicographically: [0, 1] < [1, 0]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should handle modular arithmetic', () => {\n    // Button 0: counter [0]\n    // Target: [0] mod 5\n    // Press 0 times (total=0) - best\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle wrapping', () => {\n    // Button 0: counter [0]\n    // Target: [4] mod 5\n    // Press 4 times\n    const result = solveCounter([4], [[0]], 5);\n    expect(result).toEqual([4]);\n  });\n\n  it('should solve with overlapping buttons', () => {\n    // Button 0: [0, 1]\n    // Button 1: [1, 2]\n    // Target: [1, 0, 1] mod 3\n    // x0 affects [0,1], x1 affects [1,2]\n    // counter 0: x0 = 1\n    // counter 1: x0 + x1 = 0 mod 3 → x1 = 2\n    // counter 2: x1 = 1 → contradiction with x1=2\n    // Wait: counter 2: x1 = 1 but we need x1 = 2. No solution.\n    const result = solveCounter([1, 0, 1], [[0, 1], [1, 2]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('should solve with consistent overlapping buttons', () => {\n    // Button 0: [0, 1]\n    // Button 1: [1, 2]\n    // Target: [1, 0, 2] mod 3\n    // counter 0: x0 = 1\n    // counter 1: x0 + x1 = 0 → x1 = 2\n    // counter 2: x1 = 2 ✓\n    const result = solveCounter([1, 0, 2], [[0, 1], [1, 2]], 3);\n    expect(result).toEqual([1, 2]);\n  });\n\n  it('should prefer lexicographically smallest when tied', () => {\n    // Button 0: counter [0]\n    // Button 1: counter [0]\n    // Target: [2] mod 3\n    // Options: [2,0] total=2, [1,1] total=2, [0,2] total=2\n    // Lex smallest with total 2: [0,2]\n    // Wait: [0,2] has total 2, [1,1] has total 2, [2,0] has total 2\n    // Lex order: [0,2] < [1,1] < [2,0]\n    const result = solveCounter([2], [[0], [0]], 3);\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('should handle modulus 2 (binary case)', () => {\n    // Like toggle but with counter semantics\n    const result = solveCounter([1, 1], [[0, 1]], 2);\n    expect(result).toEqual([1]);\n  });\n\n  it('should handle larger modulus', () => {\n    // Button 0: counter [0]\n    // Target: [50] mod 97\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n  });\n});\n","structuredPatch":[{"oldStart":234,"oldLines":4,"newStart":234,"newLines":85,"lines":["     const result = solveCounter([50], [[0]], 97);","     expect(result).toEqual([50]);","   });","+","+  it('should handle empty buttons for counter', () => {","+    const result = solveCounter([1], [], 3);","+    expect(result).toBeNull();","+  });","+","+  it('should handle all-zero target with empty buttons for counter', () => {","+    const result = solveCounter([0, 0], [], 5);","+    expect(result).toEqual([]);","+  });","+","+  it('should minimize with multiple free variables', () => {","+    // 3 buttons all affect counter 0. Target: [2] mod 5.","+    // Need x0 + x1 + x2 = 2 mod 5","+    // Minimize total = x0 + x1 + x2","+    // Best: total = 2, lex smallest with sum 2: [0, 0, 2]","+    const result = solveCounter([2], [[0], [0], [0]], 5);","+    expect(result).toEqual([0, 0, 2]);","+  });"," });","+","+describe('solveToggle - verification', () => {","+  function verifyToggleSolution(target: boolean[], buttons: number[][], solution: number[]): boolean {","+    const n = target.length;","+    const state = new Array(n).fill(false);","+    for (const btnIdx of solution) {","+      for (const light of buttons[btnIdx]) {","+        state[light] = !state[light];","+      }","+    }","+    return state.every((s, i) => s === target[i]);","+  }","+","+  it('should produce valid solutions for random cases', () => {","+    // Manually constructed test case with known solution","+    const target = [true, false, true, true, false];","+    const buttons = [[0, 2], [1, 3], [0, 1, 4], [2, 3], [3, 4]];","+    const result = solveToggle({ target, buttons });","+    if (result !== null) {","+      expect(verifyToggleSolution(target, buttons, result)).toBe(true);","+    }","+  });","+});","+","+describe('solveCounter - verification', () => {","+  function verifyCounterSolution(","+    lights: number[], buttons: number[][], modulus: number, solution: number[]","+  ): boolean {","+    const n = lights.length;","+    const state = new Array(n).fill(0);","+    for (let j = 0; j < solution.length; j++) {","+      for (const counter of buttons[j]) {","+        state[counter] = (state[counter] + solution[j]) % modulus;","+      }","+    }","+    return state.every((s, i) => s === lights[i] % modulus);","+  }","+","+  it('should produce valid solutions for a counter test', () => {","+    const lights = [3, 1, 4];","+    const buttons = [[0, 1], [1, 2], [0, 2]];","+    const modulus = 5;","+    const result = solveCounter(lights, buttons, modulus);","+    if (result !== null) {","+      expect(verifyCounterSolution(lights, buttons, modulus, result)).toBe(true);","+    }","+  });","+","+  it('should handle lar