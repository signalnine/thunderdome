  // Signature: for each pivot row i, sum of coeff[i][f] * x[f] for f in first half\n   598→  // Store as array of length rank.\n   599→\n   600→  interface HalfEntry {\n   601→    sig: number[]; // contribution to each pivot row (mod p)\n   602→    freeValues: number[]; // values assigned to free vars in this half\n   603→    freeTotal: number; // sum of free variable values\n   604→  }\n   605→\n   606→  const firstHalfSize = Math.pow(modulus, half1);\n   607→  const firstHalfMap: Map<string, HalfEntry[]> = new Map();\n   608→\n   609→  const freeAssignment1 = new Array(half1).fill(0);\n   610→  for (let iter = 0; iter < firstHalfSize; iter++) {\n   611→    const sig = new Array(rank).fill(0);\n   612→    let freeTotal = 0;\n   613→    for (let f = 0; f < half1; f++) {\n   614→      freeTotal += freeAssignment1[f];\n   615→      for (let i = 0; i < rank; i++) {\n   616→        sig[i] = (sig[i] + pivotFreeCoeffs[i][f] * freeAssignment1[f]) % modulus;\n   617→      }\n   618→    }\n   619→\n   620→    const entry: HalfEntry = {\n   621→      sig: sig.slice(),\n   622→      freeValues: freeAssignment1.slice(),\n   623→      freeTotal,\n   624→    };\n   625→\n   626→    const key = sig.join(',');\n   627→    const existing = firstHalfMap.get(key);\n   628→    if (existing) {\n   629→      existing.push(entry);\n   630→    } else {\n   631→      firstHalfMap.set(key, [entry]);\n   632→    }\n   633→\n   634→    // Increment\n   635→    for (let f = half1 - 1; f >= 0; f--) {\n   636→      freeAssignment1[f]++;\n   637→      if (freeAssignment1[f] < modulus) break;\n   638→      freeAssignment1[f] = 0;\n   639→    }\n   640→  }\n   641→\n   642→  // For each second half assignment, compute the needed first half signature\n   643→  // and look it up.\n   644→  let bestSolution: number[] | null = null;\n   645→  let bestTotal = Infinity;\n   646→\n   647→  const secondHalfSize = Math.pow(modulus, half2);\n   648→  const freeAssignment2 = new Array(half2).fill(0);\n   649→\n   650→  for (let iter = 0; iter < secondHalfSize; iter++) {\n   651→    const sig2 = new Array(rank).fill(0);\n   652→    let freeTotal2 = 0;\n   653→    for (let f = 0; f < half2; f++) {\n   654→      freeTotal2 += freeAssignment2[f];\n   655→      for (let i = 0; i < rank; i++) {\n   656→        sig2[i] = (sig2[i] + pivotFreeCoeffs[i][half1 + f] * freeAssignment2[f]) % modulus;\n   657→      }\n   658→    }\n   659→\n   660→    // For each first half signature, compute pivot values and total.\n   661→    // We need: pivotVal[i] = (pivotRHS[i] - sig1[i] - sig2[i]) mod p\n   662→    // pivotTotal = sum of pivotVal[i]\n   663→    // total = freeTotal1 + freeTotal2 + pivotTotal\n   664→\n   665→    // We can't easily use the map to find the best sig1 because\n   666→    // pivotTotal depends on the combination of sig1 and sig2.\n   667→    // We'd need to iterate all entries. But that's the same as brute force.\n   668→\n   669→    // Instead, iterate all entries in the map and find the best combination.\n   670→    // This is still O(p^half1 * p^half2) = O(p^numFree) in the worst case.\n   671→\n   672→    // Better: for each unique signature in the first half, keep only the best\n   673→    // (lowest freeTotal, then lexicographically smallest). This reduces work.\n   674→\n   675→    // Actually, different sig1 values give different pivotTotals.\n   676→    // We need to iterate all unique signatures.\n   677→\n   678→    for (const [, entries] of firstHalfMap) {\n   679→      // All entries with the same sig give the same pivotTotal.\n   680→      // So we just need the best entry per signature.\n   681→      // Pre-filter: keep only the entry with min freeTotal (then lex smallest).\n   682→      const e1 = entries[0]; // we'll optimize this below\n   683→\n   684→      // Compute pivot total for this signature combination\n   685→      let pivotTotal = 0;\n   686→      for (let i = 0; i < rank; i++) {\n   687→        const val = ((pivotRHS[i] - e1.sig[i] - sig