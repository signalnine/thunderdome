433→\n   434→    // Eliminate column in all other rows\n   435→    for (let r = 0; r < n; r++) {\n   436→      if (r !== currentRow && matrix[r][col] !== 0) {\n   437→        const factor = matrix[r][col];\n   438→        for (let j = col; j <= m; j++) {\n   439→          matrix[r][j] = ((matrix[r][j] - factor * matrix[currentRow][j]) % modulus + modulus) % modulus;\n   440→        }\n   441→      }\n   442→    }\n   443→\n   444→    pivotCol.push(col);\n   445→    currentRow++;\n   446→  }\n   447→\n   448→  const rank = currentRow;\n   449→\n   450→  // Check for inconsistency\n   451→  for (let r = rank; r < n; r++) {\n   452→    if (matrix[r][m] !== 0) {\n   453→      return null;\n   454→    }\n   455→  }\n   456→\n   457→  // Identify free variables\n   458→  const pivotSet = new Set(pivotCol);\n   459→  const freeVars: number[] = [];\n   460→  for (let j = 0; j < m; j++) {\n   461→    if (!pivotSet.has(j)) {\n   462→      freeVars.push(j);\n   463→    }\n   464→  }\n   465→\n   466→  const numFree = freeVars.length;\n   467→\n   468→  // For each free variable assignment, compute pivot variables and total presses.\n   469→  // Number of assignments = modulus^numFree.\n   470→  // With modulus up to 97 and numFree potentially large, we need to be smart.\n   471→\n   472→  // If modulus^numFree is manageable (say ≤ ~5M), enumerate directly.\n   473→  // Otherwise, we need a smarter approach.\n   474→\n   475→  const totalAssignments = Math.pow(modulus, numFree);\n   476→\n   477→  if (numFree === 0) {\n   478→    // Unique solution\n   479→    const result = new Array(m).fill(0);\n   480→    for (let i = 0; i < rank; i++) {\n   481→      result[pivotCol[i]] = matrix[i][m];\n   482→    }\n   483→    return result;\n   484→  }\n   485→\n   486→  if (totalAssignments <= 5_000_000) {\n   487→    return enumerateCounterSolutions(matrix, rank, m, modulus, pivotCol, freeVars, numFree);\n   488→  }\n   489→\n   490→  // For large search spaces, use a different strategy.\n   491→  // With prime modulus, we can try to optimize using the structure.\n   492→  // For now, use MITM approach for GF(p).\n   493→  return solveCounterMITM(matrix, rank, m, modulus, pivotCol, freeVars, numFree);\n   494→}\n   495→\n   496→function enumerateCounterSolutions(\n   497→  matrix: number[][],\n   498→  rank: number,\n   499→  m: number,\n   500→  modulus: number,\n   501→  pivotCol: number[],\n   502→  freeVars: number[],\n   503→  numFree: number,\n   504→): number[] | null {\n   505→  // Precompute: for each pivot row, the coefficients of free variables\n   506→  const pivotFreeCoeffs: number[][] = new Array(rank);\n   507→  const pivotRHS: number[] = new Array(rank);\n   508→  for (let i = 0; i < rank; i++) {\n   509→    pivotFreeCoeffs[i] = new Array(numFree);\n   510→    for (let f = 0; f < numFree; f++) {\n   511→      pivotFreeCoeffs[i][f] = matrix[i][freeVars[f]];\n   512→    }\n   513→    pivotRHS[i] = matrix[i][m];\n   514→  }\n   515→\n   516→  let bestSolution: number[] | null = null;\n   517→  let bestTotal = Infinity;\n   518→\n   519→  // Enumerate all assignments of free variables (base-modulus counting)\n   520→  const freeAssignment = new Array(numFree).fill(0);\n   521→\n   522→  const totalAssignments = Math.pow(modulus, numFree);\n   523→\n   524→  for (let iter = 0; iter < totalAssignments; iter++) {\n   525→    const solution = new Array(m).fill(0);\n   526→\n   527→    // Set free variables\n   528→    let freeTotal = 0;\n   529→    for (let f = 0; f < numFree; f++) {\n   530→      solution[freeVars[f]] = freeAssignment[f];\n   531→      freeTotal += freeAssignment[f];\n   532→    }\n   533→\n   534→    // Compute pivot variables\n   535→    let pivotTotal = 0;\n   536→    for (let i = 0; i < rank; i++) {\n   537→      let val = pivotRHS[i];\n   538→      for (let f = 0; f < numFree; f++) {\n   539→        val -= pivotFreeCoeffs[i][f] * freeAssignment[f];\n   540→      }\n   541→      val = ((val % modulus) + modulus) % mod