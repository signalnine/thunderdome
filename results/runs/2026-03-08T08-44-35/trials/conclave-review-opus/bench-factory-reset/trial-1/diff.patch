olveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([1, 0]);\n  });\n\n  it('should handle modular arithmetic', () => {\n    // Button 0: counter [0]\n    // Target: [0] mod 5\n    // Press 0 times (total=0) - best\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle wrapping', () => {\n    // Button 0: counter [0]\n    // Target: [4] mod 5\n    // Press 4 times\n    const result = solveCounter([4], [[0]], 5);\n    expect(result).toEqual([4]);\n  });\n\n  it('should solve with overlapping buttons', () => {\n    // Button 0: [0, 1]\n    // Button 1: [1, 2]\n    // Target: [1, 0, 1] mod 3\n    // x0 affects [0,1], x1 affects [1,2]\n    // counter 0: x0 = 1\n    // counter 1: x0 + x1 = 0 mod 3 → x1 = 2\n    // counter 2: x1 = 1 → contradiction with x1=2\n    // Wait: counter 2: x1 = 1 but we need x1 = 2. No solution.\n    const result = solveCounter([1, 0, 1], [[0, 1], [1, 2]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('should solve with consistent overlapping buttons', () => {\n    // Button 0: [0, 1]\n    // Button 1: [1, 2]\n    // Target: [1, 0, 2] mod 3\n    // counter 0: x0 = 1\n    // counter 1: x0 + x1 = 0 → x1 = 2\n    // counter 2: x1 = 2 ✓\n    const result = solveCounter([1, 0, 2], [[0, 1], [1, 2]], 3);\n    expect(result).toEqual([1, 2]);\n  });\n\n  it('should prefer lexicographically smallest when tied', () => {\n    // Button 0: counter [0]\n    // Button 1: counter [0]\n    // Target: [2] mod 3\n    // Options: [2,0] total=2, [1,1] total=2, [0,2] total=2\n    // Lex smallest with total 2: [0,2]\n    // Wait: [0,2] has total 2, [1,1] has total 2, [2,0] has total 2\n    // Lex order: [0,2] < [1,1] < [2,0]\n    const result = solveCounter([2], [[0], [0]], 3);\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('should handle modulus 2 (binary case)', () => {\n    // Like toggle but with counter semantics\n    const result = solveCounter([1, 1], [[0, 1]], 2);\n    expect(result).