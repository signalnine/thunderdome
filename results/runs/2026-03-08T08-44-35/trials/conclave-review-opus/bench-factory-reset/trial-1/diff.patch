+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  if (m === 0) {
+    return target.some(t => t) ? null : [];
+  }
+
+  // Build augmented matrix over GF(2) using bigint bitmasks.
+  // Bit layout: bits 0..m-1 are button columns, bit m is the RHS.
+  const rows: bigint[] = new Array(n);
+  for (let i = 0; i < n; i++) {
+    let row = 0n;
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row |= 1n << BigInt(j);
+      }
+    }
+    if (target[i]) {
+      row |= 1n << BigInt(m);
+    }
+    rows[i] = row;
+  }
+
+  // Gaussian elimination over GF(2) with full back-substitution
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+
+  for (let col = 0; col < m && currentRow < n; col++) {
+    let pivotRow = -1;
+    for (let r = currentRow; r < n; r++) {
+      if ((rows[r] >> BigInt(col)) & 1n) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [rows[currentRow], rows[pivotRow]] = [rows[pivotRow], rows[currentRow]];
+
+    for (let r = 0; r < n; r++) {
+      if (r !== currentRow && (rows[r] >> BigInt(col)) & 1n) {
+        rows[r] ^= rows[currentRow];
+      }
+    }
+
+    pivotCol.push(col);
+    currentRow++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < n; r++) {
+    if ((rows[r] >> BigInt(m)) & 1n) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) {
+      freeVars.push(j);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // For each free variable, precompute its contribution bitmask over pivot rows.
+  const freeContrib: bigint[] = new Array(numFree);
+  for (let f = 0; f < numFree; f++) {
+    let contrib = 0n;
+    for (let i = 0; i < rank; i++) {
+      if ((rows[i] >> BigInt(freeVars[f])) & 1n) {
+        contrib |= 1n << BigInt(i);
+      }
+    }
+    freeContrib[f] = contrib;
+  }
+
+  let rhsBitmask = 0n;
+  for (let i = 0; i < rank; i++) {
+    if ((rows[i] >> BigInt(m)) & 1n) {
+      rhsBitmask |= 1n << BigInt(i);
+    }
+  }
+
+  if (numFree <= 25) {
+    return enumerateToggleSolutions(m, rank, numFree, pivotCol, freeVars, freeContrib, rhsBitmask);
+  }
+
+  // MITM for large number of free variables.
+  // When numFree > 25, rank = m - numFree ≤ 15 (for m ≤ 40), so unique sigs ≤ 2^15.
+  return solveToggleMITM(m, rank, numFree, pivotCol, freeVars, freeContrib, rhsBitmask);
+}
+
+function enumerateToggleSolutions(
+  m: number,
+  rank: number,
+  numFree: number,
+  pivotCol: number[],
+  freeVars: number[],
+  freeContrib: bigint[],
+  rhsBitmask: bigint,
+): number[] {
+  let bestSolution: number[] | null = null;
+  let bestCount = m + 1;
+
+  const total = 1 << numFree;
+
+  for (let mask = 0; mask < total; mask++) {
+    let sig = 0n;
+    let freeCount = 0;
+    for (let f = 0; f < numFree; f++) {
+      if (mask & (1 << f)) {
+        sig ^= freeContrib[f];
+        freeCount++;
+      }
+    }
+
+    const pivotBits = rhsBitmask ^ sig;
+    const pivotCount = popcount64(pivotBits);
+    const totalCount = freeCount + pivotCount;
+
+    if (totalCount < bestCount || (totalCount === bestCount && bestSolution !== null)) {
+      const solution = buildToggleSolutionFromMask(m, rank, pivotCol, pivotBits, freeVars, numFree, mask);
+      if (totalCount < bestCount) {
+        bestCount = totalCount;
+        bestSolution = solution;
+      } else if (compareSolutionsBitmask(solution, bestSolution!, m) < 0) {
+        bestSolution = solution;
+      }
+    }
+  }
+
+  if (bestSolution === null) return [];
+
+  const result: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (bestSolution[j]) result.push(j);
+  }
+  return result;
+}
+
+function solveToggleMITM(
+  m: number,
+  rank: number,
+  numFree: number,
+  pivotCol: number[],
+  freeVars: number[],
+  freeContrib: bigint[],
+  rhsBitmask: bigint,
