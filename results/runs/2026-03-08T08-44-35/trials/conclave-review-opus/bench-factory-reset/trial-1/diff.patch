n  }\n\n  let rhsBitmask = 0n;\n  for (let i = 0; i < rank; i++) {\n    if (pivotRHS[i]) {\n      rhsBitmask |= 1n << BigInt(i);\n    }\n  }\n\n  if (numFree <= 25) {\n    return enumerateToggleSolutions(m, rank, numFree, pivotCol, freeVars, freeContrib, rhsBitmask);\n  }\n\n  // MITM for large number of free variables.\n  // Key insight: the number of unique signatures is at most min(2^half1, 2^rank).\n  // When rank is small (which it must be if numFree > 25 since rank = m - numFree ≤ 15),\n  // the number of unique signatures is small, making the second-half iteration fast.\n  return solveToggleMITM(m, rank, numFree, pivotCol, freeVars, freeContrib, rhsBitmask);\n}\n\nfunction enumerateToggleSolutions(\n  m: number,\n  rank: number,\n  numFree: number,\n  pivotCol: number[],\n  freeVars: number[],\n  freeContrib: bigint[],\n  rhsBitmask: bigint,\n): number[] {\n  let bestSolution: number[] | null = null;\n  let bestCount = m + 1;\n\n  const total = 1 << numFree;\n\n  for (let mask = 0; mask < total; mask++) {\n    // Compute signature (XOR of contributions of set free vars)\n    let sig = 0n;\n    let freeCount = 0;\n    for (let f = 0; f < numFree; f++) {\n      if (mask & (1 << f)) {\n        sig ^= freeContrib[f];\n        freeCount++;\n      }\n    }\n\n    const pivotBits = rhsBitmask ^ sig;\n    const pivotCount = popcount64(pivotBits);\n    const totalCount = freeCount + pivotCount;\n\n    if (totalCount < bestCount || (totalCount === bestCount && bestSolution !== null)) {\n      const solution = buildToggleSolution(m, rank, pivotCol, pivotBits, freeVars, numFree, mask);\n      if (totalCount < bestCount) {\n        bestCount = totalCount;\n        bestSolution = solution;\n      } else if (compareSolutionsBitmask(solution, bestSolution!, m) < 0) {\n        bestSolution = solution;\n      }\n    }\n  }\n\n  if (bestSolution === null) return [];\n\n  const result: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (bestSolution[j]) result.push(j);\n  }\n  return result;\n}\n\nfunction solveToggleMITM(\n  m: number,\n  rank: number,\n  numFree: number,\n  pivotCol: number[],\n  freeVars: number[],\n  freeContrib: bigint[],\n  rhsBitmask: bigint,\n): number[] {\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // Build first-half map: sig -> best {freeCount, mask} entries\n  // Since rank is small when numFree > 25 (rank ≤ 40 - 26 = 14), unique sigs ≤ 2^14 = 16K\n  interface BestEntry {\n    freeCount: number;\n    mask: number;\n  }\n\n  const firstHalf: Map<string, BestEntry> = new Map();\n  const firstHalfSize = 1 << half1;\n\n  for (let mask = 0; mask < firstHalfSize; mask++) {\n    let sig = 0n;\n    let freeCount = 0;\n    for (let f = 0; f < half1; f++) {\n      if (mask & (1 << f)) {\n        sig ^= freeContrib[f];\n        freeCount++;\n      }\n    }\n\n    const key = sig.toString();\n    const existing = firstHalf.get(key);\n    if (!existing || freeCount < existing.freeCount) {\n      firstHalf.set(key, { freeCount, mask });\n    }\n  }\n\n  // For the second-half MITM, we need to iterate unique sigs.\n  // But we also need to find the best combination.\n  // For each second-half assignment, and each unique first-half sig:\n  //   total = freeCount1 + freeCount2 + popcount(rhs ^ sig1 ^ sig2)\n  // We want minimum total, then lex smallest solution.\n\n  // Convert map to arrays for faster iteration\n  const sigEntries: { sig: bigint; freeCount: number; mask: number }[] = [];\n  for (const [key, val] of firstHalf) {\n    sigEntries.push({ sig: BigInt(key), freeCount: val.freeCount, mask: val.mask });\n  }\n\n  let bestSolution: number[] | null = null;\n  let bestCount = m + 1;\n\n  const secondHalfSize = 1 << half2;\n\n  for (let mask2 = 0; mask2 < secondHalfSize; mask2++) {\n    let sig2 = 0n;\n    let freeCount2 = 0;\n    for (let f = 0; f < half2; f++) {\n      if (mask2 & (1 << f)) {\n        sig2 ^= freeContrib[half1 + f];\n        freeCount2++;\n      }\n    }\n\n    const base = rhsBitmask ^ sig2;\n\n    for (const e1 of sigEntries) {\n      const pivotBits = base ^ e1.sig;\n      const pivotCount = popcount64(pivotBits);\n      const totalCount = e1.freeCount + freeCount2 + pivotCount;\n\n      if (totalCount < bestCount) {\n        bestCount = totalCount;\n        const fullMask = e1.mask | (mask2 << half1);\n        bestSolution = buildToggleSolution(m, rank, pivotCol, pivotBits, freeVars, numFree, fullMask);\n      } else if (totalCount === bestCount) {\n        const fullMask = e1.mask | (mask2 << half1);\n        const candidate = buildToggleSolution(m, rank, pivotCol, pivotBits, freeVars, numFree, fullMask);\n        if (bestSolution === null || compareSolutionsBitmask(candidate, bestSolution, m) < 0) {\n          bestSolution = candidate;\n        }\n      }\n    }\n  }\n\n  if (bestSolution === null) return [];\n\n  const result: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (bestSolution[j]) result.push(j);\n  }\n  return result;\n}\n\nfunction buildToggleSolution(\n  m: number,\n  rank: number,\n  pivotCol: number[],\n  pivotBits: bigint,\n  freeVars: number[],\n  numFree: number,\n  freeMask: number,\n): number[] {\n  const solution = new Array(m).fill(0);\n  for (let f = 0; f < numFree; f++) {\n    if (freeMask & (1 << f)) {\n      solution[freeVars[f]] = 1;\n    }\n  }\n  for (let i = 0; i < rank; i++) {\n    if ((pivotBits >> BigInt(i)) & 1n) {\n      solution[pivotCol[i]] = 1;\n    }\n  }\n  return solution;\n}\n\nfunction compareSolutionsBitmask(a: number[], b: number[], m: number): number {\n  for (let i = 0; i < m; i++) {\n    if (a[i] !== b[i]) {\n      // a[i]=1 means a includes button i (b doesn't) → a is lex smaller\n      return a[i] === 1 ? -1 : 1;\n    }\n  }\n  return 0;\n}\n\nfunction popcount64(x: bigint): number {\n  let count = 0;\n  while (x > 0n) {\n    x &= x - 1n;\n    count++;\n  }\n  return count;\n}\n\n// ============= Counter Puzzle =============\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number,\n): number[] | null {\n  const n = lights.length;\n  const m = buttons.length;\n\n  if (m === 0) {\n    return lights.some(l => l % modulus !== 0) ? null : [];\n  }\n\n  // Build augmented matrix over GF(p)\n  const matrix: number[][] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    matrix[i] = new Array(m + 1).fill(0);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        matrix[i][j] = 1;\n      }\n    }\n    matrix[i][m] = ((lights[i] % modulus) + modulus) % modulus;\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  let currentRow = 0;\n\n  for (let col = 0; col < m && currentRow < n; col++) {\n    let pivotRow = -1;\n    for (let r = currentRow; r < n; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];\n\n    const inv = modInverse(matrix[currentRow][col], modulus);\n    for (let j = col; j <= m; j++) {\n      matrix[currentRow][j] = (matrix[currentRow][j] * inv) % modulus;\n    }\n\n    for (let r = 0; r < n; r++) {\n      if (r !== currentRow && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let j = col; j <= m; j++) {\n          matrix[r][j] = ((matrix[r][j] - factor * matrix[currentRow][j]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    currentRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < n; r++) {\n    if (matrix[r][m] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute coefficients for pivot rows\n  const pivotFreeCoeffs: number[][] = new Array(rank);\n  const pivotRHS: number[] = new Array(rank);\n  for (let i = 0; i < rank; i++) {\n    pivotFreeCoeffs[i] = new Array(numFree);\n    for (let f = 0; f < numFree; f++) {\n      pivotFreeCoeffs[i][f] = matrix[i][freeVars[f]];\n    }\n    pivotRHS[i] = matrix[i][m];\n  }\n\n  if (numFree === 0) {\n    const result = new Array(m).fill(0);\n    for (let i = 0; i < rank; i++) {\n      result[pivotCol[i]] = pivotRHS[i];\n    }\n    return result;\n  }\n\n  const totalAssignments = Math.pow(modulus, numFree);\n\n  if (totalAssignments <= 8_000_000) {\n    return enumerateCounterSolutions(m, rank, modulus, pivotCol, freeVars, numFree, pivotFreeCoeffs, pivotRHS);\n  }\n\n  // MITM for counter puzzle\n  return solveCounterMITM(m, rank, modulus, pivotCol, freeVars, numFree, pivotFreeCoeffs, pivotRHS);\n}\n\nfunction enumerateCounterSolutions(\n  m: number,\n  rank: number,\n  modulus: number,\n  pivotCol: number[],\n  freeVars: number[],\n  numFree: number,\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n): number[] | null {\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  const freeAssignment = new Array(numFree).fill(0);\n  const totalAssignments = Math.pow(modulus, numFree);\n\n  for (let iter = 0; iter < totalAssignments; iter++) {\n    // Compute pivot variables and total\n    let freeTotal = 0;\n    for (let f = 0; f < numFree; f++) {\n      freeTotal += freeAssignment[f];\n    }\n\n    let pivotTotal = 0;\n    const pivotVals = new Array(rank);\n    for (let i = 0; i < rank; i++) {\n      let val = pivotRHS[i];\n      for (let f = 0; f < numFree; f++) {\n        val -= pivotFreeCoeffs[i][f] * freeAssignment[f];\n      }\n      val = ((val % modulus) + modulus) % modulus;\n      pivotVals[i] = val;\n      pivotTotal += val;\n    }\n\n    const totalPresses = freeTotal + pivotTotal;\n\n    if (totalPresses < bestTotal) {\n      bestTotal = totalPresses;\n      bestSolution = buildCounterSolution(m, rank, pivotCol, pivotVals, freeVars, numFree, freeAssignment);\n    } else if (totalPresses === bestTotal && bestSolution !== null) {\n      const candidate = buildCounterSolution(m, rank, pivotCol, pivotVals, freeVars, numFree, freeAssignment);\n      if (compareArrays(candidate, bestSolution) < 0) {\n        bestSolution = candidate;\n      }\n    }\n\n    // Increment freeAssignment (base-modulus)\n    for (let f = numFree - 1; f >= 0; f--) {\n      freeAssignment[f]++;\n      if (freeAssignment[f] < modulus) break;\n      freeAssignment[f] = 0;\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction solveCounterMITM(\n  m: number,\n  rank: number,\n  modulus: number,\n  pivotCol: number[],\n  freeVars: number[],\n  numFree: number,\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n): number[] | null {\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // Build first-half map: sig (pivot contribution) -> best entry per (sig, freeTotal)\n  // For tied freeTotal, keep lex smallest assignment\n  interface HalfEntry {\n    sig: number[];\n    freeValues: number[];\n    freeTotal: number;\n  }\n\n  const firstHalfSize = Math.pow(modulus, half1);\n  // Group by sig, keep only best entry per unique sig\n  const firstHalfMap: Map<string, HalfEntry> = new Map();\n\n  const assign1 = new Array(half1).fill(0);\n  for (let iter = 0; iter < firstHalfSize; iter++) {\n    const sig = new Array(rank).fill(0);\n    let freeTotal = 0;\n    for (let f = 0; f < half1; f++) {\n      freeTotal += assign1[f];\n      for (let i = 0; i < rank; i++) {\n        sig[i] = (sig[i] + pivotFreeCoeffs[i][f] * assign1[f]) % modulus;\n      }\n    }\n\n    const key = sig.join(',');\n    const existing = firstHalfMap.get(key);\n    if (!existing || freeTotal < existing.freeTotal ||\n        (freeTotal === existing.freeTotal && compareArrays(assign1, existing.freeValues) < 0)) {\n      firstHalfMap.set(key, {\n        sig: sig.slice(),