if (bestSolution[j]) result.push(j);\n  }\n  return result;\n}\n\nfunction compareSolutions(a: number[], b: number[], m: number): number {\n  // Compare sets of pressed buttons lexicographically.\n  // The set {indices where a[i]=1} vs {indices where b[i]=1}.\n  for (let i = 0; i < m; i++) {\n    if (a[i] !== b[i]) {\n      // a has button i pressed but b doesn't: a's set includes i first → a > b\n      // a doesn't have button i pressed but b does: b's set includes i first → a < b\n      // Wait, lexicographic comparison of sets (as sorted arrays):\n      // We need to compare the sorted arrays of pressed indices.\n      // Actually, since we iterate i from 0 upward, the first difference determines it.\n      // If a[i]=1 and b[i]=0: a includes button i, b doesn't.\n      //   This means a's set has an element that b's set doesn't at position i.\n      //   If b's set has elements before i that a doesn't, those would have been caught earlier.\n      //   So at this point, both have the same elements before i.\n      //   a has i in its set, b doesn't → a's set has i, b's next element is > i.\n      //   So a's sorted array has i where b's sorted array has something > i (or nothing).\n      //   a < b lexicographically.\n      // If a[i]=0 and b[i]=1: symmetric → a > b.\n      return a[i] - b[i] === 1 ? -1 : 1;\n    }\n  }\n  return 0;\n}\n\nfunction solveToggleMITM(\n  rows: bigint[],\n  rank: number,\n  m: number,\n  pivotCol: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n): number[] | null {\n  // Meet-in-the-middle for large number of free variables.\n  // Split free variables into two halves. For each half, enumerate all assignments\n  // and compute the \"signature\" (the XOR contribution to pivot variables).\n  // Then find matching pairs.\n\n  const numFree = freeVars.length;\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // For each pivot row, compute contribution of each free vari