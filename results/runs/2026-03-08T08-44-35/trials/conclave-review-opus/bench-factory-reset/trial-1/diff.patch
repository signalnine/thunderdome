        const totalCount = e1.freeCount + freeCount2 + pivotCount;\n\n        if (totalCount < bestCount) {\n          bestCount = totalCount;\n          bestSolution = buildSolutionFromMITM(m, rank, pivotCol, pivotBits, e1.pressedFreeIndices, pressedFree2);\n        } else if (totalCount === bestCount && bestSolution !== null) {\n          const candidate = buildSolutionFromMITM(m, rank, pivotCol, pivotBits, e1.pressedFreeIndices, pressedFree2);\n          if (compareSolutions(candidate, bestSolution, m) < 0) {\n            bestSolution = candidate;\n          }\n        }\n      }\n    }\n  }\n\n  if (bestSolution === null) return null;\n  const result: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (bestSolution[j]) result.push(j);\n  }\n  return result;\n}\n\nfunction buildSolutionFromMITM(\n  m: number,\n  rank: number,\n  pivotCol: number[],\n  pivotBits: bigint,\n  pressedFree1: number[],\n  pressedFree2: number[],\n): number[] {\n  const solution = new Array(m).fill(0);\n  for (const idx of pressedFree1) solution[idx] = 1;\n  for (const idx of pressedFree2) solution[idx] = 1;\n  for (let i = 0; i < rank; i++) {\n    if ((pivotBits >> BigInt(i)) & 1n) {\n      solution[pivotCol[i]] = 1;\n    }\n  }\n  return solution;\n}\n\nfunction popcount64(x: bigint): number {\n  let count = 0;\n  while (x > 0n) {\n    x &= x - 1n;\n    count++;\n  }\n  return count;\n}\n\n/**\n * Solve counter puzzle using Gaussian elimination over GF(p).\n *\n * Each button press increments specific counters by 1 (mod p).\n * Button j can be pressed x[j] times (0 to p-1).\n * We need sum of x[j] * column_j = target (mod p) for each counter.\n * This is a system of linear equations over GF(p).\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number,\n): number[] | null {\n  const n = lights.length; // number of counters\n  const m = buttons.length; // number of buttons\n\n  // Build augmented matrix over GF(p)\n  // Each row is a count