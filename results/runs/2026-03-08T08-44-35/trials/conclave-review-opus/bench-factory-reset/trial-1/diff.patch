+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+
+  // Use BigInt masks to avoid 32-bit overflow (numFree can exceed 31)
+  interface SigEntry {
+    freeCount: number;
+    mask: bigint;
+  }
+
+  // Group first-half entries by signature.
+  // Keep all entries per (sig, freeCount) - but only the lex-smallest full solution matters.
+  // Since we can't determine lex order without the second half, keep the mask with
+  // smallest numeric value per (sig, freeCount) as a heuristic.
+  const firstHalf: Map<string, SigEntry[]> = new Map();
+  const firstHalfSize = 1 << half1;
+
+  for (let mask = 0; mask < firstHalfSize; mask++) {
+    let sig = 0n;
+    let freeCount = 0;
+    for (let f = 0; f < half1; f++) {
+      if (mask & (1 << f)) {
+        sig ^= freeContrib[f];
+        freeCount++;
+      }
+    }
+
+    const key = sig.toString();
+    let entries = firstHalf.get(key);
+    if (!entries) {
+      entries = [];
+      firstHalf.set(key, entries);
+    }
+    // Keep first entry per freeCount (mask increases, so first is numerically smallest)
+    const existing = entries.find(e => e.freeCount === freeCount);
+    if (!existing) {
+      entries.push({ freeCount, mask: BigInt(mask) });
+    }
+  }
+
+  // Sort entries within each sig group by freeCount ascending
+  const sigGroups: { sig: bigint; entries: SigEntry[] }[] = [];
+  for (const [key, entries] of firstHalf) {
+    entries.sort((a, b) => a.freeCount - b.freeCount);
+    sigGroups.push({ sig: BigInt(key), entries });
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestCount = m + 1;
+
+  const secondHalfSize = 1 << half2;
+  const half1Big = BigInt(half1);
+
+  for (let mask2 = 0; mask2 < secondHalfSize; mask2++) {
+    let sig2 = 0n;
+    let freeCount2 = 0;
+    for (let f = 0; f < half2; f++) {
+      if (mask2 & (1 << f)) {
+        sig2 ^= freeContrib[half1 + f];
+        freeCount2++;
+      }
+    }
+
+    const base = rhsBitmask ^ sig2;
+    const mask2Big = BigInt(mask2);
+
+    for (const group of sigGroups) {
+      const pivotBits = base ^ group.sig;
+      const pivotCount = popcount64(pivotBits);
+
+      for (const e1 of group.entries) {
+        const totalCount = e1.freeCount + freeCount2 + pivotCount;
+        if (totalCount > bestCount) break;
+
+        // Use BigInt for mask combination to avoid 32-bit overflow
+        const fullMask = e1.mask | (mask2Big << half1Big);
+        const candidate = buildToggleSolutionFromBigMask(m, rank, pivotCol, pivotBits, freeVars, numFree, fullMask);
+
+        if (totalCount < bestCount) {
+          bestCount = totalCount;
+          bestSolution = candidate;
+        } else if (bestSolution === null || compareSolutionsBitmask(candidate, bestSolution, m) < 0) {
+          bestSolution = candidate;
+        }
+      }
+    }
+  }
+
+  if (bestSolution === null) return [];
+
+  const result: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (bestSolution[j]) result.push(j);
+  }
+  return result;
+}
+
+function buildToggleSolutionFromMask(
+  m: number,
+  rank: number,
+  pivotCol: number[],
+  pivotBits: bigint,
+  freeVars: number[],
+  numFree: number,
+  freeMask: number,
+): number[] {
+  const solution = new Array(m).fill(0);
+  for (let f = 0; f < numFree; f++) {
+    if (freeMask & (1 << f)) {
+      solution[freeVars[f]] = 1;
+    }
+  }
+  for (let i = 0; i < rank; i++) {
+    if ((pivotBits >> BigInt(i)) & 1n) {
+      solution[pivotCol[i]] = 1;
+    }
+  }
+  return solution;
+}
+
+function buildToggleSolutionFromBigMask(
+  m: number,
+  rank: number,
+  pivotCol: number[],
+  pivotBits: bigint,
+  freeVars: number[],
+  numFree: number,
+  freeMask: bigint,
+): number[] {
+  const solution = new Array(m).fill(0);
+  for (let f = 0; f < numFree; f++) {
+    if ((freeMask >> BigInt(f)) & 1n) {
+      solution[freeVars[f]] = 1;
+    }
+  }
+  for (let i = 0; i < rank; i++) {
+    if ((pivotBits >> BigInt(i)) & 1n) {
+      solution[pivotCol[i]] = 1;
+    }
+  }
+  return solution;
+}
+
+function compareSolutionsBitmask(a: number[], b: number[], m: number): number {
+  for (let i = 0; i < m; i++) {
+    if (a[i] !== b[i]) {
+      // Including a lower-indexed button makes the set lex-smaller
+      return a[i] === 1 ? -1 : 1;
+    }
+  }
+  return 0;
+}
+
+function popcount64(x: bigint): number {
+  let count = 0;
+  while (x > 0n) {
+    x &= x - 1n;
+    count++;
+  }
+  return count;
+}
+
+// ============= Counter Puzzle =============
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (m === 0) {
+    return lights.some(l => ((l % modulus) + modulus) % modulus !== 0) ? null : [];
+  }
+
+  // Build augmented matrix over GF(p)
+  const matrix: number[][] = new Array(n);
+  for (let i = 0; i < n; i++) {
+    matrix[i] = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        matrix[i][j] = 1;
+      }
+    }
+    matrix[i][m] = ((lights[i] % modulus) + modulus) % modulus;
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+
+  for (let col = 0; col < m && currentRow < n; col++) {
+    let pivotRow = -1;
+    for (let r = currentRow; r < n; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];
+
+    const inv = modInverse(matrix[currentRow][col], modulus);
+    for (let j = col; j <= m; j++) {
+      matrix[currentRow][j] = (matrix[currentRow][j] * inv) % modulus;
+    }
+
+    for (let r = 0; r < n; r++) {
+      if (r !== currentRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let j = col; j <= m; j++) {
+          matrix[r][j] = ((matrix[r][j] - factor * matrix[currentRow][j]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    currentRow++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < n; r++) {
+    if (matrix[r][m] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) {
+      freeVars.push(j);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Precompute coefficients for pivot rows
+  const pivotFreeCoeffs: number[][] = new Array(rank);
+  const pivotRHS: number[] = new Array(rank);
+  for (let i = 0; i < rank; i++) {
+    pivotFreeCoeffs[i] = new Array(numFree);
+    for (let f = 0; f < numFree; f++) {
+      pivotFreeCoeffs[i][f] = matrix[i][freeVars[f]];
+    }
+    pivotRHS[i] = matrix[i][m];
+  }
+
+  if (numFree === 0) {
+    const result = new Array(m).fill(0);
+    for (let i = 0; i < rank; i++) {
+      result[pivotCol[i]] = pivotRHS[i];
+    }
+    return result;
+  }
+
+  // Adaptive threshold: account for O(rank * numFree) inner loop cost
+  const innerCost = Math.max(1, rank * numFree);
+  const maxWork = 200_000_000; // ~200M operations target
+  const enumThreshold = Math.floor(maxWork / innerCost);
+  const totalAssignments = Math.pow(modulus, numFree);
+
+  if (totalAssignments <= enumThreshold) {
+    return enumerateCounterSolutions(m, rank, modulus, pivotCol, freeVars, numFree, pivotFreeCoeffs, pivotRHS);
+  }
+
+  // MITM for counter puzzle
+  return solveCounterMITM(m, rank, modulus, pivotCol, freeVars, numFree, pivotFreeCoeffs, pivotRHS);
+}
+
+function enumerateCounterSolutions(
+  m: number,
+  rank: number,
+  modulus: number,
+  pivotCol: number[],
+  freeVars: number[],
+  numFree: number,
+  pivotFreeCoeffs: number[][],
+  pivotRHS: number[],
+): number[] | null {
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const freeAssignment = new Array(numFree).fill(0);
+  const totalAssignments = Math.pow(modulus, numFree);
+
+  for (let iter = 0; iter < totalAssignments; iter++) {
+    let freeTotal = 0;
+    for (let f = 0; f < numFree; f++) {
+      freeTotal += freeAssignment[f];
+    }
+
+    let pivotTotal = 0;
+    const pivotVals = new Array(rank);
+    for (let i = 0; i < rank; i++) {
+      let val = pivotRHS[i];
+      for (let f = 0; f < numFree; f++) {
+        val -= pivotFreeCoeffs[i][f] * freeAssignment[f];
+      }
+      val = ((val % modulus) + modulus) % modulus;
+      pivotVals[i] = val;
+      pivotTotal += val;
+    }
+
+    const totalPresses = freeTotal + pivotTotal;
+
+    if (totalPresses < bestTotal) {
+      bestTotal = totalPresses;
+      bestSolution = buildCounterSolution(m, rank, pivotCol, pivotVals, freeVars, numFree, freeAssignment);
+    } else if (totalPresses === bestTotal && bestSolution !== null) {
+      const candidate = buildCounterSolution(m, rank, pivotCol, pivotVals, freeVars, numFree, freeAssignment);
+      if (compareArrays(candidate, bestSolution) < 0) {
+        bestSolution = candidate;
+      }
+    }
+
+    // Increment freeAssignment (base-modulus)
+    for (let f = numFree - 1; f >= 0; f--) {
+      freeAssignment[f]++;
+      if (freeAssignment[f] < modulus) break;
+      freeAssignment[f] = 0;
+    }
+  }
+
+  return bestSolution;
+}
+
+function solveCounterMITM(
+  m: number,
+  rank: number,
+  modulus: number,
+  pivotCol: number[],
+  freeVars: number[],
+  numFree: number,
+  pivotFreeCoeffs: number[][],
+  pivotRHS: number[],
+): number[] | null {
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+
+  interface HalfEntry {
+    sig: number[];
+    freeValues: number[];
+    freeTotal: number;
+  }
+
+  // Build first-half map: sig -> list of entries
+  const firstHalfSize = Math.pow(modulus, half1);
+  const firstHalfMap: Map<string, HalfEntry[]> = new Map();
+
+  const assign1 = new Array(half1).fill(0);
+  for (let iter = 0; iter < firstHalfSize; iter++) {
+    const sig = new Array(rank).fill(0);
+    let freeTotal = 0;
+    for (let f = 0; f < half1; f++) {
+      freeTotal += assign1[f];
+      for (let i = 0; i < rank; i++) {
+        sig[i] = (sig[i] + pivotFreeCoeffs[i][f] * assign1[f]) % modulus;
+      }
+    }
+
+    const key = sig.join(',');
+    let entries = firstHalfMap.get(key);
+    if (!entries) {
+      entries = [];
+      firstHalfMap.set(key, entries);
+    }
+
+    // For each (sig, freeTotal), keep only lex-smallest freeValues
+    const existing = entries.find(e => e.freeTotal === freeTotal);
+    if (!existing) {
+      entries.push({
+        sig: sig.slice(),
+        freeValues: assign1.slice(),
+        freeTotal,
+      });
+    } else if (compareArrays(assign1, existing.freeValues) < 0) {
+      existing.freeValues = assign1.slice();
+    }
+
+    // Increment
+    for (let f = half1 - 1; f >= 0; f--) {
+      assign1[f]++;
+      if (assign1[f] < modulus) break;
+      assign1[f] = 0;
+    }
+  }
+
+  // Sort entries within each sig group by freeTotal ascending
+  for (const [, entries] of firstHalfMap) {
+    entries.sort((a, b) => a.freeTotal - b.freeTotal);
+  }
+
+  // Convert to arrays for iteration
+  const sigEntries = Array.from(firstHalfMap.entries());
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const secondHalfSize = Math.pow(modulus, half2);
+  const assign2 = new Array(half2).fill(0);
+
+  for (let iter = 0; iter < secondHalfSize; iter++) {
+    const sig2 = new Array(rank).fill(0);
+    let freeTotal2 = 0;
+    for (let f = 0; f < half2; f++) {
+      freeTotal2 += assign2[f];
+      for (let i = 0; i < rank; i++) {
+        sig2[i] = (sig2[i] + pivotFreeCoeffs[i][half1 + f] * assign2[f]) % modulus;
+      }
+    }
+
+    // For each first-half signature, compute total and check
+    for (const [, entries] of sigEntries) {
+      const e1 = entries[0]; // entry with min freeTotal for this sig
+
+      // Compute pivot total for this sig combination
+      let pivotTotal = 0;
+      const pivotVals = new Array(rank);
+      for (let i = 0; i < rank; i++) {
+        const val = ((pivotRHS[i] - e1.sig[i] - sig2[i]) % modulus + modulus) % modulus;
+        pivotVals[i] = val;
+        pivotTotal += val;
+      }
+
+      // Check minimum possible total with this sig
+      const minTotal = e1.freeTotal + freeTotal2 + pivotTotal;
+      if (minTotal > bestTotal) continue;
+
+      if (minTotal < bestTotal) {
+        bestTotal = minTotal;
+        bestSolution = buildCounterSolutionMITM(m, rank, pivotCol, pivotVals, freeVars, half1, half2, e1.freeValues, assign2);
+      } else {
+        // Tied - check all entries with same freeTotal for lex comparison
+        for (const entry of entries) {
+          if (entry.freeTotal + freeTotal2 + pivotTotal > bestTotal) break;
+          const candidate = buildCounterSolutionMITM(m, rank, pivotCol, pivotVals, freeVars, half1, half2, entry.freeValues, assign2);
+          if (bestSolution === null || compareArrays(candidate, bestSolution) < 0) {
+            bestSolution = candidate;
+          }
+        }
+      }
+    }
+
+    // Increment
+    for (let f = half2 - 1; f >= 0; f--) {
+      assign2[f]++;
+      if (assign2[f] < modulus) break;
+      assign2[f] = 0;
+    }
+  }
+
+  return bestSolution;
+}
+
+function buildCounterSolution(
+  m: number,
+  rank: number,
+  pivotCol: number[],
+  pivotVals: number[],
+  freeVars: number[],
+  numFree: number,
+  freeAssignment: number[],
+): number[] {
+  const solution = new Array(m).fill(0);
+  for (let f = 0; f < numFree; f++) {
+    solution[freeVars[f]] = freeAssignment[f];
+  }
+  for (let i = 0; i < rank; i++) {
+    solution[pivotCol[i]] = pivotVals[i];
+  }
+  return solution;
+}
+
+function buildCounterSolutionMITM(
+  m: number,
+  rank: number,
+  pivotCol: number[],
+  pivotVals: number[],
+  freeVars: number[],
+  half1: number,
+  half2: number,
+  freeValues1: number[],
+  freeValues2: number[],
+): number[] {
+  const solution = new Array(m).fill(0);
+  for (let f = 0; f < half1; f++) {
+    solution[freeVars[f]] = freeValues1[f];
+  }
+  for (let f = 0; f < half2; f++) {
+    solution[freeVars[half1 + f]] = freeValues2[f];
+  }
+  for (let i = 0; i < rank; i++) {
+    solution[pivotCol[i]] = pivotVals[i];
+  }
+  return solution;
+}
+
+function compareArrays(a: number[], b: number[]): number {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return a.length - b.length;
+}
+
+function modInverse(a: number, p: number): number {
+  a = ((a % p) + p) % p;
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % p) + p) % p;
+}
