+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import { authMiddleware, AuthenticatedRequest } from '../helpers.js';
+
+export function activityRoutes(store: Store): Router {
+  const router = Router();
+  const auth = authMiddleware(store);
+
+  router.get('/activity', auth, (req, res: Response): void => {
+    const _userId = (req as AuthenticatedRequest).userId;
+    const { resourceType, resourceId } = req.query;
+
+    let logs = [...store.activityLog];
+
+    if (resourceType && typeof resourceType === 'string') {
+      logs = logs.filter((l) => l.resourceType === resourceType);
+    }
+
+    if (resourceId && typeof resourceId === 'string') {
+      logs = logs.filter((l) => l.resourceId === resourceId);
+    }
+
+    void _userId;
+    res.status(200).json(logs);
+  });
+
+  return router;
+}
diff --git a/src/routes/auth.ts b/src/routes/auth.ts
new file mode 100644
index 0000000..aa455d6
--- /dev/null
+++ b/src/routes/auth.ts
@@ -0,0 +1,70 @@
+import { Router, Request, Response } from 'express';
+import { Store } from '../store.js';
+import { generateId, generateToken } from '../helpers.js';
+
+export function authRoutes(store: Store): Router {
+  const router = Router();
+
+  router.post('/auth/register', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    if (typeof username !== 'string' || typeof password !== 'string') {
+      res.status(400).json({ error: 'Username and password must be strings' });
+      return;
+    }
+
+    // Check if username is taken
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = generateId();
+    const user = { id, username, password, token: null };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  router.post('/auth/login', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    let foundUser = null;
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        foundUser = user;
+        break;
+      }
+    }
+
+    if (!foundUser || foundUser.password !== password) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    // Invalidate old token if present
+    if (foundUser.token) {
+      store.tokenToUserId.delete(foundUser.token);
+    }
+
+    const token = generateToken();
+    foundUser.token = token;
+    store.tokenToUserId.set(token, foundUser.id);
+
+    res.status(200).json({ token, userId: foundUser.id });
+  });
+
+  return router;
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..499e3f9
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,167 @@
+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import {
+  generateId,
+  authMiddleware,
+  AuthenticatedRequest,
+  hasPermission,
+  addActivityLog,
+} from '../helpers.js';
+
+function handleCreateDocument(
+  store: Store,
+  req: AuthenticatedRequest,
+  res: Response,
+  folderId: string
+): void {
+  const { userId } = req;
+  const { title, content } = req.body;
+
+  if (!title || typeof title !== 'string') {
+    res.status(400).json({ error: 'Document title is required' });
+    return;
+  }
+
+  if (content === undefined || content === null) {
+    res.status(400).json({ error: 'Document content is required' });
+    return;
+  }
+
+  const folder = store.folders.get(folderId);
+  if (!folder) {
+    res.status(404).json({ error: 'Folder not found' });
+    return;
+  }
+
+  if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+    res.status(403).json({ error: 'Insufficient permissions on folder' });
+    return;
+  }
+
+  const id = generateId();
+  const now = new Date().toISOString();
+  const doc = {
+    id,
+    title,
+    content: String(content),
+    folderId,
+    ownerId: userId,
+    createdAt: now,
+    updatedAt: now,
+  };
+
+  store.documents.set(id, doc);
+
+  store.permissions.push({
+    id: generateId(),
+    resourceType: 'document',
+    resourceId: id,
+    userId,
+    role: 'owner',
+  });
+
+  addActivityLog(store, 'document_created', userId, 'document', id);
+
+  res.status(201).json(doc);
+}
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+  const auth = authMiddleware(store);
+
+  // Create document
+  router.post('/documents', auth, (req, res: Response): void => {
+    const { folderId } = req.body;
+    if (!folderId || typeof folderId !== 'string') {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+    handleCreateDocument(store, req as AuthenticatedRequest, res, folderId);
+  });
+
+  // Also support POST /folders/:folderId/documents
+  router.post('/folders/:folderId/documents', auth, (req, res: Response): void => {
+    handleCreateDocument(store, req as AuthenticatedRequest, res, req.params.folderId);
+  });
+
+  // Get document
+  router.get('/documents/:id', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  // Update document
+  router.put('/documents/:id', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+
+    if (title !== undefined) {
+      if (typeof title !== 'string' || !title) {
+        res.status(400).json({ error: 'Title must be a non-empty string' });
+        return;
+      }
+      doc.title = title;
+    }
+
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+
+    doc.updatedAt = new Date().toISOString();
+
+    addActivityLog(store, 'document_updated', userId, 'document', doc.id);
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/documents/:id', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    store.documents.delete(doc.id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)
+    );
+
+    addActivityLog(store, 'document_deleted', userId, 'document', doc.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
new file mode 100644
index 0000000..22298b4
--- /dev/null
+++ b/src/routes/folders.ts
@@ -0,0 +1,203 @@
+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import {
+  generateId,
+  authMiddleware,
+  AuthenticatedRequest,
+  hasPermission,
+  addActivityLog,
+} from '../helpers.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+  const auth = authMiddleware(store);
+
+  // Create folder
+  router.post('/folders', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const { name, parentId } = req.body;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // If parentId is specified, check it exists and user has permission
+    if (parentId !== undefined && parentId !== null) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+
+    store.folders.set(id, folder);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    addActivityLog(store, 'folder_created', userId, 'folder', id);
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/folders/:id', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get child folders and documents
+    const children: string[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        children.push(f.id);
+      }
+    }
+
+    const documents: string[] = [];
+    for (const d of store.documents.values()) {
+      if (d.folderId === folder.id) {
+        documents.push(d.id);
+      }
+    }
+
+    res.status(200).json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/folders/:id', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+
+    if (name !== undefined) {
+      if (typeof name !== 'string' || !name) {
+        res.status(400).json({ error: 'Folder name must be a non-empty string' });
+        return;
+      }
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular references by walking up the ancestor chain
+        if (wouldCreateCycle(store, folder.id, parentId)) {
+          res.status(400).json({ error: 'Cannot move folder: would create a circular reference' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.status(200).json(folder);
+  });
+
+  // Delete folder
+  router.delete('/folders/:id', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete the folder and its contents recursively
+    deleteFolderRecursive(store, folder.id);
+
+    addActivityLog(store, 'folder_deleted', userId, 'folder', folder.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function wouldCreateCycle(store: Store, folderId: string, newParentId: string): boolean {
+  let currentId: string | null = newParentId;
+  while (currentId) {
+    if (currentId === folderId) return true;
+    const folder = store.folders.get(currentId);
+    currentId = folder ? folder.parentId : null;
+  }
+  return false;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string): void {
+  // Collect child folder IDs first to avoid mutating Map during iteration
+  const childFolderIds = [...store.folders.values()]
+    .filter((f) => f.parentId === folderId)
+    .map((f) => f.id);
+
+  for (const childId of childFolderIds) {
+    deleteFolderRecursive(store, childId);
+  }
+
+  // Collect document IDs first
+  const docIds = [...store.documents.values()]
+    .filter((d) => d.folderId === folderId)
+    .map((d) => d.id);
+
+  for (const docId of docIds) {
+    store.documents.delete(docId);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === docId)
+    );
+  }
+
+  // Delete the folder itself
+  store.folders.delete(folderId);
+  store.permissions = store.permissions.filter(
+    (p) => !(p.resourceType === 'folder' && p.resourceId === folderId)
+  );
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..2e8adc0
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,191 @@
+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import {
+  generateId,
+  authMiddleware,
+  AuthenticatedRequest,
+  hasPermission,
+  getEffectiveRole,
+  addActivityLog,
+} from '../helpers.js';
+import { Role } from '../types.js';
+
+const validRoles: Role[] = ['viewer', 'editor', 'owner'];
+
+function handleResourceShare(
+  store: Store,
+  req: AuthenticatedRequest,
+  res: Response,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): void {
+  const { userId } = req;
+  const { targetUserId, role } = req.body;
+
+  if (!targetUserId || !role) {
+    res.status(400).json({ error: 'targetUserId and role are required' });
+    return;
+  }
+
+  if (!validRoles.includes(role)) {
+    res.status(400).json({ error: 'Role must be "viewer", "editor", or "owner"' });
+    return;
+  }
+
+  // Check resource exists
+  if (resourceType === 'folder' && !store.folders.has(resourceId)) {
+    res.status(404).json({ error: 'Folder not found' });
+    return;
+  }
+  if (resourceType === 'document' && !store.documents.has(resourceId)) {
+    res.status(404).json({ error: 'Document not found' });
+    return;
+  }
+
+  // Check target user exists
+  if (!store.users.has(targetUserId)) {
+    res.status(404).json({ error: 'Target user not found' });
+    return;
+  }
+
+  // Check that sharer has sufficient permission
+  const requiredRole: Role = role === 'owner' ? 'owner' : 'editor';
+  if (!hasPermission(store, userId, resourceType, resourceId, requiredRole)) {
+    res.status(403).json({ error: 'Insufficient permissions to share this resource' });
+    return;
+  }
+
+  // Check if target already has a permission on this resource
+  const existingIndex = store.permissions.findIndex(
+    (p) =>
+      p.resourceType === resourceType &&
+      p.resourceId === resourceId &&
+      p.userId === targetUserId
+  );
+
+  if (existingIndex >= 0) {
+    store.permissions[existingIndex].role = role;
+  } else {
+    store.permissions.push({
+      id: generateId(),
+      resourceType,
+      resourceId,
+      userId: targetUserId,
+      role,
+    });
+  }
+
+  addActivityLog(
+    store,
+    'resource_shared',
+    userId,
+    resourceType,
+    resourceId,
+    `Shared with user ${targetUserId} as ${role}`
+  );
+
+  res.status(200).json({ message: 'Resource shared successfully', resourceType, resourceId, targetUserId, role });
+}
+
+export function sharingRoutes(store: Store): Router {
+  const router = Router();
+  const auth = authMiddleware(store);
+
+  // Share a resource via POST /share
+  router.post('/share', auth, (req, res: Response): void => {
+    const { resourceType, resourceId } = req.body;
+
+    if (!resourceType || !resourceId) {
+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    handleResourceShare(store, req as AuthenticatedRequest, res, resourceType, resourceId);
+  });
+
+  // Share via resource-specific endpoint: POST /:resourceType/:id/share
+  router.post('/folders/:id/share', auth, (req, res: Response): void => {
+    handleResourceShare(store, req as AuthenticatedRequest, res, 'folder', req.params.id);
+  });
+
+  router.post('/documents/:id/share', auth, (req, res: Response): void => {
+    handleResourceShare(store, req as AuthenticatedRequest, res, 'document', req.params.id);
+  });
+
+  // Get effective permissions for a resource
+  router.get('/folders/:id/permissions', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const folderId = req.params.id;
+
+    if (!store.folders.has(folderId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', folderId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const permissions = store.permissions.filter(
+      (p) => p.resourceType === 'folder' && p.resourceId === folderId
+    );
+
+    res.status(200).json(permissions);
+  });
+
+  router.get('/documents/:id/permissions', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const docId = req.params.id;
+
+    if (!store.documents.has(docId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', docId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const permissions = store.permissions.filter(
+      (p) => p.resourceType === 'document' && p.resourceId === docId
+    );
+
+    res.status(200).json(permissions);
+  });
+
+  // Get effective role for a user on a resource
+  router.get('/folders/:id/role', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const folderId = req.params.id;
+
+    if (!store.folders.has(folderId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'folder', folderId);
+    res.status(200).json({ role });
+  });
+
+  router.get('/documents/:id/role', auth, (req, res: Response): void => {
+    const { userId } = req as AuthenticatedRequest;
+    const docId = req.params.id;
+
+    if (!store.documents.has(docId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', docId);
+    res.status(200).json({ role });
+  });
+
+  return router;
+}
