diff --git a/src/app.ts b/src/app.ts
new file mode 100644
index 0000000..0436885
--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,22 @@
+import express from 'express';
+import { createStore } from './store.js';
+import { authRoutes } from './routes/auth.js';
+import { folderRoutes } from './routes/folders.js';
+import { documentRoutes } from './routes/documents.js';
+import { sharingRoutes } from './routes/sharing.js';
+import { activityRoutes } from './routes/activity.js';
+
+export function createApp() {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+
+  app.use(authRoutes(store));
+  app.use(folderRoutes(store));
+  app.use(documentRoutes(store));
+  app.use(sharingRoutes(store));
+  app.use(activityRoutes(store));
+
+  return app;
+}
diff --git a/src/helpers.ts b/src/helpers.ts
new file mode 100644
index 0000000..ee9b32b
--- /dev/null
+++ b/src/helpers.ts
@@ -0,0 +1,133 @@
+import crypto from 'node:crypto';
+import { Request, Response, NextFunction } from 'express';
+import { Store } from './store.js';
+import { Role } from './types.js';
+
+export function generateId(): string {
+  return crypto.randomUUID();
+}
+
+export function generateToken(): string {
+  return crypto.randomBytes(32).toString('hex');
+}
+
+export function authMiddleware(store: Store) {
+  return (req: Request, res: Response, next: NextFunction): void => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+    const token = authHeader.slice(7);
+    const userId = store.tokenToUserId.get(token);
+    if (!userId) {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+    (req as AuthenticatedRequest).userId = userId;
+    next();
+  };
+}
+
+export interface AuthenticatedRequest extends Request {
+  userId: string;
+}
+
+const roleHierarchy: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  visited: Set<string> = new Set()
+): Role | null {
+  const key = `${resourceType}:${resourceId}`;
+  if (visited.has(key)) return null; // cycle guard
+  visited.add(key);
+
+  let bestRole: Role | null = null;
+  let bestLevel = 0;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      const level = roleHierarchy[perm.role];
+      if (level > bestLevel) {
+        bestLevel = level;
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // If the resource is a document, also check permissions on its folder chain
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId, visited);
+      if (folderRole) {
+        const level = roleHierarchy[folderRole];
+        if (level > bestLevel) {
+          bestLevel = level;
+          bestRole = folderRole;
+        }
+      }
+    }
+  }
+
+  // If the resource is a folder, also check parent folder chain
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId, visited);
+      if (parentRole) {
+        const level = roleHierarchy[parentRole];
+        if (level > bestLevel) {
+          bestLevel = level;
+          bestRole = parentRole;
+        }
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  requiredRole: Role
+): boolean {
+  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effectiveRole) return false;
+  return roleHierarchy[effectiveRole] >= roleHierarchy[requiredRole];
+}
+
+export function addActivityLog(
+  store: Store,
+  action: string,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  details?: string
+): void {
+  store.activityLog.push({
+    id: generateId(),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date().toISOString(),
+    details,
+  });
+}
