ete document\n  router.delete('/documents/:id', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'document', doc.id, 'owner')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    store.documents.delete(doc.id);\n    store.permissions = store.permissions.filter(\n      (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)\n    );\n\n    addActivityLog(store, 'document_deleted', userId, 'document', doc.id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2447,"cache_read_input_tokens":55414,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2447},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"82bc402b-6f66-43eb-81aa-8fc76b5c168d","uuid":"88582f1b-1d57-4055-9c94-b081773cd90a"}
