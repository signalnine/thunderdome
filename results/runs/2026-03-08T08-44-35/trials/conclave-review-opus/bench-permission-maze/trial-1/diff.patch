+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0183VEPsQtWT2kUMrdpzUbMt","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SoKfs6Rz1fabX4uK8fthQy","name":"Write","input":{"file_path":"/workspace/tests/app.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport type { Express } from 'express';\nimport { createApp } from '../src/app.js';\n\ndescribe('Document Management API', () => {\n  let app: Express;\n\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  // ==================== AUTH ====================\n  describe('Authentication', () => {\n    it('should register a new user', async () => {\n      const res = await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice', password: 'pass123' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.username).toBe('alice');\n      expect(res.body.id).toBeDefined();\n    });\n\n    it('should reject duplicate usernames', async () => {\n      await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice', password: 'pass123' });\n\n      const res = await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice', password: 'other' });\n\n      expect(res.status).toBe(409);\n    });\n\n    it('should reject registration without username or password', async () => {\n      const res1 = await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice' });\n      expect(res1.status).toBe(400);\n\n      const res2 = await request(app)\n        .post('/auth/register')\n        .send({ password: 'pass' });\n      expect(res2.status).toBe(400);\n    });\n\n    it('should login and return a token', async () => {\n      await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice', password: 'pass123' });\n\n      const res = await request(app)\n        .post('/auth/login')\n        .send({ username: 'alice', password: 'pass123' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n      expect(res.body.userId).toBeDefined();\n    });\n\n    it('should reject login with wrong password', async () => {\n      await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice', password: 'pass123' });\n\n      const res = await request(app)\n        .post('/auth/login')\n        .send({ username: 'alice', password: 'wrong' });\n\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject login with non-existent user', async () => {\n      const res = await request(app)\n        .post('/auth/login')\n        .send({ username: 'nobody', password: 'pass' });\n\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject unauthenticated requests', async () => {\n      const res = await request(app).get('/folders/some-id');\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject requests with invalid token', async () => {\n      const res = await request(app)\n        .get('/folders/some-id')\n        .set('Authorization', 'Bearer invalidtoken');\n      expect(res.status).toBe(401);\n    });\n  });\n\n  // Helper: register and login, return token and userId\n  async function createUser(appInst: Express, username: string, password: string) {\n    const reg = await request(appInst)\n      .post('/auth/register')\n      .send({ username, password });\n    const login = await request(appInst)\n      .post('/auth/login')\n      .send({ username, password });\n    return { token: login.body.token as string, userId: reg.body.id as string };\n  }\n\n  // ==================== FOLDERS ====================\n  describe('Folders', () => {\n    let token: string;\n    let userId: string;\n\n    beforeEach(async () => {\n      const user = await createUser(app, 'alice', 'pass');\n      token = user.token;\n      userId = user.userId;\n    });\n\n    it('should create a folder', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'My Folder' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('My Folder');\n      expect(res.body.id).toBeDefined();\n      expect(res.body.parentId).toBeNull();\n      expect(res.body.ownerId).toBe(userId);\n    });\n\n    it('should get a folder', async () => {\n      const create = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'My Folder' });\n\n      const res = await request(app)\n        .get(`/folders/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('My Folder');\n      expect(res.body.children).toEqual([]);\n      expect(res.body.documents).toEqual([]);\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .get('/folders/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should create nested folders', async () => {\n      const parent = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Parent' });\n\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n\n      expect(child.status).toBe(201);\n      expect(child.body.parentId).toBe(parent.body.id);\n\n      // Parent should list child\n      const parentGet = await request(app)\n        .get(`/folders/${parent.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(parentGet.body.children).toContain(child.body.id);\n    });\n\n    it('should update a folder', async () => {\n      const create = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Old Name' });\n\n      const res = await request(app)\n        .put(`/folders/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'New Name' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('New Name');\n    });\n\n    it('should delete a folder', async () => {\n      const create = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'To Delete' });\n\n      const res = await request(app)\n        .delete(`/folders/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/folders/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(get.status).toBe(404);\n    });\n\n    it('should delete folder recursively with children and documents', async () => {\n      const parent = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Parent' });\n\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'text', folderId: child.body.id });\n\n      // Delete parent\n      await request(app)\n        .delete(`/folders/${parent.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      // Child and doc should be gone\n      const childGet = await request(app)\n        .get(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(childGet.status).toBe(404);\n\n      const docGet = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(docGet.status).toBe(404);\n    });\n\n    it('should reject creating folder with non-existent parent', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Orphan', parentId: 'nonexistent' });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject creating folder without name', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({});\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  // ==================== DOCUMENTS ====================\n  describe('Documents', () => {\n    let token: string;\n    let folderId: string;\n\n    beforeEach(async () => {\n      const user = await createUser(app, 'alice', 'pass');\n      token = user.token;\n\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Docs Folder' });\n      folderId = folder.body.id;\n    });\n\n    it('should create a document', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Hello world', folderId });\n\n      expect(res.status).toBe(201);\n      expect(res.body.title).toBe('My Doc');\n      expect(res.body.content).toBe('Hello world');\n      expect(res.body.folderId).toBe(folderId);\n    });\n\n    it('should create a document via folder endpoint', async () => {\n      const res = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Hello' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.folderId).toBe(folderId);\n    });\n\n    it('should get a document', async () => {\n      const create = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Hello world', folderId });\n\n      const res = await request(app)\n        .get(`/documents/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('My Doc');\n    });\n\n    it('should update a document', async () => {\n      const create = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Old Title', content: 'Old content', folderId });\n\n      const res = await request(app)\n        .put(`/documents/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'New Title', content: 'New content' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('New Title');\n      expect(res.body.content).toBe('New content');\n    });\n\n    it('should delete a document', async () => {\n      const create = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'To Delete', content: 'Bye', folderId });\n\n      const del = await request(app)\n        .delete(`/documents/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(del.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/documents/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(get.status).toBe(404);\n    });\n\n    it('should return 404 for non-existent document', async () => {\n      const res = await request(app)\n        .get('/documents/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject creating document without title', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ content: 'text', folderId });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject creating document without folderId', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'text' });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject creating document in non-existent folder', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'text', folderId: 'nonexistent' });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should list documents in folder', async () => {\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'text', folderId });\n\n      const folder = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(folder.body.documents).toContain(doc.body.id);\n    });\n  });\n\n  // ==================== SHARING & PERMISSIONS ====================\n  describe('Sharing & Permissions', () => {\n    let aliceToken: string;\n    let aliceId: string;\n    let bobToken: string;\n    let bobId: string;\n    let folderId: string;\n\n    beforeEach(async () => {\n      const alice = await createUser(app, 'alice', 'pass');\n      aliceToken = alice.token;\n      aliceId = alice.userId;\n\n      const bob = await createUser(app, 'bob', 'pass');\n      bobToken = bob.token;\n      bobId = bob.userId;\n\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n      folderId = folder.body.id;\n    });\n\n    it('should deny access to non-shared folder', async () => {\n      const res = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should share a folder with viewer role', async () => {\n      const share = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      expect(share.status).toBe(200);\n\n      // Bob can now read\n      const get = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(get.status).toBe(200);\n    });\n\n    it('should deny editor actions for viewer', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      // Bob cannot update\n      const res = await request(app)\n        .put(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Renamed' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should allow editor to update', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      const res = await request(app)\n        .put(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Renamed by Bob' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Renamed by Bob');\n    });\n\n    it('should deny delete for editor', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      const res = await request(app)\n        .delete(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should allow owner to delete', async () => {\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'owner',\n        });\n\n      const res = await request(app)\n        .delete(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(204);\n    });\n\n    it('should share document directly', async () => {\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'text', folderId });\n\n      // Bob cannot see it yet\n      const denied = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(denied.status).toBe(403);\n\n      // Share it\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: doc.body.id,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      // Now Bob can see it\n      const get = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n      expect(get.status).toBe(200);\n    });\n\n    it('should inherit folder permissions for documents', async () => {\n      // Share folder with Bob as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      // Create a doc in the folder\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'text', folderId });\n\n      // Bob should be able to read the doc (inherits from folder)\n      const get = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(get.status).toBe(200);\n    });\n\n    it('should inherit nested folder permissions', async () => {\n      // Share parent folder with Bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      // Create child folder\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: folderId });\n\n      // Bob should inherit editor access on child\n      const res = await request(app)\n        .put(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Renamed Child' });\n\n      expect(res.status).toBe(200);\n    });\n\n    it('should use the most permissive role from multiple paths', async () => {\n      // Share folder with Bob as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      // Create doc\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'text', folderId });\n\n      // Share doc directly with Bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'document',\n          resourceId: doc.body.id,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      // Bob should be able to edit (editor from direct share, not just viewer from folder)\n      const update = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'Updated by Bob' });\n\n      expect(update.status).toBe(200);\n    });\n\n    it('should allow editor to share with others', async () => {\n      const charlie = await createUser(app, 'charlie', 'pass');\n\n      // Share folder with Bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      // Bob shares with Charlie\n      const share = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'viewer',\n        });\n\n      expect(share.status).toBe(200);\n\n      // Charlie can now read\n      const get = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${charlie.token}`);\n\n      expect(get.status).toBe(200);\n    });\n\n    it('should deny viewer from sharing', async () => {\n      const charlie = await createUser(app, 'charlie', 'pass');\n\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      const share = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'viewer',\n        });\n\n      expect(share.status).toBe(403);\n    });\n\n    it('should share via resource-specific endpoint', async () => {\n      const share = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'viewer' });\n\n      expect(share.status).toBe(200);\n    });\n\n    it('should update existing permission when sharing again', async () => {\n      // Share as viewer\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      // Update to editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      // Bob should be able to edit\n      const res = await request(app)\n        .put(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Edited' });\n\n      expect(res.status).toBe(200);\n    });\n\n    it('should reject sharing non-existent resource', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: 'nonexistent',\n          targetUserId: bobId,\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject sharing with non-existent user', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: 'nonexistent',\n          role: 'viewer',\n        });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject invalid role', async () => {\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'admin',\n        });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('should require editor to only assign owner if they are owner themselves', async () => {\n      // Share with Bob as editor\n      await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: bobId,\n          role: 'editor',\n        });\n\n      const charlie = await createUser(app, 'charlie', 'pass');\n\n      // Bob (editor) tries to share as owner - should fail\n      const res = await request(app)\n        .post('/share')\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({\n          resourceType: 'folder',\n          resourceId: folderId,\n          targetUserId: charlie.userId,\n          role: 'owner',\n        });\n\n      expect(res.status).toBe(403);\n    });\n  });\n\n  // ==================== ACTIVITY LOG ====================\n  describe('Activity Log', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const user = await createUser(app, 'alice', 'pass');\n      token = user.token;\n    });\n\n    it('should track document creation', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Folder' });\n\n      await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'text', folderId: folder.body.id });\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.length).toBeGreaterThan(0);\n\n      const docCreated = res.body.find(\n        (e: { action: string }) => e.action === 'document_created'\n      );\n      expect(docCreated).toBeDefined();\n      expect(docCreated.timestamp).toBeDefined();\n    });\n\n    it('should track document updates', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Folder' });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'text', folderId: folder.body.id });\n\n      await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ content: 'Updated' });\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${token}`);\n\n      const updated = res.body.find(\n        (e: { action: string }) => e.action === 'document_updated'\n      );\n      expect(updated).toBeDefined();\n    });\n\n    it('should track document deletion', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n      