rror: 'Document not found' });\n   205→    return;\n   206→  }\n   207→\n   208→  // Check target user exists\n   209→  if (!store.users.has(targetUserId)) {\n   210→    res.status(404).json({ error: 'Target user not found' });\n   211→    return;\n   212→  }\n   213→\n   214→  // Check that sharer has sufficient permission\n   215→  const requiredRole: Role = role === 'owner' ? 'owner' : 'editor';\n   216→  if (!hasPermission(store, userId, resourceType, resourceId, requiredRole)) {\n   217→    res.status(403).json({ error: 'Insufficient permissions to share this resource' });\n   218→    return;\n   219→  }\n   220→\n   221→  // Check if target already has a permission on this resource\n   222→  const existingIndex = store.permissions.findIndex(\n   223→    (p) =>\n   224→      p.resourceType === resourceType &&\n   225→      p.resourceId === resourceId &&\n   226→      p.userId === targetUserId\n   227→  );\n   228→\n   229→  if (existingIndex >= 0) {\n   230→    store.permissions[existingIndex].role = role;\n   231→  } else {\n   232→    store.permissions.push({\n   233→      id: generateId(),\n   234→      resourceType,\n   235→      resourceId,\n   236→      userId: targetUserId,\n   237→      role,\n   238→    });\n   239→  }\n   240→\n   241→  addActivityLog(\n   242→    store,\n   243→    'resource_shared',\n   244→    userId,\n   245→    resourceType,\n   246→    resourceId,\n   247→    `Shared with user ${targetUserId} as ${role}`\n   248→  );\n   249→\n   250→  res.status(200).json({ message: 'Resource shared successfully', resourceType, resourceId, targetUserId, role });\n   251→}\n   252→"}]},"parent_tool_use_id":null,"session_id":"82bc402b-6f66-43eb-81aa-8fc76b5c168d","uuid":"f98fad2d-0b31-4437-959a-77849afc4036","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/routes/sharing.ts","content":"import { Router, Response } from 'express';\nimport { Store } from '../store.js';\nimport {\n  generateId,\n  authMiddleware,\n  AuthenticatedRequest,\n  hasPermission,\n  getEffectiveRole,\n  addActivityLog,\n} from '../helpers.js';\nimport { Role } from '../types.js';\n\nconst validRoles: Role[] = ['viewer', 'editor', 'owner'];\n\nexport function sharingRoutes(store: Store): Router {\n  const router = Router();\n  const auth = authMiddleware(store);\n\n  // Share a resource via POST /share\n  router.post('/share', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const { resourceType, resourceId, targetUserId, role } = req.body;\n\n    if (!resourceType || !resourceId || !targetUserId || !role) {\n      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });\n      return;\n    }\n\n    if (resourceType !== 'folder' && resourceType !== 'document') {\n      res.status(400).json({ error: 'resourceType must be \"folder\" or \"document\"' });\n      return;\n    }\n\n    if (!validRoles.includes(role)) {\n      res.status(400).json({ error: 'Role must be \"viewer\", \"editor\", or \"owner\"' });\n      return;\n    }\n\n    // Check resource exists\n    if (resourceType === 'folder' && !store.folders.has(resourceId)) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    if (resourceType === 'document' && !store.documents.has(resourceId)) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    // Check target user exists\n    if (!store.users.has(targetUserId)) {\n      res.status(404).json({ error: 'Target user not found' });\n      return;\n    }\n\n    // Check that sharer has at least editor permission (or owner for assigning owner role)\n    const requiredRole: Role = role === 'owner' ? 'owner' : 'editor';\n    if (!hasPermission(store, userId, resourceType, resourceId, requiredRole)) {\n      res.status(403).json({ error: 'Insufficient permissions to share this resource' });\n      return;\n    }\n\n    // Check if target already has a permission 