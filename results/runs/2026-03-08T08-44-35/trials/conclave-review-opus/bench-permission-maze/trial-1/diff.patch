tatus(200).json({ role });\n  });\n\n  return router;\n}\n\nfunction handleResourceShare(\n  store: Store,\n  req: AuthenticatedRequest,\n  res: Response,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): void {\n  const { userId } = req;\n  const { targetUserId, role } = req.body;\n\n  if (!targetUserId || !role) {\n    res.status(400).json({ error: 'targetUserId and role are required' });\n    return;\n  }\n\n  if (!validRoles.includes(role)) {\n    res.status(400).json({ error: 'Role must be \"viewer\", \"editor\", or \"owner\"' });\n    return;\n  }\n\n  // Check resource exists\n  if (resourceType === 'folder' && !store.folders.has(resourceId)) {\n    res.status(404).json({ error: 'Folder not found' });\n    return;\n  }\n  if (resourceType === 'document' && !store.documents.has(resourceId)) {\n    res.status(404).json({ error: 'Document not found' });\n    return;\n  }\n\n  // Check target user exists\n  if (!store.users.has(targetUserId)) {\n    res.status(404).json({ error: 'Target user not found' });\n    return;\n  }\n\n  // Check that sharer has sufficient permission\n  const requiredRole: Role = role === 'owner' ? 'owner' : 'editor';\n  if (!hasPermission(store, userId, resourceType, resourceId, requiredRole)) {\n    res.status(403).json({ error: 'Insufficient permissions to share this resource' });\n    return;\n  }\n\n  // Check if target already has a permission on this resource\n  const existingIndex = store.permissions.findIndex(\n    (p) =>\n      p.resourceType === resourceType &&\n      p.resourceId === resourceId &&\n      p.userId === targetUserId\n  );\n\n  if (existingIndex >= 0) {\n    store.permissions[existingIndex].role = role;\n  } else {\n    store.permissions.push({\n      id: generateId(),\n      resourceType,\n      resourceId,\n      userId: targetUserId,\n      role,\n    });\n  }\n\n  addActivityLog(\n    store,\n    'resource_shared',\n    userId,\n    resourceType,\n    resourceId,\n    `Shared with user ${target