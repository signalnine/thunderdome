 a document, also check permissions on its folder chain\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc) {\n      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);\n      if (folderRole) {\n        const level = roleHierarchy[folderRole];\n        if (level > bestLevel) {\n          bestLevel = level;\n          bestRole = folderRole;\n        }\n      }\n    }\n  }\n\n  // If the resource is a folder, also check parent folder chain\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.parentId) {\n      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n      if (parentRole) {\n        const level = roleHierarchy[parentRole];\n        if (level > bestLevel) {\n          bestLevel = level;\n          bestRole = parentRole;\n        }\n      }\n    }\n  }\n\n  return bestRole;\n}\n\nexport function hasPermission(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n  requiredRole: Role\n): boolean {\n  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);\n  if (!effectiveRole) return false;\n  return roleHierarchy[effectiveRole] >= roleHierarchy[requiredRole];\n}\n\nexport function addActivityLog(\n  store: Store,\n  action: string,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n  details?: string\n): void {\n  store.activityLog.push({\n    id: generateId(),\n    action,\n    userId,\n    resourceType,\n    resourceId,\n    timestamp: new Date().toISOString(),\n    details,\n  });\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":250,"cache_read_input_tokens":21378,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":250},"output_tokens":24,"service_tier":"standard","inference_geo":"not_avai