chain\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.parentId) {\n      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n      if (parentRole) {\n        const level = roleHierarchy[parentRole];\n        if (level > bestLevel) {\n          bestLevel = level;\n          bestRole = parentRole;\n        }\n      }\n    }\n  }\n\n  return bestRole;\n}\n\nexport function hasPermission(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n  requiredRole: Role\n): boolean {\n  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);\n  if (!effectiveRole) return false;\n  return roleHierarchy[effectiveRole] >= roleHierarchy[requiredRole];\n}\n\nexport function addActivityLog(\n  store: Store,\n  action: string,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n  details?: string\n): void {\n  store.activityLog.push({\n    id: generateId(),\n    action,\n    userId,\n    resourceType,\n    resourceId,\n    timestamp: new Date().toISOString(),\n    details,\n  });\n}\n","structuredPatch":[{"oldStart":43,"oldLines":8,"newStart":43,"newLines":13,"lines":["   store: Store,","   userId: string,","   resourceType: 'folder' | 'document',","-  resourceId: string","+  resourceId: string,","+  visited: Set<string> = new Set()"," ): Role | null {","+  const key = `${resourceType}:${resourceId}`;","+  if (visited.has(key)) return null; // cycle guard","+  visited.add(key);","+","   let bestRole: Role | null = null;","   let bestLevel = 0;"," "]},{"oldStart":67,"oldLines":7,"newStart":72,"newLines":7,"lines":["   if (resourceType === 'document') {","     const doc = store.documents.get(resourceId);","     if (doc) {","-      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);","+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId, visited