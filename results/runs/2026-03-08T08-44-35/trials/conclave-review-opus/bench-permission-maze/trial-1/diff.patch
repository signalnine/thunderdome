+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019oWnYm1X4JeQBJhPtHawdd","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store } from '../store.js';\n     3→import {\n     4→  generateId,\n     5→  authMiddleware,\n     6→  AuthenticatedRequest,\n     7→  hasPermission,\n     8→  addActivityLog,\n     9→} from '../helpers.js';\n    10→\n    11→export function folderRoutes(store: Store): Router {\n    12→  const router = Router();\n    13→  const auth = authMiddleware(store);\n    14→\n    15→  // Create folder\n    16→  router.post('/folders', auth, (req, res: Response): void => {\n    17→    const { userId } = req as AuthenticatedRequest;\n    18→    const { name, parentId } = req.body;\n    19→\n    20→    if (!name || typeof name !== 'string') {\n    21→      res.status(400).json({ error: 'Folder name is required' });\n    22→      return;\n    23→    }\n    24→\n    25→    // If parentId is specified, check it exists and user has permission\n    26→    if (parentId !== undefined && parentId !== null) {\n    27→      const parentFolder = store.folders.get(parentId);\n    28→      if (!parentFolder) {\n    29→        res.status(404).json({ error: 'Parent folder not found' });\n    30→        return;\n    31→      }\n    32→      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {\n    33→        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n    34→        return;\n    35→      }\n    36→    }\n    37→\n    38→    const id = generateId();\n    39→    const folder = {\n    40→      id,\n    41→      name,\n    42→      parentId: parentId || null,\n    43→      ownerId: userId,\n    44→      createdAt: new Date().toISOString(),\n    45→    };\n    46→\n    47→    store.folders.set(id, folder);\n    48→\n    49→    // Add owner permission\n    50→    store.permissions.push({\n    51→      id: generateId(),\n    52→      resourceType: 'folder',\n    53→      resourceId: id,\n    54→      userId,\n    55→      role: 'owner',\n    56→    });\n    57→\n    58→    addActivityLog(store, 'folder_created', userId, 'folder', id);\n    59→\n    60→    res.status(201).json(folder);\n    61→  });\n    62→\n    63→  // Get folder\n    64→  router.get('/folders/:id', auth, (req, res: Response): void => {\n    65→    const { userId } = req as AuthenticatedRequest;\n    66→    const folder = store.folders.get(req.params.id);\n    67→\n    68→    if (!folder) {\n    69→      res.status(404).json({ error: 'Folder not found' });\n    70→      return;\n    71→    }\n    72→\n    73→    if (!hasPermission(store, userId, 'folder', folder.id, 'viewer')) {\n    74→      res.status(403).json({ error: 'Insufficient permissions' });\n    75→      return;\n    76→    }\n    77→\n    78→    // Get child folders and documents\n    79→    const children: string[] = [];\n    80→    for (const f of store.folders.values()) {\n    81→      if (f.parentId === folder.id) {\n    82→        children.push(f.id);\n    83→      }\n    84→    }\n    85→\n    86→    const documents: string[] = [];\n    87→    for (const d of store.documents.values()) {\n    88→      if (d.folderId === folder.id) {\n    89→        documents.push(d.id);\n    90→      }\n    91→    }\n    92→\n    93→    res.status(200).json({ ...folder, children, documents });\n    94→  });\n    95→\n    96→  // Update folder\n    97→  router.put('/folders/:id', auth, (req, res: Response): void => {\n    98→    const { userId } = req as AuthenticatedRequest;\n    99→    const folder = store.folders.get(req.params.id);\n   100→\n   101→    if (!folder) {\n   102→      res.status(404).json({ error: 'Folder not found' });\n   103→      return;\n   104→    }\n   105→\n   106→    if (!hasPermission(store, userId, 'folder', folder.id, 'editor')) {\n   107→      res.status(403).json({ error: 'Insufficient permissions' });\n   108→      return;\n   109→    }\n   110→\n   111→    const { name, parentId } = req.body;\n   112→\n   113→    if (name !== undefined) {\n   114→      if (typeof name !== 'string' || !name) {\n   115→        res.status(400).json({ error: 'Folder name must be a non-empty string' });\n   116→        return;\n   117→      }\n   118→      folder.name = name;\n   119→    }\n   120→\n   121→    if (parentId !== undefined) {\n   122→      if (parentId !== null) {\n   123→        const parentFolder = store.folders.get(parentId);\n   124→        if (!parentFolder) {\n   125→          res.status(404).json({ error: 'Parent folder not found' });\n   126→          return;\n   127→        }\n   128→        // Prevent circular references\n   129→        if (parentId === folder.id) {\n   130→          res.status(400).json({ error: 'Folder cannot be its own parent' });\n   131→          return;\n   132→        }\n   133→      }\n   134→      folder.parentId = parentId;\n   135→    }\n   136→\n   137→    res.status(200).json(folder);\n   138→  });\n   139→\n   140→  // Delete folder\n   141→  router.delete('/folders/:id', auth, (req, res: Response): void => {\n   142→    const { userId } = req as AuthenticatedRequest;\n   143→    const folder = store.folders.get(req.params.id);\n   144→\n   145→    if (!folder) {\n   146→      res.status(404).json({ error: 'Folder not found' });\n   147→      return;\n   148→    }\n   149→\n   150→    if (!hasPermission(store, userId, 'folder', folder.id, 'owner')) {\n   151→      res.status(403).json({ error: 'Insufficient permissions' });\n   152→      return;\n   153→    }\n   154→\n   155→    // Delete the folder and its contents recursively\n   156→    deleteFolderRecursive(store, folder.id);\n   157→\n   158→    addActivityLog(store, 'folder_deleted', userId, 'folder', folder.id);\n   159→\n   160→    res.status(204).send();\n   161→  });\n   162→\n   163→  return router;\n   164→}\n   165→\n   166→function deleteFolderRecursive(store: Store, folderId: string): void {\n   167→  // Delete child folders\n   168→  for (const folder of store.folders.values()) {\n   169→    if (folder.parentId === folderId) {\n   170→      deleteFolderRecursive(store, folder.id);\n   171→    }\n   172→  }\n   173→\n   174→  // Delete documents in this folder\n   175→  for (const doc of store.documents.values()) {\n   176→    if (doc.folderId === folderId) {\n   177→      store.documents.delete(doc.id);\n   178→      store.permissions = store.permissions.filter(\n   179→        (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)\n   180→      );\n   181→    }\n   182→  }\n   183→\n   184→  // Delete the folder itself\n   185→  store.folders.delete(folderId);\n   186→  store.permissions = store.permissions.filter(\n   187→    (p) => !(p.resourceType === 'folder' && p.resourceId === folderId)\n   188→  );\n   189→}\n   190→"}]},"parent_tool_use_id":"toolu_01W9vCAExMUMstH23iHnPcGy","session_id":"82bc402b-6f66-43eb-81aa-8fc76b5c168d","uuid":"4430b20d-6c5e-4be8-82fc-ab3e1f5a6db7"}
