+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EssePWLxNRDVHz73apGQde","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store } from '../store.js';\n     3→import {\n     4→  generateId,\n     5→  authMiddleware,\n     6→  AuthenticatedRequest,\n     7→  hasPermission,\n     8→  getEffectiveRole,\n     9→  addActivityLog,\n    10→} from '../helpers.js';\n    11→import { Role } from '../types.js';\n    12→\n    13→const validRoles: Role[] = ['viewer', 'editor', 'owner'];\n    14→\n    15→export function sharingRoutes(store: Store): Router {\n    16→  const router = Router();\n    17→  const auth = authMiddleware(store);\n    18→\n    19→  // Share a resource via POST /share\n    20→  router.post('/share', auth, (req, res: Response): void => {\n    21→    const { userId } = req as AuthenticatedRequest;\n    22→    const { resourceType, resourceId, targetUserId, role } = req.body;\n    23→\n    24→    if (!resourceType || !resourceId || !targetUserId || !role) {\n    25→      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });\n    26→      return;\n    27→    }\n    28→\n    29→    if (resourceType !== 'folder' && resourceType !== 'document') {\n    30→      res.status(400).json({ error: 'resourceType must be \"folder\" or \"document\"' });\n    31→      return;\n    32→    }\n    33→\n    34→    if (!validRoles.includes(role)) {\n    35→      res.status(400).json({ error: 'Role must be \"viewer\", \"editor\", or \"owner\"' });\n    36→      return;\n    37→    }\n    38→\n    39→    // Check resource exists\n    40→    if (resourceType === 'folder' && !store.folders.has(resourceId)) {\n    41→      res.status(404).json({ error: 'Folder not found' });\n    42→      return;\n    43→    }\n    44→    if (resourceType === 'document' && !store.documents.has(resourceId)) {\n    45→      res.status(404).json({ error: 'Document not found' });\n    46→      return;\n    47→    }\n    48→\n    49→    // Check target user exists\n    50→    if (!store.users.has(targetUserId)) {\n    51→      res.status(404).json({ error: 'Target user not found' });\n    52→      return;\n    53→    }\n    54→\n    55→    // Check that sharer has at least editor permission (or owner for assigning owner role)\n    56→    const requiredRole: Role = role === 'owner' ? 'owner' : 'editor';\n    57→    if (!hasPermission(store, userId, resourceType, resourceId, requiredRole)) {\n    58→      res.status(403).json({ error: 'Insufficient permissions to share this resource' });\n    59→      return;\n    60→    }\n    61→\n    62→    // Check if target already has a permission on this resource\n    63→    const existingIndex = store.permissions.findIndex(\n    64→      (p) =>\n    65→        p.resourceType === resourceType &&\n    66→        p.resourceId === resourceId &&\n    67→        p.userId === targetUserId\n    68→    );\n    69→\n    70→    if (existingIndex >= 0) {\n    71→      // Update existing permission\n    72→      store.permissions[existingIndex].role = role;\n    73→    } else {\n    74→      // Add new permission\n    75→      store.permissions.push({\n    76→        id: generateId(),\n    77→        resourceType,\n    78→        resourceId,\n    79→        userId: targetUserId,\n    80→        role,\n    81→      });\n    82→    }\n    83→\n    84→    addActivityLog(\n    85→      store,\n    86→      'resource_shared',\n    87→      userId,\n    88→      resourceType,\n    89→      resourceId,\n    90→      `Shared with user ${targetUserId} as ${role}`\n    91→    );\n    92→\n    93→    res.status(200).json({ message: 'Resource shared successfully', resourceType, resourceId, targetUserId, role });\n    94→  });\n    95→\n    96→  // Share via resource-specific endpoint: POST /:resourceType/:id/share\n    97→  router.post('/folders/:id/share', auth, (req, res: Response): void => {\n    98→    handleResourceShare(store, req as AuthenticatedRequest, res, 'folder', req.params.id);\n    99→  });\n   100→\n   101→  router.post('/documents/:id/share', auth, (req, res: Response): void => {\n   102→    handleResourceShare(store, req as AuthenticatedRequest, res, 'document', req.params.id);\n   103→  });\n   104→\n   105→  // Get effective permissions for a resource\n   106→  router.get('/folders/:id/permissions', auth, (req, res: Response): void => {\n   107→    const { userId } = req as AuthenticatedRequest;\n   108→    const folderId = req.params.id;\n   109→\n   110→    if (!store.folders.has(folderId)) {\n   111→      res.status(404).json({ error: 'Folder not found' });\n   112→      return;\n   113→    }\n   114→\n   115→    if (!hasPermission(store, userId, 'folder', folderId, 'viewer')) {\n   116→      res.status(403).json({ error: 'Insufficient permissions' });\n   117→      return;\n   118→    }\n   119→\n   120→    const permissions = store.permissions.filter(\n   121→      (p) => p.resourceType === 'folder' && p.resourceId === folderId\n   122→    );\n   123→\n   124→    res.status(200).json(permissions);\n   125→  });\n   126→\n   127→  router.get('/documents/:id/permissions', auth, (req, res: Response): void => {\n   128→    const { userId } = req as AuthenticatedRequest;\n   129→    const docId = req.params.id;\n   130→\n   131→    if (!store.documents.has(docId)) {\n   132→      res.status(404).json({ error: 'Document not found' });\n   133→      return;\n   134→    }\n   135→\n   136→    if (!hasPermission(store, userId, 'document', docId, 'viewer')) {\n   137→      res.status(403).json({ error: 'Insufficient permissions' });\n   138→      return;\n   139→    }\n   140→\n   141→    const permissions = store.permissions.filter(\n   142→      (p) => p.resourceType === 'document' && p.resourceId === docId\n   143→    );\n   144→\n   145→    res.status(200).json(permissions);\n   146→  });\n   147→\n   148→  // Get effective role for a user on a resource\n   149→  router.get('/folders/:id/role', auth, (req, res: Response): void => {\n   150→    const { userId } = req as AuthenticatedRequest;\n   151→    const folderId = req.params.id;\n   152→\n   153→    if (!store.folders.has(folderId)) {\n   154→      res.status(404).json({ error: 'Folder not found' });\n   155→      return;\n   156→    }\n   157→\n   158→    const role = getEffectiveRole(store, userId, 'folder', folderId);\n   159→    res.status(200).json({ role });\n   160→  });\n   161→\n   162→  router.get('/documents/:id/role', auth, (req, res: Response): void => {\n   163→    const { userId } = req as AuthenticatedRequest;\n   164→    const docId = req.params.id;\n   165→\n   166→    if (!store.documents.has(docId)) {\n   167→      res.status(404).json({ error: 'Document not found' });\n   168→      return;\n   169→    }\n   170→\n   171→    const role = getEffectiveRole(store, userId, 'document', docId);\n   172→    res.status(200).json({ role });\n   173→  });\n   174→\n   175→  return router;\n   176→}\n   177→\n   178→function handleResourceShare(\n   179→  store: Store,\n   180→  req: AuthenticatedRequest,\n   181→  res: Response,\n   182→  resourceType: 'folder' | 'document',\n   183→  resourceId: string\n   184→): void {\n   185→  const { userId } = req;\n   186→  const { targetUserId, role } = req.body;\n   187→\n   188→  if (!targetUserId || !role) {\n   189→    res.status(400).json({ error: 'targetUserId and role are required' });\n   190→    return;\n   191→  }\n   192→\n   193→  if (!validRoles.includes(role)) {\n   194→    res.status(400).json({ error: 'Role must be \"viewer\", \"editor\", or \"owner\"' });\n   195→    return;\n   196→  }\n   197→\n   198→  // Check resource exists\n   199→  if (resourceType === 'folder' && !store.folders.has(resourceId)) {\n   200→    res.status(404).json({ error: 'Folder not found' });\n   201→    return;\n   202→  }\n   203→  if (resourceType === 'document' && !store.documents.has(resourceId)) {\n   204→    res.status(404).json({ error: 'Document not found' });\n   205→    return;\n   206→  }\n   207→\n   208→  // Check target user exists\n   209→  if (!store.users.has(targetUserId)) {\n   210→    res.status(404).json({ error: 'Target user not found' });\n   211→    return;\n   212→  }\n   213→\n   214→  // Check that sharer has sufficient permission\n   215→  const requiredRole: Role = role === 'owner' ? 'owner' : 'editor';\n   216→  if (!hasPermission(store, userId, resourceType, resourceId, requiredRole)) {\n   217→    res.status(403).json({ error: 'Insufficient permissions to share this resource' });\n   218→    return;\n   219→  }\n   220→\n   221→  // Check if target already has a permission on this resource\n   222→  const existingIndex = store.permissions.findIndex(\n   223→    (p) =>\n   224→      p.resourceType === resourceType &&\n   225→      p.resourceId === resourceId &&\n   226→      p.userId === targetUserId\n   227→  );\n   228→\n   229→  if (existingIndex >= 0) {\n   230→    store.permissions[existingIndex].role = role;\n   231→  } else {\n   232→    store.permissions.push({\n   233→      id: generateId(),\n   234→      resourceType,\n   235→      resourceId,\n   236→      userId: targetUserId,\n   237→      role,\n   238→    });\n   239→  }\n   240→\n   241→  addActivityLog(\n   242→    store,\n   243→    'resource_shared',\n   244→    userId,\n   245→    resourceType,\n   246→    resourceId,\n   247→    `Shared with user ${targetUserId} as ${role}`\n   248→  );\n   249→\n   250→  res.status(200).json({ message: 'Resource shared successfully', resourceType, resourceId, targetUserId, role });\n   251→}\n   252→"}]},"parent_tool_use_id":"toolu_01W9vCAExMUMstH23iHnPcGy","session_id":"82bc402b-6f66-43eb-81aa-8fc76b5c168d","uuid":"a7c111df-991f-4406-8a30-694894ed6321"}
