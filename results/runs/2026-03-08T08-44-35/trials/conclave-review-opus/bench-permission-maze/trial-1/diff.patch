 'string') {\n      res.status(400).json({ error: 'Document title is required' });\n      return;\n    }\n\n    if (content === undefined || content === null) {\n      res.status(400).json({ error: 'Document content is required' });\n      return;\n    }\n\n    if (!folderId || typeof folderId !== 'string') {\n      res.status(400).json({ error: 'Folder ID is required' });\n      return;\n    }\n\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions on folder' });\n      return;\n    }\n\n    const id = generateId();\n    const now = new Date().toISOString();\n    const doc = {\n      id,\n      title,\n      content: String(content),\n      folderId,\n      ownerId: userId,\n      createdAt: now,\n      updatedAt: now,\n    };\n\n    store.documents.set(id, doc);\n\n    // Add owner permission\n    store.permissions.push({\n      id: generateId(),\n      resourceType: 'document',\n      resourceId: id,\n      userId,\n      role: 'owner',\n    });\n\n    addActivityLog(store, 'document_created', userId, 'document', id);\n\n    res.status(201).json(doc);\n  });\n\n  // Also support POST /folders/:folderId/documents\n  router.post('/folders/:folderId/documents', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const { title, content } = req.body;\n    const folderId = req.params.folderId;\n\n    if (!title || typeof title !== 'string') {\n      res.status(400).json({ error: 'Document title is required' });\n      return;\n    }\n\n    if (content === undefined || content === null) {\n      res.status(400).json({ error: 'Document content is required' });\n      return;\n    }\n\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions on folder' });\n      return;\n    }\n\n    const id = generateId();\n    const now = new Date().toISOString();\n    const doc = {\n      id,\n      title,\n      content: String(content),\n      folderId,\n      ownerId: userId,\n      createdAt: now,\n      updatedAt: now,\n    };\n\n    store.documents.set(id, doc);\n\n    store.permissions.push({\n      id: generateId(),\n      resourceType: 'document',\n      resourceId: id,\n      userId,\n      role: 'owner',\n    });\n\n    addActivityLog(store, 'document_created', userId, 'document', id);\n\n    res.status(201).json(doc);\n  });\n\n  // Get document\n  router.get('/documents/:id', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'document', doc.id, 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    res.status(200).json(doc);\n  });\n\n  // Update document\n  router.put('/documents/:id', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'document', doc.id, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const { title, content } = req.body;\n\n    if (title !== undefined) {\n      if (typeof title !== 'string' || !title) {\n        res.status(400).json({ error: 'Title must be a non-empty string' });\n        return;\n      }\n      doc.title = title;\n  