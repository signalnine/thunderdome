     expect(res.status).toBe(200);\n      for (const entry of res.body) {\n        expect(entry.resourceType).toBe('document');\n      }\n    });\n\n    it('should include userId and action in log entries', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Folder' });\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.body.length).toBeGreaterThan(0);\n      const entry = res.body[0];\n      expect(entry.userId).toBeDefined();\n      expect(entry.action).toBeDefined();\n      expect(entry.resourceType).toBeDefined();\n      expect(entry.resourceId).toBe(folder.body.id);\n    });\n  });\n\n  // ==================== EDGE CASES ====================\n  describe('Edge Cases', () => {\n    it('should handle empty content string for documents', async () => {\n      const user = await createUser(app, 'alice', 'pass');\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${user.token}`)\n        .send({ name: 'Folder' });\n\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${user.token}`)\n        .send({ title: 'Empty Doc', content: '', folderId: folder.body.id });\n\n      expect(res.status).toBe(201);\n      expect(res.body.content).toBe('');\n    });\n\n    it('should allow creating documents in subfolders', async () => {\n      const user = await createUser(app, 'alice', 'pass');\n\n      const parent = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${user.token}`)\n        .send({ name: 'Parent' });\n\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${user.token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n\n      const doc = await request(app)\n        .post(