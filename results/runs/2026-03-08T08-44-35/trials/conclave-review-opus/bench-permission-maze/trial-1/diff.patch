return;\n      }\n      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {\n        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n        return;\n      }\n    }\n\n    const id = generateId();\n    const folder = {\n      id,\n      name,\n      parentId: parentId || null,\n      ownerId: userId,\n      createdAt: new Date().toISOString(),\n    };\n\n    store.folders.set(id, folder);\n\n    // Add owner permission\n    store.permissions.push({\n      id: generateId(),\n      resourceType: 'folder',\n      resourceId: id,\n      userId,\n      role: 'owner',\n    });\n\n    addActivityLog(store, 'folder_created', userId, 'folder', id);\n\n    res.status(201).json(folder);\n  });\n\n  // Get folder\n  router.get('/folders/:id', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folder.id, 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Get child folders and documents\n    const children: string[] = [];\n    for (const f of store.folders.values()) {\n      if (f.parentId === folder.id) {\n        children.push(f.id);\n      }\n    }\n\n    const documents: string[] = [];\n    for (const d of store.documents.values()) {\n      if (d.folderId === folder.id) {\n        documents.push(d.id);\n      }\n    }\n\n    res.status(200).json({ ...folder, children, documents });\n  });\n\n  // Update folder\n  router.put('/folders/:id', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folder.id, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const { name, parentId } = req.body;\n\n    if (name !== undefined) {\n      if (typeof name !== 'string' || !name) {\n        res.status(400).json({ error: 'Folder name must be a non-empty string' });\n        return;\n      }\n      folder.name = name;\n    }\n\n    if (parentId !== undefined) {\n      if (parentId !== null) {\n        const parentFolder = store.folders.get(parentId);\n        if (!parentFolder) {\n          res.status(404).json({ error: 'Parent folder not found' });\n          return;\n        }\n        // Prevent circular references\n        if (parentId === folder.id) {\n          res.status(400).json({ error: 'Folder cannot be its own parent' });\n          return;\n        }\n      }\n      folder.parentId = parentId;\n    }\n\n    res.status(200).json(folder);\n  });\n\n  // Delete folder\n  router.delete('/folders/:id', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folder.id, 'owner')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Delete the folder and its contents recursively\n    deleteFolderRecursive(store, folder.id);\n\n    addActivityLog(store, 'folder_deleted', userId, 'folder', folder.id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n\nfunction deleteFolderRecursive(store: Store, folderId: string): void {\n  // Delete child folders\n  for (const folder of store.folders.values()) {\n    if (folder.parentId === folderId) {\n      deleteFolderRecursive(store, folder.id);\n    }\n  }\n\n  // Delete documents in this folder\n  for (const doc of store.documents.values()) {\n    if (doc.folderId === folderId) {\n      store.documents.delete(doc.id);\n      store.permissions = store.permissions.filter(\n        (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)\n      );\n    }\n  }\n\n  // Delete the folder itself\n  store.folders.delete(folderId);\n  store.permissions = store.permissions.filter(\n    (p) => !(p.resourceType === 'folder' && p.resourceId === folderId)\n  );\n}\n","numLines":190,"startLine":1,"totalLines":190}}}
