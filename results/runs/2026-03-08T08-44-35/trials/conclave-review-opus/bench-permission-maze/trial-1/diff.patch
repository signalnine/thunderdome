+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VZyFB1Keeo7CjUBed1s2AE","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store } from '../store.js';\n     3→import {\n     4→  generateId,\n     5→  authMiddleware,\n     6→  AuthenticatedRequest,\n     7→  hasPermission,\n     8→  addActivityLog,\n     9→} from '../helpers.js';\n    10→\n    11→export function documentRoutes(store: Store): Router {\n    12→  const router = Router();\n    13→  const auth = authMiddleware(store);\n    14→\n    15→  // Create document\n    16→  router.post('/documents', auth, (req, res: Response): void => {\n    17→    const { userId } = req as AuthenticatedRequest;\n    18→    const { title, content, folderId } = req.body;\n    19→\n    20→    if (!title || typeof title !== 'string') {\n    21→      res.status(400).json({ error: 'Document title is required' });\n    22→      return;\n    23→    }\n    24→\n    25→    if (content === undefined || content === null) {\n    26→      res.status(400).json({ error: 'Document content is required' });\n    27→      return;\n    28→    }\n    29→\n    30→    if (!folderId || typeof folderId !== 'string') {\n    31→      res.status(400).json({ error: 'Folder ID is required' });\n    32→      return;\n    33→    }\n    34→\n    35→    const folder = store.folders.get(folderId);\n    36→    if (!folder) {\n    37→      res.status(404).json({ error: 'Folder not found' });\n    38→      return;\n    39→    }\n    40→\n    41→    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {\n    42→      res.status(403).json({ error: 'Insufficient permissions on folder' });\n    43→      return;\n    44→    }\n    45→\n    46→    const id = generateId();\n    47→    const now = new Date().toISOString();\n    48→    const doc = {\n    49→      id,\n    50→      title,\n    51→      content: String(content),\n    52→      folderId,\n    53→      ownerId: userId,\n    54→      createdAt: now,\n    55→      updatedAt: now,\n    56→    };\n    57→\n    58→    store.documents.set(id, doc);\n    59→\n    60→    // Add owner permission\n    61→    store.permissions.push({\n    62→      id: generateId(),\n    63→      resourceType: 'document',\n    64→      resourceId: id,\n    65→      userId,\n    66→      role: 'owner',\n    67→    });\n    68→\n    69→    addActivityLog(store, 'document_created', userId, 'document', id);\n    70→\n    71→    res.status(201).json(doc);\n    72→  });\n    73→\n    74→  // Also support POST /folders/:folderId/documents\n    75→  router.post('/folders/:folderId/documents', auth, (req, res: Response): void => {\n    76→    const { userId } = req as AuthenticatedRequest;\n    77→    const { title, content } = req.body;\n    78→    const folderId = req.params.folderId;\n    79→\n    80→    if (!title || typeof title !== 'string') {\n    81→      res.status(400).json({ error: 'Document title is required' });\n    82→      return;\n    83→    }\n    84→\n    85→    if (content === undefined || content === null) {\n    86→      res.status(400).json({ error: 'Document content is required' });\n    87→      return;\n    88→    }\n    89→\n    90→    const folder = store.folders.get(folderId);\n    91→    if (!folder) {\n    92→      res.status(404).json({ error: 'Folder not found' });\n    93→      return;\n    94→    }\n    95→\n    96→    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {\n    97→      res.status(403).json({ error: 'Insufficient permissions on folder' });\n    98→      return;\n    99→    }\n   100→\n   101→    const id = generateId();\n   102→    const now = new Date().toISOString();\n   103→    const doc = {\n   104→      id,\n   105→      title,\n   106→      content: String(content),\n   107→      folderId,\n   108→      ownerId: userId,\n   109→      createdAt: now,\n   110→      updatedAt: now,\n   111→    };\n   112→\n   113→    store.documents.set(id, doc);\n   114→\n   115→    store.permissions.push({\n   116→      id: generateId(),\n   117→      resourceType: 'document',\n   118→      resourceId: id,\n   119→      userId,\n   120→      role: 'owner',\n   121→    });\n   122→\n   123→    addActivityLog(store, 'document_created', userId, 'document', id);\n   124→\n   125→    res.status(201).json(doc);\n   126→  });\n   127→\n   128→  // Get document\n   129→  router.get('/documents/:id', auth, (req, res: Response): void => {\n   130→    const { userId } = req as AuthenticatedRequest;\n   131→    const doc = store.documents.get(req.params.id);\n   132→\n   133→    if (!doc) {\n   134→      res.status(404).json({ error: 'Document not found' });\n   135→      return;\n   136→    }\n   137→\n   138→    if (!hasPermission(store, userId, 'document', doc.id, 'viewer')) {\n   139→      res.status(403).json({ error: 'Insufficient permissions' });\n   140→      return;\n   141→    }\n   142→\n   143→    res.status(200).json(doc);\n   144→  });\n   145→\n   146→  // Update document\n   147→  router.put('/documents/:id', auth, (req, res: Response): void => {\n   148→    const { userId } = req as AuthenticatedRequest;\n   149→    const doc = store.documents.get(req.params.id);\n   150→\n   151→    if (!doc) {\n   152→      res.status(404).json({ error: 'Document not found' });\n   153→      return;\n   154→    }\n   155→\n   156→    if (!hasPermission(store, userId, 'document', doc.id, 'editor')) {\n   157→      res.status(403).json({ error: 'Insufficient permissions' });\n   158→      return;\n   159→    }\n   160→\n   161→    const { title, content } = req.body;\n   162→\n   163→    if (title !== undefined) {\n   164→      if (typeof title !== 'string' || !title) {\n   165→        res.status(400).json({ error: 'Title must be a non-empty string' });\n   166→        return;\n   167→      }\n   168→      doc.title = title;\n   169→    }\n   170→\n   171→    if (content !== undefined) {\n   172→      doc.content = String(content);\n   173→    }\n   174→\n   175→    doc.updatedAt = new Date().toISOString();\n   176→\n   177→    addActivityLog(store, 'document_updated', userId, 'document', doc.id);\n   178→\n   179→    res.status(200).json(doc);\n   180→  });\n   181→\n   182→  // Delete document\n   183→  router.delete('/documents/:id', auth, (req, res: Response): void => {\n   184→    const { userId } = req as AuthenticatedRequest;\n   185→    const doc = store.documents.get(req.params.id);\n   186→\n   187→    if (!doc) {\n   188→      res.status(404).json({ error: 'Document not found' });\n   189→      return;\n   190→    }\n   191→\n   192→    if (!hasPermission(store, userId, 'document', doc.id, 'owner')) {\n   193→      res.status(403).json({ error: 'Insufficient permissions' });\n   194→      return;\n   195→    }\n   196→\n   197→    store.documents.delete(doc.id);\n   198→    store.permissions = store.permissions.filter(\n   199→      (p) => !(p.resourceType === 'document' && p.resourceId === doc.id)\n   200→    );\n   201→\n   202→    addActivityLog(store, 'document_deleted', userId, 'document', doc.id);\n   203→\n   204→    res.status(204).send();\n   205→  });\n   206→\n   207→  return router;\n   208→}\n   209→"}]},"parent_tool_use_id":"toolu_01W9vCAExMUMstH23iHnPcGy","session_id":"82bc402b-6f66-43eb-81aa-8fc76b5c168d","uuid":"ae0139bd-0bb1-47dd-84e7-74ca18dde828"}
