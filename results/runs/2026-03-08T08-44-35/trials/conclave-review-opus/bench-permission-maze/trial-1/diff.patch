+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014tDc2cdkNR73QoPcXe3Kfj","type":"tool_result","content":"     1→import { Router, Request, Response } from 'express';\n     2→import { Store } from '../store.js';\n     3→import { generateId, generateToken } from '../helpers.js';\n     4→\n     5→export function authRoutes(store: Store): Router {\n     6→  const router = Router();\n     7→\n     8→  router.post('/auth/register', (req: Request, res: Response): void => {\n     9→    const { username, password } = req.body;\n    10→\n    11→    if (!username || !password) {\n    12→      res.status(400).json({ error: 'Username and password are required' });\n    13→      return;\n    14→    }\n    15→\n    16→    if (typeof username !== 'string' || typeof password !== 'string') {\n    17→      res.status(400).json({ error: 'Username and password must be strings' });\n    18→      return;\n    19→    }\n    20→\n    21→    // Check if username is taken\n    22→    for (const user of store.users.values()) {\n    23→      if (user.username === username) {\n    24→        res.status(409).json({ error: 'Username already exists' });\n    25→        return;\n    26→      }\n    27→    }\n    28→\n    29→    const id = generateId();\n    30→    const user = { id, username, password, token: null };\n    31→    store.users.set(id, user);\n    32→\n    33→    res.status(201).json({ id, username });\n    34→  });\n    35→\n    36→  router.post('/auth/login', (req: Request, res: Response): void => {\n    37→    const { username, password } = req.body;\n    38→\n    39→    if (!username || !password) {\n    40→      res.status(400).json({ error: 'Username and password are required' });\n    41→      return;\n    42→    }\n    43→\n    44→    let foundUser = null;\n    45→    for (const user of store.users.values()) {\n    46→      if (user.username === username) {\n    47→        foundUser = user;\n    48→        break;\n    49→      }\n    50→    }\n    51→\n    52→    if (!foundUser || foundUser.password !== password) {\n    53→      res.status(401).json({ error: 'Invalid credentials' });\n    54→      return;\n    55→    }\n    56→\n    57→    const token = generateToken();\n    58→    foundUser.token = token;\n    59→    store.tokenToUserId.set(token, foundUser.id);\n    60→\n    61→    res.status(200).json({ token, userId: foundUser.id });\n    62→  });\n    63→\n    64→  return router;\n    65→}\n    66→"}]},"parent_tool_use_id":"toolu_01W9vCAExMUMstH23iHnPcGy","session_id":"82bc402b-6f66-43eb-81aa-8fc76b5c168d","uuid":"33243ba4-fa9b-4dd2-8133-eb4189abf8d3"}
