', resourceType, resourceId, targetUserId, role });\n}\n\nexport function sharingRoutes(store: Store): Router {\n  const router = Router();\n  const auth = authMiddleware(store);\n\n  // Share a resource via POST /share\n  router.post('/share', auth, (req, res: Response): void => {\n    const { resourceType, resourceId } = req.body;\n\n    if (!resourceType || !resourceId) {\n      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });\n      return;\n    }\n\n    if (resourceType !== 'folder' && resourceType !== 'document') {\n      res.status(400).json({ error: 'resourceType must be \"folder\" or \"document\"' });\n      return;\n    }\n\n    handleResourceShare(store, req as AuthenticatedRequest, res, resourceType, resourceId);\n  });\n\n  // Share via resource-specific endpoint: POST /:resourceType/:id/share\n  router.post('/folders/:id/share', auth, (req, res: Response): void => {\n    handleResourceShare(store, req as AuthenticatedRequest, res, 'folder', req.params.id);\n  });\n\n  router.post('/documents/:id/share', auth, (req, res: Response): void => {\n    handleResourceShare(store, req as AuthenticatedRequest, res, 'document', req.params.id);\n  });\n\n  // Get effective permissions for a resource\n  router.get('/folders/:id/permissions', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const folderId = req.params.id;\n\n    if (!store.folders.has(folderId)) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folderId, 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const permissions = store.permissions.filter(\n      (p) => p.resourceType === 'folder' && p.resourceId === folderId\n    );\n\n    res.status(200).json(permissions);\n  });\n\n  router.get('/documents/:id/permissions', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const docId = req.params.id;\n\n    if (!store.documents.has(docId)) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'document', docId, 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const permissions = store.permissions.filter(\n      (p) => p.resourceType === 'document' && p.resourceId === docId\n    );\n\n    res.status(200).json(permissions);\n  });\n\n  // Get effective role for a user on a resource\n  router.get('/folders/:id/role', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const folderId = req.params.id;\n\n    if (!store.folders.has(folderId)) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    const role = getEffectiveRole(store, userId, 'folder', folderId);\n    res.status(200).json({ role });\n  });\n\n  router.get('/documents/:id/role', auth, (req, res: Response): void => {\n    const { userId } = req as AuthenticatedRequest;\n    const docId = req.params.id;\n\n    if (!store.documents.has(docId)) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    const role = getEffectiveRole(store, userId, 'document', docId);\n    res.status(200).json({ role });\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":12,"oldLines":16,"newStart":12,"newLines":90,"lines":[" "," const validRoles: Role[] = ['viewer', 'editor', 'owner'];"," ","+function handleResourceShare(","+  store: Store,","+  req: AuthenticatedRequest,","+  res: Response,","+  resourceType: 'folder' | 'document',","+  resourceId: string","+): void {","+  const { userId } = req;","+  const { targetUserId, role } = req.body;","+","+  if (!targetUserId || !role) {","+    res.status(400).json({ error: 'targetUserId and role are required' });","+    return;","+  }","+","+  if