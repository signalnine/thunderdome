+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hs5gYCa1EW2E3NRvBSLT4A","type":"tool_result","content":"     1→import crypto from 'node:crypto';\n     2→import { Request, Response, NextFunction } from 'express';\n     3→import { Store } from './store.js';\n     4→import { Role } from './types.js';\n     5→\n     6→export function generateId(): string {\n     7→  return crypto.randomUUID();\n     8→}\n     9→\n    10→export function generateToken(): string {\n    11→  return crypto.randomBytes(32).toString('hex');\n    12→}\n    13→\n    14→export function authMiddleware(store: Store) {\n    15→  return (req: Request, res: Response, next: NextFunction): void => {\n    16→    const authHeader = req.headers.authorization;\n    17→    if (!authHeader || !authHeader.startsWith('Bearer ')) {\n    18→      res.status(401).json({ error: 'Authentication required' });\n    19→      return;\n    20→    }\n    21→    const token = authHeader.slice(7);\n    22→    const userId = store.tokenToUserId.get(token);\n    23→    if (!userId) {\n    24→      res.status(401).json({ error: 'Invalid token' });\n    25→      return;\n    26→    }\n    27→    (req as AuthenticatedRequest).userId = userId;\n    28→    next();\n    29→  };\n    30→}\n    31→\n    32→export interface AuthenticatedRequest extends Request {\n    33→  userId: string;\n    34→}\n    35→\n    36→const roleHierarchy: Record<Role, number> = {\n    37→  viewer: 1,\n    38→  editor: 2,\n    39→  owner: 3,\n    40→};\n    41→\n    42→export function getEffectiveRole(\n    43→  store: Store,\n    44→  userId: string,\n    45→  resourceType: 'folder' | 'document',\n    46→  resourceId: string\n    47→): Role | null {\n    48→  let bestRole: Role | null = null;\n    49→  let bestLevel = 0;\n    50→\n    51→  // Check direct permissions on the resource\n    52→  for (const perm of store.permissions) {\n    53→    if (\n    54→      perm.resourceType === resourceType &&\n    55→      perm.resourceId === resourceId &&\n    56→      perm.userId === userId\n    57→    ) {\n    58→      const level = roleHierarchy[perm.role];\n    59→      if (level > bestLevel) {\n    60→        bestLevel = level;\n    61→        bestRole = perm.role;\n    62→      }\n    63→    }\n    64→  }\n    65→\n    66→  // If the resource is a document, also check permissions on its folder chain\n    67→  if (resourceType === 'document') {\n    68→    const doc = store.documents.get(resourceId);\n    69→    if (doc) {\n    70→      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);\n    71→      if (folderRole) {\n    72→        const level = roleHierarchy[folderRole];\n    73→        if (level > bestLevel) {\n    74→          bestLevel = level;\n    75→          bestRole = folderRole;\n    76→        }\n    77→      }\n    78→    }\n    79→  }\n    80→\n    81→  // If the resource is a folder, also check parent folder chain\n    82→  if (resourceType === 'folder') {\n    83→    const folder = store.folders.get(resourceId);\n    84→    if (folder && folder.parentId) {\n    85→      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n    86→      if (parentRole) {\n    87→        const level = roleHierarchy[parentRole];\n    88→        if (level > bestLevel) {\n    89→          bestLevel = level;\n    90→          bestRole = parentRole;\n    91→        }\n    92→      }\n    93→    }\n    94→  }\n    95→\n    96→  return bestRole;\n    97→}\n    98→\n    99→export function hasPermission(\n   100→  store: Store,\n   101→  userId: string,\n   102→  resourceType: 'folder' | 'document',\n   103→  resourceId: string,\n   104→  requiredRole: Role\n   105→): boolean {\n   106→  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);\n   107→  if (!effectiveRole) return false;\n   108→  return roleHierarchy[effectiveRole] >= roleHierarchy[requiredRole];\n   109→}\n   110→\n   111→export function addActivityLog(\n   112→  store: Store,\n   113→  action: string,\n   114→  userId: string,\n   115→  resourceType: 'folder' | 'document',\n   116→  resourceId: string,\n   117→  details?: string\n   118→): void {\n   119→  store.activityLog.push({\n   120→    id: generateId(),\n   121→    action,\n   122→    userId,\n   123→    resourceType,\n   124→    resourceId,\n   125→    timestamp: new Date().toISOString(),\n   126→    details,\n   127→  });\n   128→}\n   129→"}]},"parent_tool_use_id":"toolu_01W9vCAExMUMstH23iHnPcGy","session_id":"82bc402b-6f66-43eb-81aa-8fc76b5c168d","uuid":"a2b15b28-4354-4e3c-82d8-d8bae8f7f28e"}
