send({ username: 'alice', password: 'pass123' });\n\n      const res = await request(app)\n        .post('/auth/login')\n        .send({ username: 'alice', password: 'pass123' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n      expect(res.body.userId).toBeDefined();\n    });\n\n    it('should reject login with wrong password', async () => {\n      await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice', password: 'pass123' });\n\n      const res = await request(app)\n        .post('/auth/login')\n        .send({ username: 'alice', password: 'wrong' });\n\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject login with non-existent user', async () => {\n      const res = await request(app)\n        .post('/auth/login')\n        .send({ username: 'nobody', password: 'pass' });\n\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject unauthenticated requests', async () => {\n      const res = await request(app).get('/folders/some-id');\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject requests with invalid token', async () => {\n      const res = await request(app)\n        .get('/folders/some-id')\n        .set('Authorization', 'Bearer invalidtoken');\n      expect(res.status).toBe(401);\n    });\n  });\n\n  // Helper: register and login, return token and userId\n  async function createUser(appInst: Express, username: string, password: string) {\n    const reg = await request(appInst)\n      .post('/auth/register')\n      .send({ username, password });\n    const login = await request(appInst)\n      .post('/auth/login')\n      .send({ username, password });\n    return { token: login.body.token as string, userId: reg.body.id as string };\n  }\n\n  // ==================== FOLDERS ====================\n  describe('Folders', () => {\n    let token: string;\n    let userId: string;\n\n    beforeEach(async () => {\n      const user = await createUser(app, 'alice', 'pass');\n      token = user.token;\n      userId = user.userId;\n    });\n\n    it('should create a folder', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'My Folder' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('My Folder');\n      expect(res.body.id).toBeDefined();\n      expect(res.body.parentId).toBeNull();\n      expect(res.body.ownerId).toBe(userId);\n    });\n\n    it('should get a folder', async () => {\n      const create = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'My Folder' });\n\n      const res = await request(app)\n        .get(`/folders/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('My Folder');\n      expect(res.body.children).toEqual([]);\n      expect(res.body.documents).toEqual([]);\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .get('/folders/nonexistent')\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should create nested folders', async () => {\n      const parent = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Parent' });\n\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n\n      expect(child.status).toBe(201);\n      expect(child.body.parentId).toBe(parent.body.id);\n\n      // Parent should list child\n      const parentGet = await request(app)\n        .get(`/folders/${parent.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(parentGet.body.children).toContain(child.body.id);\n    });\n\n    it('should update a folder', async () => {\n      const create = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Old Name' });\n\n      const res = await request(app)\n        .put(`/folders/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'New Name' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('New Name');\n    });\n\n    it('should delete a folder', async () => {\n      const create = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'To Delete' });\n\n      const res = await request(app)\n        .delete(`/folders/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(res.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/folders/${create.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(get.status).toBe(404);\n    });\n\n    it('should delete folder recursively with children and documents', async () => {\n      const parent = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Parent' });\n\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n\n      const doc = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'text', folderId: child.body.id });\n\n      // Delete parent\n      await request(app)\n        .delete(`/folders/${parent.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      // Child and doc should be gone\n      const childGet = await request(app)\n        .get(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(childGet.status).toBe(404);\n\n      const docGet = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(docGet.status).toBe(404);\n    });\n\n    it('should reject creating folder with non-existent parent', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Orphan', parentId: 'nonexistent' });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject creating folder without name', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({});\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  // ==================== DOCUMENTS ====================\n  describe('Documents', () => {\n    let token: string;\n    let folderId: string;\n\n    beforeEach(async () => {\n      const user = await createUser(app, 'alice', 'pass');\n      token = user.token;\n\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Docs Folder' });\n      folderId = folder.body.id;\n    });\n\n    it('should create a document', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Hello world', folderId });\n\n      expect(res.status).toBe(201);\n      expect(res.body.title).toBe('My Doc');\n      expect(res.body.content).toBe('Hello world');\n      expect(res.body.folderId).toBe(folderId);\n    });\n\n    it('should create a document via folder endpoint', async () => {\n      const res = await request(app)\n        .post(`/folders/${folderId}/documents`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'My Doc', content: 'Hello' });\n\n      expect(