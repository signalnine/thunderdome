+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QgjTc8FNpgiE3ZbFLBdrmc","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { AuthenticatedRequest, requireAuth } from \"../auth.js\";\n     4→\n     5→export function createQueryRoutes(db: Database.Database): Router {\n     6→  const router = Router();\n     7→\n     8→  // Count query\n     9→  router.post(\"/count\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    10→    const { eventName, startDate, endDate, filters } = req.body;\n    11→    const tenantId = req.user!.tenantId;\n    12→\n    13→    let sql = \"SELECT COUNT(*) as count FROM events WHERE tenant_id = ?\";\n    14→    const params: unknown[] = [tenantId];\n    15→\n    16→    if (eventName) {\n    17→      sql += \" AND name = ?\";\n    18→      params.push(eventName);\n    19→    }\n    20→\n    21→    if (startDate) {\n    22→      sql += \" AND timestamp >= ?\";\n    23→      params.push(startDate);\n    24→    }\n    25→\n    26→    if (endDate) {\n    27→      sql += \" AND timestamp <= ?\";\n    28→      params.push(endDate);\n    29→    }\n    30→\n    31→    if (filters && typeof filters === \"object\") {\n    32→      for (const [key, value] of Object.entries(filters)) {\n    33→        sql += \" AND json_extract(properties, ?) = ?\";\n    34→        params.push(`$.${key}`, value as string);\n    35→      }\n    36→    }\n    37→\n    38→    const result = db.prepare(sql).get(...params) as { count: number };\n    39→    res.json({ count: result.count });\n    40→  });\n    41→\n    42→  // Timeseries query\n    43→  router.post(\"/timeseries\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    44→    const { eventName, startDate, endDate, interval, filters } = req.body;\n    45→    const tenantId = req.user!.tenantId;\n    46→\n    47→    const bucket = interval || \"day\";\n    48→    let dateFormat: string;\n    49→\n    50→    switch (bucket) {\n    51→      case \"hour\":\n    52→        dateFormat = \"%Y-%m-%dT%H:00:00\";\n    53→        break;\n    54→      case \"month\":\n    55→        dateFormat = \"%Y-%m-01\";\n    56→        break;\n    57→      case \"day\":\n    58→      default:\n    59→        dateFormat = \"%Y-%m-%d\";\n    60→        break;\n    61→    }\n    62→\n    63→    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    64→    const params: unknown[] = [tenantId];\n    65→\n    66→    if (eventName) {\n    67→      sql += \" AND name = ?\";\n    68→      params.push(eventName);\n    69→    }\n    70→\n    71→    if (startDate) {\n    72→      sql += \" AND timestamp >= ?\";\n    73→      params.push(startDate);\n    74→    }\n    75→\n    76→    if (endDate) {\n    77→      sql += \" AND timestamp <= ?\";\n    78→      params.push(endDate);\n    79→    }\n    80→\n    81→    if (filters && typeof filters === \"object\") {\n    82→      for (const [key, value] of Object.entries(filters)) {\n    83→        sql += \" AND json_extract(properties, ?) = ?\";\n    84→        params.push(`$.${key}`, value as string);\n    85→      }\n    86→    }\n    87→\n    88→    sql += \" GROUP BY bucket ORDER BY bucket ASC\";\n    89→\n    90→    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;\n    91→    res.json({ interval: bucket, data: results });\n    92→  });\n    93→\n    94→  // Breakdown query\n    95→  router.post(\"/breakdown\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    96→    const { eventName, property, startDate, endDate, filters } = req.body;\n    97→    const tenantId = req.user!.tenantId;\n    98→\n    99→    if (!property) {\n   100→      res.status(400).json({ error: \"property is required for breakdown queries\" });\n   101→      return;\n   102→    }\n   103→\n   104→    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n   105→    const params: unknown[] = [`$.${property}`, tenantId];\n   106→\n   107→    if (eventName) {\n   108→      sql += \" AND name = ?\";\n   109→      params.push(eventName);\n   110→    }\n   111→\n   112→    if (startDate) {\n   113→      sql += \" AND timestamp >= ?\";\n   114→      params.push(startDate);\n   115→    }\n   116→\n   117→    if (endDate) {\n   118→      sql += \" AND timestamp <= ?\";\n   119→      params.push(endDate);\n   120→    }\n   121→\n   122→    if (filters && typeof filters === \"object\") {\n   123→      for (const [key, value] of Object.entries(filters)) {\n   124→        sql += \" AND json_extract(properties, ?) = ?\";\n   125→        params.push(`$.${key}`, value as string);\n   126→      }\n   127→    }\n   128→\n   129→    sql += \" GROUP BY value ORDER BY count DESC\";\n   130→\n   131→    const results = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;\n   132→    res.json({ property, data: results });\n   133→  });\n   134→\n   135→  return router;\n   136→}\n   137→"}]},"parent_tool_use_id":"toolu_01PWP8W5NgVoxRE88RA9PKhn","session_id":"7ff406d4-ecc1-4747-a791-3551abfa274d","uuid":"e1a957bd-4170-4152-919a-fc68e50d7415"}
