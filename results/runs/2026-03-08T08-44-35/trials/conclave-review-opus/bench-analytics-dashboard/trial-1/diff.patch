+++ b/src/routes/export.ts
@@ -0,0 +1,141 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, requireAuth } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function escapeCsvField(value: string): string {
+  if (value.includes('"') || value.includes(",") || value.includes("\n")) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) => {
+    return [
+      escapeCsvField(e.id),
+      escapeCsvField(e.name),
+      escapeCsvField(e.properties),
+      escapeCsvField(e.timestamp),
+      escapeCsvField(e.user_id || ""),
+      escapeCsvField(e.session_id || ""),
+    ].join(",");
+  });
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const header = "id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map((d) => {
+    return [
+      escapeCsvField(d.id),
+      escapeCsvField(d.name),
+      escapeCsvField(d.owner_id),
+      escapeCsvField(d.config),
+      escapeCsvField(d.created_at),
+      escapeCsvField(d.updated_at),
+    ].join(",");
+  });
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events
+  router.get("/events", requireAuth, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const format = (req.query.format as string) || "json";
+    const eventName = req.query.eventName as string | undefined;
+    const startDate = req.query.startDate as string | undefined;
+    const endDate = req.query.endDate as string | undefined;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    if (format === "csv") {
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+      res.send(eventsToCsv(events));
+    } else {
+      res.json(
+        events.map((e) => ({
+          id: e.id,
+          name: e.name,
+          properties: JSON.parse(e.properties),
+          timestamp: e.timestamp,
+          userId: e.user_id,
+          sessionId: e.session_id,
+        }))
+      );
+    }
+  });
+
+  // Export dashboards
+  router.get("/dashboards", requireAuth, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const format = (req.query.format as string) || "json";
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    if (format === "csv") {
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+      res.send(dashboardsToCsv(dashboards));
+    } else {
+      res.json(
+        dashboards.map((d) => ({
+          id: d.id,
+          name: d.name,
+          ownerId: d.owner_id,
+          config: JSON.parse(d.config),
+          createdAt: d.created_at,
+          updatedAt: d.updated_at,
+        }))
+      );
+    }
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..80774b7
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,128 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, requireAuth } from "../auth.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", requireAuth, (req: AuthenticatedRequest, res: Response): void => {
+    const { eventName, startDate, endDate, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", requireAuth, (req: AuthenticatedRequest, res: Response): void => {
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    const bucket = interval || "day";
+    const FORMAT_MAP: Record<string, string> = {
+      hour: "%Y-%m-%dT%H:00:00",
+      day: "%Y-%m-%d",
+      month: "%Y-%m-01",
+    };
+    const dateFormat = FORMAT_MAP[bucket] || FORMAT_MAP["day"];
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY bucket ORDER BY bucket ASC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ interval: bucket, data: results });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", requireAuth, (req: AuthenticatedRequest, res: Response): void => {
+    const { eventName, property, startDate, endDate, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: "property is required for breakdown queries" });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === "object") {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += " AND json_extract(properties, ?) = ?";
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += " GROUP BY value ORDER BY count DESC";
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;
+    res.json({ property, data: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..be21dd1
--- /dev/null
+++ b/src/routes/users.ts
@@ -0,0 +1,136 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { createHash } from "crypto";
+import { v4 as uuidv4 } from "uuid";
+import { AuthenticatedRequest, requireAuth, requireRole, signToken } from "../auth.js";
+
+function hashPassword(password: string): string {
+  return createHash("sha256").update(password).digest("hex");
+}
+
+export function createUserRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Register
+  router.post("/register", (req: AuthenticatedRequest, res: Response): void => {
+    const { email, password, tenantId, role } = req.body;
+
+    if (!email || !password || !tenantId) {
+      res.status(400).json({ error: "email, password, and tenantId are required" });
+      return;
+    }
+
+    const existing = db.prepare("SELECT id FROM users WHERE email = ?").get(email);
+    if (existing) {
+      res.status(409).json({ error: "Email already registered" });
+      return;
+    }
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+    const userRole = role && ["admin", "viewer", "editor"].includes(role) ? role : "viewer";
+
+    db.prepare(
+      "INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, email, passwordHash, tenantId, userRole);
+
+    const token = signToken({ userId: id, tenantId, role: userRole });
+
+    res.status(201).json({
+      id,
+      email,
+      tenantId,
+      role: userRole,
+      token,
+    });
+  });
+
+  // Login
+  router.post("/login", (req: AuthenticatedRequest, res: Response): void => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: "email and password are required" });
+      return;
+    }
+
+    const user = db
+      .prepare("SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?")
+      .get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;
+
+    if (!user || user.password_hash !== hashPassword(password)) {
+      res.status(401).json({ error: "Invalid credentials" });
+      return;
+    }
+
+    const token = signToken({
+      userId: user.id,
+      tenantId: user.tenant_id,
+      role: user.role,
+    });
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      token,
+    });
+  });
+
+  // Get profile
+  router.get("/me", requireAuth, (req: AuthenticatedRequest, res: Response): void => {
+    const user = db
+      .prepare("SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?")
+      .get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: "User not found" });
+      return;
+    }
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      createdAt: user.created_at,
+    });
+  });
+
+  // Change user role (admin only)
+  router.put(
+    "/:userId/role",
+    requireAuth,
+    requireRole("admin"),
+    (req: AuthenticatedRequest, res: Response): void => {
+      const { userId } = req.params;
+      const { role } = req.body;
+
+      if (!role || !["admin", "viewer", "editor"].includes(role)) {
+        res.status(400).json({ error: "Valid role is required (admin, viewer, editor)" });
+        return;
+      }
+
+      const target = db
+        .prepare("SELECT id, tenant_id FROM users WHERE id = ?")
+        .get(userId) as { id: string; tenant_id: string } | undefined;
+
+      if (!target) {
+        res.status(404).json({ error: "User not found" });
+        return;
+      }
+
+      if (target.tenant_id !== req.user!.tenantId) {
+        res.status(403).json({ error: "Cannot modify users from other tenants" });
+        return;
+      }
+
+      db.prepare("UPDATE users SET role = ? WHERE id = ?").run(role, userId);
+
+      res.json({ id: userId, role });
+    }
+  );
+
+  return router;
+}
