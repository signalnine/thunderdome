+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ee5dPU9fzchLv9YY7iMhhc","type":"tool_result","content":"     1→import { Request, Response, NextFunction } from \"express\";\n     2→import jwt from \"jsonwebtoken\";\n     3→\n     4→const JWT_SECRET = process.env.JWT_SECRET || \"analytics-dashboard-secret\";\n     5→\n     6→export interface AuthPayload {\n     7→  userId: string;\n     8→  tenantId: string;\n     9→  role: string;\n    10→}\n    11→\n    12→export interface AuthenticatedRequest extends Request {\n    13→  user?: AuthPayload;\n    14→}\n    15→\n    16→export function signToken(payload: AuthPayload): string {\n    17→  return jwt.sign(payload, JWT_SECRET, { expiresIn: \"24h\" });\n    18→}\n    19→\n    20→export function verifyToken(token: string): AuthPayload {\n    21→  return jwt.verify(token, JWT_SECRET) as AuthPayload;\n    22→}\n    23→\n    24→export function requireAuth(\n    25→  req: AuthenticatedRequest,\n    26→  res: Response,\n    27→  next: NextFunction\n    28→): void {\n    29→  const header = req.headers.authorization;\n    30→  if (!header || !header.startsWith(\"Bearer \")) {\n    31→    res.status(401).json({ error: \"Authentication required\" });\n    32→    return;\n    33→  }\n    34→\n    35→  const token = header.slice(7);\n    36→  try {\n    37→    req.user = verifyToken(token);\n    38→    next();\n    39→  } catch {\n    40→    res.status(401).json({ error: \"Invalid or expired token\" });\n    41→  }\n    42→}\n    43→\n    44→export function requireRole(...roles: string[]) {\n    45→  return (req: AuthenticatedRequest, res: Response, next: NextFunction): void => {\n    46→    if (!req.user) {\n    47→      res.status(401).json({ error: \"Authentication required\" });\n    48→      return;\n    49→    }\n    50→    if (!roles.includes(req.user.role)) {\n    51→      res.status(403).json({ error: \"Insufficient permissions\" });\n    52→      return;\n    53→    }\n    54→    next();\n    55→  };\n    56→}\n    57→"}]},"parent_tool_use_id":"toolu_01PWP8W5NgVoxRE88RA9PKhn","session_id":"7ff406d4-ecc1-4747-a791-3551abfa274d","uuid":"7aea8e5d-f03c-4d65-b47e-675d1833d514"}
