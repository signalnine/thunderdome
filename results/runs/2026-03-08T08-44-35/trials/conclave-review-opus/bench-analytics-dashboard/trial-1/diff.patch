+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G4BBe3DD3fwyXBZbLzfds7","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { createHash } from \"crypto\";\n     4→import { v4 as uuidv4 } from \"uuid\";\n     5→import { AuthenticatedRequest, requireAuth, requireRole, signToken } from \"../auth.js\";\n     6→\n     7→function hashPassword(password: string): string {\n     8→  return createHash(\"sha256\").update(password).digest(\"hex\");\n     9→}\n    10→\n    11→export function createUserRoutes(db: Database.Database): Router {\n    12→  const router = Router();\n    13→\n    14→  // Register\n    15→  router.post(\"/register\", (req: AuthenticatedRequest, res: Response): void => {\n    16→    const { email, password, tenantId, role } = req.body;\n    17→\n    18→    if (!email || !password || !tenantId) {\n    19→      res.status(400).json({ error: \"email, password, and tenantId are required\" });\n    20→      return;\n    21→    }\n    22→\n    23→    const existing = db.prepare(\"SELECT id FROM users WHERE email = ?\").get(email);\n    24→    if (existing) {\n    25→      res.status(409).json({ error: \"Email already registered\" });\n    26→      return;\n    27→    }\n    28→\n    29→    const id = uuidv4();\n    30→    const passwordHash = hashPassword(password);\n    31→    const userRole = role && [\"admin\", \"viewer\", \"editor\"].includes(role) ? role : \"viewer\";\n    32→\n    33→    db.prepare(\n    34→      \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n    35→    ).run(id, email, passwordHash, tenantId, userRole);\n    36→\n    37→    const token = signToken({ userId: id, tenantId, role: userRole });\n    38→\n    39→    res.status(201).json({\n    40→      id,\n    41→      email,\n    42→      tenantId,\n    43→      role: userRole,\n    44→      token,\n    45→    });\n    46→  });\n    47→\n    48→  // Login\n    49→  router.post(\"/login\", (req: AuthenticatedRequest, res: Response): void => {\n    50→    const { email, password } = req.body;\n    51→\n    52→    if (!email || !password) {\n    53→      res.status(400).json({ error: \"email and password are required\" });\n    54→      return;\n    55→    }\n    56→\n    57→    const user = db\n    58→      .prepare(\"SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?\")\n    59→      .get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;\n    60→\n    61→    if (!user || user.password_hash !== hashPassword(password)) {\n    62→      res.status(401).json({ error: \"Invalid credentials\" });\n    63→      return;\n    64→    }\n    65→\n    66→    const token = signToken({\n    67→      userId: user.id,\n    68→      tenantId: user.tenant_id,\n    69→      role: user.role,\n    70→    });\n    71→\n    72→    res.json({\n    73→      id: user.id,\n    74→      email: user.email,\n    75→      tenantId: user.tenant_id,\n    76→      role: user.role,\n    77→      token,\n    78→    });\n    79→  });\n    80→\n    81→  // Get profile\n    82→  router.get(\"/me\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    83→    const user = db\n    84→      .prepare(\"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\")\n    85→      .get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;\n    86→\n    87→    if (!user) {\n    88→      res.status(404).json({ error: \"User not found\" });\n    89→      return;\n    90→    }\n    91→\n    92→    res.json({\n    93→      id: user.id,\n    94→      email: user.email,\n    95→      tenantId: user.tenant_id,\n    96→      role: user.role,\n    97→      createdAt: user.created_at,\n    98→    });\n    99→  });\n   100→\n   101→  // Change user role (admin only)\n   102→  router.put(\n   103→    \"/:userId/role\",\n   104→    requireAuth,\n   105→    requireRole(\"admin\"),\n   106→    (req: AuthenticatedRequest, res: Response): void => {\n   107→      const { userId } = req.params;\n   108→      const { role } = req.body;\n   109→\n   110→      if (!role || ![\"admin\", \"viewer\", \"editor\"].includes(role)) {\n   111→        res.status(400).json({ error: \"Valid role is required (admin, viewer, editor)\" });\n   112→        return;\n   113→      }\n   114→\n   115→      const target = db\n   116→        .prepare(\"SELECT id, tenant_id FROM users WHERE id = ?\")\n   117→        .get(userId) as { id: string; tenant_id: string } | undefined;\n   118→\n   119→      if (!target) {\n   120→        res.status(404).json({ error: \"User not found\" });\n   121→        return;\n   122→      }\n   123→\n   124→      if (target.tenant_id !== req.user!.tenantId) {\n   125→        res.status(403).json({ error: \"Cannot modify users from other tenants\" });\n   126→        return;\n   127→      }\n   128→\n   129→      db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, userId);\n   130→\n   131→      res.json({ id: userId, role });\n   132→    }\n   133→  );\n   134→\n   135→  return router;\n   136→}\n   137→"}]},"parent_tool_use_id":"toolu_01PWP8W5NgVoxRE88RA9PKhn","session_id":"7ff406d4-ecc1-4747-a791-3551abfa274d","uuid":"f2ba191a-0254-445f-8f59-248e7620f5a4"}
