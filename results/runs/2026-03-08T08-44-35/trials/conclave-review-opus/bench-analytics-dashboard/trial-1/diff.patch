+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NS4rTjTf3FDYQa8mvb5GuS","type":"tool_result","content":"     1→-- Multi-tenant analytics dashboard schema\n     2→CREATE TABLE IF NOT EXISTS users (\n     3→  id TEXT PRIMARY KEY,\n     4→  email TEXT NOT NULL UNIQUE,\n     5→  password_hash TEXT NOT NULL,\n     6→  tenant_id TEXT NOT NULL,\n     7→  role TEXT NOT NULL DEFAULT 'viewer' CHECK(role IN ('admin', 'viewer', 'editor')),\n     8→  created_at TEXT NOT NULL DEFAULT (datetime('now'))\n     9→);\n    10→\n    11→CREATE TABLE IF NOT EXISTS events (\n    12→  id TEXT PRIMARY KEY,\n    13→  tenant_id TEXT NOT NULL,\n    14→  name TEXT NOT NULL,\n    15→  properties TEXT NOT NULL DEFAULT '{}',\n    16→  timestamp TEXT NOT NULL DEFAULT (datetime('now')),\n    17→  user_id TEXT,\n    18→  session_id TEXT\n    19→);\n    20→\n    21→CREATE TABLE IF NOT EXISTS dashboards (\n    22→  id TEXT PRIMARY KEY,\n    23→  tenant_id TEXT NOT NULL,\n    24→  name TEXT NOT NULL,\n    25→  owner_id TEXT NOT NULL,\n    26→  config TEXT NOT NULL DEFAULT '{}',\n    27→  created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    28→  updated_at TEXT NOT NULL DEFAULT (datetime('now')),\n    29→  FOREIGN KEY (owner_id) REFERENCES users(id)\n    30→);\n    31→\n    32→CREATE TABLE IF NOT EXISTS widgets (\n    33→  id TEXT PRIMARY KEY,\n    34→  dashboard_id TEXT NOT NULL,\n    35→  type TEXT NOT NULL CHECK(type IN ('counter', 'timeseries', 'breakdown', 'funnel')),\n    36→  config TEXT NOT NULL DEFAULT '{}',\n    37→  position_x INTEGER NOT NULL DEFAULT 0,\n    38→  position_y INTEGER NOT NULL DEFAULT 0,\n    39→  width INTEGER NOT NULL DEFAULT 1,\n    40→  height INTEGER NOT NULL DEFAULT 1,\n    41→  FOREIGN KEY (dashboard_id) REFERENCES dashboards(id) ON DELETE CASCADE\n    42→);\n    43→\n    44→CREATE INDEX IF NOT EXISTS idx_events_tenant ON events(tenant_id);\n    45→CREATE INDEX IF NOT EXISTS idx_events_name ON events(name);\n    46→CREATE INDEX IF NOT EXISTS idx_events_timestamp ON events(timestamp);\n    47→CREATE INDEX IF NOT EXISTS idx_dashboards_tenant ON dashboards(tenant_id);\n    48→CREATE INDEX IF NOT EXISTS idx_users_tenant ON users(tenant_id);\n    49→"}]},"parent_tool_use_id":"toolu_01PWP8W5NgVoxRE88RA9PKhn","session_id":"7ff406d4-ecc1-4747-a791-3551abfa274d","uuid":"20fcfd97-1a37-4996-9af7-dc5ff7a85e2e"}
