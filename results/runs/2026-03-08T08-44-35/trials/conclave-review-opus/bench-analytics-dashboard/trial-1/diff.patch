+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015fxCVfaN7XnHocJuiXGZgC","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { v4 as uuidv4 } from \"uuid\";\n     4→import { AuthenticatedRequest, requireAuth } from \"../auth.js\";\n     5→\n     6→interface DashboardRow {\n     7→  id: string;\n     8→  tenant_id: string;\n     9→  name: string;\n    10→  owner_id: string;\n    11→  config: string;\n    12→  created_at: string;\n    13→  updated_at: string;\n    14→}\n    15→\n    16→export function createDashboardRoutes(db: Database.Database): Router {\n    17→  const router = Router();\n    18→\n    19→  // Create dashboard\n    20→  router.post(\"/\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    21→    const { name, config } = req.body;\n    22→\n    23→    if (!name) {\n    24→      res.status(400).json({ error: \"Dashboard name is required\" });\n    25→      return;\n    26→    }\n    27→\n    28→    const id = uuidv4();\n    29→    const tenantId = req.user!.tenantId;\n    30→    const ownerId = req.user!.userId;\n    31→    const dashConfig = JSON.stringify(config || {});\n    32→    const now = new Date().toISOString();\n    33→\n    34→    db.prepare(\n    35→      \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    36→    ).run(id, tenantId, name, ownerId, dashConfig, now, now);\n    37→\n    38→    res.status(201).json({\n    39→      id,\n    40→      tenantId,\n    41→      name,\n    42→      ownerId,\n    43→      config: config || {},\n    44→      createdAt: now,\n    45→      updatedAt: now,\n    46→    });\n    47→  });\n    48→\n    49→  // List dashboards for tenant\n    50→  router.get(\"/\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    51→    const tenantId = req.user!.tenantId;\n    52→\n    53→    const dashboards = db\n    54→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n    55→      .all(tenantId) as DashboardRow[];\n    56→\n    57→    res.json(\n    58→      dashboards.map((d) => ({\n    59→        id: d.id,\n    60→        tenantId: d.tenant_id,\n    61→        name: d.name,\n    62→        ownerId: d.owner_id,\n    63→        config: JSON.parse(d.config),\n    64→        createdAt: d.created_at,\n    65→        updatedAt: d.updated_at,\n    66→      }))\n    67→    );\n    68→  });\n    69→\n    70→  // Get dashboard by ID\n    71→  router.get(\"/:id\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    72→    const tenantId = req.user!.tenantId;\n    73→    const { id } = req.params;\n    74→\n    75→    const dashboard = db\n    76→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    77→      .get(id, tenantId) as DashboardRow | undefined;\n    78→\n    79→    if (!dashboard) {\n    80→      res.status(404).json({ error: \"Dashboard not found\" });\n    81→      return;\n    82→    }\n    83→\n    84→    res.json({\n    85→      id: dashboard.id,\n    86→      tenantId: dashboard.tenant_id,\n    87→      name: dashboard.name,\n    88→      ownerId: dashboard.owner_id,\n    89→      config: JSON.parse(dashboard.config),\n    90→      createdAt: dashboard.created_at,\n    91→      updatedAt: dashboard.updated_at,\n    92→    });\n    93→  });\n    94→\n    95→  // Update dashboard\n    96→  router.put(\"/:id\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    97→    const tenantId = req.user!.tenantId;\n    98→    const { id } = req.params;\n    99→    const { name, config } = req.body;\n   100→\n   101→    const existing = db\n   102→      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   103→      .get(id, tenantId) as DashboardRow | undefined;\n   104→\n   105→    if (!existing) {\n   106→      res.status(404).json({ error: \"Dashboard not found\" });\n   107→      return;\n   108→    }\n   109→\n   110→    const updatedName = name || existing.name;\n   111→    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;\n   112→    const now = new Date().toISOString();\n   113→\n   114→    db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n   115→      updatedName,\n   116→      updatedConfig,\n   117→      now,\n   118→      id\n   119→    );\n   120→\n   121→    res.json({\n   122→      id,\n   123→      tenantId,\n   124→      name: updatedName,\n   125→      ownerId: existing.owner_id,\n   126→      config: JSON.parse(updatedConfig),\n   127→      createdAt: existing.created_at,\n   128→      updatedAt: now,\n   129→    });\n   130→  });\n   131→\n   132→  // Delete dashboard\n   133→  router.delete(\"/:id\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n   134→    const tenantId = req.user!.tenantId;\n   135→    const { id } = req.params;\n   136→\n   137→    const existing = db\n   138→      .prepare(\"SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   139→      .get(id, tenantId) as { id: string } | undefined;\n   140→\n   141→    if (!existing) {\n   142→      res.status(404).json({ error: \"Dashboard not found\" });\n   143→      return;\n   144→    }\n   145→\n   146→    db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(id);\n   147→\n   148→    res.status(204).send();\n   149→  });\n   150→\n   151→  return router;\n   152→}\n   153→"}]},"parent_tool_use_id":"toolu_01PWP8W5NgVoxRE88RA9PKhn","session_id":"7ff406d4-ecc1-4747-a791-3551abfa274d","uuid":"d348b7f4-a891-4a6b-9a84-86d8362a304c"}
