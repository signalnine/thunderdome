+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013mjAQEUt4N5sQuqEVN9Uu1","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import Database from \"better-sqlite3\";\n     3→import { AuthenticatedRequest, requireAuth } from \"../auth.js\";\n     4→\n     5→interface EventRow {\n     6→  id: string;\n     7→  tenant_id: string;\n     8→  name: string;\n     9→  properties: string;\n    10→  timestamp: string;\n    11→  user_id: string | null;\n    12→  session_id: string | null;\n    13→}\n    14→\n    15→interface DashboardRow {\n    16→  id: string;\n    17→  tenant_id: string;\n    18→  name: string;\n    19→  owner_id: string;\n    20→  config: string;\n    21→  created_at: string;\n    22→  updated_at: string;\n    23→}\n    24→\n    25→function eventsToCsv(events: EventRow[]): string {\n    26→  const header = \"id,name,properties,timestamp,user_id,session_id\";\n    27→  const rows = events.map((e) => {\n    28→    const props = e.properties.replace(/\"/g, '\"\"');\n    29→    const userId = e.user_id || \"\";\n    30→    const sessionId = e.session_id || \"\";\n    31→    return `${e.id},${e.name},\"${props}\",${e.timestamp},${userId},${sessionId}`;\n    32→  });\n    33→  return [header, ...rows].join(\"\\n\");\n    34→}\n    35→\n    36→function dashboardsToCsv(dashboards: DashboardRow[]): string {\n    37→  const header = \"id,name,owner_id,config,created_at,updated_at\";\n    38→  const rows = dashboards.map((d) => {\n    39→    const config = d.config.replace(/\"/g, '\"\"');\n    40→    return `${d.id},${d.name},${d.owner_id},\"${config}\",${d.created_at},${d.updated_at}`;\n    41→  });\n    42→  return [header, ...rows].join(\"\\n\");\n    43→}\n    44→\n    45→export function createExportRoutes(db: Database.Database): Router {\n    46→  const router = Router();\n    47→\n    48→  // Export events\n    49→  router.get(\"/events\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    50→    const tenantId = req.user!.tenantId;\n    51→    const format = (req.query.format as string) || \"json\";\n    52→    const eventName = req.query.eventName as string | undefined;\n    53→    const startDate = req.query.startDate as string | undefined;\n    54→    const endDate = req.query.endDate as string | undefined;\n    55→\n    56→    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    57→    const params: unknown[] = [tenantId];\n    58→\n    59→    if (eventName) {\n    60→      sql += \" AND name = ?\";\n    61→      params.push(eventName);\n    62→    }\n    63→\n    64→    if (startDate) {\n    65→      sql += \" AND timestamp >= ?\";\n    66→      params.push(startDate);\n    67→    }\n    68→\n    69→    if (endDate) {\n    70→      sql += \" AND timestamp <= ?\";\n    71→      params.push(endDate);\n    72→    }\n    73→\n    74→    sql += \" ORDER BY timestamp DESC\";\n    75→\n    76→    const events = db.prepare(sql).all(...params) as EventRow[];\n    77→\n    78→    if (format === \"csv\") {\n    79→      res.setHeader(\"Content-Type\", \"text/csv\");\n    80→      res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    81→      res.send(eventsToCsv(events));\n    82→    } else {\n    83→      res.json(\n    84→        events.map((e) => ({\n    85→          id: e.id,\n    86→          name: e.name,\n    87→          properties: JSON.parse(e.properties),\n    88→          timestamp: e.timestamp,\n    89→          userId: e.user_id,\n    90→          sessionId: e.session_id,\n    91→        }))\n    92→      );\n    93→    }\n    94→  });\n    95→\n    96→  // Export dashboards\n    97→  router.get(\"/dashboards\", requireAuth, (req: AuthenticatedRequest, res: Response): void => {\n    98→    const tenantId = req.user!.tenantId;\n    99→    const format = (req.query.format as string) || \"json\";\n   100→\n   101→    const dashboards = db\n   102→      .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   103→      .all(tenantId) as DashboardRow[];\n   104→\n   105→    if (format === \"csv\") {\n   106→      res.setHeader(\"Content-Type\", \"text/csv\");\n   107→      res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n   108→      res.send(dashboardsToCsv(dashboards));\n   109→    } else {\n   110→      res.json(\n   111→        dashboards.map((d) => ({\n   112→          id: d.id,\n   113→          name: d.name,\n   114→          ownerId: d.owner_id,\n   115→          config: JSON.parse(d.config),\n   116→          createdAt: d.created_at,\n   117→          updatedAt: d.updated_at,\n   118→        }))\n   119→      );\n   120→    }\n   121→  });\n   122→\n   123→  return router;\n   124→}\n   125→"}]},"parent_tool_use_id":"toolu_01PWP8W5NgVoxRE88RA9PKhn","session_id":"7ff406d4-ecc1-4747-a791-3551abfa274d","uuid":"557ba535-5c16-4133-add4-c5d359054881"}
