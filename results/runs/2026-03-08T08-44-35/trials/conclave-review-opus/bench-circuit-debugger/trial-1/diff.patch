n2)) consumedBy.set(gate.in2, []);\n    consumedBy.get(gate.in2)!.push(gate);\n  }\n\n  function isInput(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function isZ(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function hasXYInputs(gate: Gate): boolean {\n    return isInput(gate.in1) && isInput(gate.in2);\n  }\n\n  function isBit0XY(gate: Gate): boolean {\n    return hasXYInputs(gate) &&\n      gate.in1.endsWith('00') && gate.in2.endsWith('00');\n  }\n\n  function getBitNum(gate: Gate): number {\n    // Extract bit number from x/y input\n    const m = gate.in1.match(/^[xy](\\d+)$/) ?? gate.in2.match(/^[xy](\\d+)$/);\n    return m ? parseInt(m[1], 10) : -1;\n  }\n\n  function getConsumerOps(wire: string): Set<string> {\n    const cons = consumedBy.get(wire) ?? [];\n    return new Set(cons.map((g) => g.op));\n  }\n\n  function getConsumers(wire: string): Gate[] {\n    return consumedBy.get(wire) ?? [];\n  }\n\n  const bad = new Set<string>();\n\n  for (const gate of gates) {\n    const out = gate.out;\n\n    if (gate.op === 'XOR') {\n      if (hasXYInputs(gate)) {\n        if (isBit0XY(gate)) {\n          // x00 XOR y00 -> must output z00\n          if (out !== 'z00') bad.add(out);\n        } else {\n          // xNN XOR yNN (N>0) -> partial sum\n          // Must NOT output z\n          if (isZ(out)) {\n            bad.add(out);\n          } else {\n            // Must be consumed by a secondary XOR that outputs z{N}\n            const bit = getBitNum(gate);\n            const expectedZ = `z${bit.toString().padStart(2, '0')}`;\n            const xorConsumers = getConsumers(out).filter(\n              (g) => g.op === 'XOR'\n            );\n            // Check if any XOR consumer outputs the expected z wire\n            const hasCorrectXorConsumer = xorConsumers.some(\n              (g) => g.out === expectedZ\n            );\n            if (!hasCorrectXorConsumer) {\n              bad.add(out);\n            }\n          }\n        }\n      } else {\n        // Secondary XOR: must output a z wire\n        if (!isZ(out)) {\n          bad.add(out);\n        }\n      }\n    } else if (gate.op === 'AND') {\n      if (isBit0XY(gate)) {\n        // x00 AND y00: carry for bit 1\n        if (numBits > 1) {\n          const ops = getConsumerOps(out);\n          if (!ops.has('XOR') || !ops.has('AND')) {\n            bad.add(out);\n          }\n        }\n      } else {\n        // AND output should feed into OR\n        if (isZ(out)) {\n          bad.add(out);\n        } else {\n          const ops = getConsumerOps(out);\n          if (!ops.has('OR')) {\n            bad.add(out);\n          }\n        }\n      }\n    } else if (gate.op === 'OR') {\n      if (out === highestZ) {\n        // OK - final carry\n      } else if (isZ(out)) {\n        bad.add(out);\n      } else {\n        const ops = getConsumerOps(out);\n        if (!ops.has('XOR') || !ops.has('AND')) {\n          bad.add(out);\n        }\n      }\n    }\n  }\n\n  return [...bad].sort();\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1999,"cache_read_input_tokens":99706,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1999},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0d871afd-ee83-4cad-96df-5480e45794cb","uuid":"da1b3f47-2e51-45d0-af0d-f0f03467597c"}
