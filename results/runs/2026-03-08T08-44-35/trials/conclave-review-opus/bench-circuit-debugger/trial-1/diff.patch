n      a: 0,\n      b: 1,\n      c: 0,\n      ab: 0,\n      result: 0,\n    });\n  });\n\n  it('should simulate a correct 4-bit adder (0 + 0)', () => {\n    const gates = make4BitAdder();\n    const inputs = setInputs(4, 0, 0);\n    const result = simulate(gates, inputs);\n    expect(extractZ(result, 5)).toBe(0);\n  });\n\n  it('should simulate a correct 4-bit adder (3 + 5 = 8)', () => {\n    const gates = make4BitAdder();\n    const inputs = setInputs(4, 3, 5);\n    const result = simulate(gates, inputs);\n    expect(extractZ(result, 5)).toBe(8);\n  });\n\n  it('should simulate a correct 4-bit adder (15 + 15 = 30)', () => {\n    const gates = make4BitAdder();\n    const inputs = setInputs(4, 15, 15);\n    const result = simulate(gates, inputs);\n    expect(extractZ(result, 5)).toBe(30);\n  });\n\n  it('should simulate a correct 4-bit adder (7 + 9 = 16)', () => {\n    const gates = make4BitAdder();\n    const inputs = setInputs(4, 7, 9);\n    const result = simulate(gates, inputs);\n    expect(extractZ(result, 5)).toBe(16);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in a small adder', () => {\n    // Build a correct 8-bit adder, then swap 4 pairs\n    const gates = makeNBitAdder(8);\n    // Verify it works correctly first\n    for (let i = 0; i < 10; i++) {\n      const a = Math.floor(Math.random() * 256);\n      const b = Math.floor(Math.random() * 256);\n      const inputs = setInputs(8, a, b);\n      const result = simulate([...gates.map(g => ({...g}))], inputs);\n      expect(extractZ(result, 9)).toBe(a + b);\n    }\n  });\n\n  it('should find 8 swapped wires', () => {\n    const { gates, swappedWires } = makeSwappedAdder(8);\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...swappedWires].sort());\n  });\n\n  it('should find swapped wires in a larger adder', () => {\n    const { gates, swappedWires } = makeSwappedAdder(16);\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...swappedWires].sort());\n  });\n\n  it('should find swapped wires in a 45-bit adder', () => {\n    const { gates, swappedWires } = makeSwappedAdder(45);\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...swappedWires].sort());\n  });\n\n  it('should return results sorted alphabetically', () => {\n    const { gates } = makeSwappedAdder(10);\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n\n  it('should handle adder where z outputs are swapped', () => {\n    // Specifically swap z outputs with internal wires\n    const { gates, swappedWires } = makeSwappedAdderWithZSwaps(12);\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...swappedWires].sort());\n  });\n});\n\n// Helper functions\n\nfunction pad(n: number): string {\n  return n.toString().padStart(2, '0');\n}\n\nfunction setInputs(\n  bits: number,\n  x: number,\n  y: number\n): Record<string, number> {\n  const inputs: Record<string, number> = {};\n  for (let i = 0; i < bits; i++) {\n    inputs[`x${pad(i)}`] = (x >> i) & 1;\n    inputs[`y${pad(i)}`] = (y >> i) & 1;\n  }\n  return inputs;\n}\n\nfunction extractZ(wires: Record<string, number>, bits: number): number {\n  let result = 0;\n  for (let i = 0; i < bits; i++) {\n    result |= (wires[`z${pad(i)}`] ?? 0) << i;\n  }\n  return result;\n}\n\nfunction make4BitAdder(): Gate[] {\n  return [\n    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n    { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n    { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n    { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n    { o