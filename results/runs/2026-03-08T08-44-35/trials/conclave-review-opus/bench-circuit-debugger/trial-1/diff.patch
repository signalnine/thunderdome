ral rule checking ===\n  for (const gate of gates) {\n    const out = gate.out;\n\n    if (gate.op === 'XOR') {\n      if (hasXYInputs(gate)) {\n        // Primary XOR: xNN XOR yNN\n        if (gate.in1.endsWith('00') || gate.in2.endsWith('00')) {\n          // Bit 0: should output z00\n          if (out !== 'z00') {\n            bad.add(out);\n          }\n        } else {\n          // Bit > 0: should NOT output a z wire (outputs to secondary XOR and propagate AND)\n          if (isZ(out)) {\n            bad.add(out);\n          }\n        }\n      } else {\n        // Secondary XOR: partialSum XOR carry -> zNN\n        // MUST output a z wire\n        if (!isZ(out)) {\n          bad.add(out);\n        }\n      }\n    } else if (gate.op === 'AND') {\n      if (!hasXYInputs(gate) || !(gate.in1.endsWith('00') || gate.in2.endsWith('00'))) {\n        // For AND gates (except x00 AND y00): output should feed into OR\n        // If it outputs a z wire, that's wrong (unless it's the final carry, but that's an OR, not AND)\n        if (isZ(out)) {\n          bad.add(out);\n        } else {\n          const ops = getConsumerOps(out);\n          if (!ops.has('OR')) {\n            bad.add(out);\n          }\n        }\n      }\n    } else if (gate.op === 'OR') {\n      // Carry: should feed into XOR and AND, or be the final z bit\n      if (out !== highestZ && isZ(out)) {\n        bad.add(out);\n      }\n    }\n  }\n\n  // === Phase 2: For each bad wire that's a z output, also find its swap partner ===\n  // If a z wire is wrong (produced by wrong gate type), find the gate that should produce it\n  // A z wire (except z00 and highestZ) should be produced by a secondary XOR\n  for (let bit = 1; bit < numBits; bit++) {\n    const zw = `z${bit.toString().padStart(2, '0')}`;\n    if (!bad.has(zw)) continue;\n\n    // zw is flagged as bad, meaning the gate producing zw is not a secondary XOR\n    // We need to find the correct secondary XOR that should output zw\n    // The secondary XOR for this bit takes (partialSum, carry) as inputs\n    // where partialSum = xNN XOR yNN output\n\n    // But we don't know which secondary XOR is the right one.\n    // The gate currently outputting zw has the wrong output; its output should be elsewhere.\n    // We just flag it and leave pairing to the structural rules.\n  }\n\n  // === Phase 3: Sequential walk to catch remaining swaps ===\n  // This catches swaps between wires of the same structural type\n  // (e.g., carry <-> partial sum, which have the same consumer pattern)\n  if (bad.size < 8) {\n    // Walk the carry chain to find remaining swaps\n    let carry = '';\n\n    for (let bit = 0; bit < numBits; bit++) {\n      const xw = `x${bit.toString().padStart(2, '0')}`;\n      const yw = `y${bit.toString().padStart(2, '0')}`;\n      const zw = `z${bit.toString().padStart(2, '0')}`;\n\n      if (bit === 0) {\n        const andGate = findGate('AND', xw, yw);\n        if (andGate) carry = andGate.out;\n        continue;\n      }\n\n      const xorGate = findGate('XOR', xw, yw);\n      if (!xorGate) continue;\n      const partialSum = xorGate.out;\n\n      // If partialSum is already flagged as bad, we can't reliably walk this bit\n      if (bad.has(partialSum)) {\n        // Try to determine carry anyway\n        const andGate = findGate('AND', xw, yw);\n        if (andGate) {\n          // We can't compute carry properly here since the structure is broken\n          // Skip this bit\n        }\n        continue;\n      }\n\n      // Try to find sumGate: partialSum XOR carry\n      const sumGate = findGate('XOR', partialSum, carry);\n\n      if (!sumGate) {\n        // partialSum or carry is misplaced\n        // Look for XOR using carry\n        const carryXors = (consumedBy.get(carry) ?? []).filter(\n          (g) => g.op === 'XOR' && !hasXYInputs(g)\n        );\n\n        if (carryXors.length === 1) {\n          const otherInput =\n            carryXors[0].in1 === carry ? carryXors[0].in2 : carryXors[0].in1;\n          if (otherInput !== partialSum) {\n            bad.add(partialSum);\n            bad.add(otherInput);\n          }\n          // Use the correct sum gate\n          const sg = carryXors[0];\n          if (sg.out !== zw && !bad.has(sg.out)) {\n            bad.add(sg.out);\n            bad.add(zw);\n          }\n\n          // Compute carry for next bit using otherInput as the real partialSum\n          const realPS = otherInput;\n          const propGate = findGate('AND', realPS, carry);\n          const andGate = findGate('AND', xw, yw);\n          if (propGate && andGate) {\n            const orGate = findGate('OR', andGate.out, propGate.out);\n            if (orGate) carry = orGate.out;\n          }\n          continue;\n        }\n\n        // Look for XOR using partialSum\n        const psXors = (consumedBy.get(partialSum) ?? []).filter(\n          (g) => g.op === 'XOR' && g !== xorGate\n        );\n        if (psXors.length === 1) {\n          const otherInput =\n            psXors[0].in1 === partialSum ? psXors[0].in2 : psXors[0].in1;\n          if (otherInput !== carry) {\n            bad.add(carry);\n            bad.add(otherInput);\n            carry = otherInput;\n          }\n          const sg = psXors[0];\n          if (sg.out !== zw && !bad.has(sg.out)) {\n            bad.add(sg.out);\n            bad.add(zw);\n          }\n\n          const propGate = findGate('AND', partialSum, carry);\n          const andGate = findGate('AND', xw, yw);\n          if (propGate && andGate) {\n            const orGate = findGate('OR', andGate.out, propGate.out);\n            if (orGate) carry = orGate.out;\n          }\n          continue;\n        }\n\n        continue;\n      }\n\n      // sumGate found, check its output\n      if (sumGate.out !== zw && !bad.has(sumGate.out) && !bad.has(zw)) {\n        bad.add(sumGate.out);\n        bad.add(zw);\n      }\n\n      // Compute carry for next bit\n      const andGate = findGate('AND', xw, yw);\n      if (!andGate) continue;\n\n      const propGate = findGate('AND', partialSum, carry);\n      if (!propGate) continue;\n\n      const orGate = findGate('OR', andGate.out, propGate.out);\n      if (orGate) {\n        carry = orGate.out;\n      } else {\n        // Try to find the OR gate\n        const genOrs = (consumedBy.get(andGate.out) ?? []).filter(\n          (g) => g.op === 'OR'\n        );\n        if (genOrs.length === 1) {\n          const otherInput =\n            genOrs[0].in1 === andGate.out ? genOrs[0].in2 : genOrs[0].in1;\n          if (otherInput !== propGate.out && !bad.has(otherInput) && !bad.has(propGate.out)) {\n            bad.add(propGate.out);\n            bad.add(otherInput);\n          }\n          carry = genOrs[0].out;\n        } else {\n          const propOrs = (consumedBy.get(propGate.out) ?? []).filter(\n            (g) => g.op === 'OR'\n          );\n          if (propOrs.length === 1) {\n            const otherInput =\n              propOrs[0].in1 === propGate.out ? propOrs[0].in2 : propOrs[0].in1;\n            if (otherInput !== andGate.out && !bad.has(otherInput) && !bad.has(andGate.out)) {\n              bad.add(andGate.out);\n              bad.add(otherInput);\n            }\n            carry = propOrs[0].out;\n          }\n        }\n      }\n    }\n\n    // Check final carry\n    if (carry !== '' && carry !== highestZ && !bad.has(carry) && !bad.has(highestZ)) {\n      bad.add(carry);\n      bad.add(highestZ);\n    }\n  }\n\n  return [...bad].sort();\n}\n"}}
