)}`;\n    const ti = `t${pad(i)}`;\n    const ai = `a${pad(i)}`;\n    const bi = `b${pad(i)}`;\n    const prevC = `c${pad(i - 1)}`;\n    const ci = i < n - 1 ? `c${pad(i)}` : `z${pad(n)}`;\n\n    gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n    gates.push({ op: 'XOR', in1: ti, in2: prevC, out: zi });\n    gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n    gates.push({ op: 'AND', in1: ti, in2: prevC, out: bi });\n    gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n  }\n\n  return gates;\n}\n\ntype GateRole = 'partial' | 'sum' | 'generate' | 'propagate' | 'carry';\n\ninterface SwapSpec {\n  bit1: number;\n  role1: GateRole;\n  bit2: number;\n  role2: GateRole;\n}\n\nfunction getGateIndex(n: number, bit: number, role: GateRole): number {\n  // Gate layout:\n  // bit 0: [0] XOR x00,y00->z00, [1] AND x00,y00->c00\n  // bit i (1..n-1): [2 + (i-1)*5 + offset]\n  //   offset 0: XOR xi,yi -> ti (partial)\n  //   offset 1: XOR ti,c(i-1) -> zi (sum)\n  //   offset 2: AND xi,yi -> ai (generate)\n  //   offset 3: AND ti,c(i-1) -> bi (propagate)\n  //   offset 4: OR ai,bi -> ci (carry)\n  if (bit === 0) {\n    if (role === 'sum') return 0; // z00\n    if (role === 'carry') return 1; // c00\n    throw new Error(`Invalid role ${role} for bit 0`);\n  }\n  const base = 2 + (bit - 1) * 5;\n  switch (role) {\n    case 'partial': return base;\n    case 'sum': return base + 1;\n    case 'generate': return base + 2;\n    case 'propagate': return base + 3;\n    case 'carry': return base + 4;\n  }\n}\n\nfunction makeSwappedAdder(\n  n: number,\n  seed: number\n): { gates: Gate[]; swappedWires: string[] } {\n  const gates = makeNBitAdder(n);\n  const rng = mulberry32(seed);\n\n  // Randomize internal wire names\n  randomizeWireNames(gates, rng);\n\n  // Pick 4 swap pairs from different bit positions\n  // Each swap involves gates at distinct bit positions to avoid cascading\n  const usedBits = new Set<number>();\n  const swaps: Array<[number, number]> = [];\n\n  // Collect swappable gate indices (all gates)\n  const allIndices = gates.map((_, i) => i);\n\n  while (swaps.length < 4) {\n    const i1 = allIndices[Math.floor(rng() * allIndices.length)];\n    const i2 = allIndices[Math.floor(rng() * allIndices.length)];\n    if (i1 === i2) continue;\n\n    // Ensure these aren't already used\n    if (usedBits.has(i1) || usedBits.has(i2)) continue;\n\n    usedBits.add(i1);\n    usedBits.add(i2);\n    swaps.push([i1, i2]);\n  }\n\n  const swappedWires: string[] = [];\n  for (const [i1, i2] of swaps) {\n    swappedWires.push(gates[i1].out, gates[i2].out);\n    const tmp = gates[i1].out;\n    gates[i1].out = gates[i2].out;\n    gates[i2].out = tmp;\n  }\n\n  // Shuffle gate order\n  shuffle(gates, rng);\n\n  return { gates, swappedWires };\n}\n\nfunction makeSwappedAdderSpecific(\n  n: number,\n  specs: SwapSpec[]\n): { gates: Gate[]; swappedWires: string[] } {\n  const gates = makeNBitAdder(n);\n  const rng = mulberry32(12345);\n  randomizeWireNames(gates, rng);\n\n  const swappedWires: string[] = [];\n  for (const spec of specs) {\n    const i1 = getGateIndex(n, spec.bit1, spec.role1);\n    const i2 = getGateIndex(n, spec.bit2, spec.role2);\n    swappedWires.push(gates[i1].out, gates[i2].out);\n    const tmp = gates[i1].out;\n    gates[i1].out = gates[i2].out;\n    gates[i2].out = tmp;\n  }\n\n  shuffle(gates, rng);\n\n  return { gates, swappedWires };\n}\n\nfunction randomizeWireNames(gates: Gate[], rng: () => number): void {\n  const wireMap = new Map<string, string>();\n  const usedNames = new Set<string>();\n\n  // Reserve x, y, z wire names\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      if (/^[xyz]\\d+$/.test(w)) {\n        usedNames.add(w);\n        wireMap.set(w, w);\n      }\n    }\n  }\n\n  // Assign random 3-char names to internal wires\n  const chars = 'abcdefghijklmnopqrstuvwxyz';\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      if (!wireMap.has(w)) {\n        let name: string;\n        do {\n          name = '';\n          for (let i = 0; i < 3; i++) {\n            name += chars[Math.floor(rng() * chars.length)];\n          }\n        } while (usedNames.has(name));\n        usedNames.add(name);\n        wireMap.set(w, name);\n      }\n    }\n  }\n\n  for (const g of gates) {\n    g.in1 = wireMap.get(g.in1) ?? g.in1;\n    g.in2 = wireMap.get(g.in2) ?? g.in2;\n    g.out = wireMap.get(g.out) ?? g.out;\n  }\n}\n\nfunction shuffle<T>(arr: T[], rng: () => number): void {\n  for (let i = arr.length - 1; i > 0; i--) {\n    const j = Math.floor(rng() * (i + 1));\n    [arr[i], arr[j]] = [arr[j], arr[i]];\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5556,"cache_read_input_tokens":34267,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5556},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0d871afd-ee83-4cad-96df-5480e45794cb","uuid":"e6627f09-3081-4237-95f9-e0d91c89fb7a"}
