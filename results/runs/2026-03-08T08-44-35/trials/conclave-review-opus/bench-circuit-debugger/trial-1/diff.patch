+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = new Set(gates.map((_, i) => i));
+
+  let progress = true;
+  while (remaining.size > 0 && progress) {
+    progress = false;
+    for (const i of remaining) {
+      const g = gates[i];
+      if (wires[g.in1] !== undefined && wires[g.in2] !== undefined) {
+        const a = wires[g.in1];
+        const b = wires[g.in2];
+        switch (g.op) {
+          case 'AND':
+            wires[g.out] = a & b;
+            break;
+          case 'OR':
+            wires[g.out] = a | b;
+            break;
+          case 'XOR':
+            wires[g.out] = a ^ b;
+            break;
+        }
+        remaining.delete(i);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 swapped output wires in a broken ripple-carry adder circuit.
+ *
+ * Uses structural rules to flag rule-violating wires. The rules are based on
+ * the observation that in a ripple-carry adder, each gate type has specific
+ * constraints on what its output should look like and what should consume it.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  let numBits = 0;
+  for (const gate of gates) {
+    for (const w of [gate.in1, gate.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) numBits = Math.max(numBits, parseInt(m[1], 10) + 1);
+    }
+  }
+
+  const highestZ = `z${numBits.toString().padStart(2, '0')}`;
+
+  // Build consumer map from the ORIGINAL gates (inputs don't change in swaps)
+  const consumedBy = new Map<string, Gate[]>();
+  for (const gate of gates) {
+    if (!consumedBy.has(gate.in1)) consumedBy.set(gate.in1, []);
+    consumedBy.get(gate.in1)!.push(gate);
+    if (!consumedBy.has(gate.in2)) consumedBy.set(gate.in2, []);
+    consumedBy.get(gate.in2)!.push(gate);
+  }
+
+  function isInput(w: string): boolean {
+    return /^[xy]\d+$/.test(w);
+  }
+
+  function isZ(w: string): boolean {
+    return /^z\d+$/.test(w);
+  }
+
+  function hasXYInputs(gate: Gate): boolean {
+    return isInput(gate.in1) && isInput(gate.in2);
+  }
+
+  function isBit0XY(gate: Gate): boolean {
+    return hasXYInputs(gate) &&
+      gate.in1.endsWith('00') && gate.in2.endsWith('00');
+  }
+
+  function getConsumerOps(wire: string): Set<string> {
+    return new Set((consumedBy.get(wire) ?? []).map((g) => g.op));
+  }
+
+  const bad = new Set<string>();
+
+  for (const gate of gates) {
+    const out = gate.out;
+
+    if (gate.op === 'XOR') {
+      if (hasXYInputs(gate)) {
+        if (isBit0XY(gate)) {
+          // x00 XOR y00 -> must be z00
+          if (out !== 'z00') bad.add(out);
+        } else {
+          // Primary XOR for bit > 0: output must NOT be z
+          // and must be consumed by both XOR and AND
+          if (isZ(out)) {
+            bad.add(out);
+          } else {
+            const ops = getConsumerOps(out);
+            if (!ops.has('XOR') || !ops.has('AND')) bad.add(out);
+          }
+        }
+      } else {
+        // Secondary XOR: must output z
+        if (!isZ(out)) {
+          bad.add(out);
+        }
+      }
+    } else if (gate.op === 'AND') {
+      if (isBit0XY(gate)) {
+        // Bit 0 carry
+        if (numBits > 1) {
+          const ops = getConsumerOps(out);
+          if (!ops.has('XOR') || !ops.has('AND')) bad.add(out);
+        }
+      } else {
+        // Generate or propagate carry: must feed into OR
+        if (isZ(out)) {
+          bad.add(out);
+        } else {
+          const ops = getConsumerOps(out);
+          if (!ops.has('OR')) bad.add(out);
+        }
+      }
+    } else if (gate.op === 'OR') {
+      // Carry out: must be highestZ or feed into XOR and AND
+      if (out === highestZ) {
+        // OK
+      } else if (isZ(out)) {
+        bad.add(out);
+      } else {
+        const ops = getConsumerOps(out);
+        if (!ops.has('XOR') || !ops.has('AND')) bad.add(out);
+      }
+    }
+  }
+
+  return [...bad].sort();
+}
