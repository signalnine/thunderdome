ND':\n            wires[g.out] = a & b;\n            break;\n          case 'OR':\n            wires[g.out] = a | b;\n            break;\n          case 'XOR':\n            wires[g.out] = a ^ b;\n            break;\n        }\n        remaining.delete(i);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 swapped output wires in a broken ripple-carry adder circuit.\n *\n * Uses a two-phase approach:\n * Phase 1: Structural rule checking catches most swaps (cross-type swaps)\n * Phase 2: Sequential carry-chain walk catches carry<->partialsum swaps\n *\n * After Phase 1, we fix the detected swaps on a copy and re-walk to find remaining ones.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  let numBits = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1], 10) + 1);\n    }\n  }\n\n  const highestZ = `z${numBits.toString().padStart(2, '0')}`;\n\n  const consumedBy = new Map<string, Gate[]>();\n  for (const gate of gates) {\n    if (!consumedBy.has(gate.in1)) consumedBy.set(gate.in1, []);\n    consumedBy.get(gate.in1)!.push(gate);\n    if (!consumedBy.has(gate.in2)) consumedBy.set(gate.in2, []);\n    consumedBy.get(gate.in2)!.push(gate);\n  }\n\n  function isInput(w: string): boolean {\n    return /^[xy]\\d+$/.test(w);\n  }\n\n  function isZ(w: string): boolean {\n    return /^z\\d+$/.test(w);\n  }\n\n  function hasXYInputs(gate: Gate): boolean {\n    return isInput(gate.in1) && isInput(gate.in2);\n  }\n\n  function isBit0XY(gate: Gate): boolean {\n    return hasXYInputs(gate) &&\n      gate.in1.endsWith('00') && gate.in2.endsWith('00');\n  }\n\n  function getConsumerOps(wire: string): Set<string> {\n    const cons = consumedBy.get(wire) ?? [];\n    return new Set(cons.map((g) => g.op));\n  }\n\n  const bad = new Set<string>();\n\n  // === Phase 1: Structural rule checking ===\n  for (const gate of gates) {\n    const out = gate.out;\n\n    if (gate.op === 'XOR') {\n      if (hasXYInputs(gate)) {\n        if (isBit0XY(gate)) {\n          if (out !== 'z00') bad.add(out);\n        } else {\n          // Primary XOR for bit > 0: must NOT output z\n          if (isZ(out)) bad.add(out);\n        }\n      } else {\n        // Secondary XOR: must output z\n        if (!isZ(out)) bad.add(out);\n      }\n    } else if (gate.op === 'AND') {\n      if (isBit0XY(gate)) {\n        if (numBits > 1) {\n          const ops = getConsumerOps(out);\n          if (!ops.has('XOR') || !ops.has('AND')) bad.add(out);\n        }\n      } else {\n        if (isZ(out)) {\n          bad.add(out);\n        } else {\n          const ops = getConsumerOps(out);\n          if (!ops.has('OR')) bad.add(out);\n        }\n      }\n    } else if (gate.op === 'OR') {\n      if (out === highestZ) {\n        // OK\n      } else if (isZ(out)) {\n        bad.add(out);\n      } else {\n        const ops = getConsumerOps(out);\n        if (!ops.has('XOR') || !ops.has('AND')) bad.add(out);\n      }\n    }\n  }\n\n  // === Phase 2: Fix detected swaps, then walk carry chain to find remaining ===\n  if (bad.size < 8) {\n    // Work on a copy and fix detected swaps\n    const gCopy = gates.map((g) => ({ ...g }));\n\n    // Find pairings: for each bad z wire, find the non-z bad wire that should go there\n    // and vice versa\n    const badZ = [...bad].filter(isZ);\n    const badNonZ = [...bad].filter((w) => !isZ(w));\n\n    // Try to pair them: each bad z should be produced by the gate that currently has\n    // a bad non-z output (and vice versa)\n    for (const zw of badZ) {\n      // Find the gate producing zw - it should have produced a non-z wire\n      const producer = gCopy.find((g) => g.out === zw);\n      if (!producer) continue;\n\n      // The producer's correct output should be a non-z wire\n      // And there should be a secondary XOR that should output zw but instead outputs\n      // a non-z wire\n      for (const nzw of badNonZ) {\n        const nzProducer = gCopy.find((g) => g.out === nzw);\n        if (!nzProducer) continue;\n\n        // If nzProducer is a secondary XOR (non-xy XOR) and producer is not a secondary XOR,\n        // this could be a valid swap pair\n        if (nzProducer.op === 'XOR' && !hasXYInputs(nzProducer) &&\n            !(producer.op === 'XOR' && !hasXYInputs(producer))) {\n          // Swap them\n          nzProducer.out = zw;\n          producer.out = nzw;\n          break;\n        }\n      }\n    }\n\n    // Now walk the carry chain on the fixed copy to find remaining swaps\n    const findGate = (op: Gate['op'], in1: string, in2: string) =>\n      gCopy.find(\n        (g) =>\n          g.op === op &&\n          ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))\n      );\n\n    const consumers2 = new Map<string, Gate[]>();\n    for (const gate of gCopy) {\n      if (!consumers2.has(gate.in1)) consumers2.set(gate.in1, []);\n      consumers2.get(gate.in1)!.push(gate);\n      if (!consumers2.has(gate.in2)) consumers2.set(gate.in2, []);\n      consumers2.get(gate.in2)!.push(gate);\n    }\n\n    let carry = '';\n\n    for (let bit = 0; bit < numBits; bit++) {\n      const xw = `x${bit.toString().padStart(2, '0')}`;\n      const yw = `y${bit.toString().padStart(2, '0')}`;\n      const zw = `z${bit.toString().padStart(2, '0')}`;\n\n      if (bit === 0) {\n        const andGate = findGate('AND', xw, yw);\n        if (andGate) carry = andGate.out;\n        continue;\n      }\n\n      const xorGate = findGate('XOR', xw, yw);\n      if (!xorGate) continue;\n      let partialSum = xorGate.out;\n\n      const sumGate = findGate('XOR', partialSum, carry);\n\n      if (!sumGate) {\n        // carry or partialSum is wrong\n        const carryXors = (consumers2.get(carry) ?? []).filter(\n          (g) => g.op === 'XOR' && !(isInput(g.in1) && isInput(g.in2))\n        );\n\n        if (carryXors.length === 1) {\n          const otherInput =\n            carryXors[0].in1 === carry ? carryXors[0].in2 : carryXors[0].in1;\n          if (otherInput !== partialSum) {\n            bad.add(partialSum);\n            bad.add(otherInput);\n            // Fix in copy\n            const g1 = gCopy.find((g) => g.out === partialSum)!;\n            const g2 = gCopy.find((g) => g.out === otherInput)!;\n            g1.out = otherInput;\n            g2.out = partialSum;\n            partialSum = otherInput;\n          }\n        } else {\n          const psXors = (consumers2.get(partialSum) ?? []).filter(\n            (g) => g.op === 'XOR' && g !== xorGate\n          );\n          if (psXors.length === 1) {\n            const otherInput =\n              psXors[0].in1 === partialSum ? psXors[0].in2 : psXors[0].in1;\n            if (otherInput !== carry) {\n              bad.add(carry);\n              bad.add(otherInput);\n              const g1 = gCopy.find((g) => g.out === carry)!;\n              const g2 = gCopy.find((g) => g.out === otherInput)!;\n              g1.out = otherInput;\n              g2.out = carry;\n              carry = otherInput;\n            }\n          }\n        }\n\n        // Recompute carry\n        const andGate = findGate('AND', xw, yw);\n        const propGate = findGate('AND', partialSum, carry);\n        if (andGate && propGate) {\n          const orGate = findGate('OR', andGate.out, propGate.out);\n          if (orGate) carry = orGate.out;\n        }\n        continue;\n      }\n\n      // Compute carry for next bit\n      const andGate = findGate('AND', xw, yw);\n      if (!andGate) continue;\n\n      const propGate = findGate('AND', partialSum, carry);\n      if (!propGate) continue;\n\n      const orGate = findGate('OR', andGate.out, propGate.out);\n      if (orGate) {\n        carry = orGate.out;\n      }\n    }\n\n    // Check final carry\n    if (carry !== '' && carry !== highestZ && !bad.has(carry) && !bad.has(highestZ)) {\n      bad.add(carry);\n      bad.add(highestZ);\n    }\n  }\n\n  return [...bad].sort();\n}\n","structuredPatch":[{"oldStart":45,"oldLines":6,"newStart":45,"newLines":12,"lines":[" "," /**","  * Find the 8 swapped output wires in a broken ripple-carry adder circuit.","+ *","+ * Uses a two-phase approach:","+ * Phase 1: Structural rule checking catches most swaps (cross-type swaps)","+ * Phase 2: Sequential carry-chain walk catches carry<->partialsum swaps","+ *","+ * After Phase 1, we fix the detected swaps on a copy and re-walk to find remaining ones.","  */"," export function findSwappedWires(gates: Gate[]): string[] {","   let numBits = 0;"]},{"oldStart":82,"oldLines":90,"newStart":88,"newLines":192,"lines":["       gate.in1.endsWith('00') && gate.in2.endsWith('00');","   }"," ","-  function getBitNum(gate: Gate): number {","-    // Extract bit number from x/y input","-    const m = gate.in1.match(/^[xy](\\d+)$/) ?? gate.in2.match(/^[xy](\\d+)$/);","-    return m ? parseInt(m[1], 10) : -1;","-  }","-","   function getConsumerOps(wire: string): Set<string> {","     const cons = consumedBy.get(wire) ?? [];","     return new Set(cons.map((g) => g.op));","   }"," ","-  function getConsumers(wire: string): Gate[] {","-    return consumedBy.get(wire) ?? [];","-  }","-","   const bad = new Set<string>();"," ","+  // === Phase 1: Structural rule checking ===","   for (const gate of gates) {","     const out = gate.out;"," ","     if (gate.op === 'XOR') {","       if (hasXYInputs(gate)) {","         if (isBit0XY(gate)) {","-          // x00 XOR y00 -> must output z00","           if (out !== 'z00') bad.add(out);","         } else {","-          // xNN XOR yNN (N>0) -> partial sum","-          // Must NOT output z","-          if (isZ(out)) {","-            bad.add(out);","-          } else {","-            // Must be consumed by a secondary XOR that outputs z{N}","-            const bit = getBitNum(gate);","-            const expectedZ = `z${bit.toString().padStart(2, '0')}`;","-            const xorConsum