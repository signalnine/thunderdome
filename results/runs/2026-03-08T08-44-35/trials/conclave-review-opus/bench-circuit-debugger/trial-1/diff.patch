es;\n   216→}\n   217→\n   218→type GateRole = 'partial' | 'sum' | 'generate' | 'propagate' | 'carry';\n   219→\n   220→interface SwapSpec {\n   221→  bit1: number;\n   222→  role1: GateRole;\n   223→  bit2: number;\n   224→  role2: GateRole;\n   225→}\n   226→\n   227→function getGateIndex(n: number, bit: number, role: GateRole): number {\n   228→  // Gate layout:\n   229→  // bit 0: [0] XOR x00,y00->z00, [1] AND x00,y00->c00\n   230→  // bit i (1..n-1): [2 + (i-1)*5 + offset]\n   231→  //   offset 0: XOR xi,yi -> ti (partial)\n   232→  //   offset 1: XOR ti,c(i-1) -> zi (sum)\n   233→  //   offset 2: AND xi,yi -> ai (generate)\n   234→  //   offset 3: AND ti,c(i-1) -> bi (propagate)\n   235→  //   offset 4: OR ai,bi -> ci (carry)\n   236→  if (bit === 0) {\n   237→    if (role === 'sum') return 0; // z00\n   238→    if (role === 'carry') return 1; // c00\n   239→    throw new Error(`Invalid role ${role} for bit 0`);\n   240→  }\n   241→  const base = 2 + (bit - 1) * 5;\n   242→  switch (role) {\n   243→    case 'partial': return base;\n   244→    case 'sum': return base + 1;\n   245→    case 'generate': return base + 2;\n   246→    case 'propagate': return base + 3;\n   247→    case 'carry': return base + 4;\n   248→  }\n   249→}\n   250→\n   251→function makeSwappedAdder(\n   252→  n: number,\n   253→  seed: number\n   254→): { gates: Gate[]; swappedWires: string[] } {\n   255→  const gates = makeNBitAdder(n);\n   256→  const rng = mulberry32(seed);\n   257→\n   258→  // Randomize internal wire names\n   259→  randomizeWireNames(gates, rng);\n   260→\n   261→  // Pick 4 swap pairs from different bit positions\n   262→  // Each swap involves gates at distinct bit positions to avoid cascading\n   263→  const usedBits = new Set<number>();\n   264→  const swaps: Array<[number, number]> = [];\n   265→\n   266→  // Collect swappable gate indices (all gates)\n   267→  const allIndices = gates.map((_, i) => i);\n   268→\n   269→  while (swaps.length < 4) {\n   270→    const i1 = allIndices[Math.floor(rng() * allIndices.length)];\n   271→    const i2 = allIndices[Math.floor(rng() * allIndices.length)];\n   272→    if (i1 === i2) continue;\n   273→\n   274→    // Ensure these aren't already used\n   275→    if (usedBits.has(i1) || usedBits.has(i2)) continue;\n   276→\n   277→    usedBits.add(i1);\n   278→    usedBits.add(i2);\n   279→    swaps.push([i1, i2]);\n   280→  }\n   281→\n   282→  const swappedWires: string[] = [];\n   283→  for (const [i1, i2] of swaps) {\n   284→    swappedWires.push(gates[i1].out, gates[i2].out);\n   285→    const tmp = gates[i1].out;\n   286→    gates[i1].out = gates[i2].out;\n   287→    gates[i2].out = tmp;\n   288→  }\n   289→\n   290→  // Shuffle gate order\n   291→  shuffle(gates, rng);\n   292→\n   293→  return { gates, swappedWires };\n   294→}\n   295→\n   296→function makeSwappedAdderSpecific(\n   297→  n: number,\n   298→  specs: SwapSpec[]\n   299→): { gates: Gate[]; swappedWires: string[] } {\n   300→  const gates = makeNBitAdder(n);\n   301→  const rng = mulberry32(12345);\n   302→  randomizeWireNames(gates, rng);\n   303→\n   304→  const swappedWires: string[] = [];\n   305→  for (const spec of specs) {\n   306→    const i1 = getGateIndex(n, spec.bit1, spec.role1);\n   307→    const i2 = getGateIndex(n, spec.bit2, spec.role2);\n   308→    swappedWires.push(gates[i1].out, gates[i2].out);\n   309→    const tmp = gates[i1].out;\n   310→    gates[i1].out = gates[i2].out;\n   311→    gates[i2].out = tmp;\n   312→  }\n   313→\n   314→  shuffle(gates, rng);\n   315→\n   316→  return { gates, swappedWires };\n   317→}\n   318→\n   319→function randomizeWireNames(gates: Gate[], rng: () => number): void {\n   320→  const wireMap = new Map<string, string>();\n   321→  const usedNames = new Set<string>();\n   322→\n   323→  // Reserve x, y, z wire names\n   324→  for (const g of gates) {\n   325→    for (const w of [g.in1, g.in2, g.out]) {\n   326→      if (/^[xyz]\\d+$/.test(w)) {\n   327→        usedNames.add(w);\n   328→        wireMap.set(w, w);\n   329→      }\n   330→    }\n   331→  }\n   332→\n   333→  // Assign random 3-char names to internal wires\n   334→  const chars = 'abcdefghijklmnopqrstuvwxyz';\n   335→  for (const g of gates) {\n   336→    for (const w of [g.in1, g.in2, g.out]) {\n   337→      if (!wireMap.has(w)) {\n   338→        let name: string;\n   339→        do {\n   340→          name = '';\n   341→          for (let i = 0; i < 3; i++) {\n   342→            name += chars[Math.floor(rng() * chars.length)];\n   343→          }\n   344→        } while (usedNames.has(name));\n   345→        usedNames.add(name);\n   346→        wireMap.set(w, name);\n   347→      }\n   348→    }\n   349→  }\n   350→\n   351→  for (const g of gates) {\n   352→    g.in1 = wireMap.get(g.in1) ?? g.in1;\n   353→    g.in2 = wireMap.get(g.in2) ?? g.in2;\n   354→    g.out = wireMap.get(g.out) ?? g.out;\n   355→  }\n   356→}\n   357→\n   358→function shuffle<T>(arr: T[], rng: () => number): void {\n   359→  for (let i = arr.length - 1; i > 0; i--) {\n   360→    const j = Math.floor(rng() * (i + 1));\n   361→    [arr[i], arr[j]] = [arr[j], arr[i]];\n   362→  }\n   363→}\n   364→"}]},"parent_tool_use_id":null,"session_id":"0d871afd-ee83-4cad-96df-5480e45794cb","uuid":"e6cd31b8-d77b-4df3-94ec-81373aff0c6d","tool_use_result":{"type":"update","filePath":"/workspace/tests/index.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from '../src/index.js';\n\ndescribe('simulate', () => {\n  it('should simulate a simple AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'ab' },\n      { op: 'OR', in1: 'ab', in2: 'c', out: 'result' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, c: 0 })).toEqual({\n      a: 1, b: 1, c: 0, ab: 1, result: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, c: 0 })).toEqual({\n      a: 0, b: 1, c: 0, ab: 0, result: 0,\n    });\n  });\n\n  it('should handle gates listed out of dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'ab', in2: 'c', out: 'result' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'ab' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, c: 0 })).toEqual({\n      a: 1, b: 1, c: 0, ab: 1, result: 1,\n    });\n  });\n\n  it('should simulate a correct 4-bit adder', () => {\n    const gates = make4BitAdder();\n    // 3 + 5 = 8\n    expect(extractZ(simulate(gates, setInputs(4, 3, 5)), 5)).toBe(8);\n    // 15 + 15 = 30\n    expect(extractZ(simulate(gates, setInputs(4, 15, 15)), 5)).toBe(30);\n    // 7 + 9 = 16\n    expect(extractZ(simulate(gates, setInputs(4, 7, 9)), 5)).toBe(16);\n    // 0 + 0 = 0\n    expect(extractZ(simulate(gates, setInputs(4, 0, 0)), 5)).toBe(0);\n  });\n\n  it('should simulate a correct larger adder', () => {\n    const gates = makeNBitAdder(8);\n    for (let i = 0; i < 20; i++) {\n      const a = Math.floor(Math.random() * 256);\n      const b = Math.floor(Math.random() * 256);\n      const inputs = setInputs(8, a, b);\n      const result = simulate(gates.map((g) => ({ ...g })), inputs);\n      expect(extractZ(result, 9)).toBe(a + b);\n    }\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in an 8-bit adder', () => {\n    const { gates, swappedWires } = makeSwappedAdder(8, 42);\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...swappedWires].sort());\n  });\n\n  it('should find swapped wires in a 16-bit adder', () => {\n    const { gates, swappedWires } = makeSwappedAdder(16, 123);\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...swappedWires].sort());\n  });\n\n  it('should find swapped wires in a 45-bit adder', () => {\n    const { gates, swappedWires } = makeSwappedAdder(45, 999);\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...swappedWires].sort());\n  });\n\n  it('should return results sorted alphabetically', () => {\n    const { gates } = makeSwappedAdder(10, 77);\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n\n  it('should handle swaps involving z wires', () => {\n    // Swap z02 with a generate wire, z05 with a propagate wire\n    const { gates, swappedWires } = makeSwappedAdderSpecific(12, [\n      { bit1: 2, role1: 'sum', bit2: 3, role2: 'generate' },\n      { bit1: 5, role1: 'sum', bit2: 7, role2: 'propagate' },\n      { bit1: 4, role1: 'partial', bit2: 9, role2: 'carry' },\n      { bit1: 6, role1: 'generate', bit2: 10, role2: 'propagate' },\n    ]);\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8)