 priority: 11 })).toThrow();\n   144→      expect(() => queue.add('test', { priority: 1.5 })).toThrow();\n   145→    });\n   146→\n   147→    it('should expose priority on task object', () => {\n   148→      const task = queue.add('test', { priority: 3 });\n   149→      expect(task.priority).toBe(3);\n   150→    });\n   151→\n   152→    it('should maintain priority per queue', () => {\n   153→      queue.add('q1-low', { queue: 'q1', priority: 10 });\n   154→      queue.add('q1-high', { queue: 'q1', priority: 1 });\n   155→      queue.add('q2-low', { queue: 'q2', priority: 10 });\n   156→\n   157→      expect(queue.next('q1')?.payload).toBe('q1-high');\n   158→      expect(queue.next('q2')?.payload).toBe('q2-low');\n   159→    });\n   160→  });\n   161→\n   162→  // ==================== Phase 4: Delayed Tasks ====================\n   163→  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n   164→    it('should delay tasks by specified milliseconds', () => {\n   165→      queue.add('delayed', { delay: 10000 });\n   166→      expect(queue.next()).toBeNull();\n   167→      expect(queue.size()).toBe(1);\n   168→    });\n   169→\n   170→    it('should allow tasks with processAt date', () => {\n   171→      const future = new Date(Date.now() + 10000);\n   172→      const task = queue.add('scheduled', { processAt: future });\n   173→      expect(task.availableAt.getTime()).toBe(future.getTime());\n   174→      expect(queue.next()).toBeNull();\n   175→    });\n   176→\n   177→    it('should return delayed tasks once available', () => {\n   178→      const past = new Date(Date.now() - 1000);\n   179→      queue.add('past-scheduled', { processAt: past });\n   180→      expect(queue.next()?.payload).toBe('past-scheduled');\n   181→    });\n   182→\n   183→    it('should prefer non-delayed tasks over not-yet-available delayed ones', () => {\n   184→      queue.add('delayed', { delay: 10000 });\n   185→      queue.add('immediate');\n   186→\n   187→      expect(queue.next()?.payload).toBe('immediate');\n   188→    });\n   189→\n   190→    it('should indicate availability time on task', () => {\n   191→      const task = queue.add('test', { delay: 5000 });\n   192→      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n   193→    });\n   194→\n   195→    it('delayed tasks should work with named queues', () => {\n   196→      queue.add('delayed', { queue: 'myqueue', delay: 10000 });\n   197→      expect(queue.next('myqueue')).toBeNull();\n   198→      expect(queue.size('myqueue')).toBe(1);\n   199→    });\n   200→\n   201→    it('should order by availability time, then priority, then FIFO when multiple delayed tasks are available', () => {\n   202→      const past1 = new Date(Date.now() - 2000);\n   203→      const past2 = new Date(Date.now() - 1000);\n   204→\n   205→      queue.add('later-available', { processAt: past2, priority: 1 });\n   206→      queue.add('earlier-available', { processAt: past1, priority: 1 });\n   207→\n   208→      expect(queue.next()?.payload).toBe('earlier-available');\n   209→      expect(queue.next()?.payload).toBe('later-available');\n   210→    });\n   211→  });\n   212→\n   213→  // ==================== Phase 5: Retry with Backoff ====================\n   214→  describe('Phase 5: Retry with Backoff', () => {\n   215→    it('should complete a task', () => {\n   216→      queue.add('test');\n   217→      const retrieved = queue.next()!;\n   218→      queue.complete(retrieved.id);\n   219→      expect(queue.getTask(retrieved.id)?.status).toBe('completed');\n   220→    });\n   221→\n   222→    it('should re-queue a failed task with retries remaining', () => {\n   223→      queue.add('retry-me', { maxRetries: 3, backoffDelay: 100 });\n   224→      const retrieved = queue.next()!;\n   225→      queue.fail(retrieved.id, 'some error');\n   226→\n   227→      const updatedTask = queue.getTask(retrieved.id)!;\n   228→      expect(updatedTask.status).toBe('pending');\n   229→      expect(updatedTask.attempt).toBe(1);\n   230→      expect(updatedTask.error).toBe('some error');\n   231→      expect(updatedTask.availableAt.getTime()).toBeGreaterThan(Date.now());\n   232→    });\n   233→\n   234→    it('should apply exponential backoff', () => {\n   235→      queue.add('retry-me', { maxRetries: 3, backoffDelay: 1000 });\n   236→      const r1 = queue.next()!;\n   237→      const failTime1 = Date.now();\n   238→      queue.fail(r1.id, 'error1');\n   239→      const t1 = queue.getTask(r1.id)!;\n   240→      // backoff = 1000 * 2^(1-1) = 1000ms\n   241→      expect(t1.availableAt.getTime()).toBeGreaterThanOrEqual(failTime1 + 900);\n   242→      expect(t1.availableAt.getTime()).toBeLessThanOrEqual(failTime1 + 1200);\n   243→    });\n   244→\n   245→    it('should default maxRetries to 3', () => {\n   246→      const task = queue.add('test');\n   247→      expect(task.maxRetries).toBe(3);\n   248→    });\n   249→\n   250→    it('should default backoffDelay to 1000ms', () => {\n   251→      const task = queue.add('test');\n   252→      expect(task.backoffDelay).toBe(1000);\n   253→    });\n   254→\n   255→    it('should allow configurable maxRetries and backoffDelay', () => {\n   256→      const task = queue.add('test', { maxRetries: 5, backoffDelay: 500 });\n   257→      expect(task.maxRetries).toBe(5);\n   258→      expect(task.backoffDelay).toBe(500);\n   259→    });\n   260→\n   261→    it('should track attempt count', () => {\n   262→      queue.add('test', { maxRetries: 3, backoffDelay: 0 });\n   263→      const r1 = queue.next()!;\n   264→      expect(r1.attempt).toBe(1);\n   265→    });\n   266→\n   267→    it('should remain failed when retries exhausted', () => {\n   268→      queue.add('doomed', { maxRetries: 1, backoffDelay: 0 });\n   269→      const r1 = queue.next()!;\n   270→      queue.fail(r1.id, 'error');\n   271→      expect(queue.getTask(r1.id)?.status).toBe('failed');\n   272→    });\n   273→\n   274→    it('should keep original queue and priority on