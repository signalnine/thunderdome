9→      }\n   100→    }\n   101→\n   102→    const now = new Date();\n   103→\n   104→    // Find the best candidate: highest priority (lowest number), then earliest creation\n   105→    let bestTask: Task | null = null;\n   106→\n   107→    for (let i = 0; i < taskIds.length; i++) {\n   108→      const task = this.tasks.get(taskIds[i]);\n   109→      if (!task || task.status !== 'pending') continue;\n   110→\n   111→      // Check availability time\n   112→      if (task.availableAt > now) continue;\n   113→\n   114→      // Check dependencies\n   115→      if (!this.areDependenciesMet(task)) continue;\n   116→\n   117→      if (\n   118→        bestTask === null ||\n   119→        task.priority < bestTask.priority ||\n   120→        (task.priority === bestTask.priority && task.availableAt < bestTask.availableAt) ||\n   121→        (task.priority === bestTask.priority && task.availableAt.getTime() === bestTask.availableAt.getTime() && task.createdAt < bestTask.createdAt)\n   122→      ) {\n   123→        bestTask = task;\n   124→      }\n   125→    }\n   126→\n   127→    if (bestTask === null) {\n   128→      return null;\n   129→    }\n   130→\n   131→    bestTask.status = 'processing';\n   132→    bestTask.attempt += 1;\n   133→    return bestTask;\n   134→  }\n   135→\n   136→  // Phase 1: Get pending count\n   137→  size(queueName: string = DEFAULT_QUEUE): number {\n   138→    const taskIds = this.queues.get(queueName);\n   139→    if (!taskIds) return 0;\n   140→    return taskIds.filter(id => {\n   141→      const t = this.tasks.get(id);\n   142→      return t && t.status === 'pending';\n   143→    }).length;\n   144→  }\n   145→\n   146→  // Phase 2: List queue names\n   147→  getQueues(): string[] {\n   148→    return Array.from(this.queues.keys());\n   149→  }\n   150→\n   151→  // Phase 5: Complete a task\n   152→  complete(taskId: string): void {\n   153→    const task = this.tasks.get(taskId);\n   154→    if (!task) {\n   155→      throw new Error(`Task