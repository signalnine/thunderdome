tterQueue()).toHaveLength(1);\n   323→\n   324→      const retried = queue.retryDeadLetter(task.id);\n   325→      expect(retried.status).toBe('pending');\n   326→      expect(retried.attempt).toBe(0);\n   327→      expect(queue.getDeadLetterQueue()).toHaveLength(0);\n   328→      expect(queue.size()).toBe(1);\n   329→    });\n   330→\n   331→    it('should clear dead letter queue', () => {\n   332→      const t1 = queue.add('doomed1', { maxRetries: 1, backoffDelay: 0 });\n   333→      const t2 = queue.add('doomed2', { maxRetries: 1, backoffDelay: 0 });\n   334→      queue.next()!;\n   335→      queue.fail(t1.id, 'err1');\n   336→      queue.next()!;\n   337→      queue.fail(t2.id, 'err2');\n   338→\n   339→      expect(queue.getDeadLetterQueue()).toHaveLength(2);\n   340→      queue.clearDeadLetterQueue();\n   341→      expect(queue.getDeadLetterQueue()).toHaveLength(0);\n   342→    });\n   343→\n   344→    it('should have independent DLQs per named queue', () => {\n   345→      const t1 = queue.add('d1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n   346→      const t2 = queue.add('d2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n   347→      queue.next('q1')!;\n   348→      queue.fail(t1.id, 'err');\n   349→      queue.next('q2')!;\n   350→      queue.fail(t2.id, 'err');\n   351→\n   352→      expect(queue.getDeadLetterQueue('q1')).toHaveLength(1);\n   353→      expect(queue.getDeadLetterQueue('q2')).toHaveLength(1);\n   354→    });\n   355→\n   356→    it('should throw when retrying non-existent DLQ task', () => {\n   357→      expect(() => queue.retryDeadLetter('nonexistent')).toThrow();\n   358→    });\n   359→  });\n   360→\n   361→  // ==================== Phase 7: Task Dependencies ====================\n   362→  describe('Phase 7: Task Dependencies', () => {\n   363→    it('should block a task with unresolved dependencies', () => {\n   364→      const dep = queue.add('dependency');\n   365→      queue.add('dependent', { dependencies: [dep.id] });\n   366→\n   367→      const next = queue.next();\n   368→      expect(next?.id).toBe(dep.id);\n   369→      expect(queue.next()).toBeNull();\n   370→    });\n   371→\n   372→    it('should unblock a task when dependencies complete', () => {\n   373→      const dep = queue.add('dependency');\n   374→      const dependent = queue.add('dependent', { dependencies: [dep.id] });\n   375→\n   376→      const first = queue.next()!;\n   377→      queue.complete(first.id);\n   378→\n   379→      const second = queue.next();\n   380→      expect(second?.id).toBe(dependent.id);\n   381→    });\n   382→\n   383→    it('should throw when depending on non-existent task', () => {\n   384→      expect(() => queue.add('test', { dependencies: ['nonexistent'] })).toThrow();\n   385→    });\n   386→\n   387→    it('should keep dependents blocked when dependency fails', () => {\n   388→      const dep = queue.add('dependency', { maxRetries: 1, backoffDelay: 0 });\n   389→      queue.add('dependent', { dependencies: [dep.id] });\n   390→\n   391→      const first = queue.next()!;\n   392→      queue.fail(first.id, 'error');\n   393→\n   394→      expect(queue.next()).toBeNull();\n   395→    });\n   396→\n   397→    it('should get dependency status', () => {\n   398→      const dep1 = queue.add('dep1');\n   399→      const dep2 = queue.add('dep2');\n   400→      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n   401→\n   402→      const status = queue.getDependencyStatus(dependent.id);\n   403→      expect(status.total).toBe(2);\n   404→      expect(status.completed).toBe(0);\n   405→      expect(status.pending).toContain(dep1.id);\n   406→      expect(status.pending).toContain(dep2.id);\n   407→\n   408→      queue.next()!;\n   409→      queue.complete(dep1.id);\n   410→\n   411→      const status2 = queue.getDependencyStatus(dependent.id);\n   412→      expect(status2.completed).toBe(1);\n   413→      expect(status2.pending).toHaveLength(1);\n   414→    });\n   415→\n   416→    it('should support multiple dependencies', () => {\n   417→      const dep1 = queue.add('dep1');\n   418→      const dep2 = queue.add('dep2');\n   419→      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n   420→\n   421→      let t = queue.next()!;\n   422→      queue.complete(t.id);\n   423→      t = queue.next()!;\n   424→      queue.complete(t.id);\n   425→\n   426→      const next = queue.next();\n   427→      expect(next?.id).toBe(dependent.id);\n   428→    });\n   429→\n   430→    it('should expose dependencies on task object', () => {\n   431→      const dep = queue.add('dep');\n   432→      const task = queue.add('task', { dependencies: [dep.id] });\n   433→      expect(task.dependencies).toContain(dep.id);\n   434→    });\n   435→  });\n   436→\n   437→  // ==================== Phase 8: Concurrency Control ====================\n   438→  describe('Phase 8: Concurrency Control', () => {\n   439→    it('should limit concurrent processing tasks', () => {\n   440→      queue.setConcurrency('default', 2);\n   441→      queue.add('t1');\n   442→      queue.add('t2');\n   443→      queue.add('t3');\n   444→\n   445→      expect(queue.next()).not.toBeNull();\n   446→      expect(queue.next()).not.toBeNull();\n   447→      expect(queue.next()).toBeNull();\n   448→    });\n   449→\n   450→    it('should free slot on completion', () => {\n   451→      queue.setConcurrency('default', 1);\n   452→      queue.add('t1');\n   453→      queue.add('t2');\n   454→\n   455→      const first = queue.next()!;\n   456→      expect(queue.next()).toBeNull();\n   457→\n   458→      queue.complete(first.id);\n   459→      expect(queue.next()).not.toBeNull();\n   460→    });\n   461→\n   462→    it('should free slot on failure', () => {\n   463→      queue.setConcurrency('default', 1);\n   464→      queue.add('t1', { maxRetries: 1, backoffDelay: 0 });\n   465→      queue.add('t2');\n   466→\n   467→      const first = queue.next()!;\n   468→      expect(queue.next()).toBeNull();\n   469→\n   470→      queue.fail(first.id, 'err');\n   471→      expect(queue.next()).not.toBeNull();\n   472→    });\n   473→\n   474→    it('should have unlimited concurrency by default', () => {\n   475→      expect(queue.getConcurrency('default')).toBeUndefined();\n   476→\n   477→      for (let i = 0; i < 100; i++) {\n   478→        queue.add(`t${i}`);\n   479→      }\n   480→      for (let i = 0; i < 100; i++) {\n   481→        expect(queue.next()).not.toBeNull();\n   482→      }\n   483→    });\n   484→\n   485→    it('should report active count', () => {\n   486→      queue.add('t1');\n   487→      queue.add('t2');\n   488→      expect(queue.getActiveCount()).toBe(0);\n   489→\n   490→      queue.next();\n   491→      expect(queue.getActiveCount()).toBe(1);\n   492→\n   493→      queue.next();\n   494→      expect(queue.getActiveCount()).toBe(2);\n   495→    });\n   496→\n   497→    it('should still respect priority with concurrency limits', () => {\n   498→      queue.setConcurrency('default', 1);\n   499→      queue.add('low', { priority: 10 });\n   500→      queue.add('high', { priority: 1 });\n   501→\n   502→      expect(queue.next()?.payload).toBe('high');\n   503→    });\n   504→  });\n   505→\n   506→  // ==================== Phase 9: Progress and Cancellation ====================\n   507→  describe('Phase 9: Progress Tracking and Cancellation', () => {\n   508→    it('should report progress on a processing task', () => {\n   509→      queue.add('test');\n   510→      const processing = queue.next()!;\n   511→\n   512→      queue.reportProgress(processing.id, 50, 'halfway');\n   513→      const progress = queue.getProgress(processing.id);\n   514→      expect(progress.progress).toBe(50);\n   515→      expect(progress.message).toBe('halfway');\n   516→    });\n   517→\n   518→    it('should notify progress listeners', () => {\n   519→      queue.add('test');\n   520→      const processing = queue.next()!;\n   521→\n   522→      const updates: number[] = [];\n   523→      queue.onProgress(processing.id, (update) => {\n   524→        updates.push(update.progress);\n   525→      });\n   526→\n   527→      queue.reportProgress(processing.id, 25);\n   528→      queue.reportProgress(processing.id, 50);\n   529→      queue.reportProgress(processing.id, 75);\n   530→\n   531→      expect(updates).toEqual([25, 50, 75]);\n   532→    });\n   533→\n   534→    it('should support unsubscribing from progress', () => {\n   535→      queue.add('test');\n   536→      const processing = queue.next()!;\n   537→\n   538→      const updates: number[] = [];\n   539→      const unsub = queue.onProgress(processing.id, (update) => {\n   540→        updates.push(update.progress);\n   541→      });\n   542→\n   543→      queue.reportProgress(processing.id, 25);\n   544→      unsub();\n   545→      queue.reportProgress(processing.id, 50);\n   546→\n   547→      expect(updates).toEqual([25]);\n   548→    });\n   549→\n   550→    it('should cancel a pending task', () => {\n   551→      const task = queue.add('cancel-me');\n   552→      queue.cancel(task.id);\n   553→\n   554→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   555→      expect(queue.next()).toBeNull();\n   556→    });\n   557→\n   558→    it('should cancel a processing task', () => {\n   559→      const task = queue.add('cancel-me');\n   560→      queue.next()!;\n   561→      queue.cancel(task.id);\n   562→\n   563→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   564→    });\n   565→\n   566→    it('should not retry cancelled tasks', () => {\n   567→      const task = queue.add('cancel-me', { maxRetries: 3 });\n   568→      queue.next()!;\n   569→      queue.cancel(task.id);\n   570→\n   571→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   572→      expect(queue.getTask(task.id)?.maxRetries).toBe(0);\n   573→    });\n   574→\n   575→    it('should throw when cancelling completed task', () => {\n   576→      const task = queue.add('test');\n   577→      queue.next()!;\n   578→      queue.complete(task.id);\n   579→      expect(() => queue.cancel(task.id)).toThrow();\n   580→    });\n   581→\n   582→    it('should throw when reporting progress on non-processing task', () => {\n   583→      const task = queue.add('test');\n   584→      expect(() => queue.reportProgress(task.id, 50)).toThrow();\n   585→    });\n   586→\n   587→    it('should reject invalid progress values', () => {\n   588→      const task = queue.add('test');\n   589→      queue.next()!;\n   590→      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n   591→      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n   592→    });\n   593→  });\n   594→\n   595→  // ==================== Phase 10: Recurring Tasks ====================\n   596→  describe('Phase 10: Recurring Tasks', () => {\n   597→    it('should create a schedule', () => {\n   598→      const schedule = queue.addSchedule('cleanup', '*/5 * * * *', 'default', { type: 'cleanup' });\n   599→      expect(schedule.id).toBe('cleanup');\n   600→      expect(schedule.expression).toBe('*/5 * * * *');\n   601→    });\n   602→\n   603→    it('should list schedules', () => {\n   604→      queue.addSchedule('s1', '*/5 * * * *', 'default', {});\n   605→      queue.addSchedule('s2', '0 * * * *', 'default', {});\n   606→\n   607→      const schedules = queue.listSchedules();\n   608→      expect(schedules).toHaveLength(2);\n   609→    });\n   610→\n   611→    it('should remove a schedule', () => {\n   612→      queue.addSchedule('s1', '*/5 * * * *', 'default', {});\n   613→      expect(queue.removeSchedule('s1')).toBe(true);\n   614→      expect(queue.listSchedules()).toHaveLength(0);\n   615→    });\n   616→\n   617→    it('should enqueue tasks on tick when due', () => {\n   618→      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'scheduled' });\n   619→\n   620→      const now = new Date(2024, 0, 1, 12, 0, 0);\n   621→      const tasks = queue.tick(now);\n   622→      expect(tasks).toHaveLength(1);\n   623→      expect(tasks[0].payload).toEqual({ type: 'scheduled' });\n   624→    });\n   625→\n   626→    it('should not enqueue if not due', () => {\n   627→      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'scheduled' });\n   628→\n   629→      const now = new Date(2024, 0, 1, 12, 3, 0);\n   630→      const tasks = queue.tick(now);\n   631→      expect(tasks).toHaveLength(0);\n   632→    });\n   633→\n   634→    it('should not double-enqueue at the same time', () => {\n   635→      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'scheduled' });\n   636→\n   637→      const now = new Date(2024, 0, 1, 12, 0, 0);\n   638→      queue.tick(now);\n   639→      const tasks = queue.tick(now);\n   640→      expect(tasks).toHaveLength(0);\n   641→    });\n   642→\n   643→    it('should not create tasks after schedule is removed', () => {\n   644→      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'scheduled' });\n   645→      queue.removeSchedule('every5');\n   646→\n   647→      const now = new Date(2024, 0, 1, 12, 0, 0);\n   648→      const tasks = queue.tick(now);\n   649→      expect(tasks).toHaveLength(0);\n   650→    });\n   651→\n   652→    it('should support hourly schedule', () => {\n   653→      queue.addSchedule('hourly', '0 * * * *', 'default', { type: 'hourly' });\n   654→\n   655→      const atHour = new Date(2024, 0, 1, 14, 0, 0);\n   656→      expect(queue.tick(atHour)).toHaveLength(1);\n   657→\n   658→      const notAtHour = new Date(2024, 0, 1, 14, 30, 0);\n   659→      expect(queue.tick(notAtHour)).toHaveLength(0);\n   660→    });\n   661→\n   662→    it('should support daily schedule', () => {\n   663→      queue.addSchedule('daily', '0 0 * * *', 'default', { type: 'daily' });\n   664→\n   665→      const midnight = new Date(2024, 0, 1, 0, 0, 0);\n   666→      expect(queue.tick(midnight