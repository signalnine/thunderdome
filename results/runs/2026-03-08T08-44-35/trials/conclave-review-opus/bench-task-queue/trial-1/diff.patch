l1', { queue: 'emails' });\n      queue.add('sms1', { queue: 'sms' });\n\n      expect(queue.next('emails')?.payload).toBe('email1');\n      expect(queue.next('emails')).toBeNull();\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queue: 'q1' });\n      queue.add('b', { queue: 'q2' });\n      const names = queue.getQueues();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should create queue implicitly when adding tasks', () => {\n      queue.add('task', { queue: 'new-queue' });\n      expect(queue.getQueues()).toContain('new-queue');\n    });\n  });\n\n  // ==================== Phase 3: Priority ====================\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = queue.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 3 });\n      queue.add('second', { priority: 3 });\n      queue.add('third', { priority: 3 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.add('test', { priority: 0 })).toThrow();\n      expect(() => queue.add('test', { priority: 11 })).toThrow();\n      expect(() => queue.add('test