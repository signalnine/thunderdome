 }\n    return tasks;\n  }\n\n  private async waitForTasksToComplete(tasks: Task[]): Promise<void> {\n    // Poll until all tasks are done\n    while (tasks.some(t => t.status === 'processing')) {\n      await new Promise(resolve => setTimeout(resolve, 50));\n    }\n  }\n\n  // Helper: Get a task by ID\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // Helper: Check if shutting down\n  get shuttingDown(): boolean {\n    return this.isShuttingDown;\n  }\n}\n","structuredPatch":[{"oldStart":577,"oldLines":7,"newStart":577,"newLines":6,"lines":[" ","   private async performShutdown(timeout: number): Promise<ShutdownResult> {","     const startTime = Date.now();","-    let completed = 0;","     let forceCancelled = 0;"," ","     // Run shutdown callbacks"]},{"oldStart":585,"oldLines":7,"newStart":584,"newLines":7,"lines":["       await cb();","     }"," ","-    // Wait for processing tasks to complete","+    // Snapshot the processing tasks at shutdown time","     const processingTasks = this.getProcessingTasks();"," ","     if (processingTasks.length > 0) {"]},{"oldStart":605,"oldLines":12,"newStart":604,"newLines":8,"lines":["       }","     }"," ","-    // Count completed tasks","-    for (const task of this.tasks.values()) {","-      if (task.status === 'completed') {","-        completed++;","-      }","-    }","+    // Count tasks from the snapshot that completed during shutdown","+    const completed = processingTasks.filter(t => t.status === 'completed').length;"," ","     const duration = Date.now() - startTime;"," "]}],"userModified":false,"replaceAll":false}}
