+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C8YuPAWKM322ySUHqeE9Lv","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from './task-queue.js';\n     3→\n     4→describe('TaskQueue', () => {\n     5→  let queue: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    queue = new TaskQueue();\n     9→  });\n    10→\n    11→  // ==================== Phase 1: Basic FIFO Queue ====================\n    12→  describe('Phase 1: Basic FIFO Queue', () => {\n    13→    it('should add a task and return a task object', () => {\n    14→      const task = queue.add({ message: 'hello' });\n    15→      expect(task).toBeDefined();\n    16→      expect(task.id).toBeDefined();\n    17→      expect(task.payload).toEqual({ message: 'hello' });\n    18→      expect(task.status).toBe('pending');\n    19→      expect(task.createdAt).toBeInstanceOf(Date);\n    20→    });\n    21→\n    22→    it('should assign unique IDs to tasks', () => {\n    23→      const t1 = queue.add('task1');\n    24→      const t2 = queue.add('task2');\n    25→      expect(t1.id).not.toBe(t2.id);\n    26→    });\n    27→\n    28→    it('should retrieve tasks in FIFO order', () => {\n    29→      queue.add('first');\n    30→      queue.add('second');\n    31→      queue.add('third');\n    32→\n    33→      expect(queue.next()?.payload).toBe('first');\n    34→      expect(queue.next()?.payload).toBe('second');\n    35→      expect(queue.next()?.payload).toBe('third');\n    36→    });\n    37→\n    38→    it('should transition task to processing on retrieval', () => {\n    39→      const added = queue.add('test');\n    40→      const retrieved = queue.next();\n    41→      expect(retrieved?.id).toBe(added.id);\n    42→      expect(retrieved?.status).toBe('processing');\n    43→    });\n    44→\n    45→    it('should return null when no tasks are available', () => {\n    46→      expect(queue.next()).toBeNull();\n    47→    });\n    48→\n    49→    it('should return null after all tasks are retrieved', () => {\n    50→      queue.add('only');\n    51→      queue.next();\n    52→      expect(queue.next()).toBeNull();\n    53→    });\n    54→\n    55→    it('should report the number of pending tasks', () => {\n    56→      expect(queue.size()).toBe(0);\n    57→      queue.add('a');\n    58→      queue.add('b');\n    59→      expect(queue.size()).toBe(2);\n    60→      queue.next();\n    61→      expect(queue.size()).toBe(1);\n    62→    });\n    63→\n    64→    it('should track attempt count', () => {\n    65→      queue.add('test');\n    66→      const retrieved = queue.next();\n    67→      expect(retrieved?.attempt).toBe(1);\n    68→    });\n    69→  });\n    70→\n    71→  // ==================== Phase 2: Named Queues ====================\n    72→  describe('Phase 2: Named Queues', () => {\n    73→    it('should add tasks to a specific named queue', () => {\n    74→      queue.add('email', { queue: 'emails' });\n    75→      queue.add('sms', { queue: 'sms' });\n    76→\n    77→      expect(queue.size('emails')).toBe(1);\n    78→      expect(queue.size('sms')).toBe(1);\n    79→    });\n    80→\n    81→    it('should use default queue when no name given', () => {\n    82→      queue.add('default-task');\n    83→      expect(queue.size()).toBe(1);\n    84→      expect(queue.size('default')).toBe(1);\n    85→    });\n    86→\n    87→    it('should retrieve tasks from specified queue only', () => {\n    88→      queue.add('email1', { queue: 'emails' });\n    89→      queue.add('sms1', { queue: 'sms' });\n    90→\n    91→      expect(queue.next('emails')?.payload).toBe('email1');\n    92→      expect(queue.next('emails')).toBeNull();\n    93→      expect(queue.size('sms')).toBe(1);\n    94→    });\n    95→\n    96→    it('should list all queue names', () => {\n    97→      queue.add('a', { queue: 'q1' });\n    98→      queue.add('b', { queue: 'q2' });\n    99→      const names = queue.getQueues();\n   100→      expect(names).toContain('q1');\n   101→      expect(names).toContain('q2');\n   102→    });\n   103→\n   104→    it('should return null for non-existent queue', () => {\n   105→      expect(queue.next('nonexistent')).toBeNull();\n   106→    });\n   107→\n   108→    it('should create queue implicitly when adding tasks', () => {\n   109→      queue.add('task', { queue: 'new-queue' });\n   110→      expect(queue.getQueues()).toContain('new-queue');\n   111→    });\n   112→  });\n   113→\n   114→  // ==================== Phase 3: Priority ====================\n   115→  describe('Phase 3: Priority', () => {\n   116→    it('should default priority to 5', () => {\n   117→      const task = queue.add('test');\n   118→      expect(task.priority).toBe(5);\n   119→    });\n   120→\n   121→    it('should return higher-priority tasks first', () => {\n   122→      queue.add('low', { priority: 10 });\n   123→      queue.add('high', { priority: 1 });\n   124→      queue.add('medium', { priority: 5 });\n   125→\n   126→      expect(queue.next()?.payload).toBe('high');\n   127→      expect(queue.next()?.payload).toBe('medium');\n   128→      expect(queue.next()?.payload).toBe('low');\n   129→    });\n   130→\n   131→    it('should maintain FIFO within same priority', () => {\n   132→      queue.add('first', { priority: 3 });\n   133→      queue.add('second', { priority: 3 });\n   134→      queue.add('third', { priority: 3 });\n   135→\n   136→      expect(queue.next()?.payload).toBe('first');\n   137→      expect(queue.next()?.payload).toBe('second');\n   138→      expect(queue.next()?.payload).toBe('third');\n   139→    });\n   140→\n   141→    it('should reject invalid priority values', () => {\n   142→      expect(() => queue.add('test', { priority: 0 })).toThrow();\n   143→      expect(() => queue.add('test', { priority: 11 })).toThrow();\n   144→      expect(() => queue.add('test', { priority: 1.5 })).toThrow();\n   145→    });\n   146→\n   147→    it('should expose priority on task object', () => {\n   148→      const task = queue.add('test', { priority: 3 });\n   149→      expect(task.priority).toBe(3);\n   150→    });\n   151→\n   152→    it('should maintain priority per queue', () => {\n   153→      queue.add('q1-low', { queue: 'q1', priority: 10 });\n   154→      queue.add('q1-high', { queue: 'q1', priority: 1 });\n   155→      queue.add('q2-low', { queue: 'q2', priority: 10 });\n   156→\n   157→      expect(queue.next('q1')?.payload).toBe('q1-high');\n   158→      expect(queue.next('q2')?.payload).toBe('q2-low');\n   159→    });\n   160→  });\n   161→\n   162→  // ==================== Phase 4: Delayed Tasks ====================\n   163→  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n   164→    it('should delay tasks by specified milliseconds', () => {\n   165→      queue.add('delayed', { delay: 10000 });\n   166→      expect(queue.next()).toBeNull();\n   167→      expect(queue.size()).toBe(1);\n   168→    });\n   169→\n   170→    it('should allow tasks with processAt date', () => {\n   171→      const future = new Date(Date.now() + 10000);\n   172→      const task = queue.add('scheduled', { processAt: future });\n   173→      expect(task.availableAt.getTime()).toBe(future.getTime());\n   174→      expect(queue.next()).toBeNull();\n   175→    });\n   176→\n   177→    it('should return delayed tasks once available', () => {\n   178→      const past = new Date(Date.now() - 1000);\n   179→      queue.add('past-scheduled', { processAt: past });\n   180→      expect(queue.next()?.payload).toBe('past-scheduled');\n   181→    });\n   182→\n   183→    it('should prefer non-delayed tasks over not-yet-available delayed ones', () => {\n   184→      queue.add('delayed', { delay: 10000 });\n   185→      queue.add('immediate');\n   186→\n   187→      expect(queue.next()?.payload).toBe('immediate');\n   188→    });\n   189→\n   190→    it('should indicate availability time on task', () => {\n   191→      const task = queue.add('test', { delay: 5000 });\n   192→      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n   193→    });\n   194→\n   195→    it('delayed tasks should work with named queues', () => {\n   196→      queue.add('delayed', { queue: 'myqueue', delay: 10000 });\n   197→      expect(queue.next('myqueue')).toBeNull();\n   198→      expect(queue.size('myqueue')).toBe(1);\n   199→    });\n   200→\n   201→    it('should order by availability time, then priority, then FIFO when multiple delayed tasks are available', () => {\n   202→      const past1 = new Date(Date.now() - 2000);\n   203→      const past2 = new Date(Date.now() - 1000);\n   204→\n   205→      queue.add('later-available', { processAt: past2, priority: 1 });\n   206→      queue.add('earlier-available', { processAt: past1, priority: 1 });\n   207→\n   208→      expect(queue.next()?.payload).toBe('earlier-available');\n   209→      expect(queue.next()?.payload).toBe('later-available');\n   210→    });\n   211→  });\n   212→\n   213→  // ==================== Phase 5: Retry with Backoff ====================\n   214→  describe('Phase 5: Retry with Backoff', () => {\n   215→    it('should complete a task', () => {\n   216→      queue.add('test');\n   217→      const retrieved = queue.next()!;\n   218→      queue.complete(retrieved.id);\n   219→      expect(queue.getTask(retrieved.id)?.status).toBe('completed');\n   220→    });\n   221→\n   222→    it('should re-queue a failed task with retries remaining', () => {\n   223→      queue.add('retry-me', { maxRetries: 3, backoffDelay: 100 });\n   224→      const retrieved = queue.next()!;\n   225→      queue.fail(retrieved.id, 'some error');\n   226→\n   227→      const updatedTask = queue.getTask(retrieved.id)!;\n   228→      expect(updatedTask.status).toBe('pending');\n   229→      expect(updatedTask.attempt).toBe(1);\n   230→      expect(updatedTask.error).toBe('some error');\n   231→      expect(updatedTask.availableAt.getTime()).toBeGreaterThan(Date.now());\n   232→    });\n   233→\n   234→    it('should apply exponential backoff', () => {\n   235→      queue.add('retry-me', { maxRetries: 3, backoffDelay: 1000 });\n   236→      const r1 = queue.next()!;\n   237→      const failTime1 = Date.now();\n   238→      queue.fail(r1.id, 'error1');\n   239→      const t1 = queue.getTask(r1.id)!;\n   240→      // backoff = 1000 * 2^(1-1) = 1000ms\n   241→      expect(t1.availableAt.getTime()).toBeGreaterThanOrEqual(failTime1 + 900);\n   242→      expect(t1.availableAt.getTime()).toBeLessThanOrEqual(failTime1 + 1200);\n   243→    });\n   244→\n   245→    it('should default maxRetries to 3', () => {\n   246→      const task = queue.add('test');\n   247→      expect(task.maxRetries).toBe(3);\n   248→    });\n   249→\n   250→    it('should default backoffDelay to 1000ms', () => {\n   251→      const task = queue.add('test');\n   252→      expect(task.backoffDelay).toBe(1000);\n   253→    });\n   254→\n   255→    it('should allow configurable maxRetries and backoffDelay', () => {\n   256→      const task = queue.add('test', { maxRetries: 5, backoffDelay: 500 });\n   257→      expect(task.maxRetries).toBe(5);\n   258→      expect(task.backoffDelay).toBe(500);\n   259→    });\n   260→\n   261→    it('should track attempt count', () => {\n   262→      queue.add('test', { maxRetries: 3, backoffDelay: 0 });\n   263→      const r1 = queue.next()!;\n   264→      expect(r1.attempt).toBe(1);\n   265→    });\n   266→\n   267→    it('should remain failed when retries exhausted', () => {\n   268→      queue.add('doomed', { maxRetries: 1, backoffDelay: 0 });\n   269→      const r1 = queue.next()!;\n   270→      queue.fail(r1.id, 'error');\n   271→      expect(queue.getTask(r1.id)?.status).toBe('failed');\n   272→    });\n   273→\n   274→    it('should keep original queue and priority on retry', () => {\n   275→      queue.add('retry', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n   276→      const