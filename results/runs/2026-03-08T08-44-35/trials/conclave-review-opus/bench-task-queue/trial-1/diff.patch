+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Ai9289CFHZARDcSdLYHDL","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import type {\n     3→  Task,\n     4→  TaskOptions,\n     5→  ProgressUpdate,\n     6→  ProgressListener,\n     7→  CronSchedule,\n     8→  MiddlewareFn,\n     9→  HandlerFn,\n    10→  ShutdownResult,\n    11→  DeadLetteredTask,\n    12→} from './types.js';\n    13→\n    14→const DEFAULT_QUEUE = 'default';\n    15→\n    16→export class TaskQueue {\n    17→  private tasks: Map<string, Task> = new Map();\n    18→  private queues: Map<string, string[]> = new Map(); // queueName -> taskIds in insertion order\n    19→  private deadLetterQueues: Map<string, DeadLetteredTask[]> = new Map();\n    20→  private concurrencyLimits: Map<string, number> = new Map();\n    21→  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n    22→  private schedules: Map<string, CronSchedule> = new Map();\n    23→  private middlewareStacks: Map<string, MiddlewareFn[]> = new Map();\n    24→  private handlers: Map<string, HandlerFn> = new Map();\n    25→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    26→  private isShuttingDown = false;\n    27→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    28→\n    29→  // Phase 1: Add a task\n    30→  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    31→    if (this.isShuttingDown) {\n    32→      throw new Error('Queue system is shutting down, cannot add new tasks');\n    33→    }\n    34→\n    35→    const queueName = options.queue ?? DEFAULT_QUEUE;\n    36→    const priority = options.priority ?? 5;\n    37→\n    38→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    39→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    40→    }\n    41→\n    42→    // Validate dependencies\n    43→    if (options.dependencies) {\n    44→      for (const depId of options.dependencies) {\n    45→        if (!this.tasks.has(depId)) {\n    46→          throw new Error(`Dependency task not found: ${depId}`);\n    47→        }\n    48→      }\n    49→    }\n    50→\n    51→    const now = new Date();\n    52→    let availableAt = now;\n    53→\n    54→    if (options.processAt) {\n    55→      availableAt = options.processAt;\n    56→    } else if (options.delay != null && options.delay > 0) {\n    57→      availableAt = new Date(now.getTime() + options.delay);\n    58→    }\n    59→\n    60→    const task: Task<T> = {\n    61→      id: randomUUID(),\n    62→      payload,\n    63→      status: 'pending',\n    64→      queue: queueName,\n    65→      priority,\n    66→      createdAt: now,\n    67→      availableAt,\n    68→      attempt: 0,\n    69→      maxRetries: options.maxRetries ?? 3,\n    70→      backoffDelay: options.backoffDelay ?? 1000,\n    71→      dependencies: options.dependencies ? [...options.dependencies] : [],\n    72→      progress: 0,\n    73→    };\n    74→\n    75→    this.tasks.set(task.id, task as Task);\n    76→\n    77→    // Ensure queue exists\n    78→    if (!this.queues.has(queueName)) {\n    79→      this.queues.set(queueName, []);\n    80→    }\n    81→    this.queues.get(queueName)!.push(task.id);\n    82→\n    83→    return task;\n    84→  }\n    85→\n    86→  // Phase 1: Retrieve next task (FIFO, respecting priority, delay, dependencies, concurrency)\n    87→  next(queueName: string = DEFAULT_QUEUE): Task | null {\n    88→    const taskIds = this.queues.get(queueName);\n    89→    if (!taskIds || taskIds.length === 0) {\n    90→      return null;\n    91→    }\n    92→\n    93→    // Check concurrency limit\n    94→    const limit = this.concurrencyLimits.get(queueName);\n    95→    if (limit !== undefined) {\n    96→      const activeCount = this.getActiveCount(queueName);\n    97→      if (activeCount >= limit) {\n    98→        return null;\n    99→      }\n   100→    }\n   101→\n   102→    const now = new Date();\n   103→\n   104→    // Find the best candidate: highest priority (lowest number), then earliest creation\n   105→    let bestTask: Task | null = null;\n   106→\n   107→    for (let i = 0; i < taskIds.length; i++) {\n   108→      const task = this.tasks.get(taskIds[i]);\n   109→      if (!task || task.status !== 'pending') continue;\n   110→\n   111→      // Check availability time\n   112→      if (task.availableAt > now) continue;\n   113→\n   114→      // Check dependencies\n   115→      if (!this.areDependenciesMet(task)) continue;\n   116→\n   117→      if (\n   118→        bestTask === null ||\n   119→        task.priority < bestTask.priority ||\n   120→        (task.priority === bestTask.priority && task.availableAt < bestTask.availableAt) ||\n   121→        (task.priority === bestTask.priority && task.availableAt.getTime() === bestTask.availableAt.getTime() && task.createdAt < bestTask.createdAt)\n   122→      ) {\n   123→        bestTask = task;\n   124→      }\n   125→    }\n   126→\n   127→    if (bestTask === null) {\n   128→      return null;\n   129→    }\n   130→\n   131→    bestTask.status = 'processing';\n   132→    bestTask.attempt += 1;\n   133→    return bestTask;\n   134→  }\n   135→\n   136→  // Phase 1: Get pending count\n   137→  size(queueName: string = DEFAULT_QUEUE): number {\n   138→    const taskIds = this.queues.get(queueName);\n   139→    if (!taskIds) return 0;\n   140→    return taskIds.filter(id => {\n   141→      const t = this.tasks.get(id);\n   142→      return t && t.status === 'pending';\n   143→    }).length;\n   144→  }\n   145→\n   146→  // Phase 2: List queue names\n   147→  getQueues(): string[] {\n   148→    return Array.from(this.queues.keys());\n   149→  }\n   150→\n   151→  // Phase 5: Complete a task\n   152→  complete(taskId: string): void {\n   153→    const task = this.tasks.get(taskId);\n   154→    if (!task) {\n   155→      throw new Error(`Task