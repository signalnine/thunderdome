======= Phase 12: Graceful Shutdown ====================\n   819→  describe('Phase 12: Graceful Shutdown', () => {\n   820→    it('should reject new tasks after shutdown', async () => {\n   821→      await queue.shutdown();\n   822→      expect(() => queue.add('test')).toThrow(/shutting down/);\n   823→    });\n   824→\n   825→    it('should complete immediately when no tasks are processing', async () => {\n   826→      const result = await queue.shutdown();\n   827→      expect(result.forceCancelled).toBe(0);\n   828→      expect(result.duration).toBeDefined();\n   829→    });\n   830→\n   831→    it('should wait for processing tasks to finish', async () => {\n   832→      const task = queue.add('test');\n   833→      const processing = queue.next()!;\n   834→\n   835→      // Start shutdown, but complete the task quickly\n   836→      const shutdownPromise = queue.shutdown(5000);\n   837→\n   838→      // Complete the task\n   839→      queue.complete(processing.id);\n   840→\n   841→      const result = await shutdownPromise;\n   842→      expect(result.completed).toBeGreaterThanOrEqual(1);\n   843→      expect(result.forceCancelled).toBe(0);\n   844→    });\n   845→\n   846→    it('should force-cancel tasks that exceed timeout', async () => {\n   847→      const task = queue.add('slow-task');\n   848→      queue.next()!; // Move to processing\n   849→\n   850→      const result = await queue.shutdown(100);\n   851→      expect(result.forceCancelled).toBe(1);\n   852→    });\n   853→\n   854→    it('should run shutdown callbacks', async () => {\n   855→      let callbackRan = false;\n   856→      queue.onShutdown(() => {\n   857→        callbackRan = true;\n   858→      });\n   859→\n   860→      await queue.shutdown();\n   861→      expect(callbackRan).toBe(true);\n   862→    });\n   863→\n   864→    it('should return same result when called multiple times', async () => {\n   865→      const result1Promise = queue.shutdown();\n   866→      const result2Promise =