1→      queue.add('a', { queue: 'q1' });\n   102→      queue.add('b', { queue: 'q2' });\n   103→      const names = queue.getQueues();\n   104→      expect(names).toContain('q1');\n   105→      expect(names).toContain('q2');\n   106→    });\n   107→\n   108→    it('should return null for non-existent queue', () => {\n   109→      expect(queue.next('nonexistent')).toBeNull();\n   110→    });\n   111→\n   112→    it('should create queue implicitly when adding tasks', () => {\n   113→      queue.add('task', { queue: 'new-queue' });\n   114→      expect(queue.getQueues()).toContain('new-queue');\n   115→    });\n   116→  });\n   117→\n   118→  // ==================== Phase 3: Priority ====================\n   119→  describe('Phase 3: Priority', () => {\n   120→    it('should default priority to 5', () => {\n   121→      const task = queue.add('test');\n   122→      expect(task.priority).toBe(5);\n   123→    });\n   124→\n   125→    it('should return higher-priority tasks first', () => {\n   126→      queue.add('low', { priority: 10 });\n   127→      queue.add('high', { priority: 1 });\n   128→      queue.add('medium', { priority: 5 });\n   129→\n   130→      expect(queue.next()?.payload).toBe('high');\n   131→      expect(queue.next()?.payload).toBe('medium');\n   132→      expect(queue.next()?.payload).toBe('low');\n   133→    });\n   134→\n   135→    it('should maintain FIFO within same priority', () => {\n   136→      queue.add('first', { priority: 3 });\n   137→      queue.add('second', { priority: 3 });\n   138→      queue.add('third', { priority: 3 });\n   139→\n   140→      expect(queue.next()?.payload).toBe('first');\n   141→      expect(queue.next()?.payload).toBe('second');\n   142→      expect(queue.next()?.payload).toBe('third');\n   143→    });\n   144→\n   145→    it('should reject invalid priority values', () => {\n   146→      expect(() => queue.add('test', { priority: 0 })).toThrow();\n   147→      expect(() => queue.add('test', { priority: 11 })).toThrow();\n   148→      expect(() => queue.add('test', { priority: 1.5 })).toThrow();\n   149→    });\n   150→\n   151→    it('should expose priority on task object', () => {\n   152→      const task = queue.add('test', { priority: 3 });\n   153→      expect(task.priority).toBe(3);\n   154→    });\n   155→\n   156→    it('should maintain priority per queue', () => {\n   157→      queue.add('q1-low', { queue: 'q1', priority: 10 });\n   158→      queue.add('q1-high', { queue: 'q1', priority: 1 });\n   159→      queue.add('q2-low', { queue: 'q2', priority: 10 });\n   160→\n   161→      expect(queue.next('q1')?.payload).toBe('q1-high');\n   162→      expect(queue.next('q2')?.payload).toBe('q2-low');\n   163→    });\n   164→  });\n   165→\n   166→  // ==================== Phase 4: Delayed Tasks ====================\n   167→  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n   168→    it('should delay tasks by specified milliseconds', () => {\n   169→      queue.add('delayed', { delay: 10000 });\n   170→      expect(queue.next()).toBeNull();\n   171→      expect(queue.size()).toBe(1);\n   172→    });\n   173→\n   174→    it('should allow tasks with processAt date', () => {\n   175→      const future = new Date(Date.now() + 10000);\n   176→      const task = queue.add('scheduled', { processAt: future });\n   177→      expect(task.availableAt.getTime()).toBe(future.getTime());\n   178→      expect(queue.next()).toBeNull();\n   179→    });\n   180→\n   181→    it('should return delayed tasks once available', () => {\n   182→      const past = new Date(Date.now() - 1000);\n   183→      queue.add('past-scheduled', { processAt: past });\n   184→      const task = queue.next();\n   185→      expect(task?.payload).toBe('past-scheduled');\n   186→    });\n   187→\n   188→    it('should prefer non-delayed tasks over not-yet-available delayed ones', () => {\n   189→      queue.add('delayed', { delay: 10000 });\n   190→      queue.add('immediate');\n   191→\n   192→      expect(queue.next()?.payload).toBe('immediate');\n   193→    });\n   194→\n   195→    it('should indicate availability time on task', () => {\n   196→      const task = queue.add('test', { delay: 5000 });\n   197→      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n   198→    });\n   199→\n   200→    it('delayed tasks should work with named queues', () => {\n   201→      queue.add('delayed', { queue: 'myqueue', delay: 10000 });\n   202→      expect(queue.next('myqueue')).toBeNull();\n   203→      expect(queue.size('myqueue')).toBe(1);\n   204→    });\n   205→\n   206→    it('should order by availability time, then priority, then FIFO when multiple delayed tasks are available', () => {\n   207→      const past1 = new Date(Date.now() - 2000);\n   208→      const past2 = new Date(Date.now() - 1000);\n   209→\n   210→      queue.add('later-available', { processAt: past2, priority: 1 });\n   211→      queue.add('earlier-available', { processAt: past1, priority: 1 });\n   212→\n   213→      // Both are available, same priority. Should order by availability time.\n   214→      expect(queue.next()?.payload).toBe('earlier-available');\n   215→      expect(queue.next()?.payload).toBe('later-available');\n   216→    });\n   217→  });\n   218→\n   219→  // ==================== Phase 5: Retry with Backoff ====================\n   220→  describe('Phase 5: Retry with Backoff', () => {\n   221→    it('should complete a task', () => {\n   222→      const task = queue.add('test');\n   223→      const retrieved = queue.next()!;\n   224→      queue.complete(retrieved.id);\n   225→      expect(queue.getTask(retrieved.id)?.status).toBe('completed');\n   226→    });\n   227→\n   228→    it('should re-queue a failed task with retries remaining', () => {\n   229→      const task = queue.add('retry-me', { maxRetries: 3, backoffDelay: 100 });\n   230→      const retrieved = queue.next()!;\n   231→      queue.fail(retrieved.id, 'some error');\n   232→\n   233→      const updatedTask = queue.getTask(retrieved.id)!;\n   234→      expect(updatedTask.status).toBe('pending');\n   235→      expect(updatedTask.attempt).toBe(1);\n   236→      expect(updatedTask.error).toBe('some error');\n   237→      expect(updatedTask.availableAt.getTime()).toBeGreaterThan(Date.now());\n   238→    });\n   239→\n   240→    it('should apply exponential backoff', () => {\n   241→      const task = queue.add('retry-me', { maxRetries: 3, backoffDelay: 1000 });\n   242→\n   243→      // First attempt\n   244→      const r1 = queue.next()!;\n   245→      const failTime1 = Date.now();\n   246→      queue.fail(r1.id, 'error1');\n   247→      const t1 = queue.getTask(r1.id)!;\n   248→      // backoff = 1000 * 2^(1-1) = 1000ms\n   249→      expect(t1.availableAt.getTime()).toBeGreaterThanOrEqual(failTime1 + 900);\n   250→      expect(t1.availableAt.getTime()).toBeLessThanOrEqual(failTime1 + 1200);\n   251→    });\n   252→\n   253→    it('should default maxRetries to 3', () => {\n   254→      const task = queue.add('test');\n   255→      expect(task.maxRetries).toBe(3);\n   256→    });\n   257→\n   258→    it('should default backoffDelay to 1000ms', () => {\n   259→      const task = queue.add('test');\n   260→      expect(task.backoffDelay).toBe(1000);\n   261→    });\n   262→\n   263→    it('should allow configurable maxRetries and backoffDelay', () => {\n   264→      const task = queue.add('test', { maxRetries: 5, backoffDelay: 500 });\n   265→      expect(task.maxRetries).toBe(5);\n   266→      expect(task.backoffDelay).toBe(500);\n   267→    });\n   268→\n   269→    it('should track attempt count', () => {\n   270→      const task = queue.add('test', { maxRetries: 3, backoffDelay: 0 });\n   271→      const r1 = queue.next()!;\n   272→      expect(r1.attempt).toBe(1);\n   273→    });\n   274→\n   275→    it('should remain failed when retries exhausted', () => {\n   276→      const task = queue.add('doomed', { maxRetries: 1, backoffDelay: 0 });\n   277→      const r1 = queue.next()!;\n   278→      queue.fail(r1.id, 'error');\n   279→      expect(queue.getTask(r1.id)?.status).toBe('failed');\n   280→    });\n   281→\n   282→    it('should keep original queue and priority on retry', () => {\n   283→      const task = queue.add('retry', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n   284→      const r1 = queue.next('myq')!;\n   285→      queue.fail(r1.id, 'err');\n   286→      const updated = queue.getTask(r1.id)!;\n   287→      expect(updated.queue).toBe('myq');\n   288→      expect(updated.priority).toBe(2);\n   289→    });\n   290→\n   291→    it('should throw when completing non-processing task', () => {\n   292→      const task = queue.add('test');\n   293→      expect(() => queue.complete(task.id)).toThrow();\n   294→    });\n   295→\n   296→    it('should throw when failing non-processing task', () => {\n   297→      const task = queue.add('test');\n   298→      expect(() => queue.fail(task.id)).toThrow();\n   299→    });\n   300→  });\n   301→\n   302→  // ==================== Phase 6: Dead Letter Queue ====================\n   303→  describe('Phase 6: Dead Letter Queue', () => {\n   304→    it('should move task to DLQ after all retries exhausted', () => {\n   305→      const task = queue.add('doomed', { maxRetries: 1, backoffDelay: 0 });\n   306→      const r1 = queue.next()!;\n   307→      queue.fail(r1.id, 'fatal error');\n   308→\n   309→      const dlq = queue.getDeadLetterQueue();\n   310→      expect(dlq).toHaveLength(1);\n   311→      expect(dlq[0].id).toBe(task.id);\n   312→      expect(dlq[0].lastError).toBe('fatal error');\n   313→      expect(dlq[0].failCount).toBe(1);\n   314→    });\n   315→\n   316→    it('should retain error information in DLQ', () => {\n   317→      const task = queue.add('doomed', { maxRetries: 1, backoffDelay: 0 });\n   318→      queue.next()!;\n   319→      queue.fail(task.id, 'specific error message');\n   320→\n   321→      const dlq = queue.getDeadLetterQueue();\n   322→      expect(dlq[0].lastError).toBe('specific error message');\n   323→    });\n   324→\n   325→    it('should retry a dead-lettered task', () => {\n   326→      const task = queue.add('retry-from-dlq', { maxRetries: 1, backoffDelay: 0 });\n   327→      queue.next()!;\n   328→      queue.fail(task.id, 'error');\n   329→\n   330→      expect(queue.getDeadLetterQueue()).toHaveLength(1);\n   331→\n   332→      const retried = queue.retryDeadLetter(task.id);\n   333→      expect(retried.status).toBe('pending');\n   334→      expect(retried.attempt).toBe(0);\n   335→      expect(queue.getDeadLetterQueue()).toHaveLength(0);\n   336→      expect(queue.size()).toBe(1);\n   337→    });\n   338→\n   339→    it('should clear dead letter queue', () => {\n   340→      const t1 = queue.add('doomed1', { maxRetries: 1, backoffDelay: 0 });\n   341→      const t2 = queue.add('doomed2', { maxRetries: 1, backoffDelay: 0 });\n   342→      queue.next()!;\n   343→      queue.fail(t1.id, 'err1');\n   344→      queue.next()!;\n   345→      queue.fail(t2.id, 'err2');\n   346→\n   347→      expect(queue.getDeadLetterQueue()).toHaveLength(2);\n   348→      queue.clearDeadLetterQueue();\n   349→      expect(queue.getDeadLetterQueue()).toHaveLength(0);\n   350→    });\n   351→\n   352→    it('should have independent DLQs per named queue', () => {\n   353→      const t1 = queue.add('d1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n   354→      const t2 = queue.add('d2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n   355→      queue.next('q1')!;\n   356→      queue.fail(t1.id, 'err');\n   357→      queue.next('q2')!;\n   358→      queue.fail(t2.id, 'err');\n   359→\n   360→      expect(queue.getDeadLetterQueue('q1')).toHaveLength(1);\n   361→      expect(queue.getDeadLetterQueue('q2')).toHaveLength(1);\n   362→    });\n   363→\n   364→    it('should throw when retrying non-existent DLQ task', () => {\n   365→      expect(() => queue.retryDeadLetter('nonexistent')).toThrow();\n   366→    });\n   367→  });\n   368→\n   369→  // ==================== Phase 7: Task Dependencies ====================\n   370→  describe('Phase 7: Task Dependencies', () => {\n   371→    it('should block a task with unresolved dependencies', () => {\n   372→      const dep = queue.add('dependency');\n   373→      const dependent = queue.add('dependent', { dependencies: [dep.id] });\n   374→\n   375→      // Should get the dependency first (not the dependent which is blocked)\n   376→      const next = queue.next();\n   377→      expect(next?.id).toBe(dep.id);\n   378→\n   379→      // The dependent should not be available\n   380→      expect(queue.next()).toBeNull();\n   381→    });\n   382→\n   383→    it('should unblock a task when dependencies complete', () => {\n   384→      const dep = queue.add('dependency');\n   385→      const dependent = queue.add('dependent', { dependencies: [dep.id] });\n   386→\n   387→      const first = queue.next()!;\n   388→      queue.complete(first.id);\n   389→\n   390→      const second = queue.next();\n   391→      expect(second?.id).toBe(dependent.id);\n   392→    });\n   393→\n   394→    it('should throw when depending on non-existent task', () => {\n   395→      expect(() => queue.add('test', { dependencies: ['nonexistent'] })).toThrow();\n   396→    });\n   397→\n   398→    it('should keep dependents blocked when dependency fails', () => {\n   399→      const dep = queue.add('dependency', { maxRetries: 1, backoffDelay: 0 });\n   400→      const dependent = queue.add('dependent', { dependencies: [dep.id] });\n   401→\n   402→      const first = queue.next()!;\n   403→      queue.fail(first.id, 'error');\n   404→\n   405→      // Dependent remains blocked since dep is failed, not completed\n   406→      expect(queue.next()).toBeNull();\n   407→    });\n   408→\n   409→    it('should get dependency status', () => {\n   410→      const dep1 = queue.add('dep1');\n   411→      const dep2 = queue.add('dep2');\n   412→      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n   413→\n   414→      const status = queue.getDependencyStatus(dependent.id);\n   415→      expect(status.total).toBe(2);\n   416→      expect(status.completed).toBe(0);\n   417→      expect(status.pending).toContain(dep1.id);\n   418→      expect(status.pending).toContain(dep2.id);\n   419→\n   420→      // Complete one dependency\n   421→      queue.next()!; // dep1 (priority 5, FIFO)\n   422→      queue.complete(dep1.id);\n   423→\n   424→      const status2 = queue.getDependencyStatus(dependent.id);\n   425→      expect(status2.completed).toBe(1);\n   426→      expect(status2.pending).toHaveLength(1);\n   427→    });\n   428→\n   429→    it('should support multiple dependencies', () => {\n   430→      const dep1 = queue.add('dep1');\n   431→      const dep2 = queue.add('dep2');\n   432→      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n   433→\n   434→      // Complete both deps\n   435→      let t = queue.next()!;\n   436→      queue.complete(t.id);\n   437→      t = queue.next()!;\n   438→      queue.complete(t.id);\n   439→\n   440→      // Now dependent should be available\n   441→      const next = queue.next();\n   442→      expect(next?.id).toBe(dependent.id);\n   443→    });\n   444→\n   445→    it('should expose dependencies on task object', () => {\n   446→      const dep = queue.add('dep');\n   447→      const task = queue.add('task', { dependencies: [dep.id] });\n   448→      expect(task.dependencies).toContain(dep.id);\n   449→    });\n   450→  });\n   451→\n   452→  // ==================== Phase 8: Concurrency Control ====================\n   453→  describe('Phase 8: Concurrency Control', () => {\n   454→    it('should limit concurrent processing tasks', () => {\n   455→      queue.setConcurrency('default', 2);\n   456→      queue.add('t1');\n   457→      queue.add('t2');\n   458→      queue.add('t3');\n   459→\n   460→      const first = queue.next();\n   461→      const second = queue.next();\n   462→      expect(first).not.toBeNull();\n   463→      expect(second).not.toBeNull();\n   464→      expect(queue.next()).toBeNull(); // Limit reached\n   465→    });\n   466→\n   467→    it('should free slot on completion', () => {\n   468→      queue.setConcurrency('default', 1);\n   469→      queue.add('t1');\n   470→      queue.add('t2');\n   471→\n   472→      const first = queue.next()!;\n   473→      expect(queue.next()).toBeNull();\n   474→\n   475→      queue.complete(first.id);\n   476→      expect(queue.next()).not.toBeNull();\n   477→    });\n   478→\n   479→    it('should free slot on failure', () => {\n   480→      queue.setConcurrency('default', 1);\n   481→      queue.add('t1', { maxRetries: 1, backoffDelay: 0 });\n   482→      queue.add('t2');\n   483→\n   484→      const first = queue.next()!;\n   485→      expect(queue.next()).toBeNull();\n   486→\n   487→      queue.fail(first.id, 'err');\n   488→      // first is now failed and in DLQ, slot is free\n   489→      expect(queue.next()).not.toBeNull();\n   490→    });\n   491→\n   492→    it('should have unlimited concurrency by default', () => {\n   493→      expect(queue.getConcurrency('default')).toBeUndefined();\n   494→\n   495→      for (let i = 0; i < 100; i++) {\n   496→        queue.add(`t${i}`);\n   497→      }\n   498→      for (let i = 0; i < 100; i++) {\n   499→        expect(queue.next()).not.toBeNull();\n   500→      }\n   501→    });\n   502→\n   503→    it('should report active count', () => {\n   504→      queue.add('t1');\n   505→      queue.add('t2');\n   506→      expect(queue.getActiveCount()).toBe(0);\n   507→\n   508→      queue.next();\n   509→      expect(queue.getActiveCount()).toBe(1);\n   510→\n   511→      queue.next();\n   512→      expect(queue.getActiveCount()).toBe(2);\n   513→    });\n   514→\n   515→    it('should still respect priority with concurrency limits', () => {\n   516→      queue.setConcurrency('default', 1);\n   517→      queue.add('low', { priority: 10 });\n   518→      queue.add('high', { priority: 1 });\n   519→\n   520→      const task = queue.next()!;\n   521→      expect(task.payload).toBe('high');\n   522→    });\n   523→  });\n   524→\n   525→  // ==================== Phase 9: Progress and Cancellation ====================\n   526→  describe('Phase 9: Progress Tracking and Cancellation', () => {\n   527→    it('should report progress on a processing task', () => {\n   528→      const task = queue.add('test');\n   529→      const processing = queue.next()!;\n   530→\n   531→      queue.reportProgress(processing.id, 50, 'halfway');\n   532→      const progress = queue.getProgress(processing.id);\n   533→      expect(progress.progress).toBe(50);\n   534→      expect(progress.message).toBe('halfway');\n   535→    });\n   536→\n   537→    it('should notify progress listeners', () => {\n   538→      const task = queue.add('test');\n   539→      const processing = queue.next()!;\n   540→\n   541→      const updates: number[] = [];\n   542→      queue.onProgress(processing.id, (update) => {\n   543→        updates.push(update.progress);\n   544→      });\n   545→\n   546→      queue.reportProgress(processing.id, 25);\n   547→      queue.reportProgress(processing.id, 50);\n   548→      queue.reportProgress(processing.id, 75);\n   549→\n   550→      expect(updates).toEqual([25, 50, 75]);\n   551→    });\n   552→\n   553→    it('should support unsubscribing from progress', () => {\n   554→      const task = queue.add('test');\n   555→      const processing = queue.next()!;\n   556→\n   557→      const updates: number[] = [];\n   558→      const unsub = queue.onProgress(processing.id, (update) => {\n   559→        updates.push(update.progress);\n   560→      });\n   561→\n   562→      queue.reportProgress(processing.id, 25);\n   563→      unsub();\n   564→      queue.reportProgress(processing.id, 50);\n   565→\n   566→      expect(updates).toEqual([25]);\n   567→    });\n   568→\n   569→    it('should cancel a pending task', () => {\n   570→      const task = queue.add('cancel-me');\n   571→      queue.cancel(task.id);\n   572→\n   573→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   574→      expect(queue.next()).toBeNull();\n   575→    });\n   576→\n   577→    it('should cancel a processing task', () => {\n   578→      const task = queue.add('cancel-me');\n   579→      queue.next()!;\n   580→      queue.cancel(task.id);\n   581→\n   582→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   583→    });\n   584→\n   585→    it('should not retry cancelled tasks', () => {\n   586→      const task = queue.add('cancel-me', { maxRetries: 3 });\n   587→      queue.next()!;\n   588→      queue.cancel(task.id);\n   589→\n   590→      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n   591→      expect(queue.getTask(task.id)?.maxRetries).toBe(0);\n   592→    });\n   593→\n   594→    it('should throw when cancelling completed task', () => {\n   595→      const task = queue.add('test');\n   596→      queue.next()!;\n   597→      queue.complete(task.id);\n   598→      expect(() => queue.cancel(task.id)).toThrow();\n   599→    });\n   600→\n   601→    it('should throw when reporting progress on non-processing task', () => {\n   602→      const task = queue.add('test');\n   603→      expect(() => queue.reportProgress(task.id, 50)).toThrow();\n   604→    });\n   605→\n   606→    it('should reject invalid progress values', () => {\n   607→      const task = queue.add('test');\n   608→      queue.next()!;\n   609→      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n   610→      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n   611→    });\n   612→  });\n   613→\n   614→  // ==================== Phase 10: Recurring Tasks ====================\n   615→  describe('Phase 10: Recurring Tasks', () => {\n   616→    it('should create a schedule', () => {\n   617→      const schedule =