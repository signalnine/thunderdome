    if (options.dependencies) {\n    45→      for (const depId of options.dependencies) {\n    46→        if (!this.tasks.has(depId)) {\n    47→          throw new Error(`Dependency task not found: ${depId}`);\n    48→        }\n    49→      }\n    50→      // Check for circular dependencies\n    51→      this.checkCircularDependencies(options.dependencies);\n    52→    }\n    53→\n    54→    const now = new Date();\n    55→    let availableAt = now;\n    56→\n    57→    if (options.processAt) {\n    58→      availableAt = options.processAt;\n    59→    } else if (options.delay != null && options.delay > 0) {\n    60→      availableAt = new Date(now.getTime() + options.delay);\n    61→    }\n    62→\n    63→    const task: Task<T> = {\n    64→      id: randomUUID(),\n    65→      payload,\n    66→      status: 'pending',\n    67→      queue: queueName,\n    68→      priority,\n    69→      createdAt: now,\n    70→      availableAt,\n    71→      attempt: 0,\n    72→      maxRetries: options.maxRetries ?? 3,\n    73→      backoffDelay: options.backoffDelay ?? 1000,\n    74→      dependencies: options.dependencies ? [...options.dependencies] : [],\n    75→      progress: 0,\n    76→    };\n    77→\n    78→    this.tasks.set(task.id, task as Task);\n    79→\n    80→    // Ensure queue exists\n    81→    if (!this.queues.has(queueName)) {\n    82→      this.queues.set(queueName, []);\n    83→    }\n    84→    this.queues.get(queueName)!.push(task.id);\n    85→\n    86→    return task;\n    87→  }\n    88→\n    89→  // Phase 1: Retrieve next task (FIFO, respecting priority, delay, dependencies, concurrency)\n    90→  next(queueName: string = DEFAULT_QUEUE): Task | null {\n    91→    const taskIds = this.queues.get(queueName);\n    92→    if (!taskIds || taskIds.length === 0) {\n    93→      return null;\n    94→    }\n    95→\n    96→    // Check concurrency limit\n    97→    const limit = this.concurrencyLimits.get(queueName);\n    98→    if (limit !== undefined) {\n    99→      const activeCount = this.getActiveCount(queueName);\n   100→      if (activeCount >= limit) {\n   101→        return null;\n   102→      }\n   103→    }\n   104→\n   105→    const now = new Date();\n   106→\n   107→    // Find the best candidate: highest priority (lowest number), then earliest creation\n   108→    let bestIdx = -1;\n   109→    let bestTask: Task | null = null;\n   110→\n   111→    for (let i = 0; i < taskIds.length; i++) {\n   112→      const task = this.tasks.get(taskIds[i]);\n   113→      if (!task || task.status !== 'pending') continue;\n   114→\n   115→      // Check availability time\n   116→      if (task.availableAt > now) continue;\n   117→\n   118→      // Check dependencies\n   119→      if (!this.areDependenciesMet(task)) continue;\n   120→\n   121→      if (\n   122→        bestTask === null ||\n   123→        task.priority < bestTask.priority ||\n   124→        (task.priority === bestTask.priority && task.availableAt < bestTask.availableAt) ||\n   125→        (task.priority === bestTask.priority && task.availableAt.getTime() === bestTask.availableAt.getTime() && task.createdAt < bestTask.createdAt)\n   126→      ) {\n   127→        bestIdx = i;\n   128→        bestTask = task;\n   129→      }\n   130→    }\n   131→\n   132→    if (bestTask === null) {\n   133→      return null;\n   134→    }\n   135→\n   136→    bestTask.status = 'processing';\n   137→    bestTask.attempt += 1;\n   138→    return bestTask;\n   139→  }\n   140→\n   141→  // Phase 1: Get pending count\n   142→  size(queueName: string = DEFAULT_QUEUE): number {\n   143→    const taskIds = this.queues.get(queueName);\n   144→    if (!taskIds) return 0;\n   145→    return taskIds.filter(id => {\n   146→      const t = this.tasks.get(id);\n   147→      return t && t.status === 'pending';\n   148→    }).length;\n   149→  }\n   150→\n   151→  // Phase 2: List queue names\n   152→  getQueues(): string[] {\n   153→    return Array.from(this.queues.keys());\n   154→  }\n   155→\n   156→  // Phase 5: Complete a task\n   157→  complete(taskId: string): void {\n   158→    const task = this.tasks.get(taskId);\n   159→    if (!task) {\n   160→      throw new Error(`Task not found: ${taskId}`);\n   161→    }\n   162→    if (task.status !== 'processing') {\n   163→      throw new Error(`Cannot complete task in status: ${task.status}`);\n   164→    }\n   165→    task.status = 'completed';\n   166→    task.progress = 100;\n   167→\n   168→    // Check if any blocked tasks are now unblocked (Phase 7 handled implicitly via areDependenciesMet)\n   169→  }\n   170→\n   171→  // Phase 5: Fail a task (with retry logic)\n   172→  fail(taskId: string, error?: string): void {\n   173→    const task = this.tasks.get(taskId);\n   174→    if (!task) {\n   175→      throw new Error(`Task not found: ${taskId}`);\n   176→    }\n   177→    if (task.status !== 'processing') {\n   178→      throw new Error(`Cannot fail task in status: ${task.status}`);\n   179→    }\n   180→\n   181→    task.error = error;\n   182→\n   183→    if (task.attempt < task.maxRetries) {\n   184→      // Re-queue with backoff delay\n   185→      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n   186→      task.availableAt = new Date(Date.now() + delay);\n   187→      task.status = 'pending';\n   188→      task.progress = 0;\n   189→    } else {\n   190→      // Exhausted retries\n   191→      task.status = 'failed';\n   192→\n   193→      // Move to dead letter queue (Phase 6)\n   194→      this.moveToDeadLetterQueue(task);\n   195→    }\n   196→  }\n   197→\n   198→  // Phase 6: Move to DLQ\n   199→  private moveToDeadLetterQueue(task: Task): void {\n   200→    if (!this.deadLetterQueues.has(task.queue)) {\n   201→      this.deadLetterQueues.set(task.queue, []);\n   202→    }\n   203→    const dlqTask: DeadLetteredTask = {\n   204→      ...task,\n   205→      failCount: task.attempt,\n   206→      lastError: task.error,\n   207→    };\n   208→    this.deadLetterQueues.get(task.queue)!.push(dlqTask);\n   209→\n   210→    // Remove from queue\n   211→    const queueIds = this.queues.get(task.queue);\n   212→    if (queueIds) {\n   213→      const idx = queueIds.indexOf(task.id);\n   214→      if (idx !== -1) {\n   215→        queueIds.splice(idx, 1);\n   216→      }\n   217→    }\n   218→  }\n   219→\n   220→  // Phase 6: Get dead-lettered tasks\n   221→  getDeadLetterQueue(queueName: string = DEFAULT_QUEUE): DeadLetteredTask[] {\n   222→    return this.deadLetterQueues.get(queueName) ?? [];\n   223→  }\n   224→\n   225→  // Phase 6: Retry a dead-lettered task\n   226→  retryDeadLetter(taskId: string): Task {\n   227→    for (const [queueName, dlqTasks] of this.deadLetterQueues) {\n   228→      const idx = dlqTasks.findIndex(t => t.id === taskId);\n   229→      if (idx !== -1) {\n   230→        const dlqTask = dlqTasks[idx];\n   231→        dlqTasks.splice(idx, 1);\n   232→\n   233→        // Reset task for fresh retry\n   234→        const task = this.tasks.get(taskId);\n   235→        if (!task) {\n   236→          throw new Error(`Task not found: ${taskId}`);\n   237→        }\n   238→        task.status = 'pending';\n   239→        task.attempt = 0;\n   240→        task.error = undefined;\n   241→        task.progress = 0;\n   242→        task.availableAt = new Date();\n   243→\n   244→        // Re-add to queue\n   245→        if (!this.queues.has(queueName)) {\n   246→          this.queues.set(queueName, []);\n   247→        }\n   248→        this.queues.get(queueName)!.push(task.id);\n   249→\n   250→        return task;\n   251→      }\n   252→    }\n   253→    throw new Error(`Dead-lettered task not found: ${taskId}`);\n   254→  }\n   255→\n   256→  // Phase 6: Clear dead letter queue\n   257→  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n   258→    const dlqTasks = this.deadLetterQueues.get(queueName);\n   259→    if (dlqTasks) {\n   260→      // Also remove the tasks from the tasks map\n   261→      for (const t of dlqTasks) {\n   262→        this.tasks.delete(t.id);\n   263→      }\n   264→      this.deadLetterQueues.set(queueName, []);\n   265→    }\n   266→  }\n   267→\n   268→  // Phase 7: Check if dependencies are met\n   269→  private areDependenciesMet(task: Task): boolean {\n   270→    if (task.dependencies.length === 0) return true;\n   271→    return task.dependencies.every(depId => {\n   272→      const dep = this.tasks.get(depId);\n   273→      return dep && dep.status === 'completed';\n   274→    });\n   275→  }\n   276→\n   277→  // Phase 7: Check for circular dependencies\n   278→  private checkCircularDependencies(newDeps: string[]): void {\n   279→    // BFS/DFS to check if adding these deps creates a cycle\n   280→    // Since the new task doesn't exist yet, we just need to verify none of the\n   281→    // deps (transitively) depend on each other in a way that would create issues.\n   282→    // Actually, since the new task has no ID yet (it doesn't exist), there can't be\n   283→    // a cycle TO it. We just need to ensure deps are valid tasks.\n   284→    // Circular deps would only be possible if we check existing dep chains.\n   285→    // For now, we validate that deps exist (done in add method).\n   286→    // True circular dependency detection needs the task id, which is assigned after this check.\n   287→  }\n   288→\n   289→  // Phase 7: Check circular dependencies with the new task's id\n   290→  private wouldCreateCycle(taskId: string, dependencies: string[]): boolean {\n   291→    const visited = new Set<string>();\n   292→    const stack = [...dependencies];\n   293→\n   294→    while (stack.length > 0) {\n   295→      const depId = stack.pop()!;\n   296→      if (depId === taskId) return true;\n   297→      if (visited.has(depId)) continue;\n   298→      visited.add(depId);\n   299→\n   300→      const depTask = this.tasks.get(depId);\n   301→      if (depTask) {\n   302→        for (const d of depTask.dependencies) {\n   303→          stack.push(d);\n   304→        }\n   305→      }\n   306→    }\n   307→    return false;\n   308→  }\n   309→\n   310→  // Phase 7: Get dependency status\n   311→  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {\n   312→    const task = this.tasks.get(taskId);\n   313→    if (!task) {\n   314→      throw new Error(`Task not found: ${taskId}`);\n   315→    }\n   316→\n   317→    const pendingDeps: string[] = [];\n   318→    let completedCount = 0;\n   319→\n   320→    for (const depId of task.dependencies) {\n   321→      const dep = this.tasks.get(depId);\n   322→      if (dep && dep.status === 'completed') {\n   323→        completedCount++;\n   324→      } else {\n   325→        pendingDeps.push(depId);\n   326→      }\n   327→    }\n   328→\n   329→    return {\n   330→      total: task.dependencies.length,\n   331→      completed: completedCount,\n   332→      pending: pendingDeps,\n   333→    };\n   334→  }\n   335→\n   336→  // Phase 8: Set concurrency limit\n   337→  setConcurrency(queueName: string, limit: number): void {\n   338→    if (limit < 1) {\n   339→      throw new Error('Concurrency limit must be at least 1');\n   340→    }\n   341→    this.concurrencyLimits.set(queueName, limit);\n   342→  }\n   343→\n   344→  // Phase 8: Get concurrency limit\n   345→  getConcurrency(queueName: string): number | undefined {\n   346→    return this.concurrencyLimits.get(queueName);\n   347→  }\n   348→\n   349→  // Phase 8: Get active (processing) count\n   350→  getActiveCount(queueName: string = DEFAULT_QUEUE): number {\n   351→    const taskIds = this.queues.get(queueName);\n   352→    if (!taskIds) return 0;\n   353→    return taskIds.filter(id => {\n   354→      const t = this.tasks.get(id);\n   355→      return t && t.status === 'processing';\n   356→    }).length;\n   357→  }\n   358→\n   359→  // Phase 9: Report progress\n   360→  reportProgress(taskId: string, progress: number, message?: string): void {\n   361→    const task = this.tasks.get(taskId);\n   362→    if (!task) {\n   363→      throw new Error(`Task not found: ${taskId}`);\n   364→    }\n   365→    if (task.status !== 'processing') {\n   366→      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n   367→    }\n   368→    if (progress < 0 || progress > 100) {\n   369→      throw new Error(`Progress must be between 0 and 100, got: ${progress}`);\n   370→    }\n   371→\n   372→    task.progress = progress;\n   373→    task.progressMessage = message;\n   374→\n   375→    const update: ProgressUpdate = { taskId, progress, message };\n   376→    const listeners = this.progressListeners.get(taskId);\n   377→    if (listeners) {\n   378→      for (const listener of listeners) {\n   379→        listener(update);\n   380→      }\n   381→    }\n   382→  }\n   383→\n   384→  // Phase 9: Subscribe to progress updates\n   385→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   386→    if (!this.progressListeners.has(taskId)) {\n   387→      this.progressListeners.set(taskId, new Set());\n   388→    }\n   389→    this.progressListeners.get(taskId)!.add(listener);\n   390→\n   391→    // Return unsubscribe function\n   392→    return () => {\n   393→      const listeners = this.progressListeners.get(taskId);\n   394→      if (listeners) {\n   395→        listeners.delete(listener);\n   396→        if (listeners.size === 0) {\n   397→          this.progressListeners.delete(taskId);\n   398→        }\n   399→      }\n   400→    };\n   401→  }\n   402→\n   403→  // Phase 9: Cancel a task\n   404→  cancel(taskId: string): void {\n   405→    const task = this.tasks.get(taskId);\n   406→    if (!task) {\n   407→      throw new Error(`Task not found: ${taskId}`);\n   408→    }\n   409→    if (task.status !== 'pending' && task.status !== 'processing') {\n   410→      throw new Error(`Cannot cancel task in status: ${task.status}`);\n   411→    }\n   412→\n   413→    task.status = 'cancelled';\n   414→    // Set maxRetries to 0 so it won't be retried\n   415→    task.maxRetries = 0;\n   416→  }\n   417→\n   418→  // Phase 9: Get task progress\n   419→  getProgress(taskId: string): { progress: number; message?: string } {\n   420→    const task = this.tasks.get(taskId);\n   421→    if (!task) {\n   422→      throw new Error(`Task not found: ${taskId}`);\n   423→    }\n   424→    return { progress: task.progress, message: task.progressMessage };\n   425→  }\n   426→\n   427→  // Phase 10: Add a recurring schedule\n   428→  addSchedule(id: string, expression: string, queueName: string, payload: unknown): CronSchedule {\n   429→    if (this.isShuttingDown) {\n   430→      throw new Error('Queue system is shutting down');\n   431→    }\n   432→    this.validateCronExpression(expression);\n   433→\n   434→    const schedule: CronSchedule = {\n   435→      id,\n   436→      expression,\n   437→      queue: queueName,\n   438→      payload,\n   439→    };\n   440→    this.schedules.set(id, schedule);\n   441→    return schedule;\n   442→  }\n   443→\n   444→  // Phase 10: Remove a schedule\n   445→  removeSchedule(id: string): boolean {\n   446→    return this.schedules.delete(id);\n   447→  }\n   448→\n   449→  // Phase 10: List schedules\n   450→  listSchedules(): CronSchedule[] {\n   451→    return Array.from(this.schedules.values());\n   452→  }\n   453→\n   454→  // Phase 10: Tick - check schedules and enqueue due tasks\n   455→  tick(now: Date = new Date()): Task[] {\n   456→    const created: Task[] = [];\n   457→\n   458→    for (const schedule of this.schedules.values()) {\n   459→      if (this.shouldRunSchedule(schedule, now)) {\n   460→        const task = this.add(schedule.payload, { queue: schedule.queue });\n   461→        created.push(task);\n   462→        schedule.lastRun = now;\n   463→      }\n   464→    }\n   465→\n   466→    return created;\n   467→  }\n   468→\n   469→  private validateCronExpression(expr: string): void {\n   470→    const parts = expr.trim().split(/\\s+/);\n   471→    if (parts.length !== 5) {\n   472→      throw new Error(`Invalid cron expression: ${expr}. Must have 5 fields.`);\n   473→    }\n   474→\n   475→    // Validate minute field\n   476→    const minute = parts[0];\n   477→    if (minute !== '*' && !minute.startsWith('*/') && !/^\\d+$/.test(minute)) {\n   478→      throw new Error(`Invalid cron minute field: ${minute}`);\n   479→    }\n   480→\n   481→    // Validate hour field\n   482→    const hour = parts[1];\n   483→    if (hour !== '*' && !hour.startsWith('*/') && !/^\\d+$/.test(hour)) {\n   484→      throw new Error(`Invalid cron hour field: ${hour}`);\n   485→    }\n   486→  }\n   487→\n   488→  private shouldRunSchedule(schedule: CronSchedule, now: Date): boolean {\n   489→    const parts = schedule.expression.trim().split(/\\s+/);\n   490→    const minutePart = parts[0];\n   491→    const hourPart = parts[1];\n   492→\n   493→    const currentMinute = now.getMinutes();\n   494→    const currentHour = now.getHours();\n   495→\n   496→    // Check minute match\n   497→    let minuteMatch = false;\n   498→    if (minutePart === '*') {\n   499→      minuteMatch = true;\n   500→    } else if (minutePart.startsWith('*/')) {\n   501→      const interval = parseInt(minutePart.slice(2), 10);\n   502→      minuteMatch = currentMinute % interval === 0;\n   503→    } else {\n   504→      minuteMatch = currentMinute === parseInt(minutePart, 10);\n   505→    }\n   506→\n   507→    // Check hour match\n   508→    let hourMatch = false;\n   509→    if (hourPart === '*') {\n   510→      hourMatch = true;\n   511→    } else if (hourPart.startsWith('*/')) {\n   512→      const interval = parseInt(hourPart.slice(2), 10);\n   513→      hourMatch = currentHour % interval === 0;\n   514→    } else {\n   515→      hourMatch = currentHour === parseInt(hourPart, 10);\n   516→    }\n   517→\n   518→    if (!minuteMatch || !hourMatch) {\n   519→      return false;\n   520→    }\n   521→\n   522→    // Check if we already ran at this time\n   523→    if (schedule.lastRun) {\n   524→      const lastMinute = schedule.lastRun.getMinutes();\n   525→      const lastHour = schedule.lastRun.getHours();\n   526→      const lastDate = schedule.lastRun.toDateString();\n   527→      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === now.toDateString()) {\n   528→        return false;\n   529→      }\n   530→    }\n   531→\n   532→    return true;\n   533→  }\n   534→\n   535→  // Phase 11: Register middleware\n   536→  use(queueName: string, middleware: MiddlewareFn): void {\n   537→    if (!this.middlewareStacks.has(queueName)) {\n   538→      this.middlewareStacks.set(queueName, []);\n   539→    }\n   540→    this.middlewareStacks.get(queueName)!.push(middleware);\n   541→  }\n   542→\n   543→  // Phase 11: Register handler\n   544→  handle(queueName: string, handler: HandlerFn): void {\n   545→    this.handlers.set(queueName, handler);\n   546→  }\n   547→\n   548→  // Phase 11: Process a task through middleware pipeline and handler\n   549→  async process(taskId: string): Promise<void> {\n   550→    const task = this.tasks.get(taskId);\n   551→    if (!task) {\n   552→      throw new Error(`Task not found: ${taskId}`);\n   553→    }\n   554→    if (task.status !== 'processing') {\n   555→      throw new Error(`Task is not in processing state: ${task.status}`);\n   556→    }\n   557→\n   558→    const middleware = this.middlewareStacks.get(task.queue) ?? [];\n   559→    const handler = this.handlers.get(task.queue);\n   560→\n   561→    try {\n   562→      await this.executeMiddlewareChain(task, middleware, 0, handler);\n   563→    } catch (err) {\n   564→      this.fail(taskId, err instanceof Error ? err.message : String(err));\n   565→    }\n   566→  }\n   567→\n   568→  private async executeMiddlewareChain(\n   569→    task: Task,\n   570→    middleware: MiddlewareFn[],\n   571→    index: number,\n   572→    handler?: HandlerFn\n   573→  ): Promise<void> {\n   574→    if (index < middleware.length) {\n   575→      let nextCalled = false;\n   576→      await middleware[index](task, async () => {\n   577→        nextCalled = true;\n   578→        await this.executeMiddlewareChain(task, middleware, index + 1, handler);\n   579→      });\n   580→      // If next was not called, processing is skipped\n   581→    } else if (handler) {\n   582→      await handler(task);\n   583→    }\n   584→  }\n   585→\n   586→  // Phase 12: Register shutdown callback\n   587→  onShutdown(callback: () => void | Promise<void>): void {\n   588→    this.shutdownCallbacks.push(callback);\n   589→  }\n   590→\n   591→  // Phase 12: Graceful shutdown\n   592→  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {\n   593→    if (this.shutdownPromise) {\n   594→      return this.shutdownPromise;\n   595→    }\n   596→\n   597→    this.isShuttingDown = true;\n   598→    this.shutdownPromise = this.performShutdown(timeout);\n   599→    return this.shutdownPromise;\n   600→  }\n   601→\n   602→  private async performShutdown(timeout: number): Promise<ShutdownResult> {\n   603→    const startTime = Date.now();\n   604→    let completed = 0;\n   605→    let forceCancelled = 0;\n   606→\n   607→    // Run shutdown callbacks\n   608→    for (const cb of this.shutdownCallbacks) {\n   609→      await cb();\n   610→    }\n   611→\n   612→    // Wait for processing tasks to complete\n   613→    const processingTasks = this.getProcessingTasks();\n   614→\n   615→    if (processingTasks.length > 0) {\n   616→      const result = await Promise.race([\n   617→        this.waitForTasksToComplete(processingTasks),\n   618→        new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),\n   619→      ]);\n   620→\n   621→      if (result === 'timeout') {\n   622→        // Force cancel remaining processing tasks\n   623→        for (const task of processingTasks) {\n   624→          if (task.status === 'processing') {\n   625→            task.status = 'cancelled';\n   626→            forceCancelled++;\n   627→          }\n   628→        }\n   629→      }\n   630→    }\n   631→\n   632→    // Count completed tasks\n   633→    for (const task of this.tasks.values()) {\n   634→      if (task.status === 'completed') {\n   635→        completed++;\n   636→      }\n   637→    }\n   638→\n   639→    const duration = Date.now() - startTime;\n   640→\n   641→    return { completed, forceCancelled, duration };\n   642→  }\n   643→\n   644→  private getProcessingTasks(): Task[] {\n   645→    const tasks: Task[] = [];\n   646→    for (const task of this.tasks.values()) {\n   647→      if (task.status === 'processing') {\n   648→        tasks.push(task);\n   649→      }\n   650→    }\n   651→    return tasks;\n   652→  }\n   653→\n   654→  private async waitForTasksToComplete(tasks: Task[]): Promise<void> {\n   655→    // Poll until all tasks are done\n   656→    while (tasks.some(t => t.status === 'processing')) {\n   657→      await new Promise(resolve => setTimeout(resolve, 50));\n   658→    }\n   659→  }\n   660→\n   661→  // Helper: Get a task by ID\n   662→  getTask(taskId: string): Task | undefined {\n   663→    return this.tasks.get(taskId);\n   664→  }\n   665→\n   666→  // Helper: Check if shutting down\n   667→  get shuttingDown(): boolean {\n   668→    return this.isShuttingDown;\n   669→  }\n   670→}\n   671→"}]},"parent_tool_use_id":null,"session_id":"9304892a-c807-4021-8cf4-c5e580d7ff90","uuid":"fb7cec28-3f98-4af6-99c3-1147190a9a48","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/task-queue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskOptions,\n  TaskStatus,\n  ProgressUpdate,\n  ProgressListener,\n  CronSchedule,\n  MiddlewareFn,\n  HandlerFn,\n  ShutdownResult,\n  DeadLetteredTask,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, string[]> = new Map(); // queueName -> taskIds in insertion order\n  private deadLetterQueues: Map<string, DeadLetteredTask[]> = new Map();\n  private concurrencyLimits: Map<string, number> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private schedules: Map<string, CronSchedule> = new Map();\n  private middlewareStacks: Map<string, MiddlewareFn[]> = new Map();\n  private handlers: Map<string, HandlerFn> = new Map();\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n\n  // Phase 1: Add a task\n  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Queue system is shutting down, cannot add new tasks');\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n    const priority = options.priority ?? 5;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies\n    if (options.dependencies) {\n      for (const depId of options.dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n      // Check for circular dependencies\n      this.checkCircularDependencies(options.dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    if (options.processAt) {\n      availableAt = options.processAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      dependencies: options.dependencies ? [...options.dependencies] : [],\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n\n    // Ensure queue exists\n    if (!this.queues.has(queueName)) {\n      this.queues.set(queueName, []);\n    }\n    this.queues.get(queueName)!.push(task.id);\n\n    return task;\n  }\n\n  // Phase 1: Retrieve next task (FIFO, respecting priority, delay, dependencies, concurrency)\n  next(queueName: string = DEFAULT_QUEUE): Task | null {\n    const taskIds = this.queues.get(queueName);\n    if (!taskIds || taskIds.length === 0) {\n      return null;\n    }\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(queueName);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= limit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n\n    // Find the best candidate: highest priority (lowest number), then earliest creation\n    let bestIdx = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < taskIds.length; i++) {\n      const task = this.tasks.get(taskIds[i]);\n      if (!task || task.status !== 'pending') continue;\n\n      // Check availability time\n      if (task.availableAt > now) continue;\n\n      // Check dependencies\n      if (!this.areDependenciesMet(task)) continue;\n\n      if (\n        bestTask === null ||\n        task.priority < bestTask.priority ||\n        (task.priority === bestTask.priority && task.availableAt < bestTask.availableAt) ||\n        (task.priority === bestTask.priority && task.availableAt.getTime() === bestTask.availableAt.getTime() && task.createdAt < bestTask.createdAt)\n      ) {\n        bestIdx = i;\n        bestTask = task;\n      }\n    }\n\n    if (bestTask === null) {\n      return null;\n    }\n\n    bestTask.status = 'processing';\n    bestTask.attempt += 1;\n    return bestTask;\n  }\n\n  // Phase 1: Get pending count\n  size(queueName: string = DEFAULT_QUEUE): number {\n    const taskIds = this.queues.get(queueName);\n    if (!taskIds) return 0;\n    return taskIds.filter(id => {\n      const t = this.tasks.get(id);\n      return t && t.status === 'pending';\n    }).length;\n  }\n\n  // Phase 2: List queue names\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // Phase 5: Complete a task\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks are now unblocked (Phase 7 handled implicitly via areDependenciesMet)\n  }\n\n  // Phase 5: Fail a task (with retry logic)\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n\n    if (task.attempt < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n    } else {\n      // Exhausted retries\n      task.status = 'failed';\n\n      // Move to dead letter queue (Phase 6)\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // Phase 6: Move to DLQ\n  private moveToDeadLetterQueue(task: Task): void {\n    if (!this.deadLetterQueues.has(task.queue)) {\n      this.deadLetterQueues.set(task.queue, []);\n    }\n    const dlqTask: DeadLetteredTask = {\n      ...task,\n      failCount: task.attempt,\n      lastError: task.error,\n    };\n    this.deadLetterQueues.get(task.queue)!.push(dlqTask);\n\n    // Remove from queue\n    const queueIds = this.queues.get(task.queue);\n    if (queueIds) {\n      const idx = queueIds.indexOf(task.id);\n      if (idx !== -1) {\n        queueIds.splice(idx, 1);\n      }\n    }\n  }\n\n  // Phase 6: Get dead-lettered tasks\n  getDeadLetterQueue(queueName: string = DEFAULT_QUEUE): DeadLetteredTask[] {\n    return this.deadLetterQueues.get(queueName) ?? [];\n  }\n\n  // Phase 6: Retry a dead-lettered task\n  retryDeadLetter(taskId: string): Task {\n    for (const [queueName, dlqTasks] of this.deadLetterQueues) {\n      const idx = dlqTasks.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n        const dlqTask = dlqTasks[idx];\n        dlqTasks.splice(idx, 1);\n\n        // Reset task for fresh retry\n        const task = this.tasks.get(taskId);\n        if (!task) {\n          throw new Error(`Task not found: ${taskId}`);\n        }\n        task.status = 'pending';\n        task.attempt = 0;\n        task.error = undefined;\n        task.progress = 0;\n        task.availableAt = new Date();\n\n        // Re-add to queue\n        if (!this.queues.has(queueName)) {\n          this.queues.set(queueName, []);\n        }\n        this.queues.get(queueName)!.push(task.id);\n\n        return task;\n      }\n    }\n    throw new Error(`Dead-lettered task not found: ${taskId}`);\n  }\n\n  // Phase 6: Clear dead letter queue\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n    const dlqTasks = this.deadLetterQueues.get(queueName);\n    if (dlqTasks) {\n      // Also remove the tasks from the tasks map\n      for (const t of dlqTasks) {\n        this.tasks.delete(t.id);\n      }\n      this.deadLetterQueues.set(queueName, []);\n    }\n  }\n\n  // Phase 7: Check if dependencies are met\n  private areDependenciesMet(task: Task): boolean {\n    if (task.dependencies.length === 0) return true;\n    return task.dependencies.every(depId => {\n      const dep = this.tasks.get(depId);\n      return dep && dep.status === 'completed';\n    });\n  }\n\n  // Phase 7: Check for circular dependencies\n  private checkCircularDependencies(newDeps: string[]): void {\n    // BFS/DFS to check if adding these deps creates a cycle\n    // Since the new task doesn't exist yet, we just need to verify none of the\n    // deps (transitively) depend on each other in a way that would create issues.\n    // Actually, since the new task has no ID yet (it doesn't exist), there can't be\n    // a cycle TO it. We just need to ensure deps are valid tasks.\n    // Circular deps would only be possible if we check existing dep chains.\n    // For now, we validate that deps exist (done in add method).\n    // True circular dependency detection needs the task id, which is assigned after this check.\n  }\n\n  // Phase 7: Check circular dependencies with the new task's id\n  private wouldCreateCycle(taskId: string, dependencies: string[]): boolean {\n    const visited = new Set<string>();\n    const stack = [...dependencies];\n\n    while (stack.length > 0) {\n      const depId = stack.pop()!;\n      if (depId === taskId) return true;\n      if (visited.has(depId)) continue;\n      visited.add(depId);\n\n      const depTask = this.tasks.get(depId);\n      if (depTask) {\n        for (const d of depTask.dependencies) {\n          stack.push(d);\n        }\n      }\n    }\n    return false;\n  }\n\n  // Phase 7: Get dependency status\n  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    const pendingDeps: string[] = [];\n    let completedCount = 0;\n\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        completedCount++;\n      } else {\n        pendingDeps.push(depId);\n      }\n    }\n\n    return {\n      total: task.dependencies.length,\n      completed: completedCount,\n      pending: pendingDeps,\n    };\n  }\n\n  // Phase 8: Set concurrency limit\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1) {\n      throw new Error('Concurrency limit must be at least 1');\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  // Phase 8: Get concurrency limit\n  getConcurrency(queueName: string): number | undefined {\n    return this.concurrencyLimits.get(queueName);\n  }\n\n  // Phase 8: Get active (processing) count\n  getActiveCount(queueName: string = DEFAULT_QUEUE): number {\n    const taskIds = this.queues.get(queueName);\n    if (!taskIds) return 0;\n    return taskIds.filter(id => {\n      const t = this.tasks.get(id);\n      return t && t.status === 'processing';\n    }).length;\n  }\n\n  // Phase 9: Report progress\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Progress must be between 0 and 100, got: ${progress}`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    const update: ProgressUpdate = { taskId, progress, message };\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(update);\n      }\n    }\n  }\n\n  // Phase 9: Subscribe to progress updates\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!