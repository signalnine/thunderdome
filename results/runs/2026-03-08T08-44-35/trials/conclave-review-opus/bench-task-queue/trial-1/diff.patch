// ==================== Phase 1: Basic FIFO Queue ====================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = queue.add({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const t1 = queue.next();\n      expect(t1?.payload).toBe('first');\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('second');\n      const t3 = queue.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing on retrieval', () => {\n      const added = queue.add('test');\n      const retrieved = queue.next();\n      expect(retrieved?.id).toBe(added.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return null after all tasks are retrieved', () => {\n      queue.add('only');\n      queue.next();\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should report the number of pending tasks', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should track attempt count', () => {\n      queue.add('test');\n      const task = queue.next();\n      expect(task?.attempt).toBe(1);\n    });\n  });\n\n  // ==================== Phase 2: Named Queues ====================\n  describe('Phase 2: Named Queues', () => {\n    it('should add tasks to a specific named queue', () => {\n      queue.add('email', { queue: 'emails' });\n      queue.add('sms', { queue: 'sms' });\n\n      expect(queue.size('emails')).toBe(1);\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.add('default-task');\n      expect(queue.size()).toBe(1);\n      expect(queue.size('default')).toBe(1);\n    });\n\n    it('should retrieve tasks from specified queue only', () => {\n      queue.add('email1', { queue: 'emails' });\n      queue.add('sms1', { queue: 'sms' });\n\n      const task = queue.next('emails');\n      expect(task?.payload).toBe('email1');\n      expect(queue.next('emails')).toBeNull();\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queue: 'q1' });\n      queue.add('b', { queue: 'q2' });\n      const names = queue.getQueues();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should create queue implicitly when adding tasks', () => {\n      queue.add('task', { queue: 'new-queue' });\n      expect(queue.getQueues()).toContain('new-queue');\n    });\n  });\n\n  // ==================== Phase 3: Priority ====================\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = queue.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 3 });\n      queue.add('second', { priority: 3 });\n      queue.add('third', { priority: 3 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.add('test', { priority: 0 })).toThrow();\n      expect(() => queue.add('test', { priority: 11 })).toThrow();\n      expect(() => queue.add('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.add('test', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n\n    it('should maintain priority per queue', () => {\n      queue.add('q1-low', { queue: 'q1', priority: 10 });\n      queue.add('q1-high', { queue: 'q1', priority: 1 });\n      queue.add('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.next('q1')?.payload).toBe('q1-high');\n      expect(queue.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ==================== Phase 4: Delayed Tasks ====================\n  describe('Phase 4: Delayed and Scheduled Tasks', () => {\n    it('should delay tasks by specified milliseconds', () => {\n      queue.add('delayed', { delay: 10000 });\n      expect(queue.next()).toBeNull();\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should allow tasks with processAt date', () => {\n      const future = new Date(Date.now() + 10000);\n      const task = queue.add('scheduled', { processAt: future });\n      expect(task.availableAt.getTime()).toBe(future.getTime());\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return delayed tasks once available', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('past-scheduled', { processAt: past });\n      const task = queue.next();\n      expect(task?.payload).toBe('past-scheduled');\n    });\n\n    it('should prefer non-delayed tasks over not-yet-available delayed ones', () => {\n      queue.add('delayed', { delay: 10000 });\n      queue.add('immediate');\n\n      expect(queue.next()?.payload).toBe('immediate');\n    });\n\n    it('should indicate availability time on task', () => {\n      const task = queue.add('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('delayed tasks should work with named queues', () => {\n      queue.add('delayed', { queue: 'myqueue', delay: 10000 });\n      expect(queue.next('myqueue')).toBeNull();\n      expect(queue.size('myqueue')).toBe(1);\n    });\n\n    it('should order by availability time, then priority, then FIFO when multiple delayed tasks are available', () => {\n      const past1 = new Date(Date.now() - 2000);\n      const past2 = new Date(Date.now() - 1000);\n\n      queue.add('later-available', { processAt: past2, priority: 1 });\n      queue.add('earlier-available', { processAt: past1, priority: 1 });\n\n      // Both are available, same priority. Should order by availability time.\n      expect(queue.next()?.payload).toBe('earlier-available');\n      expect(queue.next()?.payload).toBe('later-available');\n    });\n  });\n\n  // ==================== Phase 5: Retry with Backoff ====================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      const task = queue.add('test');\n      const retrieved = queue.next()!;\n      queue.complete(retrieved.id);\n      expect(queue.getTask(retrieved.id)?.status).toBe('completed');\n    });\n\n    it('should re-queue a failed task with retries remaining', () => {\n      const task = queue.add('retry-me', { maxRetries: 3, backoffDelay: 100 });\n      const retrieved = queue.next()!;\n      queue.fail(retrieved.id, 'some error');\n\n      const updatedTask = queue.getTask(retrieved.id)!;\n      expect(updatedTask.status).toBe('pending');\n      expect(updatedTask.attempt).toBe(1);\n      expect(updatedTask.error).toBe('some error');\n      expect(updatedTask.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should apply exponential backoff', () => {\n      const task = queue.add('retry-me', { maxRetries: 3, backoffDelay: 1000 });\n\n      // First attempt\n      const r1 = queue.next()!;\n      const failTime1 = Date.now();\n      queue.fail(r1.id, 'error1');\n      const t1 = queue.getTask(r1.id)!;\n      // backoff = 1000 * 2^(1-1) = 1000ms\n      expect(t1.availableAt.getTime()).toBeGreaterThanOrEqual(failTime1 + 900);\n      expect(t1.availableAt.getTime()).toBeLessThanOrEqual(failTime1 + 1200);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = queue.add('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default backoffDelay to 1000ms', () => {\n      const task = queue.add('test');\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should allow configurable maxRetries and backoffDelay', () => {\n      const task = queue.add('test', { maxRetries: 5, backoffDelay: 500 });\n      expect(task.maxRetries).toBe(5);\n      expect(task.backoffDelay).toBe(500);\n    });\n\n    it('should track attempt count', () => {\n      const task = queue.add('test', { maxRetries: 3, backoffDelay: 0 });\n      const r1 = queue.next()!;\n      expect(r1.attempt).toBe(1);\n    });\n\n    it('should remain failed when retries exhausted', () => {\n      const task = queue.add('doomed', { maxRetries: 1, backoffDelay: 0 });\n      const r1 = queue.next()!;\n      queue.fail(r1.id, 'error');\n      expect(queue.getTask(r1.id)?.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = queue.add('retry', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const r1 = queue.next('myq')!;\n      queue.fail(r1.id, 'err');\n      const updated = queue.getTask(r1.id)!;\n      expect(updated.queue).toBe('myq');\n      expect(updated.priority).toBe(2);\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const task = queue.add('test');\n      expect(() => queue.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing non-processing task', () => {\n      const task = queue.add('test');\n      expect(() => queue.fail(task.id)).toThrow();\n    });\n  });\n\n  // ==================== Phase 6: Dead Letter Queue ====================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ after all retries exhausted', () => {\n      const task = queue.add('doomed', { maxRetries: 1, backoffDelay: 0 });\n      const r1 = queue.next()!;\n      queue.fail(r1.id, 'fatal error');\n\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].lastError).toBe('fatal error');\n      expect(dlq[0].failCount).toBe(1);\n    });\n\n    it('should retain error information in DLQ', () => {\n      const task = queue.add('doomed', { maxRetries: 1, backoffDelay: 0 });\n      queue.next()!;\n      queue.fail(task.id, 'specific error message');\n\n      const dlq = queue.getDeadLetterQueue();\n      expect(dlq[0].lastError).toBe('specific error message');\n    });\n\n    it('should retry a dead-lettered task', () => {\n      const task = queue.add('retry-from-dlq', { maxRetries: 1, backoffDelay: 0 });\n      queue.next()!;\n      queue.fail(task.id, 'error');\n\n      expect(queue.getDeadLetterQueue()).toHaveLength(1);\n\n      const retried = queue.retryDeadLetter(task.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempt).toBe(0);\n      expect(queue.getDeadLetterQueue()).toHaveLength(0);\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should clear dead letter queue', () => {\n      const t1 = queue.add('doomed1', { maxRetries: 1, backoffDelay: 0 });\n      const t2 = queue.add('doomed2', { maxRetries: 1, backoffDelay: 0 });\n      queue.next()!;\n      queue.fail(t1.id, 'err1');\n      queue.next()!;\n      queue.fail(t2.id, 'err2');\n\n      expect(queue.getDeadLetterQueue()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterQueue()).toHaveLength(0);\n    });\n\n    it('should have independent DLQs per named queue', () => {\n      const t1 = queue.add('d1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      const t2 = queue.add('d2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n      queue.next('q1')!;\n      queue.fail(t1.id, 'err');\n      queue.next('q2')!;\n      queue.fail(t2.id, 'err');\n\n      expect(queue.getDeadLetterQueue('q1')).toHaveLength(1);\n      expect(queue.getDeadLetterQueue('q2')).toHaveLength(1);\n    });\n\n    it('should throw when retrying non-existent DLQ task', () => {\n      expect(() => queue.retryDeadLetter('nonexistent')).toThrow();\n    });\n  });\n\n  // ==================== Phase 7: Task Dependencies ====================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block a task with unresolved dependencies', () => {\n      const dep = queue.add('dependency');\n      const dependent = queue.add('dependent', { dependencies: [dep.id] });\n\n      // Should get the dependency first (not the dependent which is blocked)\n      const next = queue.next();\n      expect(next?.id).toBe(dep.id);\n\n      // The dependent should not be available\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should unblock a task when dependencies complete', () => {\n      const dep = queue.add('dependency');\n      const dependent = queue.add('dependent', { dependencies: [dep.id] });\n\n      const first = queue.next()!;\n      queue.complete(first.id);\n\n      const second = queue.next();\n      expect(second?.id).toBe(dependent.id);\n    });\n\n    it('should throw when depending on non-existent task', () => {\n      expect(() => queue.add('test', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = queue.add('dependency', { maxRetries: 1, backoffDelay: 0 });\n      const dependent = queue.add('dependent', { dependencies: [dep.id] });\n\n      const first = queue.next()!;\n      queue.fail(first.id, 'error');\n\n      // Dependent remains blocked since dep is failed, not completed\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should get dependency status', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      const status = queue.getDependencyStatus(dependent.id);\n      expect(status.total).toBe(2);\n      expect(status.completed).toBe(0);\n      expect(status.pending).toContain(dep1.id);\n      expect(status.pending).toContain(dep2.id);\n\n      // Complete one dependency\n      queue.next()!; // dep1 (priority 5, FIFO)\n      queue.complete(dep1.id);\n\n      const status2 = queue.getDependencyStatus(dependent.id);\n      expect(status2.completed).toBe(1);\n      expect(status2.pending).toHaveLength(1);\n    });\n\n    it('should support multiple dependencies', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      // Complete both deps\n      let t = queue.next()!;\n      queue.complete(t.id);\n      t = queue.next()!;\n      queue.complete(t.id);\n\n      // Now dependent should be available\n      const next = queue.next();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should expose dependencies on task object', () => {\n      const dep = queue.add('dep');\n      const task = queue.add('task', { dependencies: [dep.id] });\n      expect(task.dependencies).toContain(dep.id);\n    });\n  });\n\n  // ==================== Phase 8: Concurrency Control ====================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('t1');\n      queue.add('t2');\n      queue.add('t3');\n\n      const first = queue.next();\n      const second = queue.next();\n      expect(first).not.toBeNull();\n      expect(second).not.toBeNull();\n      expect(queue.next()).toBeNull(); // Limit reached\n    });\n\n    it('should free slot on completion', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const first = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.complete(first.id);\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should free slot on failure', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1', { maxRetries: 1, backoffDelay: 0 });\n      queue.add('t2');\n\n      const first = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.fail(first.id, 'err');\n      // first is now failed and in DLQ, slot is free\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should have unlimited concurrency by default', () => {\n      expect(queue.getConcurrency('default')).toBeUndefined();\n\n      for (let i = 0; i < 100; i++) {\n        queue.add(`t${i}`);\n      }\n      for (let i = 0; i < 100; i++) {\n        expect(queue.next()).not.toBeNull();\n      }\n    });\n\n    it('should report active count', () => {\n      queue.add('t1');\n      queue.add('t2');\n      expect(queue.getActiveCount()).toBe(0);\n\n      queue.next();\n      expect(queue.getActiveCount()).toBe(1);\n\n      queue.next();\n      expect(queue.getActiveCount()).toBe(2);\n    });\n\n    it('should still respect priority with concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const task = queue.next()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ==================== Phase 9: Progress and Cancellation ====================\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should report progress on a processing task', () => {\n      const task = queue.add('test');\n      const processing = queue.next()!;\n\n      queue.reportProgress(processing.id, 50, 'halfway');\n      const progress = queue.getProgress(processing.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      const task = queue.add('test');\n      const processing = queue.next()!;\n\n      const updates: number[] = [];\n      queue.onProgress(processing.id, (update) => {\n        updates.push(update.progress);\n      });\n\n      queue.reportProgress(processing.id, 25);\n      queue.reportProgress(processing.id, 50);\n      queue.reportProgress(processing.id, 75);\n\n      expect(updates).toEqual([25, 50, 75]);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      const task = queue.add('test');\n      const processing = queue.next()!;\n\n      const updates: number[] = [];\n      const unsub = queue.onProgress(processing.id, (update) => {\n        updates.push(update.progress);\n      });\n\n      queue.reportProgress(processing.id, 25);\n      unsub();\n      queue.reportProgress(processing.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = queue.add('cancel-me');\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = queue.add('cancel-me');\n      queue.next()!;\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = queue.add('cancel-me', { maxRetries: 3 });\n      queue.next()!;\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.getTask(task.id)?.maxRetries).toBe(0);\n    });\n\n    it('should throw when cancelling completed task', () => {\n      const task = queue.add('test');\n      queue.next()!;\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n\n    it('should throw when reporting progress on non-processing task', () => {\n      const task = queue.add('test');\n      expect(() => queue.reportProgress(task.id, 50)).toThrow();\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = queue.add('test');\n      queue.next()!;\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ==================== Phase 10: Recurring Tasks ====================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule('cleanup', '*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBe('cleanup');\n      expect(schedule.expression).toBe('*/5 * * * *');\n    });\n\n    it('should list schedules', () => {\n      queue.addSchedule('s1', '*/5 * * * *', 'default', {});\n      queue.addSchedule('s2', '0 * * * *', 'default', {});\n\n      const schedules = queue.listSchedules();\n      expect(schedules).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      queue.addSchedule('s1', '*/5 * * * *', 'default', {});\n      expect(queue.removeSchedule('s1')).toBe(true);\n      expect(queue.listSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when due', () => {\n      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'scheduled' });\n\n      // Tick at minute 0 (0 % 5 === 0, should match)\n      const now = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = queue.tick(now);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'scheduled' });\n    });\n\n    it('should not enqueue if not due', () => {\n      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'scheduled' });\n\n      // Tick at minute 3 (3 % 5 !== 0, should not match)\n      const now = new Date(2024, 0, 1, 12, 3, 0);\n      const tasks = queue.tick(now);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not double-enqueue at the same time', () => {\n      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'scheduled' });\n\n      const now = new Date(2024, 0, 1, 12, 0, 0);\n      queue.tick(now);\n      const tasks = queue.tick(now);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not create tasks after schedule is removed', () => {\n      queue.addSchedule('every5', '*/5 * * * *', 'default', { type: 'scheduled' });\n      queue.removeSchedule('every5');\n\n      const now = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = queue.tick(now);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should support hourly schedule', () => {\n      queue.addSchedule('hourly', '0 * * * *', 'default', { type: 'hourly' });\n\n      // Should trigger at xx:00\n      const atHour = new Date(2024, 0, 1, 14, 0, 0);\n      expect(queue.tick(atHour)).toHaveLength(1);\n\n      // Should not trigger at xx:30\n      const notAtHour = new Date(2024, 0, 1, 14, 30, 0);\n      expect(queue.tick(notAtHour)).toHaveLength(0);\n    });\n\n    it('should support daily schedule', () => {\n      queue.addSchedule('daily', '0 0 * * *', 'default', { type: 'daily' });\n\n      // Should trigger at midnight\n      const midnight = new Date(2024, 0, 1, 0, 0, 0);\n      expect(queue.tick(midnight)).toHaveLength(1);\n\n      // Should not trigger at noon\n      const noon = new Date(2024, 0, 1, 12, 0, 0);\n      expect(queue.tick(noon)).toHaveLength(0);\n    });\n\n    it('recurring tasks should be regular tasks', () => {\n      queue.addSchedule('test', '*/1 * * * *', 'myqueue', { data: true });\n\n      const now = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = queue.tick(now);\n      expect(tasks[0].queue).toBe('myqueue');\n      expect(tasks[0].status).toBe('pending');\n    });\n  });\n\n  // ==================== Phase 11: Middleware Pipeline ====================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: string[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push('m1-before');\n        await next();\n        order.push('m1-after');\n      });\n      queue.use('default', async (_task, next) => {\n        order.push('m2-before');\n        await next();\n        order.push('m2-after');\n      });\n      queue.handle('default', async () => {\n        order.push('handler');\n      });\n\n      const task = queue.add('test');\n      const processing = queue.next()!;\n      await queue.process(processing.id);\n\n      expect(order).toEqual(['m1-before', 'm2-before', 'handler', 'm2-after', 'm1-after']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      queue.use('default', async () => {\n        // Don't call next\n      });\n      queue.handle('default', async () => {\n        handlerCalled = true;\n      });\n\n      const task = queue.add('test');\n      queue.next()!;\n      await queue.process(task.id);\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        (task as Record<string, unknown>).metadata = { enriched: true };\n        await next();\n      });\n\n      let receivedTask: Record<string, unknown> | null = null;\n      queue.handle('default', async (task) => {\n        receivedTask = task as Record<string, unknown>;\n      });\n\n      const task = queue.add('test');\n      queue.next()!;\n      await queue.process(task.id);\n\n      expect(receivedTask?.metadata).toEqual({ enriched: true });\n    });\n\n    it('should fail task if middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = queue.add('test', { maxRetries: 1, backoffDelay: 0 });\n      queue.next()!;\n      await queue.process(task.id);\n\n      // Should be failed (since maxRetries=1, one attempt used)\n      expect(queue.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      let q1Called = false;\n      let q2Called = false;\n\n      queue.use('q1', async (_task, next) => {\n        q1Called = true;\n        await next();\n      });\n      queue.use('q2', async (_task, next) => {\n        q2Called = true;\n        await next();\n      });\n      queue.handle('q1', async () => {});\n      queue.handle('q2', async () => {});\n\n      const t1 = queue.add('test', { queue: 'q1' });\n      queue.next('q1')!;\n      await queue.process(t1.id);\n\n      expect(q1Called).toBe(true);\n      expect(q2Called).toBe(false);\n    });\n\n    it('should invoke handler when no middleware registered', async () => {\n      let handlerCalled = false;\n      queue.handle('default', async () => {\n        handlerCalled = true;\n      });\n\n      const task = queue.add('test');\n      queue.next()!;\n      await queue.process(task.id);\n\n      expect(handlerCalled).toBe(true);\n    });\n  });\n\n  // ==================== Phase 12: Graceful Shutdown ====================\n  describe('Phase 12: Gracefu