turn false;\n    }\n\n    // Check if we already ran at this time\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDate = schedule.lastRun.toDateString();\n      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === now.toDateString()) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  // Phase 11: Register middleware\n  use(queueName: string, middleware: MiddlewareFn): void {\n    if (!this.middlewareStacks.has(queueName)) {\n      this.middlewareStacks.set(queueName, []);\n    }\n    this.middlewareStacks.get(queueName)!.push(middleware);\n  }\n\n  // Phase 11: Register handler\n  handle(queueName: string, handler: HandlerFn): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  // Phase 11: Process a task through middleware pipeline and handler\n  async process(taskId: string): Promise<void> {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task is not in processing state: ${task.status}`);\n    }\n\n    const middleware = this.middlewareStacks.get(task.queue) ?? [];\n    const handler = this.handlers.get(task.queue);\n\n    try {\n      await this.executeMiddlewareChain(task, middleware, 0, handler);\n    } catch (err) {\n      this.fail(taskId, err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  private async executeMiddlewareChain(\n    task: Task,\n    middleware: MiddlewareFn[],\n    index: number,\n    handler?: HandlerFn\n  ): Promise<void> {\n    if (index < middleware.length) {\n      let nextCalled = false;\n      await middleware[index](task, async () => {\n        nextCalled = true;\n        await this.executeMiddlewareChain(task, middleware, index + 1, handler);\n      });\n      // If next was not called, processing is skipped\n    } else if (handler) {\n      await handler(task);\n    }\n  }\n\n  // Phase 12: Register shutdown callback\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  // Phase 12: Graceful shutdown\n  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(timeout);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(timeout: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Wait for processing tasks to complete\n    const processingTasks = this.getProcessingTasks();\n\n    if (processingTasks.length > 0) {\n      const result = await Promise.race([\n        this.waitForTasksToComplete(processingTasks),\n        new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),\n      ]);\n\n      if (result === 'timeout') {\n        // Force cancel remaining processing tasks\n        for (const task of processingTasks) {\n          if (task.status === 'processing') {\n            task.status = 'cancelled';\n            forceCancelled++;\n          }\n        }\n      }\n    }\n\n    // Count completed tasks\n    for (const task of this.tasks.values()) {\n      if (task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    const duration = Date.now() - startTime;\n\n    return { completed, forceCancelled, duration };\n  }\n\n  private getProcessingTasks(): Task[] {\n    const tasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        tasks.push(task);\n      }\n    }\n    return tasks;\n  }\n\n  private async waitForTasksToComplete(tasks: Task[]): Promise<void> {\n    // Poll until all tasks are done\n    while (tasks.some(t => t.status === 'processing')) {\n      await new Promise(resolve => setTimeout(resolve, 50));\n    }\n  }\n\n  // Helper: Get a task by ID\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // Helper: Check if shutting down\n  get shuttingDown(): boolean {\n    return this.isShuttingDown;\n  }\n}\n","structuredPatch":[{"oldStart":539,"oldLines":12,"newStart":539,"newLines":9,"lines":["     handler?: HandlerFn","   ): Promise<void> {","     if (index < middleware.length) {","-      let nextCalled = false;","       await middleware[index](task, async () => {","-        nextCalled = true;","         await this.executeMiddlewareChain(task, middleware, index + 1, handler);","       });","-      // If next was not called, processing is skipped","     } else if (handler) {","       await handler(task);","     }"]}],"userModified":false,"replaceAll":false}}
