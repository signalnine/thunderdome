eue.add('test', { queue: 'q1' });\n      queue.next('q1')!;\n      await queue.process(t1.id);\n\n      expect(q1Called).toBe(true);\n      expect(q2Called).toBe(false);\n    });\n\n    it('should invoke handler when no middleware registered', async () => {\n      let handlerCalled = false;\n      queue.handle('default', async () => {\n        handlerCalled = true;\n      });\n\n      const task = queue.add('test');\n      queue.next()!;\n      await queue.process(task.id);\n\n      expect(handlerCalled).toBe(true);\n    });\n  });\n\n  // ==================== Phase 12: Graceful Shutdown ====================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.add('test')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately when no tasks are processing', async () => {\n      const result = await queue.shutdown();\n      expect(result.forceCancelled).toBe(0);\n      expect(result.duration).toBeDefined();\n    });\n\n    it('should wait for processing tasks to finish', async () => {\n      const task = queue.add('test');\n      const processing = queue.next()!;\n\n      // Start shutdown, but complete the task quickly\n      const shutdownPromise = queue.shutdown(5000);\n\n      // Complete the task\n      queue.complete(processing.id);\n\n      const result = await shutdownPromise;\n      expect(result.completed).toBeGreaterThanOrEqual(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel tasks that exceed timeout', async () => {\n      const task = queue.add('slow-task');\n      queue.next()!; // Move to processing\n\n      const result = await queue.shutdown(100);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      queue.onShutdown(() => {\n        callbackRan = true;\n      });\n\n      await queue.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should return same result when called multiple times', async () => {\n      const result1Promise = queue.shutdown();\n      const result2Promise = queue.shutdown();\n\n      const [result1, result2] = await Promise.all([result1Promise, result2Promise]);\n      expect(result1).toBe(result2);\n    });\n\n    it('should report shutdown duration', async () => {\n      const result = await queue.shutdown();\n      expect(typeof result.duration).toBe('number');\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should indicate shutting down state', async () => {\n      expect(queue.shuttingDown).toBe(false);\n      const promise = queue.shutdown();\n      expect(queue.shuttingDown).toBe(true);\n      await promise;\n    });\n  });\n\n  // ==================== Integration Tests ====================\n  describe('Integration', () => {\n    it('should handle priority + delay interaction', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('delayed-high', { priority: 1, processAt: past });\n      queue.add('immediate-low', { priority: 10 });\n\n      // High priority delayed (now available) should come first\n      expect(queue.next()?.payload).toBe('delayed-high');\n      expect(queue.next()?.payload).toBe('immediate-low');\n    });\n\n    it('should handle dependencies + priority interaction', () => {\n      const dep = queue.add('dependency', { priority: 10 });\n      const dependent = queue.add('high-priority-dependent', { priority: 1, dependencies: [dep.id] });\n\n      // Despite higher priority, dependent is blocked\n      expect(queue.next()?.payload).toBe('dependency');\n    });\n\n    it('should handle retry + concurrency interaction', () => {\n      queue.setConcurrency('default', 1);\n      const task = queue.add('test', { maxRetries: 2, backoffDelay: 0 });\n\n      const r1 = queue.next()!;\n      queue.fail(r1.id, 'err');\n\n      // Task