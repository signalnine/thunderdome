+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K8RmATBgdzvo2NiputzSpi","type":"tool_result","content":"     1→export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';\n     2→\n     3→export interface TaskOptions {\n     4→  queue?: string;\n     5→  priority?: number;\n     6→  delay?: number;\n     7→  processAt?: Date;\n     8→  maxRetries?: number;\n     9→  backoffDelay?: number;\n    10→  dependencies?: string[];\n    11→}\n    12→\n    13→export interface Task<T = unknown> {\n    14→  id: string;\n    15→  payload: T;\n    16→  status: TaskStatus;\n    17→  queue: string;\n    18→  priority: number;\n    19→  createdAt: Date;\n    20→  availableAt: Date;\n    21→  attempt: number;\n    22→  maxRetries: number;\n    23→  backoffDelay: number;\n    24→  error?: string;\n    25→  dependencies: string[];\n    26→  progress: number;\n    27→  progressMessage?: string;\n    28→}\n    29→\n    30→export interface ProgressUpdate {\n    31→  taskId: string;\n    32→  progress: number;\n    33→  message?: string;\n    34→}\n    35→\n    36→export type ProgressListener = (update: ProgressUpdate) => void;\n    37→\n    38→export interface CronSchedule {\n    39→  id: string;\n    40→  expression: string;\n    41→  queue: string;\n    42→  payload: unknown;\n    43→  lastRun?: Date;\n    44→}\n    45→\n    46→export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;\n    47→export type HandlerFn = (task: Task) => Promise<void> | void;\n    48→\n    49→export interface ShutdownResult {\n    50→  completed: number;\n    51→  forceCancelled: number;\n    52→  duration: number;\n    53→}\n    54→\n    55→export interface DeadLetteredTask<T = unknown> extends Task<T> {\n    56→  failCount: number;\n    57→  lastError?: string;\n    58→}\n    59→"}]},"parent_tool_use_id":"toolu_017KMV2pozodt7UcKq2jyU7n","session_id":"9304892a-c807-4021-8cf4-c5e580d7ff90","uuid":"fc388e69-1296-4877-8650-e853