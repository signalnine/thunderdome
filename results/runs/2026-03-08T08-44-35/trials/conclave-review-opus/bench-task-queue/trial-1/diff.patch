ds.indexOf(task.id);\n   209→      if (idx !== -1) {\n   210→        queueIds.splice(idx, 1);\n   211→      }\n   212→    }\n   213→  }\n   214→\n   215→  // Phase 6: Get dead-lettered tasks\n   216→  getDeadLetterQueue(queueName: string = DEFAULT_QUEUE): DeadLetteredTask[] {\n   217→    return this.deadLetterQueues.get(queueName) ?? [];\n   218→  }\n   219→\n   220→  // Phase 6: Retry a dead-lettered task\n   221→  retryDeadLetter(taskId: string): Task {\n   222→    for (const [queueName, dlqTasks] of this.deadLetterQueues) {\n   223→      const idx = dlqTasks.findIndex(t => t.id === taskId);\n   224→      if (idx !== -1) {\n   225→        dlqTasks.splice(idx, 1);\n   226→\n   227→        // Reset task for fresh retry\n   228→        const task = this.tasks.get(taskId);\n   229→        if (!task) {\n   230→          throw new Error(`Task not found: ${taskId}`);\n   231→        }\n   232→        task.status = 'pending';\n   233→        task.attempt = 0;\n   234→        task.error = undefined;\n   235→        task.progress = 0;\n   236→        task.availableAt = new Date();\n   237→\n   238→        // Re-add to queue\n   239→        if (!this.queues.has(queueName)) {\n   240→          this.queues.set(queueName, []);\n   241→        }\n   242→        this.queues.get(queueName)!.push(task.id);\n   243→\n   244→        return task;\n   245→      }\n   246→    }\n   247→    throw new Error(`Dead-lettered task not found: ${taskId}`);\n   248→  }\n   249→\n   250→  // Phase 6: Clear dead letter queue\n   251→  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n   252→    const dlqTasks = this.deadLetterQueues.get(queueName);\n   253→    if (dlqTasks) {\n   254→      // Also remove the tasks from the tasks map\n   255→      for (const t of dlqTasks) {\n   256→        this.tasks.delete(t.id);\n   257→      }\n   258→      this.deadLetterQueues.set(queueName, []);\n   259→    }\n   260→  }\n   261→\n   262→  // Phase 7: Check if dependencies are met\n   263→  private areDependenciesMet(task: Task): boolean {\n   264→    if (task.dependencies.length === 0) return true;\n   265→    return task.dependencies.every(depId => {\n   266→      const dep = this.tasks.get(depId);\n   267→      return dep && dep.status === 'completed';\n   268→    });\n   269→  }\n   270→\n   271→  // Phase 7: Detect circular dependencies at task creation time.\n   272→  // Since a new task gets a fresh UUID, no existing task can reference it,\n   273→  // making direct cycles impossible. However, we still validate that all\n   274→  // dependency IDs exist (done in add()). If addDependency were supported\n   275→  // on existing tasks, we'd need full cycle detection there.\n   276→\n   277→  // Phase 7: Get dependency status\n   278→  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {\n   279→    const task = this.tasks.get(taskId);\n   280→    if (!task) {\n   281→      throw new Error(`Task not found: ${taskId}`);\n   282→    }\n   283→\n   284→    const pendingDeps: string[] = [];\n   285→    let completedCount = 0;\n   286→\n   287→    for (const depId of task.dependencies) {\n   288→      const dep = this.tasks.get(depId);\n   289→      if (dep && dep.status === 'completed') {\n   290→        completedCount++;\n   291→      } else {\n   292→        pendingDeps.push(depId);\n   293→      }\n   294→    }\n   295→\n   296→    return {\n   297→      total: task.dependencies.length,\n   298→      completed: completedCount,\n   299→      pending: pendingDeps,\n   300→    };\n   301→  }\n   302→\n   303→  // Phase 8: Set concurrency limit\n   304→  setConcurrency(queueName: string, limit: number): void {\n   305→    if (limit < 1) {\n   306→      throw new Error('Concurrency limit must be at least 1');\n   307→    }\n   308→    this.concurrencyLimits.set(queueName, limit);\n   309→  }\n   310→\n   311→  // Phase 8: Get concurrency limit\n   312→  getConcurrency(queueName: string): number | undefined {\n   313→    return this.concurrencyLimits.get(queueName);\n   314→  }\n   315→\n   316→  // Phase 8: Get active (processing) count\n   317→  getActiveCount(queueName: string = DEFAULT_QUEUE): number {\n   318→    const taskIds = this.queues.get(queueName);\n   319→    if (!taskIds) return 0;\n   320→    return taskIds.filter(id => {\n   321→      const t = this.tasks.get(id);\n   322→      return t && t.status === 'processing';\n   323→    }).length;\n   324→  }\n   325→\n   326→  // Phase 9: Report progress\n   327→  reportProgress(taskId: string, progress: number, message?: string): void {\n   328→    const task = this.tasks.get(taskId);\n   329→    if (!task) {\n   330→      throw new Error(`Task not found: ${taskId}`);\n   331→    }\n   332→    if (task.status !== 'processing') {\n   333→      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n   334→    }\n   335→    if (progress < 0 || progress > 100) {\n   336→      throw new Error(`Progress must be between 0 and 100, got: ${progress}`);\n   337→    }\n   338→\n   339→    task.progress = progress;\n   340→    task.progressMessage = message;\n   341→\n   342→    const update: ProgressUpdate = { taskId, progress, message };\n   343→    const listeners = this.progressListeners.get(taskId);\n   344→    if (listeners) {\n   345→      for (const listener of listeners) {\n   346→        listener(update);\n   347→      }\n   348→    }\n   349→  }\n   350→\n   351→  // Phase 9: Subscribe to progress updates\n   352→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   353→    if (!this.progressListeners.has(taskId)) {\n   354→      this.progressListeners.set(taskId, new Set());\n   355→    }\n   356→    this.progressListeners.get(taskId)!.add(listener);\n   357→\n   358→    // Return unsubscribe function\n   359→    return () => {\n   360→      const listeners = this.progressListeners.get(taskId);\n   361→      if (listeners) {\n   362→        listeners.delete(listener);\n   363→        if (listeners.size === 0) {\n   364→          this.progressListeners.delete(taskId);\n   365→        }\n   366→      }\n   367→    };\n   368→  }\n   369→\n   370→  // Phase 9: Cancel a task\n   371→  cancel(taskId: string): void {\n   372→    const task = this.tasks.get(taskId);\n   373→    if (!task) {\n   374→      throw new Error(`Task not found: ${taskId}`);\n   375→    }\n   376→    if (task.status !== 'pending' && task.status !== 'processing') {\n   377→      throw new Error(`Cannot cancel task in status: ${task.status}`);\n   378→    }\n   379→\n   380→    task.status = 'cancelled';\n   381→    // Set maxRetries to 0 so it won't be retried\n   382→    task.maxRetries = 0;\n   383→  }\n   384→\n   385→  // Phase 9: Get task progress\n   386→  getProgress(taskId: string): { progress: number; message?: string } {\n   387→    const task = this.tasks.get(taskId);\n   388→    if (!task) {\n   389→      throw new Error(`Task not found: ${taskId}`);\n   390→    }\n   391→    return { progress: task.progress, message: task.progressMessage };\n   392→  }\n   393→\n   394→  // Phase 10: Add a recurring schedule\n   395→  addSchedule(id: string, expression: string, queueName: string, payload: unknown): CronSchedule {\n   396→    if (this.isShuttingDown) {\n   397→      throw new Error('Queue system is shutting down');\n   398→    }\n   399→    this.validateCronExpression(expression);\n   400→\n   401→    const schedule: CronSchedule = {\n   402→      id,\n   403→      expression,\n   404→      queue: queueName,\n   405→      payload,\n   406→    };\n   407→    this.schedules.set(id, schedule);\n   408→    return schedule;\n   409→  }\n   410→\n   411→  // Phase 10: Remove a schedule\n   412→  removeSchedule(id: string): boolean {\n   413→    return this.schedules.delete(id);\n   414→  }\n   415→\n   416→  // Phase 10: List schedules\n   417→  listSchedules(): CronSchedule[] {\n   418→    return Array.from(this.schedules.values());\n   419→  }\n   420→\n   421→  // Phase 10: Tick - check schedules and enqueue due tasks\n   422→  tick(now: Date = new Date()): Task[] {\n   423→    const created: Task[] = [];\n   424→\n   425→    for (const schedule of this.schedules.values()) {\n   426→      if (this.shouldRunSchedule(schedule, now)) {\n   427→        const task = this.add(schedule.payload, { queue: schedule.queue });\n   428→        created.push(task);\n   429→        schedule.lastRun = now;\n   430→      }\n   431→    }\n   432→\n   433→    return created;\n   434→  }\n   435→\n   436→  private validateCronExpression(expr: string): void {\n   437→    const parts = expr.trim().split(/\\s+/);\n   438→    if (parts.length !== 5) {\n   439→      throw new Error(`Invalid cron expression: ${expr}. Must have 5 fields.`);\n   440→    }\n   441→\n   442→    // Validate minute field\n   443→    const minute = parts[0];\n   444→    if (minute !== '*' && !minute.startsWith('*/') && !/^\\d+$/.test(minute)) {\n   445→      throw new Error(`Invalid cron minute field: ${minute}`);\n   446→    }\n   447→\n   448→    // Validate hour field\n   449→    const hour = parts[1];\n   450→    if (hour !== '*' && !hour.startsWith('*/') && !/^\\d+$/.test(hour)) {\n   451→      throw new Error(`Invalid cron hour field: ${hour}`);\n   452→    }\n   453→  }\n   454→\n   455→  private shouldRunSchedule(schedule: CronSchedule, now: Date): boolean {\n   456→    const parts = schedule.expression.trim().split(/\\s+/);\n   457→    const minutePart = parts[0];\n   458→    const hourPart = parts[1];\n   459→\n   460→    const currentMinute = now.getMinutes();\n   461→    const currentHour = now.getHours();\n   462→\n   463→    // Check minute match\n   464→    let minuteMatch = false;\n   465→    if (minutePart === '*') {\n   466→      minuteMatch = true;\n   467→    } else if (minutePart.startsWith('*/')) {\n   468→      const interval = parseInt(minutePart.slice(2), 10);\n   469→      minuteMatch = currentMinute % interval === 0;\n   470→    } else {\n   471→      minuteMatch = currentMinute === parseInt(minutePart, 10);\n   472→    }\n   473→\n   474→    // Check hour match\n   475→    let hourMatch = false;\n   476→    if (hourPart === '*') {\n   477→      hourMatch = true;\n   478→    } else if (hourPart.startsWith('*/')) {\n   479→      const interval = parseInt(hourPart.slice(2), 10);\n   480→      hourMatch = currentHour % interval === 0;\n   481→    } else {\n   482→      hourMatch = currentHour === parseInt(hourPart, 10);\n   483→    }\n   484→\n   485→    if (!minuteMatch || !hourMatch) {\n   486→      return false;\n   487→    }\n   488→\n   489→    // Check if we already ran at this time\n   490→    if (schedule.lastRun) {\n   491→      const lastMinute = schedule.lastRun.getMinutes();\n   492→      const lastHour = schedule.lastRun.getHours();\n   493→      const lastDate = schedule.lastRun.toDateString();\n   494→      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === now.toDateString()) {\n   495→        return false;\n   496→      }\n   497→    }\n   498→\n   499→    return true;\n   500→  }\n   501→\n   502→  // Phase 11: Register middleware\n   503→  use(queueName: string, middleware: MiddlewareFn): void {\n   504→    if (!this.middlewareStacks.has(queueName)) {\n   505→      this.middlewareStacks.set(queueName, []);\n   506→    }\n   507→    this.middlewareStacks.get(queueName)!.push(middleware);\n   508→  }\n   509→\n   510→  // Phase 11: Register handler\n   511→  handle(queueName: string, handler: HandlerFn): void {\n   512→    this.handlers.set(queueName, handler);\n   513→  }\n   514→\n   515→  // Phase 11: Process a task through middleware pipeline and handler\n   516→  async process(taskId: string): Promise<void> {\n   517→    const task = this.tasks.get(taskId);\n   518→    if (!task) {\n   519→      throw new Error(`Task not found: ${taskId}`);\n   520→    }\n   521→    if (task.status !== 'processing') {\n   522→      throw new Error(`Task is not in processing state: ${task.status}`);\n   523→    }\n   524→\n   525→    const middleware = this.middlewareStacks.get(task.queue) ?? [];\n   526→    const handler = this.handlers.get(task.queue);\n   527→\n   528→    try {\n   529→      await this.executeMiddlewareChain(task, middleware, 0, handler);\n   530→    } catch (err) {\n   531→      this.fail(taskId, err instanceof Error ? err.message : String(err));\n   532→    }\n   533→  }\n   534→\n   535→  private async executeMiddlewareChain(\n   536→    task: Task,\n   537→    middleware: MiddlewareFn[],\n   538→    index: number,\n   539→    handler?: HandlerFn\n   540→  ): Promise<void> {\n   541→    if (index < middleware.length) {\n   542→      await middleware[index](task, async () => {\n   543→        await this.executeMiddlewareChain(task, middleware, index + 1, handler);\n   544→      });\n   545→    } else if (handler) {\n   546→      await handler(task);\n   547→    }\n   548→  }\n   549→\n   550→  // Phase 12: Register shutdown callback\n   551→  onShutdown(callback: () => void | Promise<void>): void {\n   552→    this.shutdownCallbacks.push(callback);\n   553→  }\n   554→\n   555→  // Phase 12: Graceful shutdown\n   556→  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {\n   557→    if (this.shutdownPromise) {\n   558→      return this.shutdownPromise;\n   559→    }\n   560→\n   561→    this.isShuttingDown = true;\n   562→    this.shutdownPromise = this.performShutdown(timeout);\n   563→    return this.shutdownPromise;\n   564→  }\n   565→\n   566→  private async performShutdown(timeout: number): Promise<ShutdownResult> {\n   567→    const startTime = Date.now();\n   568→    let completed = 0;\n   569→    let forceCancelled = 0;\n   570→\n   571→    // Run shutdown callbacks\n   572→    for (const cb of this.shutdownCallbacks) {\n   573→      await cb();\n   574→    }\n   575→\n   576→    // Wait for processing tasks to complete\n   577→    const processingTasks = this.getProcessingTasks();\n   578→\n   579→    if (processingTasks.length > 0) {\n   580→      const result = await Promise.race([\n   581→        this.waitForTasksToComplete(processingTasks),\n   582→        new Promise<'timeout'>(resolve => setTimeout(() => resolve('timeout'), timeout)),\n   583→      ]);\n   584→\n   585→      if (result === 'timeout') {\n   586→        // Force cancel remaining processing tasks\n   587→        for (const task of processingTasks) {\n   588→          if (task.status === 'processing') {\n   589→            task.status = 'cancelled';\n   590→            forceCancelled++;\n   591→          }\n   592→        }\n   593→      }\n   594→    }\n   595→\n   596→    // Count completed tasks\n   597→    for (const task of this.tasks.values()) {\n   598→      if (task.status === 'completed') {\n   599→        completed++;\n   600→      }\n   601→    }\n   602→\n   603→    const duration = Date.now() - startTime;\n   604→\n   605→    return { completed, forceCancelled, duration };\n   606→  }\n   607→\n   608→  private getProcessingTasks(): Task[] {\n   609→    const tasks: Task[] = [];\n   610→    for (const task of this.tasks.values()) {\n   611→      if (task.status === 'processing') {\n   612→        tasks.push(task);\n   613→      }\n   614→    }\n   615→    return tasks;\n   616→  }\n   617→\n   618→  private async waitForTasksToComplete(tasks: Task[]): Promise<void> {\n   619→    // Poll until all tasks are done\n   620→    while (tasks.some(t => t.status === 'processing')) {\n   621→      await new Promise(resolve => setTimeout(resolve, 50));\n   622→    }\n   623→  }\n   624→\n   625→  // Helper: Get a task by ID\n   626→  getTask(taskId: string): Task | undefined {\n   627→    return this.tasks.get(taskId);\n   628→  }\n   629→\n   630→  // Helper: Check if shutting down\n   631→  get shuttingDown(): boolean {\n   632→    return this.isShuttingDown;\n   633→  }\n   634→}\n   635→"}]},"parent_tool_use_id":null,"session_id":"9304892a-c807-4021-8cf4-c5e580d7ff90","uuid":"20