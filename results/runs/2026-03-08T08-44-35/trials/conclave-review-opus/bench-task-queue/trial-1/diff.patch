ueue.add('test', { queue: 'q1' });\n   773→      queue.next('q1')!;\n   774→      await queue.process(t1.id);\n   775→\n   776→      expect(q1Called).toBe(true);\n   777→      expect(q2Called).toBe(false);\n   778→    });\n   779→\n   780→    it('should invoke handler when no middleware registered', async () => {\n   781→      let handlerCalled = false;\n   782→      queue.handle('default', async () => {\n   783→        handlerCalled = true;\n   784→      });\n   785→\n   786→      const added = queue.add('test');\n   787→      queue.next()!;\n   788→      await queue.process(added.id);\n   789→\n   790→      expect(handlerCalled).toBe(true);\n   791→    });\n   792→  });\n   793→\n   794→  // ==================== Phase 12: Graceful Shutdown ====================\n   795→  describe('Phase 12: Graceful Shutdown', () => {\n   796→    it('should reject new tasks after shutdown', async () => {\n   797→      await queue.shutdown();\n   798→      expect(() => queue.add('test')).toThrow(/shutting down/);\n   799→    });\n   800→\n   801→    it('should complete immediately when no tasks are processing', async () => {\n   802→      const result = await queue.shutdown();\n   803→      expect(result.forceCancelled).toBe(0);\n   804→      expect(result.duration).toBeDefined();\n   805→    });\n   806→\n   807→    it('should wait for processing tasks to finish', async () => {\n   808→      queue.add('test');\n   809→      const processing = queue.next()!;\n   810→\n   811→      const shutdownPromise = queue.shutdown(5000);\n   812→      queue.complete(processing.id);\n   813→\n   814→      const result = await shutdownPromise;\n   815→      expect(result.completed).toBeGreaterThanOrEqual(1);\n   816→      expect(result.forceCancelled).toBe(0);\n   817→    });\n   818→\n   819→    it('should force-cancel tasks that exceed timeout', async () => {\n   820→      queue.add('slow-task');\n   821→      queue.next()!;\n   822→\n   823→      const result = await queue.shutdown(100);\n   824→      expect(result.forceCancelled).toBe(1);\n   825→    });\n   826→\n   827→    it('should run shutdown callbacks', async () => {\n   828→      let callbackRan = false;\n   829→      queue.onShutdown(() => {\n   830→        callbackRan = true;\n   831→      });\n   832→\n   833→      await queue.shutdown();\n   834→      expect(callbackRan).toBe(true);\n   835→    });\n   836→\n   837→    it('should return same result when called multiple times', async () => {\n   838→      const result1Promise = queue.shutdown();\n   839→      const result2Promise = queue.shutdown();\n   840→\n   841→      const [result1, result2] = await Promise.all([result1Promise, result2Promise]);\n   842→      expect(result1).toBe(result2);\n   843→    });\n   844→\n   845→    it('should report shutdown duration', async () => {\n   846→      const result = await queue.shutdown();\n   847→      expect(typeof result.duration).toBe('number');\n   848→      expect(result.duration).toBeGreaterThanOrEqual(0);\n   849→    });\n   850→\n   851→    it('should indicate shutting down state', async () => {\n   852→      expect(queue.shuttingDown).toBe(false);\n   853→      const promise = queue.shutdown();\n   854→      expect(queue.shuttingDown).toBe(true);\n   855→      await promise;\n   856→    });\n   857→  });\n   858→\n   859→  // ==================== Integration Tests ====================\n   860→  describe('Integration', () => {\n   861→    it('should handle priority + delay interaction', () => {\n   862→      const past = new Date(Date.now() - 1000);\n   863→      queue.add('delayed-high', { priority: 1, processAt: past });\n   864→      queue.add('immediate-low', { priority: 10 });\n   865→\n   866→      expect(queue.next()?.payload).toBe('delayed-high');\n   867→      expect(queue.next()?.payload).toBe('immediate-low');\n   868→    });\n   869→\n   870→    it('should handle dependencies + priority interaction', () => {\n   871→      const dep = queue.add('dependency', { priority: 10 });\n   872→      queue.add('high-priority-dependent', { priority: 1, dependencies: [dep.id] });\n   873→\n   874→      expect(queue.next()?.payload).toBe('dependency');\n   875→    });\n   876→\n   877→    it('should handle retry + concurrency interaction', () => {\n   878→      queue.setConcurrency('default', 1);\n   879→      queue.add('test', { maxRetries: 2, backoffDelay: 0 });\n   880→\n   881→      const r1 = queue.next()!;\n   882→      queue.fail(r1.id, 'err');\n   883→\n   884→      // Task is re-queued. With backoffDelay=0, delay is 0ms\n   885→      // The task should be immediately available again\n   886→      const r2 = queue.next();\n   887→      expect(r2).not.toBeNull();\n   888→    });\n   889→\n   890→    it('should handle full lifecycle', async () => {\n   891→      queue.setConcurrency('default', 2);\n   892→\n   893→      queue.use('default', async (t, next) => {\n   894→        // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   895→        (t as any).processed = true;\n   896→        await next();\n   897→      });\n   898→\n   899→      queue.handle('default', async () => {\n   900→        // Handler runs\n   901→      });\n   902→\n   903→      queue.add('task1', { priority: 1 });\n   904→      queue.add('task2', { priority: 5 });\n   905→      queue.add('task3', { priority: 10 });\n   906→\n   907→      const p1 = queue.next()!;\n   908→      queue.next()!; // p2\n   909→      expect(queue.next()).toBeNull();\n   910→\n   911→      await queue.process(p1.id);\n   912→      queue.complete(p1.id);\n   913→\n   914→      const p3 = queue.next()!;\n   915→      expect(p3.payload).toBe('task3');\n   916→    });\n   917→  });\n   918→});\n   919→"}]},"parent_tool_use_id":"toolu_017KMV2pozodt7UcKq2jyU7n","session_id":"9304892a-c807-4021-8cf4-c5e580d7ff90","uuid":"659a8bd6-9c51-4fd9-aa82-ec871d18b0fc"}
