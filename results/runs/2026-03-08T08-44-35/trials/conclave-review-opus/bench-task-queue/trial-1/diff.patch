ffDelay: 0 });\n   319→      queue.next()!;\n   320→      queue.fail(task.id, 'error');\n   321→\n   322→      expect(queue.getDeadLetterQueue()).toHaveLength(1);\n   323→\n   324→      const retried = queue.retryDeadLetter(task.id);\n   325→      expect(retried.status).toBe('pending');\n   326→      expect(retried.attempt).toBe(0);\n   327→      expect(queue.getDeadLetterQueue()).toHaveLength(0);\n   328→      expect(queue.size()).toBe(1);\n   329→    });\n   330→\n   331→    it('should clear dead letter queue', () => {\n   332→      const t1 = queue.add('doomed1', { maxRetries: 1, backoffDelay: 0 });\n   333→      const t2 = queue.add('doomed2', { maxRetries: 1, backoffDelay: 0 });\n   334→      queue.next()!;\n   335→      queue.fail(t1.id, 'err1');\n   336→      queue.next()!;\n   337→      queue.fail(t2.id, 'err2');\n   338→\n   339→      expect(queue.getDeadLetterQueue()).toHaveLength(2);\n   340→      queue.clearDeadLetterQueue();\n   341→      expect(queue.getDeadLetterQueue()).toHaveLength(0);\n   342→    });\n   343→\n   344→    it('should have independent DLQs per named queue', () => {\n   345→      const t1 = queue.add('d1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n   346→      const t2 = queue.add('d2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n   347→      queue.next('q1')!;\n   348→      queue.fail(t1.id, 'err');\n   349→      queue.next('q2')!;\n   350→      queue.fail(t2.id, 'err');\n   351→\n   352→      expect(queue.getDeadLetterQueue('q1')).toHaveLength(1);\n   353→      expect(queue.getDeadLetterQueue('q2')).toHaveLength(1);\n   354→    });\n   355→\n   356→    it('should throw when retrying non-existent DLQ task', () => {\n   357→      expect(() => queue.retryDeadLetter('nonexistent')).toThrow();\n   358→    });\n   359→  });\n   360→\n   361→  // ==================== Phase 7: Task Dependencies ====================\n   362→  describe('Phase 7: Task Dependencies', () => {\n   363→    it('should block a task with unresolved dependencies', () => {\n   364→      const dep = queue.add('dependency');\n   365→      queue.add('dependent', { dependencies: [dep.id] });\n   366→\n   367→      const next = queue.next();\n   368→      expect(next?.id).toBe(dep.id);\n   369→      expect(queue.next()).toBeNull();\n   370→    });\n   371→\n   372→    it('should unblock a task when dependencies complete', () => {\n   373→      const dep = queue.add('dependency');\n   374→      const dependent = queue.add('dependent', { dependencies: [dep.id] });\n   375→\n   376→      const first = queue.next()!;\n   377→      queue.complete(first.id);\n   378→\n   379→      const second = queue.next();\n   380→      expect(second?.id).toBe(dependent.id);\n   381→    });\n   382→\n   383→    it('should throw when depending on non-existent task', () => {\n   384→      expect(() => queue.add('test', { dependencies: ['nonexistent'] })).toThrow();\n   385→    });\n   386→\n   387→    it('should keep dependents blocked when dependency fails', () => {\n   388→      const dep = queue.add('dependency', { maxRetries: 1, backoffDelay: 0 });\n   389→      queue.add('dependent', { dependencies: [dep.id] });\n   390→\n   391→      const first = queue.next()!;\n   392→      queue.fail(first.id, 'error');\n   393→\n   394→      expect(queue.next()).toBeNull();\n   395→    });\n   396→\n   397→    it('should get dependency status', () => {\n   398→      const dep1 = queue.add('dep1');\n   399→      const dep2 = queue.add('dep2');\n   400→      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n   401→\n   402→      const status = queue.getDependencyStatus(dependent.id);\n   403→      expect(status.total).toBe(2);\n   404→      expect(status.completed).toBe(0);\n   405→      expect(status.pending).toContain(dep1.id);\n   406→      expect(status.pending).toContain(dep2.id);\n   407→\n   408→      queue.next()!;\n   409→      queue.complete(dep1.id);\n   410→\n   411→      const status2 = queue.getDependencyStatus(dependent.id);\n   412→      expect(status2.completed).toBe(1);\n   413→      expect(status2.pending).toHaveLength(1);\n   414→    });\n   415→\n   416→    it('should support multiple dependencies', () => {\n   417→      const dep1 = queue.add('dep1');\n   418→      const dep2 = queue.add('dep2');\n   419→      const dependent = queue.add('dependent', { dependencies: [dep1.id, dep2.id] });\n   420→\n   421→      let t = queue.next()!;\n   422→      queue.complete(t.id);\n   423→      t = queue.next()!;\n   424→      queue.complete(t.id);\n   425→\n   426→      const next = queue.next();\n   427→      expect(next?.id).toBe(dependent.id);\n   428→    });\n   429→\n   430→    it('should expose dependencies on task object', () => {\n   431→      const dep = queue.add('dep');\n   432→      const task = queue.add('task', { dependencies: [dep.id] });\n   433→      expect(task.dependencies).toContain(dep.id);\n   434→    });\n   435→  });\n   436→\n   437→  // ==================== Phase 8: Concurrency Control ====================\n   438→  describe('Phase 8: Concurrency Control', () => {\n   439→    it('should limit concurrent processing tasks', () => {\n   440→      queue.setConcurrency('default', 2);\n   441→      queue.add('t1');\n   442→      queue.add('t2');\n   443→      queue.add('t3');\n   444→\n   445→      expect(queue.next()).not.toBeNull();\n   446→      expect(queue.next()).not.toBeNull();\n   447→      expect(queue.next()).toBeNull();\n   448→    });\n   449→\n   450→    it('should free slot on completion', () => {\n   451→      queue.setConcurrency('default', 1);\n   452→      queue.add('t1');\n   453→      queue.add('t2');\n   454→\n   455→      const first = queue.next()!;\n   456→      expect(queue.next()).toBeNull();\n   457→\n   458→      queue.complete(first.id);\n   459→      expect(queue.next()).not.toBeNull();\n   460→    });\n   461→\n   462→    it('should free slot on failure', () => {\n   463→      queue.setConcurrency('default', 1);\n   464