encyLimits.get(queueName);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= limit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n\n    // Find the best candidate: highest priority (lowest number), then earliest creation\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < taskIds.length; i++) {\n      const task = this.tasks.get(taskIds[i]);\n      if (!task || task.status !== 'pending') continue;\n\n      // Check availability time\n      if (task.availableAt.getTime() > now.getTime()) continue;\n\n      // Check dependencies\n      if (!this.areDependenciesMet(task)) continue;\n\n      if (\n        bestTask === null ||\n        task.priority < bestTask.priority ||\n        (task.priority === bestTask.priority && task.availableAt.getTime() < bestTask.availableAt.getTime()) ||\n        (task.priority === bestTask.priority && task.availableAt.getTime() === bestTask.availableAt.getTime() && task.createdAt.getTime() < bestTask.createdAt.getTime())\n      ) {\n        bestTask = task;\n      }\n    }\n\n    if (bestTask === null) {\n      return null;\n    }\n\n    bestTask.status = 'processing';\n    bestTask.attempt += 1;\n    return bestTask;\n  }\n\n  // Phase 1: Get pending count\n  size(queueName: string = DEFAULT_QUEUE): number {\n    const taskIds = this.queues.get(queueName);\n    if (!taskIds) return 0;\n    return taskIds.filter(id => {\n      const t = this.tasks.get(id);\n      return t && t.status === 'pending';\n    }).length;\n  }\n\n  // Phase 2: List queue names\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // Phase 5: Complete a task\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks are now unblocked (Phase 7 handled implicitly via areDependenciesMet)\n  }\n\n  // Phase 5: Fail a task (with retry logic)\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n\n    if (task.attempt < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n    } else {\n      // Exhausted retries\n      task.status = 'failed';\n\n      // Move to dead letter queue (Phase 6)\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // Phase 6: Move to DLQ\n  private moveToDeadLetterQueue(task: Task): void {\n    if (!this.deadLetterQueues.has(task.queue)) {\n      this.deadLetterQueues.set(task.queue, []);\n    }\n    const dlqTask: DeadLetteredTask = {\n      ...task,\n      failCount: task.attempt,\n      lastError: task.error,\n    };\n    this.deadLetterQueues.get(task.queue)!.push(dlqTask);\n\n    // Remove from queue\n    const queueIds = this.queues.get(task.queue);\n    if (queueIds) {\n      const idx = queueIds.indexOf(task.id);\n      if (idx !== -1) {\n        queueIds.splice(idx, 1);\n      }\n    }\n  }\n\n  // Phase 6: Get dead-lettered tasks\n  getDeadLetterQueue(queueName: string = DEFAULT_QUEUE): DeadLetteredTask[] {\n    return this.deadLetterQueues.get(queueName) ?? [];\n  }\n\n  // Phase 6: Retry a dead-lettered task\n  retryDeadLetter(taskId: string): Task {\n    for (const [queueName, dlqTasks] of this.deadLetterQueues) {\n      const idx = dlqTasks.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n       