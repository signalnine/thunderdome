east one small\n      expect(result.assignments.length).toBeGreaterThanOrEqual(2);\n    });\n  });\n\n  describe('complex scenarios', () => {\n    it('should handle a full day schedule with multiple rooms', () => {\n      const events: Event[] = [\n        { id: 'keynote', name: 'Keynote', duration: 90, attendees: 18, preferredRoom: 'room-b' },\n        { id: 'workshop1', name: 'Workshop 1', duration: 120, attendees: 8 },\n        { id: 'workshop2', name: 'Workshop 2', duration: 120, attendees: 8, prerequisites: ['keynote'] },\n        { id: 'lunch', name: 'Lunch Break', duration: 60, attendees: 5 },\n        { id: 'panel', name: 'Panel', duration: 60, attendees: 15, prerequisites: ['keynote'] },\n        { id: 'closing', name: 'Closing', duration: 30, attendees: 18, prerequisites: ['panel', 'workshop2'] },\n      ];\n\n      const conferenceRooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 20 },\n      ];\n\n      const result = schedule(events, conferenceRooms, defaultOptions);\n\n      // All events should be scheduled\n      expect(result.unscheduled).toHaveLength(0);\n      expect(result.assignments).toHaveLength(6);\n\n      // Verify keynote is in preferred room\n      const keynote = result.assignments.find(a => a.eventId === 'keynote')!;\n      expect(keynote.roomId).toBe('room-b');\n\n      // Verify prerequisites\n      const workshop2 = result.assignments.find(a => a.eventId === 'workshop2')!;\n      const panel = result.assignments.find(a => a.eventId === 'panel')!;\n      const closing = result.assignments.find(a => a.eventId === 'closing')!;\n      expect(workshop2.startTime).toBeGreaterThanOrEqual(keynote.endTime + 15);\n      expect(panel.startTime).toBeGreaterThanOrEqual(keynote.endTime + 15);\n      expect(closing.startTime).toBeGreaterThanOrEqual(panel.endTime + 15);\n      expect(closing.startTime).toBeGreaterThanOrEqual(workshop2.endTime + 15);\n    });\n\n    it('shoul