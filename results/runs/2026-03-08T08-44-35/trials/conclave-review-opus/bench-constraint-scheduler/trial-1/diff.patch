T_GAP = 15;\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws an error if a cycle is found.\n * Returns a topological order of event IDs.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        // Self-reference is a cycle\n        if (prereq === id) {\n          throw new Error(`Cycle detected in prerequisites: ${id} -> ${id}`);\n        }\n        const c = color.get(prereq);\n        if (c === GRAY) {\n          throw new Error(`Cycle detected in prerequisites involving ${prereq}`);\n        }\n        if (c === WHITE) {\n          dfs(prereq);\n        }\n        // If c === BLACK, already processed, skip\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering room availability and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  room: Room,\n  roomSchedules: Map<string, Assignment[]>,\n  assignmentMap: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number,\n): number | null {\n  const attendees = event.attendees ?? 1;\n  if (attendees > room.capacity) {\n    return null;\n  }\n\n  // Earliest based on prerequisites\n  let earliest = options.startTime;\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      const prereqAssignment = assignmentMap.get(prereqId);\n      if (!prereqAssignment) {\n        // Prerequisite not scheduled yet - can't schedule this event\n        return null;\n      }\n      earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n    }\n  }\n\n  // Check if event fits in the time window at all\n  if (earliest + event.duration > options.endTime) {\n    return null;\n  }\n\n  // Find a slot in the room\n  const roomAssignments = roomSchedules.get(room.id) ?? [];\n  // Assignments should be sorted by start time\n  const sorted = [...roomAssignments].sort((a, b) => a.startTime - b.startTime);\n\n  // Try to place at `earliest` or later, fitting between existing assignments\n  let candidateStart = earliest;\n\n  for (const existing of sorted) {\n    // If the candidate fits before this existing event\n    if (candidateStart + event.duration + gap <= existing.startTime || candidateStart + event.duration <= existing.startTime) {\n      // We need gap after our event ends and before the existing one starts\n      if (candidateStart + event.duration + gap <= existing.startTime) {\n        break; // Found a valid slot\n      }\n    }\n    // If existing event ends before our candidate start (with gap), no conflict\n    if (existing.endTime + gap <= candidateStart) {\n      continue;\n    }\n    // Conflict: push candidate start after this existing event + gap\n    candidateStart = Math.max(candidateStart, existing.endTime + gap);\n  }\n\n  // Check if it fits in the time window\n  if (candidateStart + event.duration > options.endTime) {\n    return null;\n  }\n\n  return candidateStart;\n}\n\n/**\n * Schedule events using backtracking to maximize the number of scheduled events.\n */\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? DEFAULT_GAP;\n\n  // Detect cycles - throws on cycle\n  const topoOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Sort rooms by capacity (ascending) for efficient assignment\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Use the topological order for scheduling (prerequisites first)\n  const orderedEvents = topoOrder\n    .filter(id => eventMap.has(id))\n    .map(id => eventMap.get(id)!);\n\n  // Greedy approach with smart room selection\n  // First pass: try preferred rooms, then best fit\n  const assignments: Assignment[] = [];\n  const assignmentMap = new Map<string, Assignment>();\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  // Try scheduling each event in topological order\n  for (const event of orderedEvents) {\n    let bestAssignment: Assignment | null = null;\n    let bestStartTime = Infinity;\n\n    // If there's a preferred room, try it first\n    if (event.preferredRoom) {\n      const preferredRoom = rooms.find(r => r.id === event.preferredRoom);\n      if (preferredRoom) {\n        const start = findEarliestStart(event, preferredRoom, roomSchedules, assignmentMap, options, gap);\n        if (start !== null) {\n          bestAssignment = {\n            eventId: event.id,\n            roomId: preferredRoom.id,\n            startTime: start,\n            endTime: start + event.duration,\n          };\n          bestStartTime = start;\n        }\n      }\n    }\n\n    // Try all rooms to find the best fit (earliest start, smallest sufficient room)\n    for (const room of sortedRooms) {\n      // Skip preferred room if already checked and got a good result\n      if (event.preferredRoom && room.id === event.preferredRoom && bestAssignment) {\n        continue;\n      }\n\n      const start = findEarliestStart(event, room, roomSchedules, assignmentMap, options, gap);\n      if (start !== null) {\n        // If preferred room is available