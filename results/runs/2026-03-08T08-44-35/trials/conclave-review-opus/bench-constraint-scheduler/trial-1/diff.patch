+              ...sortedRooms.filter(r => r.id !== event.preferredRoom),
+            ]
+          : sortedRooms;
+
+        for (const room of roomOrder) {
+          const start = findEarliestStart(event, room, currentRoomSchedules, currentAssignmentMap, options, gap);
+          if (start !== null) {
+            const assignment: Assignment = {
+              eventId: event.id,
+              roomId: room.id,
+              startTime: start,
+              endTime: start + event.duration,
+            };
+
+            currentAssignments.push(assignment);
+            currentAssignmentMap.set(event.id, assignment);
+            currentRoomSchedules.get(room.id)!.push(assignment);
+
+            backtrack(index + 1);
+
+            // Undo
+            currentAssignments.pop();
+            currentAssignmentMap.delete(event.id);
+            const roomList = currentRoomSchedules.get(room.id)!;
+            roomList.pop();
+          }
+        }
+      }
+
+      // Try skipping this event
+      backtrack(index + 1);
+    };
+
+    backtrack(0);
+  } else {
+    // For larger inputs, try multiple greedy orderings
+    const strategies = generateStrategies(orderedEventIds, eventMap);
+
+    for (const strategy of strategies) {
+      const result = greedySchedule(strategy, rooms, sortedRooms, eventMap, options, gap);
+      if (result.length > bestCount) {
+        bestCount = result.length;
+        bestAssignments = result;
+      }
+      if (bestCount === totalEvents) break;
+    }
+  }
+
+  const scheduledIds = new Set(bestAssignments.map(a => a.eventId));
+  const unscheduled = events.filter(e => !scheduledIds.has(e.id)).map(e => e.id);
+
+  return {
+    assignments: bestAssignments,
+    unscheduled,
+  };
+}
+
+function generateStrategies(orderedEventIds: string[], eventMap: Map<string, Event>): string[][] {
+  const strategies: string[][] = [];
+
+  // Strategy 1: topological order as-is
+  strategies.push([...orderedEventIds]);
+
+  // Strategy 2: prioritize events with more prerequisites (complex chains first)
+  const byPrereqs = [...orderedEventIds].sort((a, b) => {
+    const ea = eventMap.get(a)!;
+    const eb = eventMap.get(b)!;
+    return (eb.prerequisites?.length ?? 0) - (ea.prerequisites?.length ?? 0);
+  });
+  strategies.push(byPrereqs);
+
+  // Strategy 3: longer events first (harder to place)
+  const byDuration = [...orderedEventIds].sort((a, b) => {
+    return eventMap.get(b)!.duration - eventMap.get(a)!.duration;
+  });
+  strategies.push(byDuration);
+
+  // Strategy 4: events with more attendees first (harder capacity constraint)
+  const byAttendees = [...orderedEventIds].sort((a, b) => {
+    return (eventMap.get(b)!.attendees ?? 1) - (eventMap.get(a)!.attendees ?? 1);
+  });
+  strategies.push(byAttendees);
+
+  // Strategy 5: shorter events first (fit more)
+  const byShortDuration = [...orderedEventIds].sort((a, b) => {
+    return eventMap.get(a)!.duration - eventMap.get(b)!.duration;
+  });
+  strategies.push(byShortDuration);
+
+  return strategies;
+}
+
+function greedySchedule(
+  eventIds: string[],
+  rooms: Room[],
+  sortedRooms: Room[],
+  eventMap: Map<string, Event>,
+  options: ScheduleOptions,
+  gap: number,
+): Assignment[] {
+  const assignments: Assignment[] = [];
+  const assignmentMap = new Map<string, Assignment>();
+  const roomSchedules = new Map<string, Assignment[]>();
+  for (const room of rooms) {
+    roomSchedules.set(room.id, []);
+  }
+
+  // Need to respect topological order: can't schedule an event before its prerequisites
+  // Process in given order but skip events whose prerequisites aren't scheduled yet,
+  // then retry
+  const scheduled = new Set<string>();
+  const remaining = new Set(eventIds);
+  let progress = true;
+
+  while (progress && remaining.size > 0) {
+    progress = false;
+    for (const eventId of [...remaining]) {
+      const event = eventMap.get(eventId)!;
+
+      // Check prerequisites
+      let prereqsMet = true;
+      if (event.prerequisites) {
+        for (const prereqId of event.prerequisites) {
+          if (!scheduled.has(prereqId)) {
+            prereqsMet = false;
+            break;
+          }
+        }
+      }
+      if (!prereqsMet) continue;
+
+      let bestAssignment: Assignment | null = null;
+      let bestStart = Infinity;
+
+      // Preferred room first
+      if (event.preferredRoom) {
+        const preferredRoom = rooms.find(r => r.id === event.preferredRoom);
+        if (preferredRoom) {
+          const start = findEarliestStart(event, preferredRoom, roomSchedules, assignmentMap, options, gap);
+          if (start !== null) {
+            bestAssignment = {
+              eventId: event.id,
+              roomId: preferredRoom.id,
+              startTime: start,
+              endTime: start + event.duration,
+            };
+            bestStart = start;
+          }
+        }
+      }
+
+      for (const room of sortedRooms) {
+        if (event.preferredRoom && room.id === event.preferredRoom && bestAssignment) continue;
+        const start = findEarliestStart(event, room, roomSchedules, assignmentMap, options, gap);
+        if (start !== null) {
+          if (bestAssignment && event.preferredRoom === bestAssignment.roomId && bestStart <= start) continue;
+          if (start < bestStart) {
+            bestAssignment = {
+              eventId: event.id,
+              roomId: room.id,
+              startTime: start,
+              endTime: start + event.duration,
+            };
+            bestStart = start;
+          }
+        }
+      }
+
+      if (bestAssignment) {
+        assignments.push(bestAssignment);
+        assignmentMap.set(event.id, bestAssignment);
+        roomSchedules.get(bestAssignment.roomId)!.push(bestAssignment);
+        scheduled.add(event.id);
+        remaining.delete(eventId);
+        progress = true;
+      }
+    }
+  }
+
+  return assignments;
+}
