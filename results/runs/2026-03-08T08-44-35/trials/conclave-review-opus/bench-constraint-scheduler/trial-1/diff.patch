ledIds.has(e.id)).map(e => e.id);\n   356→\n   357→  return {\n   358→    assignments: bestAssignments,\n   359→    unscheduled,\n   360→  };\n   361→}\n   362→\n   363→function generateStrategies(orderedEventIds: string[], eventMap: Map<string, Event>, _rooms: Room[]): string[][] {\n   364→  const strategies: string[][] = [];\n   365→\n   366→  // Strategy 1: topological order as-is\n   367→  strategies.push([...orderedEventIds]);\n   368→\n   369→  // Strategy 2: prioritize events with more prerequisites (complex chains first)\n   370→  const byPrereqs = [...orderedEventIds].sort((a, b) => {\n   371→    const ea = eventMap.get(a)!;\n   372→    const eb = eventMap.get(b)!;\n   373→    return (eb.prerequisites?.length ?? 0) - (ea.prerequisites?.length ?? 0);\n   374→  });\n   375→  strategies.push(byPrereqs);\n   376→\n   377→  // Strategy 3: longer events first (harder to place)\n   378→  const byDuration = [...orderedEventIds].sort((a, b) => {\n   379→    return eventMap.get(b)!.duration - eventMap.get(a)!.duration;\n   380→  });\n   381→  strategies.push(byDuration);\n   382→\n   383→  // Strategy 4: events with more attendees first (harder capacity constraint)\n   384→  const byAttendees = [...orderedEventIds].sort((a, b) => {\n   385→    return (eventMap.get(b)!.attendees ?? 1) - (eventMap.get(a)!.attendees ?? 1);\n   386→  });\n   387→  strategies.push(byAttendees);\n   388→\n   389→  // Strategy 5: shorter events first (fit more)\n   390→  const byShortDuration = [...orderedEventIds].sort((a, b) => {\n   391→    return eventMap.get(a)!.duration - eventMap.get(b)!.duration;\n   392→  });\n   393→  strategies.push(byShortDuration);\n   394→\n   395→  return strategies;\n   396→}\n   397→\n   398→function greedySchedule(\n   399→  eventIds: string[],\n   400→  rooms: Room[],\n   401→  sortedRooms: Room[],\n   402→  eventMap: Map<string, Event>,\n   403→  options: ScheduleOptions,\n   404→  gap: number,\n   405→): Assignment[] {\n   406→  const assignments: Assignment[] = [];\n   407→  const assignmentMap = new Map<string, Assignment>();\n   408→  const roomSchedules = new Map<string, Assignment[]>();\n   409→  for (const room of rooms) {\n   410→    roomSchedules.set(room.id, []);\n   411→  }\n   412→\n   413→  // Need to respect topological order: can't schedule an event before its prerequisites\n   414→  // Process in given order but skip events whose prerequisites aren't scheduled yet,\n   415→  // then retry\n   416→  const scheduled = new Set<string>();\n   417→  const remaining = new Set(eventIds);\n   418→  let progress = true;\n   419→\n   420→  while (progress && remaining.size > 0) {\n   421→    progress = false;\n   422→    for (const eventId of [...remaining]) {\n   423→      const event = eventMap.get(eventId)!;\n   424→\n   425→      // Check prerequisites\n   426→      let prereqsMet = true;\n   427→      if (event.prerequisites) {\n   428→        for (const prereqId of event.prerequisites) {\n   429→          if (!scheduled.has(prereqId)) {\n   430→            prereqsMet = false;\n   431→            break;\n   432→          }\n   433→        }\n   434→      }\n   435→      if (!prereqsMet) continue;\n   436→\n   437→      let bestAssignment: Assignment | null = null;\n   438→      let bestStart = Infinity;\n   439→\n   440→      // Preferred room first\n   441→      if (event.preferredRoom) {\n   442→        const preferredRoom = rooms.find(r => r.id === event.preferredRoom);\n   443→        if (preferredRoom) {\n   444→          const start = findEarliestStart(event, preferredRoom, roomSchedules, assignmentMap, options, gap);\n   445→          if (start !== null) {\n   446→            bestAssignment = {\n   447→              eventId: event.id,\n   448→              roomId: preferredRoom.id,\n   449→              startTime: start,\n   450→              endTime: start + event.duration,\n   451→            };\n   452→            bestStart = start;\n   453→          }\n   454→        }\n   455→      }\n   456→