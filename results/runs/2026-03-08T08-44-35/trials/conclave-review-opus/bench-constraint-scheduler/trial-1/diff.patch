   expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should use another room when preferred room is fully booked', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 480, preferredRoom: 'room-a' }, // fills room-a\n        { id: 'e2', name: 'Event 2', duration: 60, preferredRoom: 'room-a' },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      // e2 should be in room-b since room-a is full\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(e2.roomId).toBe('room-b');\n    });\n  });\n\n  describe('unscheduled events', () => {\n    it('should report events that cannot fit as unscheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 100 },\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should report events that cannot fit in the time window as unscheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 300 },\n        { id: 'e2', name: 'Event 2', duration: 300 },\n        { id: 'e3', name: 'Event 3', duration: 300 },\n      ];\n      const oneRoom: Room[] = [\n        { id: 'r1', name: 'Room', capacity: 10 },\n      ];\n      // 480 minutes total, 3 events of 300 min + gaps won't fit in 1 room\n      const result = schedule(events, oneRoom, defaultOptions);\n      expect(result.unscheduled.length).toBeGreaterThan(0);\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize the number of events scheduled', () => {\n      // One room, 480 min window (9-5), 15 min gap\n      // Can fit: 60+15+60+15+60+15+60+15+60+15+60+15+60 = 7*60 + 6*15 = 420+90 = 510 > 480\n      // So: 60+