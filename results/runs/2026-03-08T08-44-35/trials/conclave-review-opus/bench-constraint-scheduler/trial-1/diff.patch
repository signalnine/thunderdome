   199→          };\n   200→          bestStartTime = start;\n   201→        }\n   202→      }\n   203→    }\n   204→\n   205→    if (bestAssignment) {\n   206→      assignments.push(bestAssignment);\n   207→      assignmentMap.set(event.id, bestAssignment);\n   208→      const roomList = roomSchedules.get(bestAssignment.roomId)!;\n   209→      roomList.push(bestAssignment);\n   210→    }\n   211→  }\n   212→\n   213→  // If all events scheduled, we're done\n   214→  if (assignments.length === events.length) {\n   215→    return {\n   216→      assignments,\n   217→      unscheduled: [],\n   218→    };\n   219→  }\n   220→\n   221→  // Try a more aggressive optimization: backtracking search\n   222→  // to maximize the number of scheduled events\n   223→  const bestResult = backtrackSchedule(events, rooms, options, gap, eventMap, topoOrder);\n   224→\n   225→  if (bestResult.assignments.length > assignments.length) {\n   226→    return bestResult;\n   227→  }\n   228→\n   229→  // Collect unscheduled\n   230→  const finalScheduledIds = new Set(assignments.map(a => a.eventId));\n   231→  const unscheduled = events.filter(e => !finalScheduledIds.has(e.id)).map(e => e.id);\n   232→\n   233→  return {\n   234→    assignments,\n   235→    unscheduled,\n   236→  };\n   237→}\n   238→\n   239→/**\n   240→ * Backtracking scheduler that tries different room assignments\n   241→ * to maximize the number of events scheduled.\n   242→ */\n   243→function backtrackSchedule(\n   244→  events: Event[],\n   245→  rooms: Room[],\n   246→  options: ScheduleOptions,\n   247→  gap: number,\n   248→  eventMap: Map<string, Event>,\n   249→  topoOrder: string[],\n   250→): ScheduleResult {\n   251→  const orderedEventIds = topoOrder.filter(id => eventMap.has(id));\n   252→\n   253→  let bestAssignments: Assignment[] = [];\n   254→  let bestCount = 0;\n   255→\n   256→  // Sort rooms by capacity ascending\n   257→  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n   258→\n   259→  // For small inputs, do full backtracking\n   260→  // For larger inputs, use greedy with multiple attempts\n   261→  const totalEvents = orderedEventIds.length;\n   262→\n   263→  if (totalEvents <= 15 && rooms.length <= 10) {\n   264→    // Full backtracking for small inputs\n   265→    const currentAssignments: Assignment[] = [];\n   266→    const currentAssignmentMap = new Map<string, Assignment>();\n   267→    const currentRoomSchedules = new Map<string, Assignment[]>();\n   268→    for (const room of rooms) {\n   269→      currentRoomSchedules.set(room.id, []);\n   270→    }\n   271→\n   272→    const backtrack = (index: number): void => {\n   273→      if (index === orderedEventIds.length) {\n   274→        if (currentAssignments.length > bestCount) {\n   275→          bestCount = currentAssignments.length;\n   276→          bestAssignments = [...currentAssignments];\n   277→        }\n   278→        return;\n   279→      }\n   280→\n   281→      // Pruning: even if we schedule all remaining events, can we beat best?\n   282→      const remaining = orderedEventIds.length - index;\n   283→      if (currentAssignments.length + remaining <= bestCount) {\n   284→        return;\n   285→      }\n   286→\n   287→      const eventId = orderedEventIds[index];\n   288→      const event = eventMap.get(eventId)!;\n   289→\n   290→      // Check if prerequisites are met\n   291→      let prereqsMet = true;\n   292→      if (event.prerequisites) {\n   293→        for (const prereqId of event.prerequisites) {\n   294→          if (!currentAssignmentMap.has(prereqId)) {\n   295→            prereqsMet = false;\n   296→            break;\n   297→          }\n   298→        }\n   299→      }\n   300→\n   301→      if (prereqsMet) {\n   302→        // Determine room order: preferred room first, then by capacity\n   303→        const roomOrder = event.preferredRoom\n   304→          ? [\n   305→              ...sortedRooms.filter(r => r.id === event.preferredRoom