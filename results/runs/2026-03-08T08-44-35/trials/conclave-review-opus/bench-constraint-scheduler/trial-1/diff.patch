ontain('e1');\n   467→    });\n   468→\n   469→    it('should handle prerequisite on an event that is not in the events list', () => {\n   470→      // The prerequisite references an event not provided - it can't be resolved\n   471→      const events: Event[] = [\n   472→        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['nonexistent'] },\n   473→      ];\n   474→\n   475→      // This shouldn't throw (not a cycle), but the event can't be scheduled\n   476→      // because its prerequisite was never scheduled\n   477→      const result = schedule(events, rooms, defaultOptions);\n   478→      expect(result.unscheduled).toContain('e1');\n   479→    });\n   480→  });\n   481→\n   482→  describe('edge cases', () => {\n   483→    it('should handle zero duration events', () => {\n   484→      const events: Event[] = [\n   485→        { id: 'e1', name: 'Instant Event', duration: 0 },\n   486→      ];\n   487→\n   488→      const result = schedule(events, rooms, defaultOptions);\n   489→      expect(result.assignments).toHaveLength(1);\n   490→      expect(result.assignments[0].startTime).toBe(result.assignments[0].endTime);\n   491→    });\n   492→\n   493→    it('should handle single minute time window', () => {\n   494→      const events: Event[] = [\n   495→        { id: 'e1', name: 'Quick Event', duration: 1 },\n   496→      ];\n   497→      const opts: ScheduleOptions = {\n   498→        startTime: 540,\n   499→        endTime: 541,\n   500→        gap: 0,\n   501→      };\n   502→\n   503→      const result = schedule(events, rooms, opts);\n   504→      expect(result.assignments).toHaveLength(1);\n   505→    });\n   506→\n   507→    it('should handle many events competing for few room slots', () => {\n   508→      const events: Event[] = Array.from({ length: 20 }, (_, i) => ({\n   509→        id: `e${i}`,\n   510→        name: `Event ${i}`,\n   511→        duration: 60,\n   512→      }));\n   513→      const oneSmallRoom: Room[] = [\n   514→        {