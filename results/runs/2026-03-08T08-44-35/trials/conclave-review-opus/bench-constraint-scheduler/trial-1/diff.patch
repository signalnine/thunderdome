@@ -0,0 +1,530 @@
+import { describe, it, expect } from 'vitest';
+import { schedule } from './scheduler.js';
+import { Event, Room, ScheduleOptions } from './types.js';
+
+describe('schedule', () => {
+  const defaultOptions: ScheduleOptions = {
+    startTime: 540, // 9:00 AM
+    endTime: 1020,  // 5:00 PM
+    gap: 15,
+  };
+
+  const rooms: Room[] = [
+    { id: 'room-a', name: 'Room A', capacity: 10 },
+    { id: 'room-b', name: 'Room B', capacity: 20 },
+  ];
+
+  describe('basic scheduling', () => {
+    it('should schedule a single event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0].eventId).toBe('e1');
+      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(defaultOptions.startTime);
+      expect(result.assignments[0].endTime).toBeLessThanOrEqual(defaultOptions.endTime);
+      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+    });
+
+    it('should schedule multiple events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+        { id: 'e3', name: 'Event 3', duration: 60 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle empty events list', () => {
+      const result = schedule([], rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should default attendees to 1', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const smallRooms: Room[] = [
+        { id: 'r1', name: 'Tiny Room', capacity: 1 },
+      ];
+
+      const result = schedule(events, smallRooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+    });
+
+    it('should default gap to 15 minutes', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+      const oneRoom: Room[] = [
+        { id: 'r1', name: 'Room', capacity: 10 },
+      ];
+      const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };
+
+      const result = schedule(events, oneRoom, opts);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+      // Gap between events should be at least 15
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);
+    });
+  });
+
+  describe('room capacity', () => {
+    it('should not assign an event to a room with insufficient capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },
+      ];
+      const smallRooms: Room[] = [
+        { id: 'r1', name: 'Small Room', capacity: 10 },
+      ];
+
+      const result = schedule(events, smallRooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toContain('e1');
+    });
+
+    it('should assign events to rooms with sufficient capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 15 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).toBe('room-b'); // Only room-b has capacity 20
+    });
+
+    it('should handle events exactly at room capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60, attendees: 10 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+    });
+  });
+
+  describe('time window', () => {
+    it('should not schedule events outside the time window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 500 }, // Too long for the window
+      ];
+      const tightWindow: ScheduleOptions = {
+        startTime: 540,
+        endTime: 600, // Only 1 hour
+      };
+
+      const result = schedule(events, rooms, tightWindow);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toContain('e1');
+    });
+
+    it('should schedule events that exactly fit the time window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const tightWindow: ScheduleOptions = {
+        startTime: 540,
+        endTime: 600,
+      };
+
+      const result = schedule(events, rooms, tightWindow);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].startTime).toBe(540);
+      expect(result.assignments[0].endTime).toBe(600);
+    });
+
+    it('should start events at or after start time', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(defaultOptions.startTime);
+    });
+
+    it('should end events at or before end time', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments[0].endTime).toBeLessThanOrEqual(defaultOptions.endTime);
+    });
+  });
+
+  describe('room gaps', () => {
+    it('should maintain minimum gap between events in the same room', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+      const oneRoom: Room[] = [
+        { id: 'r1', name: 'Room', capacity: 10 },
+      ];
+
+      const result = schedule(events, oneRoom, { ...defaultOptions, gap: 30 });
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);
+    });
+
+    it('should allow gap of 0', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+      const oneRoom: Room[] = [
+        { id: 'r1', name: 'Room', capacity: 10 },
+      ];
+
+      const result = schedule(events, oneRoom, { ...defaultOptions, gap: 0 });
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);
+    });
+
+    it('should allow events in different rooms at the same time', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      // With 2 rooms and no prerequisites, events can be in different rooms
+      // and start at the same time
+      const [a1, a2] = result.assignments;
+      expect(a1.roomId).not.toBe(a2.roomId);
+      expect(a1.startTime).toBe(a2.startTime);
+    });
+  });
