t i = 0;\n\n  while (i < formula.length) {\n    const ch = formula[i];\n\n    if (ch === ' ') {\n      i++;\n      continue;\n    }\n\n    // String literal\n    if (ch === '\"') {\n      let str = '';\n      i++;\n      while (i < formula.length && formula[i] !== '\"') {\n        str += formula[i];\n        i++;\n      }\n      if (i >= formula.length) throw new Error('Unterminated string');\n      i++; // skip closing quote\n      tokens.push({ type: 'STRING', value: str });\n      continue;\n    }\n\n    // Number\n    if (/\\d/.test(ch) || (ch === '.' && i + 1 < formula.length && /\\d/.test(formula[i + 1]))) {\n      let num = '';\n      while (i < formula.length && (/\\d/.test(formula[i]) || formula[i] === '.')) {\n        num += formula[i];\n        i++;\n      }\n      tokens.push({ type: 'NUMBER', value: num });\n      continue;\n    }\n\n    // Identifiers: cell references, ranges, functions, booleans\n    if (/[A-Za-z]/.test(ch)) {\n      let ident = '';\n      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n        ident += formula[i];\n        i++;\n      }\n      const upper = ident.toUpperCase();\n\n      // Check for range (CELL:CELL)\n      if (i < formula.length && formula[i] === ':') {\n        i++; // skip ':'\n        let end = '';\n        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n          end += formula[i];\n          i++;\n        }\n        tokens.push({ type: 'RANGE', value: `${upper}:${end.toUpperCase()}` });\n        continue;\n      }\n\n      if (upper === 'TRUE' || upper === 'FALSE') {\n        tokens.push({ type: 'BOOLEAN', value: upper });\n        continue;\n      }\n\n      // Check if it's a function (followed by '(')\n      if (i < formula.length && formula[i] === '(') {\n        tokens.push({ type: 'FUNC', value: upper });\n        continue;\n      }\n\n      // Cell reference\n      if (/^[A-Z]+\\d+$/.test(upper)) {\n        tokens.push({ type: 'CELL', value: upper });\n        continue;\n      }\n\n      throw new Error(`Unknown identifier: ${ident}`);\n    }\n\n    // Comparison operators\n    if (ch === '<' || ch === '>') {\n      if (i + 1 < formula.length && formula[i + 1] === '=') {\n        tokens.push({ type: 'COMP', value: ch + '=' });\n        i += 2;\n        continue;\n      }\n      if (ch === '<' && i + 1 < formula.length && formula[i + 1] === '>') {\n        tokens.push({ type: 'COMP', value: '<>' });\n        i += 2;\n        continue;\n      }\n      tokens.push({ type: 'COMP', value: ch });\n      i++;\n      continue;\n    }\n\n    if (ch === '=') {\n      tokens.push({ type: 'COMP', value: '=' });\n      i++;\n      continue;\n    }\n\n    if (ch === '+' || ch === '-') {\n      // Determine if this is unary minus/plus\n      const prev = tokens[tokens.length - 1];\n      if (ch === '-' && (!prev || prev.type === 'OP' || prev.type === 'COMP' || prev.type === 'LPAREN' || prev.type === 'COMMA' || prev.type === 'NEGATE')) {\n        tokens.push({ type: 'NEGATE', value: '-' });\n      } else if (ch === '+' && (!prev || prev.type === 'OP' || prev.type === 'COMP' || prev.type === 'LPAREN' || prev.type === 'COMMA')) {\n        // Unary plus — just skip it\n      } else {\n        tokens.push({ type: 'OP', value: ch });\n      }\n      i++;\n      continue;\n    }\n\n    if (ch === '*' || ch === '/') {\n      tokens.push({ type: 'OP', value: ch });\n      i++;\n      continue;\n    }\n\n    if (ch === '(') {\n      tokens.push({ type: 'LPAREN', value: '(' });\n      i++;\n      continue;\n    }\n\n    if (ch === ')') {\n      tokens.push({ type: 'RPAREN', value: ')' });\n      i++;\n      continue;\n    }\n\n    if (ch === ',') {\n      tokens.push({ type: 'COMMA', value: ',' });\n      i++;\n      continue;\n    }\n\n    throw new Error(`Unexpected character: ${ch}`);\n  }\n\n  return tokens;\n}\n\n// ---- AST Nodes ----\n\ntype ASTNode =\n  | { type: 'number'; value: number }\n  | { type: 'string'; value: string }\n  | { type: 'boolean'; value: boolean }\n  | { type: 'cell'; ref: string }\n  | { type: 'range'; start: string; end: string }\n  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }\n  | { type: 'unary'; op: string; operand: ASTNode }\n  | { type: 'func'; name: string; args: ASTNode[] };\n\n// ---- Parser (recursive descent) ----\n\nclass Parser {\n  private tokens: Token[];\n  private pos: number;\n\n  constructor(tokens: Token[]) {\n    this.tokens = tokens;\n    this.pos = 0;\n  }\n\n  parse(): ASTNode {\n    const node = this.parseComparison();\n    if (this.pos < this.tokens.length) {\n      throw new Error(`Unexpected token: ${this.tokens[this.pos].value}`);\n    }\n    return node;\n  }\n\n  private peek(): Token | undefined {\n    return this.tokens[this.pos];\n  }\n\n  private consume(): Token {\n    return this.tokens[this.pos++];\n  }\n\n  private expect(type: TokenType): Token {\n    const tok = this.consume();\n    if (tok.type !== type) throw new Error(`Expected ${type}, got ${tok.type}`);\n    return tok;\n  }\n\n  private parseComparison(): ASTNode {\n    let left = this.parseAddSub();\n    while (this.peek()?.type === 'COMP') {\n      const op = this.consume().value;\n      const right = this.parseAddSub();\n      left = { type: 'binop', op, left, right };\n    }\n    return left;\n  }\n\n  private parseAddSub(): ASTNode {\n    let left = this.parseMulDiv();\n    while (this.peek()?.type === 'OP' && (this.peek()!.value === '+' || this.peek()!.value === '-')) {\n      const op = this.consume().value;\n      const right = this.parseMulDiv();\n      left = { type: 'binop', op, left, right };\n    }\n    return left;\n  }\n\n  private parseMulDiv(): ASTNode {\n    let left = this.parseUnary();\n    while (this.peek()?.type === 'OP' && (this.peek()!.value === '*' || this.peek()!.value === '/')) {\n      const op = this.consume().value;\n      const right = this.parseUnary();\n      left = { type: 'binop', op, left, right };\n    }\n    return left;\n  }\n\n  private parseUnary(): ASTNode {\n    if (this.peek()?.type === 'NEGATE') {\n      this.consume();\n      const operand = this.parseUnary();\n      return { type: 'unary', op: '-', operand };\n    }\n    return this.parsePrimary();\n  }\n\n  private parsePrimary(): ASTNode {\n    const tok = this.peek();\n    if (!tok) throw new Error('Unexpected end of formula');\n\n    switch (tok.type) {\n      case 'NUMBER': {\n        this.consume();\n        return { type: 'number', value: parseFloat(tok.value) };\n      }\n      case 'STRING': {\n        this.consume();\n        return { type: 'string', value: tok.value };\n      }\n      case 'BOOLEAN': {\n        this.consume();\n        return { type: 'boolean', value: tok.value === 'TRUE' };\n      }\n      case 'CELL': {\n        this.consume();\n        return { type: 'cell', ref: tok.value };\n      }\n      case 'RANGE': {\n        this.consume();\n        const [start, end] = tok.value.split(':');\n        return { type: 'range', start, end };\n      }\n      case 'FUNC': {\n        const name = this.consume().value;\n        this.expect('LPAREN');\n        const args: ASTNode[] = [];\n        if (this.peek()?.type !== 'RPAREN') {\n          args.push(this.parseComparison());\n          while (this.peek()?.type === 'COMMA') {\n            this.consume();\n            args.push(this.parseComparison());\n          }\n        }\n        this.expect('RPAREN');\n        return { type: 'func', name, args };\n      }\n      case 'LPAREN': {\n        this.consume();\n        const node = this.parseComparison();\n        this.expect('RPAREN');\n        return node;\n      }\n      default:\n        throw new Error(`Unexpected token: ${tok.value}`);\n    }\n  }\n}\n\nfunction parseFormula(formula: string): ASTNode {\n  const tokens = tokenize(formula);\n  return new Parser(tokens).parse();\n}\n\n// ---- Expand range to list of cell keys ----\n\nfunction expandRange(start: string, end: string): string[] {\n  const s = parseCellRef(start);\n  const e = parseCellRef(end);\n  const minCol = Math.min(s.col, e.col);\n  const maxCol = Math.max(s.col, e.col);\n  const minRow = Math.min(s.row, e.row);\n  const maxRow = Math.max(s.row, e.row);\n\n  const cells: string[] = [];\n  for (let r = minRow; r <= maxRow; r++) {\n    for (let c = minCol; c <= maxCol; c++) {\n      cells.push(cellKey(c, r));\n    }\n  }\n  return cells;\n}\n\n// ---- Collect dependencies from AST ----\n\nfunction collectDeps(node: ASTNode): Set<string> {\n  const deps = new Set<string>();\n\n  function walk(n: ASTNode): void {\n    switch (n.type) {\n      case 'cell':\n        deps.add(n.ref);\n        break;\n      case 'range':\n        for (const c of expandRange(n.start, n.end)) {\n          deps.add(c);\n        }\n        break;\n      case 'binop':\n        walk(n.left);\n        walk(n.right);\n        break;\n      case 'unary':\n        walk(n.operand);\n        break;\n      case 'func':\n        for (const arg of n.args) {\n          walk(arg);\n        }\n        break;\n      // number, string, boolean — no deps\n    }\n  }\n\n  walk(node);\n  return deps;\n}\n\n// ---- Cell Storage ----\n\ninterface CellData {\n  raw: string | number | boolean;\n  formula: ASTNode | null;\n  computed: string | number | boolean | null;\n  deps: Set<string>; // cells this cell depends on\n}\n\n// ---- Spreadsheet ----\n\nexport class Spreadsheet {\n  private cells: Map<string, CellData> = new Map();\n  // Reverse dependency map: key depends on by value cells\n  private dependents: Map<string, Set<string>> = new Map();\n\n  set(cell: string, value: string | number | boolean): void {\n    const key = cell.toUpperCase();\n\n    // Remove old reverse deps\n    const existing = this.cells.get(key);\n    if (existing) {\n      for (const dep of existing.deps) {\n        this.dependents.get(dep)?.delete(key);\n      }\n    }\n\n    let formula: ASTNode | null = null;\n    let deps = new Set<string>();\n\n    if (typeof value === 'string' && va