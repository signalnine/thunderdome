eet.set('A3', '=A1/A2');\n      expect(sheet.get('A3')).toBe(5);\n    });\n\n    it('should handle operator precedence', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('A3', 4);\n      sheet.set('B1', '=A1+A2*A3');\n      expect(sheet.get('B1')).toBe(14); // 2 + (3*4) = 14\n    });\n\n    it('should handle parentheses', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('B1', 3);\n      sheet.set('C1', '=(A1+B1)*2');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('should handle nested parentheses', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=((A1+A2)*A3)');\n      expect(sheet.get('B1')).toBe(9);\n    });\n\n    it('should handle numeric literals in formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+5');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should handle formulas referencing empty cells (as 0)', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+A2');\n      expect(sheet.get('B1')).toBe(10);\n    });\n\n    it('should handle unary negation', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=-A1');\n      expect(sheet.get('B1')).toBe(-10);\n    });\n  });\n\n  describe('cell references', () => {\n    it('should handle single letter columns', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('Z1', 99);\n      expect(sheet.get('Z1')).toBe(99);\n    });\n\n    it('should handle multi-letter columns', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 100);\n      expect(sheet.get('AA1')).toBe(100);\n    });\n\n    it('should handle large row numbers', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A100', 42);\n      expect(sheet.get('A100')).toBe(42);\n    });\n\n    it('should be case insensitive for cell references', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('a1', 42);\n      expect(sheet.get('A1')).toBe(42);\n    });\n  });\n\n  describe('reactive updates', () => {\n    it('should update direct dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n    });\n\n    it('should update transitive dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', '=A1+1');\n      sheet.set('A3', '=A2+1');\n      sheet.set('A4', '=A3+1');\n      expect(sheet.get('A4')).toBe(4);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('A2')).toBe(11);\n      expect(sheet.get('A3')).toBe(12);\n      expect(sheet.get('A4')).toBe(13);\n    });\n\n    it('should update multiple dependents of the same cell', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=A1*2');\n      sheet.set('C1', '=A1*3');\n      expect(sheet.get('B1')).toBe(10);\n      expect(sheet.get('C1')).toBe(15);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(20);\n      expect(sheet.get('C1')).toBe(30);\n    });\n\n    it('should handle diamond dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=A1+2');\n      sheet.set('D1', '=B1+C1');\n      expect(sheet.get('D1')).toBe(5);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(11);\n      expect(sheet.get('C1')).toBe(12);\n      expect(sheet.get('D1')).toBe(23);\n    });\n\n    it('should update when formula cell is overwritten with value', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', '=A1+1');\n      expect(sheet.get('A2')).toBe(11);\n\n      sheet.set('A2', 99);\n      expect(sheet.get('A2')).toBe(99);\n    });\n\n    it('should update when value cell is overwritten with formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      expect(sheet.get('A2')).toBe(20);\n\n      sheet.set('A2', '=A1*3');\n      expect(sheet.get('A2')).toBe(30);\n    });\n  });\n\n  describe('circular reference detection', () => {\n    it('should detect direct self-reference', () => {\n      const sheet = new Spreadsheet();\n      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect two-cell cycle', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect indirect cycle', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=C1');\n      sheet.set('B1', '=A1');\n      expect(() => sheet.set('C1', '=B1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should not modify state on circular reference error', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+1');\n      expect(sheet.get('B1')).toBe(11);\n\n      expect(() => sheet.set('A1', '=B1')).toThrow(/[Cc]ircular/);\n      // A1 should still be 10\n      expect(sheet.get('A1')).toBe(10);\n      expect(sheet.get('B1')).toBe(11);\n    });\n  });\n\n  describe('SUM function', () => {\n    it('should sum a column range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('A4', 4);\n      sheet.set('A5', 5);\n      sheet.set('B1', '=SUM(A1:A5)');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should sum a row range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 20);\n      sheet.set('C1', 30);\n      sheet.set('D1', '=SUM(A1:C1)');\n      expect(sheet.get('D1')).toBe(60);\n    });\n\n    it('should sum a block range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('B1', 3);\n      sheet.set('B2', 4);\n      sheet.set('C1', '=SUM(A1:B2)');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('should ignore non-numeric values in SUM', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n\n    it('should reactively update SUM when range values change', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('B1')).toBe(70);\n    });\n  });\n\n  describe('AVERAGE function', () => {\n    it('should calculate average', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n  });\n\n  describe('MIN function', () => {\n    it('should find minimum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MIN(A1:A3)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('MAX function', () => {\n    it('should find maximum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n  });\n\n  describe('COUNT function', () => {\n    it('should count numeric values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('B1', '=COUNT(A1:A3)');\n      expect(sheet.get('B1')).toBe(2);\n    });\n\n    it('should count all numeric in range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=COUNT(A1:A3)');\n      expect(sheet.get('B1')).toBe(3);\n    });\n  });\n\n  describe('IF function', () => {\n    it('should return true value when condition is true', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n    });\n\n    it('should return false value when condition is false', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('should handle numeric results in IF', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=IF(A1>3, A1*2, A1)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n\n    it('should reactively update IF', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('should handle equality comparison in IF', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=IF(A1=5, \"yes\", \"no\")');\n      expect(sheet.get('B1')).toBe('yes');\n    });\n\n    it('should handle not-equal comparison in IF', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=IF(A1<>5, \"yes\", \"no\")');\n      expect(sheet.get('B1')).toBe('no');\n    });\n  });\n\n  describe('comparison operators', () => {\n    it('should handle less than', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=IF(A1<10, \"yes\", \"no\")');\n      expect(sheet.get('B1')).toBe('yes');\n    });\n\n    it('should handle greater than or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>=10, \"yes\", \"no\")');\n      expect(sheet.get('B1')).toBe('yes');\n    });\n\n    it('should handle less than or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1<=10, \"yes\", \"no\")');\n      expect(sheet.get('B1')).toBe('yes');\n    });\n  });\n\n  describe('example from spec', () => {\n    it('should handle the full example', () => {\n      const sheet = new Spreadsheet();\n\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n      expect(sheet.getDisplay('A3')).toBe('30');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(70);\n\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n    });\n  });\n\n  describe('edge cases', () => {\n    it('should handle formulas with only literals', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=2+3');\n      expect(sheet.get('A1')).toBe(5);\n    });\n\n    it('should handle chained formulas set in reverse order', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('C1', '=B1+1');\n      sheet.set('B1', '=A1+1');\n      sheet.set('A1', 1);\n      expect(sheet.get('A1')).toBe(1);\n      expect(sheet.get('B1')).toBe(2);\n      expect(sheet.get('C1')).toBe(3);\n    });\n\n    it('should handle boolean in formulas', () => {\n   