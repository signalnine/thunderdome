+        break;
+      case 'func':
+        for (const arg of n.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean — no deps
+    }
+  }
+
+  walk(node);
+  return deps;
+}
+
+// ---- Cell Storage ----
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  computed: string | number | boolean | null;
+  deps: Set<string>; // cells this cell depends on
+}
+
+// ---- Spreadsheet ----
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: key depends on by value cells
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const key = cell.toUpperCase();
+
+    // Save old state for rollback
+    const oldCell = this.cells.get(key);
+
+    // Remove old reverse deps
+    if (oldCell) {
+      for (const dep of oldCell.deps) {
+        this.dependents.get(dep)?.delete(key);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.slice(1));
+      deps = collectDeps(formula);
+    }
+
+    // Set up cell data (compute later)
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      computed: null,
+      deps,
+    };
+    this.cells.set(key, cellData);
+
+    // Register reverse deps
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(key);
+    }
+
+    // Check for circular references before computing
+    this.checkCircular(key, oldCell);
+
+    // Compute this cell
+    cellData.computed = this.evaluate(key);
+
+    // Propagate to dependents
+    this.propagate(key);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const key = cell.toUpperCase();
+    const data = this.cells.get(key);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, string | number | boolean | null> {
+    const result = new Map<string, string | number | boolean | null>();
+    for (const [key, data] of this.cells) {
+      result.set(key, data.computed);
+    }
+    return result;
+  }
+
+  private checkCircular(startKey: string, oldCell: CellData | undefined): void {
+    const visited = new Set<string>();
+
+    const dfs = (key: string): boolean => {
+      if (key === startKey) return true; // cycle found
+      if (visited.has(key)) return false;
+      visited.add(key);
+
+      const cell = this.cells.get(key);
+      if (cell) {
+        for (const dep of cell.deps) {
+          if (dfs(dep)) return true;
+        }
+      }
+      return false;
+    };
+
+    // Start DFS from the cell's dependencies
+    const cell = this.cells.get(startKey);
+    if (cell) {
+      for (const dep of cell.deps) {
+        if (dfs(dep)) {
+          // Rollback: remove new deps, restore old cell
+          this.rollback(startKey, oldCell);
+          throw new Error(`Circular reference detected involving ${startKey}`);
+        }
+      }
+    }
+  }
+
+  private rollback(key: string, oldCell: CellData | undefined): void {
+    const current = this.cells.get(key);
+    if (current) {
+      // Remove reverse deps for the new (failed) cell
+      for (const dep of current.deps) {
+        this.dependents.get(dep)?.delete(key);
+      }
+    }
+
+    if (oldCell) {
+      // Restore old cell
+      this.cells.set(key, oldCell);
+      // Re-register old reverse deps
+      for (const dep of oldCell.deps) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(key);
+      }
+    } else {
+      this.cells.delete(key);
+    }
+  }
+
+  private propagate(changedKey: string): void {
+    // Topological sort of all transitive dependents
+    const order = this.topoSort(changedKey);
+
+    for (const key of order) {
+      const cell = this.cells.get(key);
+      if (cell && cell.formula) {
+        cell.computed = this.evaluate(key);
+      }
+    }
+  }
+
+  private topoSort(startKey: string): string[] {
+    // BFS to collect all transitive dependents, then sort by depth
+    const visited = new Set<string>();
+    const queue: string[] = [];
+
+    // Collect all transitive dependents
+    const seeds = this.dependents.get(startKey);
+    if (!seeds) return [];
+
+    for (const s of seeds) {
+      if (!visited.has(s)) {
+        visited.add(s);
+        queue.push(s);
+      }
+    }
+
+    let i = 0;
+    while (i < queue.length) {
+      const key = queue[i++];
+      const deps = this.dependents.get(key);
+      if (deps) {
+        for (const dep of deps) {
+          if (!visited.has(dep)) {
+            visited.add(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    // Now topological sort: a cell must be computed after all cells it depends on
+    // Use Kahn's algorithm on the subgraph of visited cells
+    const inDegree = new Map<string, number>();
+    for (const key of visited) {
+      inDegree.set(key, 0);
+    }
+
+    // Count in-degrees (only within the visited set, plus startKey as source)
+    for (const key of visited) {
+      const cell = this.cells.get(key);
+      if (cell) {
+        for (const dep of cell.deps) {
+          if (visited.has(dep)) {
+            inDegree.set(key, (inDegree.get(key) || 0) + 1);
+          }
+        }
+      }
+    }
+
+    const sorted: string[] = [];
+    const ready: string[] = [];
+
+    for (const [key, deg] of inDegree) {
+      if (deg === 0) ready.push(key);
+    }
+
+    while (ready.length > 0) {
+      const key = ready.pop()!;
+      sorted.push(key);
+
+      const deps = this.dependents.get(key);
+      if (deps) {
+        for (const dep of deps) {
+          if (visited.has(dep)) {
+            const newDeg = (inDegree.get(dep) || 1) - 1;
+            inDegree.set(dep, newDeg);
+            if (newDeg === 0) {
+              ready.push(dep);
+            }
+          }
+        }
+      }
+    }
+
+    return sorted;
+  }
+
+  private evaluate(key: string): string | number | boolean | null {
+    const cell = this.cells.get(key);
+    if (!cell) return null;
+
+    if (!cell.formula) {
+      // Raw value
+      return cell.raw as string | number | boolean;
+    }
+
+    return this.evalNode(cell.formula);
+  }
+
+  private evalNode(node: ASTNode): string | number | boolean {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cell': {
+        const val = this.get(node.ref);
+        return val ?? 0;
+      }
+      case 'binop':
+        return this.evalBinop(node.op, node.left, node.right);
+      case 'unary': {
+        const operand = this.evalNode(node.operand);
+        if (node.op === '-' && typeof operand === 'number') {
+          return -operand;
+        }
+        throw new Error(`Cannot apply unary ${node.op} to ${typeof operand}`);
+      }
+      case 'func':
+        return this.evalFunc(node.name, node.args);
+      case 'range':
+        throw new Error('Range cannot be used as a standalone value');
+    }
+  }
+
+  private evalBinop(op: string, left: ASTNode, right: ASTNode): string | number | boolean {
+    const l = this.evalNode(left);
+    const r = this.evalNode(right);
+
+    if (op === '+' && typeof l === 'number' && typeof r === 'number') return l + r;
+    if (op === '-' && typeof l === 'number' && typeof r === 'number') return l - r;
+    if (op === '*' && typeof l === 'number' && typeof r === 'number') return l * r;
+    if (op === '/' && typeof l === 'number' && typeof r === 'number') return l / r;
+
+    // String concatenation with +
+    if (op === '+' && (typeof l === 'string' || typeof r === 'string')) {
+      return String(l) + String(r);
+    }
+
+    // Comparisons
+    if (op === '>' && typeof l === 'number' && typeof r === 'number') return l > r;
+    if (op === '<' && typeof l === 'number' && typeof r === 'number') return l < r;
+    if (op === '>=' && typeof l === 'number' && typeof r === 'number') return l >= r;
+    if (op === '<=' && typeof l === 'number' && typeof r === 'number') return l <= r;
+    if (op === '=') return l === r;
+    if (op === '<>') return l !== r;
+
+    throw new Error(`Cannot apply operator ${op} to ${typeof l} and ${typeof r}`);
+  }
+
+  private evalFunc(name: string, args: ASTNode[]): string | number | boolean {
+    switch (name) {
+      case 'SUM': {
+        const values = this.collectNumericValues(args);
+        return values.reduce((a, b) => a + b, 0);
+      }
+      case 'AVERAGE': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return values.reduce((a, b) => a + b, 0) / values.length;
+      }
+      case 'MIN': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return Math.min(...values);
+      }
+      case 'MAX': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return Math.max(...values);
+      }
+      case 'COUNT': {
+        const values = this.collectNumericValues(args);
+        return values.length;
+      }
+      case 'IF': {
+        if (args.length !== 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evalNode(args[0]);
+        if (condition && condition !== 0) {
+          return this.evalNode(args[1]);
+        } else {
+          return this.evalNode(args[2]);
+        }
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+
+  private collectNumericValues(args: ASTNode[]): number[] {
+    const values: number[] = [];
+
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const c of cells) {
+          const val = this.get(c);
+          if (typeof val === 'number') {
+            values.push(val);
+          }
+        }
+      } else {
+        const val = this.evalNode(arg);
+        if (typeof val === 'number') {
+          values.push(val);
+        }
+      }
+    }
+
+    return values;
+  }
+}
