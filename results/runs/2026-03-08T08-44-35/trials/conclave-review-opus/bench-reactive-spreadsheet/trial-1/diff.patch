+    // Comparison operators
+    if (ch === '<' || ch === '>') {
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'COMP', value: ch + '=' });
+        i += 2;
+        continue;
+      }
+      if (ch === '<' && i + 1 < formula.length && formula[i + 1] === '>') {
+        tokens.push({ type: 'COMP', value: '<>' });
+        i += 2;
+        continue;
+      }
+      tokens.push({ type: 'COMP', value: ch });
+      i++;
+      continue;
+    }
