+// ---- Cell Reference Utilities ----
+
+function columnToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64); // A=1, B=2, ...
+  }
+  return index - 1; // 0-based
+}
+
+function indexToColumn(index: number): string {
+  let col = '';
+  let n = index + 1; // 1-based
+  while (n > 0) {
+    n--;
+    col = String.fromCharCode(65 + (n % 26)) + col;
+    n = Math.floor(n / 26);
+  }
+  return col;
+}
+
+function parseCellRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: columnToIndex(match[1]), row: parseInt(match[2], 10) - 1 };
+}
+
+function cellKey(col: number, row: number): string {
+  return `${indexToColumn(col)}${row + 1}`;
+}
+
+// ---- Tokenizer ----
+
+type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'CELL'
+  | 'RANGE'
+  | 'FUNC'
+  | 'OP'
+  | 'COMP'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'COMMA'
+  | 'NEGATE';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    const ch = formula[i];
+
+    if (ch === ' ') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++;
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      if (i >= formula.length) throw new Error('Unterminated string');
+      i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Number
+    if (/\d/.test(ch) || (ch === '.' && i + 1 < formula.length && /\d/.test(formula[i + 1]))) {
+      let num = '';
+      while (i < formula.length && (/\d/.test(formula[i]) || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    // Identifiers: cell references, ranges, functions, booleans
+    if (/[A-Za-z]/.test(ch)) {
+      let ident = '';
+      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+        ident += formula[i];
+        i++;
+      }
+      const upper = ident.toUpperCase();
+
+      // Check for range (CELL:CELL)
+      if (i < formula.length && formula[i] === ':') {
+        i++; // skip ':'
+        let end = '';
+        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+          end += formula[i];
+          i++;
+        }
+        tokens.push({ type: 'RANGE', value: `${upper}:${end.toUpperCase()}` });
+        continue;
+      }
+
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: upper });
+        continue;
+      }
+
+      // Check if it's a function (followed by '(')
+      if (i < formula.length && formula[i] === '(') {
+        tokens.push({ type: 'FUNC', value: upper });
+        continue;
+      }
+
+      // Cell reference
+      if (/^[A-Z]+\d+$/.test(upper)) {
+        tokens.push({ type: 'CELL', value: upper });
+        continue;
+      }
+
+      throw new Error(`Unknown identifier: ${ident}`);
+    }
