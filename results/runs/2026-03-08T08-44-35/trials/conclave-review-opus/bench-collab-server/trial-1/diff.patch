+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, validate, inputLength, outputLength, OpComponent } from './ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply insert at beginning', () => {
+      const doc = 'hello';
+      const ops: OpComponent[] = [{ insert: 'say ' }, { retain: 5 }];
+      expect(apply(doc, ops)).toBe('say hello');
+    });
+
+    it('should apply insert at end', () => {
+      const doc = 'hello';
