ter.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const doc = store.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = store.getVersions(req.params.id);\n    res.json(versions);\n  });\n\n  // Get specific version\n  router.get('/documents/:id/versions/:version', (req: Request, res: Response) => {\n    const doc = store.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versionNum = parseInt(req.params.version, 10);\n    if (isNaN(versionNum)) {\n      res.status(400).json({ error: 'Version must be a number' });\n      return;\n    }\n    const version = store.getVersion(req.params.id, versionNum);\n    if (!version) {\n      res.status(404).json({ error: 'Version not found' });\n      return;\n    }\n    res.json(version);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3463,"cache_read_input_tokens":22993,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3463},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5f46821e-6ea2-4149-aea1-dc0de23b9165","uuid":"d6197514-445f-405c-9cf6-188b556bb2b0"}
