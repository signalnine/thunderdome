etain: 5 }]);\n   347→    const errMsg = await client.nextMessage();\n   348→    expect(errMsg.type).toBe('error');\n   349→\n   350→    client.close();\n   351→  });\n   352→\n   353→  it('should handle malformed JSON gracefully', async () => {\n   354→    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n   355→\n   356→    const client = await connectWs(port, created.id as string);\n   357→    await client.nextMessage(); // sync\n   358→\n   359→    client.sendRaw('not json at all');\n   360→    const errMsg = await client.nextMessage();\n   361→    expect(errMsg.type).toBe('error');\n   362→\n   363→    client.close();\n   364→  });\n   365→\n   366→  it('should handle 10 concurrent clients', async () => {\n   367→    const created = await createDoc(baseUrl, 'Test Doc', '');\n   368→\n   369→    const clients: WsClient[] = [];\n   370→\n   371→    // Connect 10 clients\n   372→    for (let i = 0; i < 10; i++) {\n   373→      const client = await connectWs(port, created.id as string, `client${i}`);\n   374→      await client.nextMessage(); // sync\n   375→      clients.push(client);\n   376→    }\n   377→\n   378→    // Each client inserts a character sequentially\n   379→    for (let i = 0; i < 10; i++) {\n   380→      const client = clients[i];\n   381→\n   382→      // Get current doc state to know the content length\n   383→      const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n   384→      const doc = await getRes.json();\n   385→      const currentContent = doc.content as string;\n   386→\n   387→      // Get current version\n   388→      const versionsRes = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n   389→      const allVersions = await versionsRes.json() as Array<{ version: number }>;\n   390→      const currentVersion = allVersions[allVersions.length - 1].version;\n   391→\n   392→      // Insert character at end\n   393→      const ops = currentContent.length > 0\n   394→        ? [{ retain: currentContent.length }, { insert: String(i) }]\n   395→        : [{ insert: String(i) }];\n   396→\n   397→      client.sendOp(currentVersion, ops);\n   398→\n   399→      const ackMsg = await client.nextMessage();\n   400→      expect(ackMsg.type).toBe('ack');\n   401→\n   402→      // Drain broadcasts from other clients\n   403→      for (let j = 0; j < 10; j++) {\n   404→        if (j !== i) {\n   405→          await clients[j].nextMessage(); // broadcast\n   406→        }\n   407→      }\n   408→    }\n   409→\n   410→    // Verify final document\n   411→    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n   412→    const doc = await getRes.json();\n   413→    expect(doc.content.length).toBe(10);\n   414→    for (let i = 0; i < 10; i++) {\n   415→      expect(doc.content).toContain(String(i));\n   416→    }\n   417→\n   418→    // Close all\n   419→    for (const client of clients) {\n   420→      client.close();\n   421→    }\n   422→  }, 30000);\n   423→});\n   424→\n   425→describe('Persistence', () => {\n   426→  it('should persist documents across server restarts', async () => {\n   427→    const tmpDbPath = `/tmp/test-collab-${Date.now()}.db`;\n   428→\n   429→    // Create first server instance\n   430→    const app1 = createApp(tmpDbPath);\n   431→    const port1 = await app1.start(0);\n   432→\n   433→    // Create a document\n   434→    const createRes = await fetch(`http://localhost:${port1}/api/documents`, {\n   435→      method: 'POST',\n   436→      headers: { 'Content-Type': 'application/json' },\n   437→      body: JSON.stringify({ title: 'Persistent Doc', content: 'survive restart' }),\n   438→    });\n   439→    const created = await createRes.json();\n   440→\n   441→    await app1.stop();\n   442→\n   443→    // Create second server instance with same DB\n   444→    const app2 = createApp(tmpDbPath);\n   445→    const port2 = await app2.start(0);\n   446→\n   447→    // Verify document persists\n   448→    const getRes = await fetch(`http://localhost:${port2}/api/documents/${created.id}`);\n   449→    expect(getRes.status).toBe(200);\n   450→    const doc = await getRes.json();\n   451→    expect(doc.title).toBe('Persistent Doc');\n   452→    expect(doc.content).toBe('survive restart');\n   453→\n   454→    await app2.stop();\n   455→\n   456→    // Clean up\n   457→    const { unlinkSync } = await import('fs');\n   458→    try { unlinkSync(tmpDbPath); } catch { /* ignore */ }\n   459→    try { unlinkSync(tmpDbPath + '-wal'); } catch { /* ignore */ }\n   460→    try { unlinkSync(tmpDbPath + '-shm'); } catch { /* ignore */ }\n   461→  });\n   462→\n   463→  it('should persist version history', async () => {\n   464→    const appInstance = createApp(':memory:');\n   465→    const port = await appInstance.start(0);\n   466→    const baseUrl = `http://localhost:${port}`;\n   467→\n   468→    const created = await createDoc(baseUrl, 'Test Doc', 'v1');\n   469→\n   470→    // Connect and make edits\n   471→    const client = await connectWs(port, created.id as string);\n   472→    const sync = await client.nextMessage();\n   473→    const version = sync.version as number;\n   474→\n   475→    client.sendOp(version, [{ delete: 2 }, { insert: 'v2' }]);\n   476→    await client.nextMessage(); // ack\n   477→\n   478→    client.close();\n   479→\n   480→    // Check versions\n   481→    const versionsRes = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n   482→    const versions = await versionsRes.json();\n   483→    expect(versions.length).toBe(2);\n   484→    expect(versions[0].content).toBe('v1');\n   485→    expect(versions[1].content).toBe('v2');\n   486→\n   487→    await appInstance.stop();\n   488→  });\n   489→});\n   490→"}]},"parent_tool_use_id":"toolu_01XXGT6yWgiicCPHDjw36k18","session_id":"5f46821e-6ea2-4149-aea1-dc0de23b9165","uuid":"fd962340-3ee9-4f54-ad3b-e000cb96ff72"}
