c', 'Hello');"," ","-    const ws = await connectWs(port, created.id as string);","-    await waitForMessage(ws); // sync","+    const client = await connectWs(port, created.id as string);","+    await client.nextMessage(); // sync"," ","-    ws.send('not json at all');","-    const errMsg = await waitForMessage(ws);","+    client.sendRaw('not json at all');","+    const errMsg = await client.nextMessage();","     expect(errMsg.type).toBe('error');"," ","-    ws.close();","+    client.close();","   });"," ","   it('should handle 10 concurrent clients', async () => {","     const created = await createDoc(baseUrl, 'Test Doc', '');"," ","-    const clients: WebSocket[] = [];","+    const clients: WsClient[] = [];"," ","     // Connect 10 clients","     for (let i = 0; i < 10; i++) {","-      const ws = await connectWs(port, created.id as string, `client${i}`);","-      await waitForMessage(ws); // sync","-      clients.push(ws);","+      const client = await connectWs(port, created.id as string, `client${i}`);","+      await client.nextMessage(); // sync","+      clients.push(client);","     }"," ","     // Each client inserts a character sequentially","     for (let i = 0; i < 10; i++) {","-      const ws = clients[i];","+      const client = clients[i];"," ","       // Get current doc state to know the content length","       const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);"]},{"oldStart":395,"oldLines":15,"newStart":394,"newLines":15,"lines":["         ? [{ retain: currentContent.length }, { insert: String(i) }]","         : [{ insert: String(i) }];"," ","-      sendOp(ws, currentVersion, ops);","+      client.sendOp(currentVersion, ops);"," ","-      const ackMsg = await waitForMessage(ws);","+      const ackMsg = await client.nextMessage();","       expect(ackMsg.type).toBe('ack');"," ","       // Drain broadcasts from other clients","       for (let j = 0; j < 10; j++) {","         if (j !== i) {","-          await waitForMessage(clients[j])