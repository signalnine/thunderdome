+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LWqbS7iaz5QAJEk3D4orjw","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { readFileSync } from 'fs';\n     3→import { resolve, dirname } from 'path';\n     4→import { fileURLToPath } from 'url';\n     5→\n     6→const __filename = fileURLToPath(import.meta.url);\n     7→const __dirname = dirname(__filename);\n     8→\n     9→export interface Document {\n    10→  id: string;\n    11→  title: string;\n    12→  content: string;\n    13→  created_at: string;\n    14→  updated_at: string;\n    15→}\n    16→\n    17→export interface Version {\n    18→  id: number;\n    19→  document_id: string;\n    20→  version: number;\n    21→  content: string;\n    22→  operation: string | null;\n    23→  created_at: string;\n    24→}\n    25→\n    26→export function createDb(dbPath?: string): Database.Database {\n    27→  const db = new Database(dbPath || ':memory:');\n    28→  db.pragma('journal_mode = WAL');\n    29→  db.pragma('foreign_keys = ON');\n    30→\n    31→  const schemaPath = resolve(__dirname, '..', 'schema.sql');\n    32→  const schema = readFileSync(schemaPath, 'utf-8');\n    33→  db.exec(schema);\n    34→\n    35→  return db;\n    36→}\n    37→\n    38→export class DocumentStore {\n    39→  private db: Database.Database;\n    40→\n    41→  constructor(db: Database.Database) {\n    42→    this.db = db;\n    43→  }\n    44→\n    45→  createDocument(id: string, title: string, content: string = ''): Document {\n    46→    const stmt = this.db.prepare(\n    47→      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'\n    48→    );\n    49→    stmt.run(id, title, content);\n    50→\n    51→    // Create initial version\n    52→    this.db.prepare(\n    53→      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, NULL)'\n    54→    ).run(id, content);\n    55→\n    56→    return this.getDocument(id)!;\n    57→  }\n    58→\n    59→  getDocument(id: string): Document | undefined {\n    60→    const stmt = this.db.prepare('SELECT * FROM documents WHERE id = ?');\n    61→    return stmt.get(id) as Document | undefined;\n    62→  }\n    63→\n    64→  listDocuments(): Document[] {\n    65→    const stmt = this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');\n    66→    return stmt.all() as Document[];\n    67→  }\n    68→\n    69→  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {\n    70→    const doc = this.getDocument(id);\n    71→    if (!doc) return undefined;\n    72→\n    73→    const title = updates.title ?? doc.title;\n    74→    const content = updates.content ?? doc.content;\n    75→\n    76→    this.db.prepare(\n    77→      \"UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?\"\n    78→    ).run(title, content, id);\n    79→\n    80→    return this.getDocument(id)!;\n    81→  }\n    82→\n    83→  updateDocumentContent(id: string, content: string, operation?: object): void {\n    84→    this.db.prepare(\n    85→      \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n    86→    ).run(content, id);\n    87→\n    88→    // Get current max version\n    89→    const row = this.db.prepare(\n    90→      'SELECT COALESCE(MAX(version), 0) as maxVer FROM versions WHERE document_id = ?'\n    91→    ).get(id) as { maxVer: number };\n    92→\n    93→    const nextVersion = row.maxVer + 1;\n    94→    this.db.prepare(\n    95→      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'\n    96→    ).run(id, nextVersion, content, operation ? JSON.stringify(operation) : null);\n    97→  }\n    98→\n    99→  deleteDocument(id: string): boolean {\n   100→    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);\n   101→    return result.changes > 0;\n   102→  }\n   103→\n   104→  getVersions(documentId: string): Version[] {\n   105→    const stmt = this.db.prepare(\n   106→      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'\n   107→    );\n   108→    return stmt.all(documentId) as Version[];\n   109→  }\n   110→\n   111→  getVersion(documentId: string, version: number): Version | undefined {\n   112→    const stmt = this.db.prepare(\n   113→      'SELECT * FROM versions WHERE document_id = ? AND version = ?'\n   114→    );\n   115→    return stmt.get(documentId, version) as Version | undefined;\n   116→  }\n   117→\n   118→  getCurrentVersion(documentId: string): number {\n   119→    const row = this.db.prepare(\n   120→      'SELECT COALESCE(MAX(version), 0) as maxVer FROM versions WHERE document_id = ?'\n   121→    ).get(documentId) as { maxVer: number };\n   122→    return row.maxVer;\n   123→  }\n   124→}\n   125→"}]},"parent_tool_use_id":"toolu_01XXGT6yWgiicCPHDjw36k18","session_id":"5f46821e-6ea2-4149-aea1-dc0de23b9165","uuid":"15e1d0fa-5b5f-4bed-9c6c-422eb10d9396"}
