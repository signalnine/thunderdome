+    await client2.nextMessage(); // broadcast
+
+    // Client 2 inserts 'Y' after 'b' (uses version+1 since it received broadcast)
+    client2.sendOp(version + 1, [{ retain: 3 }, { insert: 'Y' }, { retain: 1 }]);
+    await client2.nextMessage(); // ack
+    await client1.nextMessage(); // broadcast
