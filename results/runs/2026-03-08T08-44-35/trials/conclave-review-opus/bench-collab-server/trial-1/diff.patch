+    const created = await createDoc(baseUrl, 'Test Doc', 'v1');
+
+    // Connect and make edits
+    const client = await connectWs(port, created.id as string);
+    const sync = await client.nextMessage();
+    const version = sync.version as number;
+
+    client.sendOp(version, [{ delete: 2 }, { insert: 'v2' }]);
+    await client.nextMessage(); // ack
