+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016tL8w9YuWRTGzy6jJBfZdh","type":"tool_result","content":"     1→import { WebSocket } from 'ws';\n     2→import { DocumentStore } from './db.js';\n     3→import { OpComponent, Operation, apply, transform, validate } from './ot.js';\n     4→\n     5→interface Client {\n     6→  ws: WebSocket;\n     7→  clientId: string;\n     8→  docId: string;\n     9→}\n    10→\n    11→interface DocumentState {\n    12→  content: string;\n    13→  version: number;\n    14→  // History of operations applied since version 1, indexed by version\n    15→  // history[i] is the operation that transformed version i to version i+1\n    16→  history: OpComponent[][];\n    17→}\n    18→\n    19→export interface WsMessage {\n    20→  type: string;\n    21→  [key: string]: unknown;\n    22→}\n    23→\n    24→export interface OpMessage {\n    25→  type: 'operation';\n    26→  version: number;\n    27→  ops: OpComponent[];\n    28→  clientId?: string;\n    29→}\n    30→\n    31→export interface SyncMessage {\n    32→  type: 'sync';\n    33→  content: string;\n    34→  version: number;\n    35→  docId: string;\n    36→}\n    37→\n    38→export interface AckMessage {\n    39→  type: 'ack';\n    40→  version: number;\n    41→}\n    42→\n    43→export interface ErrorMessage {\n    44→  type: 'error';\n    45→  message: string;\n    46→}\n    47→\n    48→export interface RemoteOpMessage {\n    49→  type: 'operation';\n    50→  ops: OpComponent[];\n    51→  version: number;\n    52→  clientId: string;\n    53→}\n    54→\n    55→export class CollaborationManager {\n    56→  private documents: Map<string, DocumentState> = new Map();\n    57→  private clients: Map<WebSocket, Client> = new Map();\n    58→  private docClients: Map<string, Set<WebSocket>> = new Map();\n    59→  private store: DocumentStore;\n    60→\n    61→  constructor(store: DocumentStore) {\n    62→    this.store = store;\n    63→  }\n    64→\n    65→  /** Load or initialize the in-memory state for a document. */\n    66→  private getDocState(docId: string): DocumentState | null {\n    67→    let state = this.documents.get(docId);\n    68→    if (state) return state;\n    69→\n    70→    const doc = this.store.getDocument(docId);\n    71→    if (!doc) return null;\n    72→\n    73→    const version = this.store.getCurrentVersion(docId);\n    74→    state = {\n    75→      content: doc.content,\n    76→      version: version,\n    77→      history: [],\n    78→    };\n    79→    this.documents.set(docId, state);\n    80→    return state;\n    81→  }\n    82→\n    83→  /** Handle a new WebSocket connection for a document. */\n    84→  handleConnection(ws: WebSocket, docId: string, clientId: string): void {\n    85→    const state = this.getDocState(docId);\n    86→    if (!state) {\n    87→      const errorMsg: ErrorMessage = { type: 'error', message: 'Document not found' };\n    88→      ws.send(JSON.stringify(errorMsg));\n    89→      ws.close();\n    90→      return;\n    91→    }\n    92→\n    93→    const client: Client = { ws, clientId, docId };\n    94→    this.clients.set(ws, client);\n    95→\n    96→    if (!this.docClients.has(docId)) {\n    97→      this.docClients.set(docId, new Set());\n    98→    }\n    99→    this.docClients.get(docId)!.add(ws);\n   100→\n   101→    // Send sync message\n   102→    const syncMsg: SyncMessage = {\n   103→      type: 'sync',\n   104→      content: state.content,\n   105→      version: state.version,\n   106→      docId,\n   107→    };\n   108→    ws.send(JSON.stringify(syncMsg));\n   109→\n   110→    ws.on('message', (data) => {\n   111→      try {\n   112→        const raw = data.toString();\n   113→        const msg = JSON.parse(raw) as WsMessage;\n   114→        this.handleMessage(ws, msg);\n   115→      } catch (err) {\n   116→        const errorMsg: ErrorMessage = {\n   117→          type: 'error',\n   118→          message: `Invalid message: ${err instanceof Error ? err.message : String(err)}`,\n   119→        };\n   120→        ws.send(JSON.stringify(errorMsg));\n   121→      }\n   122→    });\n   123→\n   124→    ws.on('close', () => {\n   125→      this.handleDisconnect(ws);\n   126→    });\n   127→\n   128→    ws.on('error', () => {\n   129→      this.handleDisconnect(ws);\n   130→    });\n   131→  }\n   132→\n   133→  private handleMessage(ws: WebSocket, msg: WsMessage): void {\n   134→    if (msg.type === 'operation') {\n   135→      this.handleOperation(ws, msg as unknown as OpMessage);\n   136→    } else {\n   137→      const errorMsg: ErrorMessage = { type: 'error', message: `Unknown message type: ${msg.type}` };\n   138→      ws.send(JSON.stringify(errorMsg));\n   139→    }\n   140→  }\n   141→\n   142→  private handleOperation(ws: WebSocket, msg: OpMessage): void {\n   143→    const client = this.clients.get(ws);\n   144→    if (!client) return;\n   145→\n   146→    const state = this.getDocState(client.docId);\n   147→    if (!state) {\n   148→      const errorMsg: ErrorMessage = { type: 'error', message: 'Document not found' };\n   149→      ws.send(JSON.stringify(errorMsg));\n   150→      return;\n   151→    }\n   152→\n   153→    const clientVersion = msg.version;\n   154→    let ops = msg.ops;\n   155→    const opClientId = msg.clientId || client.clientId;\n   156→\n   157→    if (clientVersion < 0 || clientVersion > state.version) {\n   158→      const errorMsg: ErrorMessage = {\n   159→        type: 'error',\n   160→        message: `Invalid version: ${clientVersion}. Current version: ${state.version}`,\n   161→      };\n   162→      ws.send(JSON.stringify(errorMsg));\n   163→      return;\n   164→    }\n   165→\n   166→    // Transform against all operations that happened since clientVersion\n   167→    for (let v = clientVersion; v < state.version; v++) {\n   168→      const historyIdx = v - (state.version - state.history.length);\n   169→      if (historyIdx < 0 || historyIdx >= state.history.length) {\n   170→        const errorMsg: ErrorMessage = {\n   171→          type: 'error',\n   172→          message: 'Version history not available for transformation',\n   173→        };\n   174→        ws.send(JSON.stringify(errorMsg));\n   175→        return;\n   176→      }\n   177→      const serverOp = state.history[historyIdx];\n   178→      const [transformedClient] = transform(ops, serverOp);\n   179→      ops = transformedClient;\n   180→    }\n   181→\n   182→    // Validate the transformed operation against current document\n   183→    const validationError = validate(ops, state.content.length);\n   184→    if (validationError) {\n   185→      const errorMsg: ErrorMessage = { type: 'error', message: validationError };\n   186→      ws.send(JSON.stringify(errorMsg));\n   187→      return;\n   188→    }\n   189→\n   190→    // Apply operation\n   191→    try {\n   192→      state.content = apply(state.content, ops);\n   193→    } catch (err) {\n   194→      const errorMsg: ErrorMessage = {\n   195→        type: 'error',\n   196→        message: `Failed to apply operation: ${err instanceof Error ? err.message : String(err)}`,\n   197→      };\n   198→      ws.send(JSON.stringify(errorMsg));\n   199→      return;\n   200→    }\n   201→\n   202→    state.version++;\n   203→    state.history.push(ops);\n   204→\n   205→    // Persist to database\n   206→    const operation: Operation = {\n   207→      docId: client.docId,\n   208→      version: state.version,\n   209→      ops,\n   210→      clientId: opClientId,\n   211→    };\n   212→    this.store.updateDocumentContent(client.docId, state.content, operation);\n   213→\n   214→    // Send ack to the sender\n   215→    const ackMsg: AckMessage = { type: 'ack', version: state.version };\n   216→    ws.send(JSON.stringify(ackMsg));\n   217→\n   218→    // Broadcast to other clients\n   219→    const remoteMsg: RemoteOpMessage = {\n   220→      type: 'operation',\n   221→      ops,\n   222→      version: state.version,\n   223→      clientId: opClientId,\n   224→    };\n   225→\n   226→    const docSockets = this.docClients.get(client.docId);\n   227→    if (docSockets) {\n   228→      for (const otherWs of docSockets) {\n   229→        if (otherWs !== ws && otherWs.readyState === WebSocket.OPEN) {\n   230→          otherWs.send(JSON.stringify(remoteMsg));\n   231→        }\n   232→      }\n   233→    }\n   234→  }\n   235→\n   236→  private handleDisconnect(ws: WebSocket): void {\n   237→    const client = this.clients.get(ws);\n   238→    if (!client) return;\n   239→\n   240→    this.clients.delete(ws);\n   241→    const docSockets = this.docClients.get(client.docId);\n   242→    if (docSockets) {\n   243→      docSockets.delete(ws);\n   244→      if (docSockets.size === 0) {\n   245→        this.docClients.delete(client.docId);\n   246→        // Keep the document state cached for a while (or clean up)\n   247→      }\n   248→    }\n   249→  }\n   250→\n   251→  /** Clean up all connections. */\n   252→  closeAll(): void {\n   253→    for (const [ws] of this.clients) {\n   254→      ws.close();\n   255→    }\n   256→    this.clients.clear();\n   257→    this.docClients.clear();\n   258→    this.documents.clear();\n   259→  }\n   260→\n   261→  /** Get connected client count for a document. */\n   262→  getClientCount(docId: string): number {\n   263→    return this.docClients.get(docId)?.size ?? 0;\n   264→  }\n   265→}\n   266→"}]},"parent_tool_use_id":"toolu_01XXGT6yWgiicCPHDjw36k18","session_id":"5f46821e-6ea2-4149-aea1-dc0de23b9165","uuid":"483cfe3e-4505-4829-9384-37775a634e1c"}
