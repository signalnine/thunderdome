e version 1, indexed by version\n  // history[i] is the operation that transformed version i to version i+1\n  history: OpComponent[][];\n}\n\nexport interface WsMessage {\n  type: string;\n  [key: string]: unknown;\n}\n\nexport interface OpMessage {\n  type: 'operation';\n  version: number;\n  ops: OpComponent[];\n  clientId?: string;\n}\n\nexport interface SyncMessage {\n  type: 'sync';\n  content: string;\n  version: number;\n  docId: string;\n}\n\nexport interface AckMessage {\n  type: 'ack';\n  version: number;\n}\n\nexport interface ErrorMessage {\n  type: 'error';\n  message: string;\n}\n\nexport interface RemoteOpMessage {\n  type: 'operation';\n  ops: OpComponent[];\n  version: number;\n  clientId: string;\n}\n\nexport class CollaborationManager {\n  private documents: Map<string, DocumentState> = new Map();\n  private clients: Map<WebSocket, Client> = new Map();\n  private docClients: Map<string, Set<WebSocket>> = new Map();\n  private store: DocumentStore;\n\n  constructor(store: DocumentStore) {\n    this.store = store;\n  }\n\n  /** Load or initialize the in-memory state for a document. */\n  private getDocState(docId: string): DocumentState | null {\n    let state = this.documents.get(docId);\n    if (state) return state;\n\n    const doc = this.store.getDocument(docId);\n    if (!doc) return null;\n\n    const version = this.store.getCurrentVersion(docId);\n    state = {\n      content: doc.content,\n      version: version,\n      history: [],\n    };\n    this.documents.set(docId, state);\n    return state;\n  }\n\n  /** Handle a new WebSocket connection for a document. */\n  handleConnection(ws: WebSocket, docId: string, clientId: string): void {\n    const state = this.getDocState(docId);\n    if (!state) {\n      const errorMsg: ErrorMessage = { type: 'error', message: 'Document not found' };\n      ws.send(JSON.stringify(errorMsg));\n      ws.close();\n      return;\n    }\n\n    const client: Client = { ws, clientId, docId };\n    this.clients.set(ws, client);\n\n    if (!this.docClients.has(docId)) {\n      this.docClients.set(docId, new Set());\n    }\n    this.docClients.get(docId)!.add(ws);\n\n    // Send sync message\n    const syncMsg: SyncMessage = {\n      type: 'sync',\n      content: state.content,\n      version: state.version,\n      docId,\n    };\n    ws.send(JSON.stringify(syncMsg));\n\n    ws.on('message', (data) => {\n      try {\n        const raw = data.toString();\n        const msg = JSON.parse(raw) as WsMessage;\n        this.handleMessage(ws, msg);\n      } catch (err) {\n        const errorMsg: ErrorMessage = {\n          type: 'error',\n          message: `Invalid message: ${err instanceof Error ? err.message : String(err)}`,\n        };\n        ws.send(JSON.stringify(errorMsg));\n      }\n    });\n\n    ws.on('close', () => {\n      this.handleDisconnect(ws);\n    });\n\n    ws.on('error', () => {\n      this.handleDisconnect(ws);\n    });\n  }\n\n  private handleMessage(ws: WebSocket, msg: WsMessage): void {\n    if (msg.type === 'operation') {\n      this.handleOperation(ws, msg as unknown as OpMessage);\n    } else {\n      const errorMsg: ErrorMessage = { type: 'error', message: `Unknown message type: ${msg.type}` };\n      ws.send(JSON.stringify(errorMsg));\n    }\n  }\n\n  private handleOperation(ws: WebSocket, msg: OpMessage): void {\n    const client = this.clients.get(ws);\n    if (!client) return;\n\n    const state = this.getDocState(client.docId);\n    if (!state) {\n      const errorMsg: ErrorMessage = { type: 'error', message: 'Document not found' };\n      ws.send(JSON.stringify(errorMsg));\n      return;\n    }\n\n    const clientVersion = msg.version;\n    let ops = msg.ops;\n    const opClientId = msg.clientId || client.clientId;\n\n    if (clientVersion < 0 || clientVersion > state.version) {\n      const errorMsg: ErrorMessage = {\n        type: 'error',\n        message: `Invalid version: ${clientVersion}. Current version: ${state.version}`,\n      };\n      ws.send(JSON.stringify(errorMsg));\n      return;\n    }\n\n    // Transform against all operations that happened since clientVersion\n    for (let v = clientVersion; v < state.version; v++) {\n      const historyIdx = v - (state.version - state.history.length);\n      if (historyIdx < 0 || historyIdx >= state.history.length) {\n        const errorMsg: ErrorMessage = {\n          type: 'error',\n          message: 'Version history not available for transformation',\n        };\n        ws.send(JSON.stringify(errorMsg));\n        return;\n      }\n      const serverOp = state.history[historyIdx];\n      const [transformedClient] = transform(ops, serverOp);\n      ops = transformedClient;\n    }\n\n    // Validate the transformed operation against current document\n    const validationError = validate(ops, state.content.length);\n    if (validationError) {\n      const errorMsg: ErrorMessage = { type: 'error', message: validationError };\n      ws.send(JSON.stringify(errorMsg));\n      return;\n    }\n\n    // Apply operation\n    try {\n      state.content = apply(state.content, ops);\n    } catch (err) {\n      const errorMsg: ErrorMessage = {\n        type: 'error',\n        message: `Failed to apply operation: ${err instanceof Error ? err.message : String(err)}`,\n      };\n      ws.send(JSON.stringify(errorMsg));\n      return;\n    }\n\n    state.version++;\n    state.history.push(ops);\n\n    // Persist to database\n    const operation: Operation = {\n      docId: client.docId,\n      version: state.version,\n      ops,\n      clientId: opClientId,\n    };\n    this.store.updateDocumentContent(client.docId, state.content, operation);\n\n    // Send ack to the sender\n    const ackMsg: AckMessage = { type: 'ack', version: state.version };\n    ws.send(JSON.stringify(ackMsg));\n\n    // Broadcast to other clients\n    const remoteMsg: RemoteOpMessage = {\n      type: 'operation',\n      ops,\n      version: state.version,\n      clientId: opClientId,\n    };\n\n    const docSockets = this.docClients.get(client.docId);\n    if (docSockets) {\n      for (const otherWs of docSockets) {\n        if (otherWs !== ws && otherWs.readyState === WebSocket.OPEN) {\n          otherWs.send(JSON.stringify(remoteMsg));\n        }\n      }\n    }\n  }\n\n  private handleDisconnect(ws: WebSocket): void {\n    const client = this.clients.get(ws);\n    if (!client) return;\n\n    this.clients.delete(ws);\n    const docSockets = this.docClients.get(client.docId);\n    if (docSockets) {\n      docSockets.delete(ws);\n      if (docSockets.size === 0) {\n        this.docClients.delete(client.docId);\n        // Keep the document state cached for a while (or clean up)\n      }\n    }\n  }\n\n  /** Clean up all connections. */\n  closeAll(): void {\n    for (const [ws] of this.clients) {\n      ws.close();\n    }\n    this.clients.clear();\n    this.docClients.clear();\n    this.documents.clear();\n  }\n\n  /** Get connected client count for a document. */\n  getClientCount(docId: string): number {\n    return this.docClients.get(docId)?.size ?? 0;\n  }\n}\n","numLines":266,"startLine":1,"totalLines":266}}}
