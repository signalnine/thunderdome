+      const ops: OpComponent[] = [{ retain: 2 }, { insert: 'l' }, { retain: 2 }];
+      expect(apply(doc, ops)).toBe('hello');
+    });
+
+    it('should apply delete', () => {
+      const doc = 'hello world';
+      const ops: OpComponent[] = [{ retain: 5 }, { delete: 6 }];
+      expect(apply(doc, ops)).toBe('hello');
+    });
+
+    it('should apply delete at beginning', () => {
+      const doc = 'hello';
+      const ops: OpComponent[] = [{ delete: 2 }, { retain: 3 }];
+      expect(apply(doc, ops)).toBe('llo');
+    });
+
+    it('should apply to empty document', () => {
+      const doc = '';
+      const ops: OpComponent[] = [{ insert: 'hello' }];
+      expect(apply(doc, ops)).toBe('hello');
+    });
+
+    it('should throw if input length mismatch', () => {
+      const doc = 'hello';
+      const ops: OpComponent[] = [{ retain: 3 }];
+      expect(() => apply(doc, ops)).toThrow();
+    });
+
+    it('should apply combined insert and delete', () => {
+      const doc = 'hello';
+      const ops: OpComponent[] = [{ delete: 5 }, { insert: 'world' }];
+      expect(apply(doc, ops)).toBe('world');
+    });
+  });
+
+  describe('transform', () => {
+    it('should transform two inserts at same position', () => {
+      // Both insert at position 0 of empty doc
+      const a: OpComponent[] = [{ insert: 'a' }];
+      const b: OpComponent[] = [{ insert: 'b' }];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const doc = '';
+      const resultAB = apply(apply(doc, a), bPrime);
+      const resultBA = apply(apply(doc, b), aPrime);
+      expect(resultAB).toBe(resultBA);
+    });
+
+    it('should transform insert and retain', () => {
