+
+    // Client 2 sends against original version (hasn't processed broadcast yet)
+    client2.sendOp(version, [{ retain: 3 }, { insert: 'Y' }]);
+
+    // Collect all messages from client2 (broadcast from client1 + ack for client2's op)
+    const msg1 = await client2.nextMessage();
+    const msg2 = await client2.nextMessage();
