+      const b: OpComponent[] = [{ retain: 5 }];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const doc = 'hello';
+      const resultAB = apply(apply(doc, a), bPrime);
+      const resultBA = apply(apply(doc, b), aPrime);
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toBe('xhello');
+    });
+
+    it('should transform two inserts at different positions', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [{ retain: 1 }, { insert: 'X' }, { retain: 4 }];
+      const b: OpComponent[] = [{ retain: 4 }, { insert: 'Y' }, { retain: 1 }];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const resultAB = apply(apply(doc, a), bPrime);
+      const resultBA = apply(apply(doc, b), aPrime);
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toBe('hXellYo');
+    });
+
+    it('should transform insert and delete', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [{ retain: 2 }, { insert: 'X' }, { retain: 3 }];
+      const b: OpComponent[] = [{ retain: 1 }, { delete: 2 }, { retain: 2 }];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const resultAB = apply(apply(doc, a), bPrime);
+      const resultBA = apply(apply(doc, b), aPrime);
+      expect(resultAB).toBe(resultBA);
+    });
+
+    it('should transform two deletes at same position', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [{ delete: 2 }, { retain: 3 }];
+      const b: OpComponent[] = [{ delete: 3 }, { retain: 2 }];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const resultAB = apply(apply(doc, a), bPrime);
+      const resultBA = apply(apply(doc, b), aPrime);
+      expect(resultAB).toBe(resultBA);
+    });
+
+    it('should handle concurrent inserts preserving both', () => {
+      const doc = 'abc';
+      const a: OpComponent[] = [{ retain: 1 }, { insert: 'X' }, { retain: 2 }];
+      const b: OpComponent[] = [{ retain: 2 }, { insert: 'Y' }, { retain: 1 }];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const resultAB = apply(apply(doc, a), bPrime);
+      const resultBA = apply(apply(doc, b), aPrime);
+      expect(resultAB).toBe(resultBA);
+      // Both X and Y must be present
+      expect(resultAB).toContain('X');
+      expect(resultAB).toContain('Y');
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two sequential operations', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [{ retain: 5 }, { insert: ' world' }];
+      const b: OpComponent[] = [{ retain: 11 }, { insert: '!' }];
+      const composed = compose(a, b);
+      expect(apply(doc, composed)).toBe(apply(apply(doc, a), b));
+    });
+
+    it('should compose insert then delete', () => {
+      const doc = 'hello';
+      const a: OpComponent[] = [{ retain: 5 }, { insert: ' world' }];
+      const b: OpComponent[] = [{ retain: 5 }, { delete: 6 }];
+      const composed = compose(a, b);
+      expect(apply(doc, composed)).toBe(apply(apply(doc, a), b));
+    });
+  });
+
+  describe('validate', () => {
+    it('should accept valid operation', () => {
+      const ops: OpComponent[] = [{ retain: 3 }, { insert: 'X' }, { retain: 2 }];
+      expect(validate(ops, 5)).toBeNull();
+    });
+
+    it('should reject mismatched length', () => {
+      const ops: OpComponent[] = [{ retain: 10 }];
+      expect(validate(ops, 5)).not.toBeNull();
+    });
+
+    it('should reject negative retain', () => {
+      const ops: OpComponent[] = [{ retain: -1 }];
+      expect(validate(ops, 5)).not.toBeNull();
+    });
+  });
+
+  describe('inputLength / outputLength', () => {
+    it('should compute lengths correctly', () => {
+      const ops: OpComponent[] = [{ retain: 3 }, { insert: 'ab' }, { delete: 2 }];
+      expect(inputLength(ops)).toBe(5);
+      expect(outputLength(ops)).toBe(5);
+    });
+  });
+});
