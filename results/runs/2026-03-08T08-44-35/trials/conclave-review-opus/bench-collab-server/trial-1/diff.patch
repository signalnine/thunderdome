+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C5wndLS469wsT6LKAUwM2S","type":"tool_result","content":"     1→import express from 'express';\n     2→import http from 'http';\n     3→import { WebSocketServer, WebSocket } from 'ws';\n     4→import { URL } from 'url';\n     5→import { randomUUID } from 'crypto';\n     6→import { createDb, DocumentStore } from './db.js';\n     7→import { createRouter } from './routes.js';\n     8→import { CollaborationManager } from './collaboration.js';\n     9→\n    10→export interface AppInstance {\n    11→  app: express.Express;\n    12→  start: (port?: number) => Promise<number>;\n    13→  stop: () => Promise<void>;\n    14→}\n    15→\n    16→export function createApp(dbPath?: string): AppInstance {\n    17→  const db = createDb(dbPath);\n    18→  const store = new DocumentStore(db);\n    19→  const collaboration = new CollaborationManager(store);\n    20→\n    21→  const app = express();\n    22→  app.use(express.json());\n    23→\n    24→  const router = createRouter(store);\n    25→  app.use('/api', router);\n    26→\n    27→  let server: http.Server | null = null;\n    28→  let wss: WebSocketServer | null = null;\n    29→\n    30→  const start = async (port?: number): Promise<number> => {\n    31→    return new Promise((resolve) => {\n    32→      server = http.createServer(app);\n    33→      wss = new WebSocketServer({ server });\n    34→\n    35→      wss.on('connection', (ws: WebSocket, req) => {\n    36→        const url = new URL(req.url || '/', `http://${req.headers.host || 'localhost'}`);\n    37→        const pathParts = url.pathname.split('/').filter(Boolean);\n    38→\n    39→        // Expected path: /documents/:id or /ws/documents/:id\n    40→        let docId: string | null = null;\n    41→        if (pathParts.length >= 2 && pathParts[0] === 'documents') {\n    42→          docId = pathParts[1];\n    43→        } else if (pathParts.length >= 3 && pathParts[0] === 'ws' && pathParts[1] === 'documents') {\n    44→          docId = pathParts[2];\n    45→        }\n    46→\n    47→        if (!docId) {\n    48→          ws.send(JSON.stringify({ type: 'error', message: 'Invalid WebSocket path. Expected /documents/:id' }));\n    49→          ws.close();\n    50→          return;\n    51→        }\n    52→\n    53→        const clientId = url.searchParams.get('clientId') || randomUUID();\n    54→        collaboration.handleConnection(ws, docId, clientId);\n    55→      });\n    56→\n    57→      server.listen(port ?? 0, () => {\n    58→        const addr = server!.address();\n    59→        const assignedPort = typeof addr === 'object' && addr !== null ? addr.port : 0;\n    60→        resolve(assignedPort);\n    61→      });\n    62→    });\n    63→  };\n    64→\n    65→  const stop = async (): Promise<void> => {\n    66→    collaboration.closeAll();\n    67→\n    68→    if (wss) {\n    69→      wss.close();\n    70→      wss = null;\n    71→    }\n    72→\n    73→    return new Promise((resolve, reject) => {\n    74→      if (server) {\n    75→        server.close((err) => {\n    76→          if (err) reject(err);\n    77→          else resolve();\n    78→        });\n    79→        server = null;\n    80→      } else {\n    81→        resolve();\n    82→      }\n    83→    });\n    84→  };\n    85→\n    86→  return { app, start, stop };\n    87→}\n    88→"}]},"parent_tool_use_id":"toolu_01XXGT6yWgiicCPHDjw36k18","session_id":"5f46821e-6ea2-4149-aea1-dc0de23b9165","uuid":"6002a7c3-23f5-438c-964e-080ffe676d19"}
