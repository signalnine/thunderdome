+++ b/src/ot.ts
@@ -0,0 +1,313 @@
+/**
+ * Operational Transformation engine for collaborative text editing.
+ *
+ * Operations are represented as a sequence of components:
+ * - { retain: n }    — skip n characters
+ * - { insert: "..." } — insert text at current position
+ * - { delete: n }    — delete n characters at current position
+ *
+ * The total "input length" of an operation (sum of retain + delete) must equal
+ * the length of the document it is applied to.
+ */
+
+export type OpComponent =
+  | { retain: number }
+  | { insert: string }
+  | { delete: number };
+
+export interface Operation {
+  docId: string;
+  version: number; // the version this op was created against
+  ops: OpComponent[];
+  clientId?: string;
+}
+
+function isRetain(c: OpComponent): c is { retain: number } {
+  return 'retain' in c;
+}
+
+function isInsert(c: OpComponent): c is { insert: string } {
+  return 'insert' in c;
+}
+
+function isDelete(c: OpComponent): c is { delete: number } {
+  return 'delete' in c;
+}
+
+/** Calculate the input length of an operation (the document length it expects). */
+export function inputLength(ops: OpComponent[]): number {
+  let len = 0;
+  for (const c of ops) {
+    if (isRetain(c)) len += c.retain;
+    else if (isDelete(c)) len += c.delete;
+  }
+  return len;
+}
+
+/** Calculate the output length of an operation (the document length after applying). */
+export function outputLength(ops: OpComponent[]): number {
+  let len = 0;
+  for (const c of ops) {
+    if (isRetain(c)) len += c.retain;
+    else if (isInsert(c)) len += c.insert.length;
+  }
+  return len;
+}
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, ops: OpComponent[]): string {
+  const expectedLen = inputLength(ops);
+  if (expectedLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${expectedLen}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of ops) {
+    if (isRetain(c)) {
+      result += doc.slice(pos, pos + c.retain);
+      pos += c.retain;
+    } else if (isInsert(c)) {
+      result += c.insert;
+    } else if (isDelete(c)) {
+      pos += c.delete;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations (a, b) that were both applied to the same
+ * document state, producing (a', b') such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Returns [aPrime, bPrime].
+ */
+export function transform(
+  aOps: OpComponent[],
+  bOps: OpComponent[]
+): [OpComponent[], OpComponent[]] {
+  const aPrime: OpComponent[] = [];
+  const bPrime: OpComponent[] = [];
+
+  // Use iterators over the component arrays
+  let ai = 0;
+  let bi = 0;
+
+  // Helper to get a copy of a component (since we mutate)
+  const cloneComp = (c: OpComponent): OpComponent => {
+    if (isRetain(c)) return { retain: c.retain };
+    if (isInsert(c)) return { insert: c.insert };
+    return { delete: c.delete };
+  };
+
+  // Clone to avoid mutating originals
+  let aCur: OpComponent | null = ai < aOps.length ? cloneComp(aOps[ai]) : null;
+  let bCur: OpComponent | null = bi < bOps.length ? cloneComp(bOps[bi]) : null;
+
+  const advanceA = () => {
+    ai++;
+    aCur = ai < aOps.length ? cloneComp(aOps[ai]) : null;
+  };
+
+  const advanceB = () => {
+    bi++;
+    bCur = bi < bOps.length ? cloneComp(bOps[bi]) : null;
+  };
+
+  while (aCur !== null || bCur !== null) {
+    // If a is an insert, it goes first in a' and b' gets a retain
+    if (aCur !== null && isInsert(aCur)) {
+      aPrime.push({ insert: aCur.insert });
+      bPrime.push({ retain: aCur.insert.length });
+      advanceA();
+      continue;
+    }
+
+    // If b is an insert, it goes first in b' and a' gets a retain
+    if (bCur !== null && isInsert(bCur)) {
+      bPrime.push({ insert: bCur.insert });
+      aPrime.push({ retain: bCur.insert.length });
+      advanceB();
+      continue;
+    }
+
+    // Both must be retain or delete at this point
+    if (aCur === null || bCur === null) {
+      throw new Error('Transform: operations have different base lengths');
+    }
+
+    const aLen = isRetain(aCur) ? aCur.retain : (aCur as { delete: number }).delete;
+    const bLen = isRetain(bCur) ? bCur.retain : (bCur as { delete: number }).delete;
+
+    const minLen = Math.min(aLen, bLen);
+
+    if (isRetain(aCur) && isRetain(bCur)) {
+      // Both retain
+      aPrime.push({ retain: minLen });
+      bPrime.push({ retain: minLen });
+    } else if (isDelete(aCur) && isDelete(bCur)) {
+      // Both delete same region — no output needed
+    } else if (isDelete(aCur) && isRetain(bCur)) {
+      // a deletes, b retains — a' deletes, b' does nothing
+      aPrime.push({ delete: minLen });
+    } else if (isRetain(aCur) && isDelete(bCur)) {
+      // b deletes, a retains — b' deletes, a' does nothing
+      bPrime.push({ delete: minLen });
+    }
+
+    // Consume minLen from both
+    if (aLen === minLen) {
+      advanceA();
+    } else {
+      if (isRetain(aCur)) {
+        aCur = { retain: aLen - minLen };
+      } else {
+        aCur = { delete: aLen - minLen };
+      }
+    }
+
+    if (bLen === minLen) {
+      advanceB();
+    } else {
+      if (isRetain(bCur)) {
+        bCur = { retain: bLen - minLen };
+      } else {
+        bCur = { delete: bLen - minLen };
+      }
+    }
+  }
+
+  return [compact(aPrime), compact(bPrime)];
+}
+
+/** Compose two sequential operations into one. apply(doc, compose(a, b)) === apply(apply(doc, a), b) */
+export function compose(
+  aOps: OpComponent[],
+  bOps: OpComponent[]
+): OpComponent[] {
+  const result: OpComponent[] = [];
+
+  let ai = 0;
+  let bi = 0;
+
+  const cloneComp = (c: OpComponent): OpComponent => {
+    if (isRetain(c)) return { retain: c.retain };
+    if (isInsert(c)) return { insert: c.insert };
+    return { delete: c.delete };
+  };
+
+  let aCur: OpComponent | null = ai < aOps.length ? cloneComp(aOps[ai]) : null;
+  let bCur: OpComponent | null = bi < bOps.length ? cloneComp(bOps[bi]) : null;
+
+  const advanceA = () => {
+    ai++;
+    aCur = ai < aOps.length ? cloneComp(aOps[ai]) : null;
+  };
+
+  const advanceB = () => {
+    bi++;
+    bCur = bi < bOps.length ? cloneComp(bOps[bi]) : null;
+  };
+
+  while (aCur !== null || bCur !== null) {
+    if (aCur !== null && isDelete(aCur)) {
+      result.push({ delete: aCur.delete });
+      advanceA();
+      continue;
+    }
+
+    if (bCur !== null && isInsert(bCur)) {
+      result.push({ insert: bCur.insert });
+      advanceB();
+      continue;
+    }
+
+    if (aCur === null || bCur === null) {
+      throw new Error('Compose: operations are incompatible');
+    }
+
+    if (isRetain(aCur) && isRetain(bCur)) {
+      const minLen = Math.min(aCur.retain, bCur.retain);
+      result.push({ retain: minLen });
+      if (aCur.retain === minLen) advanceA(); else aCur = { retain: aCur.retain - minLen };
+      if (bCur.retain === minLen) advanceB(); else bCur = { retain: bCur.retain - minLen };
+    } else if (isInsert(aCur) && isRetain(bCur)) {
+      const minLen = Math.min(aCur.insert.length, bCur.retain);
+      result.push({ insert: aCur.insert.slice(0, minLen) });
+      if (aCur.insert.length === minLen) advanceA(); else aCur = { insert: aCur.insert.slice(minLen) };
+      if (bCur.retain === minLen) advanceB(); else bCur = { retain: bCur.retain - minLen };
+    } else if (isInsert(aCur) && isDelete(bCur)) {
+      const minLen = Math.min(aCur.insert.length, bCur.delete);
+      if (aCur.insert.length === minLen) advanceA(); else aCur = { insert: aCur.insert.slice(minLen) };
+      if (bCur.delete === minLen) advanceB(); else bCur = { delete: bCur.delete - minLen };
+    } else if (isRetain(aCur) && isDelete(bCur)) {
+      const minLen = Math.min(aCur.retain, bCur.delete);
+      result.push({ delete: minLen });
+      if (aCur.retain === minLen) advanceA(); else aCur = { retain: aCur.retain - minLen };
+      if (bCur.delete === minLen) advanceB(); else bCur = { delete: bCur.delete - minLen };
+    }
+  }
+
+  return compact(result);
+}
+
+/** Compact adjacent same-type components. */
+function compact(ops: OpComponent[]): OpComponent[] {
+  const result: OpComponent[] = [];
+  for (const c of ops) {
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+    const last = result[result.length - 1];
+    if (isRetain(c) && isRetain(last)) {
+      (last as { retain: number }).retain += c.retain;
+    } else if (isInsert(c) && isInsert(last)) {
+      (last as { insert: string }).insert += c.insert;
+    } else if (isDelete(c) && isDelete(last)) {
+      (last as { delete: number }).delete += c.delete;
+    } else {
+      result.push(c);
+    }
+  }
+  // Remove no-ops
+  return result.filter(c => {
+    if (isRetain(c) && c.retain === 0) return false;
+    if (isDelete(c) && c.delete === 0) return false;
+    if (isInsert(c) && c.insert === '') return false;
+    return true;
+  });
+}
+
+/** Validate an operation against a document length. */
+export function validate(ops: OpComponent[], docLength: number): string | null {
+  for (const c of ops) {
+    if (isRetain(c)) {
+      if (typeof c.retain !== 'number' || c.retain < 0 || !Number.isInteger(c.retain)) {
+        return 'Invalid retain value';
+      }
+    } else if (isInsert(c)) {
+      if (typeof c.insert !== 'string') {
+        return 'Invalid insert value';
+      }
+    } else if (isDelete(c)) {
+      if (typeof c.delete !== 'number' || c.delete < 0 || !Number.isInteger(c.delete)) {
+        return 'Invalid delete value';
+      }
+    } else {
+      return 'Unknown operation component';
+    }
+  }
+
+  const inLen = inputLength(ops);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
