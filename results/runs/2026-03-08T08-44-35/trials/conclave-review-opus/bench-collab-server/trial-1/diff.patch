+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RBmyG8hG4thiURTTTQuSAQ","type":"tool_result","content":"     1→/**\n     2→ * Operational Transformation engine for collaborative text editing.\n     3→ *\n     4→ * Operations are represented as a sequence of components:\n     5→ * - { retain: n }    — skip n characters\n     6→ * - { insert: \"...\" } — insert text at current position\n     7→ * - { delete: n }    — delete n characters at current position\n     8→ *\n     9→ * The total \"input length\" of an operation (sum of retain + delete) must equal\n    10→ * the length of the document it is applied to.\n    11→ */\n    12→\n    13→export type OpComponent =\n    14→  | { retain: number }\n    15→  | { insert: string }\n    16→  | { delete: number };\n    17→\n    18→export interface Operation {\n    19→  docId: string;\n    20→  version: number; // the version this op was created against\n    21→  ops: OpComponent[];\n    22→  clientId?: string;\n    23→}\n    24→\n    25→function isRetain(c: OpComponent): c is { retain: number } {\n    26→  return 'retain' in c;\n    27→}\n    28→\n    29→function isInsert(c: OpComponent): c is { insert: string } {\n    30→  return 'insert' in c;\n    31→}\n    32→\n    33→function isDelete(c: OpComponent): c is { delete: number } {\n    34→  return 'delete' in c;\n    35→}\n    36→\n    37→/** Calculate the input length of an operation (the document length it expects). */\n    38→export function inputLength(ops: OpComponent[]): number {\n    39→  let len = 0;\n    40→  for (const c of ops) {\n    41→    if (isRetain(c)) len += c.retain;\n    42→    else if (isDelete(c)) len += c.delete;\n    43→  }\n    44→  return len;\n    45→}\n    46→\n    47→/** Calculate the output length of an operation (the document length after applying). */\n    48→export function outputLength(ops: OpComponent[]): number {\n    49→  let len = 0;\n    50→  for (const c of ops) {\n    51→    if (isRetain(c)) len += c.retain;\n    52→    else if (isInsert(c)) len += c.insert.length;\n    53→  }\n    54→  return len;\n    55→}\n    56→\n    57→/** Apply an operation to a document string. */\n    58→export function apply(doc: string, ops: OpComponent[]): string {\n    59→  const expectedLen = inputLength(ops);\n    60→  if (expectedLen !== doc.length) {\n    61→    throw new Error(\n    62→      `Operation input length (${expectedLen}) does not match document length (${doc.length})`\n    63→    );\n    64→  }\n    65→\n    66→  let result = '';\n    67→  let pos = 0;\n    68→\n    69→  for (const c of ops) {\n    70→    if (isRetain(c)) {\n    71→      result += doc.slice(pos, pos + c.retain);\n    72→      pos += c.retain;\n    73→    } else if (isInsert(c)) {\n    74→      result += c.insert;\n    75→    } else if (isDelete(c)) {\n    76→      pos += c.delete;\n    77→    }\n    78→  }\n    79→\n    80→  return result;\n    81→}\n    82→\n    83→/**\n    84→ * Transform two concurrent operations (a, b) that were both applied to the same\n    85→ * document state, producing (a', b') such that:\n    86→ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')\n    87→ *\n    88→ * Returns [aPrime, bPrime].\n    89→ */\n    90→export function transform(\n    91→  aOps: OpComponent[],\n    92→  bOps: OpComponent[]\n    93→): [OpComponent[], OpComponent[]] {\n    94→  const aPrime: OpComponent[] = [];\n    95→  const bPrime: OpComponent[] = [];\n    96→\n    97→  // Use iterators over the component arrays\n    98→  let ai = 0;\n    99→  let bi = 0;\n   100→\n   101→  // Helper to get a copy of a component (since we mutate)\n   102→  const cloneComp = (c: OpComponent): OpComponent => {\n   103→    if (isRetain(c)) return { retain: c.retain };\n   104→    if (isInsert(c)) return { insert: c.insert };\n   105→    return { delete: c.delete };\n   106→  };\n   107→\n   108→  // Clone to avoid mutating originals\n   109→  let aCur: OpComponent | null = ai < aOps.length ? cloneComp(aOps[ai]) : null;\n   110→  let bCur: OpComponent | null = bi < bOps.length ? cloneComp(bOps[bi]) : null;\n   111→\n   112→  const advanceA = () => {\n   113→    ai++;\n   114→    aCur = ai < aOps.length ? cloneComp(aOps[ai]) : null;\n   115→  };\n   116→\n   117→  const advanceB = () => {\n   118→    bi++;\n   119→    bCur = bi < bOps.length ? cloneComp(bOps[bi]) : null;\n   120→  };\n   121→\n   122→  while (aCur !== null || bCur !== null) {\n   123→    // If a is an insert, it goes first in a' and b' gets a retain\n   124→    if (aCur !== null && isInsert(aCur)) {\n   125→      aPrime.push({ insert: aCur.insert });\n   126→      bPrime.push({ retain: aCur.insert.length });\n   127→      advanceA();\n   128→      continue;\n   129→    }\n   130→\n   131→    // If b is an insert, it goes first in b' and a' gets a retain\n   132→    if (bCur !== null && isInsert(bCur)) {\n   133→      bPrime.push({ insert: bCur.insert });\n   134→      aPrime.push({ retain: bCur.insert.length });\n   135→      advanceB();\n   136→      continue;\n   137→    }\n   138→\n   139→    // Both must be retain or delete at this point\n   140→    if (aCur === null || bCur === null) {\n   141→      throw new Error('Transform: operations have different base lengths');\n   142→    }\n   143→\n   144→    const aLen = isRetain(aCur) ? aCur.retain : (aCur as { delete: number }).delete;\n   145→    const bLen = isRetain(bCur) ? bCur.retain : (bCur as { delete: number }).delete;\n   146→\n   147→    const minLen = Math.min(aLen, bLen);\n   148→\n   149→    if (isRetain(aCur) && isRetain(bCur)) {\n   150→      // Both retain\n   151→      aPrime.push({ retain: minLen });\n   152→      bPrime.push({ retain: minLen });\n   153→    } else if (isDelete(aCur) && isDelete(bCur)) {\n   154→      // Both delete same region — no output needed\n   155→    } else if (isDelete(aCur) && isRetain(bCur)) {\n   156→      // a deletes, b retains — a' deletes, b' does nothing\n   157→      aPrime.push({ delete: minLen });\n   158→    } else if (isRetain(aCur) && isDelete(bCur)) {\n   159→      // b deletes, a retains — b' deletes, a' does nothing\n   160→      bPrime.push({ delete: minLen });\n   161→    }\n   162→\n   163→    // Consume minLen from both\n   164→    if (aLen === minLen) {\n   165→      advanceA();\n   166→    } else {\n   167→      if (isRetain(aCur)) {\n   168→        aCur = { retain: aLen - minLen };\n   169→      } else {\n   170→        aCur = { delete: aLen - minLen };\n   171→      }\n   172→    }\n   173→\n   174→    if (bLen === minLen) {\n   175→      advanceB();\n   176→    } else {\n   177→      if (isRetain(bCur)) {\n   178→        bCur = { retain: bLen - minLen };\n   179→      } else {\n   180→        bCur = { delete: bLen - minLen };\n   181→      }\n   182→    }\n   183→  }\n   184→\n   185→  return [compact(aPrime), compact(bPrime)];\n   186→}\n   187→\n   188→/** Compose two sequential operations into one. apply(doc, compose(a, b)) === apply(apply(doc, a), b) */\n   189→export function compose(\n   190→  aOps: OpComponent[],\n   191→  bOps: OpComponent[]\n   192→): OpComponent[] {\n   193→  const result: OpComponent[] = [];\n   194→\n   195→  let ai = 0;\n   196→  let bi = 0;\n   197→\n   198→  const cloneComp = (c: OpComponent): OpComponent => {\n   199→    if (isRetain(c)) return { retain: c.retain };\n   200→    if (isInsert(c)) return { insert: c.insert };\n   201→    return { delete: c.delete };\n   202→  };\n   203→\n   204→  let aCur: OpComponent | null = ai < aOps.length ? cloneComp(aOps[ai]) : null;\n   205→  let bCur: OpComponent | null = bi < bOps.length ? cloneComp(bOps[bi]) : null;\n   206→\n   207→  const advanceA = () => {\n   208→    ai++;\n   209→    aCur = ai < aOps.length ? cloneComp(aOps[ai]) : null;\n   210→  };\n   211→\n   212→  const advanceB = () => {\n   213→    bi++;\n   214→    bCur = bi < bOps.length ? cloneComp(bOps[bi]) : null;\n   215→  };\n   216→\n   217→  while (aCur !== null || bCur !== null) {\n   218→    if (aCur !== null && isDelete(aCur)) {\n   219→      result.push({ delete: aCur.delete });\n   220→      advanceA();\n   221→      continue;\n   222→    }\n   223→\n   224→    if (bCur !== null && isInsert(bCur)) {\n   225→      result.push({ insert: bCur.insert });\n   226→      advanceB();\n   227→      continue;\n   228→    }\n   229→\n   230→    if (aCur === null || bCur === null) {\n   231→      throw new Error('Compose: operations are incompatible');\n   232→    }\n   233→\n   234→    if (isRetain(aCur) && isRetain(bCur)) {\n   235→      const minLen = Math.min(aCur.retain, bCur.retain);\n   236→      result.push({ retain: minLen });\n   237→      if (aCur.retain === minLen) advanceA(); else aCur = { retain: aCur.retain - minLen };\n   238→      if (bCur.retain === minLen) advanceB(); else bCur = { retain: bCur.retain - minLen };\n   239→    } else if (isInsert(aCur) && isRetain(bCur)) {\n   240→      const minLen = Math.min(aCur.insert.length, bCur.retain);\n   241→      result.push({ insert: aCur.insert.slice(0, minLen) });\n   242→      if (aCur.insert.length === minLen) advanceA(); else aCur = { insert: aCur.insert.slice(minLen) };\n   243→      if (bCur.retain === minLen) advanceB(); else bCur = { retain: bCur.retain - minLen };\n   244→    } else if (isInsert(aCur) && isDelete(bCur)) {\n   245→      const minLen = Math.min(aCur.insert.length, bCur.delete);\n   246→      if (aCur.insert.length === minLen) advanceA(); else aCur = { insert: aCur.insert.slice(minLen) };\n   247→      if (bCur.delete === minLen) advanceB(); else bCur = { delete: bCur.delete - minLen };\n   248→    } else if (isRetain(aCur) && isDelete(bCur)) {\n   249→      const minLen = Math.min(aCur.retain, bCur.delete);\n   250→      result.push({ delete: minLen });\n   251→      if (aCur.retain === minLen) advanceA(); else aCur = { retain: aCur.retain - minLen };\n   252→      if (bCur.delete === minLen) advanceB(); else bCur = { delete: bCur.delete - minLen };\n   253→    }\n   254→  }\n   255→\n   256→  return compact(result);\n   257→}\n   258→\n   259→/** Compact adjacent same-type components. */\n   260→function compact(ops: OpComponent[]): OpComponent[] {\n   261→  const result: OpComponent[] = [];\n   262→  for (const c of ops) {\n   263→    if (result.length === 0) {\n   264→      result.push(c);\n   265→      continue;\n   266→    }\n   267→    const last = result[result.length - 1];\n   268→    if (isRetain(c) && isRetain(last)) {\n   269→      (last as { retain: number }).retain += c.retain;\n   270→    } else if (isInsert(c) && isInsert(last)) {\n   271→      (last as { insert: string }).insert += c.insert;\n   272→    } else if (isDelete(c) && isDelete(last)) {\n   273→      (last as { delete: number }).delete += c.delete;\n   274→    } else {\n   275→      result.push(c);\n   276→    }\n   277→  }\n   278→  // Remove no-ops\n   279→  return result.filter(c => {\n   280→    if (isRetain(c) && c.retain === 0) return false;\n   281→    if (isDelete(c) && c.delete === 0) return false;\n   282→    if (isInsert(c) && c.insert === '') return false;\n   283→    return true;\n   284→  });\n   285→}\n   286→\n   287→/** Validate an operation against a document length. */\n   288→export function validate(ops: OpComponent[], docLength: number): string | null {\n   289→  for (const c of ops) {\n   290→    if (isRetain(c)) {\n   291→      if (typeof c.retain !== 'number' || c.retain < 0 || !Number.isInteger(c.retain)) {\n   292→        return 'Invalid retain value';\n   293→      }\n   294→    } else if (isInsert(c)) {\n   295→      if (typeof c.insert !== 'string') {\n   296→        return 'Invalid insert value';\n   297→      }\n   298→    } else if (isDelete(c)) {\n   299→      if (typeof c.delete !== 'number' || c.delete < 0 || !Number.isInteger(c.delete)) {\n   300→        return 'Invalid delete value';\n   301→      }\n   302→    } else {\n   303→      return 'Unknown operation component';\n   304→    }\n   305→  }\n   306→\n   307→  const inLen = inputLength(ops);\n   308→  if (inLen !== docLength) {\n   309→    return `Operation input length (${inLen}) does not match document length (${docLength})`;\n   310→  }\n   311→\n   312→  return null;\n   313→}\n   314→"}]},"parent_tool_use_id":"toolu_01XXGT6yWgiicCPHDjw36k18","session_id":"5f46821e-6ea2-4149-aea1-dc0de23b9165","uuid":"e633470a-632a-4cd8-b4b0-c0f912f88cd9"}
