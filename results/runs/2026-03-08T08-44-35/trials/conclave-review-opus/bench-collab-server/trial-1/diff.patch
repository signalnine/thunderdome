romise.resolve(this.messages.shift()!);\n    }\n    return new Promise((resolve) => {\n      this.waiters.push(resolve);\n    });\n  }\n\n  send(msg: unknown): void {\n    this.ws.send(JSON.stringify(msg));\n  }\n\n  sendOp(version: number, ops: unknown[]): void {\n    this.send({ type: 'operation', version, ops });\n  }\n\n  close(): void {\n    this.ws.close();\n  }\n}\n\nfunction connectWs(port: number, docId: string, clientId?: string): Promise<WsClient> {\n  return new Promise((resolve, reject) => {\n    const url = `ws://localhost:${port}/documents/${docId}${clientId ? `?clientId=${clientId}` : ''}`;\n    const ws = new WebSocket(url);\n    const client = new WsClient(ws);\n    ws.on('open', () => resolve(client));\n    ws.on('error', reject);\n  });\n}\n\nasync function createDoc(baseUrl: string, title: string, content = ''): Promise<Msg> {\n  const res = await fetch(`${baseUrl}/api/documents`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ title, content }),\n  });\n  return await res.json();\n}\n\ndescribe('REST API', () => {\n  let appInstance: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    appInstance = createApp(':memory:');\n    const port = await appInstance.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await appInstance.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test Doc', content: 'Hello' }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json();\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('Hello');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('should list documents', async () => {\n    await createDoc(baseUrl, 'Doc 1');\n    await createDoc(baseUrl, 'Doc 2');\n\n    const res = await fetch(`${baseUrl}/api/documents`);\n    expect(res.status).toBe(200);\n    const docs = await res.json();\n    expect(docs.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Test Doc');\n  });\n\n  it('should return 404 for nonexistent document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents/nonexistent`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Updated Title', content: 'Updated content' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Updated Title');\n    expect(doc.content).toBe('Updated content');\n  });\n\n  it('should delete a document', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc');\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'DELETE',\n    });\n    expect(res.status).toBe(204);\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should reject document creation without title', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('should get version history', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'v1');\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = await res.json();\n    expect(versions.length).toBeGreaterThanOrEqual(1);\n    expect(versions[0].content).toBe('v1');\n  });\n\n  it('should get specific version', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'v1');\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}/versions/1`);\n    expect(res.status).toBe(200);\n    const version = await res.json();\n    expect(version.version).toBe(1);\n    expect(version.content).toBe('v1');\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  let appInstance: AppInstance;\n  let port: number;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    appInstance = createApp(':memory:');\n    port = await appInstance.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await appInstance.stop();\n  });\n\n  it('should send sync message on connection', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n\n    const ws = await connectWs(port, created.id as string);\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('Hello');\n    expect(msg.version).toBeDefined();\n    ws.close();\n  });\n\n  it('should send error for nonexistent document', async () => {\n    const ws = await connectWs(port, 'nonexistent');\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n    ws.close();\n  });\n\n  it('should apply an operation and send ack', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n\n    const ws = await connectWs(port, created.id as string);\n    const syncMsg = await waitForMessage(ws);\n    const version = syncMsg.version as number;\n\n    sendOp(ws, version, [{ retain: 5 }, { insert: ' World' }]);\n    const ackMsg = await waitForMessage(ws);\n    expect(ackMsg.type).toBe('ack');\n    expect(ackMsg.version).toBe(version + 1);\n\n    // Verify via REST\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    const doc = await getRes.json();\n    expect(doc.content).toBe('Hello World');\n\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n\n    const ws1 = await connectWs(port, created.id as string, 'client1');\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWs(port, created.id as string, 'client2');\n    await waitForMessage(ws2); // sync\n\n    const version = sync1.version as number;\n    const broadcastPromise = waitForMessage(ws2);\n\n    sendOp(ws1, version, [{ retain: 5 }, { insert: ' World' }]);\n\n    const [ack, broadcast] = await Promise.all([\n      waitForMessage(ws1),\n      broadcastPromise,\n    ]);\n\n    expect(ack.type).toBe('ack');\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.ops).toEqual([{ retain: 5 }, { insert: ' World' }]);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'abc');\n\n    const ws1 = await connectWs(port, created.id as string, 'client1');\n    const sync1 = await waitForMessage(ws1);\n    const version = sync1.version as number;\n\n    const ws2 = await connectWs(port, created.id as string, 'client2');\n    await waitForMessage(ws2); // sync\n\n    // Client 1 inserts 'X' after 'a'\n    sendOp(ws1, version, [{ retain: 1 }, { insert: 'X' }, { retain: 2 }]);\n    await waitForMessage(ws1); // ack\n    await waitForMessage(ws2); // broadcast\n\n    // Client 2 inserts 'Y' after 'b' (uses version+1 since it received broadcast)\n    sendOp(ws2, version + 1, [{ retain: 3 }, { insert: 'Y' }, { retain: 1 }]);\n    await waitForMessage(ws2); // ack\n    await waitForMessage(ws1); // broadcast\n\n    // Verify final state via REST\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    const doc = await getRes.json();\n    expect(doc.content).toContain('X');\n    expect(doc.content).toContain('Y');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle truly concurrent edits (same base version)', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'abc');\n\n    const ws1 = await connectWs(port, created.id as string, 'client1');\n    const sync1 = await waitForMessage(ws1);\n    const version = sync1.version as number;\n\n    const ws2 = await connectWs(port, created.id as string, 'client2');\n    await waitForMessage(ws2); // sync\n\n    // Client 1: insert 'X' at beginning\n    sendOp(ws1, version, [{ insert: 'X' }, { retain: 3 }]);\n\n    // Wait for client 1's ack\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe('ack');\n\n    // Client 2 sends against original version (hasn't received broadcast yet)\n    sendOp(ws2, version, [{ retain: 3 }, { insert: 'Y' }]);\n\n    // Collect all messages from ws2 (broadcast from ws1 + ack for ws2's op)\n    const ws2Messages: Record<string, unknown>[] = [];\n    ws2Messages.push(await waitForMessage(ws2));\n    ws2Messages.push(await waitForMessage(ws2));\n\n    const hasAck = ws2Messages.some(m => m.type === 'ack');\n    expect(hasAck).toBe(true);\n\n    // Consume broadcast on ws1\n    await waitForMessage(ws1); // broadcast from ws2\n\n    // Verify convergence via REST\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    const doc = await getRes.json();\n    expect(doc.content).toContain('X');\n    expect(doc.content).toContain('Y');\n    expect(doc.content).toContain('abc');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n\n    const ws = await connectWs(port, created.id as string);\n    const syncMsg = await waitForMessage(ws);\n    const version = syncMsg.version as number;\n\n    // Send operation with wrong input length\n    sendOp(ws, version, [{ retain: 100 }]);\n    const errMsg = await waitForMessage(ws);\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject invalid version', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n\n    const ws = await connectWs(port, created.id as string);\n    await waitForMessage(ws); // sync\n\n    sendOp(ws, 9999, [{ retain: 5 }]);\n    const errMsg = await waitForMessage(ws);\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle malformed JSON gracefully', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', 'Hello');\n\n    const ws = await connectWs(port, created.id as string);\n    await waitForMessage(ws); // sync\n\n    ws.send('not json at all');\n    const errMsg = await waitForMessage(ws);\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const created = await createDoc(baseUrl, 'Test Doc', '');\n\n    const clients: WebSocket[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(port, created.id as string, `client${i}`);\n      await waitForMessage(ws); // sync\n      clients.push(ws);\n    }\n\n    // Each client inserts a character sequentially\n    for (let i = 0; i < 10; i++) {\n      const ws = clients[i];\n\n      // Get current doc state to know the content length\n      const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n      const doc = await getRes.json();\n      const currentContent = doc.content as string;\n\n      // Get current version\n      const versionsRes = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n      const allVersions = await versionsRes.json() as Array<{ version: number }>;\n      const currentVersion = allVersions[allVersions.length - 1].version;\n\n      // Insert character at end\n      const ops = currentContent.length > 0\n        ? [{ retain: currentContent.length }, { insert: String(i) }]\n        : [{ insert: String(i) }];\n\n      sendOp(ws, currentVersion, ops);\n\n      const ackMsg = await waitForMessage(ws);\n      expect(ackMsg.type).toBe('ack');\n\n      // Drain broadcasts from other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          await waitForMessage(clients[j]); // broadcast\n        }\n      }\n    }\n\n    // Verify final document\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    const doc = await getRes.json();\n    expect(doc.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(doc.content).toContain(String(i));\n    }\n\n    // Close all\n    for (const ws of clients) {\n      ws.close();\n    }\n  }, 30000);\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across server restarts', async () => {\n    const tmpDbPath = `/tmp/test-collab-${Date.now()}.db`;\n\n    // Create first server instance\n    const app1 = createApp(tmpDbPath);\n    const port1 = await app1.start(0);\n\n    // Create a document\n    const createRes = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persistent Doc', content: 'survive restart' }),\n    });\n    const created = await createRes.json();\n\n    await app1.stop();\n\n    // Create second server instance with same DB\n    const app2 = createApp(tmpDbPath);\n    const port2 = await app2.start(0);\n\n    // Verify document persists\n    const getRes = await fetch(`http://localhost:${port2}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(200);\n    const doc = await getRes.json();\n    expect(doc.title).toBe('Persistent Doc');\n    expect(doc.content).toBe('survive restart');\n\n    await app2.stop();\n\n    // Clean up\n    const { unlinkSync } = await import('fs');\n    try { unlinkSync(tmpDbPath); } catch { /* ignore */ }\n    try { unlinkSync(tmpDbPath + '-wal'); } catch { /* ignore */ }\n    try { unlinkSync(tmpDbPath + '-shm'); } catch { /* ignore */ }\n  });\n\n  it('should persist version history', async () => {\n    const appInstance = createApp(':memory:');\n    const port = await appInstance.start(0);\n    const baseUrl = `http://localhost:${port}`;\n\n    const created = await createDoc(baseUrl, 'Test Doc', 'v1');\n\n    // Connect and make edits\n    const ws = await connectWs(port, created.id as string);\n    const sync = await waitForMessage(ws);\n    const version = sync.version as number;\n\n    sendOp(ws, version, [{ delete: 2 }, { insert: 'v2' }]);\n    await waitForMessage(ws); // ack\n\n    ws.close();\n\n    // Check versions\n    const versionsRes = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n    const versions = await versionsRes.json();\n    expect(versions.length).toBe(2);\n    expect(versions[0].content).toBe('v1');\n    expect(versions[1].content).toBe('v2');\n\n    await appInstance.stop();\n  });\n});\n"}}
