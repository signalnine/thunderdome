n  start: (port?: number) => Promise<number>;\n  stop: () => Promise<void>;\n}\n\nexport function createApp(dbPath?: string): AppInstance {\n  const db = createDb(dbPath);\n  const store = new DocumentStore(db);\n  const collaboration = new CollaborationManager(store);\n\n  const app = express();\n  app.use(express.json());\n\n  const router = createRouter(store);\n  app.use('/api', router);\n\n  let server: http.Server | null = null;\n  let wss: WebSocketServer | null = null;\n\n  const start = async (port?: number): Promise<number> => {\n    return new Promise((resolve) => {\n      server = http.createServer(app);\n      wss = new WebSocketServer({ server });\n\n      wss.on('connection', (ws: WebSocket, req) => {\n        const url = new URL(req.url || '/', `http://${req.headers.host || 'localhost'}`);\n        const pathParts = url.pathname.split('/').filter(Boolean);\n\n        // Expected path: /documents/:id or /ws/documents/:id\n        let docId: string | null = null;\n        if (pathParts.length >= 2 && pathParts[0] === 'documents') {\n          docId = pathParts[1];\n        } else if (pathParts.length >= 3 && pathParts[0] === 'ws' && pathParts[1] === 'documents') {\n          docId = pathParts[2];\n        }\n\n        if (!docId) {\n          ws.send(JSON.stringify({ type: 'error', message: 'Invalid WebSocket path. Expected /documents/:id' }));\n          ws.close();\n          return;\n        }\n\n        const clientId = url.searchParams.get('clientId') || randomUUID();\n        collaboration.handleConnection(ws, docId, clientId);\n      });\n\n      server.listen(port ?? 0, () => {\n        const addr = server!.address();\n        const assignedPort = typeof addr === 'object' && addr !== null ? addr.port : 0;\n        resolve(assignedPort);\n      });\n    });\n  };\n\n  const stop = async (): Promise<void> => {\n    collaboration.closeAll();\n\n    if (wss) {\n      wss.close();\n      wss = null;\n    }\n\n    return new Promise((resolve, reject)