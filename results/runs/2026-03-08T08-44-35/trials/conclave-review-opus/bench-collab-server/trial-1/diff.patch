__dirname = dirname(__filename);\n\nexport interface Document {\n  id: string;\n  title: string;\n  content: string;\n  created_at: string;\n  updated_at: string;\n}\n\nexport interface Version {\n  id: number;\n  document_id: string;\n  version: number;\n  content: string;\n  operation: string | null;\n  created_at: string;\n}\n\nexport function createDb(dbPath?: string): Database.Database {\n  const db = new Database(dbPath || ':memory:');\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  const schemaPath = resolve(__dirname, '..', 'schema.sql');\n  const schema = readFileSync(schemaPath, 'utf-8');\n  db.exec(schema);\n\n  return db;\n}\n\nexport class DocumentStore {\n  private db: Database.Database;\n\n  constructor(db: Database.Database) {\n    this.db = db;\n  }\n\n  createDocument(id: string, title: string, content: string = ''): Document {\n    const stmt = this.db.prepare(\n      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'\n    );\n    stmt.run(id, title, content);\n\n    // Create initial version\n    this.db.prepare(\n      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, NULL)'\n    ).run(id, content);\n\n    return this.getDocument(id)!;\n  }\n\n  getDocument(id: string): Document | undefined {\n    const stmt = this.db.prepare('SELECT * FROM documents WHERE id = ?');\n    return stmt.get(id) as Document | undefined;\n  }\n\n  listDocuments(): Document[] {\n    const stmt = this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');\n    return stmt.all() as Document[];\n  }\n\n  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {\n    const doc = this.getDocument(id);\n    if (!doc) return undefined;\n\n    const title = updates.title ?? doc.title;\n    const content = updates.content ?? doc.content;\n\n    this.db.prepare(\n      \"UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?\"\n    ).run(title, content, id);\n\n    return this.getDocument(id)!;\n  }\n\n  updateDocumentContent(id: string, content: string, operation?: object): void {\n    this.db.prepare(\n      \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n    ).run(content, id);\n\n    // Get current max version\n    const row = this.db.prepare(\n      'SELECT COALESCE(MAX(version), 0) as maxVer FROM versions WHERE document_id = ?'\n    ).get(id) as { maxVer: number };\n\n    const nextVersion = row.maxVer + 1;\n    this.db.prepare(\n      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'\n    ).run(id, nextVersion, content, operation ? JSON.stringify(operation) : null);\n  }\n\n  deleteDocument(id: string): boolean {\n    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);\n    return result.changes > 0;\n  }\n\n  getVersions(documentId: string): Version[] {\n    const stmt = this.db.prepare(\n      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'\n    );\n    return stmt.all(documentId) as Version[];\n  }\n\n  getVersion(documentId: string, version: number): Version | undefined {\n    const stmt = this.db.prepare(\n      'SELECT * FROM versions WHERE document_id = ? AND version = ?'\n    );\n    return stmt.get(documentId, version) as Version | undefined;\n  }\n\n  getCurrentVersion(documentId: string): number {\n    const row = this.db.prepare(\n      'SELECT COALESCE(MAX(version), 0) as maxVer FROM versions WHERE document_id = ?'\n    ).get(documentId) as { maxVer: number };\n    return row.maxVer;\n  }\n}\n","structuredPatch":[{"oldStart":81,"oldLines":19,"newStart":81,"newLines":21,"lines":["   }"," ","   updateDocumentContent(id: string, content: string, operation?: object): void {","-    this.db.prepare(","-      \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"","-    ).run(content, id);","+    const txn = this.db.transaction(() => {","+ 