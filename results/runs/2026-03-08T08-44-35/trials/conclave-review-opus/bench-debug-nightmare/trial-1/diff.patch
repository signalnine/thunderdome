onst existing = globalHandlers.get(event) ?? [];\n    existing.push(handler);\n    globalHandlers.set(event, existing);\n  }\n\n  off(event: string, handler: EventHandler): void {\n    const existing = globalHandlers.get(event);\n    if (!existing) return;\n    globalHandlers.set(\n      event,\n      existing.filter((h) => h !== handler)\n    );\n  }\n\n  async emit(event: string, data: unknown): Promise<void> {\n    const handlers = globalHandlers.get(event) ?? [];\n    for (const handler of handlers) {\n      await handler(data);\n    }\n  }\n\n  clear(): void {\n    globalHandlers.clear();\n  }\n}\n```\n\n**src/events/types.ts** (/workspace/src/events/types.ts)\n```typescript\nexport interface OrderEvent {\n  orderId: string;\n  timestamp: number;\n}\n\nexport interface OrderCreatedEvent extends OrderEvent {\n  items: Array<{ productId: string; quantity: number; unitPrice: number }>;\n  customerId: string;\n}\n\nexport interface OrderCancelledEvent extends OrderEvent {\n  reason: string;\n}\n\nexport interface OrderRefundedEvent extends OrderEvent {\n  amount: number;\n}\n\nexport interface PaymentChargedEvent extends OrderEvent {\n  amount: number;\n  paymentMethod: string;\n}\n\nexport interface StockReservedEvent extends OrderEvent {\n  items: Array<{ productId: string; quantity: number }>;\n}\n\nexport const ORDER_EVENTS = {\n  CREATED: 'order.created',\n  CONFIRMED: 'order.confirmed',\n  CANCELLED: 'order.cancelled',\n  REFUNDED: 'order.refunded',\n  PAYMENT_CHARGED: 'order.payment.charged',\n  STOCK_RESERVED: 'order.stock.reserved',\n  STOCK_RELEASED: 'order.stock.released',\n  NOTIFICATION_SENT: 'order.notification.sent',\n} as const;\n```\n\n**src/orders/repository.ts** (/workspace/src/orders/repository.ts)\n```typescript\nexport type OrderStatus = 'pending' | 'confirmed' | 'cancelled' | 'refunded';\n\nexport interface OrderItem {\n  productId: string;\n  quantity: number;\n  unitPrice: number;\n}\n\nexport interface Order {\n  id: string;\n  customerId: string;\n  items: OrderItem[];\n  status: OrderStatus;\n  total: number;\n  discount: number;\n  taxRate: number;\n  createdAt: number;\n  updatedAt: number;\n  notes?: string;\n}\n\nexport class OrderRepository {\n  private store: Map<string, Order> = new Map();\n\n  create(order: Order): Order {\n    this.store.set(order.id, { ...order });\n    return { ...order };\n  }\n\n  findById(id: string): Order | undefined {\n    const order = this.store.get(id);\n    return order ? { ...order } : undefined;\n  }\n\n  update(id: string, updates: Partial<Order>): Order | undefined {\n    const existing = this.store.get(id);\n    if (!existing) return undefined;\n    const updated = { ...updates, id, updatedAt: Date.now() } as Order;\n    this.store.set(id, updated);\n    return { ...updated };\n  }\n\n  findByCustomer(customerId: string): Order[] {\n    return Array.from(this.store.values())\n      .filter((o) => o.customerId === customerId)\n      .map((o) => ({ ...o }));\n  }\n\n  findByStatus(status: OrderStatus): Order[] {\n    return Array.from(this.store.values())\n      .filter((o) => o.status === status)\n      .map((o) => ({ ...o }));\n  }\n\n  clear(): void {\n    this.store.clear();\n  }\n}\n```\n\n**src/orders/service.ts** (/workspace/src/orders/service.ts)\n```typescript\nimport { EventBus } from '../events/bus.js';\nimport { ORDER_EVENTS, OrderCreatedEvent } from '../events/types.js';\nimport { OrderRepository, Order, OrderItem } from './repository.js';\nimport { BillingService } from '../billing/service.js';\n\nconst REFUND_WINDOW_DAYS = 30;\n\nexport class OrderService {\n  constructor(\n    private repo: OrderRepository,\n    private eventBus: EventBus,\n    private billingService: BillingService\n  ) {}\n\n  async createOrder(\n    id: string,\n    customerId: string,\n    items: OrderItem[],\n    discount: number = 0,\n    taxRate: number = 0.1\n  ): Promise<Order> {\n    this.repo.create({\n      id,\n      customerId,\n      items: [...items],\n      status: 'pending',\n      total: 0,\n      discount,\n      taxRate,\n      createdAt: Date.now(),\n      updatedAt: Date.now(),\n    });\n\n    const event: OrderCreatedEvent = {\n      orderId: id,\n      items: items.map((i) => ({\n        productId: i.productId,\n        quantity: i.quantity,\n        unitPrice: i.unitPrice,\n      })),\n      customerId,\n      timestamp: Date.now(),\n    };\n\n    await this.eventBus.emit(ORDER_EVENTS.CREATED, event);\n\n    // Charge payment and confirm\n    const payment = await this.billingService.chargePayment(\n      id,\n      items,\n      discount,\n      taxRate,\n      'card'\n    );\n\n    this.repo.update(id, {\n      status: 'confirmed',\n      total: payment.amount,\n    });\n\n    await this.eventBus.emit(ORDER_EVENTS.CONFIRMED, {\n      orderId: id,\n      timestamp: Date.now(),\n    });\n\n    return this.repo.findById(id)!;\n  }\n\n  async cancelOrder(id: string, reason: string): Promise<Order | undefined> {\n    const order = this.repo.findById(id);\n    if (!order) return undefined;\n    if (order.status !== 'confirmed') return undefined;\n\n    // Emit cancellation event, then update status\n    await this.eventBus.emit(ORDER_EVENTS.CANCELLED, {\n      orderId: id,\n      reason,\n      items: order.items.map((i) => ({\n        productId: i.productId,\n        quantity: i.quantity,\n      })),\n      timestamp: Date.now(),\n    });\n\n    this.repo.update(id, { status: 'cancelled' });\n\n    return this.repo.findById(id);\n  }\n\n  async refundOrder(id: string): Promise<Order | undefined> {\n    const order = this.repo.findById(id);\n    if (!order) return undefined;\n    if (order.status !== 'cancelled') return undefined;\n\n    const daysSinceCreation = Math.floor(\n      (Date.now() - order.createdAt) / (1000 * 60 * 60 * 24)\n    );\n\n    if (daysSinceCreation >= REFUND_WINDOW_DAYS) {\n      throw new Error(\n        `Refund window expired: ${daysSinceCreation} days since order (max ${REFUND_WINDOW_DAYS})`\n      );\n    }\n\n    await this.billingService.issueRefund(id, order.total);\n    this.repo.update(id, { status: 'refunded' });\n\n    return this.repo.findById(id);\n  }\n\n  getOrder(id: string): Order | undefined {\n    return this.repo.findById(id);\n  }\n\n  getOrdersByCustomer(customerId: string): Order[] {\n    return this.repo.findByCustomer(customerId);\n  }\n}\n```\n\n**src/inventory/repository.ts** (/workspace/src/inventory/repository.ts)\n```typescript\nexport interface StockRecord {\n  productId: string;\n  available: number;\n  reserved: number;\n}\n\nexport class InventoryRepository {\n  private store: Map<string, StockRecord> = new Map();\n\n  setStock(productId: string, available: number): void {\n    const existing = this.store.get(productId);\n    this.store.set(productId, {\n      productId,\n      available,\n      reserved: existing?.reserved ?? 0,\n    });\n  }\n\n  getStock(productId: string): StockRecord | undefined {\n    const record = this.store.get(productId);\n    return record ? { ...record } : undefined;\n  }\n\n  reserve(productId: string, quantity: number): boolean {\n    const record = this.store.get(productId);\n    if (!record || record.available < quantity) return false;\n    record.available -= quantity;\n    record.reserved += quantity;\n    return true;\n  }\n\n  release(productId: string, quantity: number): boolean {\n    const record = this.store.get(productId);\n    if (!record || record.reserved < quantity) return false;\n    record.reserved -= quantity;\n    record.available += quantity;\n    return true;\n  }\n\n  clear(): void {\n    this.store.clear();\n  }\n}\n```\n\n**src/inventory/service.ts** (/workspace/src/inventory/service.ts)\n```typescript\nimport { EventBus } from '../events/bus.js';\nimport { ORDER_EVENTS, OrderCreatedEvent, OrderCancelledEvent } from '../events/types.js';\nimport { InventoryRepository } from './repository.js';\n\nexport class InventoryService {\n  constructor(\n    private repo: InventoryRepository,\n    private eventBus: EventBus\n  ) {}\n\n  registerHandlers(): void {\n    this.eventBus.on(ORDER_EVENTS.CREATED, this.handleOrderCreated.bind(this));\n    this.eventBus.on(ORDER_EVENTS.CANCELLED, this.handleOrderCancelled.bind(this));\n  }\n\n  private async handleOrderCreated(data: unknown): Promise<void> {\n    const event = data as OrderCreatedEvent;\n    const reservations: Array<{ productId: string; quantity: number }> = [];\n\n    for (const item of event.items) {\n      const success = this.repo.reserve(item.productId, item.quantity);\n      if (!success) {\n        // Rollback previous reservations\n        for (const res of reservations) {\n          this.repo.release(res.productId, res.quantity);\n        }\n        throw new Error(\n          `Insufficient stock for product ${item.productId}`\n        );\n      }\n      reservations.push({ productId: item.productId, quantity: item.quantity });\n    }\n\n    await this.eventBus.emit(ORDER_EVENTS.STOCK_RESERVED, {\n      orderId: event.orderId,\n      items: reservations,\n      timestamp: Date.now(),\n    });\n  }\n\n  private async handleOrderCancelled(data: unknown): Promise<void> {\n    const event = data as OrderCancelledEvent;\n    // Release reserved stock — look up original order items from the event\n    // The order service attaches items to the cancellation event\n    const eventWithItems = data as OrderCancelledEvent & {\n      items?: Array<{ productId: string; quantity: number }>;\n      status?: string;\n    };\n\n    if (eventWithItems.status !== 'cancelled') return;\n\n    if (eventWithItems.items) {\n      for (const item of eventWithItems.items) {\n        this.repo.release(item.productId, item.quantity);\n      }\n    }\n\n    await this.eventBus.emit(ORDER_EVENTS.STOCK_RELEASED, {\n      orderId: event.orderId,\n      timestamp: Date.now(),\n    });\n  }\n\n  setStock(productId: string, quantity: number): void {\n    this.repo.setStock(productId, quantity);\n  }\n\n  getStock(productId: string) {\n    return this.repo.getStock(productId);\n  }\n}\n```\n\n**src/billing/calculator.ts** (/workspace/src/billing/calculator.ts)\n```typescript\nimport { OrderItem } from '../orders/repository.js';\n\nexport interface PriceBreakdown {\n  subtotal: number;\n  discountAmount: number;\n  taxAmount: number;\n  total: number;\n}\n\nexport function calculateOrderTotal(\n  items: OrderItem[],\n  discountPercent: number,\n  taxRate: number\n): PriceBreakdown {\n  const subtotal = items.reduce(\n    (sum, item) => sum + item.unitPrice * item.quantity,\n    0\n  );\n\n  const discountAmount = Math.round(subtotal * (discountPercent / 100) * 100) / 100;\n  const afterDiscount = Math.round((subtotal - discountAmount) * 100) / 100;\n  const taxAmount = Math.round(afterDiscount * taxRate * 100) / 100;\n  const total = afterDiscount + taxAmount;\n\n  return {\n    subtotal: Math.round(subtotal * 100) / 100,\n    discountAmount: Math.round(discountAmount * 100) / 100,\n    taxAmount: Math.round(taxAmount * 100) / 100,\n    total,\n  };\n}\n```\n\n**src/billing/service.ts** (/workspace/src/billing/service.ts)\n```typescript\nimport { EventBus } from '../events/bus.js';\nimport { ORDER_EVENTS } from '../events/types.js';\nimport { NotificationService } from '../notifications/service.js';\nimport { calculateOrderTotal } from './calculator.js';\nimport { OrderItem } from '../orders/repository.js';\n\nexport interface PaymentRecord {\n  orderId: string;\n  amount: number;\n  method: string;\n  status: 'charged' | 'refunded';\n  processedAt: number;\n}\n\nexport class BillingService {\n  private payments: Map<string, PaymentRecord> = new Map();\n\n  constructor(\n    private eventBus: EventBus,\n    private notificationService: NotificationService\n  ) {}\n\n  registerHandlers(): void {\n    this.eventBus.on(ORDER_EVENTS.STOCK_RESERVED, this.handleStockReserved.bind(this));\n    this.eventBus.on(ORDER_EVENTS.REFUNDED, this.handleRefund);\n  }\n\n  private async handleStockReserved(data: unknown): Promise<void> {\n    const event = data as { orderId: string; items: OrderItem[] };\n    // Payment would be charged here in a real system\n    await this.eventBus.emit(ORDER_EVENTS.PAYMENT_CHARGED, {\n      orderId: event.orderId,\n      amount: 0, // Actual amount set by order service\n      paymentMethod: 'card',\n      timestamp: Date.now(),\n    });\n  }\n\n  async chargePayment(\n    orderId: string,\n    items: OrderItem[],\n    discountPercent: number,\n    taxRate: number,\n    paymentMethod: string\n  ): Promise<PaymentRecord> {\n    const breakdown = calculateOrderTotal(items, discountPercent, taxRate);\n\n    const record: PaymentRecord = {\n      orderId,\n      amount: breakdown.total,\n      method: paymentMethod,\n      status: 'charged',\n      processedAt: Date.now(),\n    };\n\n    this.payments.set(orderId, record);\n    this.notificationService.sendConfirmation(orderId, breakdown.total);\n    return record;\n  }\n\n  private async handleRefund(data: unknown): Promise<void> {\n    const event = data as { orderId: string; amount: number };\n    const payment = this.payments.get(event.orderId);\n    if (payment) {\n      payment.status = 'refunded';\n      this.notificationService.sendRefundNotice(event.orderId, event.amount);\n    }\n  }\n\n  async issueRefund(orderId: string, amount: number): Promise<PaymentRecord | undefined> {\n    const payment = this.payments.get(orderId);\n    if (!payment) return undefined;\n\n    payment.status = 'refunded';\n\n    await this.eventBus.emit(ORDER_EVENTS.REFUNDED, {\n      orderId,\n      amount,\n      timestamp: Date.now(),\n    });\n\n    return { ...payment };\n  }\n\n  getPayment(orderId: string): PaymentRecord | undefined {\n    const p = this.payments.get(orderId);\n    return p ? { ...p } : undefined;\n  }\n\n  clear(): void {\n    this.payments.clear();\n  }\n}\n```\n\n**src/notifications/service.ts** (/workspace/src/notifications/service.ts)\n```typescript\nexport interface NotificationRecord {\n  type: string;\n  orderId: string;\n  message: string;\n  sentAt: number;\n}\n\nexport class NotificationService {\n  private templates: Map<string, string>;\n  private sent: NotificationRecord[] = [];\n\n  constructor() {\n    this.templates = new Map([\n      ['order.confirmed', 'Your order {orderId} has been confirmed. Total: ${total}'],\n      ['order.cancelled', 'Your order {orderId} has been cancelled. Reason: {reason}'],\n      ['order.refunded', 'Your refund of ${amount} for order {orderId} has been processed.'],\n    ]);\n  }\n\n  sendConfirmation(orderId: string, total: number): NotificationRecord {\n    const template = this.templates.get('order.confirmed')!;\n    const message = template\n      .replace('{orderId}', orderId)\n      .replace('{total}', total.toFixed(2));\n    const record: NotificationRecord = {\n      type: 'confirmation',\n      orderId,\n      message,\n      sentAt: Date.now(),\n    };\n    this.sent.push(record);\n    return record;\n  }\n\n  sendCancellation(orderId: string, reason: string): NotificationRecord {\n    const template = this.templates.get('order.cancelled')!;\n    const message = template\n      .replace('{orderId}', orderId)\n      .replace('{reason}', reason);\n    const record: NotificationRecord = {\n      type: 'cancellation',\n      orderId,\n      message,\n      sentAt: Date.now(),\n    };\n    this.sent.push(record);\n    return record;\n  }\n\n  sendRefundNotice(orderId: string, amount: number): NotificationRecord {\n    const template = this.templates.get('order.refunded')!;\n    const message = template\n      .replace('{orderId}', orderId)\n      .replace('{amount}', amount.toFixed(2));\n    const record: NotificationRecord = {\n      type: 'refund',\n      orderId,\n      message,\n      sentAt: Date.now(),\n    };\n    this.sent.push(record);\n    return record;\n  }\n\n  getSentNotifications(): NotificationRecord[] {\n    return [...this.sent];\n  }\n\n  clear(): void {\n    this.sent = [];\n  }\n}\n```\n\n### Test Files\n\n**tests/orders.test.ts** (/workspace/tests/orders.test.ts)\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/events/bus.js';\nimport { OrderRepository } from '../src/orders/repository.js';\nimport { OrderService } from '../src/orders/service.js';\nimport { InventoryRepository } from '../src/inventory/repository.js';\nimport { InventoryService } from '../src/inventory/service.js';\nimport { NotificationService } from '../src/notifications/service.js';\nimport { BillingService } from '../src/billing/service.js';\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n  let orderRepo: OrderRepository;\n  let inventoryRepo: InventoryRepository;\n  let inventoryService: InventoryService;\n  let notifications: NotificationService;\n  let billing: BillingService;\n  let orderService: OrderService;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orderRepo = new OrderRepository();\n    inventoryRepo = new InventoryRepository();\n    inventoryService = new InventoryService(inventoryRepo, bus);\n    notifications = new NotificationService();\n    billing = new BillingService(bus, notifications);\n\n    inventoryService.registerHandlers();\n    billing.registerHandlers();\n\n    orderService = new OrderService(orderRepo, bus, billing);\n  });\n\n  it('creates an order and confirms it', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    const order = await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 2, unitPrice: 25 },\n    ]);\n    expect(order.status).toBe('confirmed');\n    expect(order.total).toBe(55); // 50 + 10% tax\n  });\n\n  it('reserves stock when order is created', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 3, unitPrice: 10 },\n    ]);\n    const stock = inventoryService.getStock('SKU-1');\n    expect(stock?.available).toBe(7);\n    expect(stock?.reserved).toBe(3);\n  });\n\n  it('cancels a confirmed order', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 2, unitPrice: 10 },\n    ]);\n    const cancelled = await orderService.cancelOrder('O1', 'changed mind');\n    expect(cancelled?.status).toBe('cancelled');\n  });\n\n  it('releases stock when order is cancelled', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 4, unitPrice: 10 },\n    ]);\n    await orderService.cancelOrder('O1', 'changed mind');\n    const stock = inventoryService.getStock('SKU-1');\n    expect(stock?.available).toBe(10);\n    expect(stock?.reserved).toBe(0);\n  });\n\n  it('refuses to cancel a non-confirmed order', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 10 },\n    ]);\n    await orderService.cancelOrder('O1', 'first cancel');\n    // Try to cancel again — already cancelled\n    const result = await orderService.cancelOrder('O1', 'second cancel');\n    expect(result).toBeUndefined();\n  });\n\n  it('refunds a cancelled order within 30 days', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    ]);\n    await orderService.cancelOrder('O1', 'not needed');\n    const refunded = await orderService.refundOrder('O1');\n    expect(refunded?.status).toBe('refunded');\n  });\n\n  it('allows refund on exactly day 30', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    ]);\n    // Manually backdate the order to exactly 30 days ago\n    const thirtyDaysMs = 30 * 24 * 60 * 60 * 1000;\n    orderRepo.update('O1', { createdAt: Date.now() - thirtyDaysMs });\n    await orderService.cancelOrder('O1', 'late cancel');\n    const refunded = await orderService.refundOrder('O1');\n    expect(refunded?.status).toBe('refunded');\n  });\n\n  it('rejects refund after 30-day window', async () => {\n    inventoryService.setStock('SKU-1', 10);\n    await orderService.createOrder('O1', 'C1', [\n      { productId: 'SKU-1', quantity: 1, unitPrice: 100 },\n    ]);\n    // Backdate to 31 days ago\n    const thirtyOneDaysMs = 31 * 24 * 60 * 60 * 1000;\n    orderRepo.update('O1', { createdAt: Date.now() - thirtyOneDaysMs });\n    await orderService.cancelOrder('O1', 'very late');\n    await expect(orderService.refundOrder('O1')).rejects.toThrow('Refund window expired');\n  });\n});\n\ndescribe('OrderRepository', () => {\n  let repo: OrderRepository;\n\n  beforeEach(() => {\n    repo = new OrderRepository();\n  });\n\n  it('creates and retrieves an order', () => {\n    const order = repo.create({\n      id: 'O1',\n      customerId: 'C1',\n      items: [],\n      status: 'pending',\n      total: 0,\n      discount: 0,\n      taxRate: 0.1,\n      createdAt: Date.now(),\n      updatedAt: Date.now(),\n    });\n    expect(repo.findById('O1')).toEqual(order);\n  });\n\n  it('updates order preserves other fields', () => {\n    repo.create({\n      id: 'O1',\n      customerId: 'C1',\n      items: [{ productId: 'A', quantity: 1, unitPrice: 10 }],\n      status: 'pending',\n      total: 10,\n      discount: 0,\n      taxRate: 0.1,\n      createdAt: 1000,\n      updatedAt: 1000,\n      notes: 'rush delivery',\n    });\n    const updated = repo.update('O1', { status: 'confirmed' });\n    expect(updated?.status).toBe('confirmed');\n    expect(updated?.customerId).toBe('C1');\n    expect(updated?.notes).toBe('rush delivery');\n    expect(updated?.items).toHaveLength(1);\n    expect(updated?.total).toBe(10);\n  });\n\n  it('returns undefined for missing order', () => {\n    expect(repo.findById('NOPE')).toBeUndefined();\n  });\n\n  it('finds orders by customer', () => {\n    repo.create({\n      id: 'O1', customerId: 'C1', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    repo.create({\n      id: 'O2', customerId: 'C2', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    repo.create({\n      id: 'O3', customerId: 'C1', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    expect(repo.findByCustomer('C1')).toHaveLength(2);\n  });\n});\n```\n\n**tests/notifications.test.ts** (/workspace/tests/notifications.test.ts)\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { NotificationService } from '../src/notifications/service.js';\n\ndescribe('NotificationService', () => {\n  let service: NotificationService;\n\n  beforeEach(() => {\n    service = new NotificationService();\n  });\n\n  it('sends order confirmation', () => {\n    const record = service.sendConfirmation('O1', 99.99);\n    expect(record.type).toBe('confirmation');\n    expect(record.message).toContain('O1');\n    expect(record.message).toContain('99.99');\n  });\n\n  it('sends cancellation notice', () => {\n    const record = service.sendCancellation('O1', 'changed mind');\n    expect(record.type).toBe('cancellation');\n    expect(record.message).toContain('changed mind');\n  });\n\n  it('sends refund notice', () => {\n    const record = service.sendRefundNotice('O1', 50.00);\n    expect(record.type).toBe('refund');\n    expect(record.message).toContain('50.00');\n  });\n\n  it('tracks all sent notifications', () => {\n    service.sendConfirmation('O1', 100);\n    service.sendCancellation('O2', 'duplicate');\n    service.sendRefundNotice('O3', 75);\n    expect(service.getSentNotifications()).toHaveLength(3);\n  });\n});\n```\n\n**tests/inventory.test.ts** (/workspace/tests/inventory.test.ts)\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/events/bus.js';\nimport { InventoryRepository } from '../src/inventory/repository.js';\nimport { InventoryService } from '../src/inventory/service.js';\nimport { ORDER_EVENTS } from '../src/events/types.js';\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n  let repo: InventoryRepository;\n  let service: InventoryService;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    repo = new InventoryRepository();\n    service = new InventoryService(repo, bus);\n    service.registerHandlers();\n  });\n\n  it('reserves stock on order.created', async () => {\n    service.setStock('SKU-1', 10);\n    await bus.emit(ORDER_EVENTS.CREATED, {\n      orderId: 'O1',\n      items: [{ productId: 'SKU-1', quantity: 3, unitPrice: 10 }],\n      customerId: 'C1',\n      timestamp: Date.now(),\n    });\n    const stock = service.getStock('SKU-1');\n    expect(stock?.available).toBe(7);\n    expect(stock?.reserved).toBe(3);\n  });\n\n  it('throws when stock is insufficient', async () => {\n    service.setStock('SKU-1', 2);\n    await expect(\n      bus.emit(ORDER_EVENTS.CREATED, {\n        orderId: 'O1',\n        items: [{ productId: 'SKU-1', quantity: 5, unitPrice: 10 }],\n        customerId: 'C1',\n        timestamp: Date.now(),\n      })\n    ).rejects.toThrow('Insufficient stock');\n  });\n\n  it('rolls back partial reservations on failure', async () => {\n    service.setStock('SKU-1', 10);\n    service.setStock('SKU-2', 1);\n    try {\n      await bus.emit(ORDER_EVENTS.CREATED, {\n        orderId: 'O1',\n        items: [\n          { productId: 'SKU-1', quantity: 3, unitPrice: 10 },\n          { productId: 'SKU-2', quantity: 5, unitPrice: 20 },\n        ],\n        customerId: 'C1',\n        timestamp: Date.now(),\n      });\n    } catch { /* expected */ }\n    const stock1 = service.getStock('SKU-1');\n    expect(stock1?.available).toBe(10);\n    expect(stock1?.reserved).toBe(0);\n  });\n\n  it('releases stock on order.cancelled', async () => {\n    service.setStock('SKU-1', 10);\n    // First reserve\n    await bus.emit(ORDER_EVENTS.CREATED, {\n      orderId: 'O1',\n      items: [{ productId: 'SKU-1', quantity: 3, unitPrice: 10 }],\n      customerId: 'C1',\n      timestamp: Date.now(),\n    });\n    // Then cancel\n    await bus.emit(ORDER_EVENTS.CANCELLED, {\n      orderId: 'O1',\n      reason: 'changed mind',\n      status: 'cancelled',\n      items: [{ productId: 'SKU-1', quantity: 3 }],\n      timestamp: Date.now(),\n    });\n    const stock = service.getStock('SKU-1');\n    expect(stock?.available).toBe(10);\n    expect(stock?.reserved).toBe(0);\n  });\n\n  it('reserves stock for concurrent orders independently', async () => {\n    service.setStock('SKU-1', 20);\n    await bus.emit(ORDER_EVENTS.CREATED, {\n      orderId: 'O1',\n      items: [{ productId: 'SKU-1', quantity: 5, unitPrice: 10 }],\n      customerId: 'C1',\n      timestamp: Date.now(),\n    });\n    await bus.emit(ORDER_EVENTS.CREATED, {\n      orderId: 'O2',\n      items: [{ productId: 'SKU-1', quantity: 3, unitPrice: 10 }],\n      customerId: 'C2',\n      timestamp: Date.now(),\n    });\n    const stock = service.getStock('SKU-1');\n    expect(stock?.available).toBe(12);\n    expect(stock?.reserved).toBe(8);\n  });\n});\n```\n\n**tests/billing.test.ts** (/workspace/tests/billing.test.ts)\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/events/bus.js';\nimport { NotificationService } from '../src/notifications/service.js';\nimport { BillingService } from '../src/billing/service.js';\nimport { calculateOrderTotal } from '../src/billing/calculator.js';\n\ndescribe('calculateOrderTotal', () => {\n  it('calculates total with no discount or tax', () => {\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 2, unitPrice: 50 }],\n      0,\n      0\n    );\n    expect(result.total).toBe(100);\n    expect(result.discountAmount).toBe(0);\n    expect(result.taxAmount).toBe(0);\n  });\n\n  it('applies percentage discount before tax', () => {\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      10,\n      0.08\n    );\n    // $100 - 10% = $90, + 8% tax = $97.20\n    expect(result.total).toBe(97.2);\n  });\n\n  it('handles multiple items with discount and tax', () => {\n    const result = calculateOrderTotal(\n      [\n        { productId: 'A', quantity: 3, unitPrice: 29.99 },\n        { productId: 'B', quantity: 1, unitPrice: 49.99 },\n      ],\n      15,\n      0.1\n    );\n    // subtotal = 3*29.99 + 49.99 = 139.96\n    // discount = 139.96 * 0.15 = 20.994\n    // after discount = 118.966\n    // tax = 118.966 * 0.1 = 11.8966\n    // total = 130.8626 -> rounded to 130.86\n    expect(result.total).toBe(130.86);\n  });\n\n  it('rounds correctly for penny-edge amounts', () => {\n    // This specifically tests that we don't double-round\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 1, unitPrice: 33.33 }],\n      5,\n      0.07\n    );\n    // subtotal = 33.33\n    // discount = 33.33 * 0.05 = 1.6665\n    // after discount = 31.6635\n    // tax = 31.6635 * 0.07 = 2.21644...\n    // total = 33.87994... -> 33.88\n    expect(result.total).toBe(33.88);\n  });\n});\n\ndescribe('BillingService', () => {\n  let bus: EventBus;\n  let notifications: NotificationService;\n  let billing: BillingService;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = new NotificationService();\n    billing = new BillingService(bus, notifications);\n    billing.registerHandlers();\n  });\n\n  it('charges payment and records it', async () => {\n    const record = await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      0,\n      0.1,\n      'card'\n    );\n    expect(record.amount).toBe(110);\n    expect(record.status).toBe('charged');\n    expect(record.method).toBe('card');\n  });\n\n  it('sends confirmation notification on charge', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      0,\n      0.1,\n      'card'\n    );\n    const sent = notifications.getSentNotifications();\n    expect(sent).toHaveLength(1);\n    expect(sent[0].type).toBe('confirmation');\n    expect(sent[0].message).toContain('O1');\n  });\n\n  it('issues refund and updates payment status', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 50 }],\n      0,\n      0,\n      'card'\n    );\n    const refund = await billing.issueRefund('O1', 50);\n    expect(refund?.status).toBe('refunded');\n  });\n\n  it('sends refund notification', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 50 }],\n      0,\n      0,\n      'card'\n    );\n    await billing.issueRefund('O1', 50);\n    const sent = notifications.getSentNotifications();\n    const refundNotice = sent.find((n) => n.type === 'refund');\n    expect(refundNotice).toBeDefined();\n    expect(refundNotice!.message).toContain('50.00');\n  });\n});\n```\n\n**tests/events.test.ts** (/workspace/tests/events.test.ts)\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/events/bus.js';\n\ndescribe('EventBus', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('emits events to registered handlers', async () => {\n    const received: unknown[] = [];\n    bus.on('test', (data) => { received.push(data); });\n    await bus.emit('test', { value: 1 });\n    expect(received).toEqual([{ value: 1 }]);\n  });\n\n  it('supports multiple handlers for same event', async () => {\n    let count = 0;\n    bus.on('test', () => { count++; });\n    bus.on('test', () => { count++; });\n    await bus.emit('test', {});\n    expect(count).toBe(2);\n  });\n\n  it('does not fire handlers for different events', async () => {\n    let called = false;\n    bus.on('other', () => { called = true; });\n    await bus.emit('test', {});\n    expect(called).toBe(false);\n  });\n\n  it('removes handlers with off()', async () => {\n    let count = 0;\n    const handler = () => { count++; };\n    bus.on('test', handler);\n    bus.off('test', handler);\n    await bus.emit('test', {});\n    expect(count).toBe(0);\n  });\n\n  it('clears all handlers', async () => {\n    let count = 0;\n    bus.on('a', () => { count++; });\n    bus.on('b', () => { count++; });\n    bus.clear();\n    await bus.emit('a', {});\n    await bus.emit('b', {});\n    expect(count).toBe(0);\n  });\n});\n```\n\n## Summary\n\nThis is an **event-driven order processing system** benchmark project for debugging. The system includes:\n\n- **Event Bus**: A global event registry that enables pub-sub communication\n- **Orders Module**: Creates, cancels, and refunds orders with a 30-day refund window\n- **Inventory Module**: Manages stock reservation and release with rollback capabilities\n- **Billing Module**: Calculates prices with discounts and tax, charges payments, and issues refunds\n- **Notifications Module**: Sends order confirmations, cancellations, and refund notices\n- **Tests**: Comprehensive test suite covering all modules and their interactions\n\nAll files are located at the paths listed above."}],"totalDurationMs":62777,"totalTokens":37910,"totalToolUseCount":18,"usage":{"input_tokens":6,"cache_creation_input_tokens":7410,"cache_read_input_tokens":19143,"output_tokens":11351,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":7410,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[]}}}
