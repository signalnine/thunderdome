 = service.getStock('SKU-1');\n    expect(stock?.available).toBe(7);\n    expect(stock?.reserved).toBe(3);\n  });\n\n  it('throws when stock is insufficient', async () => {\n    service.setStock('SKU-1', 2);\n    await expect(\n      bus.emit(ORDER_EVENTS.CREATED, {\n        orderId: 'O1',\n        items: [{ productId: 'SKU-1', quantity: 5, unitPrice: 10 }],\n        customerId: 'C1',\n        timestamp: Date.now(),\n      })\n    ).rejects.toThrow('Insufficient stock');\n  });\n\n  it('rolls back partial reservations on failure', async () => {\n    service.setStock('SKU-1', 10);\n    service.setStock('SKU-2', 1);\n    try {\n      await bus.emit(ORDER_EVENTS.CREATED, {\n        orderId: 'O1',\n        items: [\n          { productId: 'SKU-1', quantity: 3, unitPrice: 10 },\n          { productId: 'SKU-2', quantity: 5, unitPrice: 20 },\n        ],\n        customerId: 'C1',\n        timestamp: Date.now(),\n      });\n    } catch { /* expected */ }\n    const stock1 = service.getStock('SKU-1');\n    expect(stock1?.available).toBe(10);\n    expect(stock1?.reserved).toBe(0);\n  });\n\n  it('releases stock on order.cancelled', async () => {\n    service.setStock('SKU-1', 10);\n    // First reserve\n    await bus.emit(ORDER_EVENTS.CREATED, {\n      orderId: 'O1',\n      items: [{ productId: 'SKU-1', quantity: 3, unitPrice: 10 }],\n      customerId: 'C1',\n      timestamp: Date.now(),\n    });\n    // Then cancel\n    await bus.emit(ORDER_EVENTS.CANCELLED, {\n      orderId: 'O1',\n      reason: 'changed mind',\n      status: 'cancelled',\n      items: [{ productId: 'SKU-1', quantity: 3 }],\n      timestamp: Date.now(),\n    });\n    const stock = service.getStock('SKU-1');\n    expect(stock?.available).toBe(10);\n    expect(stock?.reserved).toBe(0);\n  });\n\n  it('reserves stock for concurrent orders independently', async () => {\n    service.setStock('SKU-1', 20);\n    await bus.emit(ORDER_EVENTS.CREATED, {\n      orderId: 'O1',\n      items: [{ productId: 'SKU-1', quantity: 5, unitPrice: 10 }],\n      customerId: 'C1',\n      timestamp: Date.now(),\n    });\n    await bus.emit(ORDER_EVENTS.CREATED, {\n      orderId: 'O2',\n      items: [{ productId: 'SKU-1', quantity: 3, unitPrice: 10 }],\n      customerId: 'C2',\n      timestamp: Date.now(),\n    });\n    const stock = service.getStock('SKU-1');\n    expect(stock?.available).toBe(12);\n    expect(stock?.reserved).toBe(8);\n  });\n});\n```\n\n**tests/billing.test.ts** (/workspace/tests/billing.test.ts)\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/events/bus.js';\nimport { NotificationService } from '../src/notifications/service.js';\nimport { BillingService } from '../src/billing/service.js';\nimport { calculateOrderTotal } from '../src/billing/calculator.js';\n\ndescribe('calculateOrderTotal', () => {\n  it('calculates total with no discount or tax', () => {\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 2, unitPrice: 50 }],\n      0,\n      0\n    );\n    expect(result.total).toBe(100);\n    expect(result.discountAmount).toBe(0);\n    expect(result.taxAmount).toBe(0);\n  });\n\n  it('applies percentage discount before tax', () => {\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      10,\n      0.08\n    );\n    // $100 - 10% = $90, + 8% tax = $97.20\n    expect(result.total).toBe(97.2);\n  });\n\n  it('handles multiple items with discount and tax', () => {\n    const result = calculateOrderTotal(\n      [\n        { productId: 'A', quantity: 3, unitPrice: 29.99 },\n        { productId: 'B', quantity: 1, unitPrice: 49.99 },\n      ],\n      15,\n      0.1\n    );\n    // subtotal = 3*29.99 + 49.99 = 139.96\n    // discount = 139.96 * 0.15 = 20.994\n    // after discount = 118.966\n    // tax = 118.966 * 0.1 = 11.8966\n    // total = 130.8626 -> rounded to 130.86\n    expect(result.total).toBe(130.86);\n  });\n\n  it('rounds correctly for penny-edge amounts', () => {\n    // This specifically tests that we don't double-round\n    const result = calculateOrderTotal(\n      [{ productId: 'A', quantity: 1, unitPrice: 33.33 }],\n      5,\n      0.07\n    );\n    // subtotal = 33.33\n    // discount = 33.33 * 0.05 = 1.6665\n    // after discount = 31.6635\n    // tax = 31.6635 * 0.07 = 2.21644...\n    // total = 33.87994... -> 33.88\n    expect(result.total).toBe(33.88);\n  });\n});\n\ndescribe('BillingService', () => {\n  let bus: EventBus;\n  let notifications: NotificationService;\n  let billing: BillingService;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = new NotificationService();\n    billing = new BillingService(bus, notifications);\n    billing.registerHandlers();\n  });\n\n  it('charges payment and records it', async () => {\n    const record = await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      0,\n      0.1,\n      'card'\n    );\n    expect(record.amount).toBe(110);\n    expect(record.status).toBe('charged');\n    expect(record.method).toBe('card');\n  });\n\n  it('sends confirmation notification on charge', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 100 }],\n      0,\n      0.1,\n      'card'\n    );\n    const sent = notifications.getSentNotifications();\n    expect(sent).toHaveLength(1);\n    expect(sent[0].type).toBe('confirmation');\n    expect(sent[0].message).toContain('O1');\n  });\n\n  it('issues refund and updates payment status', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 50 }],\n      0,\n      0,\n      'card'\n    );\n    const refund = await billing.issueRefund('O1', 50);\n    expect(refund?.status).toBe('refunded');\n  });\n\n  it('sends refund notification', async () => {\n    await billing.chargePayment(\n      'O1',\n      [{ productId: 'A', quantity: 1, unitPrice: 50 }],\n      0,\n      0,\n      'card'\n    );\n    await billing.issueRefund('O1', 50);\n    const sent = notifications.getSentNotifications();\n    const refundNotice = sent.find((n) => n.type === 'refund');\n    expect(refundNotice).toBeDefined();\n    expect(refundNotice!.message).toContain('50.00');\n  });\n});\n```\n\n**tests/events.test.ts** (/workspace/tests/events.test.ts)\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { EventBus } from '../src/events/bus.js';\n\ndescribe('EventBus', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('emits events to registered handlers', async () => {\n    const received: unknown[] = [];\n    bus.on('test', (data) => { received.push(data); });\n    await bus.emit('test', { value: 1 });\n    expect(received).toEqual([{ value: 1 }]);\n  });\n\n  it('supports multiple handlers for same event', async () => {\n    let count = 0;\n    bus.on('test', () => { count++; });\n    bus.on('test', () => { count++; });\n    await bus.emit('test', {});\n    expect(count).toBe(2);\n  });\n\n  it('does not fire handlers for different events', async () => {\n    let called = false;\n    bus.on('other', () => { called = true; });\n    await bus.emit('test', {});\n    expect(called).toBe(false);\n  });\n\n  it('removes handlers with off()', async () => {\n    let count = 0;\n    const handler = () => { count++; };\n    bus.on('test', handler);\n    bus.off('test', handler);\n    await bus.emit('test', {});\n    expect(count).toBe(0);\n  });\n\n  it('clears all handlers', async () => {\n    let count = 0;\n    bus.on('a', () => { count++; });\n    bus.on('b', () => { count++; });\n    bus.clear();\n    await bus.emit('a', {});\n    await bus.emit('b', {});\n    expect(count).toBe(0);\n  });\n});\n```\n\n## Summary\n\nThis is an **event-driven order processing system** benchmark project for debugging. The system includes:\n\n- **Event Bus**: A global even