ves an order', () => {\n    const order = repo.create({\n      id: 'O1',\n      customerId: 'C1',\n      items: [],\n      status: 'pending',\n      total: 0,\n      discount: 0,\n      taxRate: 0.1,\n      createdAt: Date.now(),\n      updatedAt: Date.now(),\n    });\n    expect(repo.findById('O1')).toEqual(order);\n  });\n\n  it('updates order preserves other fields', () => {\n    repo.create({\n      id: 'O1',\n      customerId: 'C1',\n      items: [{ productId: 'A', quantity: 1, unitPrice: 10 }],\n      status: 'pending',\n      total: 10,\n      discount: 0,\n      taxRate: 0.1,\n      createdAt: 1000,\n      updatedAt: 1000,\n      notes: 'rush delivery',\n    });\n    const updated = repo.update('O1', { status: 'confirmed' });\n    expect(updated?.status).toBe('confirmed');\n    expect(updated?.customerId).toBe('C1');\n    expect(updated?.notes).toBe('rush delivery');\n    expect(updated?.items).toHaveLength(1);\n    expect(updated?.total).toBe(10);\n  });\n\n  it('returns undefined for missing order', () => {\n    expect(repo.findById('NOPE')).toBeUndefined();\n  });\n\n  it('finds orders by customer', () => {\n    repo.create({\n      id: 'O1', customerId: 'C1', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    repo.create({\n      id: 'O2', customerId: 'C2', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    repo.create({\n      id: 'O3', customerId: 'C1', items: [], status: 'pending',\n      total: 0, discount: 0, taxRate: 0, createdAt: 0, updatedAt: 0,\n    });\n    expect(repo.findByCustomer('C1')).toHaveLength(2);\n  });\n});\n```\n\n**tests/notifications.test.ts** (/workspace/tests/notifications.test.ts)\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { NotificationService } from '../src/notifications/service.js';\n\ndescribe('NotificationService', () => {\n  let service: NotificationService;