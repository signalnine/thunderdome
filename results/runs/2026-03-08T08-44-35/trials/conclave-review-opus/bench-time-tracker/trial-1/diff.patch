lePath));\n    } catch {\n      // ignore cleanup errors\n    }\n  });\n\n  describe(\"start/stop\", () => {\n    it(\"should start and stop a timer\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      expect(tracker.isRunning()).toBe(true);\n      expect(tracker.currentTask()).toBe(\"coding\");\n\n      const entry = tracker.stop();\n      expect(entry.task).toBe(\"coding\");\n      expect(entry.stop).not.toBeNull();\n      expect(tracker.isRunning()).toBe(false);\n    });\n\n    it(\"should auto-stop previous timer when starting a new one\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      tracker.start(\"task2\");\n\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].task).toBe(\"task1\");\n      expect(entries[0].stop).not.toBeNull();\n      expect(entries[1].task).toBe(\"task2\");\n      expect(entries[1].stop).toBeNull();\n    });\n\n    it(\"should throw when starting with empty name\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.start(\"\")).toThrow(\"Task name cannot be empty\");\n      expect(() => tracker.start(\"   \")).toThrow(\"Task name cannot be empty\");\n    });\n\n    it(\"should throw when stopping with no running timer\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should persist data across instances\", () => {\n      const tracker1 = new TimeTracker(filePath);\n      tracker1.start(\"task1\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"task1\");\n    });\n\n    it(\"should create directories if they don't exist\", () => {\n      const deepPath = path.join(os.tmpdir(), \"tt-deep\", \"a\", \"b\", \"data.json\");\n      const tracker = new TimeTracker(deepPath);\n      tracker.start(\"test\");\n      tracker.stop();\n      expect(fs.existsSync(deepPath)).toBe(true);\n\n      // cleanup\n      fs.unlinkSync(deepPath);\n      fs.rmdirSync(path.join(os.tmpdir(), \"tt-deep\", \"a\", \"b\"));\n      fs.rmdirSync(path.join(os.tmpdir(), \"tt-deep\", \"a\"));\n      fs.rmdirSync(path.join(os.tmpdir(), \"tt-deep\"));\n    });\n  });\n\n  describe(\"getEntries with date filtering\", () => {\n    it(\"should return all entries when no filter\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"a\");\n      tracker.stop();\n      tracker.start(\"b\");\n      tracker.stop();\n\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it(\"should filter by date range\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"a\");\n      tracker.stop();\n\n      const now = new Date();\n      const past = new Date(now.getTime() - 86400000);\n      const future = new Date(now.getTime() + 86400000);\n\n      expect(tracker.getEntries(past, future)).toHaveLength(1);\n      expect(tracker.getEntries(future)).toHaveLength(0);\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should sum durations per task\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"meeting\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThan(0);\n      expect(summary[\"meeting\"]).toBeGreaterThan(0);\n    });\n\n    it(\"should include running task duration using current time\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"running-task\");\n\n      const summary = tracker.getSummary();\n      expect(summary[\"running-task\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle unicode task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"编程\");\n      tracker.stop();\n      tracker.start(\"🚀 launch\");\n      tracker.stop();\n      tracker.start(\"café ☕\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"编程\");\n      expect(entries[1].task).toBe(\"🚀 launch\");\n      expect(entries[2].task).toBe(\"café ☕\");\n\n      const summary = tracker.getSummary();\n      expect(summary[\"编程\"]).toBeGreaterThanOrEqual(0);\n      expect(summary[\"🚀 launch\"]).toBeGreaterThanOrEqual(0);\n      expect(summary[\"café ☕\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":126,"oldLines":8,"newStart":126,"newLines":10,"lines":["       tracker.stop();"," ","       const summary = tracker.getSummary();","-      expect(summary[\"coding\"]).toBeGreaterThan(0);","-      expect(summary[\"meeting\"]).toBeGreaterThan(0);","+      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);","+      expect(summary[\"meeting\"]).toBeGreaterThanOrEqual(0);","+      expect(\"coding\" in summary).toBe(true);","+      expect(\"meeting\" in summary).toBe(true);","     });"," ","     it(\"should include running task duration using current time\", () => {"]}],"userModified":false,"replaceAll":false}}
