+  const allPaths = new Set<string>();
+  for (const path of getLeafPaths(baseObj)) allPaths.add(path);
+  for (const path of getLeafPaths(oursObj)) allPaths.add(path);
+  for (const path of getLeafPaths(theirsObj)) allPaths.add(path);
