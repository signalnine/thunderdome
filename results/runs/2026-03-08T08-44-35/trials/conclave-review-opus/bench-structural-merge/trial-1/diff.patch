+      }
+
+      // Apply merged content updates
+      for (const [docId, content] of Object.entries(merged)) {
+        const targetEntry = target.documents.get(docId);
+
+        if (targetEntry && !targetEntry.deleted) {
+          const version: Version = {
+            id: generateId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          targetEntry.content = deepClone(content);
+          targetEntry.versions.push(version);
+        } else {
+          const version: Version = {
+            id: generateId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          target.documents.set(docId, {
+            content: deepClone(content),
+            versions: [version],
+            deleted: false,
+          });
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  // ── Private helpers ──
+
+  private getCurrentBranchState(): BranchState {
+    const branch = this.branches.get(this.currentBranch);
+    if (!branch) {
+      throw new Error(`Branch "${this.currentBranch}" not found`);
+    }
+    return branch;
+  }
+}
