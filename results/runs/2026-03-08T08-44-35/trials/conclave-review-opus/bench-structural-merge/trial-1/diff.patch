+  for (const path of allPaths) {
+    const baseVal = getAtPath(baseObj as JsonValue, path);
+    const oursVal = getAtPath(oursObj as JsonValue, path);
+    const theirsVal = getAtPath(theirsObj as JsonValue, path);
+
+    const oursChanged = !valuesEqual(baseVal, oursVal);
+    const theirsChanged = !valuesEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      if (theirsVal === undefined) {
+        deleteAtPath(merged, path);
+      } else {
+        setAtPath(merged, path, deepClone(theirsVal) as JsonValue);
+      }
+      continue;
+    }
