+    conflicts.push({
+      documentId,
+      path,
+      base: baseVal !== undefined ? deepClone(baseVal) as JsonValue : undefined,
+      ours: oursVal !== undefined ? deepClone(oursVal) as JsonValue : undefined,
+      theirs: theirsVal !== undefined ? deepClone(theirsVal) as JsonValue : undefined,
+    });
+  }
