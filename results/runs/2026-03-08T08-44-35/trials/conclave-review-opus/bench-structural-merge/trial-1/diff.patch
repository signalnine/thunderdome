+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: JsonValue | undefined;
+  ours: JsonValue | undefined;
+  theirs: JsonValue | undefined;
