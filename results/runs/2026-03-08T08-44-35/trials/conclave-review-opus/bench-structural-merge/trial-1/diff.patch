+/**
+ * Get all keys (dot-separated paths) from a nested object.
+ */
+function getLeafPaths(obj: JsonValue | undefined, prefix: string = ''): string[] {
+  const paths: string[] = [];
+  if (obj === null || obj === undefined || typeof obj !== 'object') {
+    return prefix ? [prefix] : [];
+  }
+  if (Array.isArray(obj)) {
+    return prefix ? [prefix] : [];
+  }
+  const keys = Object.keys(obj);
+  if (keys.length === 0) {
+    return [];
+  }
+  for (const key of keys) {
+    const fullPath = prefix ? `${prefix}.${key}` : key;
+    paths.push(...getLeafPaths((obj as JsonObject)[key], fullPath));
+  }
+  return paths;
+}
+
+/**
+ * Get a value at a dot-separated path from an object.
+ */
+function getAtPath(obj: JsonValue | undefined, path: string): JsonValue | undefined {
+  const parts = path.split('.');
+  let current: JsonValue | undefined = obj;
+  for (const part of parts) {
+    if (current === null || current === undefined || typeof current !== 'object' || Array.isArray(current)) {
+      return undefined;
+    }
+    current = (current as JsonObject)[part];
+  }
+  return current;
+}
+
+/**
+ * Set a value at a dot-separated path on an object.
+ */
+function setAtPath(obj: JsonObject, path: string, value: JsonValue): void {
+  const parts = path.split('.');
+  let current: JsonObject = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    const child = current[part];
+    if (child === undefined || child === null || typeof child !== 'object' || Array.isArray(child)) {
+      current[part] = {};
+    }
+    current = current[part] as JsonObject;
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+/**
+ * Delete a value at a dot-separated path on an object.
+ */
+function deleteAtPath(obj: JsonObject, path: string): void {
+  const parts = path.split('.');
+  let current: JsonObject = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    const child = current[part];
+    if (child === undefined || child === null || typeof child !== 'object' || Array.isArray(child)) {
+      return;
+    }
+    current = child as JsonObject;
+  }
+  delete current[parts[parts.length - 1]];
