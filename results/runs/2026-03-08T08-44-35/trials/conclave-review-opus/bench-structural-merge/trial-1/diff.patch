 });\n\n  describe('get', () => {\n    it('should throw if document does not exist', () => {\n      expect(() => store.get('nonexistent')).toThrow();\n    });\n\n    it('should throw if document was deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should deep clone content on get', () => {\n      store.create('doc1', { nested: { value: 1 } });\n      const result = store.get('doc1') as Record<string, Record<string, number>>;\n      result.nested.value = 999;\n      expect(store.get('doc1')).toEqual({ nested: { value: 1 } });\n    });\n  });\n\n  describe('update', () => {\n    it('should update document content', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should throw if document does not exist', () => {\n      expect(() => store.update('nonexistent', { name: 'Bob' })).toThrow();\n    });\n\n    it('should throw if document was deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.update('doc1', { name: 'Bob' })).toThrow();\n    });\n\n    it('should deep clone content on update', () => {\n      store.create('doc1', { name: 'Alice' });\n      const content = { name: 'Bob' };\n      store.update('doc1', content);\n      content.name = 'Charlie';\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n  });\n\n  describe('delete', () => {\n    it('should delete a document', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should throw if document does not exist', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    it('should throw if document was already deleted', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n  });\n\n  // ── Version History ──\n\n  describe('getHistory', () => {\n    it('should return version history in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    it('should have unique version ids', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n\n    it('should have timestamps', () => {\n      store.create('doc1', { v: 1 });\n      const history = store.getHistory('doc1');\n      expect(typeof history[0].timestamp).toBe('number');\n    });\n\n    it('should throw if document does not exist', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should deep clone version content', () => {\n      store.create('doc1', { nested: { value: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).nested.value = 999;\n      expect(store.getHistory('doc1')[0].content).toEqual({ nested: { value: 1 } });\n    });\n  });\n\n  describe('getVersion', () => {\n    it('should return content at a specific version', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });\n    });\n\n    it('should throw if document does not exist', () => {\n      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();\n    });\n\n    it('should throw if version does not exist', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'bad-version-id')).toThrow();\n    });\n  });\n\n  // ── Branching ──\n\n  describe('branching', () => {\n    it('should default to main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should create and switch branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should list branches', () => {\n      store.createBranch('feature');\n      store.createBranch('hotfix');\n      expect(store.listBranches()).toContain('main');\n      expect(store.listBranches()).toContain('feature');\n      expect(store.listBranches()).toContain('hotfix');\n    });\n\n    it('should throw when creating duplicate branch', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to nonexistent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n\n      store.update('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should inherit documents from parent branch at creation time', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should not reflect later parent changes in child branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob' });\n\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should create branch from a specified branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Feature-Alice' });\n\n      store.switchBranch('main');\n      store.createBranch('from-feature', 'feature');\n      store.switchBranch('from-feature');\n      expect(store.get('doc1')).toEqual({ name: 'Feature-Alice' });\n    });\n\n    it('should throw when creating branch from nonexistent source', () => {\n      expect(() => store.createBranch('new', 'nonexistent')).toThrow();\n    });\n  });\n\n  // ── Merging ──\n\n  describe('merge', () => {\n    it('should merge changes from source branch when only source changed', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n\n      store.update('doc1', { name: 'Alice', age: 31 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ name: 'Alice', age: 31 });\n      expect(store.get('doc1')).toEqual({ name: 'Alice', age: 31 });\n    });\n\n    it('should handle merge when only target changed (no-op for source)', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n\n      // Change on main (target)\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      // Nothing from source changed, so merged should be empty or reflect no changes\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n    });\n\n    it('should merge non-conflicting changes from both branches', () => {\n      store.create('doc1', { name: 'Alice', age: 30, city: 'NYC' });\n      store.createBranch('feature');\n\n      // Change on main\n      store.update('doc1', { name: 'Bob', age: 30, city: 'NYC' });\n\n      // Change on feature\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice', age: 31, city: 'NYC' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ name: 'Bob', age: 31, city: 'NYC' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 31, city: 'NYC' });\n    });\n\n    it('should detect conflicts when both branches change the same field differently', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob', age: 30 });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Charlie', age: 30 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].documentId).toBe('doc1');\n      expect(result.conflicts[0].path).toBe('name');\n      expect(result.conflicts[0].base).toBe('Alice');\n      expect(result.conflicts[0].ours).toBe('Bob');\n      expect(result.conflicts[0].theirs).toBe('Charlie');\n\n      // Merged should still contain a result (ours wins for preview)\n      expect(result.merged['doc1']).toEqual({ name: 'Bob', age: 30 });\n\n      // Current branch should remain unchanged\n      expect(store.get('doc1')).toEqual({ name: 'Bob', age: 30 });\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Charlie' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      // The main branch doc should still be 'Bob'\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should handle no conflict when both sides change to same value', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'Bob' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('should merge new documents created on source branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'Alice' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ name: 'Alice' });\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should handle independent document changes on different branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.create('doc2', { name: 'Bob' });\n      store.createBranch('feature');\n\n      // Change doc1 on main\n      store.update('doc1', { name: 'Alice-main' });\n\n      // Change doc2 on feature\n      store.switchBranch('feature');\n      store.update('doc2', { name: 'Bob-feature' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ name: 'Alice-main' });\n      expect(store.get('doc2')).toEqual({ name: 'Bob-feature' });\n    });\n\n    it('should handle deeply nested field merges', () => {\n      store.create('doc1', { a: { b: { c: 1, d: 2 } } });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: { b: { c: 10, d: 2 } } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 1, d: 20 } } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: { b: { c: 10, d: 20 } } });\n      expect(store.get('doc1')).toEqual({ a: { b: { c: 10, d: 20 } } });\n    });\n\n    it('should handle deeply nested field conflicts', () => {\n      store.create('doc1', { a: { b: { c: 1 } } });\n      store.createBranch('feature');\n\n      store.update('doc1', { a: { b: { c: 2 } } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 3 } } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('a.b.c');\n      expect(result.conflicts[0].base).toBe(1);\n      expect(result.conflicts[0].ours).toBe(2);\n      expect(result.conflicts[0].theirs).toBe(3);\n    });\n\n    it('should throw when merging nonexistent branch', () => {\n      expect(() => store.merge('nonexistent')).toThrow();\n    });\n\n    it('should handle merge with no changes (no-op)', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(Object.keys(result.merged)).toHaveLength(0);\n    });\n\n    it('should add new fields from source branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice', email: 'alice@example.com' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'Alice', email: 'alice@example.com' });\n    });\n\n    it('should handle merge when a document is deleted on source branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      // Source deleted, target didn't change - delete should apply\n      expect(result.applied).toBe(true);\n    });\n\n    it('should create version entries on successful merge', () => {\n      store.create('doc1', { name: 'Alice', age: 30 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Alice', age: 31 });\n\n      store.switchBranch('main');\n      const historyBefore = store.getHistory('doc1');\n\n      store.merge('feature');\n\n      const historyAfter = store.getHistory('doc1');\n      expect(historyAfter.length).toBeGreaterThan(historyBefore.length);\n    });\n\n    it('should handle arrays as leaf values in merge', () => {\n      store.create('doc1', { tags: ['a', 'b'], name: 'test' });\n      store.createBranch('feature');\n\n      store.update('doc1', { tags: ['a', 'b'], name: 'updated' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { tags: ['a', 'b', 'c'], name: 'test' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ tags: ['a', 'b', 'c'], name: 'updated' });\n    });\n\n    it('should conflict on arrays changed differently by both sides', () => {\n      store.create('doc1', { tags: ['a', 'b'] });\n      store.createBranch('feature');\n\n      store.update('doc1', { tags: ['a', 'c'] });\n\n      store.switchBranch('feature');\n      store.update('doc1', { tags: ['a', 'd'] });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts.length).toBeGreaterThanOrEqual(1);\n      expect(result.conflicts[0].path).toBe('tags');\n    });\n  });\n\n  // ── Edge cases ──\n\n  describe('edge cases', () => {\n    it('should allow re-creating a document after deletion on same branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.delete('doc1');\n      store.create('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n    });\n\n    it('should handle multiple documents independently', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.create('doc2', { name: 'Bob' });\n\n      store.update('doc1', { name: 'Alice-updated' });\n\n      expect(store.get('doc1')).toEqual({ name: 'Alice-updated' });\n      expect(store.get('doc2')).toEqual({ name: 'Bob' });\n    });\n\n    it('should handle empty objects', () => {\n      store.create('doc1', {});\n      expect(store.get('doc1')).toEqual({});\n    });\n  });\n});\n","structuredPatch":[{"oldStart":128,"oldLines":7,"newStart":128,"newLines":7,"lines":["     it('should deep clone version content', () => {","       store.create('doc1', { nested: { value: 1 } });","       const history = store.getHistory('doc1');","-      (history[0].content as any).nested.value = 999;","+      (history[0].content as Record<string, Record<string, number>>).nested.value = 999;","       expect(store.getHistory('doc1')[0].content).toEqual({ nested: { value: 1 } });","     });","   });"]}],"userModified":false,"replaceAll":false}}
