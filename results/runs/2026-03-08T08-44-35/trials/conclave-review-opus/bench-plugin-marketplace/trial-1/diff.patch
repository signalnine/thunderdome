s[0].name).toBe('b');\n    46→      expect(tree.dependencies[0].dependencies).toHaveLength(1);\n    47→      expect(tree.dependencies[0].dependencies[0].name).toBe('c');\n    48→    });\n    49→\n    50→    it('should handle unknown plugins gracefully', () => {\n    51→      const tree = deps.buildTree('nonexistent', registry);\n    52→      expect(tree.name).toBe('nonexistent');\n    53→      expect(tree.version).toBe('unknown');\n    54→    });\n    55→  });\n    56→\n    57→  describe('detectCycles', () => {\n    58→    it('should return null when no cycles exist', () => {\n    59→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n    60→      registry.register(makeManifest({ name: 'b' }));\n    61→      expect(deps.detectCycles('a', registry)).toBeNull();\n    62→    });\n    63→\n    64→    it('should detect a simple cycle', () => {\n    65→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n    66→      registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));\n    67→\n    68→      const cycles = deps.detectCycles('a', registry);\n    69→      expect(cycles).not.toBeNull();\n    70→      expect(cycles!.length).toBeGreaterThan(0);\n    71→    });\n    72→\n    73→    it('should detect a longer cycle', () => {\n    74→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n    75→      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));\n    76→      registry.register(makeManifest({ name: 'c', dependencies: { a: '^1.0.0' } }));\n    77→\n    78→      const cycles = deps.detectCycles('a', registry);\n    79→      expect(cycles).not.toBeNull();\n    80→    });\n    81→  });\n    82→\n    83→  describe('topologicalSort', () => {\n    84→    it('should return correct order for linear dependencies', () => {\n    85→      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n    86→      registry.