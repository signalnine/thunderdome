+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018397cveSoSNz1ioev3TfBY","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { createRegistry } from '../src/registry/index.js';\n     3→import type { PluginManifest, RegistryService } from '../src/types.js';\n     4→\n     5→function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {\n     6→  return {\n     7→    name: 'test-plugin',\n     8→    version: '1.0.0',\n     9→    description: 'A test plugin',\n    10→    author: 'tester',\n    11→    dependencies: {},\n    12→    entryPoint: 'console.log(\"hello\")',\n    13→    permissions: ['read'],\n    14→    ...overrides,\n    15→  };\n    16→}\n    17→\n    18→describe('Registry', () => {\n    19→  let registry: RegistryService;\n    20→\n    21→  beforeEach(() => {\n    22→    registry = createRegistry();\n    23→  });\n    24→\n    25→  it('should register and retrieve a plugin', () => {\n    26→    const manifest = makeManifest();\n    27→    registry.register(manifest);\n    28→    const result = registry.get('test-plugin');\n    29→    expect(result).toEqual(manifest);\n    30→  });\n    31→\n    32→  it('should return null for non-existent plugin', () => {\n    33→    expect(registry.get('nonexistent')).toBeNull();\n    34→  });\n    35→\n    36→  it('should get a specific version', () => {\n    37→    const v1 = makeManifest({ version: '1.0.0' });\n    38→    const v2 = makeManifest({ version: '2.0.0' });\n    39→    registry.register(v1);\n    40→    registry.register(v2);\n    41→    expect(registry.getVersion('test-plugin', '1.0.0')).toEqual(v1);\n    42→    expect(registry.getVersion('test-plugin', '2.0.0')).toEqual(v2);\n    43→  });\n    44→\n    45→  it('should return null for non-existent version', () => {\n    46→    registry.register(makeManifest());\n    47→    expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();\n    48→  });\n    49→\n    50→  it('should list all plugins', () => {\n    51→    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    52→    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    53→    const all = registry.list();\n    54→    expect(all).toHaveLength(2);\n    55→  });\n    56→\n    57→  it('should search plugins by name, description, or author', () => {\n    58→    registry.register(makeManifest({ name: 'auth-plugin', description: 'handles auth' }));\n    59→    registry.register(makeManifest({ name: 'data-plugin', description: 'handles data' }));\n    60→\n    61→    expect(registry.search('auth')).toHaveLength(1);\n    62→    expect(registry.search('data')).toHaveLength(1);\n    63→    expect(registry.search('handles')).toHaveLength(2);\n    64→    expect(registry.search('nonexistent')).toHaveLength(0);\n    65→  });\n    66→\n    67→  it('should remove a plugin version', () => {\n    68→    registry.register(makeManifest());\n    69→    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    70→    expect(registry.get('test-plugin')).toBeNull();\n    71→  });\n    72→\n    73→  it('should return false when removing non-existent plugin', () => {\n    74→    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n    75→  });\n    76→\n    77→  it('should list versions of a plugin', () => {\n    78→    registry.register(makeManifest({ version: '1.0.0' }));\n    79→    registry.register(makeManifest({ version: '1.1.0' }));\n    80→    registry.register(makeManifest({ version: '2.0.0' }));\n    81→    const versions = registry.listVersions('test-plugin');\n    82→    expect(versions).toEqual(['1.0.0', '1.1.0', '2.0.0']);\n    83→  });\n    84→\n    85→  it('should return empty array for non-existent plugin versions', () => {\n    86→    expect(registry.listVersions('nonexistent')).toEqual([]);\n    87→  });\n    88→\n    89→  it('should update a plugin', () => {\n    90→    registry.register(makeManifest());\n    91→    registry.update('test-plugin', '1.0.0', { description: 'updated description' });\n    92→    const result = registry.getVersion('test-plugin', '1.0.0');\n    93→    expect(result?.description).toBe('updated description');\n    94→  });\n    95→\n    96→  it('should throw when updating non-existent plugin', () => {\n    97→    expect(() => registry.update('nonexistent', '1.0.0', { description: 'nope' })).toThrow();\n    98→  });\n    99→\n   100→  it('should handle multiple versions, get returns latest', () => {\n   101→    registry.register(makeManifest({ version: '1.0.0' }));\n   102→    registry.register(makeManifest({ version: '2.0.0' }));\n   103→    const result = registry.get('test-plugin');\n   104→    expect(result?.version).toBe('2.0.0');\n   105→  });\n   106→\n   107→  it('should replace a plugin on re-register with same name+version', () => {\n   108→    registry.register(makeManifest({ description: 'original' }));\n   109→    registry.register(makeManifest({ description: 'replaced' }));\n   110→    const result = registry.get('test-plugin');\n   111→    expect(result?.description).toBe('replaced');\n   112→  });\n   113→});\n   114→"}]},"parent_tool_use_id":"toolu_01T4rxmNU31Fknt84JN4VCRo","session_id":"411164de-840c-4db5-98e0-ca2a09a58f24","uuid":"628a2549-be1f-4ecf-a9b9-f5a509dd5265"}
