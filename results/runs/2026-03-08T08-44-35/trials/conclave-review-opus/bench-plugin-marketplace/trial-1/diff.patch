ROM reviews WHERE pluginName = ?\n    52→  `);\n    53→\n    54→  function rowToReview(row: Record<string, unknown>): Review {\n    55→    return {\n    56→      id: row.id as number,\n    57→      pluginName: row.pluginName as string,\n    58→      pluginVersion: row.pluginVersion as string,\n    59→      userId: row.userId as string,\n    60→      rating: row.rating as number,\n    61→      comment: row.comment as string,\n    62→      flagged: (row.flagged as number) === 1,\n    63→      createdAt: row.createdAt as string,\n    64→    };\n    65→  }\n    66→\n    67→  return {\n    68→    addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {\n    69→      const createdAt = new Date().toISOString();\n    70→      const result = insertStmt.run(\n    71→        review.pluginName,\n    72→        review.pluginVersion,\n    73→        review.userId,\n    74→        review.rating,\n    75→        review.comment,\n    76→        createdAt,\n    77→      );\n    78→      return {\n    79→        ...review,\n    80→        id: Number(result.lastInsertRowid),\n    81→        flagged: false,\n    82→        createdAt,\n    83→      };\n    84→    },\n    85→\n    86→    getReviews(pluginName: string): Review[] {\n    87→      const rows = getByPluginStmt.all(pluginName) as Record<string, unknown>[];\n    88→      return rows.map(rowToReview);\n    89→    },\n    90→\n    91→    getAverageRating(pluginName: string): number {\n    92→      const row = avgRatingStmt.get(pluginName) as { avg: number | null };\n    93→      return row.avg ?? 0;\n    94→    },\n    95→\n    96→    flagReview(reviewId: number): void {\n    97→      flagStmt.run(reviewId);\n    98→    },\n    99→\n   100→    getFlaggedReviews(): Review[] {\n   101→      const rows = flaggedStmt.all() as Record<string, unknown>[];\n   102→      return rows.map(rowToReview);\n   103→    },\n   104→\n   105→    removeReview(reviewId: number): boolean {\n   106→      const result = removeStmt.run(re