+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DZovEcKvn5YXa8znpZhqyL","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createResolver } from '../src/resolver/index.js';\n     3→\n     4→describe('Resolver', () => {\n     5→  const resolver = createResolver();\n     6→\n     7→  describe('resolve', () => {\n     8→    it('should resolve simple constraints', () => {\n     9→      const result = resolver.resolve(\n    10→        [{ name: 'foo', range: '^1.0.0' }],\n    11→        { foo: ['1.0.0', '1.1.0', '1.2.0', '2.0.0'] },\n    12→      );\n    13→      expect(result).toHaveLength(1);\n    14→      expect(result[0].name).toBe('foo');\n    15→      expect(result[0].version).toBe('1.2.0');\n    16→      expect(result[0].satisfies).toBe('^1.0.0');\n    17→    });\n    18→\n    19→    it('should resolve multiple constraints', () => {\n    20→      const result = resolver.resolve(\n    21→        [\n    22→          { name: 'foo', range: '^1.0.0' },\n    23→          { name: 'bar', range: '~2.1.0' },\n    24→        ],\n    25→        {\n    26→          foo: ['1.0.0', '1.5.0', '2.0.0'],\n    27→          bar: ['2.0.0', '2.1.0', '2.1.5', '2.2.0'],\n    28→        },\n    29→      );\n    30→      expect(result).toHaveLength(2);\n    31→      expect(result[0].version).toBe('1.5.0');\n    32→      expect(result[1].version).toBe('2.1.5');\n    33→    });\n    34→\n    35→    it('should throw if no versions available', () => {\n    36→      expect(() => resolver.resolve(\n    37→        [{ name: 'missing', range: '^1.0.0' }],\n    38→        {},\n    39→      )).toThrow('No versions available');\n    40→    });\n    41→\n    42→    it('should throw if no version satisfies the range', () => {\n    43→      expect(() => resolver.resolve(\n    44→        [{ name: 'foo', range: '^3.0.0' }],\n    45→        { foo: ['1.0.0', '2.0.0'] },\n    46→      )).toThrow('No version of \"foo\" satisfies rang