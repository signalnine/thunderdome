new file mode 100644
index 0000000..e9231e2
--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,131 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTreeInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+  ): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    if (visited.has(name)) {
+      return node;
+    }
+    visited.add(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      node.dependencies.push(buildTreeInternal(depName, registry, new Set(visited)));
+    }
+
+    return node;
+  }
+
+  function detectCyclesInternal(
+    name: string,
+    registry: RegistryService,
+    path: string[],
+    allCycles: string[][],
+    visited: Set<string>,
+  ): void {
+    const idx = path.indexOf(name);
+    if (idx !== -1) {
+      allCycles.push(path.slice(idx).concat(name));
+      return;
+    }
+
+    if (visited.has(name)) {
+      return;
+    }
+
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    path.push(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      detectCyclesInternal(depName, registry, [...path], allCycles, visited);
+    }
+
+    visited.add(name);
+  }
+
+  function topoSortInternal(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    result: string[],
+    visiting: Set<string>,
+  ): void {
+    if (visited.has(name)) return;
+    if (visiting.has(name)) return; // cycle - skip
+
+    visiting.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        topoSortInternal(depName, registry, visited, result, visiting);
+      }
+    }
+
+    visiting.delete(name);
+    visited.add(name);
+    result.push(name);
+  }
+
+  function flattenInternal(
+    name: string,
+    registry: RegistryService,
+    collected: Set<string>,
+  ): void {
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      if (!collected.has(depName)) {
+        collected.add(depName);
+        flattenInternal(depName, registry, collected);
+      }
+    }
+  }
+
+  return {
+    buildTree(name: string, registry: RegistryService): DependencyNode {
+      return buildTreeInternal(name, registry, new Set());
+    },
+
+    detectCycles(name: string, registry: RegistryService): string[][] | null {
+      const cycles: string[][] = [];
+      detectCyclesInternal(name, registry, [], cycles, new Set());
+      return cycles.length > 0 ? cycles : null;
+    },
+
+    topologicalSort(name: string, registry: RegistryService): string[] {
+      const visited = new Set<string>();
+      const result: string[] = [];
+      const visiting = new Set<string>();
+      topoSortInternal(name, registry, visited, result, visiting);
+      return result;
+    },
+
+    flattenDependencies(name: string, registry: RegistryService): string[] {
+      const collected = new Set<string>();
+      flattenInternal(name, registry, collected);
+      return Array.from(collected);
+    },
+
+    hasCircularDependency(name: string, registry: RegistryService): boolean {
+      const cycles = this.detectCycles(name, registry);
+      return cycles !== null;
+    },
+  };
+}
