+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QA6ArkFyY8Tpuow1ee99sv","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import type { PluginManifest, RegistryService } from '../types.js';\n     3→\n     4→export function createRegistry(dbPath = ':memory:'): RegistryService {\n     5→  const db = new Database(dbPath);\n     6→  db.pragma('journal_mode = WAL');\n     7→\n     8→  db.exec(`\n     9→    CREATE TABLE IF NOT EXISTS plugins (\n    10→      name TEXT NOT NULL,\n    11→      version TEXT NOT NULL,\n    12→      description TEXT NOT NULL,\n    13→      author TEXT NOT NULL,\n    14→      dependencies TEXT NOT NULL,\n    15→      entryPoint TEXT NOT NULL,\n    16→      permissions TEXT NOT NULL,\n    17→      PRIMARY KEY (name, version)\n    18→    )\n    19→  `);\n    20→\n    21→  const insertStmt = db.prepare(`\n    22→    INSERT OR REPLACE INTO plugins (name, version, description, author, dependencies, entryPoint, permissions)\n    23→    VALUES (?, ?, ?, ?, ?, ?, ?)\n    24→  `);\n    25→\n    26→  const getStmt = db.prepare(`\n    27→    SELECT * FROM plugins WHERE name = ? ORDER BY version DESC LIMIT 1\n    28→  `);\n    29→\n    30→  const getVersionStmt = db.prepare(`\n    31→    SELECT * FROM plugins WHERE name = ? AND version = ?\n    32→  `);\n    33→\n    34→  const listStmt = db.prepare(`SELECT * FROM plugins`);\n    35→\n    36→  const searchStmt = db.prepare(`\n    37→    SELECT * FROM plugins WHERE name LIKE ? OR description LIKE ? OR author LIKE ?\n    38→  `);\n    39→\n    40→  const removeStmt = db.prepare(`\n    41→    DELETE FROM plugins WHERE name = ? AND version = ?\n    42→  `);\n    43→\n    44→  const listVersionsStmt = db.prepare(`\n    45→    SELECT version FROM plugins WHERE name = ? ORDER BY version\n    46→  `);\n    47→\n    48→  const updateStmt = db.prepare(`\n    49→    UPDATE plugins SET description = ?, author = ?, dependencies = ?, entryPoint = ?, permissions = ?\n    50→    WHERE name = ? AND version = ?\n    51→  `);\n    52→\n    53→  function rowToManifest(row: Record<string, unknown>): PluginManifest {\n    54→    return {\n    55→      name: row.name as string,\n    56→      version: row.version as string,\n    57→      description: row.description as string,\n    58→      author: row.author as string,\n    59→      dependencies: JSON.parse(row.dependencies as string) as Record<string, string>,\n    60→      entryPoint: row.entryPoint as string,\n    61→      permissions: JSON.parse(row.permissions as string) as string[],\n    62→    };\n    63→  }\n    64→\n    65→  return {\n    66→    register(manifest: PluginManifest): void {\n    67→      insertStmt.run(\n    68→        manifest.name,\n    69→        manifest.version,\n    70→        manifest.description,\n    71→        manifest.author,\n    72→        JSON.stringify(manifest.dependencies),\n    73→        manifest.entryPoint,\n    74→        JSON.stringify(manifest.permissions),\n    75→      );\n    76→    },\n    77→\n    78→    get(name: string): PluginManifest | null {\n    79→      const row = getStmt.get(name) as Record<string, unknown> | undefined;\n    80→      return row ? rowToManifest(row) : null;\n    81→    },\n    82→\n    83→    getVersion(name: string, version: string): PluginManifest | null {\n    84→      const row = getVersionStmt.get(name, version) as Record<string, unknown> | undefined;\n    85→      return row ? rowToManifest(row) : null;\n    86→    },\n    87→\n    88→    list(): PluginManifest[] {\n    89→      const rows = listStmt.all() as Record<string, unknown>[];\n    90→      return rows.map(rowToManifest);\n    91→    },\n    92→\n    93→    search(query: string): PluginManifest[] {\n    94→      const pattern = `%${query}%`;\n    95→      const rows = searchStmt.all(pattern, pattern, pattern) as Record<string, unknown>[];\n    96→      return rows.map(rowToManifest);\n    97→    },\n    98→\n    99→    remove(name: string, version: string): boolean {\n   100→      const result = removeStmt.run(name, version);\n   101→      return result.changes > 0;\n   102→    },\n   103→\n   104→    listVersions(name: string): string[] {\n   105→      const rows = listVersionsStmt.all(name) as Array<{ version: string }>;\n   106→      return rows.map((r) => r.version);\n   107→    },\n   108→\n   109→    update(name: string, version: string, updates: Partial<PluginManifest>): void {\n   110→      const existing = getVersionStmt.get(name, version) as Record<string, unknown> | undefined;\n   111→      if (!existing) {\n   112→        throw new Error(`Plugin ${name}@${version} not found`);\n   113→      }\n   114→      const current = rowToManifest(existing);\n   115→      const merged = { ...current, ...updates };\n   116→      updateStmt.run(\n   117→        merged.description,\n   118→        merged.author,\n   119→        JSON.stringify(merged.dependencies),\n   120→        merged.entryPoint,\n   121→        JSON.stringify(merged.permissions),\n   122→        name,\n   123→        version,\n   124→      );\n   125→    },\n   126→  };\n   127→}\n   128→"}]},"parent_tool_use_id":"toolu_01T4rxmNU31Fknt84JN4VCRo","session_id":"411164de-840c-4db5-98e0-ca2a09a58f24","uuid":"4fba5285-23c8-4937-84a3-0d15bd82527b"}
