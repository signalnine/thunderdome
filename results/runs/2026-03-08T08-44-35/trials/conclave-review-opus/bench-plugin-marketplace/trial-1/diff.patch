@@ -0,0 +1,71 @@
+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+export function createRunner(): RunnerService {
+  async function runInSandbox(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {},
+  ): Promise<SandboxResult> {
+    const startMem = process.memoryUsage().heapUsed;
+    const startTime = performance.now();
+
+    try {
+      const sandbox: Record<string, unknown> = {
+        ...context,
+        __output: undefined,
+        console: {
+          log: (...args: unknown[]) => {
+            sandbox.__logs = ((sandbox.__logs as string[] | undefined) || []).concat(
+              args.map(String).join(' '),
+            );
+          },
+        },
+      };
+
+      vm.createContext(sandbox);
+
+      const script = new vm.Script(code);
+      const result = script.runInContext(sandbox, { timeout: timeoutMs });
+
+      const duration = performance.now() - startTime;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMem);
+
+      return {
+        success: true,
+        output: result,
+        duration,
+        memoryUsed,
+      };
+    } catch (err: unknown) {
+      const duration = performance.now() - startTime;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMem);
+      const errorObj = err as Record<string, unknown>;
+      const errorMessage = (typeof errorObj === 'object' && errorObj !== null && typeof errorObj.message === 'string')
+        ? errorObj.message
+        : String(err);
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed,
+        error: errorMessage,
+      };
+    }
+  }
+
+  return {
+    async execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+      return runInSandbox(code, 5000, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>,
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, timeoutMs, context);
+    },
+  };
+}
