+    // Place splitters at those exact positions to create true exponential splitting.
+    const numLevels = 50;
+    for (let i = 0; i < numLevels; i++) {
+      const row = 1 + i;
+      if (row >= rows) break;
+      for (let c = 100 - i; c <= 100 + i; c += 2) {
+        if (c >= 0 && c < cols) {
+          grid[row][c] = '^';
+        }
+      }
+    }
+
+    const start = Date.now();
+    const result = countBeamPaths(grid);
+    const elapsed = Date.now() - start;
+
