+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from '../src/index.js';
+
+describe('countBeamCells', () => {
+  it('returns 0 for empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('returns 0 for grid with no source', () => {
+    expect(countBeamCells([
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ])).toBe(0);
+  });
+
+  it('beam goes straight down with no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example 2: two splitters', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('beam absorbed at left boundary', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['.', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // S at (0,0), down to (1,0), (2,0) hits splitter
+    // down-left (3,-1) absorbed, down-right (3,1)
+    // visited: (0,0), (1,0), (2,0), (3,1) = 4
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  it('beam absorbed at right boundary', () => {
+    const grid = [
+      ['.', '.', 'S'],
+      ['.', '.', '.'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // S at (0,2), down to (1,2), (2,2) hits splitter
+    // down-left (3,1), down-right (3,3) absorbed
+    // visited: (0,2), (1,2), (2,2), (3,1) = 4
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  it('source on last row', () => {
+    const grid = [
+      ['.', 'S', '.'],
+    ];
+    // Source is visited, beam tries to go down but exits
+    expect(countBeamCells(grid)).toBe(1);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('returns 0n for empty grid', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('returns 1n for straight beam no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('example 1: single splitter gives 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example 2: two splitters gives 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('source on last row gives 1 path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+    ];
+    // Beam exits immediately downward
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('chain of splitters doubles each time', () => {
+    // 3 splitters in a line, each on the path
+    const grid = [
+      ['.', '.', '.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '.'],
+      ['.', '^', '.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.', '.', '.'],
+    ];
+    // S at (0,3), hits (1,3) splitter -> 2 beams
+    // down-left to (2,2) hits splitter -> 2 beams
+    // down-right to (2,4) hits splitter -> 2 beams
+    // From (2,2): down-left (3,1) hits splitter, down-right (3,3)
+    // From (2,4): down-left (3,3), down-right (3,5) hits splitter
+    // From (3,1) splitter: (4,0) and (4,2)
+    // From (3,5) splitter: (4,4) and (4,6)
+    // Paths: (4,0), (4,2), (4,3) x2, (4,4), (4,6) = 6
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+
+  it('beam absorbed at boundary counts as path', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['.', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // S at (0,0), down to (1,0), (2,0) hits splitter
+    // down-left (3,-1) absorbed (counts as path), down-right (3,1) exits bottom
+    // 2 paths total
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('handles large grid with cascading splitters efficiently', () => {
+    const rows = 200;
+    const cols = 200;
