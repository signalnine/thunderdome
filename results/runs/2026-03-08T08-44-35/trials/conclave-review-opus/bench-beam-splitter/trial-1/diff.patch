+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  if (cols === 0) return 0;
+
+  const src = findSource(grid);
+  if (!src) return 0;
+
+  const visited = new Set<number>();
+  const seen = new Set<number>();
+
+  const encodeVisited = (r: number, c: number) => r * cols + c;
+  const encodeSeen = (r: number, c: number, d: number) => (r * cols + c) * 3 + d;
+  const dirIndex = (d: Direction) => d === 'down' ? 0 : d === 'down-left' ? 1 : 2;
+
+  // Process row by row using two arrays
+  let current: Beam[] = [{ row: src[0], col: src[1], dir: 'down' }];
+  visited.add(encodeVisited(src[0], src[1]));
+  seen.add(encodeSeen(src[0], src[1], 0));
+
+  while (current.length > 0) {
+    const next: Beam[] = [];
+
+    for (const { row, col, dir } of current) {
+      const cell = grid[row][col];
+
+      if (cell === '^') {
+        const dirs: Direction[] = ['down-left', 'down-right'];
+        for (const newDir of dirs) {
+          const [nr, nc] = nextPos(row, col, newDir);
+          if (inBounds(nr, nc, rows, cols)) {
+            const key = encodeSeen(nr, nc, dirIndex(newDir));
+            if (!seen.has(key)) {
+              seen.add(key);
+              visited.add(encodeVisited(nr, nc));
+              next.push({ row: nr, col: nc, dir: newDir });
+            }
+          }
+        }
+      } else {
+        const [nr, nc] = nextPos(row, col, dir);
+        if (inBounds(nr, nc, rows, cols)) {
+          const key = encodeSeen(nr, nc, dirIndex(dir));
+          if (!seen.has(key)) {
+            seen.add(key);
+            visited.add(encodeVisited(nr, nc));
+            next.push({ row: nr, col: nc, dir: dir });
+          }
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  if (cols === 0) return 0n;
+
+  const src = findSource(grid);
+  if (!src) return 0n;
+
+  // State: (col, direction) -> path count
+  // Process row by row. All beams move down one row each step.
+  type StateKey = number; // col * 3 + dirIndex
+  const dirIdx = (d: Direction) => d === 'down' ? 0 : d === 'down-left' ? 1 : 2;
+  const encode = (c: number, di: number) => c * 3 + di;
+
+  let currentRow = new Map<StateKey, bigint>();
+  currentRow.set(encode(src[1], 0), 1n);
+
+  let totalPaths = 0n;
+
+  for (let r = src[0]; r < rows; r++) {
+    const nextRow = new Map<StateKey, bigint>();
+
+    for (const [stateKey, count] of currentRow) {
+      const col = (stateKey / 3) | 0;
+      const di = stateKey % 3;
+      const dir: Direction = di === 0 ? 'down' : di === 1 ? 'down-left' : 'down-right';
+      const cell = grid[r][col];
+
+      if (cell === '^') {
+        const dirs: Direction[] = ['down-left', 'down-right'];
+        for (const newDir of dirs) {
+          const [nr, nc] = nextPos(r, col, newDir);
+          if (inBounds(nr, nc, rows, cols)) {
+            const nkey = encode(nc, dirIdx(newDir));
+            nextRow.set(nkey, (nextRow.get(nkey) ?? 0n) + count);
+          } else {
+            totalPaths += count;
+          }
+        }
+      } else {
+        const [nr, nc] = nextPos(r, col, dir);
+        if (inBounds(nr, nc, rows, cols)) {
+          const nkey = encode(nc, dirIdx(dir));
+          nextRow.set(nkey, (nextRow.get(nkey) ?? 0n) + count);
+        } else {
+          totalPaths += count;
+        }
+      }
+    }
+
+    currentRow = nextRow;
+  }
+
+  return totalPaths;
+}
