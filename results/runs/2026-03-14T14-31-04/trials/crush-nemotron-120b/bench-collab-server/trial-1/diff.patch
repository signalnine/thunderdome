+import { createApp } from './src/server';
+import request from 'supertest';
+import { WebSocket } from 'ws';
+
+describe('WebSocket Debug Test', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+  let wsServerUrl: string;
+
+  beforeAll(async () => {
+    // Create app with in-memory database for testing
+    appInstance = createApp({ dbFile: ':memory:' });
+    port = await appInstance.start();
+    wsServerUrl = `ws://localhost:${port}`;
+    console.log(`WebSocket server URL: ${wsServerUrl}`);
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  test('should create a document and attempt WebSocket connection', async () => {
+    // Create a document
+    const createRes = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'WS Test Doc', content: 'Initial' })
+      .expect(201);
+
+    const docId = createRes.body.id;
+    console.log(`Created document with ID: ${docId}`);
+
+    // Attempt WebSocket connection
+    const wsUrl = `${wsServerUrl}/ws/${docId}`;
+    console.log(`Connecting to: ${wsUrl}`);
+
+    return new Promise<void>((resolve, reject) => {
+      const ws = new WebSocket(wsUrl);
+      
+      ws.on('open', () => {
+        console.log('WebSocket connected');
+        ws.close();
+        resolve();
+      });
+      
+      ws.on('error', (error) => {
+        console.log('WebSocket error:', error);
+        reject(error);
+      });
+      
+      ws.on('close', (code, reason) => {
+        console.log(`WebSocket closed with code ${code}: ${reason}`);
+      });
+    });
+  });
+});
