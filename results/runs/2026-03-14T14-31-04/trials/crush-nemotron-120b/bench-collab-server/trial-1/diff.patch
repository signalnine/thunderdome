+import express, { Express } from 'express';
+import { Server as HttpServer } from 'http';
+import { WebSocketServer, WebSocket } from 'ws';
+import Database from 'better-sqlite3';
+
+export interface CreateAppOptions {
+  dbFile?: string;
+}
+
+export interface App {
+  app: Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(options: CreateAppOptions = {}): App {
+  const app = express();
+  app.use(express.json());
+
+  const dbFile = options.dbFile || ':memory:';
+  const db = new Database(dbFile);
+
+  // Initialize database schema
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+  
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      operation TEXT,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      UNIQUE(document_id, version)
+    );
+  
+    CREATE TABLE IF NOT EXISTS active_connections (
+      id TEXT PRIMARY KEY,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+  `);
+
+  // Helper to generate simple unique ID
+  function generateId(): string {
+    return Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
+  }
+
+  // REST API for document management
+  app.get('/documents', async (req, res) => {
+    try {
+      const docs = db.prepare('SELECT id, title, created_at, updated_at FROM documents ORDER BY updated_at DESC').all();
+      res.json(docs);
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch documents' });
+    }
+  });
+
+  app.post('/documents', async (req, res) => {
+    console.log('POST /documents called!');
+    const { title = '', content = '' } = req.body;
+    console.log(`POST /documents received: title=${title}, content="${content}"`);
+    const id = generateId();
+    try {
+      db.prepare('INSERT INTO documents (id, title, content) VALUES (?, ?, ?)').run(id, title, content);
+      // Create initial version (version 0)
+      const version = 0;
+      db.prepare('INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)').run(id, version, content);
+      // Update in-memory document state
+      documentStates.set(id, { content, version: 0 });
+      console.log(`Created document ${id}, set in-memory state:`, documentStates.get(id));
+      res.status(201).json({ id, title, content, created_at: new Date().toISOString(), updated_at: new Date().toISOString() });
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to create document' });
+    }
+  });
+
+  app.get('/documents/:id', async (req, res) => {
+    const { id } = req.params;
+    try {
+      const doc = db.prepare('SELECT id, title, content, created_at, updated_at FROM documents WHERE id = ?').get(id);
+      if (!doc) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      res.json(doc);
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch document' });
+    }
+  });
+
+  app.put('/documents/:id', async (req, res) => {
+    const { id } = req.params;
+    const { title, content } = req.body;
+    try {
+      const result = db.prepare('UPDATE documents SET title = COALESCE(?, title), content = COALESCE(?, content), updated_at = datetime(\'now\') WHERE id = ?').run(title, content, id);
+      if (result.changes === 0) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      // Get current version and increment
+      const versionRow = db.prepare('SELECT MAX(version) as maxVersion FROM versions WHERE document_id = ?').get(id) as { maxVersion: number | null };
+      const newVersion = (versionRow.maxVersion || 0) + 1;
+      db.prepare('INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)').run(id, newVersion, content);
+      const updatedDoc = db.prepare('SELECT id, title, content, created_at, updated_at FROM documents WHERE id = ?').get(id);
+      res.json(updatedDoc);
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to update document' });
+    }
+  });
+
+  app.delete('/documents/:id', async (req, res) => {
+    const { id } = req.params;
+    try {
+      const result = db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+      if (result.changes === 0) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      res.status(204).send();
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to delete document' });
+    }
+  });
+
+  app.get('/documents/:id/versions', async (req, res) => {
+    const { id } = req.params;
+    try {
+      const versions = db.prepare('SELECT version, content, operation, created_at FROM versions WHERE document_id = ? ORDER BY version').all(id);
+      res.json(versions);
+    } catch (error) {
+      res.status(500).json({ error: 'Failed to fetch versions' });
+    }
+  });
+
+  // WebSocket server for real-time collaboration
+  const httpServer = new HttpServer(app);
+  const wss = new WebSocketServer({ server: httpServer });
+
+  // Store active connections per document
+  const documentConnections = new Map<string, Set<WebSocket>>(); // documentId -> set of websockets
+  // Store document state in memory for quick access: { content, version }
+  const documentStates = new Map<string, { content: string; version: number }>();
+
+  // Initialize document states from DB on startup
+  const initDocumentStates = () => {
+    const docs = db.prepare(`
+      SELECT d.id, d.content, COALESCE(MAX(v.version), 0) as version
+      FROM documents d
+      LEFT JOIN versions v ON d.id = v.document_id
+      GROUP BY d.id
+    `).all() as Array<{id: string; content: string; version: number}>;
+    docs.forEach((doc) => {
+      documentStates.set(doc.id, { content: doc.content, version: doc.version });
+    });
+  };
+  initDocumentStates();
+
+  // Simple text operation application
+  interface Operation {
+    type: 'insert' | 'delete';
+    position: number;
+    text?: string;
+    length?: number;
+  }
+
+  function applyOperation(content: string, operation: Operation): string {
+    if (operation.type === 'insert') {
+      return content.slice(0, operation.position) + (operation.text || '') + content.slice(operation.position);
+    } else if (operation.type === 'delete') {
+      return content.slice(0, operation.position) + content.slice(operation.position + (operation.length || 0));
+    }
+    return content;
+  }
+
+  /**
+   * Transform operation op1 against operation op2.
+   * Assumes op2 is applied first, and returns op1' such that
+   * applying op2 then op1' yields the same state as applying op1 then op2.
+   */
+  function transform(op1: Operation, op2: Operation): Operation {
+    if (op1.type === 'insert' && op2.type === 'insert') {
+      if (op1.position < op2.position) {
+        return op1;
+      } else if (op1.position > op2.position) {
+        return { type: 'insert', position: op1.position + (op2.text || '').length, text: op1.text || '' };
+      } else {
+        // Same position: shift op1 by the length of op2's text (so op1 goes after op2)
+        return { type: 'insert', position: op1.position + (op2.text || '').length, text: op1.text || '' };
+      }
+    } else if (op1.type === 'insert' && op2.type === 'delete') {
+      if (op1.position < op2.position) {
+        return op1;
+      } else if (op1.position >= op2.position && op1.position < op2.position + (op2.length || 0)) {
+        // Insert inside the deleted region: insert at the start of the deleted region
+        return { type: 'insert', position: op2.position, text: op1.text || '' };
+      } else {
+        // Insert after the deleted region
+        return { type: 'insert', position: op1.position - (op2.length || 0), text: op1.text || '' };
+      }
+    } else if (op1.type === 'delete' && op2.type === 'insert') {
+      if (op2.position < op1.position) {
+        return { type: 'delete', position: op1.position + (op2.text || '').length, length: op1.length || 0 };
+      } else {
+        // Insert at or after the start of the deletion: no change to deletion position
+        return { type: 'delete', position: op1.position, length: op1.length || 0 };
+      }
+    } else if (op1.type === 'delete' && op2.type === 'delete') {
+      // Assume no overlapping deletions for simplicity; if they overlap, we merge the deletions.
+      const op1End = op1.position + (op1.length || 0);
+      const op2End = op2.position + (op2.length || 0);
+      if (op1End <= op2.position) {
+        // op1 is completely before op2
+        return op1;
+      } else if (op2End <= op1.position) {
+        // op1 is completely after op2
+        return { type: 'delete', position: op1.position - (op2.length || 0), length: op1.length || 0 };
+      } else {
+        // They overlap: return a deletion covering the union
+        const start = Math.min(op1.position, op2.position);
+        const end = Math.max(op1End, op2End);
+        return { type: 'delete', position: start, length: end - start };
+      }
+    } else {
+      // Should not happen with valid operation types
+      return op1;
+    }
+  }
+
+  wss.on('connection', (ws, request) => {
+    console.log(`WebSocket connection request received: ${request.url}`);
+    const pathname = request.url ? new URL(request.url, `http://${request.headers.host}`).pathname : '';
+    console.log(`Pathname: ${pathname}`);
+    // Extract document ID from path like /ws/documentId
+    const match = pathname.match(/^\/ws\/(.+)$/);
+    if (!match) {
+      console.log(`Invalid WebSocket path: ${pathname}`);
+      ws.close(1008, 'Invalid WebSocket path. Use /ws/:documentId');
+      return;
+    }
+    const documentId = match[1];
+    console.log(`Document ID extracted: ${documentId}`);
+
+    // Check if document exists
+    const doc = db.prepare('SELECT id FROM documents WHERE id = ?').get(documentId);
+    if (!doc) {
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    // Add connection to document
+    if (!documentConnections.has(documentId)) {
+      documentConnections.set(documentId, new Set());
+    }
+    const connections = documentConnections.get(documentId)!;
+    connections.add(ws);
+
+    // Track this connection for cleanup
+    const connectionId = generateId();
+    db.prepare('INSERT INTO active_connections (id, document_id) VALUES (?, ?)').run(connectionId, documentId);
+
+    // Send current document state to the newly connected client
+    const state = documentStates.get(documentId);
+    console.log(`Sending init message to client for document ${documentId}:`, state);
+    if (state) {
+      ws.send(JSON.stringify({ type: 'init', content: state.content, version: state.version }));
+    }
+
+    ws.on('message', (message) => {
+      const msgStr = message.toString();
+      console.log(`Server received message: ${msgStr}`);
+      try {
+        const data = JSON.parse(msgStr);
+        console.log(`Parsed data:`, data);
+        if (data.type === 'operation') {
+          console.log(`Processing operation:`, data);
+          const { operation, baseVersion } = data;
+          // Get current document state
+          const state = documentStates.get(documentId);
+          if (!state) {
+            ws.send(JSON.stringify({ type: 'error', message: 'Document state not found' }));
+            return;
+          }
+
+          // Check if baseVersion is valid
+          if (baseVersion > state.version) {
+            ws.send(JSON.stringify({ type: 'error', message: 'Base version too new' }));
+            return;
+          }
+
+          // Fetch concurrent operations if any
+          let transformedOp: Operation = { ...operation };
+          if (baseVersion < state.version) {
+            const concurrentOps = db.prepare(`
+              SELECT operation FROM versions 
+              WHERE document_id = ? AND version > ? AND version <= ? 
+              ORDER BY version
+            `).all(documentId, baseVersion, state.version) as { operation: string }[];
+
+            for (const opRow of concurrentOps) {
+              const concurrentOp = JSON.parse(opRow.operation);
+              transformedOp = transform(transformedOp, concurrentOp);
+            }
+          }
+
+          // Apply operation to get new content
+          const newContent = applyOperation(state.content, transformedOp);
+          const newVersion = state.version + 1;
+
+          // Update document state
+          documentStates.set(documentId, { content: newContent, version: newVersion });
+
+          // Persist to DB
+          db.prepare("UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?").run(newContent, documentId);
+          db.prepare("INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)").run(documentId, newVersion, newContent, JSON.stringify(transformedOp));
+
+          // Broadcast to other connections
+          connections.forEach((client) => {
+            if (client !== ws && client.readyState === WebSocket.OPEN) {
+              client.send(JSON.stringify({ type: 'operation', operation: transformedOp, version: newVersion }));
+            }
+          });
+        }
+      } catch (error) {
+        console.log(`Error parsing message: ${error}`);
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid message format' }));
+      }
+    });
+
+    ws.on('close', () => {
+      connections.delete(ws);
+      db.prepare('DELETE FROM active_connections WHERE id = ?').run(connectionId);
+      if (connections.size === 0) {
+        documentConnections.delete(documentId);
+        // Optionally, we could clean up document state, but we'll keep it for future connections
+      }
+    });
+
+    ws.on('error', () => {
+      // Handle error
+      ws.close();
+    });
+  });
+
+  return {
+    app,
+    start: (port = 0) => {
+      return new Promise<number>((resolve) => {
+        httpServer.listen(port, () => {
+          const address = httpServer.address();
+          if (address && typeof address !== 'string' && address.port) {
+            resolve(address.port);
+          } else {
+            resolve(0);
+          }
+        });
+      });
+    },
+    stop: () => {
+      return new Promise<void>((resolve) => {
+        wss.close(() => {
+          httpServer.close(() => {
+            db.close();
+            resolve();
+          });
+        });
+      });
+    }
+  };
+}
