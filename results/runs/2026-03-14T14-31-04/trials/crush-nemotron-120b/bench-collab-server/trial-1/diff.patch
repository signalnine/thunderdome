+import { createApp } from './src/server';
+import request from 'supertest';
+import { WebSocket } from 'ws';
+
+describe('Collaborative Document Server', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+  let wsServerUrl: string;
+
+  beforeAll(async () => {
+    // Create app with in-memory database for testing
+    appInstance = createApp({ dbFile: ':memory:' });
+    port = await appInstance.start();
+    wsServerUrl = `ws://localhost:${port}`;
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  test('should create a document via REST API', async () => {
+    const response = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Test Doc', content: 'Hello world' })
+      .expect(201);
+
+    expect(response.body).toHaveProperty('id');
+    expect(response.body.title).toBe('Test Doc');
+    expect(response.body.content).toBe('Hello world');
+  });
+
+  test('should handle WebSocket real-time collaboration', async () => {
+    // Create a document
+    const createRes = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Collab Doc', content: '' })
+      .expect(201);
+
+    const docId = createRes.body.id;
+    const wsPath = `/ws/${docId}`;
+
+    // Track received messages
+    let ws1InitReceived = false;
+    let ws2InitReceived = false;
+    let ws1OperationReceived = false;
+    let ws2OperationReceived = false;
+    let ws1Operation: any = null;
+    let ws2Operation: any = null;
+
+    // Connect two clients
+    const ws1 = new WebSocket(`${wsServerUrl}${wsPath}`);
+    const ws2 = new WebSocket(`${wsServerUrl}${wsPath}`);
+
+    ws1.on('message', (data) => {
+      console.log('WS1 received message:', data.toString());
+      const message = JSON.parse(data.toString());
+      if (message.type === 'init') {
+        console.log('WS1 received init message');
+        ws1InitReceived = true;
+        expect(message.content).toBe('');
+        expect(message.version).toBe(0);
+      } else if (message.type === 'operation') {
+        console.log('WS1 received operation message');
+        ws1OperationReceived = true;
+        ws1Operation = message;
+      }
+    });
+
+    ws2.on('message', (data) => {
+      console.log('WS2 received message:', data.toString());
+      const message = JSON.parse(data.toString());
+      if (message.type === 'init') {
+        console.log('WS2 received init message');
+        ws2InitReceived = true;
+        expect(message.content).toBe('');
+        expect(message.version).toBe(0);
+      } else if (message.type === 'operation') {
+        console.log('WS2 received operation message');
+        ws2OperationReceived = true;
+        ws2Operation = message;
+      }
+    });
+
+    ws1.on('close', () => console.log('WS1 closed'));
+    ws2.on('close', () => console.log('WS2 closed'));
+    ws1.on('error', (err) => console.log('WS1 error:', err));
+    ws2.on('error', (err) => console.log('WS2 error:', err));
+
+    // Wait for both connections to open
+    await Promise.all([
+      new Promise<void>((resolve, reject) => {
+        ws1.on('open', resolve);
+        ws1.on('error', reject);
+        ws1.on('close', () => reject(new Error('WebSocket closed')));
+      }),
+      new Promise<void>((resolve, reject) => {
+        ws2.on('open', resolve);
+        ws2.on('error', reject);
+        ws2.on('close', () => reject(new Error('WebSocket closed')));
+      })
+    ]);
+
+    // Wait for init messages with timeout
+    await new Promise<void>((resolve, reject) => {
+      const timeout = setTimeout(() => reject(new Error('Timeout waiting for init messages')), 5000);
+      const check = () => {
+        if (ws1InitReceived && ws2InitReceived) {
+          clearTimeout(timeout);
+          resolve();
+        } else {
+          setTimeout(check, 10);
+        }
+      };
+      check();
+    });
+
+    // Client 1 sends an operation: insert 'Hello ' at position 0
+    const op1 = { type: 'insert', position: 0, text: 'Hello ' };
+    ws1.send(JSON.stringify({ type: 'operation', operation: op1, baseVersion: 0 }));
+
+    // Client 2 should receive the operation
+    await new Promise<void>((resolve, reject) => {
+      const timeout = setTimeout(() => reject(new Error('Timeout waiting for operation from client 1')), 5000);
+      const check = () => {
+        if (ws2OperationReceived) {
+          clearTimeout(timeout);
+          resolve();
+        } else {
+          setTimeout(check, 10);
+        }
+      };
+      check();
+    });
+
+    expect(ws2Operation).toEqual({
+      type: 'operation',
+      operation: op1,
+      version: 1
+    });
+
+    // Client 2 sends an operation: insert 'World!' at position 6 (after 'Hello ')
+    const op2 = { type: 'insert', position: 6, text: 'World!' };
+    ws2.send(JSON.stringify({ type: 'operation', operation: op2, baseVersion: 1 }));
+
+    // Client 1 should receive the operation
+    await new Promise<void>((resolve, reject) => {
+      const timeout = setTimeout(() => reject(new Error('Timeout waiting for operation from client 2')), 5000);
+      const check = () => {
+        if (ws1OperationReceived) {
+          clearTimeout(timeout);
+          resolve();
+        } else {
+          setTimeout(check, 10);
+        }
+      };
+      check();
+    });
+
+    expect(ws1Operation).toEqual({
+      type: 'operation',
+      operation: op2,
+      version: 2
+    });
+
+    // Close connections
+    ws1.close();
+    ws2.close();
+
+    // Wait for close with timeout
+    await new Promise<void>((resolve, reject) => {
+      const timeout = setTimeout(() => reject(new Error('Timeout waiting for close')), 5000);
+      let closedCount = 0;
+      const checkClose = () => {
+        closedCount++;
+        if (closedCount >= 2) {
+          clearTimeout(timeout);
+          resolve();
+        }
+      };
+      ws1.on('close', checkClose);
+      ws2.on('close', checkClose);
+    });
+
+    // Verify final state via REST
+    const finalRes = await request(appInstance.app).get(`/documents/${docId}`).expect(200);
+    expect(finalRes.body.content).toBe('Hello World!');
+  });
+});
