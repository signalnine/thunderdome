+import { createApp } from './src/server';
+import request from 'supertest';
+
+describe('Debug Server Startup', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+
+  beforeAll(async () => {
+    // Create app with in-memory database for testing
+    appInstance = createApp({ dbFile: ':memory:' });
+    port = await appInstance.start();
+    console.log(`Server started on port ${port}`);
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+    console.log('Server stopped');
+  });
+
+  test('should start server and respond to HTTP requests', async () => {
+    // Test that the server is running
+    const res = await request(appInstance.app).get('/documents').expect(200);
+    expect(Array.isArray(res.body)).toBe(true);
+  });
+
+  test('should create a document', async () => {
+    const res = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Test', content: 'Content' })
+      .expect(201);
+    
+    expect(res.body).toHaveProperty('id');
+  });
+});
