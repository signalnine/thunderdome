+
+describe('Simple WebSocket Test', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+  let wsServerUrl: string;
+
+  beforeAll(async () => {
+    appInstance = createApp({ dbFile: ':memory:' });
+    port = await appInstance.start();
+    wsServerUrl = `ws://localhost:${port}`;
+    console.log(`WebSocket server URL: ${wsServerUrl}`);
+  });
+
+  afterAll(async () => {
+    await appInstance.stop();
+  });
+
+  test('should create document and test WebSocket connection', async () => {
+    // Create a document via REST
+    const createRes = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Simple Test', content: 'Hello' })
+      .expect(201);
+    
+    const docId = createRes.body.id;
+    console.log(`Created document ID: ${docId}`);
+    
+    // Test WebSocket connection
+    const wsUrl = `${wsServerUrl}/ws/${docId}`;
+    console.log(`Connecting to: ${wsUrl}`);
+    
+    await new Promise<void>((resolve, reject) => {
+      const ws = new WebSocket(wsUrl);
+      
+      ws.on('open', () => {
+        console.log('WebSocket opened successfully');
+        ws.close();
+        resolve();
+      });
+      
+      ws.on('error', (error) => {
+        console.log('WebSocket error:', error);
+        reject(error);
+      });
+      
+      ws.on('close', (code, reason) => {
